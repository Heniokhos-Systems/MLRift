// Qwen3.5 / Qwen3.6 ("qwen35" arch tag — NOT the same as qwen3vl which we
// call "qwen36" internally for historical reasons). Hybrid Gated-DeltaNet
// + full-attention. Shipped variants per llama.cpp HEAD's `qwen35.cpp`:
//
//   block_count = 24,  n_embd = 1024  → Qwen3.5-0.8B   (this slice's target)
//   block_count = 24,  n_embd ≠ 1024  → Qwen3.5-2B
//   block_count = 32,  n_embd = 2560  → Qwen3.5-4B
//   block_count = 32,  other          → Qwen3.5-9B
//   block_count = 64,                 → Qwen3.5-27B
//
// Probe of `/home/pantelis/qwen35-0.8b/Qwen3.5-0.8B-Q8_0.gguf`:
//   embedding_length          = 1024
//   block_count               = 24
//   feed_forward_length       = 3584
//   attention.head_count      = 8        head_count_kv = 2  (GQA 4:1)
//   attention.{key,value}_length = 256   (head_dim — 2× the embed/head ratio
//                                         because Qwen3.5 uses a DOUBLE-WIDTH
//                                         Q+gate fused projection on full-attn
//                                         layers; see "Full-attn layer" below)
//   rope.dimension_count      = 64       (partial RoPE: only first 64 channels
//                                         of head_dim=256 rotate)
//   rope.dimension_sections   = [11, 11, 10, 0]   (text-only IMROPE — 3-axis
//                                                  with sect_extra=0, total =
//                                                  rope_dim/2 = 32)
//   rope.freq_base (f32 bits) = 0x4B189680  (= 1e7)
//   rms_eps        (f32 bits) = 0x358637BD  (= 1e-6)
//   ssm.conv_kernel           = 4
//   ssm.state_size            = 128       (= head_v_dim = head_k_dim)
//   ssm.group_count           = 16        (= n_k_heads)
//   ssm.time_step_rank        = 16        (= n_v_heads)
//   ssm.inner_size            = 2048      (= value_dim = n_v_heads * head_v_dim)
//   full_attention_interval   = 4         (recurrent_layer[i] = ((i+1)%4 != 0))
//   tokenizer.bos             = absent    (no BOS prepended)
//   tokenizer.eos             = 248046
//   vocab                     = 248320
//
// Layer schedule for 24 layers under interval=4:
//   recurrent (GDN): layers  0,1,2,  4,5,6,  8,9,10, 12,13,14, 16,17,18, 20,21,22  (18)
//   full-attn:       layers          3,        7,       11,       15,       19,       23  (6)
//
// ────────────────────────────────────────────────────────────────────
// Full-attn layer (e.g. blk.3) — Qwen3.5 specific Q+gate fused projection
// ────────────────────────────────────────────────────────────────────
// The Q projection is DOUBLE-WIDTH:
//   wq:        [n_embd, n_embd_head_k * n_head * 2]  =  [1024, 4096]
//   wk:        [n_embd, n_embd_k_gqa]                =  [1024, 512]   (= 2 * 256)
//   wv:        [n_embd, n_embd_v_gqa]                =  [1024, 512]
//   wo:        [n_embd_head_k * n_head, n_embd]      =  [2048, 1024]
//   q_norm:    [n_embd_head_k] = [256]
//   k_norm:    [n_embd_head_k] = [256]
//   attn_norm:               [n_embd]   (pre-attention)
//   post_attention_norm:     [n_embd]   (between attn-residual and FFN)
//   ffn_gate / ffn_up:       [n_embd, n_ff]  = [1024, 3584]
//   ffn_down:                [n_ff, n_embd]
//
// Forward (from llama.cpp qwen35.cpp::build_layer_attn):
//   1. cur = build_norm(inpL, attn_norm)                   // RMSNorm pre
//   2. Qcur_full = wq @ cur                                // [4096, 1]
//      Qcur = view(Qcur_full)[:256, :8]   per head        // Q  [256, 8]
//      gate = view(Qcur_full)[256:, :8]   per head        // [256, 8] → flatten
//   3. Qcur = build_norm(Qcur, attn_q_norm)               // per-head Q-norm
//   4. Kcur = wk @ cur  reshape [256, 2]   K-norm per head
//   5. Vcur = wv @ cur  reshape [256, 2]
//   6. Apply MRoPE (rope_multi) with rope_dim=64 partial, sections=[11,11,10,0]
//      to BOTH Q and K.
//   7. attn = softmax(QK^T / sqrt(256)) @ V       shape [2048, 1]
//   8. attn *= sigmoid(gate)                       // OUTPUT GATING (Qwen3-Next)
//   9. cur = wo @ attn                             [1024, 1]
//   Then the standard residual + post_attention_norm + FFN → residual → next layer.
//
// Note: this is NOT the same as plain Qwen3 — the Q+gate fusion plus output
// gating is unique to Qwen3.5/3.6/Next. `qwen3_forward_layer` from the
// existing dense Qwen3 path will not work as-is for these layers. (Slice B
// will implement `qwen35_forward_full_attn_layer`.)
//
// ────────────────────────────────────────────────────────────────────
// GDN layer (e.g. blk.0) — Gated DeltaNet (linear attention + recurrent state)
// ────────────────────────────────────────────────────────────────────
// Tensor inventory:
//   attn_norm:             [n_embd]
//   attn_qkv:              [n_embd, key_dim*2 + value_dim] = [1024, 6144]
//                          where key_dim   = n_k_heads * head_k_dim = 16 * 128 = 2048
//                                value_dim = n_v_heads * head_v_dim = 16 * 128 = 2048
//                                so QKV split = 2048 + 2048 + 2048 = 6144
//   attn_gate:             [n_embd, value_dim] = [1024, 2048]   // post-DN gate (z)
//   ssm_conv1d:            [conv_kernel, conv_dim] = [4, 6144]
//                          conv_dim = key_dim*2 + value_dim = 6144
//   ssm_dt.bias:           [n_v_heads] = [16]
//   ssm_a:                 [n_v_heads] = [16]   (no "weight" suffix — special)
//   ssm_alpha.weight:      [n_embd, n_v_heads] = [1024, 16]
//   ssm_beta.weight:       [n_embd, n_v_heads] = [1024, 16]
//   ssm_norm.weight:       [head_v_dim] = [128]
//   ssm_out.weight:        [value_dim, n_embd] = [2048, 1024]
//   post_attention_norm:   [n_embd]   (shared FFN-pre slot — same as full-attn)
//   ffn_gate / ffn_up / ffn_down — same shapes as full-attn layers
//
// Forward (from llama.cpp qwen35.cpp::build_layer_attn_linear, sources at the
// graph level + the autoregressive 1-token build_delta_net_autoregressive):
//
//   cur = RMSNorm(x, attn_norm)
//
//   // Input projections — produce Q+K+V mixed for conv, plus z for output gate
//   qkv_mixed = wqkv @ cur                       [6144]  // = [Q | K | V] flat
//   z         = wqkv_gate @ cur                  [2048]
//
//   // Beta (recurrence write gate, per v-head)
//   beta = sigmoid(ssm_beta @ cur)               [16]
//
//   // Alpha (recurrence forget gate magnitude)
//   alpha       = ssm_alpha @ cur                [16]
//   alpha_bias  = alpha + ssm_dt                 [16]
//   alpha_sp    = softplus(alpha_bias)           [16]
//   gate_g      = alpha_sp * ssm_a               [16]   // negative because ssm_a < 0
//
//   // 1D causal convolution over the QKV mixed channels with stored conv state.
//   // For autoregressive (1 new token), maintain a sliding window of the last
//   // (conv_kernel - 1) = 3 raw qkv_mixed vectors per channel:
//   //   conv_input[ch, t] = [conv_state[ch, 0..2], qkv_mixed[ch]]   shape [4]
//   //   conv_out[ch]      = sum(conv_input[ch, :] * ssm_conv1d[:, ch])
//   //   conv_state shifts: state[ch, t] = state[ch, t+1] for t in 0..2
//   //   state[ch, 2]      = qkv_mixed[ch]
//   conv_qkv = silu(conv_out)                     [6144]
//
//   // Split conv_qkv into Q, K, V for the linear attention
//   q = conv_qkv[0       : key_dim]                .view([head_k_dim, n_k_heads])
//   k = conv_qkv[key_dim : 2*key_dim]              .view([head_k_dim, n_k_heads])
//   v = conv_qkv[2*key_dim : 2*key_dim+value_dim]  .view([head_v_dim, n_v_heads])
//
//   // L2 normalize Q and K along their head_dim axis.
//   q = q / sqrt(sum(q^2) + eps)         per (k_head)
//   k = k / sqrt(sum(k^2) + eps)         per (k_head)
//
//   // Repeat-broadcast Q,K from n_k_heads=16 to n_v_heads=16 (here 1:1 already,
//   // so this is a no-op for 0.8B; on larger variants where n_v_heads !=
//   // n_k_heads it would replicate).
//
//   // Gated Delta Rule (autoregressive 1-token form, n_tokens == 1):
//   //   scale  = 1 / sqrt(head_k_dim)
//   //   q     *= scale
//   //   g     = exp(gate_g)              [n_v_heads, 1, 1]    // diagonal forget
//   //   s     = s * g                    [head_v_dim, head_v_dim, n_v_heads]
//   //   sk    = sum_rows(s * k)          [head_v_dim, 1, n_v_heads]    // s @ k
//   //   d     = (v - sk^T) * beta        [head_v_dim, 1, n_v_heads]    // delta
//   //   s    += k @ d^T                  [head_v_dim, head_v_dim, n_v_heads]
//   //   o     = sum_rows(s * q)          [head_v_dim, 1, n_v_heads]    // s @ q
//   //
//   // o has shape [head_v_dim, n_v_heads] = [128, 16] = 2048 flat.
//
//   // Apply gated norm: o = RMSNorm(o, ssm_norm) * silu(z_reshaped)
//   //   ssm_norm weight is [head_v_dim] = [128], normalized per (n_v_head).
//   o_normed = rmsnorm_per_vhead(o, ssm_norm)             [2048]
//   o_gated  = o_normed * silu(z)                         [2048]
//
//   // Output projection back to embed dim
//   out = ssm_out @ o_gated                               [1024]
//
//   return out
//
// Recurrent state shapes per GDN layer (allocated once at startup):
//   conv_state:  [conv_kernel - 1, conv_dim]              = [3,   6144]   = 73728 B  (f32)
//   ssm_state:   [head_v_dim, head_v_dim, n_v_heads]      = [128,128,16]  = 1048576 B (f32)
//   total per GDN layer: 1 122 304 B ≈ 1.07 MiB
//   18 GDN layers × 1.07 MiB                               ≈ 19.27 MiB total
//   (matches llama.cpp's "CPU RS buffer size = 19.27 MiB" log line)
//
// ────────────────────────────────────────────────────────────────────
// Status (this slice — Slice A)
// ────────────────────────────────────────────────────────────────────
//   - Header doc captured here (full math sequence above).
//   - Two layer-weight structs scaffolded.
//   - `qwen35_set_arch()` configurator wires the 3-section text-only IMROPE
//     and the GDN sub-arch knobs (conv_kernel, state_size, n_k/v_heads).
//   - GDN forward: STUB (memcpy x_in -> x_out — identity pass-through).
//   - Full-attn forward: STUB (identity pass-through too — Qwen3.5's Q+gate
//     fused projection + output gating doesn't fit the qwen3_forward_layer
//     contract; will be implemented in Slice B).
//   - Driver: examples/qwen35_0_8b_generate.mlr — loads weights, indexes the
//     two layer types, runs a 20-step decode loop. Expected output: garbage
//     (all layers stubbed). Validation goal: NO crashes, decode finishes.
//
// Reference llama.cpp greedy output for prompt "hello" at n=20 is captured in
// memory/project_qwen35_slice_a.md (see "20-token reference" section).

import "qwen3.mlr"

// ─── Arch knobs (separate from QWEN3_*) ───────────────────────────────
// Most knobs are inherited from std/qwen3.mlr's static state (HIDDEN, HEAD_DIM,
// FF, ROPE_DIM, IMROPE sections, etc.). Qwen3.5 adds GDN-specific dims that
// don't exist in the dense path:
static u64 QWEN35_SSM_CONV_K       = 4
static u64 QWEN35_SSM_STATE_SIZE   = 128    // = head_v_dim = head_k_dim
static u64 QWEN35_SSM_N_K_HEADS    = 16     // ssm.group_count
static u64 QWEN35_SSM_N_V_HEADS    = 16     // ssm.time_step_rank (yes, "rank"
                                            // is misnamed — it's the head count)
static u64 QWEN35_SSM_INNER_SIZE   = 2048   // = n_v_heads * head_v_dim
static u64 QWEN35_FULL_ATTN_INTV   = 4      // (i+1)%intv != 0  → GDN; else full-attn

// Setter callable by the driver.
fn qwen35_set_ssm(u64 conv_k, u64 state_sz, u64 n_k_h, u64 n_v_h, u64 inner_sz, u64 full_attn_intv) {
    QWEN35_SSM_CONV_K     = conv_k
    QWEN35_SSM_STATE_SIZE = state_sz
    QWEN35_SSM_N_K_HEADS  = n_k_h
    QWEN35_SSM_N_V_HEADS  = n_v_h
    QWEN35_SSM_INNER_SIZE = inner_sz
    QWEN35_FULL_ATTN_INTV = full_attn_intv
}

// One-shot configurator. Wires the dense qwen3 dispatcher AND the qwen3-VL
// IMROPE plumbing AND the GDN-specific dims, all in one call.
//
// `rope_dim`     = partial-RoPE channel count (e.g. 64 for the 0.8B). This is
//                  passed straight to qwen3_set_imrope_rope_dim and matches
//                  the gguf `qwen35.rope.dimension_count` key.
// `sect_t/h/w/extra` come from `qwen35.rope.dimension_sections`. For
//                  text-only inference, sect_extra is generally 0.
fn qwen35_set_arch(u64 hidden, u64 head_dim, u64 n_heads, u64 n_kv_heads,
                   u64 ff, u64 rope_dim, u64 rope_base,
                   u64 sect_t, u64 sect_h, u64 sect_w, u64 sect_extra,
                   u64 ssm_conv_k, u64 ssm_state_sz, u64 ssm_n_k_h, u64 ssm_n_v_h,
                   u64 ssm_inner, u64 full_attn_intv) {
    qwen3_set_arch(hidden, head_dim, n_heads, n_kv_heads, ff)
    qwen3_set_qknorm(1)
    qwen3_set_rope_base(rope_base)
    qwen3_set_use_imrope(1)
    qwen3_set_imrope_rope_dim(rope_dim)
    qwen3_set_imrope_sections(sect_t, sect_h, sect_w, sect_extra)
    qwen35_set_ssm(ssm_conv_k, ssm_state_sz, ssm_n_k_h, ssm_n_v_h, ssm_inner, full_attn_intv)
}

// `is_recurrent` predicate matching llama.cpp:
//   recurrent_layer_arr[i] = ((i + 1) % full_attn_interval != 0)
// i.e. the LAST layer of every interval window is full-attn.
fn qwen35_is_gdn_layer(u64 layer_idx) -> u64 {
    u64 m = (layer_idx + 1) % QWEN35_FULL_ATTN_INTV
    if m != 0 { return 1 }
    return 0
}

// ─── Layer weight structs (two variants) ─────────────────────────────
//
// Padded to 16 u64 slots = 128 B each so we can use the same stride for both
// kinds; we pick which fields to populate based on `is_gdn`. Zero-init unused
// slots so accidental reads on the wrong-kind layer trap as nullptr derefs.
//
// Index conventions (must stay in sync with the driver's pointer table loader):
//
//   FULL-ATTN layer:
//     [0]  attn_norm.weight                  (= input_norm)
//     [1]  attn_q.weight        (Q+gate fused, [n_embd, head_dim*n_head*2])
//     [2]  attn_k.weight
//     [3]  attn_v.weight
//     [4]  attn_q_norm.weight
//     [5]  attn_k_norm.weight
//     [6]  attn_output.weight
//     [7]  post_attention_norm.weight        (= post_norm)
//     [8]  ffn_gate.weight
//     [9]  ffn_up.weight
//    [10]  ffn_down.weight
//    [11..15] unused (zero)
//
//   GDN layer:
//     [0]  attn_norm.weight                  (= input_norm)
//     [1]  attn_qkv.weight    (fused Q|K|V, [n_embd, key_dim*2 + value_dim])
//     [2]  attn_gate.weight                  (z)
//     [3]  ssm_conv1d.weight
//     [4]  ssm_dt.bias                       (alpha bias before softplus)
//     [5]  ssm_a                             (per-v-head log-decay scale)
//     [6]  ssm_alpha.weight
//     [7]  ssm_beta.weight
//     [8]  ssm_norm.weight                   (per-v-head RMSNorm before output)
//     [9]  ssm_out.weight
//    [10]  post_attention_norm.weight        (= post_norm)
//    [11]  ffn_gate.weight
//    [12]  ffn_up.weight
//    [13]  ffn_down.weight
//    [14..15] unused (zero)
//
// We could split this into two structs and a tagged union; for the scaffold
// stage one fat struct is simpler. Stretch goal in a future slice: lift the
// shared norms (attn_norm, post_attention_norm, ffn_*) into a base struct.

struct Qwen35LayerWeights {
    u64 slot00     // attn_norm                    (BOTH)
    u64 slot01     // FULL: attn_q     | GDN: attn_qkv
    u64 slot02     // FULL: attn_k     | GDN: attn_gate
    u64 slot03     // FULL: attn_v     | GDN: ssm_conv1d
    u64 slot04     // FULL: attn_q_norm| GDN: ssm_dt.bias
    u64 slot05     // FULL: attn_k_norm| GDN: ssm_a
    u64 slot06     // FULL: attn_output| GDN: ssm_alpha
    u64 slot07     // FULL: post_attn_norm | GDN: ssm_beta
    u64 slot08     // FULL: ffn_gate   | GDN: ssm_norm
    u64 slot09     // FULL: ffn_up     | GDN: ssm_out
    u64 slot10     // FULL: ffn_down   | GDN: post_attn_norm
    u64 slot11     // FULL: --         | GDN: ffn_gate
    u64 slot12     // FULL: --         | GDN: ffn_up
    u64 slot13     // FULL: --         | GDN: ffn_down
    u64 slot14     // unused
    u64 slot15     // unused
}

// ─── Recurrent state (per GDN layer) ─────────────────────────────────
//
// Layout in a single contiguous block per layer for cache friendliness:
//   conv_state:  3 * conv_dim  f32  = 3 * 6144 * 4 = 73 728 B
//   ssm_state:   head_v * head_v * n_v_heads f32 = 128*128*16*4 = 1 048 576 B
// Total per GDN layer: 1 122 304 B  (matches llama.cpp's "RS buffer = 19.27 MiB"
// across 18 GDN layers).
//
// Driver allocates the full block; this helper computes the size.
fn qwen35_gdn_state_bytes() -> u64 {
    u64 conv_dim = QWEN35_SSM_N_K_HEADS * QWEN35_SSM_STATE_SIZE * 2 + QWEN35_SSM_INNER_SIZE
    u64 conv_bytes = (QWEN35_SSM_CONV_K - 1) * conv_dim * 4
    u64 ssm_bytes = QWEN35_SSM_STATE_SIZE * QWEN35_SSM_STATE_SIZE * QWEN35_SSM_N_V_HEADS * 4
    return conv_bytes + ssm_bytes
}

// ─── GDN forward (STUB — Slice A) ────────────────────────────────────
//
// TODO Slice B+: implement the full gated delta rule (math captured in the
// header comment above). For now we identity-pass: x_out := x_in.
//
// `state` is a pointer to this layer's recurrent-state block (size given by
// `qwen35_gdn_state_bytes`). It MAY be 0 in the stub path since we don't
// touch it; downstream slices will read/write it.
fn qwen35_gdn_forward_layer_stub(u64 x_out, u64 x_in, Qwen35LayerWeights w, u64 pos, u64 state) {
    // Suppress "unused" warnings on the in-progress fields.
    u64 _w00 = w.slot00
    u64 _w01 = w.slot01
    u64 _p   = pos
    u64 _s   = state
    u64 hidden = QWEN3_HIDDEN
    memcpy(x_out, x_in, hidden * 4)
}

// ─── Sigmoid (in-place) ──────────────────────────────────────────────
//
// y = 1 / (1 + exp(-x)). Used to gate the post-attention output by `gate`
// (the second half of the fused Q+gate projection — Qwen3.5/Next specific).
// Reuses `exp_f32_fast` from std/qwen3.mlr.
fn qwen35_sigmoid_inplace_f32(u64 x_ptr, u64 n) {
    u64 i = 0
    f32 one = 1.0f
    while i < n {
        f32 v = 0.0f
        unsafe { *((x_ptr + i * 4) as f32) -> v }
        f32 e = exp_f32_fast(0.0f - v)
        f32 y = one / (one + e)
        unsafe { *((x_ptr + i * 4) as f32) = y }
        i = i + 1
    }
}

// ─── Full-attn forward (Slice B) ─────────────────────────────────────
//
// Qwen3.5/Next full-attention layer with fused Q+gate projection +
// per-head QK-norm + MRoPE + GQA SDPA + output gating + wo + residual +
// post_attn_norm + SwiGLU FFN + residual.
//
// Differences from base qwen3_forward_layer (why we cannot reuse it):
//   * wq is DOUBLE-WIDTH (head_dim*n_head*2 = 4096 floats) — outputs Q AND
//     gate fused. Per-head layout: [Q_h(256), gate_h(256), Q_h+1(256), ...].
//   * After SDPA: attn *= sigmoid(gate) elementwise, BEFORE wo.
//
// Q_full memory layout per token (matches llama.cpp's ggml_view_3d args):
//   stride between heads = head_dim * 2 floats (Q+gate per head)
//   so Q for head h: Q_full[h * head_dim * 2 + 0 .. h * head_dim * 2 + head_dim]
//      gate for head h: Q_full[h * head_dim * 2 + head_dim .. h * head_dim * 2 + head_dim*2]
//
// Slot mapping (FULL-ATTN, see Qwen35LayerWeights doc above):
//   [0]  attn_norm           [1]  attn_q (Q+gate fused, [hidden, head_dim*n_head*2])
//   [2]  attn_k              [3]  attn_v
//   [4]  attn_q_norm         [5]  attn_k_norm
//   [6]  attn_output         [7]  post_attention_norm
//   [8]  ffn_gate            [9]  ffn_up               [10] ffn_down
fn qwen35_fullattn_forward_layer(u64 x_out, u64 x_in, Qwen35LayerWeights w,
                                 u64 pos, u64 k_cache_layer, u64 v_cache_layer,
                                 u64 num_workers) {
    u64 hidden = QWEN3_HIDDEN
    u64 hd     = QWEN3_HEAD_DIM
    u64 nh     = QWEN3_N_HEADS
    u64 nkv    = QWEN3_N_KV_HEADS
    u64 q_dim  = QWEN3_Q_DIM           // = nh  * hd
    u64 kv_dim = QWEN3_KV_DIM          // = nkv * hd
    u64 ff     = QWEN3_INTERMEDIATE
    u64 qg_dim = q_dim * 2              // fused Q+gate output width

    u64 input_norm_w = w.slot00
    u64 wq           = w.slot01         // [hidden, qg_dim]
    u64 wk           = w.slot02         // [hidden, kv_dim]
    u64 wv           = w.slot03         // [hidden, kv_dim]
    u64 q_norm_w     = w.slot04         // [hd]
    u64 k_norm_w     = w.slot05         // [hd]
    u64 wo           = w.slot06         // [q_dim, hidden]
    u64 post_norm_w  = w.slot07
    u64 wg           = w.slot08         // ffn_gate [hidden, ff]
    u64 wu           = w.slot09         // ffn_up   [hidden, ff]
    u64 wd           = w.slot10         // ffn_down [ff, hidden]

    u64 kv_row_bytes = kv_dim * 4
    u64 k_row = k_cache_layer + pos * kv_row_bytes
    u64 v_row = v_cache_layer + pos * kv_row_bytes

    // Save residual for post-attention add.
    u64 resid = alloc(hidden * 4)
    memcpy(resid, x_in, hidden * 4)

    // 1. Pre-attention RMSNorm.
    u64 x_norm = alloc(hidden * 4)
    qwen3_main_rmsnorm(x_norm, x_in, input_norm_w, hidden)

    // 2. Fused Q+gate projection: qg_full = wq @ x_norm  (shape [qg_dim]).
    u64 qg_full  = alloc(qg_dim * 4)
    qwen3_main_matmul(qg_full, x_norm, wq, 1, qg_dim, hidden, num_workers, 0)

    // Split per head: Q into q_buf (q_dim), gate into gate_buf (q_dim).
    u64 q_buf    = alloc(q_dim * 4)
    u64 gate_buf = alloc(q_dim * 4)
    u64 hh = 0
    while hh < nh {
        u64 src_base = qg_full + hh * (hd * 2) * 4
        u64 q_dst    = q_buf    + hh * hd * 4
        u64 gate_dst = gate_buf + hh * hd * 4
        memcpy(q_dst,    src_base,           hd * 4)
        memcpy(gate_dst, src_base + hd * 4,  hd * 4)
        hh = hh + 1
    }
    dealloc(qg_full)

    // 3. K, V projections — write straight into the cache row at `pos`.
    qwen3_main_matmul(k_row, x_norm, wk, 1, kv_dim, hidden, num_workers, 0)
    qwen3_main_matmul(v_row, x_norm, wv, 1, kv_dim, hidden, num_workers, 0)

    // 4. Per-head Q-RMSNorm + per-kv-head K-RMSNorm (weights are F32 [hd]).
    u64 h2 = 0
    while h2 < nh {
        u64 q_slice = q_buf + h2 * hd * 4
        qwen3_rmsnorm_f32_weights(q_slice, q_slice, q_norm_w, hd)
        h2 = h2 + 1
    }
    h2 = 0
    while h2 < nkv {
        u64 k_slice = k_row + h2 * hd * 4
        qwen3_rmsnorm_f32_weights(k_slice, k_slice, k_norm_w, hd)
        h2 = h2 + 1
    }

    // 5. MRoPE on Q and K (partial — first qwen3_imrope_rope_dim of head_dim).
    //    Reuses the cos/sin cache populated by std/qwen3.mlr's helpers.
    if qwen3_rope_cos_cache == 0 {
        qwen3_rope_cos_cache = alloc((hd / 2) * 4)
        qwen3_rope_sin_cache = alloc((hd / 2) * 4)
    }
    if qwen3_rope_cache_pos != pos {
        f64 theta = int_to_f64(qwen3_rope_theta_int)
        if qwen3_use_imrope != 0 {
            qwen3_rope_compute_imrope_text(qwen3_rope_cos_cache, qwen3_rope_sin_cache, pos, qwen3_imrope_rope_dim, theta)
        } else {
            qwen3_rope_compute(qwen3_rope_cos_cache, qwen3_rope_sin_cache, pos, hd, theta)
        }
        qwen3_rope_cache_pos = pos
    }
    if qwen3_use_imrope != 0 {
        qwen3_rope_apply_partial(q_buf, qwen3_rope_cos_cache, qwen3_rope_sin_cache, nh,  hd, qwen3_imrope_rope_dim)
        qwen3_rope_apply_partial(k_row, qwen3_rope_cos_cache, qwen3_rope_sin_cache, nkv, hd, qwen3_imrope_rope_dim)
    } else {
        qwen3_rope_apply(q_buf, qwen3_rope_cos_cache, qwen3_rope_sin_cache, nh,  hd)
        qwen3_rope_apply(k_row, qwen3_rope_cos_cache, qwen3_rope_sin_cache, nkv, hd)
    }

    // 6. Cached SDPA over positions 0..pos. head_dim=256 — qwen3_attn_cached
    //    uses qwen3_dot_avx2 which requires n % 8 == 0 (256 satisfies).
    u64 attn_out = alloc(q_dim * 4)
    qwen3_attn_cached(attn_out, q_buf,
                      k_cache_layer, v_cache_layer,
                      pos + 1, nh, nkv, hd)

    // 7. Output gating: attn_out *= sigmoid(gate_buf) elementwise.
    qwen35_sigmoid_inplace_f32(gate_buf, q_dim)
    u64 ig = 0
    while ig < q_dim {
        f32 a = 0.0f
        f32 g = 0.0f
        unsafe { *((attn_out + ig * 4) as f32) -> a }
        unsafe { *((gate_buf + ig * 4) as f32) -> g }
        unsafe { *((attn_out + ig * 4) as f32) = a * g }
        ig = ig + 1
    }

    // 8. Output projection: o = wo @ gated_attn  (shape [hidden]).
    u64 o_buf = alloc(hidden * 4)
    qwen3_main_matmul(o_buf, attn_out, wo, 1, hidden, q_dim, num_workers, 0)

    // 9. First residual: mid = resid + o_buf.
    u64 mid = alloc(hidden * 4)
    u64 ri = 0
    while ri < hidden {
        f32 a = 0.0f
        f32 b = 0.0f
        unsafe { *((resid + ri * 4) as f32) -> a }
        unsafe { *((o_buf + ri * 4) as f32) -> b }
        f32 y = a + b
        unsafe { *((mid + ri * 4) as f32) = y }
        ri = ri + 1
    }

    // 10. Post-attention RMSNorm + SwiGLU FFN + second residual.
    u64 mid_norm = alloc(hidden * 4)
    qwen3_main_rmsnorm(mid_norm, mid, post_norm_w, hidden)

    u64 gate_ffn = alloc(ff * 4)
    u64 up_ffn   = alloc(ff * 4)
    qwen3_main_matmul(gate_ffn, mid_norm, wg, 1, ff, hidden, num_workers, 0)
    qwen3_main_matmul(up_ffn,   mid_norm, wu, 1, ff, hidden, num_workers, 0)

    u64 ff_buf = alloc(ff * 4)
    qwen3_silu_mul(ff_buf, gate_ffn, up_ffn, ff)

    u64 ff_out = alloc(hidden * 4)
    qwen3_main_matmul(ff_out, ff_buf, wd, 1, hidden, ff, num_workers, 0)

    u64 fi = 0
    while fi < hidden {
        f32 a = 0.0f
        f32 b = 0.0f
        unsafe { *((mid + fi * 4) as f32) -> a }
        unsafe { *((ff_out + fi * 4) as f32) -> b }
        f32 y = a + b
        unsafe { *((x_out + fi * 4) as f32) = y }
        fi = fi + 1
    }

    dealloc(resid); dealloc(x_norm)
    dealloc(q_buf); dealloc(gate_buf)
    dealloc(attn_out); dealloc(o_buf)
    dealloc(mid); dealloc(mid_norm)
    dealloc(gate_ffn); dealloc(up_ffn); dealloc(ff_buf); dealloc(ff_out)
}

// Single dispatch entry — driver calls this for every layer regardless of
// kind; it consults `qwen35_is_gdn_layer` and routes.
//
// `num_workers` is needed by the full-attn matmuls; the GDN path ignores it
// for now (still stubbed; will be wired up in Slice C+D).
fn qwen35_forward_layer(u64 x_out, u64 x_in, Qwen35LayerWeights w, u64 layer_idx,
                        u64 pos, u64 k_cache_layer, u64 v_cache_layer,
                        u64 gdn_state, u64 num_workers) {
    u64 is_gdn = qwen35_is_gdn_layer(layer_idx)
    if is_gdn != 0 {
        qwen35_gdn_forward_layer_stub(x_out, x_in, w, pos, gdn_state)
    } else {
        qwen35_fullattn_forward_layer(x_out, x_in, w, pos,
                                      k_cache_layer, v_cache_layer, num_workers)
    }
}
