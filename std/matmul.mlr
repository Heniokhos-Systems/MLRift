// MLRift Standard Library — Matmul primitives
//
// Single entry point for the hot path of every transformer: multi-thread
// out[1 × N] = x[1 × K] · Wᵀ where `W` is stored row-major [N × K] in
// BF16 (HuggingFace convention). Activations and output stay f32.
//
// Extracted out of std/inference.mlr so the matmul kernel can grow
// independent of the BF16 decode helpers (AVX2 paths land next). Also
// lifts three cross-cutting fixes out of per-call land:
//
//   * Persistent thread-pool contexts — one alloc at first use, reused
//     forever. The old per-call alloc(48) was ~1 800 mmap round-trips
//     per 20-token decode at Qwen3-0.6B scale and showed up as 30 %+
//     kernel time in /usr/bin/time -v.
//
//   * Persistent per-worker BF16-decode scratch — one 64-byte cache
//     line per worker, reused forever. Removes one alloc per worker
//     per matmul call.
//
//   * Kahan-on / Kahan-off flag — the residual-stream matmuls (o_proj,
//     down_proj) compound drift across 28 layers; the rest (Q, K, V,
//     gate, up, lm_head) are fine with a naive accumulator. Callers
//     opt in per-call.
//
// The BF16 decode is still the per-element `store8 + store8 + unsafe
// load` trick — an AVX2 vpmovzxwd+vpslld kernel is next, but it drops
// in behind this interface without touching callers.

import "thread.mlr"
import "gguf.mlr"
import "math_float.mlr"

// ---------------------------------------------------------------------------
// Per-worker ctx slot layout (64 bytes — one cache line, no false sharing):
//   [ 0] out_ptr         [ 8] x_ptr          [16] w_ptr
//   [24] M               [32] N              [40] K
//   [48] scratch_ptr     [56] reserved
// Workers read slots 0..40 (shared across workers in a given matmul
// call) and slots 48..55 (their own BF16 decode scratch). Slots 56..63
// are padding to keep 64-byte alignment.
// ---------------------------------------------------------------------------
static u64 mm_ctx_base    = 0
static u64 mm_max_workers = 0

fn mm_init(u64 num_workers) {
    if mm_ctx_base != 0 {
        if num_workers <= mm_max_workers { return }
        dealloc(mm_ctx_base)
    }
    // 64 bytes of ctx + 4 bytes of BF16 scratch per worker. We pack the
    // scratch pointer INTO the ctx (slot [48]) so the worker only needs
    // one pointer load to find everything it owns. Scratch itself sits
    // right after the ctx block.
    u64 ctx_sz  = num_workers * 64
    u64 scr_sz  = num_workers * 64       // 64-byte stride avoids false sharing
    u64 total   = ctx_sz + scr_sz
    mm_ctx_base = alloc(total)
    u64 scr_base = mm_ctx_base + ctx_sz

    // Zero-seed scratch slots (BF16 decode only writes bytes 2..3 of
    // each slot; bytes 0..1 must stay 0) and stash each worker's scratch
    // pointer in its ctx slot.
    u64 i = 0
    while i < num_workers {
        u64 ctx_i = mm_ctx_base + i * 64
        u64 scr_i = scr_base + i * 64
        u64 p48 = ctx_i + 48
        unsafe { *(p48 as u64) = scr_i }
        // Zero the 4 scratch bytes (the entire 64-byte cache line is
        // fresh from alloc(), but be explicit — cheap).
        u8 zero = 0
        store8(scr_i + 0, zero)
        store8(scr_i + 1, zero)
        store8(scr_i + 2, zero)
        store8(scr_i + 3, zero)
        i = i + 1
    }
    mm_max_workers = num_workers
}

fn mm_shutdown() {
    if mm_ctx_base != 0 {
        dealloc(mm_ctx_base)
        mm_ctx_base = 0
        mm_max_workers = 0
    }
}

// ---------------------------------------------------------------------------
// BF16-weight matmul workers — one with Kahan compensation, one naive.
// Same loop body except for how the running sum is updated.
// ---------------------------------------------------------------------------

fn mm_worker_bf16_f32_kahan(u64 start_n, u64 end_n, u64 ctx_ptr) {
    u64 out_ptr = 0
    unsafe { *(ctx_ptr as u64) -> out_ptr }
    u64 x_ptr = 0
    unsafe { *((ctx_ptr + 8) as u64) -> x_ptr }
    u64 w_ptr = 0
    unsafe { *((ctx_ptr + 16) as u64) -> w_ptr }
    u64 M = 0
    unsafe { *((ctx_ptr + 24) as u64) -> M }
    u64 N = 0
    unsafe { *((ctx_ptr + 32) as u64) -> N }
    u64 K = 0
    unsafe { *((ctx_ptr + 40) as u64) -> K }
    u64 scratch = 0
    unsafe { *((ctx_ptr + 48) as u64) -> scratch }

    u64 m = 0
    while m < M {
        u64 n = start_n
        while n < end_n {
            f32 sum = 0.0f
            f32 c   = 0.0f
            u64 k = 0
            while k < K {
                f32 xv = 0.0f
                unsafe { *((x_ptr + (m * K + k) * 4) as f32) -> xv }
                u64 w_off = (n * K + k) * 2
                u8 b0u = load8(w_ptr + w_off)
                u8 b1u = load8(w_ptr + w_off + 1)
                store8(scratch + 2, b0u)
                store8(scratch + 3, b1u)
                f32 wv = 0.0f
                unsafe { *(scratch as f32) -> wv }
                f32 prod = xv * wv
                f32 y = prod - c
                f32 t = sum + y
                c = (t - sum) - y
                sum = t
                k = k + 1
            }
            unsafe { *((out_ptr + (m * N + n) * 4) as f32) = sum }
            n = n + 1
        }
        m = m + 1
    }
}

fn mm_worker_bf16_f32_naive(u64 start_n, u64 end_n, u64 ctx_ptr) {
    u64 out_ptr = 0
    unsafe { *(ctx_ptr as u64) -> out_ptr }
    u64 x_ptr = 0
    unsafe { *((ctx_ptr + 8) as u64) -> x_ptr }
    u64 w_ptr = 0
    unsafe { *((ctx_ptr + 16) as u64) -> w_ptr }
    u64 M = 0
    unsafe { *((ctx_ptr + 24) as u64) -> M }
    u64 N = 0
    unsafe { *((ctx_ptr + 32) as u64) -> N }
    u64 K = 0
    unsafe { *((ctx_ptr + 40) as u64) -> K }
    u64 scratch = 0
    unsafe { *((ctx_ptr + 48) as u64) -> scratch }

    u64 m = 0
    while m < M {
        u64 n = start_n
        while n < end_n {
            f32 sum = 0.0f
            u64 k = 0
            while k < K {
                f32 xv = 0.0f
                unsafe { *((x_ptr + (m * K + k) * 4) as f32) -> xv }
                u64 w_off = (n * K + k) * 2
                u8 b0u = load8(w_ptr + w_off)
                u8 b1u = load8(w_ptr + w_off + 1)
                store8(scratch + 2, b0u)
                store8(scratch + 3, b1u)
                f32 wv = 0.0f
                unsafe { *(scratch as f32) -> wv }
                sum = sum + xv * wv
                k = k + 1
            }
            unsafe { *((out_ptr + (m * N + n) * 4) as f32) = sum }
            n = n + 1
        }
        m = m + 1
    }
}

// AVX2 BF16×F32 inner loop. Same output as mm_worker_bf16_f32_naive but
// the K loop runs 8 elements per iteration using an ymm accumulator.
//
// BF16-to-F32 decode in vector: load 8 bf16 into an xmm register,
// vpmovzxwd widens to 8×u32 in ymm, vpslld by 16 aligns the bf16 payload
// into the f32 high bits — reinterpretation then gives a valid f32 lane.
//
// K must be a multiple of 8. That's fine for Qwen3 (K ∈ {1024, 3072}).
// The entry dispatcher falls back to the scalar worker for non-multiples.
// Same as mm_worker_bf16_f32_avx2_naive but processes TWO output columns
// per outer iteration, each with its own 8-wide accumulator (ymm0,
// ymm3). The FMAs into the two accumulators are independent, so the
// CPU can keep both FMA ports busy instead of serializing on a single
// dependency chain. On Zen 4 with FMA latency 4 / throughput 2, this
// roughly doubles the effective GFLOP/s when it's the bottleneck.
//
// Requires an even (end_n - start_n); the dispatcher sends an odd tail
// column through the 1-wide worker.
fn mm_worker_bf16_f32_avx2_naive_2w(u64 start_n, u64 end_n, u64 ctx_ptr) {
    u64 out_ptr = 0
    unsafe { *(ctx_ptr as u64) -> out_ptr }
    u64 x_ptr = 0
    unsafe { *((ctx_ptr + 8) as u64) -> x_ptr }
    u64 w_ptr = 0
    unsafe { *((ctx_ptr + 16) as u64) -> w_ptr }
    u64 M = 0
    unsafe { *((ctx_ptr + 24) as u64) -> M }
    u64 N = 0
    unsafe { *((ctx_ptr + 32) as u64) -> N }
    u64 K = 0
    unsafe { *((ctx_ptr + 40) as u64) -> K }

    u64 m = 0
    while m < M {
        u64 x_row = x_ptr + m * K * 4
        u64 o_row = out_ptr + m * N * 4
        u64 n = start_n
        while n + 1 < end_n {
            u64 w_row1 = w_ptr + n * K * 2
            u64 w_row2 = w_row1 + K * 2
            u64 out_slot = o_row + n * 4
            asm {
                // vxorps ymm0, ymm0, ymm0       ; acc1 = 0
                "0xC5 0xFC 0x57 0xC0"
                // vxorps ymm3, ymm3, ymm3       ; acc2 = 0
                "0xC5 0xE4 0x57 0xDB"
                // xor rax, rax
                "0x48 0x31 0xC0"
                // .loop: cmp rax, rdx            ; (3)
                "0x48 0x39 0xD0"
                // jge +52 (past body to reduce)  ; rel8 = 0x34
                "0x7D 0x34"
                // vmovups ymm1, [rsi + rax*4]    ; (5) x shared
                "0xC5 0xFC 0x10 0x0C 0x86"
                // vmovdqu xmm2, [rdi + rax*2]    ; (5) col1 weights
                "0xC5 0xFA 0x6F 0x14 0x47"
                // vpmovzxwd ymm2, xmm2           ; (5)
                "0xC4 0xE2 0x7D 0x33 0xD2"
                // vpslld ymm2, ymm2, 16          ; (5)
                "0xC5 0xED 0x72 0xF2 0x10"
                // vfmadd231ps ymm0, ymm1, ymm2   ; (5) acc1 += x*w1
                "0xC4 0xE2 0x75 0xB8 0xC2"
                // vmovdqu xmm2, [r8 + rax*2]     ; (6) col2 weights (r8 base)
                "0xC4 0xC1 0x7A 0x6F 0x14 0x40"
                // vpmovzxwd ymm2, xmm2           ; (5)
                "0xC4 0xE2 0x7D 0x33 0xD2"
                // vpslld ymm2, ymm2, 16          ; (5)
                "0xC5 0xED 0x72 0xF2 0x10"
                // vfmadd231ps ymm3, ymm1, ymm2   ; (5) acc2 += x*w2
                "0xC4 0xE2 0x75 0xB8 0xDA"
                // add rax, 8                     ; (4)
                "0x48 0x83 0xC0 0x08"
                // jmp .loop                       ; rel8 = -57 = 0xC7
                "0xEB 0xC7"
                // .done: horizontal reduce ymm0 → xmm0[0]
                // vextractf128 xmm1, ymm0, 1     ; (6)
                "0xC4 0xE3 0x7D 0x19 0xC1 0x01"
                // vaddps xmm0, xmm0, xmm1        ; (4)
                "0xC5 0xF8 0x58 0xC1"
                // vhaddps xmm0, xmm0, xmm0       ; (4)
                "0xC5 0xFB 0x7C 0xC0"
                // vhaddps xmm0, xmm0, xmm0       ; (4)
                "0xC5 0xFB 0x7C 0xC0"
                // vmovss [rcx], xmm0             ; (4) store col1 scalar
                "0xC5 0xFA 0x11 0x01"
                // Reduce ymm3 → xmm3[0]
                // vextractf128 xmm1, ymm3, 1     ; (6)
                "0xC4 0xE3 0x7D 0x19 0xD9 0x01"
                // vaddps xmm3, xmm3, xmm1        ; (4)
                "0xC5 0xE0 0x58 0xD9"
                // vhaddps xmm3, xmm3, xmm3       ; (4)
                "0xC5 0xE3 0x7C 0xDB"
                // vhaddps xmm3, xmm3, xmm3       ; (4)
                "0xC5 0xE3 0x7C 0xDB"
                // vmovss [rcx+4], xmm3           ; (5) store col2 scalar
                "0xC5 0xFA 0x11 0x59 0x04"
                // vzeroupper                     ; (3)
                "0xC5 0xF8 0x77"
            } in(x_row -> rsi, w_row1 -> rdi, w_row2 -> r8, K -> rdx, out_slot -> rcx) clobbers(rax)
            n = n + 2
        }
        // Odd tail column — reuse the 1-wide path inline so the caller
        // doesn't need to orchestrate it.
        if n < end_n {
            u64 w_row = w_ptr + n * K * 2
            u64 out_slot = o_row + n * 4
            asm {
                "0xC5 0xFC 0x57 0xC0"
                "0x48 0x31 0xC0"
                "0x48 0x39 0xD0"
                "0x7D 0x1F"
                "0xC5 0xFC 0x10 0x0C 0x86"
                "0xC5 0xFA 0x6F 0x14 0x47"
                "0xC4 0xE2 0x7D 0x33 0xD2"
                "0xC5 0xED 0x72 0xF2 0x10"
                "0xC4 0xE2 0x75 0xB8 0xC2"
                "0x48 0x83 0xC0 0x08"
                "0xEB 0xDC"
                "0xC4 0xE3 0x7D 0x19 0xC1 0x01"
                "0xC5 0xF8 0x58 0xC1"
                "0xC5 0xFB 0x7C 0xC0"
                "0xC5 0xFB 0x7C 0xC0"
                "0xC5 0xFA 0x11 0x01"
                "0xC5 0xF8 0x77"
            } in(x_row -> rsi, w_row -> rdi, K -> rdx, out_slot -> rcx) clobbers(rax)
        }
        m = m + 1
    }
}

fn mm_worker_bf16_f32_avx2_naive(u64 start_n, u64 end_n, u64 ctx_ptr) {
    u64 out_ptr = 0
    unsafe { *(ctx_ptr as u64) -> out_ptr }
    u64 x_ptr = 0
    unsafe { *((ctx_ptr + 8) as u64) -> x_ptr }
    u64 w_ptr = 0
    unsafe { *((ctx_ptr + 16) as u64) -> w_ptr }
    u64 M = 0
    unsafe { *((ctx_ptr + 24) as u64) -> M }
    u64 N = 0
    unsafe { *((ctx_ptr + 32) as u64) -> N }
    u64 K = 0
    unsafe { *((ctx_ptr + 40) as u64) -> K }

    u64 m = 0
    while m < M {
        u64 x_row = x_ptr + m * K * 4
        u64 o_row = out_ptr + m * N * 4
        u64 n = start_n
        while n < end_n {
            u64 w_row = w_ptr + n * K * 2
            u64 out_slot = o_row + n * 4
            asm {
                // vxorps ymm0, ymm0, ymm0       ; accumulator = 0
                "0xC5 0xFC 0x57 0xC0"
                // xor rax, rax                   ; k = 0
                "0x48 0x31 0xC0"
                // .loop: cmp rax, rdx            ; 3 bytes
                "0x48 0x39 0xD0"
                // jge +31 (past loop body to reduce block)
                "0x7D 0x1F"
                // vmovups ymm1, [rsi + rax*4]    ; 8 f32 activations
                "0xC5 0xFC 0x10 0x0C 0x86"
                // vmovdqu xmm2, [rdi + rax*2]    ; 8 bf16 weights (16 bytes)
                "0xC5 0xFA 0x6F 0x14 0x47"
                // vpmovzxwd ymm2, xmm2           ; widen 8 u16 → 8 u32
                "0xC4 0xE2 0x7D 0x33 0xD2"
                // vpslld ymm2, ymm2, 16          ; bf16 bits → upper 16 of f32
                "0xC5 0xED 0x72 0xF2 0x10"
                // vfmadd231ps ymm0, ymm1, ymm2   ; acc += x * w
                "0xC4 0xE2 0x75 0xB8 0xC2"
                // add rax, 8
                "0x48 0x83 0xC0 0x08"
                // jmp .loop  (-36 = back to cmp)
                "0xEB 0xDC"
                // .done: horizontal reduce ymm0 → scalar
                // vextractf128 xmm1, ymm0, 1
                "0xC4 0xE3 0x7D 0x19 0xC1 0x01"
                // vaddps xmm0, xmm0, xmm1
                "0xC5 0xF8 0x58 0xC1"
                // vhaddps xmm0, xmm0, xmm0
                "0xC5 0xFB 0x7C 0xC0"
                // vhaddps xmm0, xmm0, xmm0       ; xmm0[0] = sum of all 8 lanes
                "0xC5 0xFB 0x7C 0xC0"
                // vmovss [rcx], xmm0             ; store scalar f32 output
                "0xC5 0xFA 0x11 0x01"
                // vzeroupper                     ; clean AVX→SSE transition
                "0xC5 0xF8 0x77"
            } in(x_row -> rsi, w_row -> rdi, K -> rdx, out_slot -> rcx) clobbers(rax)
            n = n + 1
        }
        m = m + 1
    }
}

// ---------------------------------------------------------------------------
// F32-weights × F32-activations AVX2 worker (slice 8.3 Phase F1).
//
// Mirrors `mm_worker_bf16_f32_avx2_naive` byte-for-byte EXCEPT:
//   * Weight stride is K*4 (not K*2)
//   * Inner load is a 32-byte vmovups ymm2 from rdi+rax*4 (not vmovdqu xmm
//     + vpmovzxwd + vpslld)
//   * Loop body is 21 bytes vs 31 in the bf16 variant — `jge` rel8 is +21
//     (0x15) and `jmp` rel8 is -26 (0xE6)
//
// The reduction tree (vextractf128 + vaddps + 2× vhaddps) is IDENTICAL to
// the bf16 variant, so feeding bf16-widened weights into this kernel
// produces bit-identical output to feeding the raw bf16 weights into
// `mm_worker_bf16_f32_avx2_naive`. That equivalence is the foundation of
// the Phase F2 f32 path for Llama-3B (avoids the bf16 reduction-tree
// drift baked into the existing chain).
// ---------------------------------------------------------------------------
fn mm_worker_f32_weights_f32_avx2_naive(u64 start_n, u64 end_n, u64 ctx_ptr) {
    u64 out_ptr = 0
    unsafe { *(ctx_ptr as u64) -> out_ptr }
    u64 x_ptr = 0
    unsafe { *((ctx_ptr + 8) as u64) -> x_ptr }
    u64 w_ptr = 0
    unsafe { *((ctx_ptr + 16) as u64) -> w_ptr }
    u64 M = 0
    unsafe { *((ctx_ptr + 24) as u64) -> M }
    u64 N = 0
    unsafe { *((ctx_ptr + 32) as u64) -> N }
    u64 K = 0
    unsafe { *((ctx_ptr + 40) as u64) -> K }

    u64 m = 0
    while m < M {
        u64 x_row = x_ptr + m * K * 4
        u64 o_row = out_ptr + m * N * 4
        u64 n = start_n
        while n < end_n {
            u64 w_row = w_ptr + n * K * 4
            u64 out_slot = o_row + n * 4
            asm {
                // vxorps ymm0, ymm0, ymm0       ; accumulator = 0
                "0xC5 0xFC 0x57 0xC0"
                // xor rax, rax                   ; k = 0
                "0x48 0x31 0xC0"
                // .loop: cmp rax, rdx            ; (3)
                "0x48 0x39 0xD0"
                // jge +21 (past loop body to reduce block)
                "0x7D 0x15"
                // vmovups ymm1, [rsi + rax*4]    ; (5) 8 f32 activations
                "0xC5 0xFC 0x10 0x0C 0x86"
                // vmovups ymm2, [rdi + rax*4]    ; (5) 8 f32 weights
                "0xC5 0xFC 0x10 0x14 0x87"
                // vfmadd231ps ymm0, ymm1, ymm2   ; (5) acc += x * w
                "0xC4 0xE2 0x75 0xB8 0xC2"
                // add rax, 8                     ; (4)
                "0x48 0x83 0xC0 0x08"
                // jmp .loop                       ; rel8 = -26 = 0xE6
                "0xEB 0xE6"
                // .done: horizontal reduce ymm0 → scalar (identical to bf16)
                // vextractf128 xmm1, ymm0, 1
                "0xC4 0xE3 0x7D 0x19 0xC1 0x01"
                // vaddps xmm0, xmm0, xmm1
                "0xC5 0xF8 0x58 0xC1"
                // vhaddps xmm0, xmm0, xmm0
                "0xC5 0xFB 0x7C 0xC0"
                // vhaddps xmm0, xmm0, xmm0
                "0xC5 0xFB 0x7C 0xC0"
                // vmovss [rcx], xmm0
                "0xC5 0xFA 0x11 0x01"
                // vzeroupper
                "0xC5 0xF8 0x77"
            } in(x_row -> rsi, w_row -> rdi, K -> rdx, out_slot -> rcx) clobbers(rax)
            n = n + 1
        }
        m = m + 1
    }
}

// ---------------------------------------------------------------------------
// Public entry: matmul with F32 weights, F32 activations (slice 8.3 F1).
//
// Mirrors `matmul_bf16_weights_f32` shape but dispatches to the f32-weight
// AVX2 worker. Kahan is NOT yet implemented for the f32-weight path — if
// `use_kahan != 0` we fall back to the naive AVX2 worker (per F1 brief).
// The f32 AVX2 worker requires K % 8 == 0; F2 caller must guarantee this.
// ---------------------------------------------------------------------------
fn matmul_f32_weights_f32(u64 out_ptr, u64 x_ptr, u64 w_ptr,
                          u64 M, u64 N, u64 K,
                          u64 num_workers, u64 use_kahan) {
    if mm_ctx_base == 0 || num_workers > mm_max_workers {
        mm_init(num_workers)
    }

    u64 w = 0
    while w < num_workers {
        u64 ctx_w = mm_ctx_base + w * 64
        unsafe { *(ctx_w as u64) = out_ptr }
        u64 p8 = ctx_w + 8
        unsafe { *(p8 as u64) = x_ptr }
        u64 p16 = ctx_w + 16
        unsafe { *(p16 as u64) = w_ptr }
        u64 p24 = ctx_w + 24
        unsafe { *(p24 as u64) = M }
        u64 p32 = ctx_w + 32
        unsafe { *(p32 as u64) = N }
        u64 p40 = ctx_w + 40
        unsafe { *(p40 as u64) = K }
        w = w + 1
    }

    u64 fn_ptr = fn_addr("mm_worker_f32_weights_f32_avx2_naive")

    u64 chunk = N / num_workers
    w = 0
    while w + 1 < num_workers {
        u64 start_n = w * chunk
        u64 end_n   = start_n + chunk
        u64 ctx_w = mm_ctx_base + w * 64
        thread_pool_submit(w, fn_ptr, start_n, end_n, ctx_w)
        w = w + 1
    }
    u64 main_start = (num_workers - 1) * chunk
    u64 main_end   = N
    u64 main_ctx   = mm_ctx_base + (num_workers - 1) * 64
    mm_worker_f32_weights_f32_avx2_naive(main_start, main_end, main_ctx)
    thread_pool_wait()
}

// ---------------------------------------------------------------------------
// Public entry: matmul with BF16 weights, F32 activations, Kahan on/off.
//
// out[M × N] = x[M × K] · wᵀ, `w` stored row-major [N × K] in BF16.
// Columns are sharded across the thread pool.
//
// `use_kahan != 0` picks the compensated variant for residual-stream
// hotspots; `= 0` gives the naive accumulator.
// ---------------------------------------------------------------------------
fn matmul_bf16_weights_f32(u64 out_ptr, u64 x_ptr, u64 w_ptr,
                           u64 M, u64 N, u64 K,
                           u64 num_workers, u64 use_kahan) {
    if mm_ctx_base == 0 || num_workers > mm_max_workers {
        mm_init(num_workers)
    }

    // Populate the 6 shared fields in every worker's ctx slot. That's
    // num_workers × 6 stores per call — still far cheaper than the old
    // per-call alloc(48), which was an mmap syscall with full heap-lock
    // contention.
    u64 w = 0
    while w < num_workers {
        u64 ctx_w = mm_ctx_base + w * 64
        unsafe { *(ctx_w as u64) = out_ptr }
        u64 p8 = ctx_w + 8
        unsafe { *(p8 as u64) = x_ptr }
        u64 p16 = ctx_w + 16
        unsafe { *(p16 as u64) = w_ptr }
        u64 p24 = ctx_w + 24
        unsafe { *(p24 as u64) = M }
        u64 p32 = ctx_w + 32
        unsafe { *(p32 as u64) = N }
        u64 p40 = ctx_w + 40
        unsafe { *(p40 as u64) = K }
        w = w + 1
    }

    u64 fn_ptr = 0
    if use_kahan != 0 {
        fn_ptr = fn_addr("mm_worker_bf16_f32_kahan")
    } else {
        // Naive path — use AVX2 2-wide when K is a multiple of 8. The
        // 2-wide kernel runs two independent accumulators per inner
        // iter, so both FMA ports stay busy even under the loop-carried
        // dep; single-accumulator version serializes on one port.
        if (K & 7) == 0 {
            fn_ptr = fn_addr("mm_worker_bf16_f32_avx2_naive_2w")
        } else {
            fn_ptr = fn_addr("mm_worker_bf16_f32_naive")
        }
    }

    // Submit jobs to workers 0..num_workers-2, and run the last slice
    // inline on the main thread. Saves one futex_wake syscall per matmul
    // (+the context-switch round trip); over ~1 680 matmul calls per
    // 20-token decode that's ~3–5 ms of real wall time in our bench.
    u64 chunk = N / num_workers
    w = 0
    while w + 1 < num_workers {
        u64 start_n = w * chunk
        u64 end_n   = start_n + chunk
        u64 ctx_w = mm_ctx_base + w * 64
        thread_pool_submit(w, fn_ptr, start_n, end_n, ctx_w)
        w = w + 1
    }
    // Last slice — main thread runs it directly. Handles the N-not-
    // divisible-by-num_workers tail naturally because end=N.
    u64 main_start = (num_workers - 1) * chunk
    u64 main_end   = N
    u64 main_ctx   = mm_ctx_base + (num_workers - 1) * 64
    if use_kahan != 0 {
        mm_worker_bf16_f32_kahan(main_start, main_end, main_ctx)
    } else {
        if (K & 7) == 0 {
            mm_worker_bf16_f32_avx2_naive_2w(main_start, main_end, main_ctx)
        } else {
            mm_worker_bf16_f32_naive(main_start, main_end, main_ctx)
        }
    }
    thread_pool_wait()
}

// ---------------------------------------------------------------------------
// Q8_0 quantised weights × f32 activations.
//
// Block layout per 32 weights (34 bytes):
//   [0..1]    f16 scale (big-endian bits in gguf? no — little endian u16)
//   [2..33]   int8 qs[32]  (2's-complement, sign-extended on decode)
//
// dequant rule: real_weight[i] = scale * int8_qs[i]
//
// Row layout in a Q8_0 tensor of shape [N, K]:
//   K must be a multiple of 32.
//   Row n starts at w_ptr + n * (K/32) * 34 bytes.
//
// This is the scalar worker — correctness baseline. AVX2 variant goes
// in once there's a test model on disk to end-to-end validate against.
//
// Q8_0 matmul needs an f16-to-f32 helper. Import path brings in
// gguf_f16_to_f32_exact; keep a local alias for type stability.
// ---------------------------------------------------------------------------

// AVX2 Q8_0 × F32 matmul worker. Processes one block (32 int8 weights)
// per inner iter using 4× 8-wide FMA against the cross-block accumulator
// in ymm0.  Register convention matches the caller-bound asm input:
//   rsi = x_addr          (start of 32 f32 activations for the block)
//   rdi = block_ptr       (start of 34-byte Q8_0 block)
//   rcx = scale_scratch   (4 bytes holding f16→f32 scale of this block)
//   r8  = acc_scratch     (32 bytes storing ymm0 across block iters)
//
// Both scratches sit inside the ctx-slot-owned per-worker cache line
// (allocated once in mm_init): bytes 0..3 hold the scale, bytes 32..63
// hold the accumulator.
fn mm_worker_q8_0_f32_avx2(u64 start_n, u64 end_n, u64 ctx_ptr) {
    u64 out_ptr = 0
    unsafe { *(ctx_ptr as u64) -> out_ptr }
    u64 x_ptr = 0
    unsafe { *((ctx_ptr + 8) as u64) -> x_ptr }
    u64 w_ptr = 0
    unsafe { *((ctx_ptr + 16) as u64) -> w_ptr }
    u64 M = 0
    unsafe { *((ctx_ptr + 24) as u64) -> M }
    u64 N = 0
    unsafe { *((ctx_ptr + 32) as u64) -> N }
    u64 K = 0
    unsafe { *((ctx_ptr + 40) as u64) -> K }
    u64 scratch_base = 0
    unsafe { *((ctx_ptr + 48) as u64) -> scratch_base }

    u64 n_blocks = K / 32
    u64 block_row_bytes = n_blocks * 34

    u64 scale_buf = scratch_base
    u64 acc_buf   = scratch_base + 32

    u64 m = 0
    while m < M {
        u64 x_row = x_ptr + m * K * 4
        u64 o_row = out_ptr + m * N * 4
        u64 n = start_n
        while n < end_n {
            u64 w_row = w_ptr + n * block_row_bytes
            // Zero accumulator (8 f32 lanes of ymm0).
            f32 zero_f = 0.0f
            u64 zi = 0
            while zi < 8 {
                unsafe { *((acc_buf + zi * 4) as f32) = zero_f }
                zi = zi + 1
            }
            u64 bi = 0
            while bi < n_blocks {
                u64 block = w_row + bi * 34

                u64 x_b = x_row + bi * 32 * 4
                asm {
                    // vmovups ymm0, [r8]               ; load main acc
                    "0xC4 0xC1 0x7C 0x10 0x00"
                    // vxorps ymm4, ymm4, ymm4          ; zero side accumulators
                    "0xC5 0xDC 0x57 0xE4"
                    // vxorps ymm5, ymm5, ymm5
                    "0xC5 0xD4 0x57 0xED"
                    // vxorps ymm6, ymm6, ymm6
                    "0xC5 0xCC 0x57 0xF6"
                    // INLINE f16-scale → f32 broadcast. Replaces the old
                    // MLRift integer unpack (10+ ops) + L1 store/load
                    // round-trip via scale_buf. F16C native on Zen 4.
                    // vpbroadcastw xmm3, [rdi]         ; broadcast f16 scale
                    "0xC4 0xE2 0x79 0x79 0x1F"
                    // vcvtph2ps ymm3, xmm3             ; 8 f16 → 8 f32 (all same)
                    "0xC4 0xE2 0x7D 0x13 0xDB"
                    // -- chunk 0 → ymm0: weights [rdi+2..+9], x [rsi..] --
                    // vpmovsxbd ymm1, [rdi+2]          ; 8 int8 → 8 int32
                    "0xC4 0xE2 0x7D 0x21 0x4F 0x02"
                    // vcvtdq2ps ymm1, ymm1
                    "0xC5 0xFC 0x5B 0xC9"
                    // vmulps ymm1, ymm1, ymm3          ; * scale
                    "0xC5 0xF4 0x59 0xCB"
                    // vmovups ymm2, [rsi]              ; 8 f32 activations
                    "0xC5 0xFC 0x10 0x16"
                    // vfmadd231ps ymm0, ymm1, ymm2
                    "0xC4 0xE2 0x75 0xB8 0xC2"
                    // -- chunk 1 → ymm4: weights [rdi+10..+17], x [rsi+32..] --
                    "0xC4 0xE2 0x7D 0x21 0x4F 0x0A"
                    "0xC5 0xFC 0x5B 0xC9"
                    "0xC5 0xF4 0x59 0xCB"
                    "0xC5 0xFC 0x10 0x56 0x20"
                    // vfmadd231ps ymm4, ymm1, ymm2
                    "0xC4 0xE2 0x75 0xB8 0xE2"
                    // -- chunk 2 → ymm5: weights [rdi+18..+25], x [rsi+64..] --
                    "0xC4 0xE2 0x7D 0x21 0x4F 0x12"
                    "0xC5 0xFC 0x5B 0xC9"
                    "0xC5 0xF4 0x59 0xCB"
                    "0xC5 0xFC 0x10 0x56 0x40"
                    // vfmadd231ps ymm5, ymm1, ymm2
                    "0xC4 0xE2 0x75 0xB8 0xEA"
                    // -- chunk 3 → ymm6: weights [rdi+26..+33], x [rsi+96..] --
                    "0xC4 0xE2 0x7D 0x21 0x4F 0x1A"
                    "0xC5 0xFC 0x5B 0xC9"
                    "0xC5 0xF4 0x59 0xCB"
                    "0xC5 0xFC 0x10 0x56 0x60"
                    // vfmadd231ps ymm6, ymm1, ymm2
                    "0xC4 0xE2 0x75 0xB8 0xF2"
                    // -- reduce 4 accumulators into ymm0 --
                    // vaddps ymm0, ymm0, ymm4
                    "0xC5 0xFC 0x58 0xC4"
                    // vaddps ymm5, ymm5, ymm6
                    "0xC5 0xD4 0x58 0xEE"
                    // vaddps ymm0, ymm0, ymm5
                    "0xC5 0xFC 0x58 0xC5"
                    // vmovups [r8], ymm0               ; store acc
                    "0xC4 0xC1 0x7C 0x11 0x00"
                    // vzeroupper
                    "0xC5 0xF8 0x77"
                } in(x_b -> rsi, block -> rdi, scale_buf -> rcx, acc_buf -> r8)
                bi = bi + 1
            }
            // Horizontal reduce the 8-lane acc to scalar.
            f32 sum = 0.0f
            u64 li = 0
            while li < 8 {
                f32 v = 0.0f
                unsafe { *((acc_buf + li * 4) as f32) -> v }
                sum = sum + v
                li = li + 1
            }
            unsafe { *((o_row + n * 4) as f32) = sum }
            n = n + 1
        }
        m = m + 1
    }
}

fn mm_worker_q8_0_f32_naive(u64 start_n, u64 end_n, u64 ctx_ptr) {
    u64 out_ptr = 0
    unsafe { *(ctx_ptr as u64) -> out_ptr }
    u64 x_ptr = 0
    unsafe { *((ctx_ptr + 8) as u64) -> x_ptr }
    u64 w_ptr = 0
    unsafe { *((ctx_ptr + 16) as u64) -> w_ptr }
    u64 M = 0
    unsafe { *((ctx_ptr + 24) as u64) -> M }
    u64 N = 0
    unsafe { *((ctx_ptr + 32) as u64) -> N }
    u64 K = 0
    unsafe { *((ctx_ptr + 40) as u64) -> K }
    u64 scratch_base = 0
    unsafe { *((ctx_ptr + 48) as u64) -> scratch_base }

    u64 n_blocks = K / 32
    u64 block_row_bytes = n_blocks * 34

    u64 m = 0
    while m < M {
        u64 n = start_n
        while n < end_n {
            u64 w_row = w_ptr + n * block_row_bytes
            f32 sum = 0.0f
            u64 bi = 0
            while bi < n_blocks {
                u64 block = w_row + bi * 34
                u64 lo = load8(block)
                u64 hi = load8(block + 1)
                u64 dbits = lo | (hi << 8)
                // INLINED f16→f32 normal-path decode. See mm_worker_q8_0_f32_avx2
                // for the rationale (removes per-call stack-slot mmap).
                u64 d_exp  = (dbits >> 10) & 0x1F
                u64 d_mant = dbits & 0x3FF
                u64 d_sign = (dbits >> 15) & 1
                u64 d_bits32 = ((d_exp + 112) << 23) | (d_mant << 13) | (d_sign << 31)
                u32 d_u32 = d_bits32
                unsafe { *(scratch_base as uint32) = d_u32 }
                f32 d = 0.0f
                unsafe { *(scratch_base as f32) -> d }
                u64 qs = block + 2
                u64 j = 0
                while j < 32 {
                    u64 bval = load8(qs + j)
                    f32 q = 0.0f
                    if bval >= 128 {
                        f32 pos = int_to_f32(256 - bval)
                        q = 0.0f - pos
                    } else {
                        q = int_to_f32(bval)
                    }
                    f32 xv = 0.0f
                    unsafe { *((x_ptr + (m * K + bi * 32 + j) * 4) as f32) -> xv }
                    sum = sum + xv * (d * q)
                    j = j + 1
                }
                bi = bi + 1
            }
            unsafe { *((out_ptr + (m * N + n) * 4) as f32) = sum }
            n = n + 1
        }
        m = m + 1
    }
}

// Public entry. Mirrors matmul_bf16_weights_f32 shape; no Kahan/AVX2
// switch yet (will grow once a Q8_0 model is on disk to validate).
fn matmul_q8_0_weights_f32(u64 out_ptr, u64 x_ptr, u64 w_ptr,
                           u64 M, u64 N, u64 K,
                           u64 num_workers) {
    if mm_ctx_base == 0 || num_workers > mm_max_workers {
        mm_init(num_workers)
    }

    u64 w = 0
    while w < num_workers {
        u64 ctx_w = mm_ctx_base + w * 64
        unsafe { *(ctx_w as u64) = out_ptr }
        u64 p8 = ctx_w + 8
        unsafe { *(p8 as u64) = x_ptr }
        u64 p16 = ctx_w + 16
        unsafe { *(p16 as u64) = w_ptr }
        u64 p24 = ctx_w + 24
        unsafe { *(p24 as u64) = M }
        u64 p32 = ctx_w + 32
        unsafe { *(p32 as u64) = N }
        u64 p40 = ctx_w + 40
        unsafe { *(p40 as u64) = K }
        w = w + 1
    }

    u64 fn_ptr = fn_addr("mm_worker_q8_0_f32_avx2")
    if (K & 31) != 0 { fn_ptr = fn_addr("mm_worker_q8_0_f32_naive") }
    u64 chunk = N / num_workers
    w = 0
    while w + 1 < num_workers {
        u64 start_n = w * chunk
        u64 end_n   = start_n + chunk
        u64 ctx_w = mm_ctx_base + w * 64
        thread_pool_submit(w, fn_ptr, start_n, end_n, ctx_w)
        w = w + 1
    }
    u64 main_start = (num_workers - 1) * chunk
    u64 main_end   = N
    u64 main_ctx   = mm_ctx_base + (num_workers - 1) * 64
    if (K & 31) == 0 {
        mm_worker_q8_0_f32_avx2(main_start, main_end, main_ctx)
    } else {
        mm_worker_q8_0_f32_naive(main_start, main_end, main_ctx)
    }
    thread_pool_wait()
}

// ---------------------------------------------------------------------------
// Bit-exact Q8_0 × Q8_0 → f32 matmul (matches llama.cpp byte-for-byte).
//
// The standard `matmul_q8_0_weights_f32` above dequantizes Q8_0 weights to
// f32 then does f32×f32 FMA against an f32 activation. That's a correct
// Q8_0 matmul but its f32 outputs differ from llama.cpp on the same model
// because llama.cpp's Q8_0 matmul:
//
//   1. Quantizes the f32 activation to Q8_0 too (`quantize_row_q8_0_ref`).
//   2. Per 32-element block, computes int8×int8 → int32 dot exactly.
//   3. Multiplies the int32 by the *product of both block scales* (in f32).
//   4. Accumulates per-block contributions into a single f32.
//
// On a 16-layer Llama-3.2-1B that systematic per-block delta lifts to a
// 0.36-logit gap between the top-1 and top-2 candidates by decode pos 2,
// which flips the argmax. Token IDs only match if we use llama.cpp's
// algorithm bit-for-bit.
//
// New entry point: `matmul_q8_0_q8_0_f32(out, x_f32, w_q8_0, M, N, K, nw)`.
// `qwen3.mlr` flips to it via `qwen3_set_q8_bitexact(1)`. Performance is
// secondary (scalar int8×int8 is fine for a first cut).
// ---------------------------------------------------------------------------

// Activation Q8_0 buffer (grows on demand to fit M * (K/32) * 34 bytes).
static u64 mm_q8q8_actq_buf  = 0
static u64 mm_q8q8_actq_cap  = 0   // bytes capacity

// Separate 16-byte scratch used ONLY for the f32↔u32 bit reinterprets
// inside _q8q8_fp32_to_fp16_rne. Must not alias the activation buffer
// (otherwise quantize_row_q8_0's fp16-RNE side-call clobbers the Q8_0
// blocks it just wrote — happens whenever K > 32 because the fp16
// helper writes to byte 0 of `mm_q8q8_actq_buf` in between blocks).
static u64 mm_q8q8_bits_scratch = 0

// Lazily grow the activation Q8_0 buffer to fit M * (K/32) * 34 bytes.
fn mm_q8q8_actq_reserve(u64 m, u64 k) {
    u64 need = m * (k / 32) * 34
    if mm_q8q8_actq_cap >= need { return }
    if mm_q8q8_actq_buf != 0 { dealloc(mm_q8q8_actq_buf) }
    // Round up to 64-byte multiple to keep cache lines clean.
    u64 rounded = (need + 63) & ~63
    mm_q8q8_actq_buf = alloc(rounded)
    mm_q8q8_actq_cap = rounded
}

// FP32 → FP16 round-to-nearest-even using the Maratyszcza FP16 algorithm
// (https://github.com/Maratyszcza/FP16). This matches llama.cpp's
// `ggml_compute_fp32_to_fp16` byte-for-byte. Returns the 16 bits as a u64.
//
// The trick: scale |f| by 2^112 then 2^-110 to put the f32 mantissa into
// a position where IEEE-754 rounding-on-cast produces the correct
// 10-bit f16 mantissa. Then re-pack the exponent and reattach the sign.
fn _q8q8_fp32_to_fp16_rne(f32 f) -> u64 {
    if mm_q8q8_bits_scratch == 0 {
        mm_q8q8_bits_scratch = alloc(16)
    }
    u64 scratch = mm_q8q8_bits_scratch
    // Scaling factors as bit patterns.
    //   scale_to_inf  = 0x77800000 (2^112)
    //   scale_to_zero = 0x08800000 (2^-110)
    u32 sti_bits = 0x77800000
    unsafe { *(scratch as uint32) = sti_bits }
    f32 scale_to_inf = 0.0f
    unsafe { *(scratch as f32) -> scale_to_inf }
    u32 stz_bits = 0x08800000
    unsafe { *(scratch as uint32) = stz_bits }
    f32 scale_to_zero = 0.0f
    unsafe { *(scratch as f32) -> scale_to_zero }
    // Get the bit pattern of f.
    unsafe { *(scratch as f32) = f }
    u32 w32 = 0
    unsafe { *(scratch as uint32) -> w32 }
    u64 w = w32
    u64 sign = w & 0x80000000
    // |f| via masking off the sign bit.
    u32 absf_bits = w32 & 0x7FFFFFFF
    unsafe { *(scratch as uint32) = absf_bits }
    f32 absf = 0.0f
    unsafe { *(scratch as f32) -> absf }
    f32 base = (absf * scale_to_inf) * scale_to_zero
    u64 shl1_w = (w + w) & 0xFFFFFFFF
    u64 bias = shl1_w & 0xFF000000
    if bias < 0x71000000 { bias = 0x71000000 }
    // Compute fp32_from_bits((bias >> 1) + 0x07800000), add to base.
    u32 b2 = (bias >> 1) + 0x07800000
    unsafe { *(scratch as uint32) = b2 }
    f32 b2f = 0.0f
    unsafe { *(scratch as f32) -> b2f }
    base = base + b2f
    // base now holds the rounded f16 value in its f32 representation.
    unsafe { *(scratch as f32) = base }
    u32 bits32 = 0
    unsafe { *(scratch as uint32) -> bits32 }
    u64 bits = bits32
    u64 exp_bits = (bits >> 13) & 0x00007C00
    u64 mantissa_bits = bits & 0x00000FFF
    u64 nonsign = exp_bits + mantissa_bits
    u64 result = sign >> 16
    if shl1_w > 0xFF000000 {
        result = result | 0x7E00
    } else {
        result = result | nonsign
    }
    return result & 0xFFFF
}

// FP16 → FP32 (RNE-equivalent — bit-exact match with
// ggml_compute_fp16_to_fp32). We already have gguf_f16_to_f32_exact in
// std/gguf.mlr but it goes through a slightly different algorithm; this
// inlined helper uses the same Maratyszcza scaling trick as the encoder
// for symmetry. Both produce the same f32 for all f16 inputs (bit-exact).
fn _q8q8_fp16_to_fp32(u64 h) -> f32 {
    return gguf_f16_to_f32_exact(h)
}

// Round f32 to nearest int (half-away-from-zero, matching C99 `roundf`).
// Uses cvttss2si (truncation) on x ± 0.5 to get half-away-from-zero.
fn _q8q8_roundf_i32(f32 x) -> u64 {
    f32 half = 0.5f
    f32 nhalf = 0.0f - half
    if x >= 0.0f {
        f32 y = x + half
        u64 i = f32_to_int(y)
        return i
    }
    f32 y = x + nhalf
    // f32_to_int truncates toward zero; for negative y it yields ceil(y).
    u64 i = f32_to_int(y)
    return i
}

// quantize_row_q8_0 — per 32-element block:
//   amax = max(|x[j]|)
//   d    = amax / 127.0
//   id   = (d != 0) ? 1.0/d : 0.0
//   block.d  = f16_rne(d)
//   block.qs[j] = (int8) roundf(x[j] * id)
fn quantize_row_q8_0(u64 out_ptr, u64 x_ptr, u64 k) {
    u64 nb = k / 32
    u64 i = 0
    while i < nb {
        u64 base_in  = x_ptr + i * 32 * 4
        u64 base_out = out_ptr + i * 34
        // amax = max |x|.
        f32 amax = 0.0f
        u64 j = 0
        while j < 32 {
            f32 v = 0.0f
            unsafe { *((base_in + j * 4) as f32) -> v }
            f32 av = v
            if av < 0.0f { av = 0.0f - av }
            if av > amax { amax = av }
            j = j + 1
        }
        // d = amax / 127.0
        f32 c127 = 127.0f
        f32 d = amax / c127
        // id = (d != 0) ? 1/d : 0
        f32 id = 0.0f
        if d != 0.0f {
            f32 one = 1.0f
            id = one / d
        }
        // Store f16 scale (RNE).
        u64 d_f16 = _q8q8_fp32_to_fp16_rne(d)
        u8 lo_b = d_f16 & 0xFF
        u8 hi_b = (d_f16 >> 8) & 0xFF
        store8(base_out + 0, lo_b)
        store8(base_out + 1, hi_b)
        // Store 32 int8 quantized samples.
        j = 0
        while j < 32 {
            f32 v = 0.0f
            unsafe { *((base_in + j * 4) as f32) -> v }
            f32 q = v * id
            u64 qi = _q8q8_roundf_i32(q)
            // Mask to 8 bits — qi is signed in [-128, 127] but stored as
            // u64 (sign-extended); & 0xFF gives the byte representation.
            u8 qb = qi & 0xFF
            store8(base_out + 2 + j, qb)
            j = j + 1
        }
        i = i + 1
    }
}

// Q8_0×Q8_0 worker — scalar reference. Loops over rows [start_n, end_n)
// and for each row, sums all blocks: int32_dot * (d_w * d_x). Outputs
// f32 to out_ptr[m * N + n]. Uses ctx slots:
//   [0] out_ptr
//   [8] x_q8 ptr (M * K/32 * 34 bytes — pre-quantized activation)
//   [16] w_q8 ptr (N * K/32 * 34 bytes)
//   [24] M
//   [32] N
//   [40] K
fn mm_worker_q8_0_q8_0_f32_scalar(u64 start_n, u64 end_n, u64 ctx_ptr) {
    u64 out_ptr = 0
    unsafe { *(ctx_ptr as u64) -> out_ptr }
    u64 xq_ptr = 0
    unsafe { *((ctx_ptr + 8) as u64) -> xq_ptr }
    u64 wq_ptr = 0
    unsafe { *((ctx_ptr + 16) as u64) -> wq_ptr }
    u64 M = 0
    unsafe { *((ctx_ptr + 24) as u64) -> M }
    u64 N = 0
    unsafe { *((ctx_ptr + 32) as u64) -> N }
    u64 K = 0
    unsafe { *((ctx_ptr + 40) as u64) -> K }
    // [48] = per-worker scratch (64 bytes, owned by mm_init). Use first 8
    // bytes as two u32 slots for f16→f32 bit reinterprets so we don't race
    // with peer workers on a shared static (gguf_f16_to_f32_exact is NOT
    // thread-safe — its 4-byte scratch is a process-wide static).
    u64 scratch_base = 0
    unsafe { *((ctx_ptr + 48) as u64) -> scratch_base }
    u64 dw_slot = scratch_base
    u64 dx_slot = scratch_base + 4

    u64 nb = K / 32
    u64 row_bytes = nb * 34

    u64 m = 0
    while m < M {
        u64 x_row = xq_ptr + m * row_bytes
        u64 o_row = out_ptr + m * N * 4
        u64 n = start_n
        while n < end_n {
            u64 w_row = wq_ptr + n * row_bytes
            f32 sumf = 0.0f
            u64 ib = 0
            while ib < nb {
                u64 wblk = w_row + ib * 34
                u64 xblk = x_row + ib * 34
                // Load f16 scales (16-bit LE) and decode inline. Real
                // weight scales are always f16-normal in GGUF blobs (no
                // subnormals/inf — GGUF rejects those at quantize time)
                // so the fast normal-path branch covers everything.
                u64 dw_lo = load8(wblk)
                u64 dw_hi = load8(wblk + 1)
                u64 dw_bits = dw_lo | (dw_hi << 8)
                u64 dx_lo = load8(xblk)
                u64 dx_hi = load8(xblk + 1)
                u64 dx_bits = dx_lo | (dx_hi << 8)
                // Inline f16→f32 (normal-path widen + sign apply). Same
                // algorithm as gguf_f16_to_f32_exact, but writes to the
                // per-worker scratch slot so we don't race.
                f32 d_w = _q8q8_f16_decode(dw_bits, dw_slot)
                f32 d_x = _q8q8_f16_decode(dx_bits, dx_slot)
                // Integer dot of 32 int8 × int8 → int32. We accumulate
                // into u64 (sign-extending each product) since MLRift's
                // int arithmetic on u64 is two's complement.
                u64 sumi = 0
                u64 j = 0
                while j < 32 {
                    u64 wb = load8(wblk + 2 + j)
                    u64 xb = load8(xblk + 2 + j)
                    // Sign-extend to u64.
                    if (wb & 0x80) != 0 { wb = wb | 0xFFFFFFFFFFFFFF00 }
                    if (xb & 0x80) != 0 { xb = xb | 0xFFFFFFFFFFFFFF00 }
                    u64 prod = wb * xb
                    sumi = sumi + prod
                    j = j + 1
                }
                // Convert sumi (signed in u64 two's-complement) to f32.
                f64 sumi_f64 = int_to_f64(sumi)
                f32 sumi_f = f64_to_f32(sumi_f64)
                sumf = sumf + sumi_f * (d_w * d_x)
                ib = ib + 1
            }
            unsafe { *((o_row + n * 4) as f32) = sumf }
            n = n + 1
        }
        m = m + 1
    }
}

// Per-worker thread-safe f16→f32. Same as gguf_f16_to_f32_exact's normal
// path but writes the bit-reinterpret blob to the caller-owned 4-byte
// `slot`, not a process-wide static. Subnormal / inf branches included for
// completeness; in practice GGUF block scales are always f16-normal.
fn _q8q8_f16_decode(u64 bits, u64 slot) -> f32 {
    u64 sign = (bits >> 15) & 1
    u64 exp  = (bits >> 10) & 0x1F
    u64 mant = bits & 0x3FF
    f32 result = 0.0f
    if exp == 0 {
        if mant == 0 {
            result = 0.0f
        } else {
            // Subnormal: value = mant × 2^-24. f64-route avoids needing a
            // second scratch slot for the constant 2^-24.
            f64 mantd = int_to_f64(mant)
            f64 denom = int_to_f64(16777216)
            result = f64_to_f32(mantd / denom)
        }
    } else if exp == 31 {
        result = 0.0f   // map inf/NaN → 0 (same as gguf_f16_to_f32_exact)
    } else {
        u64 fbits = ((exp + 112) << 23) | (mant << 13)
        u32 bits32 = fbits
        unsafe { *(slot as uint32) = bits32 }
        unsafe { *(slot as f32) -> result }
    }
    if sign != 0 {
        f32 neg = 0.0f - result
        result = neg
    }
    return result
}

// Public entry: out[M, N] = x[M, K] · Wᵀ where W is Q8_0[N, K].
// Quantizes the f32 activation to Q8_0 once (single-threaded — at decode
// M=1, K≤8192, this is ~256 blocks, microseconds), then fans out the
// row-loop across `num_workers` threads using the scalar Q8×Q8 worker.
fn matmul_q8_0_q8_0_f32(u64 out_ptr, u64 x_ptr, u64 w_ptr,
                        u64 M, u64 N, u64 K,
                        u64 num_workers) {
    if mm_ctx_base == 0 || num_workers > mm_max_workers {
        mm_init(num_workers)
    }
    // Ensure activation Q8_0 scratch has room for M * K/32 * 34 bytes.
    mm_q8q8_actq_reserve(M, K)
    u64 xq_ptr = mm_q8q8_actq_buf
    // Quantize each row of the activation. M is typically 1 (decode).
    u64 m = 0
    while m < M {
        u64 row_bytes = (K / 32) * 34
        quantize_row_q8_0(xq_ptr + m * row_bytes,
                          x_ptr + m * K * 4,
                          K)
        m = m + 1
    }
    // Wire ctx slots — [8] now points at the quantized activation, not
    // the raw f32 (other slots match the f32 path).
    u64 w = 0
    while w < num_workers {
        u64 ctx_w = mm_ctx_base + w * 64
        unsafe { *(ctx_w as u64) = out_ptr }
        u64 p8 = ctx_w + 8
        unsafe { *(p8 as u64) = xq_ptr }
        u64 p16 = ctx_w + 16
        unsafe { *(p16 as u64) = w_ptr }
        u64 p24 = ctx_w + 24
        unsafe { *(p24 as u64) = M }
        u64 p32 = ctx_w + 32
        unsafe { *(p32 as u64) = N }
        u64 p40 = ctx_w + 40
        unsafe { *(p40 as u64) = K }
        w = w + 1
    }
    u64 fn_ptr = fn_addr("mm_worker_q8_0_q8_0_f32_scalar")
    u64 chunk = N / num_workers
    w = 0
    while w + 1 < num_workers {
        u64 start_n = w * chunk
        u64 end_n   = start_n + chunk
        u64 ctx_w = mm_ctx_base + w * 64
        thread_pool_submit(w, fn_ptr, start_n, end_n, ctx_w)
        w = w + 1
    }
    u64 main_start = (num_workers - 1) * chunk
    u64 main_end   = N
    u64 main_ctx   = mm_ctx_base + (num_workers - 1) * 64
    mm_worker_q8_0_q8_0_f32_scalar(main_start, main_end, main_ctx)
    thread_pool_wait()
}
