    unsafe { *((k_buf +  7 * 8) as u64) = d_post_norm_g      }
    unsafe { *((k_buf +  8 * 8) as u64) = d_q_norm_g         }
    unsafe { *((k_buf +  9 * 8) as u64) = d_k_norm_g         }
    unsafe { *((k_buf + 10 * 8) as u64) = d_rope_cos_16      }
    unsafe { *((k_buf + 11 * 8) as u64) = d_rope_sin_16      }
    unsafe { *((k_buf + 12 * 8) as u64) = d_kc_layer         }
    unsafe { *((k_buf + 13 * 8) as u64) = d_vc_layer         }
    unsafe { *((k_buf + 14 * 8) as u64) = pos_base           }
    unsafe { *((k_buf + 15 * 8) as u64) = d_barrier_ctr      }
    unsafe { *((k_buf + 16 * 8) as u64) = d_gu_scratch_16    }
    unsafe { *((k_buf + 17 * 8) as u64) = d_b_x_norm_g_16    }
    unsafe { *((k_buf + 18 * 8) as u64) = d_b_qkv_g_16       }
    unsafe { *((k_buf + 19 * 8) as u64) = d_b_attn_q_g_16    }
    unsafe { *((k_buf + 20 * 8) as u64) = d_b_mid_g_16       }
    unsafe { *((k_buf + 21 * 8) as u64) = d_b_mid_norm_g_16  }
    unsafe { *((k_buf + 22 * 8) as u64) = d_b_attn_out_g_16  }
    unsafe { *((k_buf + 23 * 8) as u64) = max_phase          }

    u64 kp = _gpu_kp_bump(24 * 8)
    u64 j = 0
    while j < 24 {
        u64 slot_ptr = k_buf + j * 8
        unsafe { *((kp + j * 8) as u64) = slot_ptr }
        j = j + 1
    }

    u32 grid_x = 512
    u32 block_x = 32
    u32 err = hipModuleLaunchKernel(_gpu_fh_qwen3_megakernel_speck16,
                                     grid_x, 1, 1, block_x, 1, 1,
                                     0, 0, kp, 0)
    if err != 0 { return 1 }
    return 0
}
