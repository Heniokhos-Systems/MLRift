// MLRift Standard Library — GPU matmul dispatch
//
// Companion to std/inference.mlr.  Provides a GPU-routed replacement for
// matmul_bf16_weights_f32_mt that:
//   1. Loads bf16_to_f32 + gemv_f32 + gemm_f32 kernels lazily on first use.
//   2. Caches dequant'd f32 weights on the device, keyed by the host
//      bf16 pointer (so subsequent calls with the same weight matrix
//      reuse the cached device buffer instead of re-copying + dequanting).
//   3. Routes M=1 calls to gemv_f32 (decode hot path) and M-multiple-
//      of-16 calls to gemm_f32 (prefill).  Other shapes return 1 and
//      let the caller fall back to CPU.
//
// Convention: HF-safetensors layout for weights is W[N, K] with
// K = in_features, N = out_features.  The CPU matmul_bf16_weights_f32
// computes out[m, n] = sum_k x[m, k] * w[n, k] (i.e. out = x @ W^T).
// gemv_f32 (c[m] = A[m, k] @ b[k]) maps cleanly with A=W; gemm_f32
// (C = A @ B with B[K, N]) needs the weight LAYOUT-TRANSPOSED — for
// now the gemm prefill path is omitted and M ≥ 16 falls through to
// CPU.  Once a transpose-on-load step is added (or a strided gemm
// variant), the prefill path lights up.
//
// All hipMalloc / hipMemcpy / hipModuleLaunchKernel calls assume the
// caller already invoked hipSetDevice(0) (typical at the top of
// main()).  Under --target=amdgpu-native these resolve to the KFD
// shim; under HIP runtime they go to libamdhip64.

import "hip.mlr"
import "kfd.mlr"
import "io.mlr"
import "fmt.mlr"
import "string.mlr"
import "quant.mlr"

@dynamic extern fn getenv(uint64 name) -> uint64

// === Static state ===

// 0 = uninitialised, 1 = ready, 2 = unavailable (env not set or
// kernel-load failure — caller falls back to CPU on every call).
static u64 _gpu_mm_init        = 0
static u64 _gpu_mm_fh_dq       = 0
static u64 _gpu_mm_fh_gemv     = 0
static u64 _gpu_mm_fh_gemv_coop = 0       // cooperative-row f32 variant
static u64 _gpu_mm_fh_gemv_coop_bf16 = 0  // bf16-direct cooperative-row variant
static u64 _gpu_mm_fh_gemv_coop_batched = 0  // M-batched f32 (Phase 1 Slice 1.3)
static u64 _gpu_mm_fh_gemv_coop_batched_bf16 = 0  // M-batched bf16-direct (memory-bound shapes)
static u64 _gpu_mm_fh_gemv_coop_batched_q4_0 = 0  // M-batched Q4_0-direct (4.5 bpw)
// Pre-allocated kernarg arena: one-shot alloc at init, reused across every
// gpu_*_to_dev call.  Replaces the per-call alloc(8)×N + alloc(N*8) pattern,
// which was burning ~7.4 ms/step in mmap syscalls (alloc lowers to mmap;
// each call costs ~2.5 µs measured 2026-05-01 via examples/llm/alloc_bench.mlr).
// Arena layout: bump pointer; reset per launch (kernel reads values
// inside hipModuleLaunchKernel and the shim COPIES them into its own
// kernarg slot before returning, so the arena is safe to reuse immediately).
static u64 _gpu_kp_arena   = 0
static u64 _gpu_kp_arena_n = 0    // bump position
static u64 _gpu_kp_arena_cap = 8192   // 8 KB — fits any single dispatcher's kernarg layout
static u64 _gpu_mm_fh_gemm     = 0
// Pipeline kernels for the full-GPU forward path.
static u64 _gpu_fh_resid_add   = 0
static u64 _gpu_fh_silu_mul    = 0
static u64 _gpu_fh_silu_mul_batched = 0   // batched silu_mul (grid (n/256, batch))
static u64 _gpu_fh_rmsnorm_1024 = 0       // hidden-dim rmsnorm (N=1024, Qwen3-0.6B)
static u64 _gpu_fh_rmsnorm_5120 = 0       // hidden-dim rmsnorm (N=5120, Qwen3-14B)
static u64 _gpu_fh_rmsnorm_128  = 0       // per-head rmsnorm (N=128, used by qknorm)
static u64 _gpu_fh_rope_f32     = 0       // per-head RoPE (head_dim=128)
static u64 _gpu_fh_qkv_split    = 0       // Qwen3 KV-slice copy (q=2048, kv=1024)
static u64 _gpu_fh_qkv_split_batched = 0  // batched qkv_split (grid (8, batch))
static u64 _gpu_fh_qkv_split_speck4  = 0  // speculative qkv_split (per-pos K/V stride 4096)
static u64 _gpu_fh_extract_q    = 0       // Qwen3 Q-extract for batched qknorm
static u64 _gpu_fh_extract_k    = 0       // Qwen3 K-extract: K-slots → contig stage
static u64 _gpu_fh_insert_k     = 0       // Qwen3 K-insert: contig stage → K-slots
static u64 _gpu_fh_extract_k_speck4 = 0   // speculative K-extract (per-pos src)
static u64 _gpu_fh_insert_k_speck4  = 0   // speculative K-insert (per-pos dst)
static u64 _gpu_fh_attn_decode  = 0       // fused decode-attn (Q·K → softmax → ·V), 0.6B (nh=16)
static u64 _gpu_fh_attn_decode_batched = 0  // batched decode-attn (grid (nh, batch))
static u64 _gpu_fh_attn_decode_speck4  = 0  // multi-Q attn for spec_K=4
static u64 _gpu_fh_attn_decode_14b      = 0  // 14B variant: kv_ratio=5 (nh=40, nkv=8)
static u64 _gpu_fh_qkv_split_14b        = 0  // 14B variant: q_dim=5120
static u64 _gpu_fh_qkv_split_batched_14b = 0  // 14B batched variant
// Slice 4.8: full-layer mega-kernel.  Single dispatch replaces 11 per-op
// calls per qwen3 layer.  Best-effort load; absence falls back to per-op.
static u64 _gpu_fh_qwen3_megakernel     = 0
// Slice 4.14: M_EFF=4 mega-kernel for spec_K=4 PLD path.
static u64 _gpu_fh_qwen3_megakernel_speck4 = 0
// Slice 4.15: M_EFF=8 mega-kernel for spec_K=8 PLD path.
static u64 _gpu_fh_qwen3_megakernel_speck8 = 0
// Slice 4.18: M_EFF=16 mega-kernel for spec_K=16 PLD path.
static u64 _gpu_fh_qwen3_megakernel_speck16 = 0
// Slice 5.8: Llama-3.2-1B M=1 mega-kernel.  Best-effort load; absence
// falls back to per-op CPU bf16 (the Llama driver does not have a per-op
// GPU path of its own).
static u64 _gpu_fh_llama_megakernel       = 0
// Slice 6.4: Llama-3.2-1B M_EFF=4 speck4 mega-kernel (spec_K=4 PLD path).
static u64 _gpu_fh_llama_megakernel_speck4 = 0

// Arch mirrors — set by gpu_set_arch() (called from qwen3_set_arch).
// inference_gpu.mlr imports BEFORE qwen3.mlr, so we can't read
// QWEN3_* directly here.  Defaults match Qwen3-0.6B.
static u64 _gpu_arch_q_dim   = 2048
static u64 _gpu_arch_n_heads = 16

@export
fn gpu_set_arch(u64 q_dim, u64 n_heads) {
    _gpu_arch_q_dim   = q_dim
    _gpu_arch_n_heads = n_heads
}

// Parallel cache for bf16-direct path: maps host w_bf16 ptr → device
// bf16 ptr (one-shot H2D, no dequant).
static u64 _gpu_mm_bf16_keys = 0
static u64 _gpu_mm_bf16_vals = 0
static u64 _gpu_mm_bf16_n    = 0
// Slice 4.13: padded-row bf16 cache for the mega-kernel matmul phases.
// Padding row stride to break gcd with the GDDR6 channel cycle (16ch x
// 256B = 4096B) so consecutive rows hit distinct memory channels.  Keys
// are (host_bf16_ptr ^ k_pad) — a cheap unique tag since k_pad <<<< the
// virtual-address entropy.
static u64 _gpu_mm_bf16_pad_keys = 0
static u64 _gpu_mm_bf16_pad_vals = 0
static u64 _gpu_mm_bf16_pad_n    = 0

// Parallel cache for Q4_0-direct path: maps host w_bf16 ptr → device
// Q4_0 ptr.  First reference: CPU-side quantize bf16 → Q4_0, alloc
// device buffer of N*(K/32)*18 bytes, H2D copy, store device ptr.
// Subsequent references hit the cache.
static u64 _gpu_mm_q4_keys = 0
static u64 _gpu_mm_q4_vals = 0
static u64 _gpu_mm_q4_n    = 0

// Weight-size threshold (bytes of bf16 weight) below which GPU is
// not worth dispatching — for decode-shape M=1 the per-call sync
// floor (~110 µs) plus signal-write latency dwarf the actual gemv
// runtime on small projections.  Tuned empirically against
// Qwen3-0.6B greedy decode (20 tokens):
//   T (MB)  total ms   tok/s   bit-vs-PyTorch
//      32       598    33.4k    ✓
//       8       557    35.9k    ✓     ← sweet spot
//       4       710    28.1k    ✗ (drift at pos 17)
//       1       699    28.6k    ✗
// 8 MB lights up qkv (8 MB), gate_up (12 MB), lm_head (304 MB) but
// keeps oproj (4 MB) and down (6 MB) on CPU where they're faster
// (per-call sync overhead exceeds GPU compute on those shapes).
// Tunable via MLRIFT_GPU_MATMUL_MIN_BYTES env var.
static u64 _gpu_mm_min_bytes  = 8388608        // 8 MB

// Weight cache: parallel arrays.  Keyed by the host bf16 pointer; on
// hit the corresponding device f32 pointer is reused.  Linear-scan
// lookup; for Qwen3-0.6B's ~200 weight tensors this is fine.
static u64 _gpu_mm_cache_cap  = 256
static u64 _gpu_mm_cache_n    = 0
static u64 _gpu_mm_cache_keys = 0    // u64[cap]   bf16 host ptrs
static u64 _gpu_mm_cache_vals = 0    // u64[cap]   device f32 ptrs

// Per-call activation/output device buffer pool.  Re-allocate when
// the requested size exceeds capacity; free at module shutdown.
//
// Both x and out are allocated as **GTT** (system RAM mapped to GPU)
// so the CPU read of the result avoids BAR1 latency — on this card
// CPU-reading 8 KB of host-visible VRAM costs ~11 ms (cacheline-bound
// PCIe round-trips), but reading the same bytes from GTT is ~6 µs.
// GPU writes to GTT cost the equivalent of one PCIe transaction
// (microseconds for the small activations) — net wins are 80×+ on
// per-call wallclock for the decode shape.  Cached host pointers
// for both buffers are set at alloc time.
static u64 _gpu_mm_d_x_buf    = 0
static u64 _gpu_mm_d_x_h      = 0
static u64 _gpu_mm_d_x_cap    = 0
static u64 _gpu_mm_d_out_buf  = 0
static u64 _gpu_mm_d_out_h    = 0
static u64 _gpu_mm_d_out_cap  = 0

// === Helpers ===

// Reset the kernarg arena bump pointer.  Called at the top of each
// gpu_*_to_dev dispatcher; the shim copies kernarg values out of the
// arena synchronously inside hipModuleLaunchKernel, so reusing the
// memory across calls is safe.
fn _gpu_kp_reset() -> u64 {
    if _gpu_kp_arena == 0 {
        _gpu_kp_arena = alloc(_gpu_kp_arena_cap)
    }
    _gpu_kp_arena_n = 0
    return _gpu_kp_arena
}

// Bump-allocate `n` bytes from the arena and return the pointer.
fn _gpu_kp_bump(u64 n) -> u64 {
    u64 p = _gpu_kp_arena + _gpu_kp_arena_n
    _gpu_kp_arena_n = _gpu_kp_arena_n + n
    return p
}

fn _gpu_mm_load_co(u64 path, u64 fname) -> u64 {
    u64 fd = file_open(path, 0)
    if fd > 0xFFFFFFFFFFFFF000 { return 0 }
    u64 sz = file_size(fd)
    u64 blob = alloc(sz)
    file_read(fd, blob, sz)
    file_close(fd)
    u64 mod_slot = alloc(8)
    u32 err = hipModuleLoadData(mod_slot, blob)
    if err != 0 { return 0 }
    u64 mod = 0; unsafe { *(mod_slot as u64) -> mod }
    u64 fh_slot = alloc(8)
    err = hipModuleGetFunction(fh_slot, mod, fname)
    if err != 0 { return 0 }
    u64 fh = 0; unsafe { *(fh_slot as u64) -> fh }
    return fh
}

fn _gpu_mm_init_once() {
    if _gpu_mm_init != 0 { return }
    _gpu_mm_init = 2   // pessimistic; flip to 1 only on full success

    // Env-gate: ANY of the following triggers GPU init.  Previously only
    // MLRIFT_GPU_MATMUL did, which silently kept the mega-kernel .co
    // loads (loaded further below under _native_mk_mode) gated off when
    // a user set only MLRIFT_NATIVE_MEGAKERNEL=2.  That was the root
    // cause of slice 5.10's false-positive "20/20 PASS" — both runs sat
    // on CPU bf16 and never fired the mega-kernel at all.
    //
    //   MLRIFT_GPU_MATMUL          — original trigger (per-op GPU matmul)
    //   MLRIFT_NATIVE_MEGAKERNEL   — Qwen3 / Llama mega-kernel (M=1)
    //   MLRIFT_NATIVE_MEGAKERNEL_SPECK4 — speck4 (M_EFF=4) mega-kernel
    //
    // Each of these needs the HIP runtime init that this function
    // performs, so widening the gate is the minimal fix.  Values "0" or
    // empty mean "off"; anything else turns the trigger on.
    u64 _gate_on = 0
    u64 ev = getenv("MLRIFT_GPU_MATMUL")
    if ev != 0 {
        u64 c0 = 0; unsafe { *(ev as u8) -> c0 }
        if c0 != 48 { _gate_on = 1 }
    }
    if _gate_on == 0 {
        u64 ev_mk = getenv("MLRIFT_NATIVE_MEGAKERNEL")
        if ev_mk != 0 {
            u64 c0m = 0; unsafe { *(ev_mk as u8) -> c0m }
            if c0m != 48 { _gate_on = 1 }
        }
    }
    if _gate_on == 0 {
        u64 ev_mk4 = getenv("MLRIFT_NATIVE_MEGAKERNEL_SPECK4")
        if ev_mk4 != 0 {
            u64 c0m4 = 0; unsafe { *(ev_mk4 as u8) -> c0m4 }
            if c0m4 != 48 { _gate_on = 1 }
        }
    }
    if _gate_on == 0 { return }

    _gpu_mm_fh_dq             = _gpu_mm_load_co("/tmp/bf16_to_f32.co",        "bf16_to_f32")
    _gpu_mm_fh_gemv           = _gpu_mm_load_co("/tmp/gemv_f32.co",           "gemv_f32")
    _gpu_mm_fh_gemv_coop      = _gpu_mm_load_co("/tmp/gemv_coop_f32.co",      "gemv_coop_f32")
    _gpu_mm_fh_gemv_coop_bf16 = _gpu_mm_load_co("/tmp/gemv_coop_bf16_f32.co", "gemv_coop_bf16_f32")
    _gpu_mm_fh_gemv_coop_batched = _gpu_mm_load_co("/tmp/gemv_coop_f32_batched.co", "gemv_coop_f32_batched")
    _gpu_mm_fh_gemv_coop_batched_bf16 = _gpu_mm_load_co("/tmp/gemv_coop_bf16_f32_batched.co", "gemv_coop_bf16_f32_batched")
    _gpu_mm_fh_gemv_coop_batched_q4_0 = _gpu_mm_load_co("/tmp/gemv_coop_q4_0_f32_batched.co", "gemv_coop_q4_0_f32_batched")
    _gpu_mm_fh_gemm           = _gpu_mm_load_co("/tmp/gemm_f32.co",           "gemm_f32")
    // Pipeline kernels — best-effort load; unset = full-GPU path falls back.
    _gpu_fh_resid_add         = _gpu_mm_load_co("/tmp/residual_add_f32.co",   "residual_add_f32")
    _gpu_fh_silu_mul          = _gpu_mm_load_co("/tmp/silu_mul_f32.co",       "silu_mul_f32")
    _gpu_fh_silu_mul_batched  = _gpu_mm_load_co("/tmp/silu_mul_f32_batched.co", "silu_mul_f32_batched")
    _gpu_fh_rmsnorm_1024      = _gpu_mm_load_co("/tmp/rmsnorm_f32_1024.co",   "rmsnorm_f32")
    _gpu_fh_rmsnorm_5120      = _gpu_mm_load_co("/tmp/rmsnorm_f32_5120.co",   "rmsnorm_f32")
    _gpu_fh_rmsnorm_128       = _gpu_mm_load_co("/tmp/qknorm_f32.co",         "rmsnorm_f32")
    _gpu_fh_rope_f32          = _gpu_mm_load_co("/tmp/rope_qwen3_f32.co",     "rope_qwen3_f32")
    _gpu_fh_qkv_split         = _gpu_mm_load_co("/tmp/qkv_split_f32.co",      "qkv_split_f32")
    _gpu_fh_qkv_split_batched = _gpu_mm_load_co("/tmp/qkv_split_f32_batched.co", "qkv_split_f32_batched")
    _gpu_fh_qkv_split_14b     = _gpu_mm_load_co("/tmp/qkv_split_f32_14b.co",  "qkv_split_f32_14b")
    _gpu_fh_qkv_split_batched_14b = _gpu_mm_load_co("/tmp/qkv_split_f32_batched_14b.co", "qkv_split_f32_batched_14b")
    _gpu_fh_qkv_split_speck4  = _gpu_mm_load_co("/tmp/qkv_split_f32_speck4.co",  "qkv_split_f32_speck4")
    _gpu_fh_extract_q         = _gpu_mm_load_co("/tmp/extract_q_qwen3_f32.co", "extract_q_qwen3_f32")
    _gpu_fh_extract_k         = _gpu_mm_load_co("/tmp/extract_k_qwen3_f32.co", "extract_k_qwen3_f32")
    _gpu_fh_insert_k          = _gpu_mm_load_co("/tmp/insert_k_qwen3_f32.co",  "insert_k_qwen3_f32")
    _gpu_fh_extract_k_speck4  = _gpu_mm_load_co("/tmp/extract_k_qwen3_f32_speck4.co", "extract_k_qwen3_f32_speck4")
    _gpu_fh_insert_k_speck4   = _gpu_mm_load_co("/tmp/insert_k_qwen3_f32_speck4.co",  "insert_k_qwen3_f32_speck4")
    _gpu_fh_attn_decode       = _gpu_mm_load_co("/tmp/attn_decode_f32.co",    "attn_decode_f32")
    _gpu_fh_attn_decode_14b   = _gpu_mm_load_co("/tmp/attn_decode_f32_14b.co", "attn_decode_f32_14b")
    _gpu_fh_attn_decode_batched = _gpu_mm_load_co("/tmp/attn_decode_f32_batched.co", "attn_decode_f32_batched")
    _gpu_fh_attn_decode_speck4  = _gpu_mm_load_co("/tmp/attn_decode_f32_speck4.co", "attn_decode_f32_speck4")
    // Slice 4.8 mega-kernel — best-effort load; absence falls back to per-op.
    // Slice 4.19.11: MLRIFT_NATIVE_MEGAKERNEL env-var collapsed.
    //   =1 (was: slice-4.18 byte-wrapper path, removed) — now ALIASES =2
    //      for backward compat with any user shell scripts.
    //   =2 (slice-4.19.0+ AST-walker) — every phase emitted by walking the
    //      @kernel AST in examples/llm/qwen3_layer_megakernel.mlr; fully
    //      native, no byte wrapper.
    //   unset/0 — legacy hipcc-built /tmp/qwen3_layer_megakernel.co (opt-out).
    u64 _native_mk_env = getenv("MLRIFT_NATIVE_MEGAKERNEL")
    u64 _native_mk_mode = 0    // 0 = legacy hipcc, 2 = AST-walker (also =1 alias)
    if _native_mk_env != 0 {
        u8 _nmc = 0; unsafe { *(_native_mk_env as u8) -> _nmc }
        // Slice 4.19.11: =1 aliases =2 (byte-wrapper path removed).
        if _nmc == 49 { _native_mk_mode = 2 }   // '1' -> v2 alias
        if _nmc == 50 { _native_mk_mode = 2 }   // '2' -> v2
    }
    if _native_mk_mode == 2 {
        _gpu_fh_qwen3_megakernel = _gpu_mm_load_co("/tmp/qwen3_layer_megakernel_v2.co", "qwen3_layer_megakernel")
    } else {
        _gpu_fh_qwen3_megakernel = _gpu_mm_load_co("/tmp/qwen3_layer_megakernel.co", "qwen3_layer_megakernel")
    }
    // Slice 4.20.0: speck4 mega-kernel env-var dispatch.
    //   MLRIFT_NATIVE_MEGAKERNEL=2          (unified) — selects v2 for ALL variants
    //   MLRIFT_NATIVE_MEGAKERNEL_SPECK4=2   (per-variant override) — speck4 only
    //   unset/0 — legacy hipcc-built /tmp/qwen3_layer_megakernel_speck4.co.
    u64 _native_mk4_env = getenv("MLRIFT_NATIVE_MEGAKERNEL_SPECK4")
    u64 _native_mk4_mode = 0
    if _native_mk4_env != 0 {
        u8 _nmc4 = 0; unsafe { *(_native_mk4_env as u8) -> _nmc4 }
        if _nmc4 == 50 { _native_mk4_mode = 2 }   // '2'
    }
    // Unified flag: if MLRIFT_NATIVE_MEGAKERNEL=2 was set, also use v2 for speck4.
    if _native_mk_mode == 2 { _native_mk4_mode = 2 }
    if _native_mk4_mode == 2 {
        _gpu_fh_qwen3_megakernel_speck4 = _gpu_mm_load_co("/tmp/qwen3_layer_megakernel_speck4_v2.co", "qwen3_layer_megakernel_speck4")
    } else {
        _gpu_fh_qwen3_megakernel_speck4 = _gpu_mm_load_co("/tmp/qwen3_layer_megakernel_speck4.co", "qwen3_layer_megakernel_speck4")
    }
    _gpu_fh_qwen3_megakernel_speck8 = _gpu_mm_load_co("/tmp/qwen3_layer_megakernel_speck8.co", "qwen3_layer_megakernel_speck8")
    _gpu_fh_qwen3_megakernel_speck16 = _gpu_mm_load_co("/tmp/qwen3_layer_megakernel_speck16.co", "qwen3_layer_megakernel_speck16")
    // Slice 5.8: Llama-3.2-1B M=1 mega-kernel.  Loaded under the same
    // MLRIFT_NATIVE_MEGAKERNEL=1|2 flag as the Qwen3 v2 path; absence
    // (e.g. user did not run --emit-amdgpu-llama-megakernel-v2) is silent
    // — _gpu_mm_load_co returns 0 if the .co file is missing, and the
    // driver's gpu_llama_megakernel_ready() probe falls back to per-op.
    if _native_mk_mode == 2 {
        _gpu_fh_llama_megakernel = _gpu_mm_load_co("/tmp/llama_layer_megakernel_v2.co", "llama_layer_megakernel")
    }
    // Slice 6.4: Llama speck4 (M_EFF=4) mega-kernel.  Loaded under the
    // unified MLRIFT_NATIVE_MEGAKERNEL=2 flag (the only mode that has a
    // working v2 .co for Llama).  Absence is silent — the driver's
    // gpu_llama_megakernel_speck4_ready() probe gates the PLD path off.
    if _native_mk_mode == 2 {
        _gpu_fh_llama_megakernel_speck4 = _gpu_mm_load_co("/tmp/llama_layer_megakernel_speck4_v2.co", "llama_layer_megakernel_speck4")
    }
    if _gpu_mm_fh_dq == 0 || _gpu_mm_fh_gemv == 0 { return }

    _gpu_mm_cache_keys = alloc(_gpu_mm_cache_cap * 8)
    _gpu_mm_cache_vals = alloc(_gpu_mm_cache_cap * 8)
    _gpu_mm_cache_n    = 0
    _gpu_mm_bf16_keys  = alloc(_gpu_mm_cache_cap * 8)
    _gpu_mm_bf16_vals  = alloc(_gpu_mm_cache_cap * 8)
    _gpu_mm_bf16_n     = 0
    _gpu_mm_q4_keys    = alloc(_gpu_mm_cache_cap * 8)
    _gpu_mm_q4_vals    = alloc(_gpu_mm_cache_cap * 8)
    _gpu_mm_q4_n       = 0
    _gpu_mm_bf16_pad_keys = alloc(_gpu_mm_cache_cap * 8)
    _gpu_mm_bf16_pad_vals = alloc(_gpu_mm_cache_cap * 8)
    _gpu_mm_bf16_pad_n    = 0

    // Optional threshold override (decimal bytes).
    u64 thr_env = getenv("MLRIFT_GPU_MATMUL_MIN_BYTES")
    if thr_env != 0 {
        u64 parsed = 0
        u64 i = 0
        u8 c = 0
        unsafe { *(thr_env as u8) -> c }
        while c >= 48 && c <= 57 {
            parsed = parsed * 10 + (c - 48)
            i = i + 1
            unsafe { *((thr_env + i) as u8) -> c }
        }
        if parsed > 0 { _gpu_mm_min_bytes = parsed }
    }

    _gpu_mm_init = 1
}

// Returns 1 if GPU matmul is enabled and ready, 0 otherwise.
fn gpu_matmul_enabled() -> u64 {
    _gpu_mm_init_once()
    if _gpu_mm_init == 1 { return 1 }
    return 0
}

// Look up a cached device f32 weight by host bf16 pointer; return 0 if
// not present.
fn _gpu_mm_cache_lookup(u64 w_bf16) -> u64 {
    u64 i = 0
    while i < _gpu_mm_cache_n {
        u64 kp = _gpu_mm_cache_keys + i * 8
        u64 k = 0; unsafe { *(kp as u64) -> k }
        if k == w_bf16 {
            u64 vp = _gpu_mm_cache_vals + i * 8
            u64 v = 0; unsafe { *(vp as u64) -> v }
            return v
        }
        i = i + 1
    }
    return 0
}

fn _gpu_mm_cache_insert(u64 w_bf16, u64 d_f32) {
    if _gpu_mm_cache_n >= _gpu_mm_cache_cap { return }   // silently drop
    u64 kp = _gpu_mm_cache_keys + _gpu_mm_cache_n * 8
    u64 vp = _gpu_mm_cache_vals + _gpu_mm_cache_n * 8
    unsafe { *(kp as u64) = w_bf16 }
    unsafe { *(vp as u64) = d_f32 }
    _gpu_mm_cache_n = _gpu_mm_cache_n + 1
}

// Parallel cache for the bf16-direct path: maps host bf16 ptr → device
// bf16 ptr.  H2D'd once, never dequanted.
fn _gpu_mm_bf16_lookup(u64 w_bf16) -> u64 {
    u64 i = 0
    while i < _gpu_mm_bf16_n {
        u64 kp = _gpu_mm_bf16_keys + i * 8
        u64 k = 0; unsafe { *(kp as u64) -> k }
        if k == w_bf16 {
            u64 vp = _gpu_mm_bf16_vals + i * 8
            u64 v = 0; unsafe { *(vp as u64) -> v }
            return v
        }
        i = i + 1
    }
    return 0
}

fn _gpu_mm_bf16_insert(u64 w_bf16, u64 d_bf16) {
    if _gpu_mm_bf16_n >= _gpu_mm_cache_cap { return }
    u64 kp = _gpu_mm_bf16_keys + _gpu_mm_bf16_n * 8
    u64 vp = _gpu_mm_bf16_vals + _gpu_mm_bf16_n * 8
    unsafe { *(kp as u64) = w_bf16 }
    unsafe { *(vp as u64) = d_bf16 }
    _gpu_mm_bf16_n = _gpu_mm_bf16_n + 1
}

// Slice 4.19: free the unpadded bf16 weight cache.  Used after warmup
// of the mega-kernel + padded-row path, where per-op gemv_coop_bf16
// will not be called again.  Each cached entry is a hipMalloc'd bf16
// device buffer; hipFree releases it.  Resets cache size to 0.
//
// Returns the number of entries dropped (informational).  Caller should
// only invoke this once they know per-op fallback is no longer needed
// — a subsequent gpu_matmul_to_dev call will re-upload, which is slow.
// Slice 4.20 audit helper: sum every active gpu_buf_reserve allocation.
// Used by qwen3_generate to checkpoint VRAM growth across the warmup
// pipeline.
@export
fn gpu_buf_pool_total() -> u64 {
    u64 sum = 0
    u64 i = 0
    while i < _gpu_buf_pool_n {
        u64 sp = _gpu_buf_pool_size_arr + i * 8
        u64 s = 0; unsafe { *(sp as u64) -> s }
        sum = sum + s
        i = i + 1
    }
    return sum
}

// Sum every cached bf16 weight (unpadded) device buffer.
@export
fn gpu_mm_bf16_cache_total() -> u64 {
    u64 sum = 0
    // We don't store sizes in the cache; assume bf16 = 2 bytes/elem
    // and total bytes = N * K * 2 (we'd need to track but instead
    // return entry count, caller can multiply).
    return _gpu_mm_bf16_n
}

// Sum every cached padded bf16 weight device buffer (slice 4.13).
@export
fn gpu_mm_bf16_pad_cache_total() -> u64 {
    return _gpu_mm_bf16_pad_n
}

@export
fn gpu_mm_drop_bf16_cache() -> u64 {
    u64 dropped = _gpu_mm_bf16_n
    u64 i = 0
    while i < _gpu_mm_bf16_n {
        u64 vp = _gpu_mm_bf16_vals + i * 8
        u64 d_bf16 = 0; unsafe { *(vp as u64) -> d_bf16 }
        if d_bf16 != 0 { hipFree(d_bf16) }
        i = i + 1
    }
    _gpu_mm_bf16_n = 0
    return dropped
}

// Slice 4.20 (lever 2): free the f32 dequant cache.  Used after warmup
// of the mega-kernel + padded-row path where the per-op f32 fallback is
// not exercised in steady state.  Each cached entry is the f32 weight
// tensor produced by _gpu_mm_dequant_weight (bf16 → f32 expansion at
// 256-row padding) — typically 1.5–2× the bf16 size, ~12 MiB per qwen3-
// 0.6B layer matmul.
@export
fn gpu_mm_drop_f32_cache() -> u64 {
    u64 dropped = _gpu_mm_cache_n
    u64 i = 0
    while i < _gpu_mm_cache_n {
        u64 vp = _gpu_mm_cache_vals + i * 8
        u64 d_f32 = 0; unsafe { *(vp as u64) -> d_f32 }
        if d_f32 != 0 { hipFree(d_f32) }
        i = i + 1
    }
    _gpu_mm_cache_n = 0
    return dropped
}

// One-shot H2D of the bf16 weight (no dequant).  Returns the device
// bf16 pointer, or 0 on failure.
fn _gpu_mm_get_or_upload_bf16(u64 w_bf16, u64 K, u64 N) -> u64 {
    u64 cached = _gpu_mm_bf16_lookup(w_bf16)
    if cached != 0 { return cached }

    u64 d_bf16 = 0
    u64 slot = alloc(8)
    u32 err = hipMalloc(slot, N * K * 2)
    if err != 0 { return 0 }
    unsafe { *(slot as u64) -> d_bf16 }
    err = hipMemcpy(d_bf16, w_bf16, N * K * 2, 1)
    if err != 0 { return 0 }

    _gpu_mm_bf16_insert(w_bf16, d_bf16)
    return d_bf16
}

// Slice 4.13: padded-row bf16 uploader for the mega-kernel matmul phases.
// Allocates [N, K_pad] bf16, copies row-by-row from [N, K] host buffer,
// leaves the K..K_pad tail of each row as alloc-time bytes (kernel only
// reads the first K elements per row, so the tail is don't-care).
//
// Cache key folds (w_bf16_host_ptr ^ K_pad).  Since the four matmul
// tensors per layer are distinct host pointers AND get distinct K_pad
// values per matrix shape, collisions are vanishingly unlikely.
fn _gpu_mm_bf16_pad_lookup(u64 w_bf16, u64 K_pad) -> u64 {
    u64 key = w_bf16 ^ K_pad
    u64 i = 0
    while i < _gpu_mm_bf16_pad_n {
        u64 kp = _gpu_mm_bf16_pad_keys + i * 8
        u64 k = 0; unsafe { *(kp as u64) -> k }
        if k == key {
            u64 vp = _gpu_mm_bf16_pad_vals + i * 8
            u64 v = 0; unsafe { *(vp as u64) -> v }
            return v
        }
        i = i + 1
    }
    return 0
}

fn _gpu_mm_bf16_pad_insert(u64 w_bf16, u64 K_pad, u64 d_bf16) {
    if _gpu_mm_bf16_pad_n >= _gpu_mm_cache_cap { return }
    u64 key = w_bf16 ^ K_pad
    u64 kp = _gpu_mm_bf16_pad_keys + _gpu_mm_bf16_pad_n * 8
    u64 vp = _gpu_mm_bf16_pad_vals + _gpu_mm_bf16_pad_n * 8
    unsafe { *(kp as u64) = key }
    unsafe { *(vp as u64) = d_bf16 }
    _gpu_mm_bf16_pad_n = _gpu_mm_bf16_pad_n + 1
}

fn _gpu_mm_get_or_upload_bf16_padded(u64 w_bf16, u64 K, u64 N, u64 K_pad) -> u64 {
    u64 cached = _gpu_mm_bf16_pad_lookup(w_bf16, K_pad)
    if cached != 0 { return cached }

    u64 d_bf16 = 0
    u64 slot = alloc(8)
    u32 err = hipMalloc(slot, N * K_pad * 2)
    if err != 0 { return 0 }
    unsafe { *(slot as u64) -> d_bf16 }

    // Allocate a host-side padded staging buffer, do the row-by-row
    // strided fill on the CPU (memory-bound but parallel-friendly),
    // then a SINGLE bulk hipMemcpy.  N hipMemcpy syncs would dominate
    // cold-start time (~1.4 s for qwen3-0.6B's 140k rows); one bulk
    // copy collapses that to a few ms.
    u64 host_pad = alloc(N * K_pad * 2)
    u64 row = 0
    while row < N {
        u64 src_row = w_bf16 + row * K * 2
        u64 dst_row = host_pad + row * K_pad * 2
        // Copy K * 2 bytes from src_row to dst_row.  Pad bytes after
        // K..K_pad are alloc-time zero; the kernel never reads them.
        memcpy(dst_row, src_row, K * 2)
        row = row + 1
    }
    err = hipMemcpy(d_bf16, host_pad, N * K_pad * 2, 1)
    dealloc(host_pad)
    if err != 0 { return 0 }

    _gpu_mm_bf16_pad_insert(w_bf16, K_pad, d_bf16)
    return d_bf16
}

@export
fn gpu_get_or_upload_bf16_weight_padded(u64 w_bf16_host, u64 K, u64 N, u64 K_pad) -> u64 {
    if gpu_matmul_enabled() == 0 { return 0 }
    return _gpu_mm_get_or_upload_bf16_padded(w_bf16_host, K, N, K_pad)
}

// Q4_0 cache: lookup, insert, get-or-upload.  Same parallel-array
// pattern as the bf16 cache; on miss, CPU-quantizes bf16 → Q4_0,
// allocates a device buffer of N*(K/32)*18 bytes, H2Ds it, frees
// the temporary CPU Q4 buffer, and caches the device pointer.
fn _gpu_mm_q4_lookup(u64 w_bf16) -> u64 {
    u64 i = 0
    while i < _gpu_mm_q4_n {
        u64 kp = _gpu_mm_q4_keys + i * 8
        u64 k = 0; unsafe { *(kp as u64) -> k }
        if k == w_bf16 {
            u64 vp = _gpu_mm_q4_vals + i * 8
            u64 v = 0; unsafe { *(vp as u64) -> v }
            return v
        }
        i = i + 1
    }
    return 0
}

fn _gpu_mm_q4_insert(u64 w_bf16, u64 d_q4) {
    if _gpu_mm_q4_n >= _gpu_mm_cache_cap { return }
    u64 kp = _gpu_mm_q4_keys + _gpu_mm_q4_n * 8
    u64 vp = _gpu_mm_q4_vals + _gpu_mm_q4_n * 8
    unsafe { *(kp as u64) = w_bf16 }
    unsafe { *(vp as u64) = d_q4 }
    _gpu_mm_q4_n = _gpu_mm_q4_n + 1
}

fn _gpu_mm_get_or_upload_q4(u64 w_bf16, u64 K, u64 N) -> u64 {
    u64 cached = _gpu_mm_q4_lookup(w_bf16)
    if cached != 0 { return cached }
    if (K & 31) != 0 { return 0 }

    u64 q4_bytes = N * (K >> 5) * 18
    u64 host_q4 = alloc(q4_bytes)
    u64 actual = quantize_bf16_to_q4_0(w_bf16, host_q4, N, K)
    if actual == 0 { dealloc(host_q4); return 0 }

    u64 d_q4 = 0
    u64 slot = alloc(8)
    u32 err = hipMalloc(slot, q4_bytes)
    if err != 0 { dealloc(host_q4); return 0 }
    unsafe { *(slot as u64) -> d_q4 }
    err = hipMemcpy(d_q4, host_q4, q4_bytes, 1)
    if err != 0 { dealloc(host_q4); return 0 }

    dealloc(host_q4)
    _gpu_mm_q4_insert(w_bf16, d_q4)
    return d_q4
}

// First-call dequant: H2D the bf16 weight, run bf16_to_f32 on device,
// free the bf16 device buffer, return the persistent f32 device pointer.
fn _gpu_mm_dequant_weight(u64 w_bf16, u64 K, u64 N) -> u64 {
    u64 n_elems = K * N

    // Pad row count up to a multiple of 256 (gemv block size).  The
    // gemv kernel's `v_cmpx_lt_u64 s[10:11], v[1:2]` bounds check has
    // a partial-wave bug — for any unaligned N the last wave hangs
    // (verified empirically: aligned N=131072 ✓, unaligned 131073 ✗).
    // Working around by always running on padded N so every wave is
    // entirely in-bounds.  Padding rows in d_W_f32 stay uninitialised;
    // gemv's writes for rows ≥ N go to padded slots in d_out that the
    // caller never reads.
    u64 N_padded = ((N + 255) / 256) * 256
    u64 n_elems_padded = K * N_padded

    u64 d_W_bf16 = 0
    u64 slot = alloc(8)
    u32 err = hipMalloc(slot, n_elems * 2)
    if err != 0 { return 0 }
    unsafe { *(slot as u64) -> d_W_bf16 }
    err = hipMemcpy(d_W_bf16, w_bf16, n_elems * 2, 1)
    if err != 0 { return 0 }

    u64 d_W_f32 = 0
    slot = alloc(8)
    err = hipMalloc(slot, n_elems_padded * 4)
    if err != 0 { return 0 }
    unsafe { *(slot as u64) -> d_W_f32 }

    u64 a0 = alloc(8); unsafe { *(a0 as u64) = d_W_bf16 }
    u64 a1 = alloc(8); unsafe { *(a1 as u64) = d_W_f32 }
    u64 a2 = alloc(8); unsafe { *(a2 as u64) = n_elems }
    u64 kp = alloc(3 * 8)
    unsafe { *(kp        as u64) = a0 }
    unsafe { *((kp +  8) as u64) = a1 }
    unsafe { *((kp + 16) as u64) = a2 }
    u64 grid_u = (n_elems + 255) / 256
    u32 grid32 = grid_u
    err = hipModuleLaunchKernel(_gpu_mm_fh_dq, grid32, 1, 1, 256, 1, 1, 0, 0, kp, 0)
    if err != 0 { return 0 }
    err = hipDeviceSynchronize()
    if err != 0 { return 0 }

    hipFree(d_W_bf16)
    return d_W_f32
}

fn _gpu_mm_get_or_dequant(u64 w_bf16, u64 K, u64 N) -> u64 {
    u64 cached = _gpu_mm_cache_lookup(w_bf16)
    if cached != 0 { return cached }
    u64 fresh = _gpu_mm_dequant_weight(w_bf16, K, N)
    if fresh == 0 { return 0 }
    _gpu_mm_cache_insert(w_bf16, fresh)
    return fresh
}

fn _gpu_mm_ensure_x_buf(u64 want_bytes) -> u64 {
    if _gpu_mm_d_x_cap >= want_bytes { return _gpu_mm_d_x_buf }
    if _gpu_mm_d_x_buf != 0 { dev_free(_gpu_mm_d_x_buf) }
    u64 va = dev_try_alloc_host_visible(want_bytes)
    if va == 0 { return 0 }
    _gpu_mm_d_x_buf = va
    _gpu_mm_d_x_h   = dev_host_ptr(va)
    _gpu_mm_d_x_cap = want_bytes
    return va
}

fn _gpu_mm_ensure_out_buf(u64 want_bytes) -> u64 {
    if _gpu_mm_d_out_cap >= want_bytes { return _gpu_mm_d_out_buf }
    if _gpu_mm_d_out_buf != 0 { dev_free(_gpu_mm_d_out_buf) }
    u64 va = dev_try_alloc_host_visible(want_bytes)
    if va == 0 { return 0 }
    _gpu_mm_d_out_buf = va
    _gpu_mm_d_out_h   = dev_host_ptr(va)
    _gpu_mm_d_out_cap = want_bytes
    return va
}

// === Public dispatch ===
//
// Computes out[m, n] = sum_k x[m, k] * w_bf16[n, k]  (HF convention).
// Returns 0 on success (GPU ran the matmul + D2H'd the result).
// Returns 1 on fall-through (caller should run the CPU path).
fn matmul_bf16_weights_f32_gpu(u64 out_ptr, u64 x_ptr, u64 w_bf16,
                                u64 M, u64 N, u64 K) -> u64 {
    if gpu_matmul_enabled() == 0 { return 1 }

    // Fall-through for shapes the dispatcher doesn't yet handle.
    // M=1: gemv path.  M ≥ 16: gemm path (NOT yet wired — needs weight
    //                          transpose-on-load).
    if M != 1 { return 1 }

    // Skip small projections — at the decode shape M=1 the per-call
    // sync floor (~110 µs) plus per-call wrapper overhead exceeds the
    // CPU-AVX2 wallclock for weights below ~32 MB.  Keep them on CPU.
    u64 w_bytes = N * K * 2
    if w_bytes < _gpu_mm_min_bytes { return 1 }

    // Slice 4.20 (lever 2): hoist use_coop/use_bf16 selection BEFORE the
    // f32 dequant to avoid uploading a wasted f32 copy when bf16-direct
    // will be selected.  Saves ~750 MiB peak VRAM during prefill where
    // bf16-direct is the default for N ≥ 4096.
    u64 use_coop = 0
    if _gpu_mm_fh_gemv_coop != 0 {
        if N >= 4096 { use_coop = 1 }
    }
    u64 use_bf16 = 0
    if use_coop != 0 {
        if _gpu_mm_fh_gemv_coop_bf16 != 0 {
            use_bf16 = 1
            u64 bf16_env = getenv("MLRIFT_GPU_MATMUL_BF16")
            if bf16_env != 0 {
                u8 bc = 0; unsafe { *(bf16_env as u8) -> bc }
                if bc == 48 { use_bf16 = 0 }   // explicit '0' = opt-out
            }
        }
    }
    if use_bf16 != 0 && N > 65536 { use_bf16 = 0 }

    u64 d_W_f32 = 0
    if use_bf16 == 0 {
        d_W_f32 = _gpu_mm_get_or_dequant(w_bf16, K, N)
        if d_W_f32 == 0 { return 1 }
    }

    u64 d_x = _gpu_mm_ensure_x_buf(K * 4)
    if d_x == 0 { return 1 }
    // Direct memcpy via the cached host-mapped GTT pointer; skips the
    // kind=1 dispatch in hipMemcpy (parallel-WC for ≥1 MB chunks) which
    // is wrong for the few-KB activation case.
    memcpy(_gpu_mm_d_x_h, x_ptr, K * 4)

    // Same 256-padding as the dequant path — see _gpu_mm_dequant_weight.
    u64 N_padded = ((N + 255) / 256) * 256
    u64 d_out = _gpu_mm_ensure_out_buf(N_padded * 4)
    if d_out == 0 { return 1 }
    u32 err = 0

    // gemv_f32: c[m] = A[m, k] @ b[k]
    //   args: A_ptr, b_ptr, c_ptr, M (rows), K (cols)
    //   block = 256, grid = ceil(M/256)
    // For our HF call: A = W (rows=N), b = x[0..K), c = out[0..N).
    u64 a0 = alloc(8); unsafe { *(a0 as u64) = d_W_f32 }
    u64 a1 = alloc(8); unsafe { *(a1 as u64) = d_x }
    u64 a2 = alloc(8); unsafe { *(a2 as u64) = d_out }
    u64 a3 = alloc(8); unsafe { *(a3 as u64) = N_padded }
    u64 a4 = alloc(8); unsafe { *(a4 as u64) = K }
    u64 kp = alloc(5 * 8)
    unsafe { *(kp        as u64) = a0 }
    unsafe { *((kp +  8) as u64) = a1 }
    unsafe { *((kp + 16) as u64) = a2 }
    unsafe { *((kp + 24) as u64) = a3 }
    unsafe { *((kp + 32) as u64) = a4 }
    u64 grid_u = N_padded / 256
    u32 grid32 = grid_u

    if use_bf16 != 0 {
        // bf16-direct path: substitute d_W_bf16 for d_W_f32 in kernarg.
        u64 d_W_bf16 = _gpu_mm_get_or_upload_bf16(w_bf16, K, N)
        if d_W_bf16 == 0 { return 1 }
        unsafe { *(a0 as u64) = d_W_bf16 }
        unsafe { *(a3 as u64) = N }
        u32 cgrid = N
        err = hipModuleLaunchKernel(_gpu_mm_fh_gemv_coop_bf16, cgrid, 1, 1, 32, 1, 1, 0, 0, kp, 0)
    } else if use_coop != 0 {
        // gemv_coop_f32: block=32 (1 wave), grid=N (1 row per WG).
        unsafe { *(a3 as u64) = N }
        u32 cgrid = N
        err = hipModuleLaunchKernel(_gpu_mm_fh_gemv_coop, cgrid, 1, 1, 32, 1, 1, 0, 0, kp, 0)
    } else {
        err = hipModuleLaunchKernel(_gpu_mm_fh_gemv, grid32, 1, 1, 256, 1, 1, 0, 0, kp, 0)
    }
    if err != 0 { return 1 }
    err = hipDeviceSynchronize()
    if err != 0 { return 1 }

    // Direct memcpy from GTT — system RAM read, native DRAM rate.
    memcpy(out_ptr, _gpu_mm_d_out_h, N * 4)
    return 0
}

// Diagnostic: how many weight matrices are currently cached on device.
fn gpu_matmul_cache_count() -> u64 { return _gpu_mm_cache_n }

// =============================================================
// Async device-pointer pipeline API (for full-GPU forward chains)
// =============================================================
//
// Convention: every `gpu_*_to_dev` function takes device-VA pointers
// and launches its kernel WITHOUT calling hipDeviceSynchronize.  The
// caller chains as many of these as needed, then calls gpu_pipeline_
// flush() to drain.  Single sync per chain (per layer or per step)
// instead of per-call.
//
// Validation: see examples/llm/gpu_chain_demo.mlr — confirmed 35 %
// per-iter saving over the per-call-sync path on the test shape.

// gpu_resid_add_to_dev: c[i] = a[i] + b[i] for i in [0, N).
// Kernarg layout (matches _emit_residual_add_f32_body):
//   [0x00] in_a (d_va)
//   [0x08] in_b (d_va)
//   [0x10] out  (d_va)
//   [0x18] N    (u64, low 32 used)
fn gpu_resid_add_to_dev(u64 d_out, u64 d_a, u64 d_b, u64 N) -> u64 {
    if _gpu_fh_resid_add == 0 { return 1 }
    u64 a0 = alloc(8); unsafe { *(a0 as u64) = d_a }
    u64 a1 = alloc(8); unsafe { *(a1 as u64) = d_b }
    u64 a2 = alloc(8); unsafe { *(a2 as u64) = d_out }
    u64 a3 = alloc(8); unsafe { *(a3 as u64) = N }
    u64 kp = alloc(4 * 8)
    unsafe { *(kp        as u64) = a0 }
    unsafe { *((kp +  8) as u64) = a1 }
    unsafe { *((kp + 16) as u64) = a2 }
    unsafe { *((kp + 24) as u64) = a3 }
    u64 grid_u = (N + 255) / 256
    u32 grid32 = grid_u
    u32 err = hipModuleLaunchKernel(_gpu_fh_resid_add, grid32, 1, 1, 256, 1, 1, 0, 0, kp, 0)
    if err != 0 { return 1 }
    return 0
}

// gpu_silu_mul_to_dev: c[i] = silu(gate[i]) * up[i] for i in [0, N).
// Kernarg layout (matches _emit_silu_mul_f32_body):
//   [0x00] gate
//   [0x08] up
//   [0x10] out
//   [0x18] N
fn gpu_silu_mul_to_dev(u64 d_out, u64 d_gate, u64 d_up, u64 N) -> u64 {
    if _gpu_fh_silu_mul == 0 { return 1 }
    u64 a0 = alloc(8); unsafe { *(a0 as u64) = d_gate }
    u64 a1 = alloc(8); unsafe { *(a1 as u64) = d_up }
    u64 a2 = alloc(8); unsafe { *(a2 as u64) = d_out }
    u64 a3 = alloc(8); unsafe { *(a3 as u64) = N }
    u64 kp = alloc(4 * 8)
    unsafe { *(kp        as u64) = a0 }
    unsafe { *((kp +  8) as u64) = a1 }
    unsafe { *((kp + 16) as u64) = a2 }
    unsafe { *((kp + 24) as u64) = a3 }
    u64 grid_u = (N + 255) / 256
    u32 grid32 = grid_u
    u32 err = hipModuleLaunchKernel(_gpu_fh_silu_mul, grid32, 1, 1, 256, 1, 1, 0, 0, kp, 0)
    if err != 0 { return 1 }
    return 0
}

// gpu_rmsnorm_1024_to_dev: out[m,i] = x[m,i] * rsqrt(mean(x²)+eps) * gamma[i]
// for the hidden-dim shape (N=1024).  Block size = N (= 1024).
// Kernarg layout (matches _emit_rmsnorm_f32_body_N):
//   [0x00] in
//   [0x08] out
//   [0x10] gamma
//   [0x18] M  (number of rows; = 1 for decode)
//   [0x20] N  (= 1024)
fn gpu_rmsnorm_1024_to_dev(u64 d_out, u64 d_in, u64 d_gamma, u64 M) -> u64 {
    return gpu_rmsnorm_hidden_to_dev(d_out, d_in, d_gamma, M, 1024)
}

// Slice 2c — fused qknorm + rope_qk.  One launch over (nh_q + nh_k) WGs
// instead of four separate launches (qknorm Q, qknorm K, rope Q, rope K).
// Kernarg layout (must match the emit body):
//   0x00 q_inout, 0x08 k_inout, 0x10 q_gamma, 0x18 k_gamma,
//   0x20 cos_ptr, 0x28 sin_ptr, 0x30 nh_q, 0x38 nh_k
// Grid = nh_q + nh_k, block_x = 128.  Loads /tmp/qknorm_rope_qk_fused_f32.co.
static u64 _gpu_fh_qknorm_rope_qk      = 0
static u64 _gpu_fh_qknorm_rope_qk_init = 0

fn gpu_qknorm_rope_qk_fused_to_dev(u64 d_q_inout, u64 d_k_inout,
                                     u64 d_q_gamma, u64 d_k_gamma,
                                     u64 d_cos, u64 d_sin,
                                     u64 nh_q, u64 nh_k) -> u64 {
    if _gpu_fh_qknorm_rope_qk_init == 0 {
        _gpu_fh_qknorm_rope_qk_init = 1
        _gpu_fh_qknorm_rope_qk = _gpu_mm_load_co(
            "/tmp/qknorm_rope_qk_fused_f32.co", "qknorm_rope_qk_fused_f32")
    }
    if _gpu_fh_qknorm_rope_qk == 0 { return 1 }
    u64 g0 = alloc(8); unsafe { *(g0 as u64) = d_q_inout }
    u64 g1 = alloc(8); unsafe { *(g1 as u64) = d_k_inout }
    u64 g2 = alloc(8); unsafe { *(g2 as u64) = d_q_gamma }
    u64 g3 = alloc(8); unsafe { *(g3 as u64) = d_k_gamma }
    u64 g4 = alloc(8); unsafe { *(g4 as u64) = d_cos }
    u64 g5 = alloc(8); unsafe { *(g5 as u64) = d_sin }
    u64 g6 = alloc(8); unsafe { *(g6 as u64) = nh_q }
    u64 g7 = alloc(8); unsafe { *(g7 as u64) = nh_k }
    u64 kp = alloc(8 * 8)
    unsafe { *(kp        as u64) = g0 }
    unsafe { *((kp +  8) as u64) = g1 }
    unsafe { *((kp + 16) as u64) = g2 }
    unsafe { *((kp + 24) as u64) = g3 }
    unsafe { *((kp + 32) as u64) = g4 }
    unsafe { *((kp + 40) as u64) = g5 }
    unsafe { *((kp + 48) as u64) = g6 }
    unsafe { *((kp + 56) as u64) = g7 }
    u32 grid32 = nh_q + nh_k
    u32 err = hipModuleLaunchKernel(_gpu_fh_qknorm_rope_qk,
                                     grid32, 1, 1, 128, 1, 1, 0, 0, kp, 0)
    if err != 0 { return 1 }
    return 0
}

// Slice 2b — fused residual_add + rmsnorm.  One launch instead of
// two for the resid+post_norm pair (twice per qwen3 layer).
// Kernarg layout (SGPR-reorder trick — must match the emit body):
//   0x00 in_a, 0x08 out_norm, 0x10 gamma, 0x18 m, 0x20 n,
//   0x28 in_b, 0x30 out_resid
// Grid = M, block_x = N.  Loads /tmp/residual_rmsnorm_f32_1024.co.
static u64 _gpu_fh_residual_rmsnorm_1024 = 0
static u64 _gpu_fh_residual_rmsnorm_init = 0

fn gpu_residual_rmsnorm_1024_to_dev(u64 d_a, u64 d_b,
                                     u64 d_resid, u64 d_norm,
                                     u64 d_gamma, u64 M) -> u64 {
    if _gpu_fh_residual_rmsnorm_init == 0 {
        _gpu_fh_residual_rmsnorm_init = 1
        _gpu_fh_residual_rmsnorm_1024 = _gpu_mm_load_co(
            "/tmp/residual_rmsnorm_f32_1024.co", "residual_rmsnorm_f32")
    }
    if _gpu_fh_residual_rmsnorm_1024 == 0 { return 1 }
    u64 N = 1024
    u64 g0 = alloc(8); unsafe { *(g0 as u64) = d_a }
    u64 g1 = alloc(8); unsafe { *(g1 as u64) = d_norm }
    u64 g2 = alloc(8); unsafe { *(g2 as u64) = d_gamma }
    u64 g3 = alloc(8); unsafe { *(g3 as u64) = M }
    u64 g4 = alloc(8); unsafe { *(g4 as u64) = N }
    u64 g5 = alloc(8); unsafe { *(g5 as u64) = d_b }
    u64 g6 = alloc(8); unsafe { *(g6 as u64) = d_resid }
    u64 kp = alloc(7 * 8)
    unsafe { *(kp        as u64) = g0 }
    unsafe { *((kp +  8) as u64) = g1 }
    unsafe { *((kp + 16) as u64) = g2 }
    unsafe { *((kp + 24) as u64) = g3 }
    unsafe { *((kp + 32) as u64) = g4 }
    unsafe { *((kp + 40) as u64) = g5 }
    unsafe { *((kp + 48) as u64) = g6 }
    u32 grid32 = M
    u32 bx32 = N
    u32 err = hipModuleLaunchKernel(_gpu_fh_residual_rmsnorm_1024,
                                     grid32, 1, 1, bx32, 1, 1, 0, 0, kp, 0)
    if err != 0 { return 1 }
    return 0
}

// Shape-aware rmsnorm dispatch: picks the kernel matching N (the row
// length).  Each variant must be pre-emitted with the right N-baked
// kernel body via --emit-amdgpu-rmsnorm-f32-N=<N>.  Block size for the
// small-N path is N; for the large-N (N > 1024) path it's 1024 with
// thread-coarsening — the variant decides internally based on its
// emitted body, so we always dispatch with block_x = min(N, 1024).
fn gpu_rmsnorm_hidden_to_dev(u64 d_out, u64 d_in, u64 d_gamma, u64 M, u64 N) -> u64 {
    u64 fh = 0
    u64 block_x = N
    if N == 1024 {
        fh = _gpu_fh_rmsnorm_1024
        block_x = 1024
    } else if N == 5120 {
        fh = _gpu_fh_rmsnorm_5120
        block_x = 1024    // thread-coarsened: K = ceil(5120/1024) = 5
    }
    if fh == 0 { return 1 }

    u64 a0 = alloc(8); unsafe { *(a0 as u64) = d_in }
    u64 a1 = alloc(8); unsafe { *(a1 as u64) = d_out }
    u64 a2 = alloc(8); unsafe { *(a2 as u64) = d_gamma }
    u64 a3 = alloc(8); unsafe { *(a3 as u64) = M }
    u64 a4 = alloc(8); unsafe { *(a4 as u64) = N }
    u64 kp = alloc(5 * 8)
    unsafe { *(kp        as u64) = a0 }
    unsafe { *((kp +  8) as u64) = a1 }
    unsafe { *((kp + 16) as u64) = a2 }
    unsafe { *((kp + 24) as u64) = a3 }
    unsafe { *((kp + 32) as u64) = a4 }
    u32 grid32 = M
    u32 bx32 = block_x
    u32 err = hipModuleLaunchKernel(fh, grid32, 1, 1, bx32, 1, 1, 0, 0, kp, 0)
    if err != 0 { return 1 }
    return 0
}

// gpu_pipeline_flush: drain all pending kernel launches.  Call this
// before reading any chained output via D2H.
fn gpu_pipeline_flush() -> u64 {
    u32 err = hipDeviceSynchronize()
    if err != 0 { return 1 }
    return 0
}

// gpu_matmul_to_dev: out_dev[N] = w_bf16[N,K] @ x_dev[K], M=1.
// Caller supplies pre-allocated device buffers for x and out; the
// weight goes through the same dequant cache as matmul_bf16_weights_
// f32_gpu.  No H2D, no D2H, no sync — meant to be chained.
//
// Returns 0 on success (kernel queued).  Returns 1 if the GPU path is
// unavailable or if N < 4096 (small-N kernel doesn't make sense in
// the chained path; caller should avoid those shapes here).
fn gpu_matmul_to_dev(u64 d_out, u64 d_x, u64 w_bf16, u64 N, u64 K) -> u64 {
    if gpu_matmul_enabled() == 0 { return 1 }
    if _gpu_mm_fh_gemv_coop == 0 { return 1 }

    // Decode shapes on the chained path (N = 1024..6144) are
    // compute-bound, not memory-bound, so the bf16-direct kernel's
    // per-fmac lshl16 makes it ~1-2 % slower than the f32 path
    // empirically.  bf16-direct stays on the legacy lm_head path
    // (N ≈ 152 k, memory-bound).  Set MLRIFT_GPU_MATMUL_BF16=1 to
    // opt in here for benchmarking.
    u64 use_bf16 = 0
    if _gpu_mm_fh_gemv_coop_bf16 != 0 {
        u64 bf16_env = getenv("MLRIFT_GPU_MATMUL_BF16")
        if bf16_env != 0 {
            u8 bc = 0; unsafe { *(bf16_env as u8) -> bc }
            if bc != 48 { use_bf16 = 1 }
        }
    }

    u64 d_W = 0
    if use_bf16 != 0 {
        d_W = _gpu_mm_get_or_upload_bf16(w_bf16, K, N)
    } else {
        d_W = _gpu_mm_get_or_dequant(w_bf16, K, N)
    }
    if d_W == 0 { return 1 }

    u64 a0 = alloc(8); unsafe { *(a0 as u64) = d_W }
    u64 a1 = alloc(8); unsafe { *(a1 as u64) = d_x }
    u64 a2 = alloc(8); unsafe { *(a2 as u64) = d_out }
    u64 a3 = alloc(8); unsafe { *(a3 as u64) = N }
    u64 a4 = alloc(8); unsafe { *(a4 as u64) = K }
    u64 kp = alloc(5 * 8)
    unsafe { *(kp        as u64) = a0 }
    unsafe { *((kp +  8) as u64) = a1 }
    unsafe { *((kp + 16) as u64) = a2 }
    unsafe { *((kp + 24) as u64) = a3 }
    unsafe { *((kp + 32) as u64) = a4 }

    u32 cgrid = N
    u64 fh = _gpu_mm_fh_gemv_coop
    if use_bf16 != 0 { fh = _gpu_mm_fh_gemv_coop_bf16 }
    u32 err = hipModuleLaunchKernel(fh, cgrid, 1, 1, 32, 1, 1, 0, 0, kp, 0)
    if err != 0 { return 1 }
    return 0
}

// gpu_attn_decode_to_dev_speck4: multi-Q attention for spec_K=4
// (Phase 2 Slice 2.1).  Q/out are [4, q_dim] contiguous.  d_kc_layer
// and d_vc_layer point to a SINGLE sequence's KV-cache slab (no per-
// batch slab — speculative shares one history across all 4 queries).
// Caller writes K speculative K/V entries to positions pos..pos+K-1
// before launching, then passes pos_plus_1 = pos + K.  The kernel's
// causal-within-K-window mask cuts off Q[m] at t = pos+m+1.
//
// Returns 0 on success.
fn gpu_attn_decode_to_dev_speck4(u64 d_q, u64 d_kc_layer, u64 d_vc_layer,
                                  u64 d_out, u64 pos_plus_1) -> u64 {
    if _gpu_fh_attn_decode_speck4 == 0 { return 1 }
    u64 a0 = alloc(8); unsafe { *(a0 as u64) = d_q }
    u64 a1 = alloc(8); unsafe { *(a1 as u64) = d_kc_layer }
    u64 a2 = alloc(8); unsafe { *(a2 as u64) = d_vc_layer }
    u64 a3 = alloc(8); unsafe { *(a3 as u64) = d_out }
    u64 a4 = alloc(8); unsafe { *(a4 as u64) = pos_plus_1 }
    u64 kp = alloc(5 * 8)
    unsafe { *(kp        as u64) = a0 }
    unsafe { *((kp +  8) as u64) = a1 }
    unsafe { *((kp + 16) as u64) = a2 }
    unsafe { *((kp + 24) as u64) = a3 }
    unsafe { *((kp + 32) as u64) = a4 }
    // Grid (nh=16, K=4, 1); block 32.
    u32 err = hipModuleLaunchKernel(_gpu_fh_attn_decode_speck4,
                                     16, 4, 1, 32, 1, 1, 0, 0, kp, 0)
    if err != 0 { return 1 }
    return 0
}

// gpu_attn_decode_to_dev_batched: batched fused decode-attention.
// Grid (nh, batch_size, 1).  Q/out are [batch, q_dim] contiguous;
// kc/vc are layer-batch-slab pointers (= layer_base + 0 for layer L,
// kernel adds wg_id_y * 262144 to reach batch_idx's KV slab).
// Returns 0 on success.
fn gpu_attn_decode_to_dev_batched(u64 d_q, u64 d_kc_layer, u64 d_vc_layer,
                                   u64 d_out, u64 pos_plus_1,
                                   u64 batch_size) -> u64 {
    // Shape-aware: 14B uses the same single-stream variant at
    // batch_size=1 (per-batch shifts inside the batched kernel are
    // hardcoded to 0.6B's qkv strides; at 14B with batch_size=1 the
    // wg_y-times-stride term is 0 anyway, so the SINGLE-STREAM kernel
    // is functionally equivalent and has the kv_ratio=5 divide).
    u64 fh = _gpu_fh_attn_decode_batched
    u64 nh = _gpu_arch_n_heads
    if nh == 40 && batch_size == 1 {
        // Use the 14B single-stream attn (kv_ratio=5 baked in).
        // Its grid expects (nh, 1, 1) which matches our dispatch here.
        fh = _gpu_fh_attn_decode_14b
    }
    if fh == 0 { return 1 }
    u64 a0 = alloc(8); unsafe { *(a0 as u64) = d_q }
    u64 a1 = alloc(8); unsafe { *(a1 as u64) = d_kc_layer }
    u64 a2 = alloc(8); unsafe { *(a2 as u64) = d_vc_layer }
    u64 a3 = alloc(8); unsafe { *(a3 as u64) = d_out }
    u64 a4 = alloc(8); unsafe { *(a4 as u64) = pos_plus_1 }
    u64 kp = alloc(5 * 8)
    unsafe { *(kp        as u64) = a0 }
    unsafe { *((kp +  8) as u64) = a1 }
    unsafe { *((kp + 16) as u64) = a2 }
    unsafe { *((kp + 24) as u64) = a3 }
    unsafe { *((kp + 32) as u64) = a4 }
    u32 cgrid_x = nh
    u32 cgrid_y = batch_size
    u32 err = hipModuleLaunchKernel(fh, cgrid_x, cgrid_y, 1, 32, 1, 1, 0, 0, kp, 0)
    if err != 0 { return 1 }
    return 0
}

// gpu_qknorm_f32_to_dev: per-head N=128 RMSNorm × M heads in one launch.
// Each WG normalises one head's 128-element slice with the shared
// `gamma` weight (from q_norm_w / k_norm_w in Qwen3).  Used by Step D
// of the attn wiring to move qknorm onto the GPU and let the qkv-matmul
// → qknorm → rope → attn chain skip the sync-1 round-trip to the CPU.
//
// Returns 0 on success.
fn gpu_qknorm_f32_to_dev(u64 d_out, u64 d_in, u64 d_gamma, u64 M) -> u64 {
    if _gpu_fh_rmsnorm_128 == 0 { return 1 }
    u64 a0 = alloc(8); unsafe { *(a0 as u64) = d_in }
    u64 a1 = alloc(8); unsafe { *(a1 as u64) = d_out }
    u64 a2 = alloc(8); unsafe { *(a2 as u64) = d_gamma }
    u64 a3 = alloc(8); unsafe { *(a3 as u64) = M }
    u64 a4 = alloc(8); unsafe { *(a4 as u64) = 128 }
    u64 kp = alloc(5 * 8)
    unsafe { *(kp        as u64) = a0 }
    unsafe { *((kp +  8) as u64) = a1 }
    unsafe { *((kp + 16) as u64) = a2 }
    unsafe { *((kp + 24) as u64) = a3 }
    unsafe { *((kp + 32) as u64) = a4 }
    u32 grid32 = M
    u32 err = hipModuleLaunchKernel(_gpu_fh_rmsnorm_128, grid32, 1, 1, 128, 1, 1, 0, 0, kp, 0)
    if err != 0 { return 1 }
    return 0
}

// gpu_matmul_to_dev_batched: batched-decode matmul.  Computes
//   out[batch, N] = w_bf16[N, K] @ x[batch, K]^T
// with W-read shared across all `batch` streams, so per-stream cost
// stays approximately constant as batch grows.  Used by the Phase 1
// batched-decode path; falls through to the single-stream
// gpu_matmul_to_dev when batch_size == 1 (caller's responsibility).
//
// Returns 0 on success.
fn gpu_matmul_to_dev_batched(u64 d_out, u64 d_x, u64 w_bf16,
                              u64 N, u64 K, u64 batch_size) -> u64 {
    if gpu_matmul_enabled() == 0 { return 1 }
    if _gpu_mm_fh_gemv_coop_batched == 0 { return 1 }
    if batch_size == 0 { return 1 }

    // bf16-direct is the DEFAULT for batched matmul (matches the
    // single-stream path).  Halves weight bandwidth on memory-bound
    // shapes (lm_head 152k × 1024 = 622 MB f32 → 311 MB bf16).  Opt
    // out via MLRIFT_GPU_MATMUL_BF16=0.
    // Q4_0-direct opt-in (takes priority over bf16) via MLRIFT_GPU_MATMUL_Q4.
    u64 use_q4 = 0
    if _gpu_mm_fh_gemv_coop_batched_q4_0 != 0 {
        u64 q4_env = getenv("MLRIFT_GPU_MATMUL_Q4")
        if q4_env != 0 {
            u8 qc = 0; unsafe { *(q4_env as u8) -> qc }
            if qc != 48 { use_q4 = 1 }
        }
    }
    if use_q4 != 0 && N > 65536 { use_q4 = 0 }

    u64 use_bf16 = 0
    if use_q4 == 0 && _gpu_mm_fh_gemv_coop_batched_bf16 != 0 {
        use_bf16 = 1
        u64 bf16_env = getenv("MLRIFT_GPU_MATMUL_BF16")
        if bf16_env != 0 {
            u8 bc = 0; unsafe { *(bf16_env as u8) -> bc }
            if bc == 48 { use_bf16 = 0 }   // explicit '0' = opt-out
        }
    }
    // Cap bf16-direct dispatch to N ≤ 65536.  At qwen3 lm_head shape
    // (N=151936) the bf16 kernel hangs the GPU queue when run at
    // batch>1 (root cause uninvestigated; the f32 batched kernel at
    // the same shape is fine).  qwen3 inner-layer projections all
    // have N ≤ 6144, so the cap doesn't lose the layer-sweep gain.
    // Override via MLRIFT_GPU_MATMUL_BF16_MAX_N for benchmarking.
    if use_bf16 != 0 {
        u64 max_n = 65536
        u64 max_n_env = getenv("MLRIFT_GPU_MATMUL_BF16_MAX_N")
        if max_n_env != 0 {
            u64 parsed = 0; u64 mn_i = 0
            u8 mn_c = 0; unsafe { *(max_n_env as u8) -> mn_c }
            while mn_c >= 48 && mn_c <= 57 {
                parsed = parsed * 10 + (mn_c - 48); mn_i = mn_i + 1
                unsafe { *((max_n_env + mn_i) as u8) -> mn_c }
            }
            if parsed > 0 { max_n = parsed }
        }
        if N > max_n { use_bf16 = 0 }
    }

    u64 d_W = 0
    if use_q4 != 0 {
        d_W = _gpu_mm_get_or_upload_q4(w_bf16, K, N)
    } else if use_bf16 != 0 {
        d_W = _gpu_mm_get_or_upload_bf16(w_bf16, K, N)
    } else {
        d_W = _gpu_mm_get_or_dequant(w_bf16, K, N)
    }
    if d_W == 0 { return 1 }

    _gpu_kp_reset()
    u64 a0 = _gpu_kp_bump(8); unsafe { *(a0 as u64) = d_W }
    u64 a1 = _gpu_kp_bump(8); unsafe { *(a1 as u64) = d_x }
    u64 a2 = _gpu_kp_bump(8); unsafe { *(a2 as u64) = d_out }
    u64 a3 = _gpu_kp_bump(8); unsafe { *(a3 as u64) = N }
    u64 a4 = _gpu_kp_bump(8); unsafe { *(a4 as u64) = K }
    u64 kp = _gpu_kp_bump(5 * 8)
    unsafe { *(kp        as u64) = a0 }
    unsafe { *((kp +  8) as u64) = a1 }
    unsafe { *((kp + 16) as u64) = a2 }
    unsafe { *((kp + 24) as u64) = a3 }
    unsafe { *((kp + 32) as u64) = a4 }

    // Grid (N, batch, 1); block (32, 1, 1).  All three kernels (f32,
    // bf16-direct, Q4_0-direct) expect the same kernarg layout and
    // read wg_id_y from s16 (rsrc2 = 0x019E enables both x and y wg ids).
    u64 fh = _gpu_mm_fh_gemv_coop_batched
    if use_bf16 != 0 { fh = _gpu_mm_fh_gemv_coop_batched_bf16 }
    if use_q4 != 0   { fh = _gpu_mm_fh_gemv_coop_batched_q4_0 }
    u32 cgrid_x = N
    u32 cgrid_y = batch_size
    u32 err = hipModuleLaunchKernel(fh, cgrid_x, cgrid_y, 1, 32, 1, 1, 0, 0, kp, 0)
    if err != 0 { return 1 }
    return 0
}

// gpu_qkv_split_f32_batched_to_dev: ONE batched dispatch covers M
// streams' qkv → K-slot/V-slot extraction.  Grid (8, batch_size, 1).
// Caller passes layer-base K/V pointers (= kv_layer_base + pos *
// kv_row_bytes for batch=0); the kernel adds wg_id_y * 262144 to
// reach the per-batch slot.  Returns 0 on success.
fn gpu_qkv_split_f32_batched_to_dev(u64 d_qkv, u64 d_k_slot_base, u64 d_v_slot_base,
                                     u64 batch_size) -> u64 {
    // Shape-aware dispatch: pick 14B variant when q_dim=5120 (vs 0.6B's 2048).
    u64 fh = _gpu_fh_qkv_split_batched
    if _gpu_arch_q_dim == 5120 { fh = _gpu_fh_qkv_split_batched_14b }
    if fh == 0 { return 1 }
    u64 a0 = alloc(8); unsafe { *(a0 as u64) = d_qkv }
    u64 a1 = alloc(8); unsafe { *(a1 as u64) = d_k_slot_base }
    u64 a2 = alloc(8); unsafe { *(a2 as u64) = d_v_slot_base }
    u64 kp = alloc(3 * 8)
    unsafe { *(kp        as u64) = a0 }
    unsafe { *((kp +  8) as u64) = a1 }
    unsafe { *((kp + 16) as u64) = a2 }
    u32 cgrid_x = 8
    u32 cgrid_y = batch_size
    u32 err = hipModuleLaunchKernel(fh, cgrid_x, cgrid_y, 1, 128, 1, 1, 0, 0, kp, 0)
    if err != 0 { return 1 }
    return 0
}

// gpu_qkv_split_f32_speck4_to_dev: speculative-layout split — one
// dispatch covers K consecutive positions of a SINGLE sequence.  Caller
// supplies K/V destination pointers already shifted to the position-pos
// row inside batch=0's slab (kv_layer_base + 0*262144 + pos*4096); the
// kernel adds wg_y * 4096 to step through positions pos..pos+K-1.
// d_qkv is the contiguous [K, qkv_dim] qkv-proj output (qkv_dim=4096
// f32 → 16384 bytes per slot).  Grid (8, K, 1).  Returns 0 on success.
fn gpu_qkv_split_f32_speck4_to_dev(u64 d_qkv, u64 d_k_pos_base, u64 d_v_pos_base,
                                    u64 spec_K) -> u64 {
    if _gpu_fh_qkv_split_speck4 == 0 { return 1 }
    u64 a0 = alloc(8); unsafe { *(a0 as u64) = d_qkv }
    u64 a1 = alloc(8); unsafe { *(a1 as u64) = d_k_pos_base }
    u64 a2 = alloc(8); unsafe { *(a2 as u64) = d_v_pos_base }
    u64 kp = alloc(3 * 8)
    unsafe { *(kp        as u64) = a0 }
    unsafe { *((kp +  8) as u64) = a1 }
    unsafe { *((kp + 16) as u64) = a2 }
    u32 cgrid_x = 8
    u32 cgrid_y = spec_K
    u32 err = hipModuleLaunchKernel(_gpu_fh_qkv_split_speck4, cgrid_x, cgrid_y, 1, 128, 1, 1, 0, 0, kp, 0)
    if err != 0 { return 1 }
    return 0
}

// gpu_silu_mul_f32_batched_to_dev: ONE batched silu_mul over M streams.
// Caller passes [batch, 2*ff] gate||up base and [batch, ff] out base;
// kernel adds wg_y * 24576 and wg_y * 12288 to the respective bases.
// n_per_stream is the per-stream element count (= ff).  Returns 0 on success.
fn gpu_silu_mul_f32_batched_to_dev(u64 d_out, u64 d_gate, u64 d_up,
                                    u64 n_per_stream, u64 batch_size) -> u64 {
    if _gpu_fh_silu_mul_batched == 0 { return 1 }
    u64 a0 = alloc(8); unsafe { *(a0 as u64) = d_gate }
    u64 a1 = alloc(8); unsafe { *(a1 as u64) = d_up }
    u64 a2 = alloc(8); unsafe { *(a2 as u64) = d_out }
    u64 a3 = alloc(8); unsafe { *(a3 as u64) = n_per_stream }
    u64 kp = alloc(4 * 8)
    unsafe { *(kp        as u64) = a0 }
    unsafe { *((kp +  8) as u64) = a1 }
    unsafe { *((kp + 16) as u64) = a2 }
    unsafe { *((kp + 24) as u64) = a3 }
    u32 cgrid_x = (n_per_stream + 255) / 256
    u32 cgrid_y = batch_size
    u32 err = hipModuleLaunchKernel(_gpu_fh_silu_mul_batched, cgrid_x, cgrid_y, 1, 256, 1, 1, 0, 0, kp, 0)
    if err != 0 { return 1 }
    return 0
}

// gpu_extract_k_qwen3_f32_to_dev: K-slots → contiguous stage buffer.
// Caller passes layer/pos K-slot base for batch=0; kernel adds wg_y *
// 262144 to reach each batch's slot.  Returns 0 on success.
fn gpu_extract_k_qwen3_f32_to_dev(u64 d_k_slot_base, u64 d_stage, u64 batch_size) -> u64 {
    if _gpu_fh_extract_k == 0 { return 1 }
    u64 a0 = alloc(8); unsafe { *(a0 as u64) = d_k_slot_base }
    u64 a1 = alloc(8); unsafe { *(a1 as u64) = d_stage }
    u64 kp = alloc(2 * 8)
    unsafe { *(kp as u64) = a0 }
    unsafe { *((kp + 8) as u64) = a1 }
    u32 err = hipModuleLaunchKernel(_gpu_fh_extract_k, 8, batch_size, 1, 128, 1, 1, 0, 0, kp, 0)
    if err != 0 { return 1 }
    return 0
}

// gpu_insert_k_qwen3_f32_to_dev: contiguous stage → K-slots.  Inverse
// of extract_k.  Returns 0 on success.
fn gpu_insert_k_qwen3_f32_to_dev(u64 d_stage, u64 d_k_slot_base, u64 batch_size) -> u64 {
    if _gpu_fh_insert_k == 0 { return 1 }
    u64 a0 = alloc(8); unsafe { *(a0 as u64) = d_stage }
    u64 a1 = alloc(8); unsafe { *(a1 as u64) = d_k_slot_base }
    u64 kp = alloc(2 * 8)
    unsafe { *(kp as u64) = a0 }
    unsafe { *((kp + 8) as u64) = a1 }
    u32 err = hipModuleLaunchKernel(_gpu_fh_insert_k, 8, batch_size, 1, 128, 1, 1, 0, 0, kp, 0)
    if err != 0 { return 1 }
    return 0
}

// gpu_extract_k_qwen3_f32_speck4_to_dev: speculative-layout K-extract.
// Reads K consecutive positions of a single sequence's K-cache slab
// (per-pos src stride 4096) into a contiguous [K, kv_dim] stage.
// Caller passes K-slot base already shifted to position pos in
// batch=0's slab.  Grid (8, K, 1).  Returns 0 on success.
fn gpu_extract_k_qwen3_f32_speck4_to_dev(u64 d_k_pos_base, u64 d_stage,
                                          u64 spec_K) -> u64 {
    if _gpu_fh_extract_k_speck4 == 0 { return 1 }
    u64 a0 = alloc(8); unsafe { *(a0 as u64) = d_k_pos_base }
    u64 a1 = alloc(8); unsafe { *(a1 as u64) = d_stage }
    u64 kp = alloc(2 * 8)
    unsafe { *(kp as u64) = a0 }
    unsafe { *((kp + 8) as u64) = a1 }
    u32 err = hipModuleLaunchKernel(_gpu_fh_extract_k_speck4, 8, spec_K, 1, 128, 1, 1, 0, 0, kp, 0)
    if err != 0 { return 1 }
    return 0
}

// gpu_insert_k_qwen3_f32_speck4_to_dev: inverse of extract_k_speck4.
// Writes a contiguous [K, kv_dim] stage back to K consecutive positions
// of a single sequence's K-cache slab.  Returns 0 on success.
fn gpu_insert_k_qwen3_f32_speck4_to_dev(u64 d_stage, u64 d_k_pos_base,
                                         u64 spec_K) -> u64 {
    if _gpu_fh_insert_k_speck4 == 0 { return 1 }
    u64 a0 = alloc(8); unsafe { *(a0 as u64) = d_stage }
    u64 a1 = alloc(8); unsafe { *(a1 as u64) = d_k_pos_base }
    u64 kp = alloc(2 * 8)
    unsafe { *(kp as u64) = a0 }
    unsafe { *((kp + 8) as u64) = a1 }
    u32 err = hipModuleLaunchKernel(_gpu_fh_insert_k_speck4, 8, spec_K, 1, 128, 1, 1, 0, 0, kp, 0)
    if err != 0 { return 1 }
    return 0
}

// gpu_extract_q_qwen3_f32_to_dev: copies the Q (q_dim = 2048 f32) part
// of the [batch, qkv_dim] _gpuq_d_qkv buffer into the contiguous
// [batch, q_dim] _gpuq_d_q_attn buffer, so per-head qknorm can run as
// a single batched M = batch * nh dispatch.  Grid (16, batch); one
// dispatch covers all M streams.  Returns 0 on success.
fn gpu_extract_q_qwen3_f32_to_dev(u64 d_qkv, u64 d_q, u64 batch_size) -> u64 {
    if _gpu_fh_extract_q == 0 { return 1 }
    u64 a0 = alloc(8); unsafe { *(a0 as u64) = d_qkv }
    u64 a1 = alloc(8); unsafe { *(a1 as u64) = d_q }
    u64 kp = alloc(2 * 8)
    unsafe { *(kp        as u64) = a0 }
    unsafe { *((kp +  8) as u64) = a1 }
    // cgrid_x = nh (one WG per Q head).  At batch_size=1 the per-batch
    // shifts in the kernel are 0, so the body is shape-agnostic across
    // 0.6B (nh=16) and 14B (nh=40) — only grid count differs.  At
    // batch>1 the per-batch lshl strides hardcode 0.6B's qkv_dim*4=
    // 16384 / q_dim*4=8192 → won't work for 14B's non-pow2 strides.
    u32 cgrid_x = _gpu_arch_n_heads
    u32 cgrid_y = batch_size
    u32 err = hipModuleLaunchKernel(_gpu_fh_extract_q, cgrid_x, cgrid_y, 1, 128, 1, 1, 0, 0, kp, 0)
    if err != 0 { return 1 }
    return 0
}

// gpu_qkv_split_f32_to_dev: copies the K (1024 f32) and V (1024 f32)
// slices out of the Qwen3-0.6B fused d_qkv buffer (q_dim=2048, kv_dim
// =1024) into the per-step KV cache slots, all on-device.  Replaces
// the CPU memcpy that previously required sync 1.  Returns 0 on success.
fn gpu_qkv_split_f32_to_dev(u64 d_qkv, u64 d_k_slot, u64 d_v_slot) -> u64 {
    if _gpu_fh_qkv_split == 0 { return 1 }
    u64 a0 = alloc(8); unsafe { *(a0 as u64) = d_qkv }
    u64 a1 = alloc(8); unsafe { *(a1 as u64) = d_k_slot }
    u64 a2 = alloc(8); unsafe { *(a2 as u64) = d_v_slot }
    u64 kp = alloc(3 * 8)
    unsafe { *(kp        as u64) = a0 }
    unsafe { *((kp +  8) as u64) = a1 }
    unsafe { *((kp + 16) as u64) = a2 }
    // grid = 8 (= 1024 elements / 128 lanes per WG); block = 128.
    u32 err = hipModuleLaunchKernel(_gpu_fh_qkv_split, 8, 1, 1, 128, 1, 1, 0, 0, kp, 0)
    if err != 0 { return 1 }
    return 0
}

// gpu_rope_f32_to_dev: in-place per-head RoPE.  Each WG rotates one
// head's 128-element slice using the precomputed cos/sin tables (each
// 64 f32s, indexed by [0..head_dim/2)).  Used by Step D part 2 of the
// attn wiring to keep RoPE on GPU after qknorm.
//
// Returns 0 on success.
fn gpu_rope_f32_to_dev(u64 d_x, u64 d_cos, u64 d_sin, u64 n_heads) -> u64 {
    if _gpu_fh_rope_f32 == 0 { return 1 }
    u64 a0 = alloc(8); unsafe { *(a0 as u64) = d_x }
    u64 a1 = alloc(8); unsafe { *(a1 as u64) = d_cos }
    u64 a2 = alloc(8); unsafe { *(a2 as u64) = d_sin }
    u64 a3 = alloc(8); unsafe { *(a3 as u64) = n_heads }
    u64 kp = alloc(4 * 8)
    unsafe { *(kp        as u64) = a0 }
    unsafe { *((kp +  8) as u64) = a1 }
    unsafe { *((kp + 16) as u64) = a2 }
    unsafe { *((kp + 24) as u64) = a3 }
    u32 grid32 = n_heads
    u32 err = hipModuleLaunchKernel(_gpu_fh_rope_f32, grid32, 1, 1, 64, 1, 1, 0, 0, kp, 0)
    if err != 0 { return 1 }
    return 0
}

// gpu_attn_decode_to_dev: fused decode-attention for Qwen3-0.6B shape
// (nh=16, nkv=8, hd=128).  Computes
//   out[h, j] = Σ_p softmax_p ((1/√128) Σ_k q[h,k] * K[p, h>>1, k])
//             * V[p, h>>1, j]
// where the softmax runs over positions 0..pos_plus_1.
//
// All four buffers are device VAs (kernel does the loads/stores via
// global_load/store).  Caller has placed the freshly-rope'd q at
// d_q (16*128 f32 = 8 KB) and the up-to-date kv-cache slots at d_kc /
// d_vc (max_seq=64; 64*8*128 f32 = 256 KB each).  Output lands in
// d_out (8 KB).
//
// Returns 0 on success (kernel queued, no implicit sync).
fn gpu_attn_decode_to_dev(u64 d_q, u64 d_kc, u64 d_vc, u64 d_out,
                           u64 pos_plus_1) -> u64 {
    // Shape-aware: pick the 14B variant when n_heads=40 (kv_ratio=5).
    u64 fh = _gpu_fh_attn_decode
    u64 nh = _gpu_arch_n_heads
    if nh == 40 { fh = _gpu_fh_attn_decode_14b }
    if fh == 0 { return 1 }
    u64 a0 = alloc(8); unsafe { *(a0 as u64) = d_q }
    u64 a1 = alloc(8); unsafe { *(a1 as u64) = d_kc }
    u64 a2 = alloc(8); unsafe { *(a2 as u64) = d_vc }
    u64 a3 = alloc(8); unsafe { *(a3 as u64) = d_out }
    u64 a4 = alloc(8); unsafe { *(a4 as u64) = pos_plus_1 }
    u64 kp = alloc(5 * 8)
    unsafe { *(kp        as u64) = a0 }
    unsafe { *((kp +  8) as u64) = a1 }
    unsafe { *((kp + 16) as u64) = a2 }
    unsafe { *((kp + 24) as u64) = a3 }
    unsafe { *((kp + 32) as u64) = a4 }
    // grid = nh (one WG per query head); block = 32 (one wave).
    u32 cgrid_x = nh
    u32 err = hipModuleLaunchKernel(fh, cgrid_x, 1, 1, 32, 1, 1, 0, 0, kp, 0)
    if err != 0 { return 1 }
    return 0
}

// Allocate (or reuse) a GTT-backed device buffer of `bytes` size.
// Shared static buffer pool; wraps around at 16 slots.  For small,
// frequently-reused intermediates in the layer chain.
static u64 _gpu_buf_pool_va  = 0
static u64 _gpu_buf_pool_h   = 0
static u64 _gpu_buf_pool_cap = 0
static u64 _GPU_BUF_POOL_SIZE = 64
static u64[64] _gpu_buf_pool_va_arr
static u64[64] _gpu_buf_pool_h_arr
static u64[64] _gpu_buf_pool_size_arr
static u64 _gpu_buf_pool_n = 0

// Reserve a fresh device buffer (GTT-backed).  Returns the device VA
// and stores the host-mapped pointer in *out_h_slot.  The buffer is
// not freed for the process lifetime — pool grows up to 64 slots.
fn gpu_buf_reserve(u64 bytes, u64 out_h_slot) -> u64 {
    if _gpu_buf_pool_n >= _GPU_BUF_POOL_SIZE { return 0 }
    u64 va = dev_try_alloc_host_visible(bytes)
    if va == 0 { return 0 }
    u64 h = dev_host_ptr(va)
    u64 idx = _gpu_buf_pool_n
    unsafe { *((_gpu_buf_pool_va_arr   + idx * 8) as u64) = va }
    unsafe { *((_gpu_buf_pool_h_arr    + idx * 8) as u64) = h }
    unsafe { *((_gpu_buf_pool_size_arr + idx * 8) as u64) = bytes }
    _gpu_buf_pool_n = idx + 1
    if out_h_slot != 0 { unsafe { *(out_h_slot as u64) = h } }
    return va
}

// Parallel cache for 1D bf16 arrays (rmsnorm gamma).  Maps host bf16
// ptr → device f32 ptr.  One-shot dequant at first lookup, cached
// thereafter.  Uses a separate table from the matmul weight cache.
static u64 _gpu_gamma_keys = 0
static u64 _gpu_gamma_vals = 0
static u64 _gpu_gamma_n    = 0

fn _gpu_gamma_init() {
    if _gpu_gamma_keys != 0 { return }
    _gpu_gamma_keys = alloc(_gpu_mm_cache_cap * 8)
    _gpu_gamma_vals = alloc(_gpu_mm_cache_cap * 8)
    _gpu_gamma_n = 0
}

fn _gpu_gamma_lookup(u64 w_bf16) -> u64 {
    u64 i = 0
    while i < _gpu_gamma_n {
        u64 kp = _gpu_gamma_keys + i * 8
        u64 k = 0; unsafe { *(kp as u64) -> k }
        if k == w_bf16 {
            u64 vp = _gpu_gamma_vals + i * 8
            u64 v = 0; unsafe { *(vp as u64) -> v }
            return v
        }
        i = i + 1
    }
    return 0
}

// Cache a 1D bf16 array as a device f32 buffer (one-shot dequant).
// For rmsnorm gamma weights.  Returns the device VA of the f32 copy,
// or 0 on failure.  Subsequent calls with the same host ptr hit
// the cache.
fn gpu_cache_bf16_as_f32(u64 w_bf16_host, u64 N) -> u64 {
    if gpu_matmul_enabled() == 0 { return 0 }
    if _gpu_mm_fh_dq == 0 { return 0 }
    _gpu_gamma_init()

    u64 cached = _gpu_gamma_lookup(w_bf16_host)
    if cached != 0 { return cached }

    // Alloc device bf16 source + f32 dest.
    u64 d_bf16 = 0
    u64 slot = alloc(8)
    u32 err = hipMalloc(slot, N * 2)
    if err != 0 { return 0 }
    unsafe { *(slot as u64) -> d_bf16 }
    err = hipMemcpy(d_bf16, w_bf16_host, N * 2, 1)
    if err != 0 { return 0 }

    u64 d_f32 = 0
    slot = alloc(8)
    err = hipMalloc(slot, N * 4)
    if err != 0 { return 0 }
    unsafe { *(slot as u64) -> d_f32 }

    // Launch dequant.
    u64 a0 = alloc(8); unsafe { *(a0 as u64) = d_bf16 }
    u64 a1 = alloc(8); unsafe { *(a1 as u64) = d_f32 }
    u64 a2 = alloc(8); unsafe { *(a2 as u64) = N }
    u64 kp = alloc(3 * 8)
    unsafe { *(kp        as u64) = a0 }
    unsafe { *((kp +  8) as u64) = a1 }
    unsafe { *((kp + 16) as u64) = a2 }
    u64 grid_u = (N + 255) / 256
    u32 grid32 = grid_u
    err = hipModuleLaunchKernel(_gpu_mm_fh_dq, grid32, 1, 1, 256, 1, 1, 0, 0, kp, 0)
    if err != 0 { return 0 }
    err = hipDeviceSynchronize()
    if err != 0 { return 0 }
    hipFree(d_bf16)

    // Insert into cache.
    if _gpu_gamma_n < _gpu_mm_cache_cap {
        u64 kp_g = _gpu_gamma_keys + _gpu_gamma_n * 8
        u64 vp_g = _gpu_gamma_vals + _gpu_gamma_n * 8
        unsafe { *(kp_g as u64) = w_bf16_host }
        unsafe { *(vp_g as u64) = d_f32 }
        _gpu_gamma_n = _gpu_gamma_n + 1
    }
    return d_f32
}

// Slice 6.7c — parallel cache for 1D F32 norm-weight arrays (Llama
// stores attn_norm.weight as F32, not bf16).  Maps host f32 ptr →
// device f32 ptr.  Plain hipMemcpy on first lookup (no dequant), cached
// thereafter.  Separate table from the bf16 gamma cache so host-ptr key
// collisions across drivers in the same process can't cross-resolve.
static u64 _gpu_f32_norm_cache_keys = 0
static u64 _gpu_f32_norm_cache_vals = 0
static u64 _gpu_f32_norm_cache_n    = 0

fn _gpu_f32_norm_cache_init() {
    if _gpu_f32_norm_cache_keys != 0 { return }
    _gpu_f32_norm_cache_keys = alloc(_gpu_mm_cache_cap * 8)
    _gpu_f32_norm_cache_vals = alloc(_gpu_mm_cache_cap * 8)
    _gpu_f32_norm_cache_n = 0
}

fn _gpu_f32_norm_cache_lookup(u64 w_f32) -> u64 {
    u64 i = 0
    while i < _gpu_f32_norm_cache_n {
        u64 kp = _gpu_f32_norm_cache_keys + i * 8
        u64 k = 0; unsafe { *(kp as u64) -> k }
        if k == w_f32 {
            u64 vp = _gpu_f32_norm_cache_vals + i * 8
            u64 v = 0; unsafe { *(vp as u64) -> v }
            return v
        }
        i = i + 1
    }
    return 0
}

// Cache a 1D F32 array as a device f32 buffer (no dequant, plain copy).
// For rmsnorm gamma weights stored as F32 in GGUF (Llama, etc).
// Returns the device VA of the f32 copy, or 0 on failure.  Subsequent
// calls with the same host ptr hit the cache.
fn gpu_cache_f32_as_f32(u64 w_f32_host, u64 N) -> u64 {
    if gpu_matmul_enabled() == 0 { return 0 }
    _gpu_f32_norm_cache_init()

    u64 cached = _gpu_f32_norm_cache_lookup(w_f32_host)
    if cached != 0 { return cached }

    // Alloc device f32 dest, then plain hipMemcpy H2D.
    u64 d_f32 = 0
    u64 slot = alloc(8)
    u32 err = hipMalloc(slot, N * 4)
    if err != 0 { return 0 }
    unsafe { *(slot as u64) -> d_f32 }
    err = hipMemcpy(d_f32, w_f32_host, N * 4, 1)
    if err != 0 { return 0 }

    // Insert into cache.
    if _gpu_f32_norm_cache_n < _gpu_mm_cache_cap {
        u64 kp_g = _gpu_f32_norm_cache_keys + _gpu_f32_norm_cache_n * 8
        u64 vp_g = _gpu_f32_norm_cache_vals + _gpu_f32_norm_cache_n * 8
        unsafe { *(kp_g as u64) = w_f32_host }
        unsafe { *(vp_g as u64) = d_f32 }
        _gpu_f32_norm_cache_n = _gpu_f32_norm_cache_n + 1
    }
    return d_f32
}

// Probe whether the full-GPU pipeline kernels loaded successfully.
fn gpu_pipeline_ready() -> u64 {
    if _gpu_fh_resid_add == 0 { return 0 }
    if _gpu_fh_silu_mul == 0 { return 0 }
    if _gpu_fh_rmsnorm_1024 == 0 { return 0 }
    return 1
}

// Slice 4.8 — public accessor to upload (or look up cached) device bf16
// weight for a host bf16 pointer.  Used by the mega-kernel launcher to
// share the SAME device bf16 slab as gpu_matmul_to_dev's bf16-direct
// path (when MLRIFT_GPU_MATMUL_BF16=1).  The mega-kernel always reads
// bf16 weights directly (no f32 dequant variant), so we always go
// through this cache.  Returns 0 on failure or if GPU is disabled.
fn gpu_get_or_upload_bf16_weight(u64 w_bf16_host, u64 K, u64 N) -> u64 {
    if gpu_matmul_enabled() == 0 { return 0 }
    return _gpu_mm_get_or_upload_bf16(w_bf16_host, K, N)
}

// Slice 4.8 — probe whether the qwen3 mega-kernel module loaded.
fn gpu_qwen3_megakernel_ready() -> u64 {
    if gpu_matmul_enabled() == 0 { return 0 }
    if _gpu_fh_qwen3_megakernel == 0 { return 0 }
    return 1
}

// Slice 4.8 — single-dispatch full-qwen3-layer launcher.  Replaces the
// 11 per-op calls in qwen3_forward_layer_gpu with one mega-kernel
// dispatch.  All 24 kernarg device pointers must already be allocated
// and populated by the caller; this function only zeroes the barrier
// counter (via the host-mapped GTT pointer) and queues the launch.
//
// Grid = (WG_PERSIST=256, 1, 1), block = (32, 1, 1).  WG_PERSIST bumped
// 64→256 in slice 4.10 to recover the matmul-row parallelism per-op
// gemv_coop already exploits.
// max_phase = 7 runs the full layer; lower values bisect for debug.
//
// Returns 0 on success, 1 on launch failure (caller should fall back).
@export
fn gpu_qwen3_layer_megakernel_to_dev(u64 d_in_residual,    u64 d_out_residual,
                                       u64 d_qkv_w,         u64 d_o_w,
                                       u64 d_gate_up_w,     u64 d_down_w,
                                       u64 d_in_norm_g,     u64 d_post_norm_g,
                                       u64 d_q_norm_g,      u64 d_k_norm_g,
                                       u64 d_rope_cos,      u64 d_rope_sin,
                                       u64 d_kc_layer,      u64 d_vc_layer,
                                       u64 pos,
                                       u64 d_barrier_ctr,   u64 h_barrier_ctr,
                                       u64 d_gu_scratch,
                                       u64 d_b_x_norm_g,    u64 d_b_qkv_g,
                                       u64 d_b_attn_q_g,    u64 d_b_mid_g,
                                       u64 d_b_mid_norm_g,  u64 d_b_attn_out_g,
                                       u64 max_phase) -> u64 {
    if _gpu_fh_qwen3_megakernel == 0 { return 1 }

    // Zero the barrier counter via the host-mapped GTT pointer.  GTT is
    // CPU-coherent so this write is visible to the GPU on next launch.
    if h_barrier_ctr != 0 {
        u32 z = 0
        unsafe { *(h_barrier_ctr as u32) = z }
    } else {
        // Fall back to D2D memset via H2D — slower path.
        u64 zbuf = alloc(4)
        u32 zv = 0; unsafe { *(zbuf as u32) = zv }
        u32 cerr = hipMemcpy(d_barrier_ctr, zbuf, 4, 1)
        if cerr != 0 { return 1 }
        dealloc(zbuf)
    }

    // Build kernarg blob (24 × u64 packed) using arena to avoid mmap.
    _gpu_kp_reset()
    u64 k_buf = _gpu_kp_bump(24 * 8)
    unsafe { *((k_buf +  0 * 8) as u64) = d_in_residual    }
    unsafe { *((k_buf +  1 * 8) as u64) = d_out_residual   }
    unsafe { *((k_buf +  2 * 8) as u64) = d_qkv_w          }
    unsafe { *((k_buf +  3 * 8) as u64) = d_o_w            }
    unsafe { *((k_buf +  4 * 8) as u64) = d_gate_up_w      }
    unsafe { *((k_buf +  5 * 8) as u64) = d_down_w         }
    unsafe { *((k_buf +  6 * 8) as u64) = d_in_norm_g      }
    unsafe { *((k_buf +  7 * 8) as u64) = d_post_norm_g    }
    unsafe { *((k_buf +  8 * 8) as u64) = d_q_norm_g       }
    unsafe { *((k_buf +  9 * 8) as u64) = d_k_norm_g       }
    unsafe { *((k_buf + 10 * 8) as u64) = d_rope_cos       }
    unsafe { *((k_buf + 11 * 8) as u64) = d_rope_sin       }
    unsafe { *((k_buf + 12 * 8) as u64) = d_kc_layer       }
    unsafe { *((k_buf + 13 * 8) as u64) = d_vc_layer       }
    unsafe { *((k_buf + 14 * 8) as u64) = pos              }
    unsafe { *((k_buf + 15 * 8) as u64) = d_barrier_ctr    }
    unsafe { *((k_buf + 16 * 8) as u64) = d_gu_scratch     }
    unsafe { *((k_buf + 17 * 8) as u64) = d_b_x_norm_g     }
    unsafe { *((k_buf + 18 * 8) as u64) = d_b_qkv_g        }
    unsafe { *((k_buf + 19 * 8) as u64) = d_b_attn_q_g     }
    unsafe { *((k_buf + 20 * 8) as u64) = d_b_mid_g        }
    unsafe { *((k_buf + 21 * 8) as u64) = d_b_mid_norm_g   }
    unsafe { *((k_buf + 22 * 8) as u64) = d_b_attn_out_g   }
    unsafe { *((k_buf + 23 * 8) as u64) = max_phase        }

    // Build void**-style pointer array.
    u64 kp = _gpu_kp_bump(24 * 8)
    u64 j = 0
    while j < 24 {
        u64 slot_ptr = k_buf + j * 8
        unsafe { *((kp + j * 8) as u64) = slot_ptr }
        j = j + 1
    }

    u32 grid_x = 512       // WG_PERSIST (slice 4.11 partitioned)
    u32 block_x = 32       // wave-aligned
    u32 err = hipModuleLaunchKernel(_gpu_fh_qwen3_megakernel,
                                     grid_x, 1, 1, block_x, 1, 1,
                                     0, 0, kp, 0)
    if err != 0 { return 1 }
    return 0
}

// Slice 5.8 — probe whether the Llama-3.2-1B mega-kernel module loaded.
@export
fn gpu_llama_megakernel_ready() -> u64 {
    if gpu_matmul_enabled() == 0 { return 0 }
    if _gpu_fh_llama_megakernel == 0 { return 0 }
    return 1
}

// Slice 5.8 — single-dispatch full-Llama-layer launcher.  Byte-for-byte
// kernarg-compatible with gpu_qwen3_layer_megakernel_to_dev (24 × u64);
// the only difference is the module handle (Llama .co compiled with
// HIDDEN=2048, HEAD_DIM=64, N_HEADS=32, N_KV_HEADS=8, FF=8192,
// USE_QKNORM=0, ROPE_PAIR_LAYOUT=1).  q_norm_g / k_norm_g pointers are
// IGNORED by the Llama .co (USE_QKNORM=0 in the kernel) but remain in
// the kernarg blob to keep the launcher signature stable.
//
// Grid = (WG_PERSIST=512, 1, 1), block = (32, 1, 1) — same as Qwen3.
// max_phase = 7 runs the full layer; lower values bisect for debug.
//
// Returns 0 on success, 1 on launch failure (caller should fall back).
@export
fn gpu_llama_layer_megakernel_to_dev(u64 d_in_residual,    u64 d_out_residual,
                                       u64 d_qkv_w,         u64 d_o_w,
                                       u64 d_gate_up_w,     u64 d_down_w,
                                       u64 d_in_norm_g,     u64 d_post_norm_g,
                                       u64 d_q_norm_g,      u64 d_k_norm_g,
                                       u64 d_rope_cos,      u64 d_rope_sin,
                                       u64 d_kc_layer,      u64 d_vc_layer,
                                       u64 pos,
                                       u64 d_barrier_ctr,   u64 h_barrier_ctr,
                                       u64 d_gu_scratch,
                                       u64 d_b_x_norm_g,    u64 d_b_qkv_g,
                                       u64 d_b_attn_q_g,    u64 d_b_mid_g,
                                       u64 d_b_mid_norm_g,  u64 d_b_attn_out_g,
                                       u64 max_phase) -> u64 {
    if _gpu_fh_llama_megakernel == 0 { return 1 }

    // Zero the barrier counter via the host-mapped GTT pointer.
    if h_barrier_ctr != 0 {
        u32 z = 0
        unsafe { *(h_barrier_ctr as u32) = z }
    } else {
        u64 zbuf = alloc(4)
        u32 zv = 0; unsafe { *(zbuf as u32) = zv }
        u32 cerr = hipMemcpy(d_barrier_ctr, zbuf, 4, 1)
        if cerr != 0 { return 1 }
        dealloc(zbuf)
    }

    // Build kernarg blob (24 × u64 packed).
    _gpu_kp_reset()
    u64 k_buf = _gpu_kp_bump(24 * 8)
    unsafe { *((k_buf +  0 * 8) as u64) = d_in_residual    }
    unsafe { *((k_buf +  1 * 8) as u64) = d_out_residual   }
    unsafe { *((k_buf +  2 * 8) as u64) = d_qkv_w          }
    unsafe { *((k_buf +  3 * 8) as u64) = d_o_w            }
    unsafe { *((k_buf +  4 * 8) as u64) = d_gate_up_w      }
    unsafe { *((k_buf +  5 * 8) as u64) = d_down_w         }
    unsafe { *((k_buf +  6 * 8) as u64) = d_in_norm_g      }
    unsafe { *((k_buf +  7 * 8) as u64) = d_post_norm_g    }
    unsafe { *((k_buf +  8 * 8) as u64) = d_q_norm_g       }
    unsafe { *((k_buf +  9 * 8) as u64) = d_k_norm_g       }
    unsafe { *((k_buf + 10 * 8) as u64) = d_rope_cos       }
    unsafe { *((k_buf + 11 * 8) as u64) = d_rope_sin       }
    unsafe { *((k_buf + 12 * 8) as u64) = d_kc_layer       }
    unsafe { *((k_buf + 13 * 8) as u64) = d_vc_layer       }
    unsafe { *((k_buf + 14 * 8) as u64) = pos              }
    unsafe { *((k_buf + 15 * 8) as u64) = d_barrier_ctr    }
    unsafe { *((k_buf + 16 * 8) as u64) = d_gu_scratch     }
    unsafe { *((k_buf + 17 * 8) as u64) = d_b_x_norm_g     }
    unsafe { *((k_buf + 18 * 8) as u64) = d_b_qkv_g        }
    unsafe { *((k_buf + 19 * 8) as u64) = d_b_attn_q_g     }
    unsafe { *((k_buf + 20 * 8) as u64) = d_b_mid_g        }
    unsafe { *((k_buf + 21 * 8) as u64) = d_b_mid_norm_g   }
    unsafe { *((k_buf + 22 * 8) as u64) = d_b_attn_out_g   }
    unsafe { *((k_buf + 23 * 8) as u64) = max_phase        }

    u64 kp = _gpu_kp_bump(24 * 8)
    u64 j = 0
    while j < 24 {
        u64 slot_ptr = k_buf + j * 8
        unsafe { *((kp + j * 8) as u64) = slot_ptr }
        j = j + 1
    }

    u32 grid_x = 512       // WG_PERSIST
    u32 block_x = 32       // wave-aligned
    u32 err = hipModuleLaunchKernel(_gpu_fh_llama_megakernel,
                                     grid_x, 1, 1, block_x, 1, 1,
                                     0, 0, kp, 0)
    if err != 0 { return 1 }
    return 0
}

