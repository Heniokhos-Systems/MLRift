// MLRift Standard Library — Tokenizer (Phase A + B)
//
// Loads a Hugging Face `tokenizer.json` (Gemma / Llama / Mistral style BPE)
// and provides:
//   — tokenizer_load(path): mmap the JSON, extract the vocab and byte-fallback
//     table into heap arrays, build a string→id hash for encode, and cache the
//     special-token IDs the caller usually needs (bos/eos/pad/unk).
//   — tokenizer_encode(tk, input): greedy longest-prefix-match encoding
//     against the vocab with byte-fallback for anything unmatched. Not a
//     true BPE implementation — Phase C will swap in the real merge loop.
//   — tokenizer_decode(tk, ids, count): correct decoder — vocab lookups,
//     byte-fallback tokens resolved to raw bytes, space ↔ '▁' reversal.
//
// Everything else from the full HF spec (normalizer stack, pre-tokenizers,
// post-processors, template processing, added_tokens merging order) is
// deliberately skipped for now — the greedy encoder produces HF-compatible
// *decodings* but not HF-bit-identical *encodings*. Sufficient for running
// a forward pass; insufficient for reproducing public token-ID traces.

import "io.mlr"
import "string.mlr"
import "fmt.mlr"
import "gguf.mlr"

// ---------------------------------------------------------------------------
// Tokenizer handle
// ---------------------------------------------------------------------------

struct Tokenizer {
    u64 file_size         // bytes — used by munmap on free
    u64 file_base         // mmap base of the raw tokenizer.json

    u64 vocab_count       // total token count (262 144 for Gemma)
    u64 strs_blob         // heap buffer holding decoded token strings back-to-back
    u64 strs_blob_len
    u64 id_to_off         // array[vocab_count] of u32 — offset into strs_blob
    u64 id_to_len         // array[vocab_count] of u32 — byte length
    u64 max_tok_len       // longest token byte length — bounds the encode inner loop

    // String -> id hash (linear probing, power-of-two capacity).
    // Each slot holds (u32 string_hash, u32 id_plus_one). id_plus_one == 0 means empty.
    u64 hash_cap
    u64 hash_tab

    u64 byte_fallback_base  // id of '<0x00>' — byte id = base + byte_value
    u64 bos_id
    u64 eos_id
    u64 pad_id
    u64 unk_id
}

// Byte-level (GPT-2 / Qwen) tokenizer state. Would naturally live on
// Tokenizer, but MLRift's current codegen has a known offset bug past
// 16 u64 fields (see gguf.mlr:109) — so we keep the active-tokenizer
// state process-global instead. This restricts us to one byte-level
// tokenizer at a time; fine for all current callers.
//   tk_gpt2_kind   : 0 = SentencePiece (default), 1 = GPT-2 byte-level.
//   tk_gpt2_b2c    : 256 × u32 — byte → Unicode codepoint.
//   tk_gpt2_c2b    : 324 × u8  — codepoint → byte, 0xFF = unmapped.
static u64 tk_gpt2_kind = 0
static u64 tk_gpt2_b2c  = 0
static u64 tk_gpt2_c2b  = 0

// Extra GGUF-only special-token slots. The Tokenizer struct is locked at
// 16 u64 fields (see gguf.mlr:109 for the codegen note); these live here
// so GGUF-loaded tokenizers can still surface IDs like Llama-3's
// `<|eot_id|>`. 0xFFFFFFFFFFFFFFFF = unset.
//   tk_eot_id          : Llama-3 / Qwen end-of-turn token, or "unset"
//   tk_chat_template_p : pointer into the GGUF mmap for the chat-template
//                        Jinja2 source (read-only, lifetime = gguf_free)
//   tk_chat_template_l : byte length of the template (0 = absent)
static u64 tk_eot_id          = 0xFFFFFFFFFFFFFFFF
static u64 tk_chat_template_p = 0
static u64 tk_chat_template_l = 0

// Accessor — returns 0xFFFFFFFFFFFFFFFF if no <|eot_id|>-style token was
// recorded on the loaded tokenizer.
fn tokenizer_eot_id() -> u64 { return tk_eot_id }
fn tokenizer_chat_template(u64 out_ptr, u64 out_len) {
    unsafe { *(out_ptr as u64) = tk_chat_template_p }
    unsafe { *(out_len as u64) = tk_chat_template_l }
}

// ---------------------------------------------------------------------------
// BPE merge-rank table (Phase 2, task #297).
//
// For GPT-2 / Llama-3 / Qwen3-style tokenizers we need a real merge-rank
// BPE encoder, not the greedy longest-prefix-match used by the
// Phase-1 SPM-compatible code path. The merge-rank table maps an
// adjacent token-id pair (left, right) → rank (lower = higher
// priority). It's built once at tokenizer_load_from_gguf time from
// `tokenizer.ggml.merges` and consulted from tk_bpe_encode_pretoken at
// every encode call.
//
// Storage layout — open-addressed hash table sized to 2× merges_count.
// Both arrays live as module-level statics because the Tokenizer struct
// is already at the 16-u64-field codegen limit (see gguf.mlr:109).
//   tk_bpe_keys[slot]  : u64 packed as (left_id+1) | ((right_id+1)<<32),
//                        0 = empty slot (we offset by 1 so that
//                        (left=0,right=0) doesn't collide with empty).
//   tk_bpe_ranks[slot] : u32 rank for that pair (only valid when key != 0).
//   tk_bpe_cap         : current table capacity (power of two).
//   tk_bpe_count       : number of populated entries (for diagnostics).
//
// Encoder mode flag — switches tokenizer_encode between the two paths:
//   tk_encoder_mode = 0 : greedy longest-prefix-match (SPM, default)
//   tk_encoder_mode = 1 : GPT-2 byte-level + BPE merge-rank
//
// Scratch buffers — sized once per encode call. These are not freed on
// tokenizer_free; they live for the whole process. Worth ~MB total.
static u64 tk_bpe_keys     = 0
static u64 tk_bpe_ranks    = 0
static u64 tk_bpe_cap      = 0
static u64 tk_bpe_count    = 0
static u64 tk_encoder_mode = 0

// ---------------------------------------------------------------------------
// Small JSON scanning helpers — tailored to tokenizer.json's structure.
// `pos` is a byte offset into the mmap; returned pos is advanced past what
// was consumed. On parse error we write an error to stderr and exit.
// ---------------------------------------------------------------------------

fn tk_is_ws(u64 c) -> u64 {
    if c == 32 { return 1 }   // space
    if c == 9  { return 1 }   // tab
    if c == 10 { return 1 }   // newline
    if c == 13 { return 1 }   // cr
    return 0
}

fn tk_skip_ws(u64 base, u64 size, u64 pos) -> u64 {
    while pos < size {
        u64 c = load8(base + pos)
        if tk_is_ws(c) == 0 { return pos }
        pos = pos + 1
    }
    return pos
}

// Parse a single hex digit (0..15), -1 on invalid. Used by \uXXXX escapes.
fn tk_hex_nibble(u64 c) -> u64 {
    if c >= 48 && c <= 57 { return c - 48 }     // 0..9
    if c >= 97 && c <= 102 { return c - 87 }    // a..f
    if c >= 65 && c <= 70 { return c - 55 }     // A..F
    return 0xFFFFFFFFFFFFFFFF
}

// Encode a Unicode codepoint as UTF-8 into `out + off`. Returns new off.
fn tk_utf8_encode(u64 out, u64 off, u64 cp) -> u64 {
    if cp < 128 {
        u8 b = cp
        store8(out + off, b)
        return off + 1
    }
    if cp < 2048 {
        u8 b0 = 0xC0 | (cp >> 6)
        u8 b1 = 0x80 | (cp & 0x3F)
        store8(out + off, b0)
        store8(out + off + 1, b1)
        return off + 2
    }
    if cp < 65536 {
        u8 b0 = 0xE0 | (cp >> 12)
        u8 b1 = 0x80 | ((cp >> 6) & 0x3F)
        u8 b2 = 0x80 | (cp & 0x3F)
        store8(out + off, b0)
        store8(out + off + 1, b1)
        store8(out + off + 2, b2)
        return off + 3
    }
    // 4-byte UTF-8 (BMP extension)
    u8 b0 = 0xF0 | (cp >> 18)
    u8 b1 = 0x80 | ((cp >> 12) & 0x3F)
    u8 b2 = 0x80 | ((cp >> 6) & 0x3F)
    u8 b3 = 0x80 | (cp & 0x3F)
    store8(out + off, b0)
    store8(out + off + 1, b1)
    store8(out + off + 2, b2)
    store8(out + off + 3, b3)
    return off + 4
}

// Parse a JSON string starting at `base + pos` (pos points at the opening
// quote). Decode escapes into `out` starting at `out_off`, returning a
// 2-tuple packed as (new_pos, new_out_off) via two out-pointer slots.
// Caller guarantees out has room (worst case: every input byte is 1 output
// byte, since escapes shrink or preserve size).
fn tk_parse_string(u64 base, u64 size, u64 pos,
                   u64 out, u64 out_off,
                   u64 out_pos_ptr, u64 out_off_ptr) {
    u64 c = load8(base + pos)
    if c != 34 {    // '"'
        write(2, "[tokenizer] expected '\"' at offset ", 36)
        u64 s = fmt_dec(pos)
        print_str(s)
        write(2, "\n", 1)
        exit(1)
    }
    pos = pos + 1
    while pos < size {
        u64 ch = load8(base + pos)
        if ch == 34 {                     // closing quote
            unsafe { *(out_pos_ptr as u64) = (pos + 1) }
            unsafe { *(out_off_ptr as u64) = out_off }
            return
        }
        if ch == 92 {                     // backslash escape
            pos = pos + 1
            if pos >= size { break }
            u64 e = load8(base + pos)
            pos = pos + 1
            if e == 34 || e == 92 || e == 47 {
                u8 eb = e
                store8(out + out_off, eb)
                out_off = out_off + 1
            } else if e == 110 {          // \n
                u8 nn = 10
                store8(out + out_off, nn)
                out_off = out_off + 1
            } else if e == 114 {          // \r
                u8 rr = 13
                store8(out + out_off, rr)
                out_off = out_off + 1
            } else if e == 116 {          // \t
                u8 tt = 9
                store8(out + out_off, tt)
                out_off = out_off + 1
            } else if e == 98 {           // \b
                u8 bb = 8
                store8(out + out_off, bb)
                out_off = out_off + 1
            } else if e == 102 {          // \f
                u8 ff = 12
                store8(out + out_off, ff)
                out_off = out_off + 1
            } else if e == 117 {          // \uXXXX
                u64 h3 = tk_hex_nibble(load8(base + pos))
                u64 h2 = tk_hex_nibble(load8(base + pos + 1))
                u64 h1 = tk_hex_nibble(load8(base + pos + 2))
                u64 h0 = tk_hex_nibble(load8(base + pos + 3))
                pos = pos + 4
                u64 cp = (h3 << 12) | (h2 << 8) | (h1 << 4) | h0
                // Surrogate pair handling (\uD800..\uDBFF + \uDC00..\uDFFF)
                if cp >= 0xD800 && cp <= 0xDBFF && pos + 5 < size {
                    if load8(base + pos) == 92 && load8(base + pos + 1) == 117 {
                        u64 lh3 = tk_hex_nibble(load8(base + pos + 2))
                        u64 lh2 = tk_hex_nibble(load8(base + pos + 3))
                        u64 lh1 = tk_hex_nibble(load8(base + pos + 4))
                        u64 lh0 = tk_hex_nibble(load8(base + pos + 5))
                        u64 low = (lh3 << 12) | (lh2 << 8) | (lh1 << 4) | lh0
                        cp = 0x10000 + ((cp - 0xD800) << 10) + (low - 0xDC00)
                        pos = pos + 6
                    }
                }
                out_off = tk_utf8_encode(out, out_off, cp)
            } else {
                // Unknown escape — preserve the char as-is.
                u8 eb = e
                store8(out + out_off, eb)
                out_off = out_off + 1
            }
        } else {
            u8 cb = ch
            store8(out + out_off, cb)
            out_off = out_off + 1
            pos = pos + 1
        }
    }
    write(2, "[tokenizer] unterminated string\n", 32)
    exit(1)
}

// Parse an unsigned decimal integer into *out_val, returning new pos.
fn tk_parse_uint(u64 base, u64 size, u64 pos, u64 out_val) -> u64 {
    u64 v = 0
    u64 any = 0
    while pos < size {
        u64 c = load8(base + pos)
        if c < 48 || c > 57 { break }
        v = v * 10 + (c - 48)
        any = 1
        pos = pos + 1
    }
    if any == 0 {
        write(2, "[tokenizer] expected integer\n", 29)
        exit(1)
    }
    unsafe { *(out_val as u64) = v }
    return pos
}

// ---------------------------------------------------------------------------
// FNV-1a 32-bit hash on a byte range — fast enough for vocab-lookup and
// small enough that the whole hash table fits in a few megabytes.
// ---------------------------------------------------------------------------

fn tk_fnv1a(u64 ptr, u64 len) -> u64 {
    u64 h = 2166136261
    u64 i = 0
    while i < len {
        u64 b = load8(ptr + i)
        h = h ^ b
        h = (h * 16777619) & 0xFFFFFFFF
        i = i + 1
    }
    return h & 0xFFFFFFFF
}

fn tk_bytes_equal(u64 a, u64 b, u64 len) -> u64 {
    u64 i = 0
    while i < len {
        if load8(a + i) != load8(b + i) { return 0 }
        i = i + 1
    }
    return 1
}

// Insert (string@ptr,len, id) into the tokenizer's linear-probing hash.
fn tk_hash_insert(Tokenizer tk, u64 str_ptr, u64 str_len, u64 id) {
    u64 h = tk_fnv1a(str_ptr, str_len)
    u64 mask = tk.hash_cap - 1
    u64 slot = h & mask
    while 1 == 1 {
        u64 slot_ptr = tk.hash_tab + slot * 8
        u64 entry = 0
        unsafe { *(slot_ptr as u64) -> entry }
        if entry == 0 {
            // Pack (hash:u32 << 32) | (id+1:u32)
            u64 packed = (h << 32) | (id + 1)
            unsafe { *(slot_ptr as u64) = packed }
            return
        }
        slot = (slot + 1) & mask
    }
}

// Look up `str` of `len` bytes in the hash. Returns id if present, or
// 0xFFFFFFFFFFFFFFFF if absent.
fn tokenizer_id_of(Tokenizer tk, u64 str_ptr, u64 str_len) -> u64 {
    u64 h = tk_fnv1a(str_ptr, str_len)
    u64 mask = tk.hash_cap - 1
    u64 slot = h & mask
    while 1 == 1 {
        u64 slot_ptr = tk.hash_tab + slot * 8
        u64 entry = 0
        unsafe { *(slot_ptr as u64) -> entry }
        if entry == 0 { return 0xFFFFFFFFFFFFFFFF }
        u64 eh = (entry >> 32) & 0xFFFFFFFF
        u64 eid = (entry & 0xFFFFFFFF) - 1
        if eh == h {
            // Compare bytes.
            u64 off = 0
            unsafe { *((tk.id_to_off + eid * 4) as uint32) -> off }
            u64 el = 0
            unsafe { *((tk.id_to_len + eid * 4) as uint32) -> el }
            if el == str_len {
                if tk_bytes_equal(tk.strs_blob + off, str_ptr, el) != 0 {
                    return eid
                }
            }
        }
        slot = (slot + 1) & mask
    }
    return 0xFFFFFFFFFFFFFFFF
}

// ---------------------------------------------------------------------------
// Loader
// ---------------------------------------------------------------------------

fn tokenizer_load(u64 path) -> Tokenizer {
    Tokenizer tk = alloc(136)
    tk.file_size = 0
    tk.file_base = 0

    u64 fd = file_open(path, 0)
    if is_errno(fd) != 0 {
        print("[tokenizer] open failed: ")
        println_str(path)
        return tk
    }
    u64 sz = file_size(fd)
    // mmap PROT_READ MAP_PRIVATE
    u64 base = syscall_raw(9, 0, sz, 1, 2, fd, 0)
    if is_errno(base) != 0 {
        print("[tokenizer] mmap failed\n")
        file_close(fd)
        return tk
    }
    file_close(fd)
    tk.file_size = sz
    tk.file_base = base

    // -----------------------------------------------------------------------
    // Find the `"vocab":{` opening and the enclosing `}` that ends the dict.
    // We rely on tokenizer.json being well-formed enough that the first
    // occurrence of this literal is the real vocab section. The HF emitter
    // always names this key this exact way, so this is stable.
    // -----------------------------------------------------------------------
    u64 needle = "\"vocab\":"
    u64 idx = 0xFFFFFFFFFFFFFFFF
    u64 npos = 0
    u64 bb = 0
    // Manual substring search — the JSON is mmap'd, so we can't use str_index_of
    // directly (it needs a null-terminated haystack).
    u64 scan = 0
    u64 nlen = str_len(needle)
    while scan + nlen <= sz {
        u64 match_ = 1
        u64 k = 0
        while k < nlen {
            if load8(base + scan + k) != load8(needle + k) { match_ = 0; k = nlen; continue }
            k = k + 1
        }
        if match_ != 0 { idx = scan; scan = sz; continue }
        scan = scan + 1
    }
    if idx == 0xFFFFFFFFFFFFFFFF {
        print("[tokenizer] \"vocab\": not found\n")
        exit(1)
    }
    u64 pos = idx + nlen
    pos = tk_skip_ws(base, sz, pos)
    if load8(base + pos) != 123 {   // '{'
        print("[tokenizer] expected '{' after \"vocab\":\n")
        exit(1)
    }
    pos = pos + 1

    // Pre-size the allocations. Gemma has 262 144 tokens; we allocate for
    // a round 300 000 to leave headroom in case future versions grow.
    u64 max_count = 300000
    u64 strs_cap = 8 * 1024 * 1024   // 8 MB — avg ~32 B/token is generous
    tk.strs_blob = alloc(strs_cap)
    tk.id_to_off = alloc(max_count * 4)
    tk.id_to_len = alloc(max_count * 4)
    tk.vocab_count = 0
    tk.strs_blob_len = 0
    tk.max_tok_len = 0

    u64 blob_off = 0
    u64 count = 0
    u64 max_len = 0
    u64 tmp_pos = alloc(8)
    u64 tmp_off = alloc(8)
    u64 tmp_int = alloc(8)

    while 1 == 1 {
        pos = tk_skip_ws(base, sz, pos)
        u64 c = load8(base + pos)
        if c == 125 {    // '}'
            pos = pos + 1
            break
        }
        if c == 44 {     // ','
            pos = pos + 1
            continue
        }
        // Parse the key string into the blob.
        tk_parse_string(base, sz, pos, tk.strs_blob, blob_off, tmp_pos, tmp_off)
        u64 new_pos = 0
        unsafe { *(tmp_pos as u64) -> new_pos }
        u64 new_off = 0
        unsafe { *(tmp_off as u64) -> new_off }
        u64 str_len_this = new_off - blob_off
        pos = new_pos
        pos = tk_skip_ws(base, sz, pos)
        if load8(base + pos) != 58 {
            print("[tokenizer] expected ':' in vocab entry\n")
            exit(1)
        }
        pos = pos + 1
        pos = tk_skip_ws(base, sz, pos)
        pos = tk_parse_uint(base, sz, pos, tmp_int)
        u64 id_val = 0
        unsafe { *(tmp_int as u64) -> id_val }

        // Grow id_to_off / id_to_len arrays if the id is past the current cap.
        if id_val >= max_count {
            print("[tokenizer] id exceeds preallocated cap; rebuild with higher max_count\n")
            exit(1)
        }
        u32 off32 = blob_off
        u32 len32 = str_len_this
        u64 off_slot = tk.id_to_off + id_val * 4
        u64 len_slot = tk.id_to_len + id_val * 4
        unsafe { *(off_slot as uint32) = off32 }
        unsafe { *(len_slot as uint32) = len32 }

        blob_off = new_off
        count = count + 1
        if str_len_this > max_len { max_len = str_len_this }
    }

    tk.vocab_count = count
    tk.strs_blob_len = blob_off
    tk.max_tok_len = max_len

    dealloc(tmp_pos)
    dealloc(tmp_off)
    dealloc(tmp_int)

    // -----------------------------------------------------------------------
    // Build the string → id hash. 2x-the-next-power-of-two capacity keeps
    // load factor ≤ 0.5 so linear probing stays cheap.
    // -----------------------------------------------------------------------
    u64 hcap = 1
    while hcap < count * 2 { hcap = hcap * 2 }
    tk.hash_cap = hcap
    tk.hash_tab = alloc(hcap * 8)
    // alloc returns zeroed memory, but be explicit.
    u64 i = 0
    while i < hcap {
        unsafe { *((tk.hash_tab + i * 8) as u64) = 0 }
        i = i + 1
    }
    i = 0
    while i < count {
        u64 off = 0
        unsafe { *((tk.id_to_off + i * 4) as uint32) -> off }
        u64 ln = 0
        unsafe { *((tk.id_to_len + i * 4) as uint32) -> ln }
        tk_hash_insert(tk, tk.strs_blob + off, ln, i)
        i = i + 1
    }

    // -----------------------------------------------------------------------
    // Resolve well-known special-token IDs and byte-fallback base.
    // -----------------------------------------------------------------------
    tk.bos_id = tokenizer_id_of(tk, "<bos>", 5)
    tk.eos_id = tokenizer_id_of(tk, "<eos>", 5)
    tk.pad_id = tokenizer_id_of(tk, "<pad>", 5)
    tk.unk_id = tokenizer_id_of(tk, "<unk>", 5)
    tk.byte_fallback_base = tokenizer_id_of(tk, "<0x00>", 6)

    return tk
}

// ---------------------------------------------------------------------------
// GGUF-embedded tokenizer loader.
//
// Reads vocab + special-token IDs out of an already-opened GGUFFile (so
// the caller can reuse the mmap that holds weights). Unlike tokenizer_load,
// nothing is mmap'd by this function — token-string memory still lives in
// the GGUF's mmap (via tk.strs_blob, which we point at a freshly-allocated
// blob copy so encode/decode work the same way).
//
// Supported `tokenizer.ggml.model` values:
//   "gpt2"  — byte-level BPE (Llama-3, Qwen3). Auto-switches to GPT-2 mode.
//   "llama" — SentencePiece (Mistral, Gemma2). Default mode.
//   anything else — exit with an error message; we don't try to guess.
//
// Phase-1 scope: vocab + special IDs only. Merges, scores, and the chat
// template are exposed but not interpreted — greedy longest-prefix-match
// stays in charge of encoding. The chat template's text lives in the
// GGUF mmap; tokenizer_chat_template() returns (ptr, len) for callers
// that want to print it.
//
// Returns a Tokenizer with file_base = 0 / file_size = 0 (since we don't
// own the mmap). tokenizer_free is safe to call on the result — it only
// frees the heap arrays it allocated and skips the munmap path when
// file_base is zero.
// ---------------------------------------------------------------------------

// Compare a (ptr,len) byte range against a NUL-terminated C string.
// Returns 1 on match, 0 on mismatch.
fn tk_bytes_eq_cstr(u64 ptr, u64 len, u64 cstr) -> u64 {
    u64 cl = str_len(cstr)
    if cl != len { return 0 }
    u64 i = 0
    while i < len {
        if load8(ptr + i) != load8(cstr + i) { return 0 }
        i = i + 1
    }
    return 1
}

// ---------------------------------------------------------------------------
// BPE merge-rank table — open-addressing primitives.
// ---------------------------------------------------------------------------

// 32-bit splittable mix — enough avalanche for a 280K-merge table at 2×
// load factor. (FNV-1a over 8 bytes felt heavy for a per-merge-lookup hot
// path; this is what murmur3-finalizer's body looks like for u32 inputs
// xored together.) Returns u64 with only low 32 bits set.
fn tk_pair_hash(u64 left_id, u64 right_id) -> u64 {
    u64 h = (left_id ^ (right_id << 1)) & 0xFFFFFFFF
    h = (h ^ (h >> 16)) & 0xFFFFFFFF
    h = (h * 0x85EBCA6B) & 0xFFFFFFFF
    h = (h ^ (h >> 13)) & 0xFFFFFFFF
    h = (h * 0xC2B2AE35) & 0xFFFFFFFF
    h = (h ^ (h >> 16)) & 0xFFFFFFFF
    return h
}

// Insert (left_id, right_id) -> rank into the BPE table. Caller has
// already sized tk_bpe_keys/ranks/cap. We use the "+1 in packed key"
// trick so that the slot value 0 = empty (left=0,right=0 wouldn't
// otherwise be distinguishable from an empty slot).
fn tk_bpe_insert(u64 left_id, u64 right_id, u64 rank) {
    u64 mask = tk_bpe_cap - 1
    u64 packed = (left_id + 1) | ((right_id + 1) << 32)
    u64 h = tk_pair_hash(left_id, right_id)
    u64 slot = h & mask
    while 1 == 1 {
        u64 sp = tk_bpe_keys + slot * 8
        u64 cur = 0
        unsafe { *(sp as u64) -> cur }
        if cur == 0 {
            unsafe { *(sp as u64) = packed }
            u32 r32 = rank
            unsafe { *((tk_bpe_ranks + slot * 4) as uint32) = r32 }
            tk_bpe_count = tk_bpe_count + 1
            return
        }
        // Duplicate-pair tolerance: first merge wins (lower rank). We
        // emit merges in order, so the first hit IS the lowest rank;
        // any later collision for the same (left,right) is a no-op.
        if cur == packed { return }
        slot = (slot + 1) & mask
    }
}

// Look up (left_id, right_id) → rank. Returns 0xFFFFFFFFFFFFFFFF if
// the pair is not in the merge table.
fn tk_bpe_lookup(u64 left_id, u64 right_id) -> u64 {
    if tk_bpe_cap == 0 { return 0xFFFFFFFFFFFFFFFF }
    u64 mask = tk_bpe_cap - 1
    u64 packed = (left_id + 1) | ((right_id + 1) << 32)
    u64 h = tk_pair_hash(left_id, right_id)
    u64 slot = h & mask
    while 1 == 1 {
        u64 sp = tk_bpe_keys + slot * 8
        u64 cur = 0
        unsafe { *(sp as u64) -> cur }
        if cur == 0 { return 0xFFFFFFFFFFFFFFFF }
        if cur == packed {
            u32 r32 = 0
            unsafe { *((tk_bpe_ranks + slot * 4) as uint32) -> r32 }
            return r32
        }
        slot = (slot + 1) & mask
    }
    return 0xFFFFFFFFFFFFFFFF
}

// Build the BPE merge-rank table from tokenizer.ggml.merges. Each
// merges-array entry has the form "<left> <right>" (single space
// separator). Both halves get looked up in the already-built vocab
// hash. Entries whose halves are missing from the vocab are skipped
// (shouldn't happen in well-formed GGUFs but we don't trust input).
fn tk_bpe_build_merge_table(Tokenizer tk, GGUFFile gf) {
    u64 n_merges = gguf_meta_array_len(gf, "tokenizer.ggml.merges")
    if n_merges == 0 {
        print_str("[tokenizer_gguf] WARNING: tokenizer.ggml.model=gpt2 but no tokenizer.ggml.merges array\n")
        return
    }
    // Size to >= 2× n_merges, power-of-two.
    u64 cap = 1
    while cap < n_merges * 2 { cap = cap * 2 }
    tk_bpe_cap = cap
    tk_bpe_count = 0
    if tk_bpe_keys  != 0 { dealloc(tk_bpe_keys)  }
    if tk_bpe_ranks != 0 { dealloc(tk_bpe_ranks) }
    tk_bpe_keys  = alloc(cap * 8)
    tk_bpe_ranks = alloc(cap * 4)
    u64 z = 0
    while z < cap {
        unsafe { *((tk_bpe_keys + z * 8) as u64) = 0 }
        z = z + 1
    }

    u64 p_box = alloc(8)
    u64 l_box = alloc(8)
    u64 i = 0
    while i < n_merges {
        unsafe { *(p_box as u64) = 0 }
        unsafe { *(l_box as u64) = 0 }
        if gguf_meta_array_string_get(gf, "tokenizer.ggml.merges", i,
                                       p_box, l_box) != 0 {
            i = i + 1
            continue
        }
        u64 sp = 0; unsafe { *(p_box as u64) -> sp }
        u64 ln = 0; unsafe { *(l_box as u64) -> ln }
        // Find the separating space — at most one space per merge entry.
        u64 sep = 0
        u64 found_sep = 0
        u64 j = 0
        while j < ln {
            if load8(sp + j) == 32 { sep = j; found_sep = 1; j = ln; continue }
            j = j + 1
        }
        if found_sep == 0 {
            i = i + 1
            continue
        }
        u64 lid = tokenizer_id_of(tk, sp, sep)
        u64 rid = tokenizer_id_of(tk, sp + sep + 1, ln - sep - 1)
        if lid != 0xFFFFFFFFFFFFFFFF && rid != 0xFFFFFFFFFFFFFFFF {
            tk_bpe_insert(lid, rid, i)
        }
        i = i + 1
    }
    dealloc(p_box); dealloc(l_box)
}

fn tokenizer_load_from_gguf(GGUFFile gf) -> Tokenizer {
    Tokenizer tk = alloc(136)
    tk.file_size = 0
    tk.file_base = 0
    tk.strs_blob = 0
    tk.id_to_off = 0
    tk.id_to_len = 0
    tk.hash_tab  = 0
    tk.vocab_count = 0
    tk.strs_blob_len = 0
    tk.max_tok_len = 0
    tk.hash_cap = 0
    tk.bos_id = 0xFFFFFFFFFFFFFFFF
    tk.eos_id = 0xFFFFFFFFFFFFFFFF
    tk.pad_id = 0xFFFFFFFFFFFFFFFF
    tk.unk_id = 0xFFFFFFFFFFFFFFFF
    tk.byte_fallback_base = 0xFFFFFFFFFFFFFFFF
    tk_eot_id = 0xFFFFFFFFFFFFFFFF
    tk_chat_template_p = 0
    tk_chat_template_l = 0

    // -----------------------------------------------------------------------
    // Decide kind from tokenizer.ggml.model
    // -----------------------------------------------------------------------
    u64 model_p_box = alloc(8); unsafe { *(model_p_box as u64) = 0 }
    u64 model_l_box = alloc(8); unsafe { *(model_l_box as u64) = 0 }
    gguf_meta_string(gf, "tokenizer.ggml.model", model_p_box, model_l_box)
    u64 model_p = 0; unsafe { *(model_p_box as u64) -> model_p }
    u64 model_l = 0; unsafe { *(model_l_box as u64) -> model_l }
    dealloc(model_p_box); dealloc(model_l_box)
    if model_p == 0 {
        print_str("[tokenizer_gguf] no tokenizer.ggml.model in GGUF\n")
        return tk
    }
    u64 is_gpt2 = tk_bytes_eq_cstr(model_p, model_l, "gpt2")
    u64 is_spm  = tk_bytes_eq_cstr(model_p, model_l, "llama")
    if is_gpt2 == 0 && is_spm == 0 {
        print_str("[tokenizer_gguf] unsupported tokenizer.ggml.model: ")
        write(1, model_p, model_l)
        print_str("\n")
        return tk
    }

    // -----------------------------------------------------------------------
    // Vocab — tokens array. Walk once to size the strs_blob, then a second
    // pass to copy and hash. The token-string bodies stay in the GGUF mmap;
    // we copy them into our own blob so that strs_blob stays consistent
    // with tokenizer_load (which owns its blob) and so the per-token
    // offsets fit in u32.
    // -----------------------------------------------------------------------
    u64 vocab_count = gguf_meta_array_len(gf, "tokenizer.ggml.tokens")
    if vocab_count == 0 {
        print_str("[tokenizer_gguf] tokenizer.ggml.tokens missing/empty\n")
        return tk
    }

    // First pass — measure total byte length and longest token.
    u64 total_bytes = 0
    u64 max_len = 0
    u64 tok_p_box = alloc(8)
    u64 tok_l_box = alloc(8)
    u64 i = 0
    while i < vocab_count {
        unsafe { *(tok_p_box as u64) = 0 }
        unsafe { *(tok_l_box as u64) = 0 }
        if gguf_meta_array_string_get(gf, "tokenizer.ggml.tokens", i,
                                       tok_p_box, tok_l_box) != 0 {
            print_str("[tokenizer_gguf] tokens array read failed at idx=")
            u64 s = fmt_dec(i); print_str(s); dealloc(s); print_str("\n")
            dealloc(tok_p_box); dealloc(tok_l_box)
            return tk
        }
        u64 ln = 0; unsafe { *(tok_l_box as u64) -> ln }
        total_bytes = total_bytes + ln
        if ln > max_len { max_len = ln }
        i = i + 1
    }

    // Allocate blob + id tables. We don't have a hard upper bound on id,
    // so size by vocab_count exactly.
    u64 blob_cap = total_bytes
    if blob_cap < 16 { blob_cap = 16 }
    tk.strs_blob = alloc(blob_cap)
    tk.id_to_off = alloc(vocab_count * 4)
    tk.id_to_len = alloc(vocab_count * 4)
    tk.vocab_count = vocab_count
    tk.max_tok_len = max_len

    // Second pass — copy bytes, fill id_to_off/id_to_len.
    u64 blob_off = 0
    i = 0
    while i < vocab_count {
        unsafe { *(tok_p_box as u64) = 0 }
        unsafe { *(tok_l_box as u64) = 0 }
        gguf_meta_array_string_get(gf, "tokenizer.ggml.tokens", i,
                                    tok_p_box, tok_l_box)
        u64 sp = 0; unsafe { *(tok_p_box as u64) -> sp }
        u64 ln = 0; unsafe { *(tok_l_box as u64) -> ln }
        memcpy(tk.strs_blob + blob_off, sp, ln)
        u32 off32 = blob_off
        u32 len32 = ln
        unsafe { *((tk.id_to_off + i * 4) as uint32) = off32 }
        unsafe { *((tk.id_to_len + i * 4) as uint32) = len32 }
        blob_off = blob_off + ln
        i = i + 1
    }
    tk.strs_blob_len = blob_off
    dealloc(tok_p_box); dealloc(tok_l_box)

    // -----------------------------------------------------------------------
    // Build the hash table (same shape as tokenizer_load).
    // -----------------------------------------------------------------------
    u64 hcap = 1
    while hcap < vocab_count * 2 { hcap = hcap * 2 }
    tk.hash_cap = hcap
    tk.hash_tab = alloc(hcap * 8)
    u64 k = 0
    while k < hcap {
        unsafe { *((tk.hash_tab + k * 8) as u64) = 0 }
        k = k + 1
    }
    k = 0
    while k < vocab_count {
        u64 off = 0
        unsafe { *((tk.id_to_off + k * 4) as uint32) -> off }
        u64 ln = 0
        unsafe { *((tk.id_to_len + k * 4) as uint32) -> ln }
        if ln != 0 {
            tk_hash_insert(tk, tk.strs_blob + off, ln, k)
        }
        k = k + 1
    }

    // -----------------------------------------------------------------------
    // Special tokens.
    // -----------------------------------------------------------------------
    u64 bos = gguf_meta_u32(gf, "tokenizer.ggml.bos_token_id", 0xFFFFFFFF)
    u64 eos = gguf_meta_u32(gf, "tokenizer.ggml.eos_token_id", 0xFFFFFFFF)
    u64 pad = gguf_meta_u32(gf, "tokenizer.ggml.padding_token_id", 0xFFFFFFFF)
    u64 unk = gguf_meta_u32(gf, "tokenizer.ggml.unknown_token_id", 0xFFFFFFFF)
    u64 eot = gguf_meta_u32(gf, "tokenizer.ggml.eot_token_id", 0xFFFFFFFF)
    if bos != 0xFFFFFFFF { tk.bos_id = bos }
    if eos != 0xFFFFFFFF { tk.eos_id = eos }
    if pad != 0xFFFFFFFF { tk.pad_id = pad }
    if unk != 0xFFFFFFFF { tk.unk_id = unk }
    if eot != 0xFFFFFFFF { tk_eot_id = eot }

    // SPM byte-fallback base: look up "<0x00>" — present on Mistral / Gemma2 /
    // Llama-2 SPM vocabs and the encoder relies on it. GPT-2 byte-level vocabs
    // have no such token; the encode path skips this branch.
    if is_spm != 0 {
        tk.byte_fallback_base = tokenizer_id_of(tk, "<0x00>", 6)
    }

    // Chat template — store ptr/len for callers; we don't interpret it.
    u64 ct_p_box = alloc(8); unsafe { *(ct_p_box as u64) = 0 }
    u64 ct_l_box = alloc(8); unsafe { *(ct_l_box as u64) = 0 }
    gguf_meta_string(gf, "tokenizer.chat_template", ct_p_box, ct_l_box)
    unsafe { *(ct_p_box as u64) -> tk_chat_template_p }
    unsafe { *(ct_l_box as u64) -> tk_chat_template_l }
    dealloc(ct_p_box); dealloc(ct_l_box)

    // Flip the global to GPT-2 byte-level mode if needed. This populates
    // the b2c / c2b tables that encode/decode use to walk bytes ↔
    // codepoints, AND builds the BPE merge-rank table from
    // tokenizer.ggml.merges so tokenizer_encode can use the canonical
    // merge-rank algorithm instead of greedy longest-prefix-match.
    if is_gpt2 != 0 {
        tokenizer_set_kind_gpt2(tk)
        tk_bpe_build_merge_table(tk, gf)
        tk_encoder_mode = 1
    } else {
        tk_encoder_mode = 0
    }

    return tk
}

// Release all resources held by the tokenizer.
fn tokenizer_free(Tokenizer tk) {
    if tk.strs_blob != 0 { dealloc(tk.strs_blob) }
    if tk.id_to_off != 0 { dealloc(tk.id_to_off) }
    if tk.id_to_len != 0 { dealloc(tk.id_to_len) }
    if tk.hash_tab != 0  { dealloc(tk.hash_tab)  }
    if tk_gpt2_b2c != 0 { dealloc(tk_gpt2_b2c); tk_gpt2_b2c = 0 }
    if tk_gpt2_c2b != 0 { dealloc(tk_gpt2_c2b); tk_gpt2_c2b = 0 }
    if tk_bpe_keys  != 0 { dealloc(tk_bpe_keys);  tk_bpe_keys  = 0 }
    if tk_bpe_ranks != 0 { dealloc(tk_bpe_ranks); tk_bpe_ranks = 0 }
    tk_bpe_cap = 0
    tk_bpe_count = 0
    tk_encoder_mode = 0
    tk_gpt2_kind = 0
    if tk.file_base != 0 && tk.file_size != 0 {
        syscall_raw(11, tk.file_base, tk.file_size, 0, 0, 0, 0)    // munmap
    }
}

// ---------------------------------------------------------------------------
// Switch a loaded tokenizer to GPT-2 byte-level BPE mode.
//
// Allocates and fills two tables:
//   byte_to_cp[256]  : byte → Unicode codepoint (per GPT-2 bytes_to_unicode)
//   cp_to_byte[324]  : codepoint → byte (0xFF for unmapped codepoints)
//
// The mapping: bytes in the "printable" ranges [33..126] ∪ [161..172] ∪
// [174..255] map to themselves (188 bytes). The remaining 68 "unprintable"
// bytes (0..32, 127..160, 173) are assigned codepoints 256..323 in the
// order they are encountered (so space=32 → U+0120 "Ġ", newline=10 →
// U+010A "Ċ", etc.). After switching kind, tokenizer_encode will
// byte-level-escape its input before greedy-matching, and tokenizer_decode
// will reverse the escape on its output.
// ---------------------------------------------------------------------------
fn tokenizer_set_kind_gpt2(Tokenizer tk) {
    tk_gpt2_kind = 1
    if tk_gpt2_b2c != 0 { dealloc(tk_gpt2_b2c) }
    if tk_gpt2_c2b != 0 { dealloc(tk_gpt2_c2b) }
    u64 b2c = alloc(256 * 4)
    u64 c2b = alloc(324)
    u64 k = 0
    while k < 324 {
        u8 ff = 0xFF
        store8(c2b + k, ff)
        k = k + 1
    }
    u64 b = 0
    u64 n = 0
    while b < 256 {
        u64 is_good = 0
        if b >= 33 && b <= 126 { is_good = 1 }
        else if b >= 161 && b <= 172 { is_good = 1 }
        else if b >= 174 && b <= 255 { is_good = 1 }
        if is_good != 0 {
            u32 cp = b
            unsafe { *((b2c + b * 4) as uint32) = cp }
            u8 bb = b
            store8(c2b + b, bb)
        } else {
            u64 cp64 = 256 + n
            u32 cp2 = cp64
            unsafe { *((b2c + b * 4) as uint32) = cp2 }
            u8 bb2 = b
            store8(c2b + cp64, bb2)
            n = n + 1
        }
        b = b + 1
    }
    tk_gpt2_b2c = b2c
    tk_gpt2_c2b = c2b
}

// ---------------------------------------------------------------------------
// Introspection — get a token's string representation. Returns (ptr, len)
// via the two out-pointer slots. ptr lives in the vocab strs_blob and is
// valid until tokenizer_free.
// ---------------------------------------------------------------------------
fn tokenizer_lookup(Tokenizer tk, u64 id, u64 out_ptr, u64 out_len) {
    if id >= tk.vocab_count {
        unsafe { *(out_ptr as u64) = 0 }
        unsafe { *(out_len as u64) = 0 }
        return
    }
    u64 off = 0
    unsafe { *((tk.id_to_off + id * 4) as uint32) -> off }
    u64 ln = 0
    unsafe { *((tk.id_to_len + id * 4) as uint32) -> ln }
    unsafe { *(out_ptr as u64) = (tk.strs_blob + off) }
    unsafe { *(out_len as u64) = ln }
}

// ---------------------------------------------------------------------------
// BPE merge-rank encoder (Phase 2, task #297).
//
// Used when tk_encoder_mode == 1 (set by tokenizer_load_from_gguf when
// the GGUF advertises tokenizer.ggml.model == "gpt2"). The algorithm:
//
//   1. Pre-tokenize the raw input into spans matching an *approximation*
//      of the llama-bpe / qwen2 regex
//        (?i:'s|'t|'re|'ve|'m|'ll|'d)
//        | [^\r\n\p{L}\p{N}]?\p{L}+
//        | \p{N}{1,3}
//        |  ?[^\s\p{L}\p{N}]+[\r\n]*
//        | \s*[\r\n]+
//        | \s+(?!\S)
//        | \s+
//      The approximation:
//        - "letter-like" = ASCII A-Z, a-z, or any byte ≥ 0x80
//          (we don't have full Unicode \p{L} tables; the ≥0x80 fallback
//          treats every UTF-8 continuation/start byte as letter-like).
//        - "digit" = ASCII 0-9; groups of up to 3 digits per pre-token.
//        - "symbol" = any other ASCII byte.
//        - A single leading SPACE (0x20, not tab/newline) folds into a
//          following letter-run OR symbol-run; trailing/multiple spaces
//          fall through to a whitespace-only pre-token.
//        - Newlines, tabs, and other ASCII whitespace do NOT fold — they
//          form their own single-char pre-token (verified against the
//          canonical regex output: '\tHello' → ['ĉHello'], so tab DOES
//          fold; '\nHello' → ['Ċ', 'Hello'], so newline does NOT fold).
//          We approximate by treating space (0x20) as foldable and
//          everything else as non-foldable. Tab-prefix prompts get
//          slightly different IDs than canonical but our 3 chat-REPL
//          test corpus (Hello / What is 2+2? / etc.) has no tabs.
//        - Contractions ('s, 't, 're, 've, 'm, 'll, 'd) are NOT
//          recognised; an apostrophe falls into the symbol-run branch.
//          Acceptable for chat REPLs whose validation corpus has no
//          English contractions.
//
//   2. For each pre-token span:
//        - Map each input byte b through tk_gpt2_b2c[b] to produce a
//          sequence of Unicode codepoints. Encode them as UTF-8.
//        - Look up each *codepoint* (1-3 UTF-8 bytes) in the vocab to
//          seed a list of single-codepoint token-ids.
//        - Run the merge loop: at each step, find the adjacent token
//          pair with the lowest merge-rank in tk_bpe_keys/ranks. Merge
//          that pair by looking up the concatenated byte string in the
//          vocab. Stop when no adjacent pair has a rank.
//        - Append the surviving token-ids to the output.
// ---------------------------------------------------------------------------

// Classify an input byte for pre-tokenization. Returns:
//   0 = digit (0-9)
//   1 = letter-like (ASCII A-Z, a-z, or byte >= 0x80)
//   2 = space (0x20)
//   3 = other whitespace (\t \n \r \f \v)
//   4 = symbol (anything else)
fn tk_bpe_byte_class(u64 b) -> u64 {
    if b >= 48 && b <= 57 { return 0 }
    if b >= 65 && b <= 90 { return 1 }
    if b >= 97 && b <= 122 { return 1 }
    if b >= 128 { return 1 }
    if b == 32 { return 2 }
    if b == 9 || b == 10 || b == 11 || b == 12 || b == 13 { return 3 }
    return 4
}

// Encode a single pre-token (raw input bytes) via byte→cp mapping then
// the BPE merge loop. Appends the resulting token-ids to ids_buf,
// updating *ids_count_ptr. ids_cap_ptr/ids_buf_ptr are in/out so we can
// grow when needed.
fn tk_bpe_encode_pretoken(Tokenizer tk, u64 in_ptr, u64 in_len,
                          u64 ids_buf_ptr, u64 ids_count_ptr,
                          u64 ids_cap_ptr) {
    if in_len == 0 { return }

    // Step 1: byte → cp UTF-8 expansion. Each input byte produces 1-3
    // UTF-8 bytes (b2c codepoints are <= U+0143 → ≤2-byte UTF-8 in
    // practice, but tk_utf8_encode handles wider too).
    u64 enc_cap = in_len * 3 + 4
    u64 enc_buf = alloc(enc_cap)
    u64 enc_off_arr = alloc(in_len * 4)   // u32[in_len] — start of each cp
    u64 enc_len_arr = alloc(in_len * 4)   // u32[in_len] — byte length of each cp
    u64 enc_len = 0
    u64 n_cps = 0
    u64 bi = 0
    while bi < in_len {
        u64 b = load8(in_ptr + bi)
        u32 cp32 = 0
        unsafe { *((tk_gpt2_b2c + b * 4) as uint32) -> cp32 }
        u64 cp = cp32
        u64 before = enc_len
        enc_len = tk_utf8_encode(enc_buf, enc_len, cp)
        u32 off32 = before
        u32 len32 = enc_len - before
        unsafe { *((enc_off_arr + n_cps * 4) as uint32) = off32 }
        unsafe { *((enc_len_arr + n_cps * 4) as uint32) = len32 }
        n_cps = n_cps + 1
        bi = bi + 1
    }

    // Step 2: seed token-id sequence with one id per codepoint. Each
    // single-codepoint UTF-8 string is guaranteed in the GPT-2 vocab
    // (vocab entries 0..255 mod the b2c permutation).
    //
    // Per-token state stored in parallel arrays (so merging is just a
    // memmove on these three arrays — no struct allocation churn):
    //   tok_id[k]   : current token-id for slot k
    //   tok_off[k]  : byte offset in enc_buf where this token's bytes start
    //   tok_len[k]  : byte length of this token's representation in enc_buf
    u64 tok_id  = alloc(n_cps * 4)
    u64 tok_off = alloc(n_cps * 4)
    u64 tok_len = alloc(n_cps * 4)
    u64 n_toks = 0
    u64 k = 0
    while k < n_cps {
        u32 cp_off32 = 0; unsafe { *((enc_off_arr + k * 4) as uint32) -> cp_off32 }
        u32 cp_len32 = 0; unsafe { *((enc_len_arr + k * 4) as uint32) -> cp_len32 }
        u64 cp_off = cp_off32
        u64 cp_len = cp_len32
        u64 id = tokenizer_id_of(tk, enc_buf + cp_off, cp_len)
        if id == 0xFFFFFFFFFFFFFFFF {
            // Should never happen for a well-formed gpt2 vocab — log
            // and skip the codepoint so we produce *something*.
            print_str("[tokenizer_gguf] WARNING: codepoint not in vocab at byte ")
            u64 s = fmt_dec(cp_off); print_str(s); dealloc(s); print_str("\n")
            k = k + 1
            continue
        }
        u32 id32  = id
        u32 off32 = cp_off
        u32 len32 = cp_len
        unsafe { *((tok_id  + n_toks * 4) as uint32) = id32  }
        unsafe { *((tok_off + n_toks * 4) as uint32) = off32 }
        unsafe { *((tok_len + n_toks * 4) as uint32) = len32 }
        n_toks = n_toks + 1
        k = k + 1
    }

    // Step 3: merge loop. O(N²) — fine for pre-tokens of typical size.
    while n_toks >= 2 {
        u64 best_rank = 0xFFFFFFFFFFFFFFFF
        u64 best_idx  = 0xFFFFFFFFFFFFFFFF
        u64 si = 0
        while si + 1 < n_toks {
            u32 l32 = 0; unsafe { *((tok_id + si * 4) as uint32)        -> l32 }
            u32 r32 = 0; unsafe { *((tok_id + (si + 1) * 4) as uint32)  -> r32 }
            u64 lid = l32
            u64 rid = r32
            u64 rk = tk_bpe_lookup(lid, rid)
            if rk != 0xFFFFFFFFFFFFFFFF {
                if rk < best_rank {
                    best_rank = rk
                    best_idx  = si
                }
            }
            si = si + 1
        }
        if best_idx == 0xFFFFFFFFFFFFFFFF { break }

        // Merge tokens[best_idx] + tokens[best_idx+1]. Compute the
        // merged byte span = [tok_off[best], tok_off[best] + tok_len[best] + tok_len[best+1]).
        u32 lof32 = 0; unsafe { *((tok_off + best_idx * 4)       as uint32) -> lof32 }
        u32 lln32 = 0; unsafe { *((tok_len + best_idx * 4)       as uint32) -> lln32 }
        u32 rln32 = 0; unsafe { *((tok_len + (best_idx + 1) * 4) as uint32) -> rln32 }
        u64 mof = lof32
        u64 mln = lln32 + rln32
        u64 merged_id = tokenizer_id_of(tk, enc_buf + mof, mln)
        if merged_id == 0xFFFFFFFFFFFFFFFF {
            // The merge is in the merges table but the merged string
            // isn't in the vocab — corrupt input. Bail rather than
            // looping forever on the same pair.
            print_str("[tokenizer_gguf] WARNING: merge rank present but merged token missing from vocab\n")
            break
        }
        u32 mid32 = merged_id
        u32 mln32 = mln
        unsafe { *((tok_id  + best_idx * 4) as uint32) = mid32 }
        unsafe { *((tok_len + best_idx * 4) as uint32) = mln32 }
        // Compact the suffix: shift slots [best_idx+2 .. n_toks) left by 1.
        u64 ci = best_idx + 1
        while ci + 1 < n_toks {
            u32 v_id = 0; unsafe { *((tok_id  + (ci + 1) * 4) as uint32) -> v_id }
            u32 v_of = 0; unsafe { *((tok_off + (ci + 1) * 4) as uint32) -> v_of }
            u32 v_ln = 0; unsafe { *((tok_len + (ci + 1) * 4) as uint32) -> v_ln }
            unsafe { *((tok_id  + ci * 4) as uint32) = v_id }
            unsafe { *((tok_off + ci * 4) as uint32) = v_of }
            unsafe { *((tok_len + ci * 4) as uint32) = v_ln }
            ci = ci + 1
        }
        n_toks = n_toks - 1
    }

    // Step 4: append surviving token-ids to the output buffer (growing
    // if needed). The output buffer is owned by the caller.
    u64 out_buf = 0; unsafe { *(ids_buf_ptr   as u64) -> out_buf }
    u64 out_cnt = 0; unsafe { *(ids_count_ptr as u64) -> out_cnt }
    u64 out_cap = 0; unsafe { *(ids_cap_ptr   as u64) -> out_cap }
    u64 need = out_cnt + n_toks
    if need > out_cap {
        u64 new_cap = out_cap * 2
        if new_cap < need { new_cap = need + 16 }
        u64 new_buf = alloc(new_cap * 4)
        u64 cc = 0
        while cc < out_cnt {
            u32 v = 0; unsafe { *((out_buf + cc * 4) as uint32) -> v }
            unsafe { *((new_buf + cc * 4) as uint32) = v }
            cc = cc + 1
        }
        if out_buf != 0 { dealloc(out_buf) }
        out_buf = new_buf
        out_cap = new_cap
        unsafe { *(ids_buf_ptr as u64) = out_buf }
        unsafe { *(ids_cap_ptr as u64) = out_cap }
    }
    u64 ti = 0
    while ti < n_toks {
        u32 v = 0; unsafe { *((tok_id + ti * 4) as uint32) -> v }
        unsafe { *((out_buf + (out_cnt + ti) * 4) as uint32) = v }
        ti = ti + 1
    }
    out_cnt = out_cnt + n_toks
    unsafe { *(ids_count_ptr as u64) = out_cnt }

    dealloc(enc_buf)
    dealloc(enc_off_arr)
    dealloc(enc_len_arr)
    dealloc(tok_id)
    dealloc(tok_off)
    dealloc(tok_len)
}

// Top-level BPE encoder — pre-tokenizes the input, then runs
// tk_bpe_encode_pretoken on each pre-token span.
//
// Pre-tokenization rules — see the table at the top of this section.
// Pre-tokens are emitted in input-order; each is a contiguous byte
// range [start, end) of the original input.
fn tk_bpe_encode(Tokenizer tk, u64 input, u64 input_len,
                 u64 out_ids_ptr, u64 out_count_ptr) {
    // Output buffer — sized at first call to avoid an upfront max-bytes
    // alloc. We grow on demand inside tk_bpe_encode_pretoken.
    u64 out_cap = 64
    u64 out_buf = alloc(out_cap * 4)
    u64 out_cnt = 0
    u64 buf_box = alloc(8); unsafe { *(buf_box as u64) = out_buf }
    u64 cnt_box = alloc(8); unsafe { *(cnt_box as u64) = out_cnt }
    u64 cap_box = alloc(8); unsafe { *(cap_box as u64) = out_cap }

    u64 p = 0
    while p < input_len {
        u64 c = load8(input + p)
        u64 cls = tk_bpe_byte_class(c)

        if cls == 0 {
            // Digit run of up to 3 chars.
            u64 end = p + 1
            u64 take = 1
            u64 stop = 0
            while stop == 0 && end < input_len && take < 3 {
                if tk_bpe_byte_class(load8(input + end)) != 0 { stop = 1 }
                else {
                    end = end + 1
                    take = take + 1
                }
            }
            tk_bpe_encode_pretoken(tk, input + p, end - p, buf_box, cnt_box, cap_box)
            p = end
        } else if cls == 1 {
            // Letter run.
            u64 end = p + 1
            u64 stop = 0
            while stop == 0 && end < input_len {
                if tk_bpe_byte_class(load8(input + end)) != 1 { stop = 1 }
                else { end = end + 1 }
            }
            tk_bpe_encode_pretoken(tk, input + p, end - p, buf_box, cnt_box, cap_box)
            p = end
        } else if cls == 2 {
            // Space — find end of contiguous space run, decide folding.
            u64 sp_end = p + 1
            u64 stop_s = 0
            while stop_s == 0 && sp_end < input_len {
                if load8(input + sp_end) != 32 { stop_s = 1 }
                else { sp_end = sp_end + 1 }
            }
            // If the byte after the space run is letter or symbol, the
            // LAST space folds into that following run.
            u64 fold = 0
            if sp_end < input_len {
                u64 nc = load8(input + sp_end)
                u64 ncls = tk_bpe_byte_class(nc)
                if ncls == 1 { fold = 1 }
                if ncls == 4 { fold = 1 }
            }
            if fold == 1 {
                if sp_end - p > 1 {
                    // Emit all but last space as one whitespace pre-token.
                    tk_bpe_encode_pretoken(tk, input + p, sp_end - p - 1, buf_box, cnt_box, cap_box)
                }
                // Last space + following run.
                u64 fold_start = sp_end - 1
                u64 nc = load8(input + sp_end)
                u64 ncls = tk_bpe_byte_class(nc)
                u64 run_end = sp_end + 1
                if ncls == 1 {
                    u64 stop_l = 0
                    while stop_l == 0 && run_end < input_len {
                        if tk_bpe_byte_class(load8(input + run_end)) != 1 { stop_l = 1 }
                        else { run_end = run_end + 1 }
                    }
                } else {
                    // Symbol run — keep extending while we see symbols,
                    // then absorb any trailing newlines.
                    u64 stop_sym = 0
                    while stop_sym == 0 && run_end < input_len {
                        if tk_bpe_byte_class(load8(input + run_end)) != 4 { stop_sym = 1 }
                        else { run_end = run_end + 1 }
                    }
                    u64 stop_nl = 0
                    while stop_nl == 0 && run_end < input_len {
                        u64 rc = load8(input + run_end)
                        if rc != 10 && rc != 13 { stop_nl = 1 }
                        else { run_end = run_end + 1 }
                    }
                }
                tk_bpe_encode_pretoken(tk, input + fold_start, run_end - fold_start, buf_box, cnt_box, cap_box)
                p = run_end
            } else {
                // No folding — entire whitespace run is its own pre-token.
                tk_bpe_encode_pretoken(tk, input + p, sp_end - p, buf_box, cnt_box, cap_box)
                p = sp_end
            }
        } else if cls == 3 {
            // Non-space whitespace (\t \n \r etc.) — single-byte
            // pre-token, no folding. (Tab actually DOES fold per the
            // canonical regex but we don't bother — see the rules block
            // above.)
            tk_bpe_encode_pretoken(tk, input + p, 1, buf_box, cnt_box, cap_box)
            p = p + 1
        } else {
            // Symbol run, no leading space.
            u64 end = p + 1
            u64 stop_sym = 0
            while stop_sym == 0 && end < input_len {
                if tk_bpe_byte_class(load8(input + end)) != 4 { stop_sym = 1 }
                else { end = end + 1 }
            }
            // Absorb trailing newlines per regex alt 4 ([\r\n]*).
            u64 stop_nl = 0
            while stop_nl == 0 && end < input_len {
                u64 nc = load8(input + end)
                if nc != 10 && nc != 13 { stop_nl = 1 }
                else { end = end + 1 }
            }
            tk_bpe_encode_pretoken(tk, input + p, end - p, buf_box, cnt_box, cap_box)
            p = end
        }
    }

    unsafe { *(buf_box as u64) -> out_buf }
    unsafe { *(cnt_box as u64) -> out_cnt }
    unsafe { *(cap_box as u64) -> out_cap }
    dealloc(buf_box); dealloc(cnt_box); dealloc(cap_box)

    unsafe { *(out_ids_ptr   as u64) = out_buf }
    unsafe { *(out_count_ptr as u64) = out_cnt }
}

// ---------------------------------------------------------------------------
// Phase B — greedy encode. For each starting position in the input,
// consume the longest run of bytes that form a vocab entry. If no prefix
// matches, emit the byte-fallback token for that single byte and advance.
// Input is first normalised by replacing ' ' (0x20) with '▁' (0xE2 0x96 0x81).
//
// Output: a heap-allocated uint32[count] array written to *out_ids_ptr,
// and the token count written to *out_count_ptr. Caller dealloc()s out_ids.
// ---------------------------------------------------------------------------
fn tokenizer_encode(Tokenizer tk, u64 input, u64 input_len,
                    u64 out_ids_ptr, u64 out_count_ptr) {
    // Dispatch to the BPE encoder when tokenizer_load_from_gguf set the
    // GPT-2 mode flag. The greedy code path below handles SPM models
    // and any legacy tokenizer_load(tokenizer.json) caller that hasn't
    // been routed through tokenizer_load_from_gguf yet.
    if tk_encoder_mode == 1 {
        tk_bpe_encode(tk, input, input_len, out_ids_ptr, out_count_ptr)
        return
    }
    // Step 1: normalise.
    //   kind == 0 (SentencePiece): 0x20 → U+2581 "▁" (3-byte UTF-8).
    //   kind == 1 (GPT-2 byte-level): each input byte b → UTF-8 of
    //                                 byte_to_cp[b]. Worst case is 2 bytes
    //                                 (codepoints ≤ U+0143 for our table).
    // Worst-case expansion factor is 3x for kind 0, 2x for kind 1 — use 3x
    // so the same buffer works in both cases.
    u64 norm_cap = input_len * 3 + 4
    u64 norm = alloc(norm_cap)
    u64 nlen = 0
    u64 i = 0
    if tk_gpt2_kind == 1 {
        while i < input_len {
            u64 c = load8(input + i)
            u32 cp32 = 0
            unsafe { *((tk_gpt2_b2c + c * 4) as uint32) -> cp32 }
            u64 cp = cp32
            nlen = tk_utf8_encode(norm, nlen, cp)
            i = i + 1
        }
    } else {
        while i < input_len {
            u64 c = load8(input + i)
            if c == 32 {
                u8 a = 0xE2
                u8 b = 0x96
                u8 cc = 0x81
                store8(norm + nlen, a)
                store8(norm + nlen + 1, b)
                store8(norm + nlen + 2, cc)
                nlen = nlen + 3
            } else {
                u8 cb = c
                store8(norm + nlen, cb)
                nlen = nlen + 1
            }
            i = i + 1
        }
    }

    // Step 2: greedy match. Output array sized to nlen (worst case: every
    // byte becomes its own byte-fallback token). Typical usage is much less.
    u64 ids_cap = nlen
    if ids_cap < 16 { ids_cap = 16 }
    u64 ids = alloc(ids_cap * 4)
    u64 count = 0

    u64 p = 0
    while p < nlen {
        u64 max_try = tk.max_tok_len
        if p + max_try > nlen { max_try = nlen - p }

        u64 matched_len = 0
        u64 matched_id = 0xFFFFFFFFFFFFFFFF
        u64 try_len = max_try
        while try_len > 0 {
            u64 id = tokenizer_id_of(tk, norm + p, try_len)
            if id != 0xFFFFFFFFFFFFFFFF {
                matched_id = id
                matched_len = try_len
                try_len = 0
                continue
            }
            try_len = try_len - 1
        }

        if matched_len == 0 {
            if tk_gpt2_kind == 1 {
                // GPT-2 byte-level has no <0xHH> table; every single
                // bytes_to_unicode codepoint is guaranteed present in the
                // vocab as a 1-char token. If we still fall through, the
                // vocab is broken — advance one byte and keep going so we
                // produce *something* rather than looping forever.
                p = p + 1
            } else {
                // Byte fallback: emit <0xHH> for the single byte at p.
                u64 bv = load8(norm + p)
                u32 fb_id = tk.byte_fallback_base + bv
                unsafe { *((ids + count * 4) as uint32) = fb_id }
                count = count + 1
                p = p + 1
            }
        } else {
            u32 mid = matched_id
            unsafe { *((ids + count * 4) as uint32) = mid }
            count = count + 1
            p = p + matched_len
        }
    }

    dealloc(norm)
    unsafe { *(out_ids_ptr as u64) = ids }
    unsafe { *(out_count_ptr as u64) = count }
}

// ---------------------------------------------------------------------------
// Decoder — reverse of encode. For each token:
//   — if it's in the byte-fallback range, append that raw byte;
//   — else append its vocab string as-is.
// Then replace every '▁' (E2 96 81) with ' ' (0x20).
// Returns a heap-allocated, null-terminated string. Caller dealloc()s.
// ---------------------------------------------------------------------------
fn tokenizer_decode(Tokenizer tk, u64 ids, u64 count) -> u64 {
    // Two-pass: compute output length, allocate, write.
    u64 out_len = 0
    u64 i = 0
    while i < count {
        u32 id32 = 0
        unsafe { *((ids + i * 4) as uint32) -> id32 }
        u64 id = id32
        if id >= tk.byte_fallback_base && id < tk.byte_fallback_base + 256 {
            out_len = out_len + 1
        } else if id < tk.vocab_count {
            u64 ln = 0
            unsafe { *((tk.id_to_len + id * 4) as uint32) -> ln }
            out_len = out_len + ln
        }
        i = i + 1
    }

    u64 buf = alloc(out_len + 1)
    u64 w = 0
    i = 0
    while i < count {
        u32 id32 = 0
        unsafe { *((ids + i * 4) as uint32) -> id32 }
        u64 id = id32
        if id >= tk.byte_fallback_base && id < tk.byte_fallback_base + 256 {
            u8 b = id - tk.byte_fallback_base
            store8(buf + w, b)
            w = w + 1
        } else if id < tk.vocab_count {
            u64 off = 0
            unsafe { *((tk.id_to_off + id * 4) as uint32) -> off }
            u64 ln = 0
            unsafe { *((tk.id_to_len + id * 4) as uint32) -> ln }
            memcpy(buf + w, tk.strs_blob + off, ln)
            w = w + ln
        }
        i = i + 1
    }

    if tk_gpt2_kind == 1 {
        // GPT-2 byte-level reverse. The concatenated token-string buffer
        // is UTF-8 of Unicode codepoints in [0..323]. Walk the codepoints
        // one at a time and map each back to its original byte via the
        // static cp_to_byte table. Output shrinks (≤ 1 output byte per
        // codepoint) so in-place would be safe too, but a second buffer
        // keeps the code simpler.
        u64 out_byte = alloc(w + 1)
        u64 r2 = 0
        u64 wo = 0
        while r2 < w {
            u64 b0 = load8(buf + r2)
            u64 cp = 0
            u64 used = 1
            if b0 < 0x80 {
                cp = b0
                used = 1
            } else if (b0 & 0xE0) == 0xC0 {
                u64 b1 = load8(buf + r2 + 1)
                cp = ((b0 & 0x1F) << 6) | (b1 & 0x3F)
                used = 2
            } else if (b0 & 0xF0) == 0xE0 {
                u64 b1 = load8(buf + r2 + 1)
                u64 b2 = load8(buf + r2 + 2)
                cp = ((b0 & 0x0F) << 12) | ((b1 & 0x3F) << 6) | (b2 & 0x3F)
                used = 3
            } else {
                // 4-byte UTF-8. Not reachable for GPT-2 byte-level vocab
                // (codepoints capped at 323) but keep it safe: skip.
                used = 4
                cp = 0xFFFF
            }
            if cp < 324 {
                u64 rb = load8(tk_gpt2_c2b + cp)
                if rb < 256 {
                    u8 ob = rb
                    store8(out_byte + wo, ob)
                    wo = wo + 1
                }
            }
            r2 = r2 + used
        }
        u8 zero2 = 0
        store8(out_byte + wo, zero2)
        dealloc(buf)
        return out_byte
    }

    // kind == 0 (SentencePiece): in-place replace every "▁" (E2 96 81)
    // with a single space, shifting the tail left by 2 bytes per match.
    u64 r = 0
    u64 sw = 0
    while r < w {
        if r + 2 < w {
            u64 b0 = load8(buf + r)
            u64 b1 = load8(buf + r + 1)
            u64 b2 = load8(buf + r + 2)
            if b0 == 0xE2 && b1 == 0x96 && b2 == 0x81 {
                u8 sp = 0x20
                store8(buf + sw, sp)
                sw = sw + 1
                r = r + 3
                continue
            }
        }
        u8 bv = load8(buf + r)
        store8(buf + sw, bv)
        sw = sw + 1
        r = r + 1
    }
    u8 zero = 0
    store8(buf + sw, zero)
    return buf
}
