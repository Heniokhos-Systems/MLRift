    patch_u32(296, total_aligned6 & 0xFFFFFFFF)
    patch_u32(300, (total_aligned6 >> 32) & 0xFFFFFFFF)
    patch_u32(304, dal6 & 0xFFFFFFFF)
    patch_u32(308, (dal6 >> 32) & 0xFFFFFFFF)
    // __LINKEDIT: chained fixups + symtab + strtab via helper
    uint64 lva6 = dva6 + dal6
    uint64 lfoff6 = dfoff6 + dal6
    uint64 main_off6 = find_main_offset()
    emit_macho_linkedit_a64(lfoff6, main_off6)
    uint64 lraw6 = codegen_output_len() - lfoff6
    uint64 lsize6 = (lraw6 + 16383) & ~16383
    if lsize6 == 0 { lsize6 = 16384 }
    while codegen_output_len() < lfoff6 + lsize6 { emit_byte(0) }
    patch_u32(352, lva6 & 0xFFFFFFFF)
    patch_u32(356, (lva6 >> 32) & 0xFFFFFFFF)
    patch_u32(360, lsize6 & 0xFFFFFFFF)
    patch_u32(364, (lsize6 >> 32) & 0xFFFFFFFF)
    patch_u32(368, lfoff6 & 0xFFFFFFFF)
    patch_u32(372, (lfoff6 >> 32) & 0xFFFFFFFF)
    patch_u32(376, lraw6 & 0xFFFFFFFF)
    patch_u32(380, (lraw6 >> 32) & 0xFFFFFFFF)

    uint64 macho_a64_len = codegen_output_len()
    uint64 macho_a64_buf = alloc(macho_a64_len)
    uint64 mai = 0
    while mai < macho_a64_len {
        uint64 sp = out_buf + mai
        uint64 dp = macho_a64_buf + mai
        uint64 bv = 0
        unsafe { *(sp as uint8) -> bv }
        uint8 bb = bv
        unsafe { *(dp as uint8) = bb }
        mai = mai + 1
    }
    set_target_arch(0)

    // === Compile x86_64 Android PIE ELF ===
    target_os = 3
    out_len = 0
    fn_count = 0
    fixup_count = 0
    static_fixup_count = 0
    str_fixup_count = 0
    str_len = 0
    extern_fn_count = 0
    extern_call_count = 0
    fnaddr_fixup_count = 0
    static_count = 0
    static_data_size = 0
    struct_count = 0
    struct_var_count = 0
    enum_count = 0
    type_alias_count = 0
    arr_elem_count = 0
    fn_ret_float_count = 0
    fn_ret_struct_count = 0
    line_table_count = 0
    last_recorded_line = 0
    debug_file_count = 0
    diag_count = 0
    diag_error_count = 0
    diag_warn_count = 0
    slice_len_count = 0
    device_count = 0
    device_field_count = 0
    var_type_count = 0
    win_iat_fixup_count = 0
    a64_win_iat_fixup_count = 0

    restore_src_and_tokens(source, size, src_snapshot, my_tokens, tok_bytes, tok_snapshot)
    ast_init(524288)
    parser_init(my_tokens, saved_tcount)
    uint64 root8 = parse_module()
    inline_pass(root8)
    dce_init()
    dce_scan(root8)

    emit_elf_header_android_x86_64()
    uint64 text_start8 = codegen_output_len()

    uint32 child8 = ast_child(root8)
    uint64 wchild8 = child8
    while wchild8 != 0 {
        uint32 ck8 = ast_kind(wchild8)
        if ck8 == 2 {
            uint32 fn_name8 = ast_data1(wchild8)
            if dce_is_live(fn_name8) != 0 {
                if emit_ir_mode != 0 {
                    fn_register(fn_name8, out_len)
                    ir_init()
                    ir_emit_x86_function(wchild8)
                } else {
                    gen_function(wchild8)
                }
            }
        }
        uint32 nxt8 = ast_next(wchild8)
        wchild8 = nxt8
    }
    resolve_fixups()
    resolve_fnaddr_fixups()
    resolve_teardown_fixups()
    uint64 data_start8 = codegen_output_len()
    emit_static_data()
    resolve_static_fixups(data_start8)
    uint64 str_start8 = codegen_output_len()
    emit_string_data()
    resolve_string_fixups(str_start8)

    // Android PIE ELF: separate RX code + RW data segments
    uint64 androidx_entry = find_main_offset()
    patch_u32(24, androidx_entry & 0xFFFFFFFF)
    patch_u32(28, (androidx_entry >> 32) & 0xFFFFFFFF)
    uint64 androidx_rx = codegen_output_len()
    patch_u32(208, androidx_rx & 0xFFFFFFFF)
    patch_u32(212, (androidx_rx >> 32) & 0xFFFFFFFF)
    patch_u32(216, androidx_rx & 0xFFFFFFFF)
    patch_u32(220, (androidx_rx >> 32) & 0xFFFFFFFF)
    uint64 androidx_rx_aligned = (androidx_rx + 0xFFFF) & ~0xFFFF
    while codegen_output_len() < androidx_rx_aligned { emit_byte(0) }
    uint64 ax_dfoff = codegen_output_len()
    emit_static_data()
    uint64 ax_draw = codegen_output_len() - ax_dfoff
    uint64 ax_dal = (ax_draw + 0xFFFF) & ~0xFFFF
    if ax_dal == 0 { ax_dal = 0x10000 }
    while codegen_output_len() < ax_dfoff + ax_dal { emit_byte(0) }
    resolve_static_fixups(ax_dfoff)
    patch_u32(296, ax_dfoff & 0xFFFFFFFF)
    patch_u32(300, (ax_dfoff >> 32) & 0xFFFFFFFF)
    patch_u32(304, androidx_rx_aligned & 0xFFFFFFFF)
    patch_u32(308, (androidx_rx_aligned >> 32) & 0xFFFFFFFF)
    patch_u32(312, androidx_rx_aligned & 0xFFFFFFFF)
    patch_u32(316, (androidx_rx_aligned >> 32) & 0xFFFFFFFF)
    patch_u32(320, ax_draw & 0xFFFFFFFF)
    patch_u32(324, (ax_draw >> 32) & 0xFFFFFFFF)
    // p_memsz = page-aligned size: bionic SIGBUSes on p_memsz=0.
    patch_u32(328, ax_dal & 0xFFFFFFFF)
    patch_u32(332, (ax_dal >> 32) & 0xFFFFFFFF)

    uint64 androidx_len = codegen_output_len()
    uint64 androidx_buf = alloc(androidx_len)
    uint64 axi = 0
    while axi < androidx_len {
        uint64 sp = out_buf + axi
        uint64 dp = androidx_buf + axi
        uint64 bv = 0
        unsafe { *(sp as uint8) -> bv }
        uint8 bb = bv
        unsafe { *(dp as uint8) = bb }
        axi = axi + 1
    set_target_arch(1)
    }

    // === Compile ARM64 Android PIE ELF ===
    target_os = 3
    out_len = 0
    fn_count = 0
    fixup_count = 0
    static_fixup_count = 0
    str_fixup_count = 0
    str_len = 0
    extern_fn_count = 0
    extern_call_count = 0
    fnaddr_fixup_count = 0
    static_count = 0
    static_data_size = 0
    struct_count = 0
    struct_var_count = 0
    enum_count = 0
    type_alias_count = 0
    arr_elem_count = 0
    fn_ret_float_count = 0
    fn_ret_struct_count = 0
    line_table_count = 0
    last_recorded_line = 0
    debug_file_count = 0
    diag_count = 0
    diag_error_count = 0
    diag_warn_count = 0
    slice_len_count = 0
    device_count = 0
    device_field_count = 0
    var_type_count = 0
    win_iat_fixup_count = 0
    a64_win_iat_fixup_count = 0

    restore_src_and_tokens(source, size, src_snapshot, my_tokens, tok_bytes, tok_snapshot)
    ast_init(524288)
    parser_init(my_tokens, saved_tcount)
    uint64 root7 = parse_module()
    inline_pass(root7)
    dce_init()
    dce_scan(root7)

    emit_elf_header_android_a64()
    uint64 text_start7 = codegen_output_len()

    uint32 child7 = ast_child(root7)
    uint64 wchild7 = child7
    while wchild7 != 0 {
        uint32 ck7 = ast_kind(wchild7)
        if ck7 == 2 {
            uint32 fn_name7 = ast_data1(wchild7)
            if dce_is_live(fn_name7) != 0 {
                if emit_ir_mode != 0 {
                    fn_register(fn_name7, out_len)
                    ir_init()
                    ir_emit_arm64_function(wchild7)
                } else {
                    gen_function_a64(wchild7)
                }
            }
        }
        uint32 nxt7 = ast_next(wchild7)
        wchild7 = nxt7
    }
    resolve_fixups_a64()
    resolve_fnaddr_fixups_a64()
    // Align to 8 bytes on arm64 (matches direct compile() path) so static
    // data LDR (imm12 scaled by 8) can encode any slot offset exactly.
    while (codegen_output_len() & 7) != 0 { emit_byte(0) }
    uint64 data_start7 = codegen_output_len()
    emit_static_data()
    resolve_static_fixups_a64(data_start7)
    uint64 str_start7 = codegen_output_len()
    emit_string_data()
    resolve_string_fixups_a64(str_start7)

    // Android PIE ELF: separate RX code + RW data segments
    uint64 android_entry = find_main_offset()
    patch_u32(24, android_entry & 0xFFFFFFFF)
    patch_u32(28, (android_entry >> 32) & 0xFFFFFFFF)
    // PT_LOAD RX: code + strings only
    uint64 android_rx = codegen_output_len()
    patch_u32(208, android_rx & 0xFFFFFFFF)
    patch_u32(212, (android_rx >> 32) & 0xFFFFFFFF)
    patch_u32(216, android_rx & 0xFFFFFFFF)
    patch_u32(220, (android_rx >> 32) & 0xFFFFFFFF)
    // Pad to 64KB page boundary for PT_LOAD RW
    uint64 android_rx_aligned = (android_rx + 0xFFFF) & ~0xFFFF
    while codegen_output_len() < android_rx_aligned { emit_byte(0) }
    // Emit data segment (statics)
    uint64 a7_dfoff = codegen_output_len()
    emit_static_data()
    uint64 a7_draw = codegen_output_len() - a7_dfoff
    uint64 a7_dal = (a7_draw + 0xFFFF) & ~0xFFFF
    if a7_dal == 0 { a7_dal = 0x10000 }
    while codegen_output_len() < a7_dfoff + a7_dal { emit_byte(0) }
    // Re-resolve static fixups to point into RW segment
    resolve_static_fixups_a64(a7_dfoff)
    // Patch PT_LOAD RW @288
    patch_u32(296, a7_dfoff & 0xFFFFFFFF)
    patch_u32(300, (a7_dfoff >> 32) & 0xFFFFFFFF)
    patch_u32(304, android_rx_aligned & 0xFFFFFFFF)
    patch_u32(308, (android_rx_aligned >> 32) & 0xFFFFFFFF)
    patch_u32(312, android_rx_aligned & 0xFFFFFFFF)
    patch_u32(316, (android_rx_aligned >> 32) & 0xFFFFFFFF)
    patch_u32(320, a7_draw & 0xFFFFFFFF)
    patch_u32(324, (a7_draw >> 32) & 0xFFFFFFFF)
    // p_memsz = page-aligned size: bionic SIGBUSes on p_memsz=0.
    patch_u32(328, a7_dal & 0xFFFFFFFF)
    patch_u32(332, (a7_dal >> 32) & 0xFFFFFFFF)

    uint64 android_len = codegen_output_len()
    uint64 android_buf = alloc(android_len)
    uint64 adi = 0
    while adi < android_len {
        uint64 sp = out_buf + adi
        uint64 dp = android_buf + adi
        uint64 bv = 0
        unsafe { *(sp as uint8) -> bv }
        uint8 bb = bv
        unsafe { *(dp as uint8) = bb }
        adi = adi + 1
    }

    // Reset target_os for fat binary emission
    target_os = 0

    // === BCJ filter before compression ===
    // x86_64 slices: filter E8/E9 CALL/JMP
    filter_x86_64_bcj(x86_buf, x86_len, 1)
    filter_x86_64_bcj(pe_x86_buf, pe_x86_len, 1)
    filter_x86_64_bcj(macho_x86_buf, macho_x86_len, 1)
    filter_x86_64_bcj(androidx_buf, androidx_len, 1)
    // arm64 slices: filter B/BL instructions
    filter_aarch64_bcj(a64_buf, a64_len, 1)
    filter_aarch64_bcj(pe_a64_buf, pe_a64_len, 1)
    filter_aarch64_bcj(macho_a64_buf, macho_a64_len, 1)
    filter_aarch64_bcj(android_buf, android_len, 1)

    // === Custom target subset: emit only the selected slices, each
    // compressed as a standalone (non-paired) LZ4 blob. The runner treats
    // an entry with pair_off == 0 and pair_uncomp_size == slice_uncomp_size
    // as a single-slice blob. Full-set selection (all 8) drops into the
    // default paired-compression path below for tighter compression.
    if target_mask != 0 && target_mask != 0xFF {
        uint64 comp_bufs = alloc(8 * 8)
        uint64 comp_lens = alloc(8 * 8)
        uint64 uncomp_lens = alloc(8 * 8)
        uint64 zi = 0
        while zi < 8 {
            uint64 zp = comp_bufs + zi * 8
            uint64 zl = comp_lens + zi * 8
            uint64 zu = uncomp_lens + zi * 8
            unsafe { *(zp as uint64) = 0 }
            unsafe { *(zl as uint64) = 0 }
            unsafe { *(zu as uint64) = 0 }
            zi = zi + 1
        }

        uint64 sel_count = 0
        uint64 aid = 1
        while aid <= 8 {
            uint64 bit = aid - 1
            if ((target_mask >> bit) & 1) != 0 {
                uint64 buf = 0
                uint64 len = 0
                if aid == 1 { buf = x86_buf; len = x86_len }
                if aid == 2 { buf = a64_buf; len = a64_len }
                if aid == 3 { buf = pe_x86_buf; len = pe_x86_len }
                if aid == 4 { buf = pe_a64_buf; len = pe_a64_len }
                if aid == 5 { buf = macho_x86_buf; len = macho_x86_len }
                if aid == 6 { buf = macho_a64_buf; len = macho_a64_len }
                if aid == 7 { buf = android_buf; len = android_len }
                if aid == 8 { buf = androidx_buf; len = androidx_len }
                uint64 cap = lz4_compress_bound(len)
                uint64 cbuf = alloc(cap)
                uint64 clen = lz4_compress_frame(buf, len, cbuf)
                uint64 cp = comp_bufs + bit * 8
                uint64 lp = comp_lens + bit * 8
                uint64 ulp = uncomp_lens + bit * 8
                unsafe { *(cp as uint64) = cbuf }
                unsafe { *(lp as uint64) = clen }
                unsafe { *(ulp as uint64) = len }
                sel_count = sel_count + 1
            }
            aid = aid + 1
        }

        out_len = 0
        emit_mlrbofat_v2_header(sel_count)
        uint64 c_data_offset = 16 + sel_count * 48
        uint64 c_pad = (16 - (c_data_offset & 15)) & 15
        c_data_offset = c_data_offset + c_pad

        uint64 cur_off = c_data_offset
        uint64 aid2 = 1
        while aid2 <= 8 {
            uint64 bit2 = aid2 - 1
            if ((target_mask >> bit2) & 1) != 0 {
                uint64 lp2 = comp_lens + bit2 * 8
                uint64 ulp2 = uncomp_lens + bit2 * 8
                uint64 clen2 = 0
                uint64 ulen2 = 0
                unsafe { *(lp2 as uint64) -> clen2 }
                unsafe { *(ulp2 as uint64) -> ulen2 }
                emit_mlrbofat_v2_entry_hdr(aid2, 1, cur_off, clen2, ulen2)
                emit_mlrbofat_v2_entry_rt(0, ulen2)
                cur_off = cur_off + clen2
            }
            aid2 = aid2 + 1
        }

        uint64 cpi = 0
        while cpi < c_pad { emit_byte(0); cpi = cpi + 1 }

        uint64 aid3 = 1
        while aid3 <= 8 {
            uint64 bit3 = aid3 - 1
            if ((target_mask >> bit3) & 1) != 0 {
                uint64 cp3 = comp_bufs + bit3 * 8
                uint64 lp3 = comp_lens + bit3 * 8
                uint64 cbuf3 = 0
                uint64 clen3 = 0
                unsafe { *(cp3 as uint64) -> cbuf3 }
                unsafe { *(lp3 as uint64) -> clen3 }
                emit_raw_bytes(cbuf3, clen3)
            }
            aid3 = aid3 + 1
        }

        codegen_write_output(output_path)

        uint8[64] nb3
        uint64 msg3 = "custom fat binary: "
        write(1, msg3, 19)
        uint64 nl3 = fmt_uint(nb3, sel_count)
        write(1, nb3, nl3)
        msg3 = " slice"
        write(1, msg3, 6)
        if sel_count != 1 {
            msg3 = "s"
            write(1, msg3, 1)
        }
        msg3 = " -> "
        write(1, msg3, 4)
        uint64 olen3 = str_len(output_path)
        write(1, output_path, olen3)
        msg3 = "\n"
        write(1, msg3, 1)
        return
    }

    // === LZ4 compress 4 arch-paired blobs ===
    // Best layout from experimental benchmarks (FAT_COMPRESSION_EXPERIMENTS.md):
    //   x86_64: Linux + macOS,     Windows + Android
    //   arm64:  Linux + Android,   Windows + macOS
    uint64[1] x64_lm_comp_slot
    uint64[1] x64_lm_comp_len_slot
    uint64[1] x64_lm_linux_off_slot
    uint64[1] x64_lm_mac_off_slot
    uint64[1] x64_lm_pair_len_slot
    compress_pair_best(
        x86_buf, x86_len, macho_x86_buf, macho_x86_len,
        x64_lm_comp_slot, x64_lm_comp_len_slot,
        x64_lm_linux_off_slot, x64_lm_mac_off_slot,
        x64_lm_pair_len_slot
    )
    uint64 x64_lm_comp = slot_load_u64(x64_lm_comp_slot)
    uint64 x64_lm_comp_len = slot_load_u64(x64_lm_comp_len_slot)
    uint64 x64_lm_linux_off = slot_load_u64(x64_lm_linux_off_slot)
    uint64 x64_lm_mac_off = slot_load_u64(x64_lm_mac_off_slot)
    uint64 x64_lm_pair_len = slot_load_u64(x64_lm_pair_len_slot)

    uint64[1] x64_wa_comp_slot
    uint64[1] x64_wa_comp_len_slot
    uint64[1] x64_wa_win_off_slot
    uint64[1] x64_wa_android_off_slot
    uint64[1] x64_wa_pair_len_slot
    compress_pair_best(
        pe_x86_buf, pe_x86_len, androidx_buf, androidx_len,
        x64_wa_comp_slot, x64_wa_comp_len_slot,
        x64_wa_win_off_slot, x64_wa_android_off_slot,
        x64_wa_pair_len_slot
    )
    uint64 x64_wa_comp = slot_load_u64(x64_wa_comp_slot)
    uint64 x64_wa_comp_len = slot_load_u64(x64_wa_comp_len_slot)
    uint64 x64_wa_win_off = slot_load_u64(x64_wa_win_off_slot)
    uint64 x64_wa_android_off = slot_load_u64(x64_wa_android_off_slot)
    uint64 x64_wa_pair_len = slot_load_u64(x64_wa_pair_len_slot)

    uint64[1] arm_la_comp_slot
    uint64[1] arm_la_comp_len_slot
    uint64[1] arm_la_linux_off_slot
    uint64[1] arm_la_android_off_slot
    uint64[1] arm_la_pair_len_slot
    compress_pair_best(
        a64_buf, a64_len, android_buf, android_len,
        arm_la_comp_slot, arm_la_comp_len_slot,
        arm_la_linux_off_slot, arm_la_android_off_slot,
        arm_la_pair_len_slot
    )
    uint64 arm_la_comp = slot_load_u64(arm_la_comp_slot)
    uint64 arm_la_comp_len = slot_load_u64(arm_la_comp_len_slot)
    uint64 arm_la_linux_off = slot_load_u64(arm_la_linux_off_slot)
    uint64 arm_la_android_off = slot_load_u64(arm_la_android_off_slot)
    uint64 arm_la_pair_len = slot_load_u64(arm_la_pair_len_slot)

    uint64[1] arm_wm_comp_slot
    uint64[1] arm_wm_comp_len_slot
    uint64[1] arm_wm_win_off_slot
    uint64[1] arm_wm_mac_off_slot
    uint64[1] arm_wm_pair_len_slot
    compress_pair_best(
        pe_a64_buf, pe_a64_len, macho_a64_buf, macho_a64_len,
        arm_wm_comp_slot, arm_wm_comp_len_slot,
        arm_wm_win_off_slot, arm_wm_mac_off_slot,
        arm_wm_pair_len_slot
    )
    uint64 arm_wm_comp = slot_load_u64(arm_wm_comp_slot)
    uint64 arm_wm_comp_len = slot_load_u64(arm_wm_comp_len_slot)
    uint64 arm_wm_win_off = slot_load_u64(arm_wm_win_off_slot)
    uint64 arm_wm_mac_off = slot_load_u64(arm_wm_mac_off_slot)
    uint64 arm_wm_pair_len = slot_load_u64(arm_wm_pair_len_slot)

    // === Emit MlrboFat v2 ===
    out_len = 0
    emit_mlrbofat_v2_header(8)
    uint64 data_offset = 16 + 8 * 48
    uint64 pad = (16 - (data_offset & 15)) & 15
    data_offset = data_offset + pad
    uint64 blob1_data_off = data_offset
    uint64 blob2_data_off = blob1_data_off + x64_lm_comp_len
    uint64 blob3_data_off = blob2_data_off + x64_wa_comp_len
    uint64 blob4_data_off = blob3_data_off + arm_la_comp_len

    // Entry fields: arch_id, compression, blob_offset, blob_comp_size,
    // slice_uncomp_size, slice_offset_in_pair, pair_uncomp_size.
    emit_mlrbofat_v2_entry_hdr(1, 1, blob1_data_off, x64_lm_comp_len, x86_len)
    emit_mlrbofat_v2_entry_rt(x64_lm_linux_off, x64_lm_pair_len)
    emit_mlrbofat_v2_entry_hdr(2, 1, blob3_data_off, arm_la_comp_len, a64_len)
    emit_mlrbofat_v2_entry_rt(arm_la_linux_off, arm_la_pair_len)
    emit_mlrbofat_v2_entry_hdr(3, 1, blob2_data_off, x64_wa_comp_len, pe_x86_len)
    emit_mlrbofat_v2_entry_rt(x64_wa_win_off, x64_wa_pair_len)
    emit_mlrbofat_v2_entry_hdr(4, 1, blob4_data_off, arm_wm_comp_len, pe_a64_len)
    emit_mlrbofat_v2_entry_rt(arm_wm_win_off, arm_wm_pair_len)
    emit_mlrbofat_v2_entry_hdr(5, 1, blob1_data_off, x64_lm_comp_len, macho_x86_len)
    emit_mlrbofat_v2_entry_rt(x64_lm_mac_off, x64_lm_pair_len)
    emit_mlrbofat_v2_entry_hdr(6, 1, blob4_data_off, arm_wm_comp_len, macho_a64_len)
    emit_mlrbofat_v2_entry_rt(arm_wm_mac_off, arm_wm_pair_len)
    emit_mlrbofat_v2_entry_hdr(7, 1, blob3_data_off, arm_la_comp_len, android_len)
    emit_mlrbofat_v2_entry_rt(arm_la_android_off, arm_la_pair_len)
    emit_mlrbofat_v2_entry_hdr(8, 1, blob2_data_off, x64_wa_comp_len, androidx_len)
    emit_mlrbofat_v2_entry_rt(x64_wa_android_off, x64_wa_pair_len)

    uint64 pi = 0
    while pi < pad { emit_byte(0); pi = pi + 1 }

    emit_raw_bytes(x64_lm_comp, x64_lm_comp_len)
    emit_raw_bytes(x64_wa_comp, x64_wa_comp_len)
    emit_raw_bytes(arm_la_comp, arm_la_comp_len)
    emit_raw_bytes(arm_wm_comp, arm_wm_comp_len)

    codegen_write_output(output_path)

    uint8[64] nb
    uint64 msg = "fat binary: x86_64("
    write(1, msg, 19)
    uint64 nl = fmt_uint(nb, x86_len)
    write(1, nb, nl)
    msg = ") + arm64("
    write(1, msg, 10)
    nl = fmt_uint(nb, a64_len)
    write(1, nb, nl)
    msg = ") + win-x64("
    write(1, msg, 12)
    nl = fmt_uint(nb, pe_x86_len)
    write(1, nb, nl)
    msg = ") + win-arm("
    write(1, msg, 12)
    nl = fmt_uint(nb, pe_a64_len)
    write(1, nb, nl)
    msg = ") + mac-x64("
    write(1, msg, 12)
    nl = fmt_uint(nb, macho_x86_len)
    write(1, nb, nl)
    msg = ") + mac-arm("
    write(1, msg, 12)
    nl = fmt_uint(nb, macho_a64_len)
    write(1, nb, nl)
    msg = ") + android-arm64("
    write(1, msg, 18)
    nl = fmt_uint(nb, android_len)
    write(1, nb, nl)
    msg = ") + android-x64("
    write(1, msg, 16)
    nl = fmt_uint(nb, androidx_len)
    write(1, nb, nl)
    msg = ") -> "
    write(1, msg, 5)
    uint64 olen = str_len(output_path)
    write(1, output_path, olen)
    // Same "(X.XX ms)" timer as single-file compile(). Gated on t_start_fat
    // having landed as non-zero — older target_os paths that stub time_ns()
    // to 0 just fall back to the plain newline.
    uint64 t_end_fat = time_ns()
    if t_start_fat != 0 {
        uint64 elapsed_fat = t_end_fat - t_start_fat
        uint64 ms_whole_f = elapsed_fat / 1000000
        uint64 ms_hund_f  = (elapsed_fat / 10000) % 100
        msg = "  ("
        write(1, msg, 3)
        uint64 w_len_f = fmt_uint(nb, ms_whole_f)
        write(1, nb, w_len_f)
        msg = "."
        write(1, msg, 1)
        uint8[2] hb_f
        uint8 d0_f = 48 + (ms_hund_f / 10)
        uint8 d1_f = 48 + (ms_hund_f % 10)
        unsafe { *(hb_f as uint8) = d0_f }
        uint64 hb_f1 = hb_f + 1
        unsafe { *(hb_f1 as uint8) = d1_f }
        write(1, hb_f, 2)
        msg = " ms)\n"
        write(1, msg, 5)
    } else {
        msg = "\n"
        write(1, msg, 1)
    }
}

// Statics set by _start trampoline
static uint64 cli_argc = 0
static uint64 cli_argv = 0

// Living compiler CLI options
static uint64 lc_ci_mode = 0
static uint64 lc_min_fitness = 0
static uint64 lc_fix_mode = 0
static uint64 lc_dry_run = 0
static uint64 lc_list_proposals = 0
static uint64 lc_promote_name = 0
static uint64 lc_deprecate_name = 0
static uint64 lc_reject_name = 0
static uint64 freestanding = 0
// Compiler-level auto-injection of `hipkfd_teardown()` at every exit
// path (main epilogue + every exit() syscall) when `--target=amdgpu-native`
// is on AND `hipkfd_teardown` is reachable in the link set. Default ON;
// `--no-auto-teardown` disables for power users who want manual control.
// Read directly from src/codegen.mlr and src/ir.mlr at the four
// injection points (legacy main epilogue, legacy exit() builtin,
// IR main epilogue, IR_SYSCALL with imm=231).
static uint64 auto_teardown_disabled = 0

fn parse_uint_arg(uint64 s) -> uint64 {
    uint64 val = 0
    uint64 i = 0
    uint64 p = s + i
    uint64 c = 0
    unsafe { *(p as uint8) -> c }
    while c >= 48 && c <= 57 {
        val = val * 10 + (c - 48)
        i = i + 1
        p = s + i
        unsafe { *(p as uint8) -> c }
    }
    return val
}

@export
fn main() {
    // Windows: parse raw GetCommandLineA result into argc/argv
    if cli_argc == 0xFFFFFFFF {
        win_init_args()
    }

    uint64 input_path = 0
    uint64 output_path = "a.mlrbo"
    uint64 mode = 0
    uint64 arch = 0
    uint64 emit_mode = 0
    uint64 arch_set = 0
    uint64 emit_set = 0

    if cli_argc > 1 {
        uint64 i = 1
        while i < cli_argc {
            uint64 arg_ptr = cli_argv + i * 8
            uint64 arg = 0
            unsafe { *(arg_ptr as uint64) -> arg }
            if str_starts_with(arg, "-o", 2) != 0 {
                uint64 arg_len = str_len(arg)
                if arg_len == 2 {
                    i = i + 1
                    uint64 next_ptr = cli_argv + i * 8
                    unsafe { *(next_ptr as uint64) -> output_path }
                } else {
                    output_path = arg + 2
                }
            } else if str_starts_with(arg, "--arch=", 7) != 0 {
                arch_set = 1
                uint64 arch_str = arg + 7
                if str_starts_with(arch_str, "arm64", 5) != 0 {
                    arch = 1
                } else if str_starts_with(arch_str, "aarch64", 7) != 0 {
                    arch = 1
                } else {
                    arch = 0
                }
            } else if str_starts_with(arg, "--emit=", 7) != 0 {
                emit_set = 1
                uint64 emit_str = arg + 7
                if str_starts_with(emit_str, "elfexe", 6) != 0 {
                    emit_mode = 0
                } else if str_starts_with(emit_str, "elf", 3) != 0 {
                    // "elf" / "elf-arm64" / "elf-x86_64" aliases for ELF
                    emit_mode = 0
                } else if str_starts_with(emit_str, "linux", 5) != 0 {
                    // "linux", "linux-x86_64", "linux-arm64", "linux-x86-64" all alias to ELF
                    emit_mode = 0
                } else if str_starts_with(emit_str, "macho", 5) != 0 {
                    emit_mode = 1
                } else if str_starts_with(emit_str, "mac", 3) != 0 {
                    // "macos", "mac-x64", "mac-arm64" alias to Mach-O
                    emit_mode = 1
                } else if str_starts_with(emit_str, "darwin", 6) != 0 {
                    emit_mode = 1
                } else if str_starts_with(emit_str, "windows", 7) != 0 {
                    // "windows", "windows-x64", "windows-arm64" alias to PE
                    emit_mode = 2
                } else if str_starts_with(emit_str, "win", 3) != 0 {
                    // "win", "win-x64", "win-arm64" alias to PE
                    emit_mode = 2
                } else if str_starts_with(emit_str, "pe", 2) != 0 {
                    emit_mode = 2
                } else if str_starts_with(emit_str, "obj", 3) != 0 {
                    emit_mode = 3
                } else if str_starts_with(emit_str, "android", 7) != 0 {
                    emit_mode = 4
                } else if str_starts_with(emit_str, "asm", 3) != 0 {
                    emit_mode = 5
                } else if str_starts_with(emit_str, "ir", 2) != 0 {
                    emit_mode = 6
                } else {
                    write(2, "error: unknown emit format '", 28)
                    uint64 esl = str_len(emit_str)
                    write(2, emit_str, esl)
                    write(2, "'\n", 2)
                    write(2, "valid: elfexe, linux, macho, mac, pe, windows, win, obj, android, asm, ir\n", 74)
                    exit(1)
                }
            } else if str_eq_full(arg, "-c") != 0 {
                emit_set = 1
                emit_mode = 3
            } else if str_starts_with(arg, "--targets=", 10) != 0 {
                parse_targets_arg(arg + 10)
            } else if str_starts_with(arg, "--emit-amdgpu-atomic-demo=", 26) != 0 {
                // Stage-1 M1o smoke: hand-crafted single-thread kernel
                // that exercises global_atomic_cmpswap_b64 by swapping
                // *out from 0 to 7. Proves the atomic encoder + GLC
                // flag work end-to-end before the CSR f64-add CAS
                // loops (M1p) can be composed.
                uint64 ad_path = arg + 26
                uint64 ad_rc = emit_amdgpu_atomic_demo_blob(ad_path)
                if ad_rc != 0 {
                    write(2, "mlrc: --emit-amdgpu-atomic-demo failed\n", 39)
                    exit(1)
                }
                write(1, "mlrc: wrote ", 12)
                uint64 apl = str_len(ad_path)
                write(1, ad_path, apl)
                write(1, " (amdgpu atomic-demo code object)\n", 34)
                exit(0)
            // --emit-amdgpu-gemv-f32= deleted — Phase 3c-2 owns AST path.
            // Build via: mlrc --target=amdgpu-native examples/llm/gemv_f32.mlr -o /tmp/gemv_f32
            } else if str_starts_with(arg, "--emit-amdgpu-gemv-coop-f32=", 28) != 0 {
                // Cooperative-row gemv_coop_f32 (task #75).  32-thread
                // workgroups, 1 row per WG, LDS reduce.  Kernarg layout
                // identical to gemv_f32 — drop-in replacement at
                // dispatch time but launches with block=32, grid=M.
                uint64 gc_path = arg + 28
                uint64 gc_rc = emit_amdgpu_gemv_coop_f32_blob(gc_path)
                if gc_rc != 0 {
                    write(2, "mlrc: --emit-amdgpu-gemv-coop-f32 failed\n", 41)
                    exit(1)
                }
                write(1, "mlrc: wrote ", 12)
                uint64 gcl = str_len(gc_path)
                write(1, gc_path, gcl)
                write(1, " (amdgpu gemv-coop-f32 code object)\n", 36)
                exit(0)
            } else if str_starts_with(arg, "--emit-amdgpu-gemv-coop-f32-batched=", 36) != 0 {
                uint64 gvb_path = arg + 36
                uint64 gvb_rc = emit_amdgpu_gemv_coop_f32_batched_blob(gvb_path)
                if gvb_rc != 0 {
                    write(2, "mlrc: --emit-amdgpu-gemv-coop-f32-batched failed\n", 49)
                    exit(1)
                }
                write(1, "mlrc: wrote ", 12)
                uint64 gvbl = str_len(gvb_path)
                write(1, gvb_path, gvbl)
                write(1, " (amdgpu gemv-coop-f32-batched code object, grid=(N,batch))\n", 61)
                exit(0)
            } else if str_starts_with(arg, "--emit-amdgpu-gemv-coop-q4-0-f32-batched=", 41) != 0 {
                uint64 gqb_path = arg + 41
                uint64 gqb_rc = emit_amdgpu_gemv_coop_q4_0_f32_batched_blob(gqb_path)
                if gqb_rc != 0 {
                    write(2, "mlrc: --emit-amdgpu-gemv-coop-q4-0-f32-batched failed\n", 54)
                    exit(1)
                }
                write(1, "mlrc: wrote ", 12)
                uint64 gqbl = str_len(gqb_path)
                write(1, gqb_path, gqbl)
                write(1, " (amdgpu gemv-coop-q4_0-f32-batched code object, grid=(N,batch))\n", 66)
                exit(0)
            } else if str_starts_with(arg, "--emit-amdgpu-gemv-coop-bf16-f32-batched=", 41) != 0 {
                uint64 gbb_path = arg + 41
                uint64 gbb_rc = emit_amdgpu_gemv_coop_bf16_f32_batched_blob(gbb_path)
                if gbb_rc != 0 {
                    write(2, "mlrc: --emit-amdgpu-gemv-coop-bf16-f32-batched failed\n", 54)
                    exit(1)
                }
                write(1, "mlrc: wrote ", 12)
                uint64 gbbl = str_len(gbb_path)
                write(1, gbb_path, gbbl)
                write(1, " (amdgpu gemv-coop-bf16-f32-batched code object, grid=(N,batch))\n", 66)
                exit(0)
            } else if str_starts_with(arg, "--emit-amdgpu-gemv-coop-bf16-f32-cputree=", 41) != 0 {
                // Phase 1 of Llama-3B bit-exactness project (2026-05-14).
                // Standalone validator: mimics CPU AVX2 8-lane vhaddps
                // reduction tree (XOR offsets [4,1,2]).
                uint64 gbct_path = arg + 41
                uint64 gbct_rc = emit_amdgpu_gemv_coop_bf16_f32_cputree_blob(gbct_path)
                if gbct_rc != 0 {
                    write(2, "mlrc: --emit-amdgpu-gemv-coop-bf16-f32-cputree failed\n", 54)
                    exit(1)
                }
                write(1, "mlrc: wrote ", 12)
                uint64 gbctl = str_len(gbct_path)
                write(1, gbct_path, gbctl)
                write(1, " (amdgpu gemv-coop-bf16-f32-cputree code object)\n", 49)
                exit(0)
            } else if str_starts_with(arg, "--emit-amdgpu-gemv-coop-f32-f32-cputree=", 40) != 0 {
                // Phase F3a of Llama-3B fp32 bit-exactness (2026-05-14).
                // fp32 weight × fp32 act gemv, same CPU-vhaddps tree as the
                // bf16 cputree validator (XOR offsets [4,1,2]).
                uint64 gfct_path = arg + 40
                uint64 gfct_rc = emit_amdgpu_gemv_coop_f32_f32_cputree_blob(gfct_path)
                if gfct_rc != 0 {
                    write(2, "mlrc: --emit-amdgpu-gemv-coop-f32-f32-cputree failed\n", 53)
                    exit(1)
                }
                write(1, "mlrc: wrote ", 12)
                uint64 gfctl = str_len(gfct_path)
                write(1, gfct_path, gfctl)
                write(1, " (amdgpu gemv-coop-f32-f32-cputree code object)\n", 48)
                exit(0)
            } else if str_starts_with(arg, "--emit-amdgpu-gemv-coop-bf16-f32=", 33) != 0 {
                // bf16-direct cooperative gemv (task #76).  Reads bf16
                // weights directly, halves A bandwidth + skips dequant.
                uint64 gb_path = arg + 33
                uint64 gb_rc = emit_amdgpu_gemv_coop_bf16_f32_blob(gb_path)
                if gb_rc != 0 {
                    write(2, "mlrc: --emit-amdgpu-gemv-coop-bf16-f32 failed\n", 46)
                    exit(1)
                }
                write(1, "mlrc: wrote ", 12)
                uint64 gbl = str_len(gb_path)
                write(1, gb_path, gbl)
                write(1, " (amdgpu gemv-coop-bf16-f32 code object)\n", 41)
                exit(0)
            } else if str_starts_with(arg, "--emit-amdgpu-attn-decode-f32-14b=", 34) != 0 {
                uint64 ad14_path = arg + 34
                uint64 ad14_rc = emit_amdgpu_attn_decode_f32_14b_blob(ad14_path)
                if ad14_rc != 0 {
                    write(2, "mlrc: --emit-amdgpu-attn-decode-f32-14b failed\n", 47)
