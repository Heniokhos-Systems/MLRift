// Phase 3c-9 — gemv_coop_q4_0_f32_batched (Q4_0 weights, 2D grid).
//
// Recognises a 5-param cooperative gemv with a `block_idx_y()` Call
// (the batch dimension) and `lds_reduce_sum_f32` reduction.  This is
// the discriminator vs 3c-7/3c-8 (non-batched).  Routing places 3c-9
// BEFORE 3c-8 so the 2D-grid kernel wins.  Delegates ISA emission to
// `_emit_gemv_coop_q4_0_f32_batched_body`.
//
// Returns 0 on success; non-zero means "doesn't match the 3c-9 shape".
fn amdgpu_lower_gemv_coop_q4_0_f32_batched_3c(uint64 fn_node, uint64 source,
                                                uint64 kname_ptr, uint64 nl) -> uint64 {
    uint64 n_params = 0
    uint64 wp = ast_child(fn_node)
    while wp != 0 {
        n_params = n_params + 1
        wp = ast_next(wp)
    }
    if n_params != 5 { return 1 }

    uint32 body = ast_data3(fn_node)
    if body == 0 { return 1 }
    if ast_kind(body) != 15 { return 1 }

    // Recursive search for both `block_idx_y` and `lds_reduce_sum_f32`.
    uint64 saw_block_y = 0
    uint64 saw_lds_reduce = 0
    uint32 walk = ast_child(body)
    while walk != 0 {
        if ast_kind(walk) == 35 {
            uint32 callee = ast_data1(walk)
            if tok_matches(callee, "block_idx_y",        11) != 0 { saw_block_y = 1 }
            if tok_matches(callee, "lds_reduce_sum_f32", 18) != 0 { saw_lds_reduce = 1 }
        }
        if ast_kind(walk) == 10 {
            uint32 init = ast_child(walk)
            if init != 0 && ast_kind(init) == 35 {
                uint32 callee = ast_data1(init)
                if tok_matches(callee, "block_idx_y",        11) != 0 { saw_block_y = 1 }
                if tok_matches(callee, "lds_reduce_sum_f32", 18) != 0 { saw_lds_reduce = 1 }
            }
        }
        if ast_kind(walk) == 13 {
            uint32 tblk = ast_data1(walk)
            if tblk != 0 && ast_kind(tblk) == 15 {
                uint32 tw = ast_child(tblk)
                while tw != 0 {
                    if ast_kind(tw) == 10 {
                        uint32 i2 = ast_child(tw)
                        if i2 != 0 && ast_kind(i2) == 35 {
                            uint32 c2 = ast_data1(i2)
                            if tok_matches(c2, "block_idx_y",        11) != 0 { saw_block_y = 1 }
                            if tok_matches(c2, "lds_reduce_sum_f32", 18) != 0 { saw_lds_reduce = 1 }
                        }
                    }
                    if ast_kind(tw) == 35 {
                        uint32 c2 = ast_data1(tw)
                        if tok_matches(c2, "block_idx_y",        11) != 0 { saw_block_y = 1 }
                        if tok_matches(c2, "lds_reduce_sum_f32", 18) != 0 { saw_lds_reduce = 1 }
                    }
                    tw = ast_next(tw)
                }
            }
        }
        walk = ast_next(walk)
    }
    if saw_block_y == 0 { return 1 }
    if saw_lds_reduce == 0 { return 1 }

    // ── emit ISA ─────────────────────────────────────────────────
    // Delegate to the production hand-tuned body.
    uint64 args_desc = alloc(10 * 16)
    _emit_gemv_coop_q4_0_f32_batched_body(args_desc)

    uint64 k_text_size = asm_text_len
    uint64 k_text_buf  = alloc(k_text_size)
    uint64 ci = 0
    while ci < k_text_size {
        uint64 sp = asm_text_buf + ci
        uint64 b = 0
        unsafe { *(sp as uint8) -> b }
        uint64 dp = k_text_buf + ci
        uint8 b8 = b
        unsafe { *(dp as uint8) = b8 }
        ci = ci + 1
    }

    // KD identical to the gemv_coop_q4_0_f32_batched blob: rsrc2=0x019E
    // enables both wg_x and wg_y.
    uint64 rsrc1 = 0xE0AF0003
    uint64 rsrc2 = 0x0000019E
    uint64 rsrc3 = 0x00000010
    uint64 props = 0x0408

    kt_push_lds(kname_ptr, nl, k_text_buf, k_text_size,
                args_desc, 5, 40,
                18, 32,
                rsrc1, rsrc2, rsrc3, props,
                128)
    return 0
}

// Phase 3c-21 — gemv_coop_f32_batched (multi-stream f32 coop).
//
// Discriminator: 5 params + lds_reduce_sum + block_idx_y +
// gemv_coop_batched_marker() Call.  Routes BEFORE 3c-9 (q4_0 batched
// — same shape signature minus the marker) so the f32 variant wins.
fn amdgpu_lower_gemv_coop_f32_batched_3c(uint64 fn_node, uint64 source,
                                          uint64 kname_ptr, uint64 nl) -> uint64 {
