// v_fma_f32 vdst, v_src0, v_src1, v_src2   (VOP3 op 0x113; standard f32 FMA)
//   Verified: v_fma_f32 v0, v2, v3, v4 → 0xD6130000 0x04120702.
fn asm_v_fma_f32_e64_vvv(uint64 vdst, uint64 v_src0, uint64 v_src1, uint64 v_src2) {
    uint64 word1 = 0xD6130000 | (vdst & 0xFF)
    uint64 src0_enc = 0x100 | (v_src0 & 0xFF)
    uint64 src1_enc = 0x100 | (v_src1 & 0xFF)
    uint64 src2_enc = 0x100 | (v_src2 & 0xFF)
    uint64 word2 = ((src2_enc & 0x1FF) << 18)
                   | ((src1_enc & 0x1FF) << 9)
                   | (src0_enc & 0x1FF)
    asm_u32(word1)
    asm_u32(word2)
}

// v_fma_f32 vdst, -v_src0, v_src1, 1.0   (VOP3 op 0x113; src0 negated, src2=1.0 inline)
//   Verified via llvm-mc: v_fma_f32 v8, -v2, v3, 1.0 → 0xD6130008 0x23CA0702.
//   word2: (neg<<29) | (0xF2<<18) | (src1_enc<<9) | src0_enc, where 0xF2 is the
//   inline-1.0 encoding and neg=1 negates src0.
//   Used by Phase 2.6 cputree rmsnorm scalar pipeline for the f32 div Newton-
//   Raphson correction step: u = -d * r + 1.0.
fn asm_v_fma_f32_e64_neg_v_v_lit1(uint64 vdst, uint64 v_src0, uint64 v_src1) {
    uint64 word1 = 0xD6130000 | (vdst & 0xFF)
    uint64 src0_enc = 0x100 | (v_src0 & 0xFF)
    uint64 src1_enc = 0x100 | (v_src1 & 0xFF)
    uint64 src2_enc = 0xF2                                    // inline 1.0
    uint64 neg = 0x1                                          // neg[0] = 1 → -src0
    uint64 word2 = (neg << 29)
                   | ((src2_enc & 0x1FF) << 18)
                   | ((src1_enc & 0x1FF) << 9)
                   | (src0_enc & 0x1FF)
    asm_u32(word1)
    asm_u32(word2)
}

// v_fma_f32 vdst, -v_src0, v_src1, v_src2   (VOP3 op 0x113; src0 negated)
//   Mirrors asm_v_fma_f64_negv_v_v.  Used by f32 div residual: e = -d * q + n.
fn asm_v_fma_f32_e64_neg_v_v_v(uint64 vdst, uint64 v_src0, uint64 v_src1, uint64 v_src2) {
    uint64 word1 = 0xD6130000 | (vdst & 0xFF)
    uint64 src0_enc = 0x100 | (v_src0 & 0xFF)
    uint64 src1_enc = 0x100 | (v_src1 & 0xFF)
    uint64 src2_enc = 0x100 | (v_src2 & 0xFF)
    uint64 neg = 0x1
    uint64 word2 = (neg << 29)
                   | ((src2_enc & 0x1FF) << 18)
                   | ((src1_enc & 0x1FF) << 9)
                   | (src0_enc & 0x1FF)
    asm_u32(word1)
    asm_u32(word2)
}

// v_sqrt_f32_e32 vdst, v_src    (VOP1 op 0x33; correctly-rounded f32 sqrt)
//   Verified via llvm-mc: v_sqrt_f32 v2, v2 → 0x7E046702.
//   word = (0x3F<<25) | (vdst<<17) | (0x33<<9) | (0x100 | v_src)
fn asm_v_sqrt_f32_e32_v(uint64 vdst, uint64 v_src) {
    uint64 word = (0x3F << 25) | ((vdst & 0xFF) << 17)
                  | (0x33 << 9) | (0x100 | (v_src & 0xFF))
    asm_u32(word)
}

// v_div_scale_f32 vdst, sdst, v_src0, v_src1, v_src2    (VOP3B op 0x0FC)
//   sdst = scale flag (vcc_lo=0x6A or null=0x7C).
//   Verified via llvm-mc:
//     v_div_scale_f32 v4, vcc_lo, 1.0, v2, 1.0 → 0xD6FC6A04 0x03CA04F2.
//     v_div_scale_f32 v5, null,   1.0, v2, 1.0 → 0xD6FC7C05 0x03CA04F2.
//   word1 = 0xD6FC0000 | (sdst<<8) | vdst.  Same word2 layout as div_scale_f64.
//   Helper accepts encoded src operands so caller can pass inline-1.0 (0xF2)
//   or VGPR (0x100 | reg).
fn asm_v_div_scale_f32(uint64 vdst, uint64 sdst,
                       uint64 src0_enc, uint64 src1_enc, uint64 src2_enc) {
    uint64 word1 = 0xD6FC0000 | ((sdst & 0xFF) << 8) | (vdst & 0xFF)
    uint64 word2 = ((src2_enc & 0x1FF) << 18)
                   | ((src1_enc & 0x1FF) << 9)
                   | (src0_enc & 0x1FF)
    asm_u32(word1)
    asm_u32(word2)
}

// v_div_fmas_f32 vdst, v_src0, v_src1, v_src2   (VOP3 op 0x037)
//   Verified via llvm-mc: v_div_fmas_f32 v6, v4, v5, v3 → 0xD6370006 0x040E0B04.
fn asm_v_div_fmas_f32(uint64 vdst, uint64 v_src0, uint64 v_src1, uint64 v_src2) {
    uint64 word1 = 0xD6370000 | (vdst & 0xFF)
    uint64 src0_enc = 0x100 | (v_src0 & 0xFF)
    uint64 src1_enc = 0x100 | (v_src1 & 0xFF)
    uint64 src2_enc = 0x100 | (v_src2 & 0xFF)
    uint64 word2 = ((src2_enc & 0x1FF) << 18)
                   | ((src1_enc & 0x1FF) << 9)
                   | (src0_enc & 0x1FF)
    asm_u32(word1)
    asm_u32(word2)
}

// v_div_fixup_f32 vdst, v_src0, v_src1, v_src2   (VOP3 op 0x027)
//   src0 = computed quotient, src1 = denominator, src2 = numerator.
//   src2 can be inline-1.0 for `q = 1.0 / d` form.
//   Verified via llvm-mc: v_div_fixup_f32 v7, v6, v2, 1.0 → 0xD6270007 0x03CA0506.
fn asm_v_div_fixup_f32(uint64 vdst, uint64 v_src0, uint64 v_src1, uint64 src2_enc) {
    uint64 word1 = 0xD6270000 | (vdst & 0xFF)
    uint64 src0_enc = 0x100 | (v_src0 & 0xFF)
    uint64 src1_enc = 0x100 | (v_src1 & 0xFF)
    uint64 word2 = ((src2_enc & 0x1FF) << 18)
                   | ((src1_enc & 0x1FF) << 9)
                   | (src0_enc & 0x1FF)
    asm_u32(word1)
    asm_u32(word2)
}

// Correctly-rounded IEEE f32 division: v_q = v_n / v_d.
//   Implements the canonical 9-op LLVM AMDGPU sequence used by clang's
//   `-fno-fast-math` codegen.  All VGPRs are distinct (caller-managed):
//     v_n, v_d : numerator, denominator (read-only inputs).
//     v_q      : output (must NOT alias scratch).
//     v_ds, v_ns, v_r, v_r2, v_q0 : five scratch VGPRs.
//   Sequence:
//     v_ds = div_scale_f32(vcc_lo, d, d, n)
//     v_ns = div_scale_f32(null,    n, d, n)
//     v_r  = rcp_f32(v_ds)
//     v_c  = -v_ds * v_r + 1.0                  (FMA, reuses v_r2 slot temporarily)
//     v_r2 = v_c  * v_r + v_r                   (Newton-Raphson refine)
//     v_q0 = v_ns * v_r2
//     v_e  = -v_ds * v_q0 + v_ns                (residual, reuses v_r slot)
//     v_q1 = div_fmas_f32(v_e, v_r2, v_q0)
//     v_q  = div_fixup_f32(v_q1, d, n)
// This matches Apple Clang / LLVM AMDGPU's IEEE-correct f32 div sequence
// (verified against `clang -O3 --target=amdgcn -mcpu=gfx1100 -emit-llvm-bc`).
fn asm_v_div_f32_ieee(uint64 v_q, uint64 v_n, uint64 v_d,
                      uint64 v_ds, uint64 v_ns, uint64 v_r, uint64 v_r2, uint64 v_q0) {
    // src encodings for v_n / v_d (inputs)
    uint64 n_enc = 0x100 | (v_n & 0xFF)
    uint64 d_enc = 0x100 | (v_d & 0xFF)
    // div_scale_f32 v_ds, vcc_lo, d, d, n
    asm_v_div_scale_f32(v_ds, 0x6A, d_enc, d_enc, n_enc)
    // div_scale_f32 v_ns, null,    n, d, n
    asm_v_div_scale_f32(v_ns, 0x7C, n_enc, d_enc, n_enc)
    // v_r = rcp_f32(v_ds)
    asm_u32(0x7E005400 | ((v_r & 0xFF) << 17) | (0x100 | (v_ds & 0xFF)))
    // v_r2 (temp = correction) = -v_ds * v_r + 1.0
    asm_v_fma_f32_e64_neg_v_v_lit1(v_r2, v_ds, v_r)
    // v_r2 = v_r2_temp * v_r + v_r   (Newton-Raphson refined recip in v_r2)
    asm_v_fma_f32_e64_vvv(v_r2, v_r2, v_r, v_r)
    // v_q0 = v_ns * v_r2   (rough quotient)
    // VOP2 v_mul_f32 v_q0, v_ns, v_r2:
    //   (8<<25)|(vdst<<17)|(src1=v_r2<<9)|(src0=v_ns|0x100)
    asm_u32((8 << 25) | ((v_q0 & 0xFF) << 17) | ((v_r2 & 0xFF) << 9) | (0x100 | (v_ns & 0xFF)))
    // v_r (residual) = -v_ds * v_q0 + v_ns
    asm_v_fma_f32_e64_neg_v_v_v(v_r, v_ds, v_q0, v_ns)
    // v_q (q1) = div_fmas_f32(v_r, v_r2, v_q0)
    asm_v_div_fmas_f32(v_q, v_r, v_r2, v_q0)
    // v_q = div_fixup_f32(v_q, v_d, v_n)  → final IEEE-correct quotient
    asm_v_div_fixup_f32(v_q, v_q, v_d, n_enc)
}

// v_fmac_f32_e32 vdst, v_src0, v_src1   (VOP2 op 0x2B; vdst += s0*s1)
//   The VOP2 form pairs with v_dual_fmac_f32 for RDNA3 dual-issue.
//   Verified: v_fmac_f32_e32 v0, v2, v3 → 0x56000702.
fn asm_v_fmac_f32_e32_vv(uint64 vdst, uint64 v_src0, uint64 v_src1) {
    uint64 word = (0x2B << 25) | ((vdst & 0xFF) << 17)
                  | ((v_src1 & 0xFF) << 9) | (0x100 | (v_src0 & 0xFF))
    asm_u32(word)
}

// v_readfirstlane_b32 sdst, v_src   (VOP1 op 0x02; broadcast lane 0 → SGPR)
//   Verified: v_readfirstlane_b32 s4, v2 → 0x7E080502.
fn asm_v_readfirstlane_b32(uint64 sdst, uint64 v_src) {
    uint64 word = (0x3F << 25) | ((sdst & 0xFF) << 17) | (0x02 << 9) | (0x100 | (v_src & 0xFF))
    asm_u32(word)
}

// v_readlane_b32 sdst, v_src, <inline lane 0..63>   (VOP3 op 0x160)
//   Verified: v_readlane_b32 s4, v2, 0 → 0xD7600004 0x00010102.
fn asm_v_readlane_b32_imm(uint64 sdst, uint64 v_src, uint64 lane_imm) {
    uint64 word1 = 0xD7600000 | (sdst & 0xFF)
    uint64 src0_enc = 0x100 | (v_src & 0xFF)
    uint64 src1_enc = 0x80 + (lane_imm & 0x3F)
    uint64 word2 = ((src1_enc & 0x1FF) << 9) | (src0_enc & 0x1FF)
    asm_u32(word1)
    asm_u32(word2)
}

// v_writelane_b32 vdst, s_src, <inline lane 0..63>   (VOP3 op 0x161)
//   Verified: v_writelane_b32 v0, s4, 0 → 0xD7610000 0x00010004.
fn asm_v_writelane_b32_imm(uint64 vdst, uint64 s_src, uint64 lane_imm) {
    uint64 word1 = 0xD7610000 | (vdst & 0xFF)
    uint64 src0_enc = s_src & 0x1FF                          // SGPR raw
    uint64 src1_enc = 0x80 + (lane_imm & 0x3F)
    uint64 word2 = ((src1_enc & 0x1FF) << 9) | (src0_enc & 0x1FF)
    asm_u32(word1)
    asm_u32(word2)
}

// ds_bpermute_b32 vdst, v_addr, v_data   (LDS-class, op 0xCC)
//   Cross-lane permute: vdst[lane] = v_data[v_addr[lane] >> 2].
//   Verified: ds_bpermute_b32 v0, v2, v3 → 0xDACC0000 0x00000302.
fn asm_ds_bpermute_b32(uint64 vdst, uint64 v_addr, uint64 v_data) {
    uint64 word1 = 0xDACC0000
    uint64 word2 = ((vdst & 0xFF) << 24)
                   | ((v_data & 0xFF) << 8)
                   | (v_addr & 0xFF)
    asm_u32(word1)
    asm_u32(word2)
}

// ds_read_b128 v[dst:+3], v_addr   (LDS read 16 bytes; op 0xFC)
//   Verified: ds_read_b128 v[0:3], v4 → 0xDBFC0000 0x00000004.
fn asm_ds_read_b128(uint64 vdst_quad, uint64 v_addr) {
    asm_u32(0xDBFC0000)
    uint64 word2 = ((vdst_quad & 0xFF) << 24) | (v_addr & 0xFF)
    asm_u32(word2)
}

// ds_write_b128 v_addr, v[data:+3]   (LDS write 16 bytes; op 0x7C)
//   Verified: ds_write_b128 v0, v[4:7] → 0xDB7C0000 0x00000400.
fn asm_ds_write_b128(uint64 v_addr, uint64 vdata_quad) {
    asm_u32(0xDB7C0000)
    uint64 word2 = ((vdata_quad & 0xFF) << 8) | (v_addr & 0xFF)
    asm_u32(word2)
}

// s_barrier   — workgroup-wide LDS sync (SOPP op 0x3D).
//   Verified: s_barrier → 0xBFBD0000.
fn asm_s_barrier() { asm_sopp(0x3D, 0) }

// global_atomic_add_f32 v[addr:+1], vdata, off   (GLOBAL op 0x5A; no return)
//   Verified: global_atomic_add_f32 v[2:3], v4, off → 0xDD5A0000 0x007C0402.
fn asm_global_atomic_add_f32_offvaddr(uint64 v_addr_pair, uint64 vdata) {
    asm_u32(0xDD5A0000)
    uint64 word2 = (0x7C << 16)                                // saddr=off
                   | ((vdata & 0xFF) << 8)
                   | (v_addr_pair & 0xFF)
    asm_u32(word2)
}

// v_lshrrev_b64 v[dst:dst+1], s_idx, v[src:src+1]  — SGPR-shift form
//   Verified: v_lshrrev_b64 v[2:3], s24, v[0:1] → 0xD73D0002 0x00020018.
fn asm_v_lshrrev_b64_sgpr_vv(uint64 vdst_pair, uint64 s_idx, uint64 v_src_pair) {
    uint64 word1 = 0xD73D0000 | (vdst_pair & 0xFF)
    uint64 src0_enc = s_idx & 0x1FF
    uint64 src1_enc = 0x100 | (v_src_pair & 0xFF)
    uint64 word2 = ((src1_enc & 0x1FF) << 9) | (src0_enc & 0x1FF)
    asm_u32(word1)
    asm_u32(word2)
}

// v_xor_b32_e64 vdst, v_src0, v_src1   (VOP3 op 0x11D)
//   word1 = 0xD51D0000 | vdst
//   Verified: v_xor_b32_e64 v0, v2, v3 → 0xD51D0000 0x00020702.
fn asm_v_xor_b32_e64_vv(uint64 vdst, uint64 v_src0, uint64 v_src1) {
    uint64 word1 = 0xD51D0000 | (vdst & 0xFF)
    uint64 src0_enc = 0x100 | (v_src0 & 0xFF)
    uint64 src1_enc = 0x100 | (v_src1 & 0xFF)
    uint64 word2 = ((src1_enc & 0x1FF) << 9) | (src0_enc & 0x1FF)
    asm_u32(word1)
    asm_u32(word2)
}

// v_sub_co_u32 vdst, vcc_lo, v_src0, v_src1   (VOP3B op 0x101)
//   Mirrors v_add_co_u32 (op 0x100) byte-for-byte.
//   Verified: v_sub_co_u32 v0, vcc_lo, v2, v4 → 0xD7016A00 0x00020902.
fn asm_v_sub_co_u32_vcc_vv(uint64 vdst, uint64 v_src0, uint64 v_src1) {
    uint64 word1 = 0xD7016A00 | (vdst & 0xFF)
    uint64 src0_enc = 0x100 | (v_src0 & 0xFF)
    uint64 src1_enc = 0x100 | (v_src1 & 0xFF)
    uint64 word2 = ((src1_enc & 0x1FF) << 9) | (src0_enc & 0x1FF)
    asm_u32(word1)
    asm_u32(word2)
}

// v_sub_co_ci_u32_e64 vdst, null, v_src0, v_src1, vcc_lo   (VOP3B op 0x121)
//   Reads vcc_lo (borrow-in), discards borrow-out into null.
//   Verified: v_sub_co_ci_u32_e64 v0, null, v2, v4, vcc_lo → 0xD5217C00 0x01AA0902.
fn asm_v_sub_co_ci_u32_null_vv_vcc(uint64 vdst, uint64 v_src0, uint64 v_src1) {
    uint64 word1 = 0xD5217C00 | (vdst & 0xFF)
    uint64 src0_enc = 0x100 | (v_src0 & 0xFF)
    uint64 src1_enc = 0x100 | (v_src1 & 0xFF)
    uint64 src2_enc = 0x6A                                 // vcc_lo
    uint64 word2 = ((src2_enc & 0x1FF) << 18)
                   | ((src1_enc & 0x1FF) << 9)
                   | (src0_enc & 0x1FF)
    asm_u32(word1)
    asm_u32(word2)
}

// v_cmp_ge_u64_e64 vcc_lo, v[a:a+1], v[b:b+1]   (VOPC op 0xDE)
//   Sets vcc_lo = (a >= b) per lane.
//   Verified: v_cmp_ge_u64_e64 vcc_lo, v[0:1], v[2:3] → 0xD45E006A 0x00020500.
fn asm_v_cmp_ge_u64_vv(uint64 v_src0_pair, uint64 v_src1_pair) {
    uint64 word1 = 0xD45E006A
    uint64 src0_enc = 0x100 | (v_src0_pair & 0xFF)
    uint64 src1_enc = 0x100 | (v_src1_pair & 0xFF)
    uint64 word2 = ((src1_enc & 0x1FF) << 9) | (src0_enc & 0x1FF)
    asm_u32(word1)
    asm_u32(word2)
}

// v_lshlrev_b32_e64 vdst, <imm 0..31>, v_src   (VOP3 op 0x118)
//   Verified: v_lshlrev_b32_e64 v0, 1, v1 → 0xD5180000 0x00020281.
fn asm_v_lshlrev_b32_imm_e64(uint64 vdst, uint64 shift_amount, uint64 v_src) {
    uint64 word1 = 0xD5180000 | (vdst & 0xFF)
    uint64 src0_enc = 0x80 + (shift_amount & 0x1F)
    uint64 src1_enc = 0x100 | (v_src & 0xFF)
    uint64 word2 = ((src1_enc & 0x1FF) << 9) | (src0_enc & 0x1FF)
    asm_u32(word1)
    asm_u32(word2)
}

// v_lshrrev_b32_e64 vdst, <imm 0..31>, v_src   (VOP3 op 0x119)
//   Verified: v_lshrrev_b32_e64 v0, 1, v1 → 0xD5190000 0x00020281.
fn asm_v_lshrrev_b32_imm_e64(uint64 vdst, uint64 shift_amount, uint64 v_src) {
    uint64 word1 = 0xD5190000 | (vdst & 0xFF)
    uint64 src0_enc = 0x80 + (shift_amount & 0x1F)
    uint64 src1_enc = 0x100 | (v_src & 0xFF)
    uint64 word2 = ((src1_enc & 0x1FF) << 9) | (src0_enc & 0x1FF)
    asm_u32(word1)
    asm_u32(word2)
}

// v_or_b32_e64 vdst, v_src0, v_src1   (VOP3 op 0x11C)
//   Verified: v_or_b32_e64 v0, v2, v3 → 0xD51C0000 0x00020702.
fn asm_v_or_b32_e64_vv(uint64 vdst, uint64 v_src0, uint64 v_src1) {
    uint64 word1 = 0xD51C0000 | (vdst & 0xFF)
    uint64 src0_enc = 0x100 | (v_src0 & 0xFF)
    uint64 src1_enc = 0x100 | (v_src1 & 0xFF)
    uint64 word2 = ((src1_enc & 0x1FF) << 9) | (src0_enc & 0x1FF)
    asm_u32(word1)
    asm_u32(word2)
}

// v_and_b32_e64 vdst, v_src0, <inline imm 0..63>   (VOP3 op 0x11B)
//   Verified: v_and_b32_e64 v0, v2, 1 → 0xD51B0000 0x00010302.
fn asm_v_and_b32_imm_e64(uint64 vdst, uint64 v_src0, uint64 imm) {
    uint64 word1 = 0xD51B0000 | (vdst & 0xFF)
    uint64 src0_enc = 0x100 | (v_src0 & 0xFF)
    uint64 src1_enc = 0x80 + (imm & 0x3F)
    uint64 word2 = ((src1_enc & 0x1FF) << 9) | (src0_enc & 0x1FF)
    asm_u32(word1)
    asm_u32(word2)
}

// v_mov_b32_e32 vdst, <32-bit literal>   (VOP1 op 0x01, lit32 follows)
//   Verified: v_mov_b32_e32 v3, 0xBF58476D
//             → word = 0x7E0602FF, lit = 0xBF58476D.
fn asm_v_mov_b32_lit32(uint64 vdst, uint64 lit32) {
    uint64 word = 0x7E0002FF | ((vdst & 0xFF) << 17)
    asm_u32(word)
    asm_u32(lit32 & 0xFFFFFFFF)
}

// v_cndmask_b32_e64 vdst, v_src0, v_src1, vcc_lo  — VOP3 op 0x101.
//   gfx11 rejects an SGPR-pair pair as src0/src1 (verified in session 2).
//   This helper is for the post-mov VGPR-only operand form.
//   Verified: v_cndmask_b32_e64 v0, v2, v4, vcc_lo → 0xD5010000 0x01AA0902.
fn asm_v_cndmask_b32_e64_vv_vcc(uint64 vdst, uint64 v_src0, uint64 v_src1) {
    uint64 word1 = 0xD5010000 | (vdst & 0xFF)
    uint64 src0_enc = 0x100 | (v_src0 & 0xFF)
    uint64 src1_enc = 0x100 | (v_src1 & 0xFF)
    uint64 src2_enc = 0x6A                                 // vcc_lo
    uint64 word2 = ((src2_enc & 0x1FF) << 18)
                   | ((src1_enc & 0x1FF) << 9)
                   | (src0_enc & 0x1FF)
    asm_u32(word1)
    asm_u32(word2)
}

// global_load_u8 v_dst, v[v_addr_pair:+1], off  — GLOBAL op 0x10, size=1,
//   zero-extends to 32 bits. Saddr = OFF (0x7C); v_addr is a 64-bit pair.
//   Verified: global_load_u8 v3, v[2:3], off → 0xDC420000 0x037C0002.
fn asm_global_load_u8_offvaddr(uint64 vdst, uint64 v_addr_pair) {
    asm_u32(0xDC420000)
    uint64 word2 = ((vdst & 0xFF) << 24)
                   | (0x7C << 16)                          // saddr = OFF
                   | (v_addr_pair & 0xFF)
    asm_u32(word2)
}

// global_load_b64 v[vdst:vdst+1], v[vaddr_pair:vaddr_pair+1], off
//   off-saddr form with full 64-bit v_addr (vs the saddr_pair form in
//   asm_global_load_b64 above which uses a 32-bit v_addr). Used by the
//   CAS retry loop — the per-lane atomic target address is a 64-bit
//   pair built by v_add_co_u32 + v_add_co_ci_u32, not a (sgpr_pair +
//   u32_offset) split.
//   Verified: global_load_b64 v[2:3], v[20:21], off → 0xDC560000 0x027C0014.
fn asm_global_load_b64_offvaddr(uint64 vdst_pair, uint64 vaddr_pair) {
    asm_u32(0xDC560000)
    uint64 word2 = ((vdst_pair & 0xFF) << 24)
                   | (0x7C << 16)                          // saddr = OFF
                   | (vaddr_pair & 0xFF)
    asm_u32(word2)
}

// global_store_b64 v[addr:+1], v[data:+1], off  — off-saddr form.
//   Verified: global_store_b64 v[2:3], v[4:5], off → 0xDC6E0000 0x007C0402.
fn asm_global_store_b64_offvaddr(uint64 vaddr_pair, uint64 vdata_pair) {
    asm_u32(0xDC6E0000)
    uint64 word2 = (0x7C << 16)                              // saddr = OFF
                   | ((vdata_pair & 0xFF) << 8)
                   | (vaddr_pair & 0xFF)
    asm_u32(word2)
}

// global_atomic_cmpswap_b64 v[vdst:vdst+1], v[vaddr:+1], v[vdata_quad:+3], off glc
//   Off-saddr form (vs the asm_global_atomic_cmpswap_b64_glc above
//   which takes saddr_pair). v_addr is a full 64-bit pair.
//   Verified: v[0:1], v[8:9], v[2:5], off glc → 0xDD0A4000 0x007C0208.
fn asm_global_atomic_cmpswap_b64_offvaddr(uint64 vdst_pair, uint64 vaddr_pair, uint64 vdata_quad) {
    asm_u32(0xDD0A4000)
    uint64 word2 = ((vdst_pair  & 0xFF) << 24)
                   | (0x7C << 16)                          // saddr = OFF
                   | ((vdata_quad & 0xFF) << 8)
                   | (vaddr_pair & 0xFF)
    asm_u32(word2)
}

// v_cmp_ne_u32_e32 vcc_lo, 0, v_src — VOPC op 0x4D.
//   Sets VCC[lane] = (0 != u32(v[src])). The "fired != 0" predicate
//   in delivery_step. Verified: vcc_lo, 0, v0 → 0x7C9A0080.
fn asm_v_cmp_ne_u32_imm0_vgpr(uint64 vgpr) {
    uint64 src0_enc = 0x80                                  // inline 0
    uint64 word = (0x3E << 25)
                  | (0x4D << 17)
                  | ((vgpr & 0xFF) << 9)
                  | (src0_enc & 0x1FF)
    asm_u32(word)
}

// ─── ISA helpers used by the noesis lif_step lowering ──────────────
// All encodings verified against llvm-mc -triple=amdgcn -mcpu=gfx1100.

// v_cmp_lt_u64_e32 vcc_lo, 0, v[src1:+1]  — VOPC op 0x59.
//   vcc_lo = (0 < v[src1]) per active lane. With src1=ref pair, this
//   is the "ref > 0" guard at the head of lif_step's main branch.
//   Verified: `v_cmp_lt_u64_e32 vcc_lo, 0, v[2:3]` → 0x7CB20480.
fn asm_v_cmp_lt_u64_imm0_vgpr_pair(uint64 vsrc1_pair) {
    uint64 src0_enc = 0x80                                   // inline 0
    uint64 word = (0x3E << 25)
                  | (0x59 << 17)
                  | ((vsrc1_pair & 0xFF) << 9)
                  | (src0_enc & 0x1FF)
    asm_u32(word)
}

// global_store_b8 v[v_addr_pair:+1], v_data, off  — GLOBAL op 0x18,
//   off-saddr form (saddr = OFF/0x7C). Stores the low byte of v_data
//   to the byte at v[v_addr_pair]. Used by lif_step to write
//   fired[i] = 0 / 1 (u8). Verified:
//     global_store_b8 v[2:3], v0, off → 0xDC620000 0x00007C02.
fn asm_global_store_b8_offvaddr(uint64 vaddr_pair, uint64 vdata) {
    asm_u32(0xDC620000)
    uint64 word2 = (0x7C << 16)                              // saddr = OFF
                   | ((vdata     & 0xFF) << 8)
                   | (vaddr_pair & 0xFF)
    asm_u32(word2)
}

// global_store_b8 v_addr_u32, v_data, s[saddr:+1]  — GLOBAL op 0x18.
//   With sbase form (saddr is a raw SGPR pair), v_addr is a single
//   VGPR with a 32-bit byte offset. Used by lif_step's "fired[i]=0"
//   write at function entry (cheap since the byte offset is just gid).
//   Encoding for `global_store_b8 v0, v0, s[14:15]`: word1=0xDC620000,
//   word2 = (saddr_pair_raw_lo<<16) | (vdata<<8) | vaddr  with
//   saddr=14 → 0x000E0000 (NOT pair-halved like SMEM; saddr is a raw
//   SGPR index, same as the existing global_load_b64's saddr_pair arg).
fn asm_global_store_b8_saddr(uint64 vaddr, uint64 vdata, uint64 saddr_pair) {
    asm_u32(0xDC620000)
    uint64 word2 = ((saddr_pair & 0x7F) << 16)
                   | ((vdata     & 0xFF) << 8)
                   | (vaddr      & 0xFF)
    asm_u32(word2)
}

// v_rcp_f64 v[vdst:+1], v[vsrc:+1]  — VOP1 op 0x2F (gfx11 b3 → 0x18 e32 form).
//   Initial reciprocal estimate (~14 bits of accuracy) for f64 division.
//   Verified: `v_rcp_f64_e32 v[12:13], v[10:11]` → 0x7E185F0A.
fn asm_v_rcp_f64(uint64 vdst_pair, uint64 vsrc_pair) {
    uint64 src0_enc = 0x100 | (vsrc_pair & 0xFF)             // VGPR
    uint64 word = (0x3F << 25)                                // VOP1 prefix
                  | ((vdst_pair & 0xFF) << 17)
                  | (0x2F << 9)                               // op
                  | (src0_enc & 0x1FF)
    asm_u32(word)
}

// v_div_scale_f64 v[vdst:+1], <sdst>, v[s0:+1], v[s1:+1], v[s2:+1]
//   VOP3B op 0x0FD. Scales operands of f64 division to avoid
//   underflow / overflow. sdst gets a scale flag (0x7C=null to discard,
//   0x6A=vcc_lo to feed v_div_fmas_f64's implicit shift control).
//   Verified:
//     v[4:5], null, v[2:3], v[2:3], v[0:1] → 0xD6FD7C04 0x04020502.
//     v[8:9], vcc_lo, v[0:1], v[2:3], v[0:1] → 0xD6FD6A08 0x04020500.
//   word1 = 0xD6FD0000 | (sdst << 8) | vdst.
//   word2 = (src2_enc<<18) | (src1_enc<<9) | src0_enc, no neg/abs.
fn asm_v_div_scale_f64(uint64 vdst_pair, uint64 sdst,
                       uint64 vsrc0_pair, uint64 vsrc1_pair, uint64 vsrc2_pair) {
    uint64 word1 = 0xD6FD0000 | ((sdst & 0xFF) << 8) | (vdst_pair & 0xFF)
    uint64 src0_enc = 0x100 | (vsrc0_pair & 0xFF)
    uint64 src1_enc = 0x100 | (vsrc1_pair & 0xFF)
    uint64 src2_enc = 0x100 | (vsrc2_pair & 0xFF)
    uint64 word2 = ((src2_enc & 0x1FF) << 18)
                   | ((src1_enc & 0x1FF) << 9)
                   | (src0_enc & 0x1FF)
    asm_u32(word1)
    asm_u32(word2)
}

// v_fma_f64 v[vdst:+1], -v[s0:+1], v[s1:+1], 1.0  — VOP3 op 0x014, neg src0.
//   Computes vdst = -src0 * src1 + 1.0  (f64 inline literal 1.0 = 0xF2).
//   Verified: `v_fma_f64 v[16:17], -v[10:11], v[12:13], 1.0`
//             → 0xD6140010 0x23CA190A.
fn asm_v_fma_f64_neg_v_v_lit1(uint64 vdst_pair, uint64 v_src0_pair,
                               uint64 v_src1_pair) {
    uint64 word1 = (0x6B << 25) | (0x014 << 16) | (vdst_pair & 0xFF)
    asm_u32(word1)
    uint64 src0_enc = 0x100 | (v_src0_pair & 0xFF)
    uint64 src1_enc = 0x100 | (v_src1_pair & 0xFF)
    uint64 src2_enc = 0xF2                                    // inline 1.0
    uint64 neg = 0x1                                          // neg[0] = 1 → -src0
    uint64 word2 = (neg << 29)
                   | ((src2_enc & 0x1FF) << 18)
                   | ((src1_enc & 0x1FF) << 9)
                   | (src0_enc & 0x1FF)
    asm_u32(word2)
}

// v_fma_f64 v[vdst:+1], v[s0:+1], v[s1:+1], v[s2:+1]  — VOP3 op 0x014, no neg.
//   All-VGPR three-source FMA. Verified:
//     v_fma_f64 v[12:13], v[16:17], v[12:13], v[12:13] → 0xD614000C 0x04321910.
//     v_fma_f64 v[16:17], v[10:11], v[12:13], v[14:15] → 0xD6140010 0x041A190A.
fn asm_v_fma_f64_v_v_v(uint64 vdst_pair, uint64 v_src0_pair,
                       uint64 v_src1_pair, uint64 v_src2_pair) {
    uint64 word1 = (0x6B << 25) | (0x014 << 16) | (vdst_pair & 0xFF)
    asm_u32(word1)
    uint64 src0_enc = 0x100 | (v_src0_pair & 0xFF)
    uint64 src1_enc = 0x100 | (v_src1_pair & 0xFF)
    uint64 src2_enc = 0x100 | (v_src2_pair & 0xFF)
    uint64 word2 = ((src2_enc & 0x1FF) << 18)
                   | ((src1_enc & 0x1FF) << 9)
                   | (src0_enc & 0x1FF)
    asm_u32(word2)
}

// v_fma_f64 v[vdst:+1], -v[s0:+1], v[s1:+1], v[s2:+1]  — VOP3 op 0x014, neg src0.
//   All-VGPR three-source FMA, src0 negated.
//   Verified: `v_fma_f64 v[18:19], -v[16:17], v[12:13], v[14:15]`
//             → 0xD6140012 0x243A1910.
fn asm_v_fma_f64_negv_v_v(uint64 vdst_pair, uint64 v_src0_pair,
                          uint64 v_src1_pair, uint64 v_src2_pair) {
    uint64 word1 = (0x6B << 25) | (0x014 << 16) | (vdst_pair & 0xFF)
    asm_u32(word1)
    uint64 src0_enc = 0x100 | (v_src0_pair & 0xFF)
    uint64 src1_enc = 0x100 | (v_src1_pair & 0xFF)
    uint64 src2_enc = 0x100 | (v_src2_pair & 0xFF)
    uint64 neg = 0x1                                          // neg[0] = 1
    uint64 word2 = (neg << 29)
                   | ((src2_enc & 0x1FF) << 18)
                   | ((src1_enc & 0x1FF) << 9)
                   | (src0_enc & 0x1FF)
    asm_u32(word2)
}

// v_div_fmas_f64 v[vdst:+1], v[s0:+1], v[s1:+1], v[s2:+1]  — VOP3 op 0x038.
//   FMA with implicit shift control from VCC; used in IEEE-correct f64
//   division to compute the rounded quotient.
//   Verified: v_div_fmas_f64 v[16:17], v[12:13], v[10:11], v[14:15]
//             → 0xD6380010 0x043A150C.
fn asm_v_div_fmas_f64(uint64 vdst_pair, uint64 v_src0_pair,
                      uint64 v_src1_pair, uint64 v_src2_pair) {
    uint64 word1 = (0x6B << 25) | (0x038 << 16) | (vdst_pair & 0xFF)
    asm_u32(word1)
    uint64 src0_enc = 0x100 | (v_src0_pair & 0xFF)
    uint64 src1_enc = 0x100 | (v_src1_pair & 0xFF)
    uint64 src2_enc = 0x100 | (v_src2_pair & 0xFF)
    uint64 word2 = ((src2_enc & 0x1FF) << 18)
                   | ((src1_enc & 0x1FF) << 9)
                   | (src0_enc & 0x1FF)
    asm_u32(word2)
}

// v_div_fmas_f64 v[vdst:+1], -v[s0:+1], v[s1:+1], v[s2:+1] — neg src0 form.
//   Verified: v_div_fmas_f64 v[16:17], -v[12:13], v[10:11], v[14:15]
//             → 0xD6380010 0x243A150C.
fn asm_v_div_fmas_f64_neg(uint64 vdst_pair, uint64 v_src0_pair,
                          uint64 v_src1_pair, uint64 v_src2_pair) {
    uint64 word1 = (0x6B << 25) | (0x038 << 16) | (vdst_pair & 0xFF)
    asm_u32(word1)
    uint64 src0_enc = 0x100 | (v_src0_pair & 0xFF)
    uint64 src1_enc = 0x100 | (v_src1_pair & 0xFF)
    uint64 src2_enc = 0x100 | (v_src2_pair & 0xFF)
    uint64 neg = 0x1                                          // neg[0] = 1
    uint64 word2 = (neg << 29)
                   | ((src2_enc & 0x1FF) << 18)
                   | ((src1_enc & 0x1FF) << 9)
                   | (src0_enc & 0x1FF)
    asm_u32(word2)
}

// v_div_fixup_f64 v[vdst:+1], v[s0:+1], v[s1:+1], v[s2:+1]  — VOP3 op 0x028.
//   Final IEEE rounding fixup for f64 division. src0 = quotient,
//   src1 = denominator, src2 = numerator.
//   Verified: v_div_fixup_f64 v[18:19], v[16:17], v[2:3], v[0:1]
//             → 0xD6280012 0x04020510.
fn asm_v_div_fixup_f64(uint64 vdst_pair, uint64 v_src0_pair,
                       uint64 v_src1_pair, uint64 v_src2_pair) {
    uint64 word1 = (0x6B << 25) | (0x028 << 16) | (vdst_pair & 0xFF)
    asm_u32(word1)
    uint64 src0_enc = 0x100 | (v_src0_pair & 0xFF)
    uint64 src1_enc = 0x100 | (v_src1_pair & 0xFF)
    uint64 src2_enc = 0x100 | (v_src2_pair & 0xFF)
    uint64 word2 = ((src2_enc & 0x1FF) << 18)
                   | ((src1_enc & 0x1FF) << 9)
                   | (src0_enc & 0x1FF)
    asm_u32(word2)
}

// f64 division helper: v[r:r+1] = v[n:n+1] / v[d:d+1], using IEEE-correct
// gfx11 sequence (10 instructions). Scratch VGPR pairs s0=scaled_d,
// s1=scaled_n, t=reciprocal, u=correction term. Caller must reserve
// 8 contiguous VGPRs for {s0,s1,t,u} (each is a pair) — we accept them
// as 4 pair indices.
//
// Sequence (per AMD ISA + LLVM AMDGPU codegen):
//   scaled_d = div_scale_f64(d, d, n)         ; vcc gets scale flag
//   t        = rcp_f64(scaled_d)              ; ~14 bits
//   u        = -scaled_d * t + 1              ; e0
//   t        = u * t + t                      ; r += e0*r
//   u        = -scaled_d * t + 1              ; e1
//   t        = u * t + t                      ; r += e1*r (~52 bits)
//   scaled_n = div_scale_f64(n, d, n)
//   u        = div_fmas_f64(t, scaled_d, 0)   ; rounded q*d (no, actually...)
//   ...
// LLVM-correct sequence (cross-checked against AMDGPU backend codegen):
//   scaled_d = div_scale_f64(vcc, d, d, n)     ; vdst pair, vcc gets flag
//   rcp      = v_rcp_f64(scaled_d)
//   u0       = v_fma_f64(-scaled_d, rcp, 1.0)
//   t1       = v_fma_f64(u0, rcp, rcp)
//   u1       = v_fma_f64(-scaled_d, t1, 1.0)
//   t2       = v_fma_f64(u1, t1, t1)
//   scaled_n = div_scale_f64(vcc, n, d, n)
//   q1       = v_div_fmas_f64(t2, scaled_n, 0)   ; can't use 0 directly
// On gfx11, the canonical LLVM sequence is:
//   scaled_d = div_scale_f64(vcc, d, d, n)
//   rcp      = v_rcp_f64(scaled_d)
//   u0       = v_fma_f64(-scaled_d, rcp, 1.0)
//   rcp1     = v_fma_f64(u0, rcp, rcp)
//   u1       = v_fma_f64(-scaled_d, rcp1, 1.0)
//   rcp2     = v_fma_f64(u1, rcp1, rcp1)
//   scaled_n = div_scale_f64(vcc, n, d, n)        ; reset vcc to numerator scale
//   q        = v_mul_f64(scaled_n, rcp2)          ; OR div_fmas_f64 trick
//   r        = v_fma_f64(-scaled_d, q, scaled_n)  ; residual
//   q1       = v_div_fmas_f64(r, rcp2, q)         ; corrected q with shift
//   result   = v_div_fixup_f64(q1, d, n)
//
// Total: 11 VOP3 instructions. Caller passes:
//   v_n_pair, v_d_pair, v_r_pair  (numerator, denominator, result; can alias)
//   sd_pair = scaled_d scratch; sn_pair = scaled_n scratch;
//   t_pair = reciprocal scratch; u_pair = correction scratch.
// Result lands in v_r_pair.
fn asm_lif_div_f64(uint64 v_n, uint64 v_d, uint64 v_r,
                   uint64 sd, uint64 sn, uint64 t, uint64 u) {
    asm_v_div_scale_f64(sd, 0x7C, v_d, v_d, v_n)       // sd = scaled_d, sdst=null
    asm_v_rcp_f64(t, sd)                               // t = 1/scaled_d (rough)
    asm_v_fma_f64_neg_v_v_lit1(u, sd, t)               // u = -sd*t + 1
    asm_v_fma_f64_v_v_v(t, u, t, t)                    // t = u*t + t
    asm_v_fma_f64_neg_v_v_lit1(u, sd, t)               // u = -sd*t + 1
    asm_v_fma_f64_v_v_v(t, u, t, t)                    // t ≈ 1/sd accurate
    asm_v_div_scale_f64(sn, 0x6A, v_n, v_d, v_n)       // sn = scaled_n, sdst=vcc_lo
    asm_v_mul_f64_vv(u, sn, t)                         // u = sn * t (rough q)
    asm_v_fma_f64_negv_v_v(v_r, sd, u, sn)             // r_scratch = -sd*u + sn
    asm_v_div_fmas_f64(u, v_r, t, u)                   // u = r*t + u  (corrected)
    asm_v_div_fixup_f64(v_r, u, v_d, v_n)              // result = fixup(u, d, n)
}

// gid = wg_id_x * 256 + tid_in_wg, written into v1.
//   v_mov_b32 v1, s15            ; v1 = wg_id_x
//   v_lshlrev_b32 v1, 8, v1      ; v1 = wg_id_x << 8
//   v_add_nc_u32 v1, v1, v0      ; v1 = gid (tid_in_wg < 256 always)
fn asm_noesis_compute_gid_v1() {
    asm_v_mov_b32(1, 15)                            // v1 = s15
    asm_v_lshlrev_b32_imm(1, 8, 1)                  // v1 <<= 8
    asm_v_add_nc_u32_vv(1, 1, 0)                    // v1 += v0
    asm_s_delay_alu(0x01)
}

// noesis decay_step lowering.
//
//   @kernel fn decay_step(uint64 buf, uint64 n, f64 factor) {
//       uint64 i = tid_x()
//       if i < n {
//           uint64 p = buf + i * 8
//           f64 v; *(p as f64) -> v
//           v = v - v * factor
//           *(p as f64) = v
//       }
//   }
//
// Kernarg layout (matches launcher kp_decay):
//   [0x00] buf    (u64*) — GLOBAL_BUFFER size 8
//   [0x08] n      (u64 by-value, low 32 bits used) — size 4 + 4 pad
//   [0x10] factor (f64 by-value)                   — size 8
//   total = 24 bytes
fn amdgpu_lower_noesis_decay(uint64 kname_ptr, uint64 nl) -> uint64 {
    asm_init()
    asm_noesis_compute_gid_v1()                     // v1 = gid

    // Load n (low 32 bits) into s2 — sdata_pair=1 → s2.
    asm_s_load_b32(1, 0, 0x8)
    asm_s_waitcnt_lgkmcnt_zero()

    // gid < n: vcc_lo = (s2 > v1).
    asm_v_cmp_gt_u32_sgpr_vgpr(2, 1)
    asm_s_and_saveexec_b32_vcc_lo(2)
    asm_s_cbranch_execz(13)                         // skip 13 dwords to s_endpgm

    // Load buf into s[2:3], factor into s[4:5].
    asm_s_load_b64(1, 0)                            // s[2:3] = buf
    asm_s_load_b64_off(2, 0, 0x10)                  // s[4:5] = factor
    asm_v_lshlrev_b32_imm(2, 3, 1)                  // v2 = gid * 8
    asm_s_waitcnt_lgkmcnt_zero()

    // Load buf[gid] into v[4:5] (saddr = raw SGPR index of pair low half = 2).
    asm_global_load_b64(4, 2, 2)                    // v[4:5] = buf[gid]
    asm_s_waitcnt_vmcnt_zero()

    // v[4:5] = v - v*factor = -factor*v + v
    //   asm_v_fma_f64_neg_s_v_v(vdst=4, neg_sgpr_pair=4, vsrc1=4, vsrc2=4)
    //   → v_fma_f64 v[4:5], -s[4:5], v[4:5], v[4:5]
    asm_v_fma_f64_neg_s_v_v(4, 4, 4, 4)
    asm_global_store_b64(2, 4, 2)                   // buf[gid] = v[4:5]
    asm_s_endpgm()

    // 3 args; matches launcher's 24-byte buffer with HIP runtime
    // size-driven packing (4-byte n + 4-byte pad + 8-byte factor).
    uint64 args_desc = alloc(3 * 16)
    uint64 a0s = args_desc + 0;   unsafe { *(a0s as uint64) = 8 }
    uint64 a0k = args_desc + 8;   unsafe { *(a0k as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a1s = args_desc + 16;  unsafe { *(a1s as uint64) = 4 }
    uint64 a1k = args_desc + 24;  unsafe { *(a1k as uint64) = AMD_ARG_KIND_BY_VALUE }
    uint64 a2s = args_desc + 32;  unsafe { *(a2s as uint64) = 8 }
    uint64 a2k = args_desc + 40;  unsafe { *(a2k as uint64) = AMD_ARG_KIND_BY_VALUE }

    // Snapshot the asm text into its own buffer (next kernel's asm_init
    // will clobber asm_text_buf otherwise — same pattern as the
    // existing structural lowerer).
    uint64 k_text_size = asm_text_len
    uint64 k_text_buf  = alloc(k_text_size)
    uint64 ci = 0
    while ci < k_text_size {
        uint64 sp = asm_text_buf + ci
        uint64 b = 0
        unsafe { *(sp as uint8) -> b }
        uint64 dp = k_text_buf + ci
        uint8 b8 = b
        unsafe { *(dp as uint8) = b8 }
        ci = ci + 1
    }

    uint64 rsrc1 = 0xE0AF0000        // VGPR granule 0 → 8 VGPRs (we use v0..v5)
    uint64 rsrc2 = 0x0000009E
    uint64 rsrc3 = 0x00000010
    uint64 props = 0x0408
    kt_push(kname_ptr, nl, k_text_buf, k_text_size,
            args_desc, 3, 24,
            18, 6,                                  // sgpr=18 (s0..s15+exec save), vgpr=6
            rsrc1, rsrc2, rsrc3, props)
    return 0
}

// _kfd_copy_u64: device-side memcpy for 8-byte-aligned buffers. The
// canonical use is hipMemcpy(D2H) from a host-mapped VRAM buffer into
// a GTT staging area, where CPU-side reads from VRAM are PCIe-BAR1-
// limited (~1.3 GB/s) and a kernel copy through HBM (~960 GB/s) →
// GTT (~32 GB/s) drops the cost from minutes to milliseconds at
// 60M-thread scale.
//
// Kernarg layout (3 args × 8 = 24 bytes):
//   [0x00] dst_ptr  (u64*)  — destination, typically GTT staging
//   [0x08] src_ptr  (u64*)  — source, typically host-vis VRAM
//   [0x10] n_u64    (u64 by-value, low 32 used) — number of u64s to copy
//
// Block size = 256, grid = ceil(n_u64 / 256). Each lane copies one
// 8-byte word.
fn amdgpu_lower_kfd_copy_u64(uint64 kname_ptr, uint64 nl) -> uint64 {
    asm_init()
    asm_noesis_compute_gid_v1()                          // v1 = gid

    asm_s_load_b64(1, 0)                                 // s[2:3] dst_ptr
    asm_s_load_b64_off(2, 0, 0x08)                       // s[4:5] src_ptr
    asm_s_load_b32(3, 0, 0x10)                           // s6     n_u64 (lo32)
    asm_s_waitcnt_lgkmcnt_zero()

    // Bounds check: gid < n_u64.
    asm_v_cmp_gt_u32_sgpr_vgpr(6, 1)
    asm_s_and_saveexec_b32_vcc_lo(8)                     // s8 = old EXEC
    uint64 skip_off = asm_text_len / 4
    asm_s_cbranch_execz(0)                               // patched to s_endpgm

    // gid_byte_offset = gid * 8 → v[2:3] (zero-extended u64).
    asm_v_lshlrev_b32_imm(2, 3, 1)
    asm_v_mov_b32_inline_u(3, 0)

    // src_addr = s[4:5] + v[2:3] → v[6:7].
    asm_v_mov_b32(6, 0x100 | 2)
    asm_v_mov_b32(7, 0x100 | 3)
    asm_v_add_co_u32_vcc_sv(6, 4, 6)
    asm_v_add_co_ci_u32_null_sv_vcc(7, 5, 7)

    // Load src[gid] into v[4:5].
    asm_global_load_b64_offvaddr(4, 6)
    asm_s_waitcnt_vmcnt_zero()

    // dst_addr = s[2:3] + v[2:3] → v[6:7].
    asm_v_mov_b32(6, 0x100 | 2)
    asm_v_mov_b32(7, 0x100 | 3)
    asm_v_add_co_u32_vcc_sv(6, 2, 6)
    asm_v_add_co_ci_u32_null_sv_vcc(7, 3, 7)

    // Store v[4:5] into dst[gid].
    asm_global_store_b64_offvaddr(6, 4)
    asm_s_waitcnt_vscnt_zero()

    // Back-patch s_cbranch_execz to land here.
    uint64 end_off = asm_text_len / 4
    uint64 skip_dwords = end_off - (skip_off + 1)
    uint64 skip_byte = asm_text_buf + skip_off * 4
    uint32 skip_word = 0xBFA50000 | (skip_dwords & 0xFFFF)
    unsafe { *(skip_byte as uint32) = skip_word }

    asm_s_endpgm()

    // 3 args: 2 GLOBAL_BUFFER + 1 BY_VALUE.
    uint64 args_desc = alloc(3 * 16)
    uint64 a0s = args_desc + 0;   unsafe { *(a0s as uint64) = 8 }
    uint64 a0k = args_desc + 8;   unsafe { *(a0k as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a1s = args_desc + 16;  unsafe { *(a1s as uint64) = 8 }
    uint64 a1k = args_desc + 24;  unsafe { *(a1k as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a2s = args_desc + 32;  unsafe { *(a2s as uint64) = 8 }
    uint64 a2k = args_desc + 40;  unsafe { *(a2k as uint64) = AMD_ARG_KIND_BY_VALUE }

    uint64 k_text_size = asm_text_len
    uint64 k_text_buf  = alloc(k_text_size)
    uint64 ci = 0
    while ci < k_text_size {
        uint64 sp = asm_text_buf + ci
        uint64 b = 0; unsafe { *(sp as uint8) -> b }
        uint64 dp = k_text_buf + ci
        uint8 b8 = b; unsafe { *(dp as uint8) = b8 }
        ci = ci + 1
    }

    uint64 rsrc1 = 0xE0AF0000           // VGPR granule 0 → 8 VGPRs (v0..v7)
    uint64 rsrc2 = 0x0000009E
    uint64 rsrc3 = 0x00000010
    uint64 props = 0x0408

    kt_push(kname_ptr, nl, k_text_buf, k_text_size,
            args_desc, 3, 24,
            10, 8,
            rsrc1, rsrc2, rsrc3, props)
    return 0
}

// Slice 4.19.11 — amdgpu_lower_qwen3_megakernel (slice 4.18 byte-wrapper)
// removed.  Was: pushed pre-extracted gfx1100 .text bytes from
// build/native_megakernel/qwen3_layer_megakernel.gfx1100.bin into the
// kernel table for module-level emit.  The v2 AST-walker
// (--emit-amdgpu-qwen3-megakernel-v2=PATH) replaces this entirely;
// see emit_amdgpu_qwen3_megakernel_blob_v2 below.

// noesis csr_build lowering.
//
//   @kernel fn csr_build(
//       uint64 col_tgt, uint64 col_w, uint64 col_is_inh, uint64 cell_type,
//       uint64 n, uint64 syn_per, uint64 seed,
//       f64 w_ee, f64 w_ei, f64 w_ie
//   ) {
//       src = tid_x()
//       if src >= n: return
//       src_e = (cell_type[src] == 0) ? 1 : 0
//       base = src * syn_per
//       for k in 0..syn_per {
//           ctr = base + k
//           // splitmix64
//           z = seed + ctr * C0
//           z = (z ^ (z >> 30)) * C1
//           z = (z ^ (z >> 27)) * C2
//           z = z ^ (z >> 31)
//           tgt = z % n
//           if tgt == src: tgt = (tgt+1) == n ? 0 : tgt+1
//           tgt_e = (cell_type[tgt] == 0) ? 1 : 0
//           if src_e:  w = tgt_e ? w_ee : w_ei; inh = 0
//           else:      w = w_ie;                inh = 1
//           col_tgt[base+k] = tgt; col_w[base+k] = w; col_is_inh[base+k] = inh
//       }
//   }
//
// Kernarg layout (10 args × 8 bytes = 80 bytes; matches launcher kp_csr):
//   [0x00] col_tgt    [0x08] col_w   [0x10] col_is_inh   [0x18] cell_type
//   [0x20] n          [0x28] syn_per  [0x30] seed        [0x38] w_ee
//   [0x40] w_ei       [0x48] w_ie
//
// Splitmix64 constants: C0=0x9E3779B97F4A7C15, C1=0xBF58476D1CE4E5B9,
// C2=0x94D049BB133111EB. Loaded into SGPRs at kernel start as
// {s30:s31, s32:s33, s34:s35} via two 32-bit literal stores per pair.
//
// Modulo (z % n) uses 64-iter long division — one-shot startup kernel,
// performance is fine. Loop body is ~10 vector instructions guarded by
// an SALU s24 = 63..0 counter; each iteration shifts a bit out of z,
// shifts r left, ORs the bit in, and conditionally subtracts n.
//
// VGPR plan: 32 used (granule 3). v0=tid_in_wg, v1=gid (=src),
// v2:v3=z, v4:v5=z_shr scratch, v6:v7=mul scratch, v8:v9=mul scratch,
// v10:v11=ctr, v12:v13=r, v14:v15=n_v, v16:v17=r_minus_n,
// v18=bit_in, v19=src_ct, v20=tgt_ct, v21:v22=w (f64),
// v23=inh, v24:v25=byte addr scratch, v26:v27=full ptr.
//
// SGPR plan: kernarg loads (s2..s27 sparsely; s14:s15 skipped because
// s15=wg_id_x), then s24=k, s25=i (long-div), s26=base, s28=outer EXEC
// save, s30..s35=splitmix64 constants. Total ~36 SGPRs.
fn amdgpu_lower_noesis_csr_build(uint64 kname_ptr, uint64 nl) -> uint64 {
    asm_init()

    // gid in v1 = wg_id_x*256 + tid_in_wg.
    asm_noesis_compute_gid_v1()

    // Prologue: load kernargs. Skip s14:s15 because s15 = wg_id_x.
    asm_s_load_b64(1, 0)                            // s[2:3]   col_tgt
    asm_s_load_b64_off(2, 0, 0x08)                  // s[4:5]   col_w
    asm_s_load_b64_off(3, 0, 0x10)                  // s[6:7]   col_is_inh
    asm_s_load_b64_off(4, 0, 0x18)                  // s[8:9]   cell_type
    asm_s_load_b64_off(5, 0, 0x20)                  // s[10:11] n  (only s10 used)
    asm_s_load_b64_off(6, 0, 0x28)                  // s[12:13] syn_per (only s12 used)
    asm_s_load_b64_off(8, 0, 0x30)                  // s[16:17] seed
    asm_s_load_b64_off(9, 0, 0x38)                  // s[18:19] w_ee
    asm_s_load_b64_off(10, 0, 0x40)                 // s[20:21] w_ei
    asm_s_load_b64_off(11, 0, 0x48)                 // s[22:23] w_ie
    asm_s_waitcnt_lgkmcnt_zero()

    // Splitmix64 constants into SGPRs: s30:s31=C0, s32:s33=C1, s34:s35=C2.
    asm_s_mov_b32_lit32(30, 0x7F4A7C15)             // C0_lo
    asm_s_mov_b32_lit32(31, 0x9E3779B9)             // C0_hi
    asm_s_mov_b32_lit32(32, 0x1CE4E5B9)             // C1_lo
    asm_s_mov_b32_lit32(33, 0xBF58476D)             // C1_hi
    asm_s_mov_b32_lit32(34, 0x133111EB)             // C2_lo
    asm_s_mov_b32_lit32(35, 0x94D049BB)             // C2_hi

    // Bounds check: gid < n (vcc_lo = (s10 > v1)).
    asm_v_cmp_gt_u32_sgpr_vgpr(10, 1)
    asm_s_and_saveexec_b32_vcc_lo(28)               // s28 = old EXEC
    uint64 outer_skip_off = asm_text_len / 4
    asm_s_cbranch_execz(0)                          // patched at end

    // src_e = (cell_type[src] == 0) ? 1 : 0.
    // Compute byte address: v24:v25 = s8:s9 + v1*8.
    asm_v_lshlrev_b32_imm(24, 3, 1)                 // v24 = v1 * 8 (low)
    asm_v_mov_b32_inline_u(25, 0)                   // v25 = 0 (high)
    asm_v_add_co_u32_vcc_sv(24, 8, 24)              // v24 += s8
    asm_v_add_co_ci_u32_null_sv_vcc(25, 9, 25)      // v25 += s9 + carry

    asm_global_load_b64_offvaddr(26, 24)            // v[26:27] = cell_type[src]
    asm_s_waitcnt_vmcnt_zero()
    asm_v_cmp_eq_u32_imm_vgpr(0, 26)                  // vcc_lo = (v26 == 0)
    asm_v_mov_b32_inline_u(19, 0)                   // v19 = 0
    asm_v_mov_b32_inline_u(28, 1)                   // v28 = 1 (scratch literal)
    asm_v_cndmask_b32_e64_vv_vcc(19, 19, 28)        // v19 = vcc ? 1 : 0  (src_e)

    // base = src * syn_per (u32). Hold in v30 — survives the loop body
    // (the cell_type[tgt] address computation later writes v[24:25],
    // so v25 is not safe for cross-iteration storage).
    asm_v_mul_lo_u32_vs(30, 1, 12)                  // v30 = src * syn_per

    // Initialise k counter in s24 = 0; loop while k < syn_per (s12).
    asm_s_mov_b32_inline_imm(24, 0)                 // s24 = 0

    // ── k loop top ──
    uint64 k_loop_top_off = asm_text_len / 4
    asm_s_cmp_lt_u32(24, 12)                        // SCC = (k < syn_per)
    uint64 k_scc_patch_off = asm_text_len / 4
    asm_s_cbranch_scc0(0)                           // patched to k_loop_end

    // ctr = base + k as u64. v_add_nc_u32 v_ctr_lo = v30 + s24, v_ctr_hi = 0.
    // Need v_add_nc_u32 with SGPR src — use the inline pattern from delivery.
    // Encoding: word = (0x25<<25) | (vdst<<17) | (vsrc1<<9) | (sgpr_src0)
    uint64 add_word = (0x25 << 25)
                      | ((10 & 0xFF) << 17)            // vdst = v10
                      | ((30 & 0xFF) << 9)             // vsrc1 = v30 (= base, stable)
                      | (24 & 0x1FF)                    // src0 = s24 raw
    asm_u32(add_word)
    asm_v_mov_b32_inline_u(11, 0)                   // v11 = 0  (ctr_hi)

    // ── splitmix64 step 1: z = seed + ctr * C0 ──
    // z (v[2:3]) = seed (s[16:17]) + (ctr_lo (v10) * C0 (s[30:31])) low 64.
    // Since ctr_hi = 0:
    //   ll_lo = mul_lo(v10, s30)        → bits 0..31
    //   ll_hi = mul_hi(v10, s30)        → bits 32..63 (low part)
    //   lh_lo = mul_lo(v10, s31)        → bits 32..63 (cross part)
    //   z_hi = ll_hi + lh_lo  (carry dropped)
    asm_v_mul_lo_u32_vs(2, 10, 30)                  // v2 = ll_lo
    asm_v_mul_hi_u32_vs(6, 10, 30)                  // v6 = ll_hi
    asm_v_mul_lo_u32_vs(7, 10, 31)                  // v7 = lh_lo
    asm_v_add_nc_u32_vv(3, 6, 7)                    // v3 = ll_hi + lh_lo

    // z += seed (s[16:17]). v_add_co_u32 / v_add_co_ci_u32 with SGPR src0.
    asm_v_add_co_u32_vcc_sv(2, 16, 2)               // v2 += s16 (carry → vcc)
    asm_v_add_co_ci_u32_null_sv_vcc(3, 17, 3)       // v3 += s17 + carry

    // ── splitmix64 step 2: z = (z ^ (z >> 30)) * C1 ──
    asm_v_lshrrev_b64_imm_vv(4, 30, 2)              // v[4:5] = z >> 30
    asm_v_xor_b32_e64_vv(2, 2, 4)                   // z_lo ^= shr_lo
    asm_v_xor_b32_e64_vv(3, 3, 5)                   // z_hi ^= shr_hi

    // z (v[2:3]) = z * C1 (s[32:33]) — full u64×u64 → low 64.
    //   ll_lo = mul_lo(z_lo, C1_lo)
    //   ll_hi = mul_hi(z_lo, C1_lo)
    //   lh_lo = mul_lo(z_lo, C1_hi)
    //   hl_lo = mul_lo(z_hi, C1_lo)
    //   z_lo' = ll_lo
    //   z_hi' = ll_hi + lh_lo + hl_lo
    asm_v_mul_lo_u32_vs(4, 2, 32)                   // v4 = ll_lo
    asm_v_mul_hi_u32_vs(6, 2, 32)                   // v6 = ll_hi
    asm_v_mul_lo_u32_vs(7, 2, 33)                   // v7 = lh_lo
    asm_v_mul_lo_u32_vs(8, 3, 32)                   // v8 = hl_lo
    asm_v_add_nc_u32_vv(6, 6, 7)                    // v6 = ll_hi + lh_lo
    asm_v_add_nc_u32_vv(6, 6, 8)                    // v6 += hl_lo  → z_hi'
    asm_v_mov_b32(2, 0x100 | 4)                     // v2 = v4   (z_lo')
    asm_v_mov_b32(3, 0x100 | 6)                     // v3 = v6   (z_hi')

    // ── splitmix64 step 3: z = (z ^ (z >> 27)) * C2 ──
    asm_v_lshrrev_b64_imm_vv(4, 27, 2)
    asm_v_xor_b32_e64_vv(2, 2, 4)
    asm_v_xor_b32_e64_vv(3, 3, 5)

    asm_v_mul_lo_u32_vs(4, 2, 34)                   // ll_lo
    asm_v_mul_hi_u32_vs(6, 2, 34)                   // ll_hi
    asm_v_mul_lo_u32_vs(7, 2, 35)                   // lh_lo
    asm_v_mul_lo_u32_vs(8, 3, 34)                   // hl_lo
    asm_v_add_nc_u32_vv(6, 6, 7)
    asm_v_add_nc_u32_vv(6, 6, 8)
    asm_v_mov_b32(2, 0x100 | 4)
    asm_v_mov_b32(3, 0x100 | 6)

    // ── splitmix64 step 4: z ^= z >> 31 ──
    asm_v_lshrrev_b64_imm_vv(4, 31, 2)
    asm_v_xor_b32_e64_vv(2, 2, 4)
    asm_v_xor_b32_e64_vv(3, 3, 5)

    // ── Modulo: tgt = z % n via 64-iter long division ──
    // r (v[12:13]) = 0; n_v (v[14:15]) = (s10, 0); s25 = 63 (i counter).
    asm_v_mov_b32_inline_u(12, 0)                   // r_lo = 0
    asm_v_mov_b32_inline_u(13, 0)                   // r_hi = 0
    asm_v_mov_b32(14, 10)                           // n_v_lo = s10
    asm_v_mov_b32_inline_u(15, 0)                   // n_v_hi = 0  (n < 2^32)
    asm_s_mov_b32_inline_imm(25, 63)                // i = 63

    uint64 div_loop_top_off = asm_text_len / 4
    // bit_in = (z >> i) & 1  (shifted goes into v[4:5])
    asm_v_lshrrev_b64_sgpr_vv(4, 25, 2)             // v[4:5] = z >> i
    asm_v_and_b32_imm_e64(18, 4, 1)                 // v18 = (shifted_lo) & 1

    // r = (r << 1) | bit_in
    asm_v_lshlrev_b64_imm_vv(12, 1, 12)             // r <<= 1
    asm_v_or_b32_e64_vv(12, 12, 18)                 // r_lo |= bit_in

    // r_minus_n = r - n  (v[16:17])
    asm_v_sub_co_u32_vcc_vv(16, 12, 14)             // v16 = r_lo - n_lo (sets vcc borrow)
    asm_v_sub_co_ci_u32_null_vv_vcc(17, 13, 15)     // v17 = r_hi - n_hi - borrow

    // vcc = (r >= n)
    asm_v_cmp_ge_u64_vv(12, 14)

    // r = vcc ? r_minus_n : r
    asm_v_cndmask_b32_e64_vv_vcc(12, 12, 16)        // r_lo = vcc ? r_minus_lo : r_lo
    asm_v_cndmask_b32_e64_vv_vcc(13, 13, 17)        // r_hi = vcc ? r_minus_hi : r_hi

    // SALU loop control: if i == 0 break, else i--, branch top.
    asm_s_cmp_eq_u32(25, 0x80)                      // SCC = (s25 == inline 0)
    uint64 div_exit_patch_off = asm_text_len / 4
    asm_s_cbranch_scc1(0)                           // patched to div_loop_end
    asm_s_sub_u32_imm(25, 25, 1)                    // i = i - 1
    uint64 div_back_branch_off = asm_text_len / 4
    uint64 div_back_delta = div_loop_top_off - (div_back_branch_off + 1)
    asm_s_branch(div_back_delta & 0xFFFF)

    uint64 div_loop_end_off = asm_text_len / 4
    uint64 div_exit_skip = div_loop_end_off - (div_exit_patch_off + 1)
    uint64 div_exit_byte = asm_text_buf + div_exit_patch_off * 4
    uint32 div_exit_word = 0xBFA20000 | (div_exit_skip & 0xFFFF)   // s_cbranch_scc1 op 0x22
    unsafe { *(div_exit_byte as uint32) = div_exit_word }

    // tgt is in v[12:13] (r at end of long division).
    // NOTE: the (tgt == src) self-loop fixup that the HIP version
    // applies is omitted in this initial native landing. Probability
    // of collision per edge = 1/n ≈ 1.7e-8 for n = 60M, so <1 in
    // every 60M edges differs vs the HIP reference. Self-loops are
    // legal in the runtime CSR delivery (a neuron firing into itself
    // adds its own release back into s_exc) and therefore preserve
    // simulation correctness within statistical noise.
    // Adding the fixup needs a v_cmp_eq_u32 vv-to-vcc helper plus a
    // chained "if vcc then conditional-add-1-with-rollover" — staged
    // for a follow-up so this emitter lands cleanly.

    // tgt_e = (cell_type[tgt] == 0) ? 1 : 0
    // Compute byte address: v24:v25 = s8:s9 + tgt*8.
    asm_v_lshlrev_b64_imm_vv(24, 3, 12)             // v[24:25] = tgt * 8
    asm_v_add_co_u32_vcc_sv(24, 8, 24)              // v24 += s8
    asm_v_add_co_ci_u32_null_sv_vcc(25, 9, 25)      // v25 += s9 + carry
    asm_global_load_b64_offvaddr(26, 24)            // v[26:27] = cell_type[tgt]
    asm_s_waitcnt_vmcnt_zero()
    asm_v_cmp_eq_u32_imm_vgpr(0, 26)                  // vcc = (tgt_ct == 0)
    asm_v_mov_b32_inline_u(20, 0)
    // v28 may have been clobbered by the previous iter's inh store;
    // restore the literal 1 right before the tgt_e cndmask.
    asm_v_mov_b32_inline_u(28, 1)
    asm_v_cndmask_b32_e64_vv_vcc(20, 20, 28)        // v20 = vcc ? 1 : 0  (tgt_e)

    // Compute (w, inh):
    //   if src_e (v19) == 1: w = tgt_e ? w_ee : w_ei; inh = 0
    //   else:                w = w_ie;               inh = 1
    //
    // Branch-free: build w_pair from (src_e, tgt_e):
    //   v[21:22] = w_ie (default for src_e = 0)
    //   if src_e == 1: v[21:22] = tgt_e ? w_ee : w_ei
    //
    // Use cndmask on the full 64-bit value (two 32-bit cndmasks).
    asm_v_mov_b32(21, 22)                           // v21 = s22 (w_ie lo)
    asm_v_mov_b32(22, 23)                           // v22 = s23 (w_ie hi)

    // Compute w_e = tgt_e ? w_ee : w_ei  in v[26:27], then if src_e cndmask
    // v[21:22] = w_e.
    asm_v_mov_b32(26, 20)                           // v26 = s20 (w_ei lo)
    asm_v_mov_b32(27, 21)                           // v27 = s21 (w_ei hi)
    // vcc = (tgt_e == 1)
    asm_v_cmp_eq_u32_imm_vgpr(1, 20)                // vcc = (v20 == 1)
    asm_v_mov_b32(34, 18)                           // v34 = s18 (w_ee lo)
    asm_v_mov_b32(35, 19)                           // v35 = s19 (w_ee hi)
    asm_v_cndmask_b32_e64_vv_vcc(26, 26, 34)        // v26 = vcc ? w_ee_lo : w_ei_lo
    asm_v_cndmask_b32_e64_vv_vcc(27, 27, 35)        // v27 = vcc ? w_ee_hi : w_ei_hi

    // vcc = (src_e == 1)
    asm_v_cmp_eq_u32_imm_vgpr(1, 19)                // vcc = (v19 == 1)
    asm_v_cndmask_b32_e64_vv_vcc(21, 21, 26)        // v21 = src_e ? w_e_lo : w_ie_lo
    asm_v_cndmask_b32_e64_vv_vcc(22, 22, 27)        // v22 = src_e ? w_e_hi : w_ie_hi

    // inh = src_e ? 0 : 1   = !src_e
    asm_v_mov_b32_inline_u(23, 1)
    asm_v_mov_b32_inline_u(26, 0)
    asm_v_cmp_eq_u32_imm_vgpr(1, 19)                // vcc = (src_e == 1)
    asm_v_cndmask_b32_e64_vv_vcc(23, 23, 26)        // v23 = src_e ? 0 : 1

    // ── stores to col_tgt[ctr], col_w[ctr], col_is_inh[ctr] ──
    // ctr (= base+k) is in v10. Byte offset = ctr * 8.
    asm_v_lshlrev_b32_imm(24, 3, 10)                // v24 = ctr * 8 (low)
    asm_v_mov_b32_inline_u(25, 0)                   // v25 = 0 (high)

    // col_tgt[ctr] = tgt (u64): saddr=s2, vaddr=v24.
    // global_store_b64 saddr form. Use the existing helper.
    asm_global_store_b64(24, 12, 2)                 // saddr=s[2:3], vdata=v[12:13]

    // col_w[ctr] = w (f64): saddr=s4, vaddr=v24, vdata=v[21:22].
    asm_global_store_b64(24, 21, 4)

    // col_is_inh[ctr] = inh (u64): saddr=s6, vaddr=v24, vdata pair v[28:29].
    asm_v_mov_b32(28, 0x100 | 23)                   // v28 = v23 (inh lo)
    asm_v_mov_b32_inline_u(29, 0)                   // v29 = 0 (inh hi)
    asm_global_store_b64(24, 28, 6)
    asm_s_waitcnt_vscnt_zero()

    // k = k + 1; branch top.
    asm_s_add_u32_imm(24, 24, 1)
    uint64 k_back_branch_off = asm_text_len / 4
    uint64 k_back_delta = k_loop_top_off - (k_back_branch_off + 1)
    asm_s_branch(k_back_delta & 0xFFFF)

    // ── k_loop_end ── back-patch the scc0 cbranch.
    uint64 k_loop_end_off = asm_text_len / 4
    uint64 k_scc_skip = k_loop_end_off - (k_scc_patch_off + 1)
    uint64 k_scc_patch_byte = asm_text_buf + k_scc_patch_off * 4
    uint32 k_scc_word = 0xBFA10000 | (k_scc_skip & 0xFFFF)
    unsafe { *(k_scc_patch_byte as uint32) = k_scc_word }

    // Back-patch the outer s_cbranch_execz too.
    uint64 outer_skip_target = asm_text_len / 4
    uint64 outer_skip_dwords = outer_skip_target - (outer_skip_off + 1)
    uint64 outer_skip_byte = asm_text_buf + outer_skip_off * 4
    uint32 outer_skip_word = 0xBFA50000 | (outer_skip_dwords & 0xFFFF)
    unsafe { *(outer_skip_byte as uint32) = outer_skip_word }

    asm_s_endpgm()

    // 10 args, all size=8 declared. 4 GLOBAL_BUFFER + 6 BY_VALUE
    // (n, syn_per, seed, w_ee, w_ei, w_ie).
    uint64 args_desc = alloc(10 * 16)
    uint64 ai = 0
    while ai < 4 {
        uint64 p0 = args_desc + ai * 16;     unsafe { *(p0 as uint64) = 8 }
        uint64 p1 = args_desc + ai * 16 + 8; unsafe { *(p1 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
        ai = ai + 1
    }
    while ai < 10 {
        uint64 p0 = args_desc + ai * 16;     unsafe { *(p0 as uint64) = 8 }
        uint64 p1 = args_desc + ai * 16 + 8; unsafe { *(p1 as uint64) = AMD_ARG_KIND_BY_VALUE }
        ai = ai + 1
    }

    uint64 k_text_size = asm_text_len
    uint64 k_text_buf  = alloc(k_text_size)
    uint64 ci = 0
    while ci < k_text_size {
        uint64 sp = asm_text_buf + ci
        uint64 b = 0; unsafe { *(sp as uint8) -> b }
        uint64 dp = k_text_buf + ci
        uint8 b8 = b; unsafe { *(dp as uint8) = b8 }
        ci = ci + 1
    }

    uint64 rsrc1 = 0xE0AF0004                       // VGPR granule=4 → 40 VGPRs (use v0..v35)
    uint64 rsrc2 = 0x0000009E
    uint64 rsrc3 = 0x00000010
    uint64 props = 0x0408

    // sgpr_count: s0..s35 = 36; round up.
    kt_push(kname_ptr, nl, k_text_buf, k_text_size,
            args_desc, 10, 80,
            40, 36,
            rsrc1, rsrc2, rsrc3, props)
    return 0
}

// noesis delivery_step lowering.
//
//   @kernel fn delivery_step(
//       uint64 fired_ptr, uint64 col_tgt_ptr, uint64 col_w_ptr,
//       uint64 col_is_inh_ptr, uint64 s_exc_ptr, uint64 s_inh_ptr,
//       uint64 n, uint64 syn_per
//   ) {
//       uint64 src = tid_x()
//       if src < n {
//           if u8(fired[src]) > 0 {
//               for k in 0..syn_per {
//                   slot = src * syn_per + k
//                   tgt  = u64(col_tgt[slot])
//                   w    = f64(col_w[slot])
//                   inh  = u64(col_is_inh[slot])
//                   dst_base = inh > 0 ? s_inh_ptr : s_exc_ptr
//                   atomic_add_f64(&dst_base[tgt], w)
//               }
//           }
//       }
//   }
//
// Kernarg layout (8 args × 8 bytes = 64 bytes total, matches launcher
// kp_deliv byte-for-byte; n and syn_per are stored as u64 by-value but
// HIP runtime size-drives the metadata so we only declare 4 bytes for
// them — matching decay_step's treatment of `n`).
//   [0x00] fired_ptr      (u64*) — GLOBAL_BUFFER
//   [0x08] col_tgt_ptr    (u64*) — GLOBAL_BUFFER
//   [0x10] col_w_ptr      (f64*) — GLOBAL_BUFFER
//   [0x18] col_is_inh_ptr (u64*) — GLOBAL_BUFFER
//   [0x20] s_exc_ptr      (f64*) — GLOBAL_BUFFER
//   [0x28] s_inh_ptr      (f64*) — GLOBAL_BUFFER
//   [0x30] n      (u64 by-value, low 32 bits used) — size 4 + 4 pad
//   [0x38] syn_per (u64 by-value, low 32 bits used) — size 4 + 4 pad
//   total = 64 bytes (the 4-byte declarations leave 4-byte holes that
//   the HIP runtime preserves by dispatched-arg copy size; the launcher
//   writes 8 bytes per slot so the actual segment is 64 bytes regardless
//   of how we declare the trailing two; matches the kp_deliv = alloc(8*8)
//   buffer the launcher hands to hipModuleLaunchKernel).
//
// Register plan:
//   SGPRs: s2..s13 = pointer kernargs; s14 = n; s16 = syn_per;
//          s15 = wg_id_x (rsrc2 reserves it); s18..s21 = EXEC saves +
//          k loop counter.
//   VGPRs: v0..v23. v0..v3 = CAS quad (NEW lo, NEW hi, CMP lo, CMP hi);
//          v4..v5 = scratch byte offset; v6..v7 = fired addr pair;
//          v8..v9 = s_exc splat; v10..v11 = s_inh splat;
//          v12..v13 = tgt b64; v14..v15 = w f64; v16..v17 = inh b64;
//          v18..v19 = dst_base (cndmask result); v20..v21 = tgt*8 pair;
//          v22..v23 = dst_addr pair (= dst_base + tgt*8).
fn amdgpu_lower_noesis_delivery(uint64 kname_ptr, uint64 nl) -> uint64 {
    asm_init()

    // gid in v1 = wg_id_x*256 + tid_in_wg.
    asm_noesis_compute_gid_v1()

    // Prologue: load all 8 kernargs into SGPRs.
    // Wrap them in a single s_clause so the hardware issues them as a
    // contiguous batch (mirrors hipcc's delivery_step).  Tried
    // consolidating into b256+b128+b32 — bit-exact but +50 ms wall
    // (b256 SMEM micro-op latency dominates the b64 issue savings).
    asm_s_clause(7)                             // 8 loads as one clause
    asm_s_load_b64(1, 0)                        // s[2:3]   = fired_ptr
    asm_s_load_b64_off(2, 0, 0x08)              // s[4:5]   = col_tgt_ptr
    asm_s_load_b64_off(3, 0, 0x10)              // s[6:7]   = col_w_ptr
    asm_s_load_b64_off(4, 0, 0x18)              // s[8:9]   = col_is_inh_ptr
    asm_s_load_b64_off(5, 0, 0x20)              // s[10:11] = s_exc_ptr
    asm_s_load_b64_off(6, 0, 0x28)              // s[12:13] = s_inh_ptr
    asm_s_load_b32(7, 0, 0x30)                  // s14 = n (low 32 bits)
    asm_s_load_b32(8, 0, 0x38)                  // s16 = syn_per (low 32 bits)
    asm_s_waitcnt_lgkmcnt_zero()

    // Bounds check: gid < n  (vcc_lo = (s14 > v1)).
    asm_v_cmp_gt_u32_sgpr_vgpr(14, 1)
    asm_s_and_saveexec_b32_vcc_lo(18)           // s18 = old EXEC; EXEC &= bounds
    // Forward-skip target patched at end of kernel: s_cbranch_execz to s_endpgm.
    uint64 outer_skip_off = asm_text_len / 4
    asm_s_cbranch_execz(0)                      // (placeholder, patched)

    // Splat s_exc (s[10:11]) and s_inh (s[12:13]) into VGPR pairs so the
    // per-lane cndmask in the loop can pick between them. SGPR-pair
    // operands are not encodable directly in v_cndmask_b32_e64.
    // VOPD dual-mov collapses each 2-mov splat into 1 VALU issue.
    asm_v_dual_mov_b32_pair_sxsy(8, 10, 11)     // v[8:9]  = s[10:11] (s_exc ptr)
    asm_v_dual_mov_b32_pair_sxsy(10, 12, 13)    // v[10:11] = s[12:13] (s_inh ptr)
    asm_s_delay_alu(0x02)

    // Build 64-bit address of fired[gid] = fired_ptr + gid*1.
    //   v6 = gid (v1) — byte offset low half
    //   v7 = 0       — byte offset high half
    //   v[6:7] = s[2:3] + v[6:7]    (32-bit add then carry)
    asm_v_mov_b32(6, 0x100 | 1)                 // v6 = v1 (gid)
    asm_v_mov_b32_inline_u(7, 0)                // v7 = 0
    asm_v_add_co_u32_vcc_sv(6, 2, 6)            // v6 = s2 + v6
    asm_v_add_co_ci_u32_null_sv_vcc(7, 3, 7)    // v7 = s3 + v7 + carry
    asm_s_delay_alu(0x01)

    // Load fired[gid] (u8, zero-extended) into v4.
    asm_global_load_u8_offvaddr(4, 6)
    asm_s_waitcnt_vmcnt_zero()

    // Fired guard: vcc_lo = (fired != 0). f > 0 with f a u8 ≡ f != 0.
    asm_v_cmp_ne_u32_imm0_vgpr(4)
    asm_s_and_saveexec_b32_vcc_lo(19)           // s19 = pre-fired EXEC; EXEC &= fired
    uint64 fired_skip_off = asm_text_len / 4
    asm_s_cbranch_execz(0)                      // (placeholder, patched to k-loop end)

    // Per-lane base = src * syn_per. v1 (=gid=src) × s16 (=syn_per).
    // Result fits in u32: 60M * 4 = 240M < 2^32. v25 (free reg)? Use v5.
    asm_v_mul_lo_u32_vs(5, 1, 16)               // v5 = gid * syn_per

    // SALU k-loop. k lives in s20; bound is s16 (syn_per).
    asm_s_mov_b32_imm0(20)                      // s20 = 0 (k)

    // ── loop_top ──
    uint64 loop_top_off = asm_text_len / 4
    asm_s_cmp_lt_u32(20, 16)                    // SCC = (k < syn_per)
    uint64 scc_patch_off = asm_text_len / 4
    asm_s_cbranch_scc0(0)                       // (placeholder, patched to loop_end)

    // slot = base + k. v4 = (base + k) — base in v5 (per-lane), k in s20 (scalar).
    // v_add_nc_u32 with src0 = SGPR encodes as raw SGPR index in src0.
    //   Word: (0x25<<25) | (vdst<<17) | (vsrc1<<9) | (sgpr_src0 & 0x1FF)
    uint64 add_word = (0x25 << 25)
                      | ((4 & 0xFF) << 17)        // vdst = v4
                      | ((5 & 0xFF) << 9)         // vsrc1 = v5
                      | (20 & 0x1FF)              // src0 = s20 (raw SGPR)
    asm_u32(add_word)

    // slot_byte_offset_u32 = (base + k) << 3.
    asm_v_lshlrev_b32_imm(4, 3, 4)              // v4 = v4 * 8
    asm_s_delay_alu(0x01)

    // Per-lane VMEM loads (saddr=raw SGPR pair index of base ptr; v_addr=v4).
    //   tgt = col_tgt[slot]   → v[12:13]   saddr=s4
    //   w   = col_w[slot]     → v[14:15]   saddr=s6
    //   inh = col_is_inh[slot] → v[16:17]  saddr=s8
    // Tried interleaving via vmcnt(2)/vmcnt(1) partial waits with the
    // inh→cndmask chain pipelined behind the tgt+w loads — bit-exact
    // but +35 ms wall vs the simple s_clause/vmcnt(0) shape on this
    // kernel. The 3 loads share the same v_addr and saddr base style
    // and are already issued back-to-back; the partial waits added
    // observable s_waitcnt overhead that exceeded the latency hiding.
    asm_s_clause(2)
    asm_global_load_b64(12, 4, 4)               // v[12:13] = tgt
    asm_global_load_b64(14, 4, 6)               // v[14:15] = w
    asm_global_load_b64(16, 4, 8)               // v[16:17] = inh
    asm_s_waitcnt_vmcnt_zero()

    // inh predicate: vcc_lo = (inh_lo != 0).
    asm_v_cmp_ne_u32_imm0_vgpr(16)

    // dst_base = inh ? s_inh : s_exc, per-lane. cndmask src0=false (s_exc=v[8:9]),
    // src1=true (s_inh=v[10:11]). Result → v[18:19].
    asm_v_cndmask_b32_e64_vv_vcc(18, 8, 10)     // v18 = inh ? v10 : v8 (lo)
    asm_v_cndmask_b32_e64_vv_vcc(19, 9, 11)     // v19 = inh ? v11 : v9 (hi)
    asm_s_delay_alu(0x01)

    // tgt * 8 (per-lane 64-bit) → v[20:21].
    asm_v_lshlrev_b64_imm_vv(20, 3, 12)         // v[20:21] = v[12:13] << 3
    asm_s_delay_alu(0x01)

    // dst_addr = dst_base + tgt*8 (per-lane 64-bit) → v[22:23].
    asm_v_add_co_u32_vcc_vv(22, 18, 20)         // v22 = v18 + v20 (lo, sets vcc carry)
    asm_v_add_co_ci_u32_null_vv_vcc(23, 19, 21) // v23 = v19 + v21 + carry
    asm_s_delay_alu(0x01)

    // Prime the CAS: assumed = *dst_addr → v[2:3] (cmp half of CAS quad).
    // Off-saddr form with v_addr = v[22:23] (per-lane 64-bit pair).
    asm_global_load_b64_offvaddr(2, 22)
    asm_s_waitcnt_vmcnt_zero()

    // Save EXEC (= fired-mask intersected with outer-bounds) before the
    // CAS retry narrows it to retrying lanes only.
    asm_s_mov_b32(21, 0x7E)                     // s21 = exec_lo

    // ── CAS retry loop (atomic add f64 at *dst_addr += w) ──
    uint64 cas_head_off = asm_text_len / 4
    asm_v_add_f64_vv(0, 2, 14)                  // v[0:1] = assumed + w
    asm_s_delay_alu(0x01)
    asm_global_atomic_cmpswap_b64_offvaddr(0, 22, 0) // v[0:1] = CAS(*v[22:23], v[2:3], v[0:1])
    asm_s_waitcnt_vmcnt_zero()
    asm_s_waitcnt_vscnt_zero()
    asm_v_cmp_ne_u64_vv(2, 0)                   // vcc = (returned_prev != assumed)
    asm_v_mov_b32(2, 0x100 | 0)                 // v2 = v0 (assumed = returned_prev lo)
    asm_v_mov_b32(3, 0x100 | 1)                 // v3 = v1 (assumed hi)
    asm_s_and_b32_exec_vcc_lo()                 // exec_lo &= vcc_lo (narrow to retrying lanes)
    uint64 cas_branch_off = asm_text_len / 4
    uint64 cas_delta = cas_head_off - (cas_branch_off + 1)
    asm_s_cbranch_execnz(cas_delta & 0xFFFF)

    // Restore EXEC = fired-and-bounds mask for the next k iteration.
    asm_s_mov_b32(0x7E, 21)                     // exec_lo = s21

    // k += 1; loop back.
    asm_s_add_u32_imm(20, 20, 1)
    uint64 outer_branch_off = asm_text_len / 4
    uint64 outer_delta = loop_top_off - (outer_branch_off + 1)
    asm_s_branch(outer_delta & 0xFFFF)

    // ── loop_end ── back-patch the scc0 cbranch.
    uint64 loop_end_off = asm_text_len / 4
    uint64 scc_skip = loop_end_off - (scc_patch_off + 1)
    uint64 scc_patch_byte = asm_text_buf + scc_patch_off * 4
    uint32 scc_word = 0xBFA10000 | (scc_skip & 0xFFFF)
    unsafe { *(scc_patch_byte as uint32) = scc_word }

    // Back-patch the fired_skip s_cbranch_execz to land here too. (Both
    // the loop-end and the no-fired-lanes path converge before s_endpgm.)
    uint64 fired_skip_target = asm_text_len / 4
    uint64 fired_skip_dwords = fired_skip_target - (fired_skip_off + 1)
    uint64 fired_skip_byte = asm_text_buf + fired_skip_off * 4
    uint32 fired_skip_word = 0xBFA50000 | (fired_skip_dwords & 0xFFFF)
    unsafe { *(fired_skip_byte as uint32) = fired_skip_word }

    // Back-patch the outer s_cbranch_execz to skip to s_endpgm too.
    uint64 outer_skip_target = asm_text_len / 4
    uint64 outer_skip_dwords = outer_skip_target - (outer_skip_off + 1)
    uint64 outer_skip_byte = asm_text_buf + outer_skip_off * 4
    uint32 outer_skip_word = 0xBFA50000 | (outer_skip_dwords & 0xFFFF)
    unsafe { *(outer_skip_byte as uint32) = outer_skip_word }

    asm_s_endpgm()

    // 8 args, all GLOBAL_BUFFER for the 6 pointers + 2 BY_VALUE u64 for
    // n and syn_per. They're declared u64 (size 8) — not u32 (size 4) —
    // so consecutive 4-byte declarations don't pack tightly into a single
    // 8-byte slot (which would shift syn_per's offset to 0x34 instead of
    // the launcher-expected 0x38). The launcher writes 8 bytes per kernarg
    // slot anyway; the kernel reads only the low 32 bits via s_load_b32.
    uint64 args_desc = alloc(8 * 16)
    uint64 ai = 0
    while ai < 6 {
        uint64 p0 = args_desc + ai * 16;     unsafe { *(p0 as uint64) = 8 }
        uint64 p1 = args_desc + ai * 16 + 8; unsafe { *(p1 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
        ai = ai + 1
    }
    while ai < 8 {
        uint64 p0 = args_desc + ai * 16;     unsafe { *(p0 as uint64) = 8 }
        uint64 p1 = args_desc + ai * 16 + 8; unsafe { *(p1 as uint64) = AMD_ARG_KIND_BY_VALUE }
        ai = ai + 1
    }

    // Snapshot text into private buffer (asm_init clobbers asm_text_buf).
    uint64 k_text_size = asm_text_len
    uint64 k_text_buf  = alloc(k_text_size)
    uint64 ci = 0
    while ci < k_text_size {
        uint64 sp = asm_text_buf + ci
        uint64 b = 0
        unsafe { *(sp as uint8) -> b }
        uint64 dp = k_text_buf + ci
        uint8 b8 = b
        unsafe { *(dp as uint8) = b8 }
        ci = ci + 1
    }

    uint64 rsrc1 = 0xE0AF0002                   // VGPR granule=2 → 24 VGPRs (v0..v23)
    uint64 rsrc2 = 0x0000009E
    uint64 rsrc3 = 0x00000010
    uint64 props = 0x0408

    // sgpr_count: s0..s21 used = 22, +2 for safety = 24.
    // The launcher's kernarg buffer is 64 bytes; the metadata declares
    // 6×8 (ptrs) + 2×4 (u32s) = 56 bytes "payload" but kernarg_segment_size
    // is rounded up to 8-byte alignment => 56 + padding = ... actually the
    // HIP runtime computes kernarg_segment_size from arg metadata sizes
    // with alignment rules. Use 64 to match the launcher's allocated
    // buffer; ROCm tolerates a slightly larger declared kernarg segment
    // (the runtime memcpys arg-by-arg into it).
    kt_push(kname_ptr, nl, k_text_buf, k_text_size,
            args_desc, 8, 64,
            24, 24,
            rsrc1, rsrc2, rsrc3, props)
    return 0
}

// noesis lif_step lowering.
//
//   @kernel fn lif_step(
//       uint64 V_ptr, uint64 ref_ptr, uint64 RI_ptr,
//       uint64 s_exc_ptr, uint64 s_inh_ptr, uint64 spike_ptr,
//       uint64 fired_ptr, uint64 n,
//       f64 dt, f64 V_rest, f64 V_reset, f64 V_thresh,
//       f64 tau_m, f64 J_E, f64 J_I, uint64 ref_steps
//   ) {
//       i = tid_x()
//       if i < n {
//           fired[i] = 0  (u8)
//           rc = ref[i]
//           if rc > 0 {
//               ref[i] = rc - 1
//               V[i] = V_reset
//           } else {
//               v = V[i]; ri = RI[i]; se = s_exc[i]; si = s_inh[i]
//               drive = ri + se*J_E - si*J_I
//               dv    = dt * (V_rest - v + drive) / tau_m
//               v_new = v + dv
//               if v_new >= V_thresh {
//                   V[i] = V_reset; ref[i] = ref_steps; spike[i]++; fired[i]=1
//               } else {
//                   V[i] = v_new
//               }
//           }
//       }
//   }
//
// Kernarg layout (16 args × 8 bytes = 128 bytes total, matches launcher
// kp_lif byte-for-byte). Per the lesson from the delivery_step session,
// every kernarg is declared as size=8 — the launcher writes 8 bytes per
// slot regardless of declared type, and HIP runtime auto-alignment from
// declared sizes can slip the offset of a downstream f64 if a u32 sneaks
// in (caused the session-3 illegal-address bug). With size=8 across the
// board, offsets land at 0,8,16,...,120 byte-for-byte.
//
//   [0x00] V_ptr      (u64*)  → s[2:3]
//   [0x08] ref_ptr    (u64*)  → s[4:5]
//   [0x10] RI_ptr     (f64*)  → s[6:7]
//   [0x18] s_exc_ptr  (f64*)  → s[8:9]
//   [0x20] s_inh_ptr  (f64*)  → s[10:11]
//   [0x28] spike_ptr  (u64*)  → s[12:13]
//   [0x30] fired_ptr  (u8*)   → s[16:17]   (skip s[14:15] — s15 = wg_id_x)
//   [0x38] n          (u32 lo)→ s14
//   [0x40] dt         (f64)   → s[18:19]
//   [0x48] V_rest     (f64)   → s[20:21]
//   [0x50] V_reset    (f64)   → s[22:23]
//   [0x58] V_thresh   (f64)   → s[24:25]
//   [0x60] tau_m      (f64)   → s[26:27]
//   [0x68] J_E        (f64)   → s[28:29]
//   [0x70] J_I        (f64)   → s[30:31]
//   [0x78] ref_steps  (u32 lo)→ s32
//
// EXEC saves: s33 = outer (gid<n), s34 = refractory, s35 = spike.
//
// VGPR plan:
//   v0  = tid_in_wg (kernel input)
//   v1  = gid (= wg_id_x*256 + v0)
//   v2  = byte offset (= gid*8) for f64/u64 stores
//   v3  = byte offset (= gid) for the u8 fired store
//   v4  = scratch (0 / 1 inline for fired writes)
//   v[10:11] = V (active) / V_reset splat (refractory + spike)
//   v[12:13] = rc (refractory test) / ref_steps splat (spike)
//   v[14:15] = RI (active) / dt splat / tau_m splat / spike[i] (spike)
//   v[16:17] = se (active) / div scratch sd (active div)
//   v[18:19] = si (active) / div scratch sn
//   v[20:21] = drive accumulator / div scratch t (rcp)
//   v[22:23] = dv_num = (V_rest - V + drive) * dt
//   v[24:25] = div scratch u
//   v[26:27] = dv (= num/den)
//   v[28:29] = v_new (= V + dv)
//   v[30:31] = V_thresh splat
//
// VGPR count: 32 → granule=3 (rsrc1 = 0xE0AF0003).
fn amdgpu_lower_noesis_lif(uint64 kname_ptr, uint64 nl) -> uint64 {
    asm_init()

    // ── Phase 1: gid in v1 = wg_id_x*256 + tid_in_wg ──
    asm_noesis_compute_gid_v1()

    // ── Phase 2: prologue, load all 16 kernargs into SGPRs ──
    // Wider-load consolidation: fold consecutive pairs of b64 loads into
    // single b128/b256 ops where the destinations are 4-aligned and
    // contiguous, mirroring hipcc's wide kernarg load. Reduces 16 SMEM
    // ops to 10 (fewer issue cycles + a tighter clause). b128/b256 dst
    // SGPRs must be multiples of 4 — s2/s12/s14/s16/s18 are not, so
    // those stay as b64 / b32; the rest collapse.
    asm_s_clause(9)                             // 10 loads as one clause
    asm_s_load_b64(1, 0)                        // s[2:3]   = V_ptr
    asm_u32(0xF4080100); asm_u32(0xF8000008)    // s_load_b128 s[4:7],  0x08 (ref+RI)
    asm_u32(0xF4080200); asm_u32(0xF8000018)    // s_load_b128 s[8:11], 0x18 (s_exc+s_inh)
    asm_s_load_b64_off(6, 0, 0x28)              // s[12:13] = spike_ptr
    asm_s_load_b64_off(8, 0, 0x30)              // s[16:17] = fired_ptr (skip s14:s15)
    asm_s_load_b32(7, 0, 0x38)                  // s14 = n (low 32 bits)
    asm_s_load_b64_off(9, 0, 0x40)              // s[18:19] = dt (s18 not 4-aligned)
    asm_u32(0xF40C0500); asm_u32(0xF8000048)    // s_load_b256 s[20:27], 0x48 (V_rest+V_reset+V_thresh+tau_m)
    asm_u32(0xF4080700); asm_u32(0xF8000068)    // s_load_b128 s[28:31], 0x68 (J_E+J_I)
    asm_s_load_b32(16, 0, 0x78)                 // s32 = ref_steps (low 32 bits)
    asm_s_waitcnt_lgkmcnt_zero()

    // ── Phase 3: outer bounds check (gid < n) ──
    asm_v_cmp_gt_u32_sgpr_vgpr(14, 1)           // vcc_lo = (s14 > v1)
    asm_s_and_saveexec_b32_vcc_lo(33)           // s33 = old EXEC; EXEC &= bounds
    uint64 outer_skip_off = asm_text_len / 4
    asm_s_cbranch_execz(0)                      // (placeholder, patched to s_endpgm)

    // Compute byte offsets used throughout:
    //   v2 = gid*8   (for u64/f64 strided arrays)
    //   v3 = gid     (for u8 fired array)
    asm_v_lshlrev_b32_imm(2, 3, 1)              // v2 = v1 << 3
    asm_v_mov_b32(3, 0x100 | 1)                 // v3 = v1
    asm_s_delay_alu(0x01)

    // ── Phase 4: unconditional fired[i] = 0 (only for active outer lanes) ──
    asm_v_mov_b32_inline_u(4, 0)                // v4 = 0
    asm_global_store_b8_saddr(3, 4, 16)         // store_b8 (s[16:17]+v3) = v4

    // ── Phase 5: load rc = ref[i] into v[12:13] ──
    asm_global_load_b64(12, 2, 4)               // v[12:13] = ref[gid]
    asm_s_waitcnt_vmcnt_zero()

    // ── Phase 6: refractory test (rc > 0) ──
    asm_v_cmp_lt_u64_imm0_vgpr_pair(12)         // vcc = (0 < rc) = (rc > 0)
    asm_s_and_saveexec_b32_vcc_lo(34)           // s34 = bounded EXEC; EXEC &= rc>0
    uint64 ref_then_skip_off = asm_text_len / 4
    asm_s_cbranch_execz(0)                      // (placeholder, patched to ref_else_label)

    // ── Phase 7: refractory body ──
    //   ref[i] = rc - 1 (u64 with carry chain)
    //   V[i]   = V_reset
    asm_v_add_co_u32_vcc_sv(12, 0xC1, 12)       // v12 = -1 + v12 (low, sets vcc)
    asm_v_add_co_ci_u32_null_sv_vcc(13, 0xC1, 13)  // v13 = -1 + v13 + carry-in
    asm_s_delay_alu(0x01)
    asm_global_store_b64(2, 12, 4)              // ref[gid] = v[12:13]

    // V[i] = V_reset:
    //   splat V_reset (s[22:23]) into v[10:11] via VOPD dual-mov
    //   (1 cycle for both halves instead of 2 sequential VALU ops).
    asm_v_dual_mov_b32_pair_sxsy(10, 22, 23)    // v[10:11] = s[22:23]
    asm_s_delay_alu(0x01)
    asm_global_store_b64(2, 10, 2)              // V[gid] = v[10:11]

    // ── Phase 8: flip EXEC to active branch (bounded ∩ rc==0) ──
    uint64 ref_else_label_off = asm_text_len / 4
    // Back-patch ref_then_skip's execz target → ref_else_label.
    uint64 ref_then_dwords = ref_else_label_off - (ref_then_skip_off + 1)
    uint64 ref_then_patch_byte = asm_text_buf + ref_then_skip_off * 4
    uint32 ref_then_word = 0xBFA50000 | (ref_then_dwords & 0xFFFF)
    unsafe { *(ref_then_patch_byte as uint32) = ref_then_word }
    // exec = exec ^ s34 = (bounded ∩ rc>0) ^ bounded = bounded ∩ rc==0
    asm_s_xor_b32_exec_sgpr(34)

    // Skip the active body if no lanes are active:
    uint64 active_skip_off = asm_text_len / 4
    asm_s_cbranch_execz(0)                      // (placeholder, patched to outer_end)

    // ── Phase 9: active body — load V, RI, se, si ──
    asm_global_load_b64(10, 2, 2)               // v[10:11] = V[gid]
    asm_global_load_b64(14, 2, 6)               // v[14:15] = RI[gid]
    asm_global_load_b64(16, 2, 8)               // v[16:17] = se[gid]
    asm_global_load_b64(18, 2, 10)              // v[18:19] = si[gid]
    asm_s_waitcnt_vmcnt_zero()

    // ── Phase 10: drive = ri + se*J_E - si*J_I ──
    //   v[20:21] = J_E*se + ri  (fma_f64_s_v_v with s_src=s[28:29], v1=v[16:17], v2=v[14:15])
    asm_v_fma_f64_s_v_v(20, 28, 16, 14)
    asm_s_delay_alu(0x01)
    //   v[20:21] = -J_I*si + drive
    asm_v_fma_f64_neg_s_v_v(20, 30, 18, 20)
    asm_s_delay_alu(0x01)

    // ── Phase 11: dv_num = (V_rest - V + drive) ──
    //   v[22:23] = V_rest + (-V) [V in v[10:11]]
    asm_v_add_f64_s_negv(22, 20, 10)            // s[20:21] = V_rest, -v[10:11] = -V
    asm_s_delay_alu(0x01)
    //   v[22:23] = (V_rest - V) + drive [drive in v[20:21]]
    asm_v_add_f64_vv(22, 22, 20)
    asm_s_delay_alu(0x01)

    // ── Phase 12: numerator = dt * dv_num ──
    //   Splat dt (s[18:19]) into v[14:15] via VOPD dual-mov, then v_mul_f64.
    asm_v_dual_mov_b32_pair_sxsy(14, 18, 19)    // v[14:15] = s[18:19] (dt)
    asm_s_delay_alu(0x01)
    asm_v_mul_f64_vv(22, 14, 22)                // v[22:23] = dt * dv_num

    // ── Phase 13: dv = numerator / tau_m ──
    //   Splat tau_m (s[26:27]) into v[14:15] via dual-mov (reuse the pair).
    asm_v_dual_mov_b32_pair_sxsy(14, 26, 27)    // v[14:15] = s[26:27] (tau_m)
    asm_s_delay_alu(0x01)
    //   IEEE-correct f64 div: scratch sd=v[16:17], sn=v[18:19],
    //   t=v[20:21], u=v[24:25]. Result in v[26:27].
    asm_lif_div_f64(22, 14, 26, 16, 18, 20, 24)

    // ── Phase 14: v_new = V + dv ──
    asm_v_add_f64_vv(28, 10, 26)                // v[28:29] = V + dv
    asm_s_delay_alu(0x01)

    // ── Phase 15: spike test (v_new >= V_thresh) ──
    //   Splat V_thresh (s[24:25]) into v[30:31] via dual-mov, then v_cmp_ge_f64_vv.
    asm_v_dual_mov_b32_pair_sxsy(30, 24, 25)    // v[30:31] = s[24:25] (V_thresh)
    asm_s_delay_alu(0x01)
    asm_v_cmp_ge_f64_vv(28, 30)                 // vcc = (v_new >= V_thresh)
    asm_s_and_saveexec_b32_vcc_lo(35)           // s35 = active EXEC; EXEC &= spike
    uint64 spike_then_skip_off = asm_text_len / 4
    asm_s_cbranch_execz(0)                      // (placeholder, patched to spike_else_label)

    // ── Phase 16: spike body ──
    //   V[i] = V_reset (dual-mov splat).
    asm_v_dual_mov_b32_pair_sxsy(10, 22, 23)    // v[10:11] = s[22:23] (V_reset)
    asm_s_delay_alu(0x01)
    asm_global_store_b64(2, 10, 2)              // V[gid] = V_reset
    //   ref[i] = ref_steps (u64 with high half = 0). Dual-mov: src_x =
    //   s32, src_y = inline-zero (0x80 in raw 9-bit src encoding).
    asm_v_dual_mov_b32_pair_sxsy(12, 32, 0x80)  // v12 = s32, v13 = 0
    asm_s_delay_alu(0x01)
    asm_global_store_b64(2, 12, 4)              // ref[gid] = ref_steps
    //   spike[i] += 1 (per-neuron, no race because i is unique)
    asm_global_load_b64(14, 2, 12)              // v[14:15] = spike[gid]
    asm_s_waitcnt_vmcnt_zero()
    asm_v_add_co_u32_vcc_sv(14, 0x81, 14)       // v14 = 1 + v14 (sets vcc carry)
    asm_v_add_co_ci_u32_null_sv_vcc(15, 0x80, 15)  // v15 = 0 + v15 + carry
    asm_s_delay_alu(0x01)
    asm_global_store_b64(2, 14, 12)             // spike[gid] = incremented
    //   fired[i] = 1
    asm_v_mov_b32_inline_u(4, 1)                // v4 = 1
    asm_global_store_b8_saddr(3, 4, 16)

    // ── Phase 17: flip to no-spike (active ∩ v_new < V_thresh) ──
    uint64 spike_else_label_off = asm_text_len / 4
    // Back-patch spike_then_skip → spike_else_label.
    uint64 spike_then_dwords = spike_else_label_off - (spike_then_skip_off + 1)
    uint64 spike_then_patch_byte = asm_text_buf + spike_then_skip_off * 4
    uint32 spike_then_word = 0xBFA50000 | (spike_then_dwords & 0xFFFF)
    unsafe { *(spike_then_patch_byte as uint32) = spike_then_word }
    asm_s_xor_b32_exec_sgpr(35)                 // exec = active ∩ no-spike

    // ── Phase 18: no-spike body: V[i] = v_new ──
    asm_global_store_b64(2, 28, 2)              // V[gid] = v_new

    // ── Phase 19: outer end ──
    uint64 outer_end_off = asm_text_len / 4
    // Back-patch outer execz (skip whole body if all lanes failed bounds).
    uint64 outer_dwords = outer_end_off - (outer_skip_off + 1)
    uint64 outer_patch_byte = asm_text_buf + outer_skip_off * 4
    uint32 outer_word = 0xBFA50000 | (outer_dwords & 0xFFFF)
    unsafe { *(outer_patch_byte as uint32) = outer_word }
    // Back-patch active execz (skip active body if all bounded lanes are refractory).
    uint64 active_dwords = outer_end_off - (active_skip_off + 1)
    uint64 active_patch_byte = asm_text_buf + active_skip_off * 4
    uint32 active_word = 0xBFA50000 | (active_dwords & 0xFFFF)
    unsafe { *(active_patch_byte as uint32) = active_word }
    asm_s_endpgm()

    // ── Args desc: 16 entries, all size=8. The first 7 are pointers
    //   (GLOBAL_BUFFER); n is BY_VALUE (u64); 7 f64s are BY_VALUE; the
    //   last (ref_steps) is BY_VALUE. ──
    uint64 args_desc = alloc(16 * 16)
    uint64 ai = 0
    while ai < 7 {                              // 7 pointers
        uint64 p0 = args_desc + ai * 16;     unsafe { *(p0 as uint64) = 8 }
        uint64 p1 = args_desc + ai * 16 + 8; unsafe { *(p1 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
        ai = ai + 1
    }
    while ai < 16 {                             // n + dt + V_rest + V_reset + V_thresh + tau_m + J_E + J_I + ref_steps = 9 by-values
        uint64 p0 = args_desc + ai * 16;     unsafe { *(p0 as uint64) = 8 }
        uint64 p1 = args_desc + ai * 16 + 8; unsafe { *(p1 as uint64) = AMD_ARG_KIND_BY_VALUE }
        ai = ai + 1
    }

    // Snapshot text into private buffer (asm_init clobbers asm_text_buf).
    uint64 k_text_size = asm_text_len
    uint64 k_text_buf  = alloc(k_text_size)
    uint64 ci = 0
    while ci < k_text_size {
        uint64 sp = asm_text_buf + ci
        uint64 b = 0
        unsafe { *(sp as uint8) -> b }
        uint64 dp = k_text_buf + ci
        uint8 b8 = b
        unsafe { *(dp as uint8) = b8 }
        ci = ci + 1
    }

    uint64 rsrc1 = 0xE0AF0003                   // VGPR granule=3 → 32 VGPRs
    uint64 rsrc2 = 0x0000009E
    uint64 rsrc3 = 0x00000010
    uint64 props = 0x0408

    // sgpr_count: s0..s35 = 36 SGPRs.
    kt_push(kname_ptr, nl, k_text_buf, k_text_size,
            args_desc, 16, 128,
            36, 32,
            rsrc1, rsrc2, rsrc3, props)
    return 0
}

// Phase 3a — pointwise binary-op kernels.
//
// First piece of the AST-walking @kernel compiler. Recognises the
// shape:
//
//   @kernel fn name(uint64 buf, uint64 n, f32 scalar) {
//       uint64 gid = block_idx_x() * 256 + tid_local_x()
//       if gid < n {
//           uint64 p = buf + gid * 4
//           f32 v = 0.0
//           unsafe { *(p as f32) -> v }
//           v = v <op> scalar           // op ∈ {*, +, -, /}
//           unsafe { *(p as f32) = v }
//       }
//   }
//
// The arithmetic is the only thing that varies — every other line is a
// fixed template. The recogniser checks structure (two top-level stmts,
// then five inside the if), extracts the operator from the BinOp's
// op-token, and emits the same prologue/epilogue + the operator-
// specific VOP2 instruction. Unlike the Phase 2 name-matched routers,
// this is not tied to any specific kernel name — it accepts any
// @kernel that fits the body shape.
//
// Returns 0 on success; non-zero means "doesn't match the 3a shape"
// and the caller should fall through to other recognisers.
fn amdgpu_lower_pointwise_3a(uint64 fn_node, uint64 source,
                              uint64 kname_ptr, uint64 nl) -> uint64 {
    // ── shape: 3 params ──────────────────────────────────────────
    uint64 n_params = 0
    uint64 wp = ast_child(fn_node)
    while wp != 0 {
        n_params = n_params + 1
        wp = ast_next(wp)
    }
    if n_params != 2 && n_params != 3 { return 1 }

    // ── shape: body has Block, Block has 2 stmts (gid_decl, if) ──
    // FnDecl.body lives in data3 (not next, despite the AstKind comment).
    uint32 body = ast_data3(fn_node)
    if body == 0 { return 1 }
    if ast_kind(body) != 15 { return 1 }   // 15 = Block
    uint32 stmt0 = ast_child(body)
    if stmt0 == 0 { return 1 }
    if ast_kind(stmt0) != 10 { return 1 }  // 10 = VarDecl (gid)
    uint32 stmt1 = ast_next(stmt0)
    if stmt1 == 0 { return 1 }
    if ast_kind(stmt1) != 13 { return 1 }  // 13 = If
    if ast_next(stmt1) != 0 { return 1 }

    // ── shape: if-then has Block with 5 stmts ────────────────────
    uint32 then_block = ast_data1(stmt1)
    if then_block == 0 { return 1 }
    if ast_kind(then_block) != 15 { return 1 }
    uint32 ts0 = ast_child(then_block)
    if ts0 == 0 { return 1 }
    if ast_kind(ts0) != 10 { return 1 }   // VarDecl p
    uint32 ts1 = ast_next(ts0)
    if ts1 == 0 || ast_kind(ts1) != 10 { return 1 }   // VarDecl v
    uint32 ts2 = ast_next(ts1)
    if ts2 == 0 || ast_kind(ts2) != 41 { return 1 }   // PtrLoad
    uint32 ts3 = ast_next(ts2)
    if ts3 == 0 || ast_kind(ts3) != 11 { return 1 }   // Assign v = ...
    uint32 ts4 = ast_next(ts3)
    if ts4 == 0 || ast_kind(ts4) != 42 { return 1 }   // PtrStore
    if ast_next(ts4) != 0 { return 1 }

    // PtrLoad / PtrStore must be f32 (fkind=2, type_size=4).
    if ast_data1(ts2) != 4 { return 1 }
    if ast_data3(ts2) != 2 { return 1 }
    if ast_data1(ts4) != 4 { return 1 }
    if ast_data3(ts4) != 2 { return 1 }

    // The Assign value is either:
    //   (a) BinOp(Ident(v), Ident(scalar))           — needs 3 params
    //   (b) Call(intrinsic, Ident(v))                — needs 2 params
    // We branch on the AST kind. op_kind / unary_op encode which family.
    //   op_kind = 0    → unary  (1 = relu_f32, 2 = exp2_f32)
    //   op_kind > 0    → binary (22=*, 30=+, 31=-, 32=/)
    uint32 assign_val = ast_child(ts3)
    if assign_val == 0 { return 1 }
    uint64 op_kind = 0       // 0 means "unary"
    uint64 unary_id = 0      // 1=relu, 2=exp2 (only valid when op_kind==0)
    uint32 av_kind = ast_kind(assign_val)
    if av_kind == 33 {
        // BinOp branch — must be 3-param shape.
        if n_params != 3 { return 1 }
        uint32 op_tok = ast_data1(assign_val)
        uint64 ok = tok_kind_at_raw(op_tok)
        if ok != 22 && ok != 30 && ok != 31 && ok != 32 { return 1 }
        op_kind = ok
        uint32 lhs = ast_child(assign_val)
        uint32 rhs = ast_data2(assign_val)
        if lhs == 0 || rhs == 0 { return 1 }
        if ast_kind(lhs) != 32 || ast_kind(rhs) != 32 { return 1 }   // both Idents
        // rhs ident must name the 3rd param.
        uint32 p0_b = ast_child(fn_node)
        uint32 p1_b = ast_next(p0_b)
        uint32 p2_b = ast_next(p1_b)
        uint32 p2_name = ast_data2(p2_b)
        uint32 rhs_tok = ast_data1(rhs)
        if tok_text_eq(rhs_tok, p2_name) == 0 { return 1 }
    } else if av_kind == 35 {
        // Call branch — must be 2-param shape, callee in {relu_f32, exp2_f32}.
        if n_params != 2 { return 1 }
        uint32 callee = ast_data1(assign_val)
        if tok_matches(callee, "relu_f32", 8) != 0 { unary_id = 1 }
        else if tok_matches(callee, "exp2_f32", 8) != 0 { unary_id = 2 }
        else { return 1 }
        // Single Ident arg.
        uint32 arg0 = ast_child(assign_val)
        if arg0 == 0 || ast_kind(arg0) != 32 { return 1 }
        if ast_next(arg0) != 0 { return 1 }
    } else {
        return 1
    }

    // ── emit ISA ─────────────────────────────────────────────────
    // gid lives entirely in 32-bit v1; the saveexec dance mirrors
    // gemv's pattern with v_cmpx (compare-and-set-exec) so we don't
    // depend on v1's high half being zero (it isn't, on gfx11 wave32
    // — only X workitem id is auto-loaded, so v1 holds garbage on
    // entry). v_mul_lo_u32 + v_add_nc_u32 keep everything 32-bit.
    asm_init()
    asm_u32(0xF4080100); asm_u32(0xF8000000)   // s_load_b128 s[4:7], s[0:1], 0x0
    if n_params == 3 {
        asm_u32(0xF4000200); asm_u32(0xF8000010) // s_load_b32 s8, s[0:1], 0x10 (binary scalar)
    }
    asm_u32(0xBF89FC07)                         // s_waitcnt   lgkmcnt(0)
    asm_u32(0xBE8900FF); asm_u32(0x00000100)   // s_mov_b32   s9, 0x100 (=256)
    asm_u32(0xD72C0001); asm_u32(0x0000120F)   // v_mul_lo_u32 v1, s15, s9 (wg_id_x lives at s15 with USER_SGPR_COUNT=15)
    asm_u32(0x4A020300)                         // v_add_nc_u32_e32 v1, v0, v1  (tid_x + wgid*256)
    asm_u32(0xBE89007E)                         // s_mov_b32   s9, exec_lo
    asm_u32(0x7C980206)                         // v_cmp_gt_u32_e32 vcc_lo, s6, v1
    asm_u32(0x8B7E6A7E)                         // s_and_b32   exec_lo, exec_lo, vcc_lo
    asm_u32(0xBFA5000D)                         // s_cbranch_execz +13 → .Lend
    asm_u32(0x30040282)                         // v_lshlrev_b32_e32 v2, 2, v1  (gid*4 lo)
    asm_u32(0x7E060280)                         // v_mov_b32_e32 v3, 0          (gid*4 hi)
    asm_u32(0xD7006A02); asm_u32(0x00020404)   // v_add_co_u32 v2, vcc_lo, s4, v2
    asm_u32(0xD5207C03); asm_u32(0x01AA0605)   // v_add_co_ci_u32_e64 v3, null, s5, v3, vcc_lo
    asm_u32(0xDC520000); asm_u32(0x057C0002)   // global_load_b32 v5, v[2:3], off
    asm_u32(0xBF8903F7)                         // s_waitcnt vmcnt(0)
    // Operator-specific VOP2 (e32, src0=s8 = scalar param, dst=src1=v5):
    //   v_mul_f32_e32 v5, s8, v5  → 0x100A0A08   (op 0x08)
    //   v_add_f32_e32 v5, s8, v5  → 0x060A0A08   (op 0x03)
    //   v_sub_f32_e32 v5, s8, v5  → 0x080A0A08   (op 0x04)  // s8 - v5
    //   v_div_scale_f32 isn't used; for /: emit reciprocal + multiply
    //
    // VOP2 e32 layout: bits 31:25=0x0 (VOP2 prefix not strictly 0; the
    // top byte encodes opcode). Actually the encoding is just opcode*2
    // followed by the operands. The high byte for v_mul_f32_e32 is
    // 0x10, for v_add 0x06, for v_sub 0x08.
    if op_kind == 22 {
        asm_u32(0x100A0A08)                     // v_mul_f32_e32 v5, s8, v5
    } else if op_kind == 30 {
        asm_u32(0x060A0A08)                     // v_add_f32_e32 v5, s8, v5
    } else if op_kind == 31 {
        asm_u32(0x080A0A08)                     // v_sub_f32_e32 v5, s8, v5
    } else if op_kind == 32 {
        // op_kind == 32: division. v_div_f32 isn't a single op on
        // gfx11. Use v_rcp_f32 v6, s8 then v_mul_f32 v5, v5, v6.
        asm_u32(0xD5A50006); asm_u32(0x00000008) // v_rcp_f32_e64 v6, s8
        asm_u32(0x100A0B06)                     // v_mul_f32_e32 v5, v6, v5
    } else if unary_id == 1 {
        // relu_f32(v) = max(0, v)
        asm_u32(0x200A0A80)                     // v_max_f32_e32 v5, 0, v5
    } else {
        // unary_id == 2: exp2_f32(v) = 2^v (raw v_exp_f32)
        asm_u32(0x7E0A4B05)                     // v_exp_f32_e32 v5, v5
    }
    asm_u32(0xDC6A0000); asm_u32(0x007C0502)   // global_store_b32 v[2:3], v5, off
    asm_u32(0xBC7C0000)                         // s_waitcnt_vscnt null, 0
    asm_u32(0xBFB00000)                         // s_endpgm

    // ── kernarg layout: 2 or 3 args of 8 bytes ───────────────────
    uint64 args_desc = alloc(6 * 16)
    uint64 a0 = args_desc + 0;   unsafe { *(a0 as uint64) = 8 }
    uint64 a1 = args_desc + 8;   unsafe { *(a1 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a2 = args_desc + 16;  unsafe { *(a2 as uint64) = 8 }
    uint64 a3 = args_desc + 24;  unsafe { *(a3 as uint64) = AMD_ARG_KIND_BY_VALUE }
    if n_params == 3 {
        uint64 a4 = args_desc + 32;  unsafe { *(a4 as uint64) = 8 }
        uint64 a5 = args_desc + 40;  unsafe { *(a5 as uint64) = AMD_ARG_KIND_BY_VALUE }
    }
    uint64 kernarg_size = 16
    if n_params == 3 { kernarg_size = 24 }

    // Snapshot ISA before the next kernel's asm_init() can clobber it.
    uint64 k_text_size = asm_text_len
    uint64 k_text_buf  = alloc(k_text_size)
    uint64 ci = 0
    while ci < k_text_size {
        uint64 sp = asm_text_buf + ci
        uint64 b = 0
        unsafe { *(sp as uint8) -> b }
        uint64 dp = k_text_buf + ci
        uint8 b8 = b
        unsafe { *(dp as uint8) = b8 }
        ci = ci + 1
    }

    // rsrc1 vgpr_granulated=1 → 16 VGPRs (kernel uses v0..v6 = 7;
    // 8 alloc would suffice but matches gemv N1 setting which also
    // works under the auto governor).
    // sgpr_granulated=1 → 16 SGPRs (kernel uses s0..s9 = 10).
    uint64 rsrc1 = 0xE0AF0041
    uint64 rsrc2 = 0x0000009E
    uint64 rsrc3 = 0x00000010
    uint64 props = 0x0408

    kt_push(kname_ptr, nl, k_text_buf, k_text_size,
            args_desc, n_params, kernarg_size,
            10, 7,
            rsrc1, rsrc2, rsrc3, props)
    return 0
}

// Phase 3a-2 — two-input pointwise binary-op kernels.
//
// Recognises the shape:
//
//   @kernel fn name(uint64 a_ptr, uint64 b_ptr, uint64 out_ptr, uint64 n) {
//       uint64 gid = block_idx_x() * 256 + tid_local_x()
//       if gid < n {
//           uint64 ap = a_ptr  + gid * 4
//           uint64 bp = b_ptr  + gid * 4
//           uint64 op = out_ptr + gid * 4
//           f32 a = 0.0
//           unsafe { *(ap as f32) -> a }
//           f32 b = 0.0
//           unsafe { *(bp as f32) -> b }
//           f32 r = a + b              // op ∈ {+, -, *}
//           unsafe { *(op as f32) = r }
//       }
//   }
//
// Replaces the legacy hand-tuned _emit_residual_add_f32_body with
// compiler-emitted ISA.  ISA template lifted from that body (33 dwords;
// the operator-specific dword is the only thing that varies per op).
//
// Returns 0 on success; non-zero means "doesn't match the 3a-2 shape".
fn amdgpu_lower_pointwise_2in_3a(uint64 fn_node, uint64 source,
                                  uint64 kname_ptr, uint64 nl) -> uint64 {
    // ── shape: 4 params (a_ptr, b_ptr, out_ptr, n) ──────────────
    uint64 n_params = 0
    uint64 wp = ast_child(fn_node)
    while wp != 0 {
        n_params = n_params + 1
        wp = ast_next(wp)
    }
    if n_params != 4 { return 1 }

    // Snapshot param name tokens.
    uint32 p0 = ast_child(fn_node)
    uint32 p1 = ast_next(p0)
    uint32 p2 = ast_next(p1)
    uint32 p3 = ast_next(p2)
    uint32 p0_name = ast_data2(p0)
    uint32 p1_name = ast_data2(p1)
    uint32 p2_name = ast_data2(p2)
    uint32 p3_name = ast_data2(p3)

    // ── shape: body Block has 2 stmts (gid VarDecl + If) ────────
    uint32 body = ast_data3(fn_node)
    if body == 0 { return 1 }
    if ast_kind(body) != 15 { return 1 }
    uint32 stmt0 = ast_child(body)
    if stmt0 == 0 || ast_kind(stmt0) != 10 { return 1 }
    uint32 stmt1 = ast_next(stmt0)
    if stmt1 == 0 || ast_kind(stmt1) != 13 { return 1 }
    if ast_next(stmt1) != 0 { return 1 }

    // ── if-then-block has 9 stmts in canonical order ────────────
    uint32 then_block = ast_data1(stmt1)
    if then_block == 0 || ast_kind(then_block) != 15 { return 1 }
    uint32 t0 = ast_child(then_block)
    if t0 == 0 || ast_kind(t0) != 10 { return 1 }
    uint32 t1 = ast_next(t0)
    if t1 == 0 || ast_kind(t1) != 10 { return 1 }
    uint32 t2 = ast_next(t1)
    if t2 == 0 || ast_kind(t2) != 10 { return 1 }
    uint32 t3 = ast_next(t2)
    if t3 == 0 || ast_kind(t3) != 10 { return 1 }
    uint32 t4 = ast_next(t3)
    if t4 == 0 || ast_kind(t4) != 41 { return 1 }
    uint32 t5 = ast_next(t4)
    if t5 == 0 || ast_kind(t5) != 10 { return 1 }
    uint32 t6 = ast_next(t5)
    if t6 == 0 || ast_kind(t6) != 41 { return 1 }
    uint32 t7 = ast_next(t6)
    if t7 == 0 || ast_kind(t7) != 10 { return 1 }
    uint32 t8 = ast_next(t7)
    if t8 == 0 || ast_kind(t8) != 42 { return 1 }
    if ast_next(t8) != 0 { return 1 }

    // PtrLoads / PtrStore must be f32 (fkind=2, type_size=4).
    if ast_data1(t4) != 4 { return 1 }
    if ast_data3(t4) != 2 { return 1 }
    if ast_data1(t6) != 4 { return 1 }
    if ast_data3(t6) != 2 { return 1 }
    if ast_data1(t8) != 4 { return 1 }
    if ast_data3(t8) != 2 { return 1 }

    // Names of the f32 temps (a, b, r).
    uint32 a_name = ast_data2(t3)
    uint32 b_name = ast_data2(t5)
    uint32 r_name = ast_data2(t7)

    // PtrStore (kind 42): data1=size, child=addr_expr, data2=val_expr.
    // Value lives in data2; the address (child) is the `op` Ident.
    uint32 store_val = ast_data2(t8)
    if store_val == 0 || ast_kind(store_val) != 32 { return 1 }
    if tok_text_eq(ast_data1(store_val), r_name) == 0 { return 1 }

    // r's init must be BinOp(Ident(a_name), Ident(b_name)) with op ∈ {+, -, *}.
    uint32 r_init = ast_child(t7)
    if r_init == 0 || ast_kind(r_init) != 33 { return 1 }
    uint32 op_tok = ast_data1(r_init)
    uint64 ok = tok_kind_at_raw(op_tok)
    if ok != 22 && ok != 30 && ok != 31 { return 1 }
    uint64 op_kind = ok
    uint32 lhs = ast_child(r_init)
    uint32 rhs = ast_data2(r_init)
    if lhs == 0 || rhs == 0 { return 1 }
    if ast_kind(lhs) != 32 || ast_kind(rhs) != 32 { return 1 }
    if tok_text_eq(ast_data1(lhs), a_name) == 0 { return 1 }
    if tok_text_eq(ast_data1(rhs), b_name) == 0 { return 1 }

    // ── emit ISA ─────────────────────────────────────────────────
    // Template ported verbatim from _emit_residual_add_f32_body
    // (commit 11075-11119 of format_amdgpu.mlr).  USER_SGPR_COUNT=15;
    // s_load_b256 pulls all 4 args; v1 = wgid*256 + tid_x; bounds check
    // via v_cmp_gt_u32 + s_and_saveexec; per-pointer base+offset compute
    // from gid*4; two global_load_b32; one VOP2 op; global_store_b32.
    // Dword pairs (gfx11, gfx10) verified via llvm-mc on the exact
    // instruction stream of residual_add_f32. Same kernel semantics,
    // different ISA encoding. gfx11 is the established bit-exact path.
    asm_init()
    asm_u32_arch(0xF40C0100, 0xF40C0100); asm_u32_arch(0xF8000000, 0xFA000000) // s_load_b256/dwordx8 s[4:11], s[0:1], 0x0
    asm_u32_arch(0xBF89FC07, 0xBF8CC07F)            // s_waitcnt   lgkmcnt(0)
    asm_u32_arch(0x840C880F, 0x8F0C880F)            // s_lshl_b32  s12, s15, 8
    asm_u32     (0x4A02000C)                        // v_add_nc_u32 v1, s12, v0  (same encoding)
    asm_u32_arch(0x7C98020A, 0x7D88020A)            // v_cmp_gt_u32 vcc_lo, s10, v1
    asm_u32_arch(0xBE8D206A, 0xBE8D3C6A)            // s_and_saveexec_b32 s13, vcc_lo
    asm_u32_arch(0xBFA50019, 0xBF880019)            // s_cbranch_execz +25 → endpgm
    asm_u32_arch(0x30100282, 0x34100282)            // v_lshlrev_b32 v8, 2, v1
    asm_u32     (0x7E060280)                        // v_mov_b32    v3, 0  (same)
    asm_u32_arch(0xD7006A02, 0xD70F6A02); asm_u32(0x00021004) // v_add_co_u32 v2, vcc_lo, s4, v8
    asm_u32_arch(0xD5207C03, 0xD5287D03); asm_u32(0x01AA0605) // v_add_co_ci_u32 v3, null, s5, v3, vcc_lo
    asm_u32     (0x7E0A0280)                        // v_mov_b32    v5, 0
    asm_u32_arch(0xD7006A04, 0xD70F6A04); asm_u32(0x00021006) // v_add_co_u32 v4, vcc_lo, s6, v8
    asm_u32_arch(0xD5207C05, 0xD5287D05); asm_u32(0x01AA0A07) // v_add_co_ci_u32 v5, null, s7, v5, vcc_lo
    asm_u32     (0x7E0E0280)                        // v_mov_b32    v7, 0
    asm_u32_arch(0xD7006A06, 0xD70F6A06); asm_u32(0x00021008) // v_add_co_u32 v6, vcc_lo, s8, v8
    asm_u32_arch(0xD5207C07, 0xD5287D07); asm_u32(0x01AA0E09) // v_add_co_ci_u32 v7, null, s9, v7, vcc_lo
    asm_u32_arch(0xDC520000, 0xDC308000); asm_u32_arch(0x097C0002, 0x097D0002) // global_load_b32 v9,  v[2:3]
    asm_u32_arch(0xDC520000, 0xDC308000); asm_u32_arch(0x0A7C0004, 0x0A7D0004) // global_load_b32 v10, v[4:5]
    asm_u32_arch(0xBF8903F7, 0xBF8C3F70)            // s_waitcnt vmcnt(0)
    // Operator-specific VOP2 e32 — v_add/sub/mul_f32 ops are unchanged
    // between gfx10 and gfx11.
    if op_kind == 30 {
        asm_u32(0x06121509)                         // v_add_f32
    } else if op_kind == 31 {
        asm_u32(0x08121509)                         // v_sub_f32 (a - b)
    } else {
        asm_u32(0x10121509)                         // v_mul_f32
    }
    asm_u32_arch(0xDC6A0000, 0xDC708000); asm_u32_arch(0x007C0906, 0x007D0906) // global_store_b32 v[6:7], v9
    asm_u32_arch(0xBC7C0000, 0xBBFD0000)            // s_waitcnt_vscnt null, 0
    asm_u32_arch(0xBFB00000, 0xBF810000)            // s_endpgm

    // ── kernarg layout: 4 args × 16 bytes each ───────────────────
    uint64 args_desc = alloc(8 * 16)
    uint64 a0 = args_desc +  0;  unsafe { *(a0 as uint64) = 8 }
    uint64 a1 = args_desc +  8;  unsafe { *(a1 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a2 = args_desc + 16;  unsafe { *(a2 as uint64) = 8 }
    uint64 a3 = args_desc + 24;  unsafe { *(a3 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a4 = args_desc + 32;  unsafe { *(a4 as uint64) = 8 }
    uint64 a5 = args_desc + 40;  unsafe { *(a5 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a6 = args_desc + 48;  unsafe { *(a6 as uint64) = 8 }
    uint64 a7 = args_desc + 56;  unsafe { *(a7 as uint64) = AMD_ARG_KIND_BY_VALUE }
    uint64 kernarg_size = 32

    // Snapshot ISA before next asm_init() can clobber it.
    uint64 k_text_size = asm_text_len
    uint64 k_text_buf  = alloc(k_text_size)
    uint64 ci = 0
    while ci < k_text_size {
        uint64 sp = asm_text_buf + ci
        uint64 b = 0
        unsafe { *(sp as uint8) -> b }
        uint64 dp = k_text_buf + ci
        uint8 b8 = b
        unsafe { *(dp as uint8) = b8 }
        ci = ci + 1
    }

    // KD identical to the legacy hand-tuned residual_add_f32 emit:
    // 16 SGPRs / 11 VGPRs, USER_SGPR_COUNT=15 (rsrc2=0x9E), no LDS,
    // rsrc1=0xE0AF0001 (vgpr_grant=0 → ≤8 VGPRs in 8-step bins; 11
    // rounds to 16 alloc).
    uint64 rsrc1 = 0xE0AF0001
    uint64 rsrc2 = 0x0000009E
    uint64 rsrc3 = 0x00000010
    uint64 props = 0x0408

    kt_push(kname_ptr, nl, k_text_buf, k_text_size,
            args_desc, 4, kernarg_size,
            16, 11,
            rsrc1, rsrc2, rsrc3, props)
    return 0
}

// Phase 3a-3 — silu(a) * b pointwise (SwiGLU element-wise op).
//
// Recognises the shape:
//
//   @kernel fn name(uint64 gate_ptr, uint64 up_ptr, uint64 out_ptr, uint64 n) {
//       uint64 gid = block_idx_x() * 256 + tid_local_x()
//       if gid < n {
//           uint64 gp = gate_ptr + gid * 4
//           uint64 up = up_ptr   + gid * 4
//           uint64 op = out_ptr  + gid * 4
//           f32 g = 0.0
//           unsafe { *(gp as f32) -> g }
//           f32 u = 0.0
//           unsafe { *(up as f32) -> u }
//           f32 sg = silu_f32(g)
//           f32 r  = sg * u
//           unsafe { *(op as f32) = r }
//       }
//   }
//
// Replaces the legacy hand-tuned _emit_silu_mul_f32_body with
// compiler-emitted ISA.  ISA template lifted verbatim (41 dwords).
// silu(x) = x / (1 + exp(-x)) is implemented as the standard 6-op
// composer: log2e mov, e64 mul, v_exp, +1.0, v_rcp, mul-back-to-x.
//
// Returns 0 on success; non-zero means "doesn't match the 3a-3 shape".
fn amdgpu_lower_silu_mul_3a(uint64 fn_node, uint64 source,
                             uint64 kname_ptr, uint64 nl) -> uint64 {
    // ── shape: 4 params (gate_ptr, up_ptr, out_ptr, n) ─────────
    uint64 n_params = 0
    uint64 wp = ast_child(fn_node)
    while wp != 0 {
        n_params = n_params + 1
        wp = ast_next(wp)
    }
    if n_params != 4 { return 1 }

    // ── shape: body Block has 2 stmts (gid VarDecl + If) ────────
    uint32 body = ast_data3(fn_node)
    if body == 0 { return 1 }
    if ast_kind(body) != 15 { return 1 }
    uint32 stmt0 = ast_child(body)
    if stmt0 == 0 || ast_kind(stmt0) != 10 { return 1 }
    uint32 stmt1 = ast_next(stmt0)
    if stmt1 == 0 || ast_kind(stmt1) != 13 { return 1 }
    if ast_next(stmt1) != 0 { return 1 }

    // ── if-then-block has 10 stmts in canonical order ──────────
    uint32 then_block = ast_data1(stmt1)
    if then_block == 0 || ast_kind(then_block) != 15 { return 1 }
    uint32 t0 = ast_child(then_block)
    if t0 == 0 || ast_kind(t0) != 10 { return 1 }   // VarDecl gp
    uint32 t1 = ast_next(t0)
    if t1 == 0 || ast_kind(t1) != 10 { return 1 }   // VarDecl up
    uint32 t2 = ast_next(t1)
    if t2 == 0 || ast_kind(t2) != 10 { return 1 }   // VarDecl op
    uint32 t3 = ast_next(t2)
    if t3 == 0 || ast_kind(t3) != 10 { return 1 }   // VarDecl g (f32)
    uint32 t4 = ast_next(t3)
    if t4 == 0 || ast_kind(t4) != 41 { return 1 }   // PtrLoad → g
    uint32 t5 = ast_next(t4)
    if t5 == 0 || ast_kind(t5) != 10 { return 1 }   // VarDecl u (f32)
    uint32 t6 = ast_next(t5)
    if t6 == 0 || ast_kind(t6) != 41 { return 1 }   // PtrLoad → u
    uint32 t7 = ast_next(t6)
    if t7 == 0 || ast_kind(t7) != 10 { return 1 }   // VarDecl sg = silu_f32(g)
    uint32 t8 = ast_next(t7)
    if t8 == 0 || ast_kind(t8) != 10 { return 1 }   // VarDecl r  = sg * u
    uint32 t9 = ast_next(t8)
    if t9 == 0 || ast_kind(t9) != 42 { return 1 }   // PtrStore op = r
    if ast_next(t9) != 0 { return 1 }

    // PtrLoads / PtrStore must be f32.
    if ast_data1(t4) != 4 || ast_data3(t4) != 2 { return 1 }
    if ast_data1(t6) != 4 || ast_data3(t6) != 2 { return 1 }
    if ast_data1(t9) != 4 || ast_data3(t9) != 2 { return 1 }

    // f32 temp names.
    uint32 g_name  = ast_data2(t3)
    uint32 u_name  = ast_data2(t5)
    uint32 sg_name = ast_data2(t7)
    uint32 r_name  = ast_data2(t8)

    // sg's init must be Call(silu_f32, Ident(g_name)).
    uint32 sg_init = ast_child(t7)
    if sg_init == 0 || ast_kind(sg_init) != 35 { return 1 }
    uint32 sg_callee = ast_data1(sg_init)
    if tok_matches(sg_callee, "silu_f32", 8) == 0 { return 1 }
    uint32 sg_arg = ast_child(sg_init)
    if sg_arg == 0 || ast_kind(sg_arg) != 32 { return 1 }
    if ast_next(sg_arg) != 0 { return 1 }
    if tok_text_eq(ast_data1(sg_arg), g_name) == 0 { return 1 }

    // r's init must be BinOp(*, Ident(sg_name), Ident(u_name)).
    uint32 r_init = ast_child(t8)
    if r_init == 0 || ast_kind(r_init) != 33 { return 1 }
    uint32 op_tok = ast_data1(r_init)
    uint64 ok = tok_kind_at_raw(op_tok)
    if ok != 22 { return 1 }   // 22 = *
    uint32 lhs = ast_child(r_init)
    uint32 rhs = ast_data2(r_init)
    if lhs == 0 || rhs == 0 { return 1 }
    if ast_kind(lhs) != 32 || ast_kind(rhs) != 32 { return 1 }
    if tok_text_eq(ast_data1(lhs), sg_name) == 0 { return 1 }
    if tok_text_eq(ast_data1(rhs), u_name) == 0 { return 1 }

    // PtrStore (kind 42): value lives in data2 (child is the addr).
    uint32 store_val = ast_data2(t9)
    if store_val == 0 || ast_kind(store_val) != 32 { return 1 }
    if tok_text_eq(ast_data1(store_val), r_name) == 0 { return 1 }

    // ── emit ISA ─────────────────────────────────────────────────
    // 41-dword sequence ported verbatim from _emit_silu_mul_f32_body.
    // Differs from residual_add_f32's 33-dword emit only in:
    //   • s_cbranch_execz +33 (vs +25) — extends past the SiLU composer
    //   • SiLU composer (8 dwords) inserted between loads and final mul
    //   • final dword v_mul_f32 v9, v9, v10 (vs v_add)
    // gfx10/gfx11 dword pairs follow the patterns established in
    // residual_add and silu_f32; same opcode-shift table.
    asm_init()
    asm_u32_arch(0xF40C0100, 0xF40C0100); asm_u32_arch(0xF8000000, 0xFA000000) // s_load_b256/dwordx8 s[4:11], s[0:1], 0x0
    asm_u32_arch(0xBF89FC07, 0xBF8CC07F)            // s_waitcnt   lgkmcnt(0)
    asm_u32_arch(0x840C880F, 0x8F0C880F)            // s_lshl_b32  s12, s15, 8
    asm_u32     (0x4A02000C)                        // v_add_nc_u32 v1, s12, v0
    asm_u32_arch(0x7C98020A, 0x7D88020A)            // v_cmp_gt_u32 vcc_lo, s10, v1
    asm_u32_arch(0xBE8D206A, 0xBE8D3C6A)            // s_and_saveexec_b32 s13, vcc_lo
    asm_u32_arch(0xBFA50021, 0xBF880021)            // s_cbranch_execz +33 → endpgm
    asm_u32_arch(0x30100282, 0x34100282)            // v_lshlrev_b32 v8, 2, v1
    asm_u32     (0x7E060280)                        // v_mov_b32   v3, 0
    asm_u32_arch(0xD7006A02, 0xD70F6A02); asm_u32(0x00021004) // v_add_co_u32  v2, vcc_lo, s4, v8
    asm_u32_arch(0xD5207C03, 0xD5287D03); asm_u32(0x01AA0605) // v_add_co_ci_u32 v3, null, s5, v3, vcc_lo
    asm_u32     (0x7E0A0280)                        // v_mov_b32   v5, 0
    asm_u32_arch(0xD7006A04, 0xD70F6A04); asm_u32(0x00021006) // v_add_co_u32  v4, vcc_lo, s6, v8
    asm_u32_arch(0xD5207C05, 0xD5287D05); asm_u32(0x01AA0A07) // v_add_co_ci_u32 v5, null, s7, v5, vcc_lo
    asm_u32     (0x7E0E0280)                        // v_mov_b32   v7, 0
    asm_u32_arch(0xD7006A06, 0xD70F6A06); asm_u32(0x00021008) // v_add_co_u32  v6, vcc_lo, s8, v8
    asm_u32_arch(0xD5207C07, 0xD5287D07); asm_u32(0x01AA0E09) // v_add_co_ci_u32 v7, null, s9, v7, vcc_lo
    asm_u32_arch(0xDC520000, 0xDC308000); asm_u32_arch(0x097C0002, 0x097D0002) // global_load_b32 v9,  v[2:3], off
    asm_u32_arch(0xDC520000, 0xDC308000); asm_u32_arch(0x0A7C0004, 0x0A7D0004) // global_load_b32 v10, v[4:5], off
    asm_u32_arch(0xBF8903F7, 0xBF8C3F70)            // s_waitcnt vmcnt(0)
    // SiLU composer (silu(g) materialised in v9). VOP1/VOP2 ops
    // unchanged; s_mov_b32 imm SOP1 op shifts, v_mul_f32_e64 omod-bit
    // clears on gfx10.
    asm_u32_arch(0xBE8C00FF, 0xBE8C03FF); asm_u32(0x3FB8AA3B) // s_mov_b32 s12, log2(e) = 0x3FB8AA3B
    asm_u32     (0xD508000B); asm_u32_arch(0x20001909, 0x00001909) // v_mul_f32_e64 v11, v9, s12
    asm_u32     (0x7E164B0B)                        // v_exp_f32   v11, v11
    asm_u32     (0x061616F2)                        // v_add_f32   v11, 1.0, v11
    asm_u32     (0x7E16550B)                        // v_rcp_f32   v11, v11
    asm_u32     (0x10121709)                        // v_mul_f32   v9, v9, v11   (silu(g))
    // Final mul: silu(g) * u → v9.
    asm_u32     (0x10121509)                        // v_mul_f32   v9, v9, v10
    asm_u32_arch(0xDC6A0000, 0xDC708000); asm_u32_arch(0x007C0906, 0x007D0906) // global_store_b32 v[6:7], v9, off
    asm_u32_arch(0xBC7C0000, 0xBBFD0000)            // s_waitcnt_vscnt null, 0
    asm_u32_arch(0xBFB00000, 0xBF810000)            // s_endpgm

    // ── kernarg layout: 4 args × 16 bytes ────────────────────────
    uint64 args_desc = alloc(8 * 16)
    uint64 a0 = args_desc +  0;  unsafe { *(a0 as uint64) = 8 }
    uint64 a1 = args_desc +  8;  unsafe { *(a1 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a2 = args_desc + 16;  unsafe { *(a2 as uint64) = 8 }
    uint64 a3 = args_desc + 24;  unsafe { *(a3 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a4 = args_desc + 32;  unsafe { *(a4 as uint64) = 8 }
    uint64 a5 = args_desc + 40;  unsafe { *(a5 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a6 = args_desc + 48;  unsafe { *(a6 as uint64) = 8 }
    uint64 a7 = args_desc + 56;  unsafe { *(a7 as uint64) = AMD_ARG_KIND_BY_VALUE }

    // Snapshot ISA before next asm_init().
    uint64 k_text_size = asm_text_len
    uint64 k_text_buf  = alloc(k_text_size)
    uint64 ci = 0
    while ci < k_text_size {
        uint64 sp = asm_text_buf + ci
        uint64 b = 0
        unsafe { *(sp as uint8) -> b }
        uint64 dp = k_text_buf + ci
        uint8 b8 = b
        unsafe { *(dp as uint8) = b8 }
        ci = ci + 1
    }

    // KD identical to the legacy hand-tuned silu_mul_f32 emit: 16
    // SGPRs / 12 VGPRs, USER_SGPR_COUNT=15, no LDS, rsrc1=0xE0AF0001.
    uint64 rsrc1 = 0xE0AF0001
    uint64 rsrc2 = 0x0000009E
    uint64 rsrc3 = 0x00000010
    uint64 props = 0x0408

    kt_push(kname_ptr, nl, k_text_buf, k_text_size,
            args_desc, 4, 32,
            16, 12,
            rsrc1, rsrc2, rsrc3, props)
    return 0
}

// Phase 3a-5 — silu_f32 single-buffer pointwise (Swish y = silu(x)).
//
// Recognises the shape:
//
//   @kernel fn name(uint64 in_ptr, uint64 out_ptr, uint64 n) {
//       uint64 gid = block_idx_x() * 256 + tid_local_x()
//       if gid < n {
//           uint64 ip = in_ptr  + gid * 4
//           uint64 op = out_ptr + gid * 4
//           f32 x = 0.0
//           unsafe { *(ip as f32) -> x }
//           f32 r = silu_f32(x)
//           unsafe { *(op as f32) = r }
//       }
//   }
//
// Replaces the legacy hand-tuned `_emit_silu_f32_body` (33 dwords).
//
// Returns 0 on success; non-zero means "doesn't match the 3a-5 shape".
fn amdgpu_lower_silu_f32_3a(uint64 fn_node, uint64 source,
                             uint64 kname_ptr, uint64 nl) -> uint64 {
    // ── shape: 3 params (in_ptr, out_ptr, n) ───────────────────
    uint64 n_params = 0
    uint64 wp = ast_child(fn_node)
    while wp != 0 {
        n_params = n_params + 1
        wp = ast_next(wp)
    }
    if n_params != 3 { return 1 }

    // ── shape: body Block has 2 stmts (gid VarDecl + If) ────────
    uint32 body = ast_data3(fn_node)
    if body == 0 { return 1 }
    if ast_kind(body) != 15 { return 1 }
    uint32 stmt0 = ast_child(body)
    if stmt0 == 0 || ast_kind(stmt0) != 10 { return 1 }
    uint32 stmt1 = ast_next(stmt0)
    if stmt1 == 0 || ast_kind(stmt1) != 13 { return 1 }
    if ast_next(stmt1) != 0 { return 1 }

    // ── if-then-block has 6 stmts in canonical order ────────────
    uint32 then_block = ast_data1(stmt1)
    if then_block == 0 || ast_kind(then_block) != 15 { return 1 }
    uint32 t0 = ast_child(then_block)
    if t0 == 0 || ast_kind(t0) != 10 { return 1 }   // VarDecl ip
    uint32 t1 = ast_next(t0)
    if t1 == 0 || ast_kind(t1) != 10 { return 1 }   // VarDecl op
    uint32 t2 = ast_next(t1)
    if t2 == 0 || ast_kind(t2) != 10 { return 1 }   // VarDecl x (f32)
    uint32 t3 = ast_next(t2)
    if t3 == 0 || ast_kind(t3) != 41 { return 1 }   // PtrLoad → x
    uint32 t4 = ast_next(t3)
    if t4 == 0 || ast_kind(t4) != 10 { return 1 }   // VarDecl r = Call(silu_f32, x)
    uint32 t5 = ast_next(t4)
    if t5 == 0 || ast_kind(t5) != 42 { return 1 }   // PtrStore op = r
    if ast_next(t5) != 0 { return 1 }

    // f32 type checks on PtrLoad / PtrStore.
    if ast_data1(t3) != 4 || ast_data3(t3) != 2 { return 1 }
    if ast_data1(t5) != 4 || ast_data3(t5) != 2 { return 1 }

    uint32 x_name = ast_data2(t2)
    uint32 r_name = ast_data2(t4)

    // r's init must be Call(silu, Ident(x_name)).
    // Intrinsic name is `silu` (not `silu_f32`) — the @kernel itself
    // is named silu_f32, so the call site uses the unsuffixed name.
    uint32 r_init = ast_child(t4)
    if r_init == 0 || ast_kind(r_init) != 35 { return 1 }
    uint32 callee = ast_data1(r_init)
    if tok_matches(callee, "silu", 4) == 0 { return 1 }
    uint32 cargs = ast_child(r_init)
    if cargs == 0 || ast_kind(cargs) != 32 { return 1 }
    if ast_next(cargs) != 0 { return 1 }
    if tok_text_eq(ast_data1(cargs), x_name) == 0 { return 1 }

    // PtrStore value (data2) must be Ident(r_name).
    uint32 store_val = ast_data2(t5)
    if store_val == 0 || ast_kind(store_val) != 32 { return 1 }
    if tok_text_eq(ast_data1(store_val), r_name) == 0 { return 1 }

    // ── emit ISA ─────────────────────────────────────────────────
    // 33-dword sequence ported verbatim from the legacy hand-tuned
    // `_emit_silu_f32_body`.  s_load_b256 reads 32 B though kernarg is
    // only 24 — the over-read is harmless on gfx11.  n lives in s8 here
    // (vs s10 in residual_add) since only 3 args precede it.
    // gfx10 dwords verified via llvm-mc -mcpu=gfx1030; gfx11 path is
    // the established bit-exact production encoding.
    asm_init()
    asm_u32_arch(0xF40C0100, 0xF40C0100); asm_u32_arch(0xF8000000, 0xFA000000) // s_load_b256/dwordx8 s[4:11], s[0:1], 0x0
    asm_u32_arch(0xBF89FC07, 0xBF8CC07F)            // s_waitcnt   lgkmcnt(0)
    asm_u32_arch(0x840C880F, 0x8F0C880F)            // s_lshl_b32  s12, s15, 8
    asm_u32     (0x4A02000C)                        // v_add_nc_u32 v1, s12, v0
    asm_u32_arch(0x7C980208, 0x7D880208)            // v_cmp_gt_u32 vcc_lo, s8, v1
    asm_u32_arch(0xBE8D206A, 0xBE8D3C6A)            // s_and_saveexec_b32 s13, vcc_lo
    asm_u32_arch(0xBFA50019, 0xBF880019)            // s_cbranch_execz +25
    asm_u32_arch(0x300C0282, 0x340C0282)            // v_lshlrev_b32 v6, 2, v1
    asm_u32     (0x7E060280)                        // v_mov_b32   v3, 0
    asm_u32_arch(0xD7006A02, 0xD70F6A02); asm_u32(0x00020C04) // v_add_co_u32 v2, vcc_lo, s4, v6
    asm_u32_arch(0xD5207C03, 0xD5287D03); asm_u32(0x01AA0605) // v_add_co_ci_u32 v3, null, s5, v3, vcc_lo
    asm_u32     (0x7E0A0280)                        // v_mov_b32   v5, 0
    asm_u32_arch(0xD7006A04, 0xD70F6A04); asm_u32(0x00020C06) // v_add_co_u32 v4, vcc_lo, s6, v6
    asm_u32_arch(0xD5207C05, 0xD5287D05); asm_u32(0x01AA0A07) // v_add_co_ci_u32 v5, null, s7, v5, vcc_lo
    asm_u32_arch(0xDC520000, 0xDC308000); asm_u32_arch(0x077C0002, 0x077D0002) // global_load_b32 v7, v[2:3], off
    asm_u32_arch(0xBF8903F7, 0xBF8C3F70)            // s_waitcnt vmcnt(0)
    // SiLU composer (silu(x) materialised in v7).  Most VOP1/VOP2/VOP3
    // ops are unchanged across gfx10/11; s_mov_b32 SOP1 op shifted
    // (BE8C00FF → BE8C03FF) and v_mul_f32_e64 modifier-bit nominal
    // value differs (omod field encoding).
    asm_u32_arch(0xBE8C00FF, 0xBE8C03FF); asm_u32(0x3FB8AA3B) // s_mov_b32 s12, log2(e)
    asm_u32     (0xD5080008); asm_u32_arch(0x20001907, 0x00001907) // v_mul_f32_e64 v8, v7, s12
    asm_u32     (0x7E104B08)                        // v_exp_f32   v8, v8
    asm_u32     (0x061010F2)                        // v_add_f32   v8, 1.0, v8
    asm_u32     (0x7E105508)                        // v_rcp_f32   v8, v8
    asm_u32     (0x100E1107)                        // v_mul_f32   v7, v7, v8
    asm_u32_arch(0xDC6A0000, 0xDC708000); asm_u32_arch(0x007C0704, 0x007D0704) // global_store_b32 v[4:5], v7, off
    asm_u32_arch(0xBC7C0000, 0xBBFD0000)            // s_waitcnt_vscnt null, 0
    asm_u32_arch(0xBFB00000, 0xBF810000)            // s_endpgm

    // ── kernarg layout: 3 args × 16 bytes (in, out are buffers; n by-value) ──
    uint64 args_desc = alloc(6 * 16)
    uint64 a0 = args_desc +  0;  unsafe { *(a0 as uint64) = 8 }
    uint64 a1 = args_desc +  8;  unsafe { *(a1 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a2 = args_desc + 16;  unsafe { *(a2 as uint64) = 8 }
    uint64 a3 = args_desc + 24;  unsafe { *(a3 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a4 = args_desc + 32;  unsafe { *(a4 as uint64) = 8 }
    uint64 a5 = args_desc + 40;  unsafe { *(a5 as uint64) = AMD_ARG_KIND_BY_VALUE }

    uint64 k_text_size = asm_text_len
    uint64 k_text_buf  = alloc(k_text_size)
    uint64 ci = 0
    while ci < k_text_size {
        uint64 sp = asm_text_buf + ci
        uint64 b = 0
        unsafe { *(sp as uint8) -> b }
        uint64 dp = k_text_buf + ci
        uint8 b8 = b
        unsafe { *(dp as uint8) = b8 }
        ci = ci + 1
    }

    // KD identical to legacy hand-tuned silu_f32: 16 SGPRs / 9 VGPRs,
    // USER_SGPR_COUNT=15, no LDS, rsrc1=0xE0AF0001.
    uint64 rsrc1 = 0xE0AF0001
    uint64 rsrc2 = 0x0000009E
    uint64 rsrc3 = 0x00000010
    uint64 props = 0x0408

    kt_push(kname_ptr, nl, k_text_buf, k_text_size,
            args_desc, 3, 24,
            16, 9,
            rsrc1, rsrc2, rsrc3, props)
    return 0
}

// Phase 3a-6 — bf16_to_f32 type-cast pointwise (in u16 → out u32).
//
// Recognises the shape:
//
//   @kernel fn name(uint64 in_ptr, uint64 out_ptr, uint64 n) {
//       uint64 gid = block_idx_x() * 256 + tid_local_x()
//       if gid < n {
//           uint64 ip = in_ptr  + gid * 2
//           uint64 op = out_ptr + gid * 4
//           uint16 b = 0
//           unsafe { *(ip as uint16) -> b }
//           uint64 b64 = b
//           uint32 r = b64 << 16
//           unsafe { *(op as uint32) = r }
//       }
//   }
//
// Replaces the legacy hand-tuned `_emit_bf16_to_f32_body` (30 dwords).
// The conversion is purely a 16-bit lshl in-register: bf16's bit pattern
// IS the high 16 bits of an f32 with the same sign + exponent.
//
// Returns 0 on success; non-zero means "doesn't match the 3a-6 shape".
fn amdgpu_lower_bf16_to_f32_3a(uint64 fn_node, uint64 source,
                                uint64 kname_ptr, uint64 nl) -> uint64 {
    // ── shape: 3 params (in_ptr, out_ptr, n) ───────────────────
    uint64 n_params = 0
    uint64 wp = ast_child(fn_node)
    while wp != 0 {
        n_params = n_params + 1
        wp = ast_next(wp)
    }
    if n_params != 3 { return 1 }

    // ── shape: body Block has 2 stmts (gid VarDecl + If) ────────
    uint32 body = ast_data3(fn_node)
    if body == 0 { return 1 }
    if ast_kind(body) != 15 { return 1 }
    uint32 stmt0 = ast_child(body)
    if stmt0 == 0 || ast_kind(stmt0) != 10 { return 1 }
    uint32 stmt1 = ast_next(stmt0)
    if stmt1 == 0 || ast_kind(stmt1) != 13 { return 1 }
    if ast_next(stmt1) != 0 { return 1 }

    // ── if-then-block has 7 stmts in canonical order ────────────
    uint32 then_block = ast_data1(stmt1)
    if then_block == 0 || ast_kind(then_block) != 15 { return 1 }
    uint32 t0 = ast_child(then_block)
    if t0 == 0 || ast_kind(t0) != 10 { return 1 }   // VarDecl ip
    uint32 t1 = ast_next(t0)
    if t1 == 0 || ast_kind(t1) != 10 { return 1 }   // VarDecl op
    uint32 t2 = ast_next(t1)
    if t2 == 0 || ast_kind(t2) != 10 { return 1 }   // VarDecl b (uint16)
    uint32 t3 = ast_next(t2)
    if t3 == 0 || ast_kind(t3) != 41 { return 1 }   // PtrLoad u16 → b
    uint32 t4 = ast_next(t3)
    if t4 == 0 || ast_kind(t4) != 10 { return 1 }   // VarDecl b64
    uint32 t5 = ast_next(t4)
    if t5 == 0 || ast_kind(t5) != 10 { return 1 }   // VarDecl r (= b64 << 16)
    uint32 t6 = ast_next(t5)
    if t6 == 0 || ast_kind(t6) != 42 { return 1 }   // PtrStore u32 op = r
    if ast_next(t6) != 0 { return 1 }

    // PtrLoad must be u16 (data1=2, data3=0=int).
    if ast_data1(t3) != 2 { return 1 }
    if ast_data3(t3) != 0 { return 1 }
    // PtrStore must be u32 (data1=4, data3=0=int).
    if ast_data1(t6) != 4 { return 1 }
    if ast_data3(t6) != 0 { return 1 }

    // ── emit ISA ─────────────────────────────────────────────────
    // 30-dword sequence; gfx10 dword pairs verified via llvm-mc -mcpu=gfx1030.
    // New encoding pairs: s_load_b128/dwordx4, s_load_b32/dword (kernarg
    // offset 0x10), s_mov_b32 reg-form (SOP1 op 0x00→0x03), v_cmpx_gt_u32_e64
    // (VOP3 op + word2 layout differ), global_load_u16/ushort.
    asm_init()
    asm_u32_arch(0xF4080100, 0xF4080100); asm_u32_arch(0xF8000000, 0xFA000000) // s_load_b128/dwordx4 s[4:7], s[0:1], 0x0
    asm_u32_arch(0xF4000200, 0xF4000200); asm_u32_arch(0xF8000010, 0xFA000010) // s_load_b32/dword s8, s[0:1], 0x10
    asm_u32_arch(0xBF89FC07, 0xBF8CC07F)            // s_waitcnt   lgkmcnt(0)
    asm_u32_arch(0x840A880F, 0x8F0A880F)            // s_lshl_b32  s10, s15, 8
    asm_u32     (0x4A02000A)                        // v_add_nc_u32 v1, s10, v0
    asm_u32_arch(0xBE82007E, 0xBE82037E)            // s_mov_b32   s2, exec_lo  (SOP1 op shift)
    asm_u32_arch(0xD4C9007E, 0xD4D4007E); asm_u32_arch(0x00001101, 0x00020208) // v_cmpx_gt_u32_e64 vcc_lo, s8, v1
    asm_u32_arch(0xBFA50012, 0xBF880012)            // s_cbranch_execz +18
    asm_u32_arch(0x30080281, 0x34080281)            // v_lshlrev_b32 v4, 1, v1  (gid*2)
    asm_u32     (0x7E0A0280)                        // v_mov_b32   v5, 0
    asm_u32_arch(0xD7006A02, 0xD70F6A02); asm_u32(0x00020804) // v_add_co_u32 v2, vcc_lo, s4, v4
    asm_u32_arch(0xD5207C03, 0xD5287D03); asm_u32(0x01AA0A05) // v_add_co_ci_u32 v3, null, s5, v5, vcc_lo
    asm_u32_arch(0xDC4A0000, 0xDC288000); asm_u32_arch(0x067C0002, 0x067D0002) // global_load_u16/ushort v6, v[2:3], off
    asm_u32_arch(0xBF8903F7, 0xBF8C3F70)            // s_waitcnt vmcnt(0)
    asm_u32_arch(0x300C0C90, 0x340C0C90)            // v_lshlrev_b32 v6, 16, v6
    asm_u32_arch(0x30080282, 0x34080282)            // v_lshlrev_b32 v4, 2, v1  (gid*4)
    asm_u32_arch(0xD7006A02, 0xD70F6A02); asm_u32(0x00020806) // v_add_co_u32 v2, vcc_lo, s6, v4
    asm_u32_arch(0xD5207C03, 0xD5287D03); asm_u32(0x01AA0A07) // v_add_co_ci_u32 v3, null, s7, v5, vcc_lo
    asm_u32_arch(0xDC6A0000, 0xDC708000); asm_u32_arch(0x007C0602, 0x007D0602) // global_store_b32/dword v[2:3], v6, off
    asm_u32_arch(0xBC7C0000, 0xBBFD0000)            // s_waitcnt_vscnt null, 0
    asm_u32_arch(0xBFB00000, 0xBF810000)            // s_endpgm

    // ── kernarg layout: 3 args × 16 bytes (in_buf, out_buf, n) ───
    uint64 args_desc = alloc(6 * 16)
    uint64 a0 = args_desc +  0;  unsafe { *(a0 as uint64) = 8 }
    uint64 a1 = args_desc +  8;  unsafe { *(a1 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a2 = args_desc + 16;  unsafe { *(a2 as uint64) = 8 }
    uint64 a3 = args_desc + 24;  unsafe { *(a3 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a4 = args_desc + 32;  unsafe { *(a4 as uint64) = 8 }
    uint64 a5 = args_desc + 40;  unsafe { *(a5 as uint64) = AMD_ARG_KIND_BY_VALUE }

    uint64 k_text_size = asm_text_len
    uint64 k_text_buf  = alloc(k_text_size)
    uint64 ci = 0
    while ci < k_text_size {
        uint64 sp = asm_text_buf + ci
        uint64 b = 0
        unsafe { *(sp as uint8) -> b }
        uint64 dp = k_text_buf + ci
        uint8 b8 = b
        unsafe { *(dp as uint8) = b8 }
        ci = ci + 1
    }

    // KD identical to legacy hand-tuned bf16_to_f32: 16 SGPRs / 7 VGPRs,
    // USER_SGPR_COUNT=15, no LDS, rsrc1=0xE0AF0001.
    uint64 rsrc1 = 0xE0AF0001
    uint64 rsrc2 = 0x0000009E
    uint64 rsrc3 = 0x00000010
    uint64 props = 0x0408

    kt_push(kname_ptr, nl, k_text_buf, k_text_size,
            args_desc, 3, 24,
            16, 7,
            rsrc1, rsrc2, rsrc3, props)
    return 0
}

// Phase 3b — rmsnorm_f32 (LDS-reduce, hardcoded N=256).
//
// Recognises a kernel of the form:
//
//   @kernel fn name(uint64 in_ptr, uint64 out_ptr, uint64 gamma_ptr,
//                   uint64 m, uint64 n) {
//       uint64 row  = block_idx_x()
//       uint64 lane = tid_local_x()
//       if row < m {
//           ...
//           f32 sumsq = lds_reduce_sum_f32(x * x)
//           ...
//       }
//   }
//
// First reduction kernel under the AST walker.  Recogniser does
// loose structural validation (5-param signature + body skeleton +
// at least one Call to the `lds_reduce_sum_f32` composer); the body's
// arithmetic is opaque — the canonical 144-dword ISA is hardcoded
// to N=256, eps=1e-5, gamma mandatory.
//
// Returns 0 on success; non-zero means "doesn't match the 3b shape".
fn amdgpu_lower_rmsnorm_f32_3b(uint64 fn_node, uint64 source,
                                uint64 kname_ptr, uint64 nl) -> uint64 {
    // ── shape: 5 params (in, out, gamma, m, n) ───────────────────
    uint64 n_params = 0
    uint64 wp = ast_child(fn_node)
    while wp != 0 {
        n_params = n_params + 1
        wp = ast_next(wp)
    }
    if n_params != 5 { return 1 }

    // ── shape: body Block has 3 top-level stmts (row, lane, If) ──
    uint32 body = ast_data3(fn_node)
    if body == 0 { return 1 }
    if ast_kind(body) != 15 { return 1 }
    uint32 stmt0 = ast_child(body)
    if stmt0 == 0 || ast_kind(stmt0) != 10 { return 1 }   // VarDecl row
    uint32 stmt1 = ast_next(stmt0)
    if stmt1 == 0 || ast_kind(stmt1) != 10 { return 1 }   // VarDecl lane
    uint32 stmt2 = ast_next(stmt1)
    if stmt2 == 0 || ast_kind(stmt2) != 13 { return 1 }   // If
    if ast_next(stmt2) != 0 { return 1 }

    // ── if-then-block must contain a Call to lds_reduce_sum_f32 AND
    // a Call to rsqrt_f32 (the defining op of *RMS*norm).  Without the
    // rsqrt check, this recogniser is structurally identical to the
    // gemv_coop_f32 shape (5p + 3-stmt body + lds_reduce_sum_f32) and
    // would mis-emit gemv_coop_f32 as rmsnorm bytes — symptom: kernel
    // squares its input instead of computing a dot product, qwen3
    // lm_head hangs the queue at N=151936.
    uint32 then_block = ast_data1(stmt2)
    if then_block == 0 || ast_kind(then_block) != 15 { return 1 }
    uint64 saw_lds_reduce = 0
    uint64 saw_rsqrt = 0
    uint32 walk = ast_child(then_block)
    while walk != 0 {
        // The reducer call is the init-expr of a VarDecl: `f32 sumsq =
        // lds_reduce_sum_f32(...)`.  Check VarDecls whose init is a Call
        // whose callee text matches our composer name.
        if ast_kind(walk) == 10 {
            uint32 init = ast_child(walk)
            if init != 0 && ast_kind(init) == 35 {
                uint32 callee = ast_data1(init)
                if tok_matches(callee, "lds_reduce_sum_f32", 18) != 0 {
                    saw_lds_reduce = 1
                }
                if tok_matches(callee, "rsqrt_f32", 9) != 0 {
                    saw_rsqrt = 1
                }
            }
        }
        if ast_kind(walk) == 35 {
            uint32 callee = ast_data1(walk)
            if tok_matches(callee, "rsqrt_f32", 9) != 0 { saw_rsqrt = 1 }
        }
        walk = ast_next(walk)
    }
    if saw_lds_reduce == 0 { return 1 }
    if saw_rsqrt == 0 { return 1 }

    // ── emit ISA via parametric helper at N=256 ──────────────────
    // The helper (`_emit_rmsnorm_f32_body_N_eps`) emits the same
    // 144-dword sequence and is target-arch-aware (gfx10/gfx11).
    // Single source of truth — same path as N=128/1024 below.
    uint64 args_desc = alloc(10 * 16)
    _emit_rmsnorm_f32_body_N_eps(args_desc, 256, 0x3727C5AC)

    uint64 k_text_size = asm_text_len
    uint64 k_text_buf  = alloc(k_text_size)
    uint64 ci = 0
    while ci < k_text_size {
        uint64 sp = asm_text_buf + ci
        uint64 b = 0
        unsafe { *(sp as uint8) -> b }
        uint64 dp = k_text_buf + ci
        uint8 b8 = b
        unsafe { *(dp as uint8) = b8 }
        ci = ci + 1
    }

    // KD identical to the legacy hand-tuned rmsnorm_f32: 16 SGPRs / 14
    // VGPRs, USER_SGPR_COUNT=15, LDS=1024 (256 lanes × 4 B), rsrc1 =
    // 0xE0AF0001.
    uint64 rsrc1 = 0xE0AF0001
    uint64 rsrc2 = 0x0000009E
    uint64 rsrc3 = 0x00000010
    uint64 props = 0x0408

    kt_push_lds(kname_ptr, nl, k_text_buf, k_text_size,
                args_desc, 5, 40,
                16, 14,
                rsrc1, rsrc2, rsrc3, props,
                1024)
    return 0
}

// Phase 3b-1024 — rmsnorm_f32 at N=1024 (Qwen3-0.6B hidden).
//
// Discriminator: 5 params + lds_reduce_sum_f32 + rmsnorm_N1024_marker.
// Routes BEFORE 3b (which hardcodes N=256).  Delegates to the
// parametric `_emit_rmsnorm_f32_body_N(args, 1024)` emitter.
fn amdgpu_lower_rmsnorm_f32_N1024_3b(uint64 fn_node, uint64 source,
                                       uint64 kname_ptr, uint64 nl) -> uint64 {
    uint64 n_params = 0
    uint64 wp = ast_child(fn_node)
    while wp != 0 {
        n_params = n_params + 1
        wp = ast_next(wp)
    }
    if n_params != 5 { return 1 }

    uint32 body = ast_data3(fn_node)
    if body == 0 { return 1 }
    if ast_kind(body) != 15 { return 1 }

    uint64 saw_marker = 0
    uint32 walk = ast_child(body)
    while walk != 0 {
        if ast_kind(walk) == 35 {
            uint32 callee = ast_data1(walk)
            if tok_matches(callee, "rmsnorm_N1024_marker", 20) != 0 { saw_marker = 1 }
        }
        if ast_kind(walk) == 10 {
            uint32 init = ast_child(walk)
            if init != 0 && ast_kind(init) == 35 {
                uint32 callee = ast_data1(init)
                if tok_matches(callee, "rmsnorm_N1024_marker", 20) != 0 { saw_marker = 1 }
            }
        }
        walk = ast_next(walk)
    }
    if saw_marker == 0 { return 1 }

    uint64 args_desc = alloc(10 * 16)
    _emit_rmsnorm_f32_body_N(args_desc, 1024)

    uint64 k_text_size = asm_text_len
    uint64 k_text_buf  = alloc(k_text_size)
    uint64 ci = 0
    while ci < k_text_size {
        uint64 sp = asm_text_buf + ci
        uint64 b = 0
        unsafe { *(sp as uint8) -> b }
        uint64 dp = k_text_buf + ci
        uint8 b8 = b
        unsafe { *(dp as uint8) = b8 }
        ci = ci + 1
    }

    uint64 rsrc1 = 0xE0AF0001
    uint64 rsrc2 = 0x0000009E
    uint64 rsrc3 = 0x00000010
    uint64 props = 0x0408

    kt_push_lds(kname_ptr, nl, k_text_buf, k_text_size,
                args_desc, 5, 40,
                16, 18,
                rsrc1, rsrc2, rsrc3, props,
                4096)
    return 0
}

// Phase 3b-5120 — rmsnorm_f32 at N=5120 (Qwen3-14B hidden, large-N).
fn amdgpu_lower_rmsnorm_f32_N5120_3b(uint64 fn_node, uint64 source,
                                       uint64 kname_ptr, uint64 nl) -> uint64 {
    uint64 n_params = 0
    uint64 wp = ast_child(fn_node)
    while wp != 0 {
        n_params = n_params + 1
        wp = ast_next(wp)
    }
    if n_params != 5 { return 1 }

    uint32 body = ast_data3(fn_node)
    if body == 0 { return 1 }
    if ast_kind(body) != 15 { return 1 }

    uint64 saw_marker = 0
    uint32 walk = ast_child(body)
    while walk != 0 {
        if ast_kind(walk) == 35 {
            uint32 callee = ast_data1(walk)
            if tok_matches(callee, "rmsnorm_N5120_marker", 20) != 0 { saw_marker = 1 }
        }
        if ast_kind(walk) == 10 {
            uint32 init = ast_child(walk)
            if init != 0 && ast_kind(init) == 35 {
                uint32 callee = ast_data1(init)
                if tok_matches(callee, "rmsnorm_N5120_marker", 20) != 0 { saw_marker = 1 }
            }
        }
        walk = ast_next(walk)
    }
    if saw_marker == 0 { return 1 }

    uint64 args_desc = alloc(10 * 16)
    _emit_rmsnorm_f32_body_NL(args_desc, 5120)

    uint64 k_text_size = asm_text_len
    uint64 k_text_buf  = alloc(k_text_size)
    uint64 ci = 0
    while ci < k_text_size {
        uint64 sp = asm_text_buf + ci
        uint64 b = 0
        unsafe { *(sp as uint8) -> b }
        uint64 dp = k_text_buf + ci
        uint8 b8 = b
        unsafe { *(dp as uint8) = b8 }
        ci = ci + 1
    }

    // Large-N path: rsrc1=0xE0AF0002 (24 vgpr), lds=4096.
    uint64 rsrc1 = 0xE0AF0002
    uint64 rsrc2 = 0x0000009E
    uint64 rsrc3 = 0x00000010
    uint64 props = 0x0408

    kt_push_lds(kname_ptr, nl, k_text_buf, k_text_size,
                args_desc, 5, 40,
                16, 18,
                rsrc1, rsrc2, rsrc3, props,
                4096)
    return 0
}

// Phase 3b-128 — qknorm: rmsnorm at N=128, eps=1e-6.
fn amdgpu_lower_qknorm_f32_3b(uint64 fn_node, uint64 source,
                                uint64 kname_ptr, uint64 nl) -> uint64 {
    uint64 n_params = 0
    uint64 wp = ast_child(fn_node)
    while wp != 0 {
        n_params = n_params + 1
        wp = ast_next(wp)
    }
    if n_params != 5 { return 1 }

    uint32 body = ast_data3(fn_node)
    if body == 0 { return 1 }
    if ast_kind(body) != 15 { return 1 }

    uint64 saw_marker = 0
    uint32 walk = ast_child(body)
    while walk != 0 {
        if ast_kind(walk) == 35 {
            uint32 callee = ast_data1(walk)
            if tok_matches(callee, "qknorm_marker", 13) != 0 { saw_marker = 1 }
        }
        if ast_kind(walk) == 10 {
            uint32 init = ast_child(walk)
            if init != 0 && ast_kind(init) == 35 {
                uint32 callee = ast_data1(init)
                if tok_matches(callee, "qknorm_marker", 13) != 0 { saw_marker = 1 }
            }
        }
        walk = ast_next(walk)
    }
    if saw_marker == 0 { return 1 }

    uint64 args_desc = alloc(10 * 16)
    // qknorm: N=128, eps_bits = 0x358637BD (1e-6).
    _emit_rmsnorm_f32_body_N_eps(args_desc, 128, 0x358637BD)

    uint64 k_text_size = asm_text_len
    uint64 k_text_buf  = alloc(k_text_size)
    uint64 ci = 0
    while ci < k_text_size {
        uint64 sp = asm_text_buf + ci
        uint64 b = 0
        unsafe { *(sp as uint8) -> b }
        uint64 dp = k_text_buf + ci
        uint8 b8 = b
        unsafe { *(dp as uint8) = b8 }
        ci = ci + 1
    }

    uint64 rsrc1 = 0xE0AF0001
    uint64 rsrc2 = 0x0000009E
    uint64 rsrc3 = 0x00000010
    uint64 props = 0x0408

    kt_push_lds(kname_ptr, nl, k_text_buf, k_text_size,
                args_desc, 5, 40,
                16, 18,
                rsrc1, rsrc2, rsrc3, props,
                512)
    return 0
}

// Phase 3c — slice 2c: fused qknorm + rope_qk over Q+K heads.
//
// Discriminator: 8-param @kernel + Call to qknorm_rope_qk_marker() in
// the body.  Routes BEFORE rmsnorm_3b / qknorm_3b / rope_qwen3_3c so the
// fused marker wins when present.  Body emit ignores the AST and
// produces a hardcoded gfx1100 ISA matching the .mlr semantics.
fn amdgpu_lower_qknorm_rope_qk_3c(uint64 fn_node, uint64 source,
                                    uint64 kname_ptr, uint64 nl) -> uint64 {
    uint64 n_params = 0
    uint64 wp = ast_child(fn_node)
    while wp != 0 {
        n_params = n_params + 1
        wp = ast_next(wp)
    }
    if n_params != 8 { return 1 }

    uint32 body = ast_data3(fn_node)
    if body == 0 { return 1 }
    if ast_kind(body) != 15 { return 1 }

    uint64 saw_marker = 0
    uint32 walk = ast_child(body)
    while walk != 0 {
        if ast_kind(walk) == 35 {
            uint32 callee = ast_data1(walk)
            if tok_matches(callee, "qknorm_rope_qk_marker", 21) != 0 { saw_marker = 1 }
        }
        if ast_kind(walk) == 10 {
            uint32 init = ast_child(walk)
            if init != 0 && ast_kind(init) == 35 {
                uint32 callee = ast_data1(init)
                if tok_matches(callee, "qknorm_rope_qk_marker", 21) != 0 { saw_marker = 1 }
            }
        }
        walk = ast_next(walk)
    }
    if saw_marker == 0 { return 1 }

    uint64 args_desc = alloc(16 * 16)
    _emit_qknorm_rope_qk_fused_f32_body(args_desc)

    uint64 k_text_size = asm_text_len
    uint64 k_text_buf  = alloc(k_text_size)
    uint64 ci = 0
    while ci < k_text_size {
        uint64 sp = asm_text_buf + ci
        uint64 b = 0
        unsafe { *(sp as uint8) -> b }
        uint64 dp = k_text_buf + ci
        uint8 b8 = b
        unsafe { *(dp as uint8) = b8 }
        ci = ci + 1
    }

    // KD: 32-SGPR / 24-VGPR grant, USER_SGPR_COUNT=15, LDS=1024 B,
    // rsrc1=0xE0AF0082.  Matches emit_amdgpu_qknorm_rope_qk_fused_f32_blob.
    uint64 rsrc1 = 0xE0AF0082
    uint64 rsrc2 = 0x0000009E
    uint64 rsrc3 = 0x00000010
    uint64 props = 0x0408

    kt_push_lds(kname_ptr, nl, k_text_buf, k_text_size,
                args_desc, 8, 64,
                32, 22,
                rsrc1, rsrc2, rsrc3, props,
                1024)
    return 0
}

// Phase 3b-2-N128 — softmax_f32 parametric N=128.
//
// Discriminator: 4 params + softmax_N128_marker() Call.  Routes BEFORE
// 3b-2 (which hardcodes N=256).  Calls _emit_softmax_f32_body_N(args, 128).
fn amdgpu_lower_softmax_f32_N128_3b(uint64 fn_node, uint64 source,
                                      uint64 kname_ptr, uint64 nl) -> uint64 {
    uint64 n_params = 0
    uint64 wp = ast_child(fn_node)
    while wp != 0 {
        n_params = n_params + 1
        wp = ast_next(wp)
    }
    if n_params != 4 { return 1 }

    uint32 body = ast_data3(fn_node)
    if body == 0 { return 1 }
    if ast_kind(body) != 15 { return 1 }

    uint64 saw_marker = 0
    uint32 walk = ast_child(body)
    while walk != 0 {
        if ast_kind(walk) == 35 {
            uint32 callee = ast_data1(walk)
            if tok_matches(callee, "softmax_N128_marker", 19) != 0 { saw_marker = 1 }
        }
        if ast_kind(walk) == 10 {
            uint32 init = ast_child(walk)
            if init != 0 && ast_kind(init) == 35 {
                uint32 callee = ast_data1(init)
                if tok_matches(callee, "softmax_N128_marker", 19) != 0 { saw_marker = 1 }
            }
        }
        walk = ast_next(walk)
    }
    if saw_marker == 0 { return 1 }

    uint64 args_desc = alloc(8 * 16)
    _emit_softmax_f32_body_N(args_desc, 128)

    uint64 k_text_size = asm_text_len
    uint64 k_text_buf  = alloc(k_text_size)
    uint64 ci = 0
    while ci < k_text_size {
        uint64 sp = asm_text_buf + ci
        uint64 b = 0
        unsafe { *(sp as uint8) -> b }
        uint64 dp = k_text_buf + ci
        uint8 b8 = b
        unsafe { *(dp as uint8) = b8 }
        ci = ci + 1
    }

    uint64 rsrc1 = 0xE0AF0001
    uint64 rsrc2 = 0x0000009E
    uint64 rsrc3 = 0x00000010
    uint64 props = 0x0408

    kt_push_lds(kname_ptr, nl, k_text_buf, k_text_size,
                args_desc, 4, 32,
                16, 20,
                rsrc1, rsrc2, rsrc3, props,
                512)
    return 0
}

// Phase 3b-2 — softmax_f32 (max + sum LDS reductions, hardcoded N=256).
//
// Recognises a kernel of the form:
//
//   @kernel fn name(uint64 in_ptr, uint64 out_ptr, uint64 m, uint64 n) {
//       uint64 row  = block_idx_x()
//       uint64 lane = tid_local_x()
//       if row < m {
//           ...
//           f32 max_x  = lds_reduce_max_f32(x)
//           f32 sum_ex = lds_reduce_sum_f32(exp_f32(x - max_x))
//           ...
//       }
//   }
//
// Loose body validation: requires both reduce-max and reduce-sum
// composer calls; the canonical 230-dword ISA is hardcoded N=256.
//
// Returns 0 on success; non-zero means "doesn't match the 3b-2 shape".
fn amdgpu_lower_softmax_f32_3b(uint64 fn_node, uint64 source,
                                uint64 kname_ptr, uint64 nl) -> uint64 {
    // ── shape: 4 params (in, out, m, n) ─────────────────────────
    uint64 n_params = 0
    uint64 wp = ast_child(fn_node)
    while wp != 0 {
        n_params = n_params + 1
        wp = ast_next(wp)
    }
    if n_params != 4 { return 1 }

    // ── shape: body Block has 3 top-level stmts (row, lane, If) ──
    uint32 body = ast_data3(fn_node)
    if body == 0 { return 1 }
    if ast_kind(body) != 15 { return 1 }
    uint32 stmt0 = ast_child(body)
    if stmt0 == 0 || ast_kind(stmt0) != 10 { return 1 }
    uint32 stmt1 = ast_next(stmt0)
    if stmt1 == 0 || ast_kind(stmt1) != 10 { return 1 }
    uint32 stmt2 = ast_next(stmt1)
    if stmt2 == 0 || ast_kind(stmt2) != 13 { return 1 }
    if ast_next(stmt2) != 0 { return 1 }

    // ── if-then-block must contain Calls to lds_reduce_max_f32 and
    //    lds_reduce_sum_f32 (both reductions for stable softmax). ──
    uint32 then_block = ast_data1(stmt2)
    if then_block == 0 || ast_kind(then_block) != 15 { return 1 }
    uint64 saw_max = 0
    uint64 saw_sum = 0
    uint32 walk = ast_child(then_block)
    while walk != 0 {
        if ast_kind(walk) == 10 {
            uint32 init = ast_child(walk)
            if init != 0 && ast_kind(init) == 35 {
                uint32 callee = ast_data1(init)
                if tok_matches(callee, "lds_reduce_max_f32", 18) != 0 { saw_max = 1 }
                if tok_matches(callee, "lds_reduce_sum_f32", 18) != 0 { saw_sum = 1 }
            }
        }
        walk = ast_next(walk)
    }
    if saw_max == 0 { return 1 }
    if saw_sum == 0 { return 1 }

    // ── emit ISA via parametric helper at N=256 ──────────────────
    // Same path as the parametric softmax_f32_N128 lowerer; single
    // source of truth, target-arch-aware.
    uint64 args_desc = alloc(8 * 16)
    _emit_softmax_f32_body_N(args_desc, 256)

    uint64 k_text_size = asm_text_len
    uint64 k_text_buf  = alloc(k_text_size)
    uint64 ci = 0
    while ci < k_text_size {
        uint64 sp = asm_text_buf + ci
        uint64 b = 0
        unsafe { *(sp as uint8) -> b }
        uint64 dp = k_text_buf + ci
        uint8 b8 = b
        unsafe { *(dp as uint8) = b8 }
        ci = ci + 1
    }

    // KD identical to legacy hand-tuned softmax_f32: 16 SGPRs / 14 VGPRs,
    // USER_SGPR_COUNT=15, LDS=1024, rsrc1=0xE0AF0001.
    uint64 rsrc1 = 0xE0AF0001
    uint64 rsrc2 = 0x0000009E
    uint64 rsrc3 = 0x00000010
    uint64 props = 0x0408

    kt_push_lds(kname_ptr, nl, k_text_buf, k_text_size,
                args_desc, 4, 32,
                16, 14,
                rsrc1, rsrc2, rsrc3, props,
                1024)
    return 0
}

// Phase 3b-3-N128 — layernorm_f32 parametric N=128.
fn amdgpu_lower_layernorm_f32_N128_3b(uint64 fn_node, uint64 source,
                                        uint64 kname_ptr, uint64 nl) -> uint64 {
    uint64 n_params = 0
    uint64 wp = ast_child(fn_node)
    while wp != 0 {
        n_params = n_params + 1
        wp = ast_next(wp)
    }
    if n_params != 4 { return 1 }

    uint32 body = ast_data3(fn_node)
    if body == 0 { return 1 }
    if ast_kind(body) != 15 { return 1 }

    uint64 saw_marker = 0
    uint32 walk = ast_child(body)
    while walk != 0 {
        if ast_kind(walk) == 35 {
            uint32 callee = ast_data1(walk)
            if tok_matches(callee, "layernorm_N128_marker", 21) != 0 { saw_marker = 1 }
        }
        if ast_kind(walk) == 10 {
            uint32 init = ast_child(walk)
            if init != 0 && ast_kind(init) == 35 {
                uint32 callee = ast_data1(init)
                if tok_matches(callee, "layernorm_N128_marker", 21) != 0 { saw_marker = 1 }
            }
        }
        walk = ast_next(walk)
    }
    if saw_marker == 0 { return 1 }

    uint64 args_desc = alloc(8 * 16)
    _emit_layernorm_f32_body_N(args_desc, 128)

    uint64 k_text_size = asm_text_len
    uint64 k_text_buf  = alloc(k_text_size)
    uint64 ci = 0
    while ci < k_text_size {
        uint64 sp = asm_text_buf + ci
        uint64 b = 0
        unsafe { *(sp as uint8) -> b }
        uint64 dp = k_text_buf + ci
        uint8 b8 = b
        unsafe { *(dp as uint8) = b8 }
        ci = ci + 1
    }

    uint64 rsrc1 = 0xE0AF0001
    uint64 rsrc2 = 0x0000009E
    uint64 rsrc3 = 0x00000010
    uint64 props = 0x0408

    kt_push_lds(kname_ptr, nl, k_text_buf, k_text_size,
                args_desc, 4, 32,
                16, 20,
                rsrc1, rsrc2, rsrc3, props,
                512)
    return 0
}

// Phase 3b-3 — layernorm_f32 (mean + variance LDS reductions, N=256).
//
// Recognises a kernel of the form:
//
//   @kernel fn name(uint64 in_ptr, uint64 out_ptr, uint64 m, uint64 n) {
//       uint64 row  = block_idx_x()
//       uint64 lane = tid_local_x()
//       if row < m {
//           ...
//           f32 sum_x = lds_reduce_sum_f32(x)         // mean reduce
//           ...
//           f32 sumsq = lds_reduce_sum_f32(dx * dx)    // variance reduce
//           ...
//       }
//   }
//
// Loose body validation: requires the if-block to contain at least
// TWO Calls to lds_reduce_sum_f32.  The 236-dword hand-tuned ISA is
// hardcoded N=256, eps=1e-5, no gamma/beta.
//
// Returns 0 on success; non-zero means "doesn't match the 3b-3 shape".
fn amdgpu_lower_layernorm_f32_3b(uint64 fn_node, uint64 source,
                                  uint64 kname_ptr, uint64 nl) -> uint64 {
    // ── shape: 4 params (in, out, m, n) ─────────────────────────
    uint64 n_params = 0
    uint64 wp = ast_child(fn_node)
    while wp != 0 {
        n_params = n_params + 1
        wp = ast_next(wp)
    }
    if n_params != 4 { return 1 }

    // ── shape: body Block has 3 stmts (row, lane, If) ──────────
    uint32 body = ast_data3(fn_node)
    if body == 0 { return 1 }
    if ast_kind(body) != 15 { return 1 }
    uint32 stmt0 = ast_child(body)
    if stmt0 == 0 || ast_kind(stmt0) != 10 { return 1 }
    uint32 stmt1 = ast_next(stmt0)
    if stmt1 == 0 || ast_kind(stmt1) != 10 { return 1 }
    uint32 stmt2 = ast_next(stmt1)
    if stmt2 == 0 || ast_kind(stmt2) != 13 { return 1 }
    if ast_next(stmt2) != 0 { return 1 }

    // ── if-then-block must contain TWO Calls to lds_reduce_sum_f32. ──
    // Distinguishes layernorm (2 sum reduces) from softmax (1 sum +
    // 1 max) and rmsnorm (1 sum, but with 5 params — caught above).
    uint32 then_block = ast_data1(stmt2)
    if then_block == 0 || ast_kind(then_block) != 15 { return 1 }
    uint64 sum_count = 0
    uint64 saw_max = 0
    uint32 walk = ast_child(then_block)
    while walk != 0 {
        if ast_kind(walk) == 10 {
            uint32 init = ast_child(walk)
            if init != 0 && ast_kind(init) == 35 {
                uint32 callee = ast_data1(init)
                if tok_matches(callee, "lds_reduce_sum_f32", 18) != 0 { sum_count = sum_count + 1 }
                if tok_matches(callee, "lds_reduce_max_f32", 18) != 0 { saw_max = 1 }
            }
        }
        walk = ast_next(walk)
    }
    if sum_count < 2 { return 1 }
    if saw_max != 0 { return 1 }   // softmax has both — defer to 3b-2

    // ── emit ISA via parametric helper at N=256 ──────────────────
    // Same path as parametric layernorm_f32_N128 lowerer; single
    // source of truth, target-arch-aware.
    uint64 args_desc = alloc(8 * 16)
    _emit_layernorm_f32_body_N(args_desc, 256)

    uint64 k_text_size = asm_text_len
    uint64 k_text_buf  = alloc(k_text_size)
    uint64 ci = 0
    while ci < k_text_size {
        uint64 sp = asm_text_buf + ci
        uint64 b = 0
        unsafe { *(sp as uint8) -> b }
        uint64 dp = k_text_buf + ci
        uint8 b8 = b
        unsafe { *(dp as uint8) = b8 }
        ci = ci + 1
    }

    uint64 rsrc1 = 0xE0AF0001
    uint64 rsrc2 = 0x0000009E
    uint64 rsrc3 = 0x00000010
    uint64 props = 0x0408

    kt_push_lds(kname_ptr, nl, k_text_buf, k_text_size,
                args_desc, 4, 32,
                16, 14,
                rsrc1, rsrc2, rsrc3, props,
                1024)
    return 0
}

// Phase 3c-1 — rope_f32 (half-split rotary embedding, hardcoded D=128).
//
// Recognises a kernel of the form:
//
//   @kernel fn name(uint64 in_ptr, uint64 out_ptr, uint64 cos_ptr,
//                   uint64 sin_ptr, uint64 m) {
//       uint64 i = block_idx_x()
//       uint64 j = tid_local_x()
//       if i < m {
//           ... loads a, b, c, s ...
//           ... compute (a*c - b*s, a*s + b*c) ...
//           ... two stores ...
//       }
//   }
//
// Discriminator vs the 5-param rmsnorm (which is also caught by 3b):
// rope's if-body has ≥4 PtrLoads and NO lds_reduce calls.  Routing
// places this AFTER 3b, so rmsnorm wins when its lds_reduce-call
// signature matches.
//
// Returns 0 on success; non-zero means "doesn't match the 3c-1 shape".
fn amdgpu_lower_rope_f32_3c(uint64 fn_node, uint64 source,
                             uint64 kname_ptr, uint64 nl) -> uint64 {
    // ── shape: 5 params (in, out, cos, sin, m) ──────────────────
    uint64 n_params = 0
    uint64 wp = ast_child(fn_node)
    while wp != 0 {
        n_params = n_params + 1
        wp = ast_next(wp)
    }
    if n_params != 5 { return 1 }

    // ── shape: body Block has 3 stmts (i, j, If) ───────────────
    uint32 body = ast_data3(fn_node)
    if body == 0 { return 1 }
    if ast_kind(body) != 15 { return 1 }
    uint32 stmt0 = ast_child(body)
    if stmt0 == 0 || ast_kind(stmt0) != 10 { return 1 }
    uint32 stmt1 = ast_next(stmt0)
    if stmt1 == 0 || ast_kind(stmt1) != 10 { return 1 }
    uint32 stmt2 = ast_next(stmt1)
    if stmt2 == 0 || ast_kind(stmt2) != 13 { return 1 }
    if ast_next(stmt2) != 0 { return 1 }

    // ── if-body: count PtrLoads and check no lds_reduce calls. ──
    uint32 then_block = ast_data1(stmt2)
    if then_block == 0 || ast_kind(then_block) != 15 { return 1 }
    uint64 ptrload_count = 0
    uint64 ptrstore_count = 0
    uint32 walk = ast_child(then_block)
    while walk != 0 {
        if ast_kind(walk) == 41 { ptrload_count = ptrload_count + 1 }
        if ast_kind(walk) == 42 { ptrstore_count = ptrstore_count + 1 }
        if ast_kind(walk) == 10 {
            uint32 init = ast_child(walk)
            if init != 0 && ast_kind(init) == 35 {
                uint32 callee = ast_data1(init)
                if tok_matches(callee, "lds_reduce_sum_f32", 18) != 0 { return 1 }
                if tok_matches(callee, "lds_reduce_max_f32", 18) != 0 { return 1 }
            }
        }
        walk = ast_next(walk)
    }
    if ptrload_count < 4 { return 1 }
    if ptrstore_count < 2 { return 1 }

    // ── emit ISA ─────────────────────────────────────────────────
    // 55-dword sequence ported verbatim from `_emit_rope_f32_body`.
    // Block=64, grid=M (one WG per token).  Hardcoded D=128: two halves
    // each 64 elements; 64 lanes each pair (j, j+64).  Per lane:
    // load a, b, c, s; compute (a*c - b*s) and (a*s + b*c); store both.
    // gfx10 dword pairs verified via llvm-mc -mcpu=gfx1030.
    // New pair: v_fma_f32 VOP3 op 0x213 → 0x14B. v_fmac_f32 stable.
    asm_init()
    asm_u32_arch(0xF40C0100, 0xF40C0100); asm_u32_arch(0xF8000000, 0xFA000000) // s_load_b256/dwordx8
    asm_u32_arch(0xF4000300, 0xF4000300); asm_u32_arch(0xF8000020, 0xFA000020) // s_load_b32/dword
    asm_u32_arch(0xBF89FC07, 0xBF8CC07F) // s_waitcnt
    asm_u32     (0xBF090C0F)             // s_cmp_ge_u32 s15, s12
    asm_u32_arch(0xBFA2002D, 0xBF85002D) // s_cbranch_scc1 +45
    asm_u32_arch(0x840D890F, 0x8F0D890F) // s_lshl_b32 s13, s15, 9
    asm_u32_arch(0x30020082, 0x34020082) // v_lshlrev_b32 v1, 2, v0
    asm_u32     (0x4A02020D)             // v_add_nc_u32 v1, s13, v1
    asm_u32     (0x7E060280)
    asm_u32_arch(0xD7006A02, 0xD70F6A02); asm_u32(0x00020204)
    asm_u32_arch(0xD5207C03, 0xD5287D03); asm_u32(0x01AA0605)
    asm_u32     (0x7E0A0280)
    asm_u32_arch(0xD7006A04, 0xD70F6A04); asm_u32(0x00020206)
    asm_u32_arch(0xD5207C05, 0xD5287D05); asm_u32(0x01AA0A07)
    asm_u32_arch(0x840D880F, 0x8F0D880F) // s_lshl_b32 s13, s15, 8
    asm_u32_arch(0x30200082, 0x34200082) // v_lshlrev_b32 v16, 2, v0
    asm_u32     (0x4A20200D)             // v_add_nc_u32 v16, s13, v16
    asm_u32     (0x7E0E0280)
    asm_u32_arch(0xD7006A06, 0xD70F6A06); asm_u32(0x00022008)
    asm_u32_arch(0xD5207C07, 0xD5287D07); asm_u32(0x01AA0E09)
    asm_u32     (0x7E120280)
    asm_u32_arch(0xD7006A08, 0xD70F6A08); asm_u32(0x0002200A)
    asm_u32_arch(0xD5207C09, 0xD5287D09); asm_u32(0x01AA120B)
    asm_u32_arch(0xDC520000, 0xDC308000); asm_u32_arch(0x0A7C0002, 0x0A7D0002) // load a
    asm_u32_arch(0xDC520100, 0xDC308100); asm_u32_arch(0x0B7C0002, 0x0B7D0002) // load b (offset 256)
    asm_u32_arch(0xDC520000, 0xDC308000); asm_u32_arch(0x0C7C0006, 0x0C7D0006) // load c
    asm_u32_arch(0xDC520000, 0xDC308000); asm_u32_arch(0x0D7C0008, 0x0D7D0008) // load s
    asm_u32_arch(0xBF8903F7, 0xBF8C3F70) // s_waitcnt vmcnt(0)
    asm_u32     (0x101C1B0B)             // v_mul_f32 v14, v11, v13
    asm_u32_arch(0xD613000E, 0xD54B000E); asm_u32(0x843A190A) // v_fma_f32 v14, v10, v12, -v14
    asm_u32     (0x101E1B0A)             // v_mul_f32 v15, v10, v13
    asm_u32     (0x561E190B)             // v_fmac_f32 v15, v11, v12 (VOP2 stable)
    asm_u32_arch(0xDC6A0000, 0xDC708000); asm_u32_arch(0x007C0E04, 0x007D0E04) // store first
    asm_u32_arch(0xDC6A0100, 0xDC708100); asm_u32_arch(0x007C0F04, 0x007D0F04) // store second
    asm_u32_arch(0xBC7C0000, 0xBBFD0000) // s_waitcnt_vscnt
    asm_u32_arch(0xBFB00000, 0xBF810000) // s_endpgm

    // ── kernarg layout: 5 args × 16 bytes ────────────────────────
    uint64 args_desc = alloc(10 * 16)
    uint64 a0 = args_desc +  0;  unsafe { *(a0 as uint64) = 8 }
    uint64 a1 = args_desc +  8;  unsafe { *(a1 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a2 = args_desc + 16;  unsafe { *(a2 as uint64) = 8 }
    uint64 a3 = args_desc + 24;  unsafe { *(a3 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a4 = args_desc + 32;  unsafe { *(a4 as uint64) = 8 }
    uint64 a5 = args_desc + 40;  unsafe { *(a5 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a6 = args_desc + 48;  unsafe { *(a6 as uint64) = 8 }
    uint64 a7 = args_desc + 56;  unsafe { *(a7 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a8 = args_desc + 64;  unsafe { *(a8 as uint64) = 8 }
    uint64 a9 = args_desc + 72;  unsafe { *(a9 as uint64) = AMD_ARG_KIND_BY_VALUE }

    uint64 k_text_size = asm_text_len
    uint64 k_text_buf  = alloc(k_text_size)
    uint64 ci = 0
    while ci < k_text_size {
        uint64 sp = asm_text_buf + ci
        uint64 b = 0
        unsafe { *(sp as uint8) -> b }
        uint64 dp = k_text_buf + ci
        uint8 b8 = b
        unsafe { *(dp as uint8) = b8 }
        ci = ci + 1
    }

    // KD identical to legacy hand-tuned rope_f32: 16 SGPRs / 17 VGPRs,
    // USER_SGPR_COUNT=15, no LDS, rsrc1=0xE0AF0002 (vgpr_grant=2 → 24).
    uint64 rsrc1 = 0xE0AF0002
    uint64 rsrc2 = 0x0000009E
    uint64 rsrc3 = 0x00000010
    uint64 props = 0x0408

    kt_push(kname_ptr, nl, k_text_buf, k_text_size,
            args_desc, 5, 40,
            16, 17,
            rsrc1, rsrc2, rsrc3, props)
    return 0
}

// Phase 3b-4-N128 — softmax_causal_f32 parametric N=128.
fn amdgpu_lower_softmax_causal_f32_N128_3b(uint64 fn_node, uint64 source,
                                             uint64 kname_ptr, uint64 nl) -> uint64 {
    uint64 n_params = 0
    uint64 wp = ast_child(fn_node)
    while wp != 0 {
        n_params = n_params + 1
        wp = ast_next(wp)
    }
    if n_params != 4 { return 1 }

    uint32 body = ast_data3(fn_node)
    if body == 0 { return 1 }
    if ast_kind(body) != 15 { return 1 }

    uint64 saw_marker = 0
    uint32 walk = ast_child(body)
    while walk != 0 {
        if ast_kind(walk) == 35 {
            uint32 callee = ast_data1(walk)
            if tok_matches(callee, "softmax_causal_N128_marker", 26) != 0 { saw_marker = 1 }
        }
        if ast_kind(walk) == 10 {
            uint32 init = ast_child(walk)
            if init != 0 && ast_kind(init) == 35 {
                uint32 callee = ast_data1(init)
                if tok_matches(callee, "softmax_causal_N128_marker", 26) != 0 { saw_marker = 1 }
            }
        }
        walk = ast_next(walk)
    }
    if saw_marker == 0 { return 1 }

    uint64 args_desc = alloc(8 * 16)
    _emit_softmax_causal_f32_body_N(args_desc, 128)

    uint64 k_text_size = asm_text_len
    uint64 k_text_buf  = alloc(k_text_size)
    uint64 ci = 0
    while ci < k_text_size {
        uint64 sp = asm_text_buf + ci
        uint64 b = 0
        unsafe { *(sp as uint8) -> b }
        uint64 dp = k_text_buf + ci
        uint8 b8 = b
        unsafe { *(dp as uint8) = b8 }
        ci = ci + 1
    }

    uint64 rsrc1 = 0xE0AF0001
    uint64 rsrc2 = 0x0000009E
    uint64 rsrc3 = 0x00000010
    uint64 props = 0x0408

    kt_push_lds(kname_ptr, nl, k_text_buf, k_text_size,
                args_desc, 4, 32,
                16, 20,
                rsrc1, rsrc2, rsrc3, props,
                512)
    return 0
}

// Phase 3b-4 — softmax_causal_f32 (causal-masked softmax, N=256).
//
// Recognises a kernel of the form:
//
//   @kernel fn name(uint64 in_ptr, uint64 out_ptr, uint64 m, uint64 n) {
//       uint64 row  = block_idx_x()
//       uint64 lane = tid_local_x()
//       if row < m {
//           ...
//           f32 xm_in  = causal_mask_f32(x, lane, row)   // ← discriminator
//           f32 max_x  = lds_reduce_max_f32(xm_in)
//           ... f32 sum_ex = lds_reduce_sum_f32(...)
//           ...
//       }
//   }
//
// Discriminator vs 3b-2 (softmax_f32): presence of a `causal_mask_f32`
// Call.  Must run BEFORE 3b-2 in dispatch.
//
// Returns 0 on success; non-zero means "doesn't match the 3b-4 shape".
fn amdgpu_lower_softmax_causal_f32_3b(uint64 fn_node, uint64 source,
                                       uint64 kname_ptr, uint64 nl) -> uint64 {
    uint64 n_params = 0
    uint64 wp = ast_child(fn_node)
    while wp != 0 {
        n_params = n_params + 1
        wp = ast_next(wp)
    }
    if n_params != 4 { return 1 }

    uint32 body = ast_data3(fn_node)
    if body == 0 { return 1 }
    if ast_kind(body) != 15 { return 1 }
    uint32 stmt0 = ast_child(body)
    if stmt0 == 0 || ast_kind(stmt0) != 10 { return 1 }
    uint32 stmt1 = ast_next(stmt0)
    if stmt1 == 0 || ast_kind(stmt1) != 10 { return 1 }
    uint32 stmt2 = ast_next(stmt1)
    if stmt2 == 0 || ast_kind(stmt2) != 13 { return 1 }
    if ast_next(stmt2) != 0 { return 1 }

    // ── if-body must contain causal_mask_f32, lds_reduce_max_f32,
    //    and lds_reduce_sum_f32 calls. ─────────────────────────────
    uint32 then_block = ast_data1(stmt2)
    if then_block == 0 || ast_kind(then_block) != 15 { return 1 }
    uint64 saw_mask = 0
    uint64 saw_max = 0
    uint64 saw_sum = 0
    uint32 walk = ast_child(then_block)
    while walk != 0 {
        if ast_kind(walk) == 10 {
            uint32 init = ast_child(walk)
            if init != 0 && ast_kind(init) == 35 {
                uint32 callee = ast_data1(init)
                if tok_matches(callee, "causal_mask_f32",    15) != 0 { saw_mask = 1 }
                if tok_matches(callee, "lds_reduce_max_f32", 18) != 0 { saw_max = 1 }
                if tok_matches(callee, "lds_reduce_sum_f32", 18) != 0 { saw_sum = 1 }
            }
        }
        walk = ast_next(walk)
    }
    if saw_mask == 0 { return 1 }
    if saw_max == 0 { return 1 }
    if saw_sum == 0 { return 1 }

    // ── emit ISA via parametric helper at N=256 ──────────────────
    // Same path as parametric softmax_causal_f32_N128 lowerer.
    uint64 args_desc = alloc(8 * 16)
    _emit_softmax_causal_f32_body_N(args_desc, 256)

    uint64 k_text_size = asm_text_len
    uint64 k_text_buf  = alloc(k_text_size)
    uint64 ci = 0
    while ci < k_text_size {
        uint64 sp = asm_text_buf + ci
        uint64 b = 0
        unsafe { *(sp as uint8) -> b }
        uint64 dp = k_text_buf + ci
        uint8 b8 = b
        unsafe { *(dp as uint8) = b8 }
        ci = ci + 1
    }

    // KD: 16 SGPRs / 16 VGPRs (one more than softmax_f32 because the
    // mask uses v15), USER_SGPR_COUNT=15, LDS=1024, rsrc1=0xE0AF0001.
    uint64 rsrc1 = 0xE0AF0001
    uint64 rsrc2 = 0x0000009E
    uint64 rsrc3 = 0x00000010
    uint64 props = 0x0408

    kt_push_lds(kname_ptr, nl, k_text_buf, k_text_size,
                args_desc, 4, 32,
                16, 16,
                rsrc1, rsrc2, rsrc3, props,
                1024)
    return 0
}

// Phase 3c-D128 — rope at D=128 via parametric `_emit_rope_f32_body_D`.
//
// Discriminator: 5 params + rope_D128_marker() Call.  Routes BEFORE
// 3c-1 (legacy hardcoded-D rope).  The kernel name `rope_qwen3_f32`
// is what the runtime expects; emitted bytes match production
// `/tmp/rope_qwen3_f32.co`.
fn amdgpu_lower_rope_qwen3_f32_3c(uint64 fn_node, uint64 source,
                                    uint64 kname_ptr, uint64 nl) -> uint64 {
    uint64 n_params = 0
    uint64 wp = ast_child(fn_node)
    while wp != 0 {
        n_params = n_params + 1
        wp = ast_next(wp)
    }
    if n_params != 5 { return 1 }

    uint32 body = ast_data3(fn_node)
    if body == 0 { return 1 }
    if ast_kind(body) != 15 { return 1 }

    uint64 saw_marker = 0
    uint32 walk = ast_child(body)
    while walk != 0 {
        if ast_kind(walk) == 35 {
            uint32 callee = ast_data1(walk)
            if tok_matches(callee, "rope_D128_marker", 16) != 0 { saw_marker = 1 }
        }
        if ast_kind(walk) == 10 {
            uint32 init = ast_child(walk)
            if init != 0 && ast_kind(init) == 35 {
                uint32 callee = ast_data1(init)
                if tok_matches(callee, "rope_D128_marker", 16) != 0 { saw_marker = 1 }
            }
        }
        walk = ast_next(walk)
    }
    if saw_marker == 0 { return 1 }

    uint64 args_desc = alloc(8 * 16)
    _emit_rope_qwen3_f32_body(args_desc)

    uint64 k_text_size = asm_text_len
    uint64 k_text_buf  = alloc(k_text_size)
    uint64 ci = 0
    while ci < k_text_size {
        uint64 sp = asm_text_buf + ci
        uint64 b = 0
        unsafe { *(sp as uint8) -> b }
        uint64 dp = k_text_buf + ci
        uint8 b8 = b
        unsafe { *(dp as uint8) = b8 }
        ci = ci + 1
    }

    // KD identical to rope_qwen3_f32 blob: 18 SGPRs / 16 VGPRs,
    // kernarg=32 (4 buffer ptrs declared), no LDS, rsrc1=0xE0AF0001.
    uint64 rsrc1 = 0xE0AF0001
    uint64 rsrc2 = 0x0000009E
    uint64 rsrc3 = 0x00000010
    uint64 props = 0x0408

    kt_push(kname_ptr, nl, k_text_buf, k_text_size,
            args_desc, 4, 32,
            18, 16,
            rsrc1, rsrc2, rsrc3, props)
    return 0
}

// Phase 3c-2 — gemv_f32 (one lane per row, serial K-loop).
//
// Recognises a kernel of the form:
//
//   @kernel fn name(uint64 a_ptr, uint64 b_ptr, uint64 c_ptr,
//                   uint64 m, uint64 k_dim) {
//       uint64 row = tid_x()
//       if row < m {
//           f32 sum = 0.0
//           uint64 row_base = a_ptr + row * k_dim * 4
//           uint64 j = 0
//           while j < k_dim { ... sum += a*b ... j += 1 }
//           ... store sum to c[row] ...
//       }
//   }
//
// Discriminator: 5 params + body has exactly 2 stmts (row VarDecl +
// If — vs rmsnorm/rope's 3 body stmts) + if-body contains a While.
// First slice that recognises a *control-flow* shape (while loop).
//
// Returns 0 on success; non-zero means "doesn't match the 3c-2 shape".
fn amdgpu_lower_gemv_f32_3c(uint64 fn_node, uint64 source,
                             uint64 kname_ptr, uint64 nl) -> uint64 {
    uint64 n_params = 0
    uint64 wp = ast_child(fn_node)
    while wp != 0 {
        n_params = n_params + 1
        wp = ast_next(wp)
    }
    if n_params != 5 { return 1 }

    uint32 body = ast_data3(fn_node)
    if body == 0 { return 1 }
    if ast_kind(body) != 15 { return 1 }
    uint32 stmt0 = ast_child(body)
    if stmt0 == 0 || ast_kind(stmt0) != 10 { return 1 }   // VarDecl row
    uint32 stmt1 = ast_next(stmt0)
    if stmt1 == 0 || ast_kind(stmt1) != 13 { return 1 }   // If
    if ast_next(stmt1) != 0 { return 1 }                   // exactly 2 stmts

    // ── if-body must contain a While stmt (the K-loop). ─────────
    uint32 then_block = ast_data1(stmt1)
    if then_block == 0 || ast_kind(then_block) != 15 { return 1 }
    uint64 saw_while = 0
    uint32 walk = ast_child(then_block)
    while walk != 0 {
        if ast_kind(walk) == 14 { saw_while = 1 }
        walk = ast_next(walk)
    }
    if saw_while == 0 { return 1 }

    // ── emit ISA ─────────────────────────────────────────────────
    // 51-dword sequence ported verbatim from `_emit_gemv_f32_body`.
    // wg_id_x at s15 (USER_SGPR_COUNT=15); v_mad_u64_u32 computes
    // global row = wg*256 + lane.  K-loop iterates k_dim times
    // accumulating into v5; store to c[row].
    // gfx10 pairs verified via llvm-mc -mcpu=gfx1030.  New pairs this
    // slice: v_mad_u64_u32 (op 0x2FE → 0x176), v_cmpx_lt_u32_e64
    // (op 0xC9 → 0xD1), v_mul_lo_u32 (op 0x72C → 0x569), v_lshlrev_b64
    // (op 0x73C → 0x6FF), s_mov_b32 reg-imm-form (0x80 → 0x380), VOP3
    // v_add_nc_u32_e64 stable, SOPC stable, SOP2 s_add_u32 stable.
    asm_init()
    asm_u32_arch(0xF40C0100, 0xF40C0100); asm_u32_arch(0xF8000000, 0xFA000000) // s_load_b256/dwordx8
    asm_u32_arch(0xF4040300, 0xF4040300); asm_u32_arch(0xF8000020, 0xFA000020) // s_load_b64/dwordx2
    asm_u32_arch(0xBF89FC07, 0xBF8CC07F) // s_waitcnt
    asm_u32_arch(0xBE8E00FF, 0xBE8E03FF); asm_u32(0x00000100) // s_mov_b32 s14, 0x100
    asm_u32_arch(0xD6FE7C01, 0xD5767D01); asm_u32(0x04001C0F) // v_mad_u64_u32 v[1:2], null, s15, s14, v[0:1]
    asm_u32_arch(0xBE82007E, 0xBE82037E) // s_mov_b32 s2, exec_lo
    asm_u32_arch(0xD4D9007E, 0xD4D1007E); asm_u32(0x0002020A) // v_cmpx_lt_u32_e64 v0, s10
    asm_u32_arch(0xBFA50021, 0xBF880021) // s_cbranch_execz +33 → endpgm
    asm_u32_arch(0xD72C0003, 0xD5690003); asm_u32(0x00001901) // v_mul_lo_u32 v3, s12, v1
    asm_u32     (0x7E080280)             // v_mov_b32 v4, 0
    asm_u32_arch(0xD73C0003, 0xD6FF0003); asm_u32(0x00020682) // v_lshlrev_b64 v[3:4], 2, v[3:4]
    asm_u32_arch(0xD7006A03, 0xD70F6A03); asm_u32(0x00020604) // v_add_co_u32 v3, vcc_lo, s4, v3
    asm_u32_arch(0xD5207C04, 0xD5287D04); asm_u32(0x01AA0805) // v_add_co_ci_u32 v4, null, s5, v4, vcc_lo
    asm_u32     (0x7E0A0280)             // v_mov_b32 v5, 0
    asm_u32_arch(0xBE8E0080, 0xBE8E0380) // s_mov_b32 s14, 0  (counter init, SOP1 reg op shift)
    asm_u32     (0xBF090C0E)             // s_cmp_ge_u32 s14, s12  (SOPC stable)
    asm_u32_arch(0xBFA20010, 0xBF850010) // s_cbranch_scc1 +16 → store
    asm_u32     (0x7E0C0280)             // v_mov_b32 v6, 0
    asm_u32_arch(0xDC520000, 0xDC308000); asm_u32_arch(0x077C0003, 0x077D0003) // global_load_b32 v7, v3
    asm_u32_arch(0xDC520000, 0xDC308000); asm_u32(0x08060006) // global_load_b32 v8, v6, s[6:7]
    asm_u32_arch(0xBF8903F7, 0xBF8C3F70) // s_waitcnt vmcnt(0)
    asm_u32     (0x560A1107)             // v_fmac_f32 v5, v7, v8 (VOP2 stable)
    asm_u32_arch(0xD7006A03, 0xD70F6A03); asm_u32(0x00010903) // v_add_co_u32 v3, vcc_lo, v3, 4
    asm_u32_arch(0xD5207C04, 0xD5287D04); asm_u32(0x01AA0880) // v_add_co_ci_u32 v4, null, 0, v4, vcc_lo
    asm_u32     (0xD5250006); asm_u32(0x00010906) // v_add_nc_u32_e64 v6, v6, 4 (VOP3 op 0x125 stable)
    asm_u32     (0x800E810E)             // s_add_u32 s14, s14, 1 (SOP2 stable)
    asm_u32     (0xBF0A0C0E)             // s_cmp_lt_u32 s14, s12 (SOPC stable)
    asm_u32_arch(0xBFA2FFF1, 0xBF85FFF1) // s_cbranch_scc1 -15 → loop
    asm_u32_arch(0x30060282, 0x34060282) // v_lshlrev_b32 v3, 2, v1
    asm_u32_arch(0xDC6A0000, 0xDC708000); asm_u32(0x00080503) // global_store_b32 v6, v5, s[8:9]
    asm_u32_arch(0xBC7C0000, 0xBBFD0000) // s_waitcnt_vscnt
    asm_u32_arch(0xBFB00000, 0xBF810000) // s_endpgm

    uint64 args_desc = alloc(10 * 16)
    uint64 a0 = args_desc +  0;  unsafe { *(a0 as uint64) = 8 }
    uint64 a1 = args_desc +  8;  unsafe { *(a1 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a2 = args_desc + 16;  unsafe { *(a2 as uint64) = 8 }
    uint64 a3 = args_desc + 24;  unsafe { *(a3 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a4 = args_desc + 32;  unsafe { *(a4 as uint64) = 8 }
    uint64 a5 = args_desc + 40;  unsafe { *(a5 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a6 = args_desc + 48;  unsafe { *(a6 as uint64) = 8 }
    uint64 a7 = args_desc + 56;  unsafe { *(a7 as uint64) = AMD_ARG_KIND_BY_VALUE }
    uint64 a8 = args_desc + 64;  unsafe { *(a8 as uint64) = 8 }
    uint64 a9 = args_desc + 72;  unsafe { *(a9 as uint64) = AMD_ARG_KIND_BY_VALUE }

    uint64 k_text_size = asm_text_len
    uint64 k_text_buf  = alloc(k_text_size)
    uint64 ci = 0
    while ci < k_text_size {
        uint64 sp = asm_text_buf + ci
        uint64 b = 0
        unsafe { *(sp as uint8) -> b }
        uint64 dp = k_text_buf + ci
        uint8 b8 = b
        unsafe { *(dp as uint8) = b8 }
        ci = ci + 1
    }

    // KD identical to the legacy hand-tuned gemv_f32: 15 SGPRs / 9
    // VGPRs, USER_SGPR_COUNT=15, no LDS, rsrc1=0xE0AF0001.
    uint64 rsrc1 = 0xE0AF0001
    uint64 rsrc2 = 0x0000009E
    uint64 rsrc3 = 0x00000010
    uint64 props = 0x0408

    kt_push(kname_ptr, nl, k_text_buf, k_text_size,
            args_desc, 5, 40,
            15, 9,
            rsrc1, rsrc2, rsrc3, props)
    return 0
}

// Phase 3c-7 — gemv_coop_f32 (cooperative-row gemv, LDS reduce 32→1).
//
// Recognises a kernel of the form:
//
//   @kernel fn name(uint64 a_ptr, uint64 b_ptr, uint64 c_ptr,
//                   uint64 m, uint64 k_dim) {
//       uint64 row  = block_idx_x()
//       uint64 lane = tid_local_x()
//       if row < m {
//           ... while j<k_dim { partial += a*b; j+=32 } ...
//           f32 total = lds_reduce_sum_f32(partial)
//           if lane == 0 { c[row] = total }
//       }
//   }
//
// Discriminator vs 3c-2 (gemv_f32, also 5 params + While): presence of
// a `lds_reduce_sum_f32` Call.  Routing places 3c-7 BEFORE 3c-2 so
// the cooperative variant wins.  Production-critical kernel (qwen3
// hot path, 270× lm_head speedup); delegates to `_emit_gemv_coop_f32_body`
// for byte-identical ISA emission.
//
// Returns 0 on success; non-zero means "doesn't match the 3c-7 shape".
fn amdgpu_lower_gemv_coop_f32_3c(uint64 fn_node, uint64 source,
                                  uint64 kname_ptr, uint64 nl) -> uint64 {
    uint64 n_params = 0
    uint64 wp = ast_child(fn_node)
    while wp != 0 {
        n_params = n_params + 1
        wp = ast_next(wp)
    }
    if n_params != 5 { return 1 }

    uint32 body = ast_data3(fn_node)
    if body == 0 { return 1 }
    if ast_kind(body) != 15 { return 1 }

    // Recursive search for any `lds_reduce_sum_f32` Call in the body.
    uint64 saw_lds_reduce = 0
    uint32 walk = ast_child(body)
    while walk != 0 {
        if ast_kind(walk) == 35 {
            uint32 callee = ast_data1(walk)
            if tok_matches(callee, "lds_reduce_sum_f32", 18) != 0 { saw_lds_reduce = 1 }
        }
        if ast_kind(walk) == 10 {
            uint32 init = ast_child(walk)
            if init != 0 && ast_kind(init) == 35 {
                uint32 callee = ast_data1(init)
                if tok_matches(callee, "lds_reduce_sum_f32", 18) != 0 { saw_lds_reduce = 1 }
            }
        }
        if ast_kind(walk) == 13 {
            uint32 tblk = ast_data1(walk)
            if tblk != 0 && ast_kind(tblk) == 15 {
                uint32 tw = ast_child(tblk)
                while tw != 0 {
                    if ast_kind(tw) == 10 {
                        uint32 i2 = ast_child(tw)
                        if i2 != 0 && ast_kind(i2) == 35 {
                            uint32 c2 = ast_data1(i2)
                            if tok_matches(c2, "lds_reduce_sum_f32", 18) != 0 { saw_lds_reduce = 1 }
                        }
                    }
                    if ast_kind(tw) == 35 {
                        uint32 c2 = ast_data1(tw)
                        if tok_matches(c2, "lds_reduce_sum_f32", 18) != 0 { saw_lds_reduce = 1 }
                    }
                    tw = ast_next(tw)
                }
            }
        }
        walk = ast_next(walk)
    }
    if saw_lds_reduce == 0 { return 1 }

    // ── emit ISA ─────────────────────────────────────────────────
    // Delegate to the production-tested hand-tuned emit which uses
    // `_emit_lds_reduce_pow2` + runtime branch patching.  Byte-identical
    // to /tmp/gemv_coop_f32.co.
    uint64 args_desc = alloc(10 * 16)
    _emit_gemv_coop_f32_body(args_desc)

    uint64 k_text_size = asm_text_len
    uint64 k_text_buf  = alloc(k_text_size)
    uint64 ci = 0
    while ci < k_text_size {
        uint64 sp = asm_text_buf + ci
        uint64 b = 0
        unsafe { *(sp as uint8) -> b }
        uint64 dp = k_text_buf + ci
        uint8 b8 = b
        unsafe { *(dp as uint8) = b8 }
        ci = ci + 1
    }

    // KD identical to the gemv_coop_f32 blob: 18 SGPRs / 32 VGPRs,
    // USER_SGPR_COUNT=15, LDS=128 bytes (32 lanes × 4 B), rsrc1=
    // 0xE0AF0003 (vgpr_grant=3 → 32 VGPRs).
    uint64 rsrc1 = 0xE0AF0003
    uint64 rsrc2 = 0x0000009E
    uint64 rsrc3 = 0x00000010
    uint64 props = 0x0408

    kt_push_lds(kname_ptr, nl, k_text_buf, k_text_size,
                args_desc, 5, 40,
                18, 32,
                rsrc1, rsrc2, rsrc3, props,
                128)
    return 0
}

// Phase 3c-10 — attn_decode_f32 (single-stream decode-shape attention).
//
// Discriminator: 5 params + presence of `lds_reduce_max_f32` Call.
// Distinguishes from gemv_coop_* (sum reduce only) and softmax_f32
// (4 params).  Routing places 3c-10 BEFORE the gemv_coop family.
// Delegates ISA emission to `_emit_attn_decode_f32_body` (which calls
// `_emit_attn_decode_f32_body_kvr(args_desc, 2)` — kv_ratio=2 for
// Qwen3-0.6B).
fn amdgpu_lower_attn_decode_f32_3c(uint64 fn_node, uint64 source,
                                    uint64 kname_ptr, uint64 nl) -> uint64 {
    uint64 n_params = 0
    uint64 wp = ast_child(fn_node)
    while wp != 0 {
        n_params = n_params + 1
        wp = ast_next(wp)
    }
    if n_params != 5 { return 1 }

    uint32 body = ast_data3(fn_node)
    if body == 0 { return 1 }
    if ast_kind(body) != 15 { return 1 }

    // Recursive search for lds_reduce_max_f32.
    uint64 saw_max = 0
    uint32 walk = ast_child(body)
    while walk != 0 {
        if ast_kind(walk) == 35 {
            uint32 callee = ast_data1(walk)
            if tok_matches(callee, "lds_reduce_max_f32", 18) != 0 { saw_max = 1 }
        }
        if ast_kind(walk) == 10 {
            uint32 init = ast_child(walk)
            if init != 0 && ast_kind(init) == 35 {
                uint32 callee = ast_data1(init)
                if tok_matches(callee, "lds_reduce_max_f32", 18) != 0 { saw_max = 1 }
            }
        }
        if ast_kind(walk) == 13 {
            uint32 tblk = ast_data1(walk)
            if tblk != 0 && ast_kind(tblk) == 15 {
                uint32 tw = ast_child(tblk)
                while tw != 0 {
                    if ast_kind(tw) == 10 {
                        uint32 i2 = ast_child(tw)
                        if i2 != 0 && ast_kind(i2) == 35 {
                            uint32 c2 = ast_data1(i2)
                            if tok_matches(c2, "lds_reduce_max_f32", 18) != 0 { saw_max = 1 }
                        }
                    }
                    if ast_kind(tw) == 35 {
                        uint32 c2 = ast_data1(tw)
                        if tok_matches(c2, "lds_reduce_max_f32", 18) != 0 { saw_max = 1 }
                    }
                    tw = ast_next(tw)
                }
            }
        }
        walk = ast_next(walk)
    }
    if saw_max == 0 { return 1 }

    // ── emit ISA ─────────────────────────────────────────────────
    uint64 args_desc = alloc(10 * 16)
    _emit_attn_decode_f32_body(args_desc)

    uint64 k_text_size = asm_text_len
    uint64 k_text_buf  = alloc(k_text_size)
    uint64 ci = 0
    while ci < k_text_size {
        uint64 sp = asm_text_buf + ci
        uint64 b = 0
        unsafe { *(sp as uint8) -> b }
        uint64 dp = k_text_buf + ci
        uint8 b8 = b
        unsafe { *(dp as uint8) = b8 }
        ci = ci + 1
    }

    // KD identical to attn_decode_f32 blob: 18 SGPRs / 32 VGPRs,
    // USER_SGPR_COUNT=15, LDS=1024, rsrc1=0xE0AF0003, rsrc2=0x9E.
    uint64 rsrc1 = 0xE0AF0003
    uint64 rsrc2 = 0x0000009E
    uint64 rsrc3 = 0x00000010
    uint64 props = 0x0408

    kt_push_lds(kname_ptr, nl, k_text_buf, k_text_size,
                args_desc, 5, 40,
                18, 32,
                rsrc1, rsrc2, rsrc3, props,
                1024)
    return 0
}

// Phase 3c-13 — attn_decode_f32_batched (2D-grid batched attention).
//
// Discriminator: 5 params + lds_reduce_max_f32 Call + block_idx_y Call.
// Distinguishes from 3c-10 (single-stream, no batch dim) — runs BEFORE
// it.  Delegates ISA emission to `_emit_attn_decode_f32_batched_body`
// (KD: rsrc2=0x019E enables wg_id_y).
fn amdgpu_lower_attn_decode_f32_batched_3c(uint64 fn_node, uint64 source,
                                            uint64 kname_ptr, uint64 nl) -> uint64 {
    uint64 n_params = 0
    uint64 wp = ast_child(fn_node)
    while wp != 0 {
        n_params = n_params + 1
        wp = ast_next(wp)
    }
    if n_params != 5 { return 1 }

    uint32 body = ast_data3(fn_node)
    if body == 0 { return 1 }
    if ast_kind(body) != 15 { return 1 }

    uint64 saw_max = 0
    uint64 saw_block_y = 0
    uint32 walk = ast_child(body)
    while walk != 0 {
        if ast_kind(walk) == 35 {
            uint32 callee = ast_data1(walk)
            if tok_matches(callee, "lds_reduce_max_f32", 18) != 0 { saw_max = 1 }
            if tok_matches(callee, "block_idx_y",        11) != 0 { saw_block_y = 1 }
        }
        if ast_kind(walk) == 10 {
            uint32 init = ast_child(walk)
            if init != 0 && ast_kind(init) == 35 {
                uint32 callee = ast_data1(init)
                if tok_matches(callee, "lds_reduce_max_f32", 18) != 0 { saw_max = 1 }
                if tok_matches(callee, "block_idx_y",        11) != 0 { saw_block_y = 1 }
            }
        }
        if ast_kind(walk) == 13 {
            uint32 tblk = ast_data1(walk)
            if tblk != 0 && ast_kind(tblk) == 15 {
                uint32 tw = ast_child(tblk)
                while tw != 0 {
                    if ast_kind(tw) == 10 {
                        uint32 i2 = ast_child(tw)
                        if i2 != 0 && ast_kind(i2) == 35 {
                            uint32 c2 = ast_data1(i2)
                            if tok_matches(c2, "lds_reduce_max_f32", 18) != 0 { saw_max = 1 }
                            if tok_matches(c2, "block_idx_y",        11) != 0 { saw_block_y = 1 }
                        }
                    }
                    if ast_kind(tw) == 35 {
                        uint32 c2 = ast_data1(tw)
                        if tok_matches(c2, "lds_reduce_max_f32", 18) != 0 { saw_max = 1 }
                        if tok_matches(c2, "block_idx_y",        11) != 0 { saw_block_y = 1 }
                    }
                    tw = ast_next(tw)
                }
            }
        }
        walk = ast_next(walk)
    }
    if saw_max == 0 { return 1 }
    if saw_block_y == 0 { return 1 }

    // ── emit ISA ─────────────────────────────────────────────────
    uint64 args_desc = alloc(10 * 16)
    _emit_attn_decode_f32_batched_body(args_desc)

    uint64 k_text_size = asm_text_len
    uint64 k_text_buf  = alloc(k_text_size)
    uint64 ci = 0
    while ci < k_text_size {
        uint64 sp = asm_text_buf + ci
        uint64 b = 0
        unsafe { *(sp as uint8) -> b }
        uint64 dp = k_text_buf + ci
        uint8 b8 = b
        unsafe { *(dp as uint8) = b8 }
        ci = ci + 1
    }

    uint64 rsrc1 = 0xE0AF0003
    uint64 rsrc2 = 0x0000019E
    uint64 rsrc3 = 0x00000010
    uint64 props = 0x0408

    kt_push_lds(kname_ptr, nl, k_text_buf, k_text_size,
                args_desc, 5, 40,
                18, 32,
                rsrc1, rsrc2, rsrc3, props,
                1024)
    return 0
}

// Phase 3c-17 — attn_decode_f32_speck4 (multi-Q spec_K=4 attention).
//
// Discriminator: 5 params + lds_reduce_max + speck4_marker() Call.
// Routes BEFORE 3c-13 / 3c-10 so the speck4 marker wins.
fn amdgpu_lower_attn_decode_f32_speck4_3c(uint64 fn_node, uint64 source,
                                           uint64 kname_ptr, uint64 nl) -> uint64 {
    uint64 n_params = 0
    uint64 wp = ast_child(fn_node)
    while wp != 0 {
        n_params = n_params + 1
        wp = ast_next(wp)
    }
    if n_params != 5 { return 1 }

    uint32 body = ast_data3(fn_node)
    if body == 0 { return 1 }
    if ast_kind(body) != 15 { return 1 }

    uint64 saw_max = 0
    uint64 saw_marker = 0
    uint32 walk = ast_child(body)
    while walk != 0 {
        if ast_kind(walk) == 35 {
            uint32 callee = ast_data1(walk)
            if tok_matches(callee, "lds_reduce_max_f32", 18) != 0 { saw_max = 1 }
            if tok_matches(callee, "speck4_marker",      13) != 0 { saw_marker = 1 }
        }
        if ast_kind(walk) == 10 {
            uint32 init = ast_child(walk)
            if init != 0 && ast_kind(init) == 35 {
                uint32 callee = ast_data1(init)
                if tok_matches(callee, "lds_reduce_max_f32", 18) != 0 { saw_max = 1 }
                if tok_matches(callee, "speck4_marker",      13) != 0 { saw_marker = 1 }
            }
        }
        if ast_kind(walk) == 13 {
            uint32 tblk = ast_data1(walk)
            if tblk != 0 && ast_kind(tblk) == 15 {
                uint32 tw = ast_child(tblk)
                while tw != 0 {
                    if ast_kind(tw) == 10 {
                        uint32 i2 = ast_child(tw)
                        if i2 != 0 && ast_kind(i2) == 35 {
                            uint32 c2 = ast_data1(i2)
                            if tok_matches(c2, "lds_reduce_max_f32", 18) != 0 { saw_max = 1 }
                        }
                    }
                    if ast_kind(tw) == 35 {
                        uint32 c2 = ast_data1(tw)
                        if tok_matches(c2, "lds_reduce_max_f32", 18) != 0 { saw_max = 1 }
                    }
                    tw = ast_next(tw)
                }
            }
        }
        walk = ast_next(walk)
    }
    if saw_max == 0 { return 1 }
    if saw_marker == 0 { return 1 }

    uint64 args_desc = alloc(10 * 16)
    _emit_attn_decode_f32_speck4_body(args_desc)

    uint64 k_text_size = asm_text_len
    uint64 k_text_buf  = alloc(k_text_size)
    uint64 ci = 0
    while ci < k_text_size {
        uint64 sp = asm_text_buf + ci
        uint64 b = 0
        unsafe { *(sp as uint8) -> b }
        uint64 dp = k_text_buf + ci
        uint8 b8 = b
        unsafe { *(dp as uint8) = b8 }
        ci = ci + 1
    }

    uint64 rsrc1 = 0xE0AF0003
    uint64 rsrc2 = 0x0000019E
    uint64 rsrc3 = 0x00000010
    uint64 props = 0x0408

    kt_push_lds(kname_ptr, nl, k_text_buf, k_text_size,
                args_desc, 5, 40,
                18, 32,
                rsrc1, rsrc2, rsrc3, props,
                1024)
    return 0
}

// Phase 3c-26 — attn_decode_f32_14b (Qwen3-14B kv_ratio=5).
//
// Discriminator: 5 params + lds_reduce_max + attn_decode_14b_marker.
// Calls _emit_attn_decode_f32_body_kvr(args, 5) instead of the 0.6B
// kvr=2 wrapper, producing different scale + magic-number-divide
