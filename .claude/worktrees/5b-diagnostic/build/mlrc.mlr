                // Check if this is a struct arg
                uint64 saf_addr_c = arg_struct_flags_a + ii_a * 8
                uint64 saf_val_c = 0
                unsafe { *(saf_addr_c as uint64) -> saf_val_c }
                if saf_val_c != 0xFFFFFFFF && abi_struct_pass_by_val != 0 {
                    // Skip HFA structs — they were handled in the float pass
                    uint64 sflags_skip = struct_abi_flags(saf_val_c)
                    uint64 is_hfa_skip = sflags_skip & 1
                    if is_hfa_skip != 0 {
                        ii_a = ii_a + 1
                        continue
                    }
                    // Struct arg: load eightbytes into consecutive x registers
                    uint64 s_ssize_c = struct_total_size(saf_val_c)
                    if s_ssize_c > 16 {
                        // MEMORY class (>16 bytes): pass pointer in next x register
                        emit_a64_load_x0(arg_slots_base + ii_a * 8)
                        if call_int_idx != 0 {
                            emit_a64_mov(call_int_idx, 0)
                        }
                        call_int_idx = call_int_idx + 1
                    } else {
                    // Load struct pointer from temp slot
                    emit_a64_load_x0(arg_slots_base + ii_a * 8)
                    // Save pointer to temp_slot_0 since loading might clobber it
                    emit_a64_store_x0(temp_slot_0)
                    // Load first eightbyte: ldr xN, [x0, #0]
                    if call_int_idx == 0 {
                        emit_a64_ldr(0, 0, 0)
                    } else {
                        emit_a64_ldr(call_int_idx, 0, 0)
                    }
                    call_int_idx = call_int_idx + 1
                    if s_ssize_c > 8 && call_int_idx < 8 {
                        // Reload pointer from temp
                        emit_a64_load_x0(temp_slot_0)
                        // Load second eightbyte: ldr xN, [x0, #8]
                        emit_a64_ldr(call_int_idx, 0, 8)
                        call_int_idx = call_int_idx + 1
                    }
                    }
                } else {
                    emit_a64_load_x0(arg_slots_base + ii_a * 8)
                    if call_int_idx != 0 {
                        emit_a64_mov(call_int_idx, 0)
                    }
                    call_int_idx = call_int_idx + 1
                }
            }
            ii_a = ii_a + 1
        }
        // Reload x0 from first int arg slot if it was overwritten
        if call_int_idx > 1 {
            // Find the first integer arg and reload it
            uint64 ri_a = 0
            while ri_a < arg_count {
                uint64 ri_addr = arg_float_flags_a + ri_a * 8
                uint64 ri_val = 0
                unsafe { *(ri_addr as uint64) -> ri_val }
                if ri_val == 0 {
                    // Check if first int arg is a struct — reload eightbyte 0
                    uint64 ri_saf = arg_struct_flags_a + ri_a * 8
                    uint64 ri_sv = 0
                    unsafe { *(ri_saf as uint64) -> ri_sv }
                    if ri_sv != 0xFFFFFFFF && abi_struct_pass_by_val != 0 {
                        // Skip HFA structs — they don't use int regs
                        uint64 ri_hfa_flags = struct_abi_flags(ri_sv)
                        if (ri_hfa_flags & 1) != 0 {
                            ri_a = ri_a + 1
                            continue
                        }
                        uint64 ri_ss = struct_total_size(ri_sv)
                        if ri_ss > 16 {
                            // MEMORY class: pointer is the value to pass
                            emit_a64_load_x0(arg_slots_base + ri_a * 8)
                        } else {
                        // Struct: reload ptr and dereference
                        emit_a64_load_x0(arg_slots_base + ri_a * 8)
                        emit_a64_ldr(0, 0, 0)
                        }
                    } else {
                        emit_a64_load_x0(arg_slots_base + ri_a * 8)
                    }
                    break
                }
                ri_a = ri_a + 1
            }
        }

        // Push overflow args (9+) onto stack (AAPCS64: x0-x7 = first 8 args)
        uint64 stack_args = 0
        if arg_count > 8 {
            stack_args = arg_count - 8
            if (stack_args & 1) != 0 { stack_args = stack_args + 1 }
        }
        if stack_args > 0 {
            uint64 stack_bytes = stack_args * 8
            // sub sp, sp, #stack_bytes
            uint64 sub_insn = 0xD1000000 | (stack_bytes << 10) | (31 << 5) | 31
            emit_a64(sub_insn)
            // Store overflow args at [sp+0], [sp+8], ...
            uint64 real_overflow = arg_count - 8
            uint64 oi = 0
            while oi < real_overflow {
                // Load from temp slot (offset shifted by stack_bytes because sp moved)
                emit_a64_ldr(9, 31, a64_var_base + arg_slots_base + (8 + oi) * 8 + stack_bytes)
                emit_a64_str(9, 31, oi * 8)
                oi = oi + 1
            }
        }

        // If callee returns MEMORY-class struct, allocate sret area and load x8
        uint64 caller_sret_needed_a = 0
        uint64 caller_sret_area_a = 0
        uint64 caller_sret_si_a = fn_ret_struct_lookup(callee_tok)
        if caller_sret_si_a != 0xFFFFFFFF {
            uint64 caller_sret_c0_a = struct_abi_class0(caller_sret_si_a)
            if caller_sret_c0_a == 3 {
                caller_sret_needed_a = 1
                uint64 caller_ret_sz_a = struct_total_size(caller_sret_si_a)
                uint64 caller_ret_sl_a = (caller_ret_sz_a + 7) / 8
                caller_sret_area_a = var_count * 8
                uint64 csi_a = 0
                while csi_a < caller_ret_sl_a { var_count = var_count + 1; csi_a = csi_a + 1 }
                var_frame_size = var_count * 8
                uint64 csrem_a = var_frame_size & 15
                if csrem_a != 0 { var_frame_size = var_frame_size + 16 - csrem_a }
                // Load x8 = address of sret area on stack
                emit_a64_add_imm(8, 31, a64_var_base + caller_sret_area_a)
            }
        }

        // BL rel26 (placeholder, fixup needed)
        uint64 fixup_off = out_len
        emit_a64_bl(0)

        // Clean up overflow args from stack
        if stack_args > 0 {
            uint64 cleanup = stack_args * 8
            uint64 add_insn = 0x91000000 | (cleanup << 10) | (31 << 5) | 31
            emit_a64(add_insn)
        }

        // Set expr_is_float_a64 based on callee's return type
        uint64 wct_ret_a = callee_tok
        uint64 ret_fk_a = fn_ret_float_lookup(wct_ret_a)
        expr_is_float_a64 = ret_fk_a

        // Check if callee returns a struct
        uint64 ret_struct_si_a = fn_ret_struct_lookup(callee_tok)
        if ret_struct_si_a != 0xFFFFFFFF {
            uint64 ret_c0_caller_a = struct_abi_class0(ret_struct_si_a)
            if ret_c0_caller_a == 3 {
                // MEMORY class: data already written to caller_sret_area_a by callee
                // Point x0 at the sret area
                emit_a64_add_imm(0, 31, a64_var_base + caller_sret_area_a)
                expr_is_struct_a64 = ret_struct_si_a
            } else {
                // Check if this is an HFA return
                uint64 ret_sflags_c = struct_abi_flags(ret_struct_si_a)
                uint64 ret_is_hfa_c = ret_sflags_c & 1
                uint64 ret_ssize_a = struct_total_size(ret_struct_si_a)
                uint64 ret_sslots_a = (ret_ssize_a + 7) / 8
                uint64 ret_soff_a = var_count * 8
                uint64 rsi2_a = 0
                while rsi2_a < ret_sslots_a { var_count = var_count + 1; rsi2_a = rsi2_a + 1 }
                var_frame_size = var_count * 8
                uint64 rsrem_a = var_frame_size & 15
                if rsrem_a != 0 { var_frame_size = var_frame_size + 16 - rsrem_a }
                if ret_is_hfa_c != 0 {
                    // HFA return: store d/s registers into stack area
                    uint64 ret_hfa_count_c = ((ret_sflags_c >> 1) & 3) + 1
                    uint64 ret_hfa_type_c = (ret_sflags_c >> 3) & 3
                    uint64 rci = 0
                    while rci < ret_hfa_count_c {
                        if ret_hfa_type_c == 1 {
                            uint64 rcoff = rci * 8
                            emit_a64_store_dN(rci, ret_soff_a + rcoff)
                        } else {
                            uint64 rcoff = rci * 4
                            emit_a64_store_sN(rci, ret_soff_a + rcoff)
                        }
                        rci = rci + 1
                    }
                } else {
                // Eightbyte 0: store from x0
                emit_a64_str(0, 31, a64_var_base + ret_soff_a)
                if ret_ssize_a > 8 {
                    // Eightbyte 1: store from x1
                    emit_a64_str(1, 31, a64_var_base + ret_soff_a + 8)
                }
                }
                // Set x0 = pointer to struct area
                emit_a64_add_imm(0, 31, a64_var_base + ret_soff_a)
                expr_is_struct_a64 = ret_struct_si_a
            }
        }

        // @dynamic extern → record in the dyn-call table (M2a.3.b).
        // Note: aarch64 PLT lowering will need ADRP+LDR+BLR sequences,
        // not the simple BL used for local/extern calls. M2a.3.c /
        // M2a.4 will emit that when (and if) aarch64 becomes a dyn-link
        // target; for now we record the call-site offset so no arch-
        // specific emit bug goes unnoticed once the patcher lands.
        uint64 wct_dyn_a = callee_tok
        uint64 dyn_idx_a = dyn_sym_lookup(wct_dyn_a)
        if dyn_idx_a != 0xFFFFFFFF {
            dyn_call_record(fixup_off, dyn_idx_a)
            return
        }

        // If the callee is an extern fn, record a call site for a linker
        // relocation and skip the internal fixup (the BL's imm26 stays zero
        // until the linker patches it with R_AARCH64_CALL26).
        uint64 wct_ext_a = callee_tok
        uint64 ext_idx_a = extern_fn_lookup(wct_ext_a)
        if ext_idx_a != 0xFFFFFFFF {
            extern_call_record(fixup_off, ext_idx_a)
            return
        }

        // Record fixup (same table as x86_64 — resolve_fixups handles both)
        uint64 fentry = fixup_table + fixup_count * 8
        uint32 fo = fixup_off
        unsafe { *(fentry as uint32) = fo }
        uint64 fe4 = fentry + 4
        uint32 ct = callee_tok
        unsafe { *(fe4 as uint32) = ct }
        fixup_count = fixup_count + 1
        return
    }
}

// ---------------------------------------------------------------------------
// AArch64 statement codegen
// ---------------------------------------------------------------------------

fn gen_stmt_a64(uint64 node) {
    uint32 dbg_tok_sa = ast_tok(node)
    if dbg_tok_sa == 0 { dbg_tok_sa = ast_data1(node) }
    if dbg_tok_sa == 0 { dbg_tok_sa = ast_data2(node) }
    uint64 wdbg_sa = dbg_tok_sa
    if wdbg_sa != 0 { line_table_record(wdbg_sa) }

    uint32 kind = ast_kind(node)

    // Variable declaration
    if kind == 10 {
        uint32 name_tok = ast_data2(node)
        uint32 arr_size_tok = ast_data3(node)
        uint64 was = arr_size_tok
        uint32 struct_marker = ast_data4(node)
        uint64 wsm = struct_marker
        if was != 0 && wsm == 0 {
            uint64 arr_size = parse_int_token(was)
            uint32 type_tok_v = ast_data1(node)
            uint64 elem_size_v = type_tok_elem_size(type_tok_v)
            uint64 total_bytes = arr_size * elem_size_v
            uint64 n_slots = (total_bytes + 7) / 8
            uint64 arr_offset = var_count * 8
            uint64 si = 0
            while si < n_slots { var_count = var_count + 1; si = si + 1 }
            var_frame_size = var_count * 8
            uint64 arem2 = var_frame_size & 15
            if arem2 != 0 { var_frame_size = var_frame_size + 16 - arem2 }
            uint64 ptr_offset = var_declare(name_tok)
            arr_elem_register(name_tok, elem_size_v)
            arr_count_set_last(arr_size)
            emit_a64_add_imm(0, 31, a64_var_base + arr_offset)
            emit_a64_store_x0(ptr_offset)
            return
        }
        if wsm != 0 {
            uint64 sidx = wsm - 1
            // Struct initializer form: `StructName n = expr`
            uint32 sinit_a = ast_child(node)
            uint64 wsinit_a = sinit_a
            if wsinit_a != 0 && was == 0 {
                gen_expr_a64(wsinit_a)
                if expr_is_struct_a64 != 0xFFFFFFFF {
                    // Value semantics: copy struct to own stack area
                    uint64 copy_size_a = struct_total_size(sidx)
                    uint64 copy_slots_a = (copy_size_a + 7) / 8
                    uint64 copy_off_a = var_count * 8
                    uint64 csi_a = 0
                    while csi_a < copy_slots_a {
                        var_count = var_count + 1
                        csi_a = csi_a + 1
                    }
                    var_frame_size = var_count * 8
                    uint64 crem_a = var_frame_size & 15
                    if crem_a != 0 { var_frame_size = var_frame_size + 16 - crem_a }
                    // x0 = source pointer, save it
                    emit_a64_store_x0(temp_slot_0)
                    // Inline copy: qword-at-a-time
                    uint64 qi_a = 0
                    while qi_a < copy_slots_a {
                        emit_a64_load_x0(temp_slot_0)
                        uint64 qoff_a = qi_a * 8
                        // ldr x9, [x0, #qoff]
                        emit_a64_ldr(9, 0, qoff_a)
                        // str x9, [sp, #(a64_var_base + copy_off + qoff)]
                        emit_a64_str(9, 31, a64_var_base + copy_off_a + qoff_a)
                        qi_a = qi_a + 1
                    }
                    // Variable points to local copy
                    uint64 ptr_off_h = var_declare(name_tok)
                    emit_a64_add_imm(0, 31, a64_var_base + copy_off_a)
                    emit_a64_store_x0(ptr_off_h)
                    struct_var_register(name_tok, sidx)
                    expr_is_struct_a64 = 0xFFFFFFFF
                    return
                }
                // Non-struct init (heap pointer): just store
                uint64 ptr_off_h = var_declare(name_tok)
                emit_a64_store_x0(ptr_off_h)
                struct_var_register(name_tok, sidx)
                return
            }
            uint64 ssize = struct_total_size(sidx)
            // Struct array support: count from data3 (if set)
            uint64 count = 1
            if was != 0 { count = parse_int_token(was) }
            uint64 total_bytes = ssize * count
            uint64 n_slots = (total_bytes + 7) / 8
            uint64 struct_off = var_count * 8
            uint64 ssi = 0
            while ssi < n_slots { var_count = var_count + 1; ssi = ssi + 1 }
            var_frame_size = var_count * 8
            uint64 srem = var_frame_size & 15
            if srem != 0 { var_frame_size = var_frame_size + 16 - srem }
            uint64 ptr_off = var_declare(name_tok)
            emit_a64_add_imm(0, 31, a64_var_base + struct_off)
            emit_a64_store_x0(ptr_off)
            struct_var_register(name_tok, sidx)
            return
        }
        uint64 offset = var_declare(name_tok)
        uint32 type_tok_vd = ast_data1(node)
        uint64 wtype_a = tok_kind_at_raw(type_tok_vd)
        var_type_register(name_tok, wtype_a)
        uint32 init_child = ast_child(node)
        uint64 wic = init_child
        if wic != 0 {
            gen_expr_a64(wic)
            if is_float_type(wtype_a) != 0 {
                if is_f32_type(wtype_a) != 0 {
                    emit_a64_store_s0(offset)
                } else {
                    emit_a64_store_d0(offset)
                }
            } else {
                emit_a64_store_x0(offset)
            }
        }
        return
    }

    // Assignment
    if kind == 11 {
        uint32 name_tok = ast_data1(node)
        uint32 val_child = ast_child(node)
        uint64 wvc = val_child
        gen_expr_a64(wvc)
        // Struct assignment: copy bytes for value semantics
        if expr_is_struct_a64 != 0xFFFFFFFF {
            uint64 src_si_a = expr_is_struct_a64
            uint64 copy_size_as = struct_total_size(src_si_a)
            uint64 copy_slots_as = (copy_size_as + 7) / 8
            // x0 = source pointer, save it
            emit_a64_store_x0(temp_slot_0)
            // Get dest pointer from variable
            uint64 dest_off_as = var_lookup(name_tok)
            emit_a64_load_x0(dest_off_as)
            emit_a64_store_x0(temp_slot_1)
            // Copy qword-at-a-time
            uint64 qi_as = 0
            while qi_as < copy_slots_as {
                emit_a64_load_x0(temp_slot_0)
                uint64 qoff_as = qi_as * 8
                // ldr x9, [x0, #qoff]
                emit_a64_ldr(9, 0, qoff_as)
                emit_a64_load_x0(temp_slot_1)
                // str x9, [x0, #qoff]
                emit_a64_str(9, 0, qoff_as)
                qi_as = qi_as + 1
            }
            expr_is_struct_a64 = 0xFFFFFFFF
            return
        }
        uint64 offset = var_lookup(name_tok)
        if offset != 0xFFFFFFFF {
            // Check if this variable is float-typed
            uint64 vtype_as = var_type_lookup(name_tok)
            if is_float_type(vtype_as) != 0 {
                if is_f32_type(vtype_as) != 0 {
                    emit_a64_store_s0(offset)
                } else {
                    emit_a64_store_d0(offset)
                }
            } else {
                emit_a64_store_x0(offset)
            }
        } else {
            uint64 soff = static_lookup(name_tok)
            if soff != 0xFFFFFFFF {
                emit_a64_static_store(soff)
            }
        }
        return
    }

    // Return
    if kind == 12 {
        uint32 expr_child = ast_child(node)
        uint64 wec = expr_child
        uint32 second_idx_r = ast_data3(node)
        uint64 wsi_r = second_idx_r
        uint32 third_idx_r = ast_data4(node)
        uint64 wti_r = third_idx_r
        if wti_r != 0 && wsi_r != 0 {
            // 3-tuple return: first → x0, second → x1, third → x2
            gen_expr_a64(wec)
            emit_a64_str(0, 31, a64_var_base + temp_slot_0)
            gen_expr_a64(wsi_r)
            emit_a64_str(0, 31, a64_var_base + temp_slot_1)
            gen_expr_a64(wti_r)
            emit_a64(0xAA0003E2)          // mov x2, x0  (ORR x2, xzr, x0)
            // Reload second → x1
            emit_a64_ldr(0, 31, a64_var_base + temp_slot_1)
            emit_a64(0xAA0003E1)          // mov x1, x0  (ORR x1, xzr, x0)
            // Reload first → x0
            emit_a64_ldr(0, 31, a64_var_base + temp_slot_0)
        } else if wsi_r != 0 {
            // 2-tuple return: evaluate first into x0, stash in temp_slot_0,
            // evaluate second into x0, move to x1, reload first into x0.
            // On AAPCS64 x1 is a caller-saved arg/return reg so it flows
            // unchanged through the epilogue to the caller.
            gen_expr_a64(wec)
            emit_a64_str(0, 31, a64_var_base + temp_slot_0)
            gen_expr_a64(wsi_r)
            emit_a64(0xAA0003E1)          // mov x1, x0  (ORR x1, xzr, x0)
            emit_a64_ldr(0, 31, a64_var_base + temp_slot_0)
        } else if wec != 0 {
            gen_expr_a64(wec)
            // Struct return: load eightbytes or copy via sret
            if expr_is_struct_a64 != 0xFFFFFFFF {
                uint64 ret_si_ar = expr_is_struct_a64
                uint64 ret_sz_ar = struct_total_size(ret_si_ar)
                uint64 ret_c0_ar = struct_abi_class0(ret_si_ar)
                if ret_c0_ar == 3 {
                    // MEMORY class: copy struct data to sret buffer [x8]
                    // x0 = source pointer (from gen_expr)
                    emit_a64_mov(9, 0)    // x9 = source
                    // Load saved sret pointer from stack
                    emit_a64_ldr(10, 31, a64_var_base + sret_slot_a64) // x10 = dest (sret)
                    // qword copy loop
                    uint64 aqi_ret = 0
                    uint64 aqslots_ret = (ret_sz_ar + 7) / 8
                    while aqi_ret < aqslots_ret {
                        uint64 aqoff_ret = aqi_ret * 8
                        emit_a64_ldr(11, 9, aqoff_ret)   // x11 = [src + off]
                        emit_a64_str(11, 10, aqoff_ret)   // [dest + off] = x11
                        aqi_ret = aqi_ret + 1
                    }
                } else {
                    // Check if this is an HFA return
                    uint64 ret_sflags = struct_abi_flags(ret_si_ar)
                    uint64 ret_is_hfa = ret_sflags & 1
                    if ret_is_hfa != 0 {
                        // HFA return: load fields into consecutive d/s registers
                        uint64 ret_hfa_count = ((ret_sflags >> 1) & 3) + 1
                        uint64 ret_hfa_type = (ret_sflags >> 3) & 3
                        // x0 = pointer to struct data
                        emit_a64_mov(9, 0)
                        uint64 rhi = 0
                        while rhi < ret_hfa_count {
                            if ret_hfa_type == 1 {
                                uint64 rhoff = rhi * 8
                                emit_a64_load_dN_from_ptr(rhi, 9, rhoff)
                            } else {
                                uint64 rhoff = rhi * 4
                                emit_a64_load_sN_from_ptr(rhi, 9, rhoff)
                            }
                            rhi = rhi + 1
                        }
                    } else {
                    // Small struct: load eightbytes from pointer into x0/x1
                    // x0 = pointer to struct data
                    emit_a64_mov(9, 0)
                    // Load first eightbyte into x0
                    emit_a64_ldr(0, 9, 0)
                    if ret_sz_ar > 8 {
                        // Load second eightbyte into x1
                        emit_a64_ldr(1, 9, 8)
                    }
                    }
                }
                expr_is_struct_a64 = 0xFFFFFFFF
            }
        }
        // Jump to epilogue
        emit_a64_b(0)
        uint64 ret_patch = out_len - 4
        uint64 rentry = ret_fixups + ret_fixup_count * 4
        uint32 rp32 = ret_patch
        unsafe { *(rentry as uint32) = rp32 }
        ret_fixup_count = ret_fixup_count + 1
        return
    }

    // TupleDestruct: (T1 a, T2 b) = rhs_expr
    // Mirrors the x86_64 path: the RHS leaves (x0, x1) from a tuple call.
    if kind == 44 {
        uint32 name1_tok = ast_data2(node)
        uint32 name2_tok = ast_data4(node)
        uint64 off1 = var_declare(name1_tok)
        uint64 off2 = var_declare(name2_tok)
        uint32 rhs = ast_child(node)
        uint64 wrhs = rhs
        if wrhs != 0 {
            gen_expr_a64(wrhs)
            // Store x1 (second) first so the x0 caching isn't needed;
            // then store x0 (first) into slot 1.
            emit_a64_str(1, 31, a64_var_base + off2)
            emit_a64_store_x0(off1)
        }
        return
    }

    // TupleDestruct3: (T1 a, T2 b, T3 c) = rhs_expr
    if kind == 47 {
        uint32 name1_tok = ast_data2(node)
        uint32 name2_tok = ast_data4(node)
        uint32 name3_tok = ast_tok(node)
        uint64 off1 = var_declare(name1_tok)
        uint64 off2 = var_declare(name2_tok)
        uint64 off3 = var_declare(name3_tok)
        uint32 rhs = ast_child(node)
        uint64 wrhs = rhs
        if wrhs != 0 {
            gen_expr_a64(wrhs)
            // Store x2 (third) → slot3
            emit_a64_str(2, 31, a64_var_base + off3)
            // Store x1 (second) → slot2
            emit_a64_str(1, 31, a64_var_base + off2)
            // Store x0 (first) → slot1
            emit_a64_store_x0(off1)
        }
        return
    }

    // If/else
    if kind == 13 {
        uint32 cond = ast_child(node)
        uint64 wcond = cond
        gen_expr_a64(wcond)
        // cbz x0, else_target (placeholder)
        uint64 cbz_patch = out_len
        emit_a64_cbz(0, 0)
        // Then body
        uint32 then_idx = ast_data1(node)
        uint64 wthen = then_idx
        gen_block_a64(wthen)
        // b endif (placeholder)
        uint64 b_patch = out_len
        emit_a64_b(0)
        // Patch cbz to here
        uint64 else_target = out_len
        uint64 cbz_disp = else_target - cbz_patch
        patch_u32(cbz_patch, 0xB4000000 | (((cbz_disp / 4) & 0x7FFFF) << 5) | 0)
        // Else body
        uint32 else_idx = ast_data2(node)
        uint64 welse = else_idx
        if welse != 0 {
            uint32 else_kind = ast_kind(welse)
            if else_kind == 13 {
                gen_stmt_a64(welse)
            } else {
                gen_block_a64(welse)
            }
        }
        // Patch b to here
        uint64 endif_target = out_len
        uint64 b_disp = endif_target - b_patch
        patch_u32(b_patch, 0x14000000 | ((b_disp / 4) & 0x3FFFFFF))
        return
    }

    // Block: nested block of statements (used by for-loop desugaring)
    if kind == 15 {
        gen_block_a64(node)
        return
    }

    // While
    if kind == 14 {
        uint64 loop_start = out_len
        uint64 lentry = loop_stack + loop_depth * 16
        unsafe { *(lentry as uint64) = loop_start }
        uint64 lentry8 = lentry + 8
        unsafe { *(lentry8 as uint64) = break_fixup_count }
        loop_depth = loop_depth + 1

        uint32 cond = ast_child(node)
        uint64 wcond = cond
        gen_expr_a64(wcond)
        uint64 cbz_patch = out_len
        emit_a64_cbz(0, 0)
        uint32 body_idx = ast_data1(node)
        uint64 wbody = body_idx
        gen_block_a64(wbody)
        // b loop_start
        uint64 back_disp = loop_start - out_len
        emit_a64_b(back_disp & 0xFFFFFFFF)
        // Patch cbz to here
        uint64 loop_end = out_len
        uint64 fwd_disp = loop_end - cbz_patch
        patch_u32(cbz_patch, 0xB4000000 | (((fwd_disp / 4) & 0x7FFFF) << 5) | 0)
        // Patch break fixups
        loop_depth = loop_depth - 1
        uint64 lentry2 = loop_stack + loop_depth * 16 + 8
        uint64 saved_break_start = 0
        unsafe { *(lentry2 as uint64) -> saved_break_start }
        uint64 bi = saved_break_start
        while bi < break_fixup_count {
            uint64 bentry = break_fixups + bi * 4
            uint32 bpatch = 0
            unsafe { *(bentry as uint32) -> bpatch }
            uint64 wbp = bpatch
            uint64 bdisp = loop_end - wbp
            patch_u32(wbp, 0x14000000 | ((bdisp / 4) & 0x3FFFFFF))
            bi = bi + 1
        }
        break_fixup_count = saved_break_start
        return
    }

    // Break
    if kind == 17 {
        uint64 brk_off = out_len
        emit_a64_b(0)
        uint64 brk_entry = break_fixups + break_fixup_count * 4
        uint32 brk32 = brk_off
        unsafe { *(brk_entry as uint32) = brk32 }
        break_fixup_count = break_fixup_count + 1
        return
    }

    // Continue
    if kind == 18 {
        uint64 lentry3 = loop_stack + (loop_depth - 1) * 16
        uint64 cont_target = 0
        unsafe { *(lentry3 as uint64) -> cont_target }
        uint64 cont_disp = cont_target - out_len
        emit_a64_b(cont_disp & 0xFFFFFFFF)
        return
    }

    // Match statement
    if kind == 19 {
        uint32 scrutinee = ast_child(node)
        uint64 wscr = scrutinee
        gen_expr_a64(wscr)
        uint64 match_temp = var_count * 8
        var_count = var_count + 1
        var_frame_size = var_count * 8
        uint64 mrem = var_frame_size & 15
        if mrem != 0 { var_frame_size = var_frame_size + 16 - mrem }
        emit_a64_store_x0(match_temp)
        uint64 saved_break = break_fixup_count
        uint32 arm_idx = ast_data1(node)
        uint64 warm = arm_idx
        while warm != 0 {
            uint32 val_idx = ast_data1(warm)
            uint64 wval = val_idx
            uint64 is_wild = 0
            uint32 vk = ast_kind(wval)
            if vk == 32 {
                uint32 wild_tok = ast_data1(wval)
                uint64 wwt = wild_tok
                if tok_matches(wwt, "_", 1) != 0 { is_wild = 1 }
            }
            // For multi-pattern arms (p1, p2, p3 => ...) we emit a chain
            // of B.EQ body-label jumps, then a single B skip_arm for the
            // fall-through (no pattern matched). Capture the body-jumps
            // to patch after body emission.
            uint64 beq_patches = 0
            uint64 beq_count = 0
            uint64 skip_patch = 0
            if is_wild == 0 {
                beq_patches = alloc(64)
                uint64 pat = wval
                while pat != 0 {
                    uint32 pat_k_raw = ast_kind(pat)
                    uint64 pat_k = pat_k_raw
                    if pat_k == 52 {
                        write(2, "error: range patterns require the IR backend (drop --legacy)\n", 62)
                        exit(1)
                    }
                    gen_expr_a64(pat)
                    emit_a64_mov(9, 0)
                    emit_a64_load_x0(match_temp)
                    emit_a64_cmp(0, 9)
                    // B.EQ body (placeholder — cond = 0 = EQ)
                    uint64 beq_p = out_len
                    emit_a64(0x54000000)   // B.EQ +0 (patched)
                    uint64 slot = beq_patches + beq_count * 8
                    unsafe { *(slot as uint64) = beq_p }
                    beq_count = beq_count + 1
                    uint32 pnxt = ast_next(pat)
                    pat = pnxt
                }
                // None matched → jump to skip_arm.
                skip_patch = out_len
                emit_a64(0x14000000)   // B +0 (patched)
            }
            // Body label: patch every B.EQ to land here.
            uint64 body_addr = out_len
            uint64 ji = 0
            while ji < beq_count {
                uint64 slot = beq_patches + ji * 8
                uint64 jp = 0
                unsafe { *(slot as uint64) -> jp }
                uint64 boff = (body_addr - jp) >> 2
                patch_u32(jp, 0x54000000 | ((boff & 0x7FFFF) << 5))
                ji = ji + 1
            }
            // Execute body
            uint32 body_idx = ast_data2(warm)
            uint64 wbody = body_idx
            gen_block_a64(wbody)
            // B end_match (stored in break_fixups)
            uint64 end_patch = out_len
            emit_a64(0x14000000)  // B +0 (patched)
            uint64 bf = break_fixups + break_fixup_count * 4
            uint32 ep32 = end_patch
            unsafe { *(bf as uint32) = ep32 }
            break_fixup_count = break_fixup_count + 1
            // Patch the fall-through B (none matched) to skip_arm = here.
            if is_wild == 0 {
                uint64 skip_off = (out_len - skip_patch) >> 2
                patch_u32(skip_patch, 0x14000000 | (skip_off & 0x3FFFFFF))
            }
            uint32 next_arm = ast_next(warm)
            warm = next_arm
        }
        // Patch end-match jumps
        uint64 end_addr = out_len
        uint64 bi = saved_break
        while bi < break_fixup_count {
            uint64 bfe = break_fixups + bi * 4
            uint32 bp32 = 0
            unsafe { *(bfe as uint32) -> bp32 }
            uint64 wbp = bp32
            uint64 b_off = (end_addr - wbp) >> 2
            patch_u32(wbp, 0x14000000 | (b_off & 0x3FFFFFF))
            bi = bi + 1
        }
        break_fixup_count = saved_break
        return
    }

    // PtrLoad
    if kind == 41 {
        uint32 type_size = ast_data1(node)
        uint64 wts = type_size
        uint32 addr_child = ast_child(node)
        uint64 wa = addr_child
        gen_expr_a64(wa)
        if wts == 1 { emit_a64_ldrb(0, 0, 0) }
        else if wts == 2 { emit_a64_ldrh(0, 0, 0) }
        else if wts == 4 { emit_a64_ldr32(0, 0, 0) }
        else { emit_a64_ldr(0, 0, 0) }
        // Volatile barrier after load (DSB SY — ensures device read completes)
        uint32 vol_flag = ast_data3(node)
        uint64 wvf = vol_flag
        if wvf == 1 { emit_a64(0xD5033F9F) }
        uint32 dest_tok = ast_data2(node)
        uint64 doff = var_lookup(dest_tok)
        if doff != 0xFFFFFFFF {
            emit_a64_store_x0(doff)
        } else {
            uint64 soff = static_lookup(dest_tok)
            if soff != 0xFFFFFFFF { emit_a64_static_store(soff) }
        }
        return
    }

    // PtrStore
    if kind == 42 {
        uint32 type_size = ast_data1(node)
        uint64 wts = type_size
        uint32 val_child = ast_data2(node)
        uint64 wv = val_child
        gen_expr_a64(wv)
        emit_a64_store_x0(temp_slot_0)
        uint32 addr_child = ast_child(node)
        uint64 wa = addr_child
        gen_expr_a64(wa)
        emit_a64_mov(10, 0)
        emit_a64_load_x0(temp_slot_0)
        // Volatile barrier before store (DSB SY — ensures device write commits)
        uint32 vol_flag2 = ast_data3(node)
        uint64 wvf2 = vol_flag2
        if wvf2 == 1 { emit_a64(0xD5033BBF) }
        if wts == 1 { emit_a64_strb(0, 10, 0) }
        else if wts == 2 { emit_a64_strh(0, 10, 0) }
        else if wts == 4 { emit_a64_str32(0, 10, 0) }
        else { emit_a64_str(0, 10, 0) }
        return
    }

    // Indexed assignment (arr[i] = val): scale index by elem_size, store N bytes.
    if kind == 37 {
        uint32 idx_d3 = ast_data3(node)
        uint64 wd3 = idx_d3
        if wd3 == 1 {
            uint32 rhs_child = ast_data2(node)
            uint64 wrhs = rhs_child
            gen_expr_a64(wrhs)
            emit_a64_store_x0(temp_slot_0)
            uint32 idx_child = ast_child(node)
            uint64 wi = idx_child
            gen_expr_a64(wi)
            emit_a64_store_x0(temp_slot_1)
            uint32 arr_tok = ast_data1(node)
            uint64 warrtb = arr_tok
            uint64 arr_offset = var_lookup(arr_tok)
            uint64 elem_sz_w = arr_elem_lookup(arr_tok)
            if arr_offset != 0xFFFFFFFF {
                emit_a64_load_x0(arr_offset)
            } else {
                uint64 sasb = static_array_size_of(warrtb)
                if sasb != 0xFFFFFFFF && sasb != 0 {
                    uint64 soffb = static_lookup(warrtb)
                    emit_a64_static_lea(soffb)
                } else {
                    arr_offset = 0
                    emit_a64_load_x0(arr_offset)
                }
            }
            emit_a64_mov(10, 0)              // x10 = base
            emit_a64_load_x0(temp_slot_1)    // x0 = index
            uint64 shift_w = 0
            if elem_sz_w == 2 { shift_w = 1 }
            if elem_sz_w == 4 { shift_w = 2 }
            if elem_sz_w == 8 { shift_w = 3 }
            emit_a64_add_lsl(10, 10, 0, shift_w)  // x10 = base + (idx << shift)
            emit_a64_load_x0(temp_slot_0)    // x0 = value
            if elem_sz_w == 1 {
                emit_a64_strb(0, 10, 0)
            } else if elem_sz_w == 2 {
                emit_a64_strh(0, 10, 0)
            } else if elem_sz_w == 4 {
                emit_a64_str32(0, 10, 0)
            } else {
                emit_a64_str(0, 10, 0)
            }
            return
        }
    }

    // Field assignment (var.field = val)
    if kind == 36 {
        uint32 fa_d4 = ast_data4(node)
        uint64 wfad4 = fa_d4
        if wfad4 == 1 {
            uint32 fa_child = ast_child(node)
            uint64 wfachild = fa_child
            uint32 field_tok = ast_data2(node)
            uint32 val_node = ast_data3(node)
            uint64 wval = val_node

            // Struct array element field write: arr[i].field = val
            if wfachild != 0 {
                uint32 cfk_aw = ast_kind(wfachild)
                uint64 wcfk_aw = cfk_aw
                if wcfk_aw == 37 {
                    uint32 ai_tok_aw = ast_data1(wfachild)
                    uint64 wait_aw = ai_tok_aw
                    uint64 sia_aw = struct_var_lookup(ai_tok_aw)
                    if sia_aw != 0xFFFFFFFF {
                        uint64 stride_aw = struct_total_size(sia_aw)
                        uint64 foff_aw = struct_field_offset(sia_aw, field_tok)
                        uint64 fsz_aw = struct_field_size(sia_aw, field_tok)
                        // Evaluate value → save to temp_slot_0
                        gen_expr_a64(wval)
                        emit_a64_store_x0(temp_slot_0)
                        // Evaluate index → x0
                        uint32 idx_ch_aw = ast_child(wfachild)
                        uint64 widx_aw = idx_ch_aw
                        gen_expr_a64(widx_aw)
                        // Multiply by stride
                        emit_a64_mov_imm(10, stride_aw)
                        uint64 mulinsn2 = 0x9B007C00 | (10 << 16) | (0 << 5) | 0
                        emit_a64(mulinsn2)
                        emit_a64_mov(11, 0)
                        // Load base address
                        uint64 aoff_aw = var_lookup(wait_aw)
                        if aoff_aw != 0xFFFFFFFF {
                            emit_a64_load_x0(aoff_aw)
                        }
                        // Addr = base + x11 + foff
                        emit_a64_add(0, 0, 11)
                        if foff_aw != 0 { emit_a64_add_imm(0, 0, foff_aw) }
                        emit_a64_mov(10, 0)
                        emit_a64_load_x0(temp_slot_0)
                        if fsz_aw == 1 { emit_a64_strb(0, 10, 0) }
                        else if fsz_aw == 2 { emit_a64_strh(0, 10, 0) }
                        else if fsz_aw == 4 { emit_a64_str32(0, 10, 0) }
                        else { emit_a64_str(0, 10, 0) }
                        return
                    }
                }
            }

            // Nested struct field write: child is another FieldAccess
            if wfachild != 0 {
                uint32 cfk_nwa = ast_kind(wfachild)
                uint64 wcfk_nwa = cfk_nwa
                if wcfk_nwa == 36 {
                    gen_expr_a64(wval)
                    if expr_is_float_a64 == 1 {
                        // fmov x0, d0
                        emit_a64(0x9E660000)
                    }
                    if expr_is_float_a64 == 2 {
                        // fmov w0, s0
                        emit_a64(0x1E260000)
                    }
                    emit_a64_store_x0(temp_slot_0)
                    gen_expr_a64(wfachild)
                    uint64 nsi_wa = expr_is_struct_a64
                    if nsi_wa != 0xFFFFFFFF {
                        uint64 nfoff_wa = struct_field_offset(nsi_wa, field_tok)
                        uint64 nfsz_wa = struct_field_size(nsi_wa, field_tok)
                        if nfoff_wa != 0 {
                            emit_a64_add_imm(0, 0, nfoff_wa)
                        }
                        emit_a64_mov(10, 0)
                        emit_a64_load_x0(temp_slot_0)
                        if nfsz_wa == 1 { emit_a64_strb(0, 10, 0) }
                        else if nfsz_wa == 2 { emit_a64_strh(0, 10, 0) }
                        else if nfsz_wa == 4 { emit_a64_str32(0, 10, 0) }
                        else { emit_a64_str(0, 10, 0) }
                    }
                    return
                }
            }

            uint32 obj_tok = 0
            if wfachild != 0 {
                uint32 fack = ast_kind(wfachild)
                uint64 wfack = fack
                if wfack == 32 {
                    obj_tok = ast_data1(wfachild)
                }
            }
            // Device field write
            if obj_tok != 0 {
                uint64 wdtwa = obj_tok
                uint64 dev_idx_wa = device_lookup(wdtwa)
                if dev_idx_wa != 0xFFFFFFFF {
                    uint64 wftwa = field_tok
                    uint64 dev_off_wa = device_field_offset_of(dev_idx_wa, wftwa)
                    if dev_off_wa != 0xFFFFFFFF {
                        uint64 dev_sz_wa = device_field_size_of(dev_idx_wa, wftwa)
                        uint64 dev_addr_wa = device_base(dev_idx_wa) + dev_off_wa
                        // Evaluate value to x0
                        gen_expr_a64(wval)
                        emit_a64_mov(1, 0)
                        // x0 = address
                        emit_a64_mov_imm(0, dev_addr_wa)
                        // DSB SY before store
                        emit_a64(0xD5033F9F)
                        if dev_sz_wa == 1 { emit_a64_strb(1, 0, 0) }
                        else if dev_sz_wa == 2 { emit_a64_strh(1, 0, 0) }
                        else if dev_sz_wa == 4 { emit_a64_str32(1, 0, 0) }
                        else { emit_a64_str(1, 0, 0) }
                        return
                    }
                }
            }
            gen_expr_a64(wval)
            uint64 si = struct_var_lookup(obj_tok)
            if si != 0xFFFFFFFF {
                // Check if field is a float type
                uint64 fftk_w = struct_field_type_kind_by_tok(si, field_tok)
                if fftk_w == 96 {
                    // f64 field: value is in d0, save to temp, compute addr, store
                    emit_a64_store_d0(temp_slot_0)
                    uint64 var_off = var_lookup(obj_tok)
                    if var_off == 0xFFFFFFFF { var_off = 0 }
                    uint64 foff = struct_field_offset(si, field_tok)
                    emit_a64_load_x0(var_off)
                    if foff != 0 { emit_a64_add_imm(0, 0, foff) }
                    emit_a64_mov(10, 0)
                    emit_a64_load_d0(temp_slot_0)
                    // str d0, [x10, #0]
                    emit_a64_store_dN_to_ptr(0, 10, 0)
                    return
                }
                if fftk_w == 95 {
                    // f32 field: value is in s0, save to temp, compute addr, store
                    emit_a64_store_s0(temp_slot_0)
                    uint64 var_off = var_lookup(obj_tok)
                    if var_off == 0xFFFFFFFF { var_off = 0 }
                    uint64 foff = struct_field_offset(si, field_tok)
                    emit_a64_load_x0(var_off)
                    if foff != 0 { emit_a64_add_imm(0, 0, foff) }
                    emit_a64_mov(10, 0)
                    emit_a64_load_s0(temp_slot_0)
                    // str s0, [x10, #0]
                    emit_a64_store_sN_to_ptr(0, 10, 0)
                    return
                }
                emit_a64_store_x0(temp_slot_0)
                uint64 var_off = var_lookup(obj_tok)
                if var_off == 0xFFFFFFFF { var_off = 0 }
                uint64 foff = struct_field_offset(si, field_tok)
                uint64 fsz = struct_field_size(si, field_tok)
                emit_a64_load_x0(var_off)
                if foff != 0 { emit_a64_add_imm(0, 0, foff) }
                emit_a64_mov(10, 0)
                emit_a64_load_x0(temp_slot_0)
                if fsz == 1 { emit_a64_strb(0, 10, 0) }
                else if fsz == 2 { emit_a64_strh(0, 10, 0) }
                else if fsz == 4 { emit_a64_str32(0, 10, 0) }
                else { emit_a64_str(0, 10, 0) }
            } else {
                emit_a64_store_x0(temp_slot_0)
            }
            return
        }
    }

    // Inline assembly — see x86_64 gen_stmt for the constraint contract.
    if kind == 43 {
        uint32 cons_head = ast_data3(node)
        uint64 wch_a = cons_head

        // Inputs: `ldr xN, [sp, #slot]`
        uint64 wci = wch_a
        while wci != 0 {
            uint32 ck = ast_data1(wci)
            if ck == 0 {
                uint32 rtok = ast_data2(wci)
                uint32 vtok = ast_data3(wci)
                uint64 wrtok = rtok
                uint64 wvtok = vtok
                uint64 rcode = a64_reg_code(wrtok)
                uint64 voff  = var_lookup(wvtok)
                if rcode != 0xFFFF && voff != 0xFFFFFFFF {
                    emit_a64_ldr(rcode, 31, a64_var_base + voff)
                }
            }
            uint32 nxti = ast_next(wci)
            wci = nxti
        }

        uint32 single_tok = ast_data1(node)
        uint64 ws = single_tok
        if ws != 0 {
            asm_emit_a64(ws)
        }
        uint32 child_str = ast_child(node)
        uint64 wcs = child_str
        while wcs != 0 {
            uint32 stk = ast_data1(wcs)
            uint64 wstk = stk
            asm_emit_a64(wstk)
            uint32 nxt = ast_next(wcs)
            wcs = nxt
        }

        // Outputs: `str xN, [sp, #slot]`
        uint64 wco = wch_a
        while wco != 0 {
            uint32 ck2 = ast_data1(wco)
            if ck2 == 1 {
                uint32 rtok2 = ast_data2(wco)
                uint32 vtok2 = ast_data3(wco)
                uint64 wrtok2 = rtok2
                uint64 wvtok2 = vtok2
                uint64 rcode2 = a64_reg_code(wrtok2)
                uint64 voff2  = var_lookup(wvtok2)
                if rcode2 != 0xFFFF && voff2 != 0xFFFFFFFF {
                    emit_a64_str(rcode2, 31, a64_var_base + voff2)
                }
            }
            uint32 nxto = ast_next(wco)
            wco = nxto
        }
        return
    }

    // Expression statement
    if kind == 16 {
        uint32 expr_child = ast_child(node)
        uint64 wec = expr_child
        gen_expr_a64(wec)
        return
    }

    // Defer (51): legacy ARM64 codegen doesn't implement defer. Fail
    // loudly so users drop --legacy and use the IR backend where it
    // works.
    if kind == 51 {
        write(2, "error: `defer` requires the IR backend (drop --legacy)\n", 56)
        exit(1)
    }
}

fn gen_block_a64(uint64 block_node) {
    uint32 child = ast_child(block_node)
    uint64 wchild = child
    while wchild != 0 {
        gen_stmt_a64(wchild)
        uint32 nxt = ast_next(wchild)
        wchild = nxt
    }
}

// ---------------------------------------------------------------------------
// AArch64 ELF header emission
// ---------------------------------------------------------------------------

fn emit_elf_header_a64() {
    emit_byte(0x7F); emit_byte(69); emit_byte(76); emit_byte(70)
    emit_byte(2); emit_byte(1); emit_byte(1); emit_byte(0)
    uint64 i = 0
    while i < 8 { emit_byte(0); i = i + 1 }
    emit_u16_le(2)
    emit_u16_le(0xB7)
    emit_u32_le(1)
    emit_u64_le(0)
    emit_u64_le(64)
    emit_u64_le(0)
    emit_u32_le(0)
    emit_u16_le(64)
    emit_u16_le(56)
    emit_u16_le(1)
    emit_u16_le(64)
    emit_u16_le(0)
    emit_u16_le(0)
}

fn emit_program_header_a64(uint64 text_size) {
    uint64 total = 120 + text_size
    emit_u32_le(1)
    emit_u32_le(7)
    emit_u64_le(0)
    emit_u64_le(0x400000)
    emit_u64_le(0x400000)
    emit_u64_le(total)
    emit_u64_le(total)
    emit_u64_le(0x10000)
}

// ---------------------------------------------------------------------------
// AArch64 function codegen (prologue + body + epilogue)
// ---------------------------------------------------------------------------

@export
fn gen_function_a64(uint64 fn_node) {
    uint32 name_tok = ast_data1(fn_node)

    // Check annotation flags: bit 0 = noreturn, bit 1 = naked, bit 3 = extern
    uint32 ann_flags = ast_data4(fn_node)
    uint64 is_naked = ann_flags & 2
    uint64 is_extern_a = ann_flags & 8

    // Extern declarations have no body — skip codegen.
    if is_extern_a != 0 { return }
    uint32 body_check_a = ast_data3(fn_node)
    if body_check_a == 0 { return }

    // Leaf function optimization disabled for now — needs register allocator
    uint64 is_leaf = 0
    uint64 is_noreturn = ann_flags & 1

    // Overflow arg patch tracking (for functions with >8 params)
    uint64[16] a64_overflow_patches
    uint64 a64_overflow_patch_count = 0

    var_reset()
    expr_is_float_a64 = 0
    temp_slot_0 = var_count * 8
    var_count = var_count + 1
    temp_slot_1 = var_count * 8
    var_count = var_count + 1
    var_frame_size = var_count * 8
    uint64 rem0 = var_frame_size & 15
    if rem0 != 0 { var_frame_size = var_frame_size + 16 - rem0 }

    fn_register(name_tok, out_len)

    // Register float return type if applicable
    uint32 ret_type_tok_a = ast_data2(fn_node)
    uint64 wrt_a = ret_type_tok_a
    if wrt_a != 0 {
        uint64 ret_kind_a = tok_kind_at_raw(wrt_a)
        if ret_kind_a == 96 { fn_ret_float_register(name_tok, 1) }
        if ret_kind_a == 95 { fn_ret_float_register(name_tok, 2) }
        // Register struct return type if applicable
        uint64 ret_si_a = struct_lookup(wrt_a)
        if ret_si_a != 0xFFFFFFFF {
            fn_ret_struct_register(name_tok, ret_si_a)
        }
    }

    // Check if return type is a MEMORY-class struct (needs sret via x8)
    sret_slot_a64 = 0xFFFFFFFF
    if wrt_a != 0 {
        uint64 sret_si_a = struct_lookup(wrt_a)
        if sret_si_a != 0xFFFFFFFF {
            uint64 sret_c0_a = struct_abi_class0(sret_si_a)
            if sret_c0_a == 3 {
                // Reserve a stack slot for the x8 sret pointer
                sret_slot_a64 = var_count * 8
                var_count = var_count + 1
                var_frame_size = var_count * 8
                uint64 sret_rem_a = var_frame_size & 15
                if sret_rem_a != 0 { var_frame_size = var_frame_size + 16 - sret_rem_a }
            }
        }
    }

    // For main: platform-specific _start trampoline
    uint64 wnt_a64 = name_tok
    if tok_matches(wnt_a64, "main", 4) != 0 && target_os == 2 && freestanding == 0 {
        // All 13 IAT entries are loader-resolved. Call GetCommandLineA directly.
        emit_a64_win_call_iat(7)       // GetCommandLineA → x0 = cmdline
        uint64 argv_off_w = static_lookup_by_name("cli_argv", 8)
        if argv_off_w != 0xFFFFFFFF {
            emit_a64_static_store(argv_off_w)
        }
        // Set cli_argc = 0xFFFFFFFF as "needs parsing" sentinel
        emit_a64_mov_imm(0, 0xFFFFFFFF)
        uint64 argc_off_w = static_lookup_by_name("cli_argc", 8)
        if argc_off_w != 0xFFFFFFFF {
            emit_a64_static_store(argc_off_w)
        }
    }
    if tok_matches(wnt_a64, "main", 4) != 0 && target_os != 2 && freestanding == 0 {
        if target_os == 1 {
            // macOS Mach-O: _main receives argc in x0, argv in x1
            uint64 argc_off_mac = static_lookup_by_name("cli_argc", 8)
            if argc_off_mac != 0xFFFFFFFF {
                emit_a64_static_store(argc_off_mac)  // store x0 (argc)
            }
            emit_a64_mov(0, 1)  // x0 = argv (from x1)
            uint64 argv_off_mac = static_lookup_by_name("cli_argv", 8)
            if argv_off_mac != 0xFFFFFFFF {
                emit_a64_static_store(argv_off_mac)
            }
        } else {
            // Linux/Android ELF: argc/argv on stack. [SP]=argc, [SP+8]=&argv[0]
            emit_a64_ldr(0, 31, 0)
            uint64 argc_off_a64 = static_lookup_by_name("cli_argc", 8)
            if argc_off_a64 != 0xFFFFFFFF {
                emit_a64_static_store(argc_off_a64)
            }
            emit_a64_add_imm(0, 31, 8)
            uint64 argv_off_a64 = static_lookup_by_name("cli_argv", 8)
            if argv_off_a64 != 0xFFFFFFFF {
                emit_a64_static_store(argv_off_a64)
            }
        }
        // Compute envp: on Linux/Android = sp + 8 + (argc+1)*8
        // On macOS, envp is apple[0] which comes after argv NULL terminator
        // but argc/argv were passed as function params, not on stack.
        // For macOS, compute from the cli_argv static: envp = argv + (argc+1)*8
        uint64 envp_off_a64 = static_lookup_by_name("cli_envp", 8)
        if envp_off_a64 != 0xFFFFFFFF {
            if target_os == 1 {
                // macOS: envp = argv + (argc+1)*8
                uint64 argc_off_env = static_lookup_by_name("cli_argc", 8)
                if argc_off_env != 0xFFFFFFFF { emit_a64_static_load(argc_off_env) }
                emit_a64_mov(9, 0)               // x9 = argc
                emit_a64_add_imm(9, 9, 1)        // x9 = argc + 1
                emit_a64_mov_imm(10, 8)
                emit_a64_mul(9, 9, 10)            // x9 = (argc+1)*8
                uint64 argv_off_env = static_lookup_by_name("cli_argv", 8)
                if argv_off_env != 0xFFFFFFFF { emit_a64_static_load(argv_off_env) }
                emit_a64_add(0, 0, 9)             // x0 = argv + (argc+1)*8 = envp
            } else {
                // Linux/Android: envp = sp + 8 + (argc+1)*8
                emit_a64_ldr(9, 31, 0)            // x9 = argc
                emit_a64_add_imm(9, 9, 1)
                emit_a64_mov_imm(10, 8)
                emit_a64_mul(9, 9, 10)
                emit_a64_add_imm(0, 31, 8)        // x0 = sp + 8
                emit_a64_add(0, 0, 9)
            }
            emit_a64_static_store(envp_off_a64)
        }
    }

    // Clear per-function slice table
    slice_len_count = 0

    // Parse params
    uint32 first_param = ast_child(fn_node)
    uint64 wparam = first_param
    while wparam != 0 {
        uint32 pk = ast_kind(wparam)
        if pk == 3 {
            uint32 param_name = ast_data2(wparam)
            uint64 ptr_off_a = var_declare(param_name)
            // Register float type for float-typed params
            uint32 param_type_reg_a = ast_data1(wparam)
            uint64 pt_kind_a = tok_kind_at_raw(param_type_reg_a)
            if is_float_type(pt_kind_a) != 0 {
                var_type_register(param_name, pt_kind_a)
            }
            // Slice parameter: also reserve a length slot (no name)
            uint32 pflag_a = ast_data4(wparam)
            uint64 wpflag_a = pflag_a
            if wpflag_a == 1 {
                uint64 len_off_a = var_count * 8
                var_count = var_count + 1
                var_frame_size = var_count * 8
                uint64 srem_spa = var_frame_size & 15
                if srem_spa != 0 { var_frame_size = var_frame_size + 16 - srem_spa }
                slice_len_register(ptr_off_a, len_off_a)
            }
            // If the param's type is a struct name, register it as a struct var
            uint32 param_type = ast_data1(wparam)
            uint64 wpt = param_type
            uint64 psi = struct_lookup(wpt)
            if psi != 0xFFFFFFFF {
                struct_var_register(param_name, psi)
            }
        }
        uint32 pnxt = ast_next(wparam)
        wparam = pnxt
    }

    // Prologue — for large frames (>4080) we split: pre_sub + prologue_sub
    uint64 pre_sub_patch = out_len
    // NOP placeholder — patched to SUB SP for large frames (>4080 bytes)
    if is_naked == 0 {
        emit_a64(0xD503201F)
    }
    uint64 prologue_start = out_len
    uint64 stp_fp_off = 0
    uint64 stp_callee_off = 0
    if is_naked == 0 {
        emit_a64(0xD1000000)  // SUB SP, SP, #imm (patched)
        stp_fp_off = out_len
        emit_a64(0xA9007BFD)  // stp x29, x30, [sp]
        emit_a64_add_imm(29, 31, 0)  // mov x29, sp
        stp_callee_off = out_len
        emit_a64(0xA90153F3)  // stp x19, x20, [sp, #16]
    }

    uint64 saved_var_base = a64_var_base

    // If this function returns a MEMORY-class struct, save x8 (sret pointer)
    // to the reserved slot.  AAPCS64: x8 is separate from arg registers x0-x7,
    // so no parameter shift is needed.
    if sret_slot_a64 != 0xFFFFFFFF {
        emit_a64_str(8, 31, a64_var_base + sret_slot_a64)
    }

    // Spill params to stack (x0-x7 for int, d0-d7 for float)
    // AAPCS64: separate int/float register counters
    uint64 pidx = 0
    uint64 int_pidx_a = 0
    uint64 float_pidx_a = 0
    uint64 wp2 = first_param
    while wp2 != 0 {
        uint32 pk2 = ast_kind(wp2)
        if pk2 == 3 {
            uint32 pn2 = ast_data2(wp2)
            uint64 poff = var_lookup(pn2)
            uint32 pflag_as = ast_data4(wp2)
            uint64 wpflag_as = pflag_as
            // Check if this param is a float type
            uint32 pt_spill_a = ast_data1(wp2)
            uint64 pt_kind_spill_a = tok_kind_at_raw(pt_spill_a)
            uint64 param_is_float_a = is_float_type(pt_kind_spill_a)
            if poff != 0xFFFFFFFF {
                // Check for struct parameter (by-value receiving, AAPCS64)
                uint64 param_si_spill_a = struct_lookup(pt_spill_a)
                if param_si_spill_a != 0xFFFFFFFF && abi_struct_pass_by_val != 0 {
                    // AAPCS64 struct by value: allocate struct-sized area on stack
                    uint64 sv_ssize_a = struct_total_size(param_si_spill_a)
                    uint64 sv_sslots_a = (sv_ssize_a + 7) / 8
                    uint64 struct_area_a = var_count * 8
                    uint64 sv_ci_a = 0
                    while sv_ci_a < sv_sslots_a { var_count = var_count + 1; sv_ci_a = sv_ci_a + 1 }
                    var_frame_size = var_count * 8
                    uint64 sv_rem_a = var_frame_size & 15
                    if sv_rem_a != 0 { var_frame_size = var_frame_size + 16 - sv_rem_a }
                    // Check if this is an HFA struct — spill from d/s regs
                    uint64 sflags_c = struct_abi_flags(param_si_spill_a)
                    uint64 is_hfa_c = sflags_c & 1
                    if is_hfa_c != 0 {
                        uint64 hfa_count_c = ((sflags_c >> 1) & 3) + 1
                        uint64 hfa_type_c = (sflags_c >> 3) & 3
                        uint64 field_size_c = 4
                        if hfa_type_c == 1 { field_size_c = 8 }
                        // Spill each d/s register to struct area
                        uint64 ci = 0
                        while ci < hfa_count_c {
                            uint64 foff_c = ci * field_size_c
                            if hfa_type_c == 1 {
                                emit_a64_store_dN(float_pidx_a, struct_area_a + foff_c)
                            } else {
                                emit_a64_store_sN(float_pidx_a, struct_area_a + foff_c)
                            }
                            float_pidx_a = float_pidx_a + 1
                            ci = ci + 1
                        }
                    } else if sv_ssize_a > 16 {
                        // MEMORY class (>16 bytes): register holds a pointer
                        // Copy struct bytes from pointer to local stack area
                        if int_pidx_a <= 7 {
                            // Save source pointer: mov x9, xN
                            emit_a64_mov(9, int_pidx_a)
                        }
                        int_pidx_a = int_pidx_a + 1
                        // Inline qword copy from [x9] to [sp + a64_var_base + struct_area_a]
                        uint64 aqi = 0
                        while aqi < sv_sslots_a {
                            uint64 aqoff = aqi * 8
                            // ldr x10, [x9, #aqoff]
                            emit_a64_ldr(10, 9, aqoff)
                            // str x10, [sp, #(a64_var_base + struct_area_a + aqoff)]
                            emit_a64_str(10, 31, a64_var_base + struct_area_a + aqoff)
                            aqi = aqi + 1
                        }
                    } else {
                    // Spill register(s) into contiguous struct area
                    if int_pidx_a <= 7 {
                        emit_a64_str(int_pidx_a, 31, a64_var_base + struct_area_a)
                    }
                    int_pidx_a = int_pidx_a + 1
                    if sv_ssize_a > 8 && int_pidx_a <= 7 {
                        emit_a64_str(int_pidx_a, 31, a64_var_base + struct_area_a + 8)
                        int_pidx_a = int_pidx_a + 1
                    }
                    }
                    // Store pointer to struct area in the variable's slot
                    // add x0, sp, #(a64_var_base + struct_area_a)
                    emit_a64_add_imm(0, 31, a64_var_base + struct_area_a)
                    emit_a64_str(0, 31, a64_var_base + poff)
                    pidx = pidx + 1
                    uint32 pn3_sv = ast_next(wp2)
                    wp2 = pn3_sv
                    continue
                }
                if param_is_float_a != 0 {
                    // Float param: spill dN to stack
                    if float_pidx_a <= 7 {
                        emit_a64_store_dN(float_pidx_a, poff)
                    }
                    float_pidx_a = float_pidx_a + 1
                } else {
                    // Integer param: spill xN to stack
                    uint64 reg = int_pidx_a
                    if reg <= 7 {
                        emit_a64_str(reg, 31, a64_var_base + poff)
                    }
                    if reg >= 8 {
                        // Stack-passed arg: emit ldr x0, [sp, #PLACEHOLDER]
                        // Offset will be patched when frame_size is known
                        uint64 patch_loc = out_len
                        emit_a64(0xF9400000 | (31 << 5) | 0) // ldr x0, [sp, #0] placeholder
                        // str x0, [sp, #(a64_var_base + poff)]
                        emit_a64_str(0, 31, a64_var_base + poff)
                        // Save patch location
                        uint64 opi = reg - 8
                        uint64 op_entry = a64_overflow_patches + opi * 8
                        uint32 pl32 = patch_loc
                        unsafe { *(op_entry as uint32) = pl32 }
                        a64_overflow_patch_count = opi + 1
                    }
                    int_pidx_a = int_pidx_a + 1
                    // Slice param: spill length register to the length slot
                    if wpflag_as == 1 {
                        uint64 len_off_as = slice_len_lookup(poff)
                        if len_off_as != 0xFFFFFFFF {
                            uint64 reg2 = int_pidx_a
                            if reg2 <= 7 {
                                emit_a64_str(reg2, 31, a64_var_base + len_off_as)
                            }
                        }
                        int_pidx_a = int_pidx_a + 1
                    }
                }
                pidx = pidx + 1
            }
        }
        uint32 pn3 = ast_next(wp2)
        wp2 = pn3
    }

    ret_fixup_count = 0

    // Generate body
    uint32 body_idx = ast_data3(fn_node)
    uint64 wbody = body_idx
    if wbody != 0 {
        gen_block_a64(wbody)
    }

    // Epilogue — patch return jumps here
    uint64 epilogue_start = out_len
    uint64 ri = 0
    while ri < ret_fixup_count {
        uint64 rentry = ret_fixups + ri * 4
        uint32 rpatch = 0
        unsafe { *(rentry as uint32) -> rpatch }
        uint64 wrp = rpatch
        uint64 disp = epilogue_start - wrp
        // Patch B instruction
        patch_u32(wrp, 0x14000000 | ((disp / 4) & 0x3FFFFFF))
        ri = ri + 1
    }

    // For @naked functions, skip epilogue entirely
    if is_naked != 0 {
        return
    }

    // For main: auto-insert exit(x0) so programs don't segfault on return
    // AND main's return value reaches the kernel. For void main, zero x0
    // first so fall-through still produces exit(0). Skip in freestanding.
    uint64 wnt_ep = name_tok
    if tok_matches(wnt_ep, "main", 4) != 0 && freestanding == 0 {
        if wrt_a == 0 {
            emit_a64_mov_imm(0, 0)
        }
        if target_os == 2 {
            emit_a64_win_call_iat(0)
        } else {
            if target_os == 1 { emit_a64_syscall_nr(1) } else { emit_a64_syscall_nr(93) }
            emit_a64_svc()
        }
    }

    uint64 ldp_callee_off = out_len
    emit_a64(0xA94153F3)  // ldp x19, x20, [sp, #16]
    uint64 ldp_fp_off = out_len
    emit_a64(0xA9407BFD)  // ldp x29, x30, [sp]
    // add sp, sp, #FRAME (placeholder, patched)
    uint64 epilogue_add = out_len
    emit_a64(0x91000000)
    uint64 post_add_patch = out_len
    // NOP placeholder — patched to ADD SP for large frames (>4080 bytes)
    if is_naked == 0 {
        emit_a64(0xD503201F)
    }
    // ret
    emit_a64_ret()

    // Restore a64_var_base
    a64_var_base = saved_var_base

    // Patch prologue and epilogue frame sizes
    uint64 frame = a64_var_base + var_frame_size
    uint64 fmod = frame & 15
    if fmod != 0 { frame = frame + 16 - fmod }

    if frame > 4080 {
        // Split: pre_sub does (frame>>12)*4096 via LSL#12, prologue_sub does remainder
        uint64 hi = frame >> 12
        uint64 lo = frame & 0xFFF
        // Ensure lo is 16-aligned
        uint64 lmod = lo & 15
        if lmod != 0 { lo = lo + 16 - lmod; hi = (frame - lo) >> 12 }
        // pre_sub: SUB SP, SP, #hi, LSL #12 (0xD1400000)
        patch_u32(pre_sub_patch, 0xD1400000 | (hi << 10) | (31 << 5) | 31)
        // prologue: SUB SP, SP, #lo
        patch_u32(prologue_start, 0xD1000000 | (lo << 10) | (31 << 5) | 31)
        // Epilogue: ADD SP, SP, #lo then ADD SP, SP, #hi, LSL #12 (0x91400000)
        patch_u32(epilogue_add, 0x91000000 | (lo << 10) | (31 << 5) | 31)
        patch_u32(post_add_patch, 0x91400000 | (hi << 10) | (31 << 5) | 31)
    } else {
        // pre_sub stays NOP, prologue does the full frame
        patch_u32(prologue_start, 0xD1000000 | (frame << 10) | (31 << 5) | 31)
        // epilogue does the full frame, post_add stays NOP
        patch_u32(epilogue_add, 0x91000000 | (frame << 10) | (31 << 5) | 31)
    }

    // Patch overflow arg offsets (9+ params, AAPCS64)
    // After SUB SP, SP, #frame + STP x29,x30,[sp]:
    // [sp + frame] = saved x29/x30 (16 bytes via STP)
    // [sp + frame + 0]  = overflow arg 0
    // [sp + frame + 8]  = overflow arg 1
    // Actually the caller pushed overflow args BELOW the return address.
    // The BL stores return address in LR (x30), not on stack.
    // So overflow args are at [sp + frame + i*8] from callee's perspective.
    if a64_overflow_patch_count > 0 {
        uint64 oi = 0
        while oi < a64_overflow_patch_count {
            uint64 op_e = a64_overflow_patches + oi * 8
            uint32 ploc = 0
            unsafe { *(op_e as uint32) -> ploc }
            uint64 wploc = ploc
            uint64 soff = frame + oi * 8
            // Patch LDR x0, [sp, #soff]: F9400000 | (imm12<<10) | (31<<5) | 0
            uint64 imm12 = soff / 8
            patch_u32(wploc, 0xF9400000 | (imm12 << 10) | (31 << 5) | 0)
            oi = oi + 1
        }
    }

    // Leaf function optimization: if no BL was emitted, NOP out the STP/LDP
    // Stack layout stays the same (a64_var_base=32), just skip the memory ops
    if is_naked == 0 {
        uint64 has_bl = 0
        uint64 scan = prologue_start
        while scan + 4 <= out_len {
            uint64 sp2 = out_buf + scan
            uint32 si = 0
            unsafe { *(sp2 as uint32) -> si }
            uint64 wsi = si
            // BL rel26: 0x94000000 (direct call)
            // BLR Xn:  0xD63F0000 (indirect call, used by Windows IAT)
            if (wsi & 0xFC000000) == 0x94000000 { has_bl = 1; break }
            if (wsi & 0xFFFFF000) == 0xD63F0000 { has_bl = 1; break }
            scan = scan + 4
        }
        if has_bl == 0 {
            // Leaf: NOP out STP x29,x30 + MOV x29,sp + STP x19,x20
            patch_u32(stp_fp_off, 0xD503201F)
            patch_u32(stp_fp_off + 4, 0xD503201F)
            patch_u32(stp_callee_off, 0xD503201F)
            // NOP out LDP x19,x20 + LDP x29,x30
            patch_u32(ldp_callee_off, 0xD503201F)
            patch_u32(ldp_fp_off, 0xD503201F)
        }
    }
}

// ---------------------------------------------------------------------------
// AArch64 fixup resolution
// ---------------------------------------------------------------------------

@export
fn resolve_fixups_a64() {
    uint64 i = 0
    while i < fixup_count {
        uint64 fentry = fixup_table + i * 8
        uint32 patch_off = 0
        unsafe { *(fentry as uint32) -> patch_off }
        uint64 fe4 = fentry + 4
        uint32 target_tok = 0
        unsafe { *(fe4 as uint32) -> target_tok }

        uint64 wtt = target_tok
        uint64 target_off = fn_lookup(wtt)
        if target_off != 0xFFFFFFFF {
            uint64 wpo = patch_off
            uint64 disp = target_off - wpo
            // Patch BL instruction: BL rel26
            patch_u32(wpo, 0x94000000 | ((disp / 4) & 0x3FFFFFF))
        }
        i = i + 1
    }
}

// Resolve fn_addr fixups for ARM64: ADRP+ADD → patch to function address
fn resolve_fnaddr_fixups_a64() {
    uint64 i = 0
    while i < fnaddr_fixup_count {
        uint64 fentry = fnaddr_fixup_table + i * 8
        uint32 patch_off = 0
        unsafe { *(fentry as uint32) -> patch_off }
        uint64 fe4 = fentry + 4
        uint32 str_tok = 0
        unsafe { *(fe4 as uint32) -> str_tok }

        uint64 wst = str_tok
        uint64 sstart = tok_text_start(wst)
        uint64 slen = tok_text_len(wst)
        uint64 name_start = sstart + 1
        uint64 name_len = slen - 2

        // Search function table
        uint64 found = 0
        uint64 target_off = 0
        uint64 fi = 0
        while fi < fn_count {
            uint64 fentry2 = fn_table + fi * 8
            uint32 fn_name_tok = 0
            unsafe { *(fentry2 as uint32) -> fn_name_tok }
            uint64 wfn = fn_name_tok
            uint64 fn_start = tok_text_start(wfn)
            uint64 fn_len = tok_text_len(wfn)
            if fn_len == name_len {
                uint64 eq = 1
                uint64 ci = 0
                while ci < name_len {
                    uint64 ca = cg_source + name_start + ci
                    uint64 cb = cg_source + fn_start + ci
                    uint64 va = 0
                    uint64 vb = 0
                    unsafe { *(ca as uint8) -> va }
                    unsafe { *(cb as uint8) -> vb }
                    if va != vb { eq = 0 }
                    ci = ci + 1
                }
                if eq != 0 {
                    uint64 fe4_2 = fentry2 + 4
                    uint32 foff = 0
                    unsafe { *(fe4_2 as uint32) -> foff }
                    target_off = foff
                    found = 1
                }
            }
            fi = fi + 1
        }

        if found != 0 {
            uint64 wpo = patch_off
            // For ARM64, ADRP+ADD is PC-relative
            // ADRP uses page-aligned PC-relative addressing
            // For simplicity in flat binary: use ADR x0, target (if within ±1MB)
            // ADR: bits [31]=0, [30:29]=immlo, [28:24]=10000, [23:5]=immhi, [4:0]=Rd
            uint64 disp = target_off - wpo
            uint64 imm21 = disp & 0x1FFFFF
            uint64 immlo = imm21 & 3
            uint64 immhi = (imm21 >> 2) & 0x7FFFF
            // ADR x0, disp
            uint32 adr_instr = 0x10000000 | (immlo << 29) | (immhi << 5) | 0
            patch_u32(wpo, adr_instr)
            // NOP the second instruction (ADD)
            patch_u32(wpo + 4, 0xD503201F)
        } else {
            write(2, "error: fn_addr: undefined function '", 36)
            write(2, cg_source + name_start, name_len)
            write(2, "'\n", 2)
            exit(1)
        }
        i = i + 1
    }
}

// AArch64 static access uses absolute addresses loaded via MOV immediate sequence
// The fixup patches the MOV sequence to point to the correct address
//
// VA computation depends on target format:
//   ELF:    VA = 0x400000 + file_offset
//   Mach-O: VA = 0x100000000 + file_offset
//   PE:     VA = 0x140000000 + 0x1000 + (file_offset - 0x200)
//                = 0x140000E00 + file_offset

// Compute VA from a raw file offset based on target_os
fn a64_compute_va(uint64 file_offset) -> uint64 {
    if target_os == 2 {
        // PE: image_base(0x140000000) + text_rva(0x1000) + (file_off - header_size(0x200))
        return 0x140000E00 + file_offset
    }
    if target_os == 1 {
        // Mach-O: vmaddr(0x100000000) + file_offset
        return 0x100000000 + file_offset
    }
    if target_os == 3 {
        // Android PIE: PT_LOAD maps file offset 0 to VA 0
        return file_offset
    }
    // ELF: load at 0x400000
    return 0x400000 + file_offset
}

@export
fn resolve_static_fixups_a64(uint64 data_start) {
    uint64 i = 0
    while i < static_fixup_count {
        uint64 fentry = static_fixups + i * 8
        uint32 code_off = 0
        unsafe { *(fentry as uint32) -> code_off }
        uint64 fe4 = fentry + 4
        uint32 data_off = 0
        unsafe { *(fe4 as uint32) -> data_off }
        uint64 wdo = data_off
        uint64 wco = code_off
        // All ARM64: patch ADRP + LDR/STR with PC-relative offsets
        uint64 code_va = a64_compute_va(wco)
        uint64 target_va = a64_compute_va(data_start + wdo)
        uint64 code_page = code_va >> 12
        uint64 target_page = target_va >> 12
        uint64 page_delta = target_page - code_page
        uint64 page_off = target_va & 0xFFF
        // Patch ADRP X16
        uint64 immlo = page_delta & 3
        uint64 immhi = (page_delta >> 2) & 0x7FFFF
        patch_u32(wco, 0x90000010 | (immlo << 29) | (immhi << 5))
        // Patch LDR/STR X?, [X16, #offset] OR ADD X?, X16, #offset
        uint64 insn_off = wco + 4
        uint64 insn_ptr = out_buf + insn_off
        uint32 existing = 0
        unsafe { *(insn_ptr as uint32) -> existing }
        uint64 wex = existing
        // Detect ADD (immediate, 64-bit): top 8 bits = 0x91
        uint64 opbyte = (wex >> 24) & 0xFF
        if opbyte == 0x91 {
            // ADD: unshifted 12-bit byte offset
            uint64 imm12_add = page_off & 0xFFF
            uint64 base_add = wex & 0xFFC003FF
            patch_u32(insn_off, base_add | (imm12_add << 10))
        } else {
            // LDR/STR: offset is scaled by element width (8 for X reg)
            uint64 imm12 = (page_off >> 3) & 0xFFF
            uint64 base_insn = wex & 0xFFC003FF
            patch_u32(insn_off, base_insn | (imm12 << 10))
        }
        i = i + 1
    }
}

@export
fn resolve_string_fixups_a64(uint64 str_data_start) {
    uint64 i = 0
    while i < str_fixup_count {
        uint64 fentry = str_fixups + i * 8
        uint32 code_off = 0
        unsafe { *(fentry as uint32) -> code_off }
        uint64 fe4 = fentry + 4
        uint32 str_off = 0
        unsafe { *(fe4 as uint32) -> str_off }
        uint64 wso = str_off
        uint64 wco = code_off
        if target_os == 2 || target_os == 3 {
            // PE/Android: patch ADRP + ADD with PC-relative offsets
            uint64 code_va = a64_compute_va(wco)
            uint64 target_va = a64_compute_va(str_data_start + wso)
            uint64 code_page = code_va >> 12
            uint64 target_page = target_va >> 12
            uint64 page_delta = target_page - code_page
            uint64 page_off = target_va & 0xFFF
            uint64 immlo = page_delta & 3
            uint64 immhi = (page_delta >> 2) & 0x7FFFF
            patch_u32(wco, 0x90000010 | (immlo << 29) | (immhi << 5))
            // ADD Xd, X16, #page_off (preserve Rd from original instruction)
            uint32 existing_add = 0
            uint64 add_addr = out_buf + wco + 4
            unsafe { *(add_addr as uint32) -> existing_add }
            uint64 rd = existing_add & 0x1F
            patch_u32(wco + 4, 0x91000200 | (page_off << 10) | rd)
        } else {
            // ELF/Mach-O: ADRP + ADD (PC-relative, position-independent)
            uint64 code_va = a64_compute_va(wco)
            uint64 target_va = a64_compute_va(str_data_start + wso)
            uint64 code_page = code_va >> 12
            uint64 target_page = target_va >> 12
            uint64 page_delta = target_page - code_page
            uint64 page_off = target_va & 0xFFF
            uint64 immlo = page_delta & 3
            uint64 immhi = (page_delta >> 2) & 0x7FFFF
            patch_u32(wco, 0x90000010 | (immlo << 29) | (immhi << 5))
            uint32 existing_add = 0
            uint64 add_addr = out_buf + wco + 4
            unsafe { *(add_addr as uint32) -> existing_add }
            uint64 rd = existing_add & 0x1F
            patch_u32(wco + 4, 0x91000200 | (page_off << 10) | rd)
        }
        i = i + 1
    }
}
// MLRift — built on KernRift — SSA IR infrastructure
//
// Arena-based intermediate representation for SSA-form optimisation passes.
//
// Instruction format (32 bytes per instruction):
//   [0..4)   opcode     (uint32)
//   [4..8)   dest_vreg  (uint32)
//   [8..12)  src1       (uint32)
//   [12..16) src2       (uint32)
//   [16..24) imm64      (uint64)
//   [24..28) bb_idx     (uint32) — owning basic block
//   [28..32) next       (uint32) — next instruction in block list (0xFFFFFFFF = end)
//
// Basic block format (16 bytes per block):
//   [0..4)   first_insn (uint32) — first instruction index (0xFFFFFFFF = empty)
//   [4..8)   last_insn  (uint32) — last instruction index  (0xFFFFFFFF = empty)
//   [8..12)  succ0      (uint32) — first successor block   (0xFFFFFFFF = none)
//   [12..16) succ1      (uint32) — second successor block  (0xFFFFFFFF = none)

// ---------------------------------------------------------------------------
// Opcode constants
// ---------------------------------------------------------------------------

static uint64 IR_CONST = 1
static uint64 IR_ADD = 2
static uint64 IR_SUB = 3
static uint64 IR_MUL = 4
static uint64 IR_DIV = 5
static uint64 IR_MOD = 6
static uint64 IR_AND = 7
static uint64 IR_OR = 8
static uint64 IR_XOR = 9
static uint64 IR_SHL = 10
static uint64 IR_SHR = 11
static uint64 IR_NEG = 12
static uint64 IR_NOT = 13

static uint64 IR_CMP_EQ = 14
static uint64 IR_CMP_NE = 15
static uint64 IR_CMP_LT = 16
static uint64 IR_CMP_LE = 17
static uint64 IR_CMP_GT = 18
static uint64 IR_CMP_GE = 19

static uint64 IR_FADD = 20
static uint64 IR_FSUB = 21
static uint64 IR_FMUL = 22
static uint64 IR_FDIV = 23
static uint64 IR_FCMP_EQ = 24
static uint64 IR_FCMP_LT = 25
static uint64 IR_ITOF = 26
static uint64 IR_FTOI = 27

static uint64 IR_LOAD = 30
static uint64 IR_STORE = 31
static uint64 IR_STACK_ADDR = 32

static uint64 IR_BR = 40
static uint64 IR_BR_COND = 41
static uint64 IR_RET = 42
static uint64 IR_RET_VOID = 43

static uint64 IR_CALL = 50
static uint64 IR_ARG = 51
static uint64 IR_SYSCALL = 52

static uint64 IR_PHI = 60
static uint64 IR_COPY = 61

static uint64 IR_ALLOC = 70
static uint64 IR_DEALLOC = 71

static uint64 IR_MEMCPY = 72
static uint64 IR_STRLEN = 73
static uint64 IR_FMT_UINT = 74
static uint64 IR_STR_EQ = 75
static uint64 IR_MEMSET = 76
static uint64 IR_STATIC_LOAD = 77     // dest = load from static data offset (imm64)
static uint64 IR_STATIC_STORE = 78    // store src1 to static data offset (imm64)
static uint64 IR_STR_CONST = 79       // dest = lea string data (imm = str_offset)
static uint64 IR_EXTRACT_RDX = 80    // dest = rdx after a call (2-tuple second value)
static uint64 IR_EXTRACT_R8 = 81     // dest = r8 after a call (3-tuple third value)
static uint64 IR_RET2 = 82           // return (src1, src2) — first in rax, second in rdx
static uint64 IR_RET3 = 83           // return (src1, src2, imm-vreg) — rax, rdx, r8
static uint64 IR_STATIC_ADDR = 84    // dest = lea static data address (imm = offset)
static uint64 IR_SYSCALL_RAW = 85    // dest = raw syscall; src1 = nr vreg; args already in regs via IR_ARG
static uint64 IR_FN_ADDR = 86        // dest = lea function address; imm = string token of fn name
static uint64 IR_CALL_IND = 87       // dest = indirect call result; src1 = fn pointer vreg
static uint64 IR_MEMCMP = 88         // dest = (memcmp(src1, src2, imm) == 0) ? 1 : 0

static uint64 IR_ATOMIC_STORE = 90   // atomic_store(ptr, val): lock xchg [ptr], val
static uint64 IR_ATOMIC_LOAD = 91    // atomic_load(ptr): mov + mfence
static uint64 IR_ATOMIC_ADD = 92     // atomic_add(ptr, val): lock xadd [ptr], val → old value
static uint64 IR_ATOMIC_CAS = 93     // atomic_cas(ptr, expected, desired): lock cmpxchg
static uint64 IR_VSTORE = 94         // volatile store: mfence + store
static uint64 IR_VLOAD = 95          // volatile load: load + mfence
static uint64 IR_ASM_BLOCK = 96      // inline asm block passthrough

// Float builtins / conversions
static uint64 IR_FSQRT = 97         // dest = sqrt(src1) f64
static uint64 IR_FFMA = 98          // dest = src1*src2+imm_vreg f64 (a*b+c)
static uint64 IR_FCMP_NE = 99       // dest = (src1 != src2) f64
static uint64 IR_FCMP_LE = 100      // dest = (src1 <= src2) f64
static uint64 IR_FCMP_GT = 101      // dest = (src1 > src2) f64
static uint64 IR_FCMP_GE = 102      // dest = (src1 >= src2) f64
static uint64 IR_F32TOF64 = 103     // dest = cvtss2sd src1
static uint64 IR_F64TOF32 = 104     // dest = cvtsd2ss src1
static uint64 IR_F32TOF16 = 105     // dest = f32-to-f16 bit conversion
static uint64 IR_F16TOF32 = 106     // dest = f16-to-f32 bit conversion
static uint64 IR_ITOF32 = 107       // dest = cvtsi2ss src1 (int to f32 bits)
static uint64 IR_FTOI32 = 108       // dest = cvttss2si src1 (f32 bits to int)

// Atomic RMW (CAS-loop based)
static uint64 IR_ATOMIC_SUB = 109    // atomic_sub(ptr, val): negate + lock xadd
static uint64 IR_ATOMIC_AND = 110    // atomic_and(ptr, val): CAS-loop with AND
static uint64 IR_ATOMIC_OR = 111     // atomic_or(ptr, val): CAS-loop with OR
static uint64 IR_ATOMIC_XOR = 112    // atomic_xor(ptr, val): CAS-loop with XOR

// Process / OS builtins
static uint64 IR_EXEC = 113         // exec_process(path): execve with auto-argv
static uint64 IR_EXEC_ARGV = 114    // exec_process_argv(path, argv): execve
static uint64 IR_SET_EXEC = 115     // set_executable(path): chmod +x
static uint64 IR_FSQRT32 = 118      // dest = sqrtss(src1) f32
static uint64 IR_TIME_NS = 119      // dest = monotonic nanosecond counter

// Signed comparisons (dedicated opcodes, no collision with CMP_xx+100 hack)
static uint64 IR_SCMP_LT = 120      // dest = (src1 < src2) signed
static uint64 IR_SCMP_LE = 121      // dest = (src1 <= src2) signed
static uint64 IR_SCMP_GT = 122      // dest = (src1 > src2) signed
static uint64 IR_SCMP_GE = 123      // dest = (src1 >= src2) signed

// 124/125 are taken (IR_FMT_BOOL / IR_FMT_F64) — assign signed div/mod
// past the highest existing opcode to avoid colliding with format ops.
static uint64 IR_SDIV = 132         // dest = src1 / src2 (signed: cqo+idiv)
static uint64 IR_SMOD = 133         // dest = src1 % src2 (signed: cqo+idiv)
static uint64 IR_SAR  = 134         // dest = src1 >> src2 (arithmetic / sign-fill)
// LEA-fused arithmetic: src1 vreg + signed-32 immediate. src2 is unused; imm
// holds the displacement. Emitted as `lea dst, [src1 ± imm]` (3-7 bytes) on
// x86 — replaces `mov const; mov src1; add/sub` (8-13 bytes) for the very
// common pattern of `n - 1`, `i + 4`, etc. Const-fold rewrites IR_ADD/SUB to
// these when src2 is a known constant fitting in signed 32-bit.
static uint64 IR_ADD_IMM = 135      // dest = src1 + imm (signed i32)
static uint64 IR_SUB_IMM = 136      // dest = src1 - imm (signed i32)

// 32-bit right-rotation: dest = ROR_w(src1, src2). imm = rotation width
// (32 or 64). Synthesized by ir_opt_recognize_rotate from the canonical
// `OR(AND(SHR(x,n), MASK), AND(SHL(x, W-n), MASK))` shape that 32-bit
// rotation idioms produce on a 64-bit IR. Codegen emits a single x86
// `ROR r32, cl` (or imm8) when imm == 32.
static uint64 IR_ROR = 137          // dest = ((src1 >> src2) | (src1 << (W - src2))) & ((1<<W)-1)
// IMUL r64, r/m64, imm — three-operand form. Eliminates the load-and-
// spill round-trip for the constant when src2 came from IR_CONST. Saves
// 4-9 bytes per IR_MUL site that scales by a small constant
// (matmul / sort / address-scaling are full of these). Only fires for
// imm fitting in signed 32-bit; src2 is left unused.
static uint64 IR_MUL_IMM = 138      // dest = src1 * imm (signed i32)
// Base + index*scale LEA fusion. Encodes `dst = src1 + src2 * imm`
// where imm ∈ {1, 2, 4, 8} — exactly x86's SIB scale set. Replaces the
// `imul idx, idx, scale; mov tmp, base; add tmp, idx` 7-10 byte
// sequence with a single 4-byte `lea dst, [base + idx*scale]`. Used by
// matmul / sort hot loops that pun on byte-offset address math.
static uint64 IR_LEA_BIS = 139      // dest = src1 + src2 * imm  (imm ∈ {1,2,4,8})

// Typed print formatters: dest=len_vreg, src1=buf_vreg, src2=val_vreg
static uint64 IR_FMT_BOOL = 124     // format bool as "true"/"false" into buf
static uint64 IR_FMT_F64 = 125      // format f64 as decimal into buf
static uint64 IR_ISB = 126          // instruction-sync barrier (ARM64 ISB; x86 no-op)
static uint64 IR_DCACHE_FLUSH = 127 // D-cache clean+invalidate by VA (ARM64 DC CIVAC; x86 CLFLUSH)
static uint64 IR_ICACHE_INV = 128   // I-cache invalidate by VA (ARM64 IC IVAU; x86 no-op)
static uint64 IR_DSB = 129          // data-sync barrier (ARM64 DSB SY; x86 MFENCE)
static uint64 IR_DMB = 130          // data-memory barrier (ARM64 DMB ISH; x86 MFENCE)
static uint64 IR_ARR_CHECK = 131    // bounds check: trap if s1_v (idx) >= imm (count)

// ---------------------------------------------------------------------------
// Instruction arena
// ---------------------------------------------------------------------------

static uint64 ir_insn_buf = 0       // pointer to instruction arena
static uint64 ir_insn_count = 0     // number of instructions allocated
static uint64 ir_insn_cap = 0       // max instructions

// Parallel table of source tokens per instruction, used by the -g DWARF
// emitter so each insn's emission can record a source-line mapping.
// Zero means "no source info" — the emitter skips line recording.
static uint64 ir_insn_src_tok = 0
// Current source token, set by ir_lower_stmt so every ir_emit call
// during a given statement's lowering inherits the same line.
static uint64 ir_current_src_tok = 0

@export
fn ir_set_current_src_tok(uint64 tok) { ir_current_src_tok = tok }


// ---------------------------------------------------------------------------
// Basic block arena
// ---------------------------------------------------------------------------

static uint64 ir_bb_buf = 0         // pointer to basic block arena
static uint64 ir_bb_count = 0       // number of blocks allocated
static uint64 ir_bb_cap = 0         // max blocks

// ---------------------------------------------------------------------------
// Virtual register allocator
// ---------------------------------------------------------------------------

static uint64 ir_vreg_next = 0      // next vreg number to allocate

// Float-kind per vreg: 0=int, 1=f64, 2=f32
static uint64 ir_vreg_fkind_buf = 0  // array of uint8, indexed by vreg
static uint64 ir_vreg_fkind_cap = 0

// Signed-int flag per vreg (1 = signed int8/16/32/64). Only meaningful
// when fkind == 0. Drives Compare lowering to pick IR_SCMP_LT/LE/GT/GE
// (signed setl/setle/setg/setge on x86) over the unsigned IR_CMP_LT/etc.
// Without this, `int64 k = -3; if k < 0` lowers to an unsigned compare
// and never fires (the bit pattern 0xFFFFFFFFFFFFFFFD looks larger than 0).
static uint64 ir_vreg_signed_buf = 0
static uint64 ir_vreg_signed_cap = 0

// Per-vreg use count (saturates at 255). Populated in ir_compute_use_count.
// Used by the CMP+JCC fusion peephole to prove a cmp result is single-use
// (so its materialization can be elided in favour of a direct jcc).
static uint64 ir_use_count_buf = 0
static uint64 ir_use_count_cap = 0

// Fused-cmp handoff: when a CMP in the current BB is the last non-terminator
// and is single-use by the terminator BR_COND, the emitter elides setcc/movzx/
// mov and stores the matching short-jcc opcode (0x84..0x8F) here. The block
// terminator then emits `0F <jcc> disp32` directly instead of test+jne.
// 0 = not fused. Reset at the start of each BB.
static uint64 ir_fused_jcc_code = 0

// ---------------------------------------------------------------------------
// Initialisation and reset
// ---------------------------------------------------------------------------

// Allocate arenas for instructions and basic blocks.
@export
fn ir_init() {
    if ir_insn_buf == 0 {
        ir_insn_cap = 65536
        ir_insn_buf = alloc(ir_insn_cap * 32)
        // 4 bytes per insn — enough for a u32 token index. Shares the
        // same cap as the main insn buf so indexing matches.
        ir_insn_src_tok = alloc(ir_insn_cap * 4)
    }
    ir_insn_count = 0
    ir_current_src_tok = 0

    if ir_bb_buf == 0 {
        ir_bb_cap = 4096
        ir_bb_buf = alloc(ir_bb_cap * 16)
    }
    ir_bb_count = 0

    ir_vreg_next = 1

    if ir_vreg_fkind_buf == 0 {
        ir_vreg_fkind_cap = 65536
        ir_vreg_fkind_buf = alloc(ir_vreg_fkind_cap)
    }
    // Float-kind buffer is indexed by vreg number without a length guard,
    // so stale bytes from a prior function would mislabel a vreg as float.
    memset(ir_vreg_fkind_buf, 0, ir_vreg_fkind_cap)

    if ir_vreg_signed_buf == 0 {
        ir_vreg_signed_cap = 65536
        ir_vreg_signed_buf = alloc(ir_vreg_signed_cap)
    }
    memset(ir_vreg_signed_buf, 0, ir_vreg_signed_cap)

    if ir_use_count_buf == 0 {
        ir_use_count_cap = 65536
        ir_use_count_buf = alloc(ir_use_count_cap)
    }
    memset(ir_use_count_buf, 0, ir_use_count_cap)
    ir_fused_jcc_code = 0

    if ir_loop_exit_stack == 0 {
        ir_loop_exit_stack = alloc(32 * 8)
        ir_loop_header_stack = alloc(32 * 8)
        ir_loop_hdr_buf_stack = alloc(32 * 8)
        ir_loop_hdr_count_stack = alloc(32 * 8)
    }
    ir_loop_depth = 0

    if ir_loops == 0 {
        ir_loop_cap = 256
        ir_loops = alloc(ir_loop_cap * 16)
    }
    ir_loop_count = 0

    if ir_overflow_args == 0 {
        ir_overflow_args = alloc(32 * 8)
    }
    ir_overflow_arg_count = 0
}

// Reset all counters to zero so the arenas can be reused.
@export
fn ir_reset() {
    ir_insn_count = 0
    ir_bb_count = 0
    ir_vreg_next = 1
    ir_loop_depth = 0
    ir_loop_count = 0
    if ir_vreg_fkind_buf != 0 {
        memset(ir_vreg_fkind_buf, 0, ir_vreg_fkind_cap)
    }
    if ir_vreg_signed_buf != 0 {
        memset(ir_vreg_signed_buf, 0, ir_vreg_signed_cap)
    }
    if ir_use_count_buf != 0 {
        memset(ir_use_count_buf, 0, ir_use_count_cap)
    }
    ir_fused_jcc_code = 0
}

// ---------------------------------------------------------------------------
// Virtual register allocation
// ---------------------------------------------------------------------------

// Allocate the next virtual register number.
@export
fn ir_new_vreg() -> uint64 {
    uint64 v = ir_vreg_next
    ir_vreg_next = ir_vreg_next + 1
    return v
}

static uint64 FKIND_INT = 0
static uint64 FKIND_F64 = 1
static uint64 FKIND_F32 = 2
static uint64 FKIND_BOOL = 3
static uint64 FKIND_CHAR = 4

fn ir_vreg_fkind_set(uint64 vreg, uint64 fk) {
    if vreg < ir_vreg_fkind_cap {
        uint64 p = ir_vreg_fkind_buf + vreg
        uint8 b = fk
        unsafe { *(p as uint8) = b }
    }
}

fn ir_vreg_fkind_get(uint64 vreg) -> uint64 {
    if vreg < ir_vreg_fkind_cap {
        uint64 p = ir_vreg_fkind_buf + vreg
        uint64 b = 0
        unsafe { *(p as uint8) -> b }
        return b
    }
    return 0
}

fn ir_vreg_signed_set(uint64 vreg, uint64 s) {
    if vreg < ir_vreg_signed_cap {
        uint64 p = ir_vreg_signed_buf + vreg
        uint8 b = s
        unsafe { *(p as uint8) = b }
    }
}

fn ir_vreg_signed_get(uint64 vreg) -> uint64 {
    if vreg < ir_vreg_signed_cap {
        uint64 p = ir_vreg_signed_buf + vreg
        uint64 b = 0
        unsafe { *(p as uint8) -> b }
        return b
    }
    return 0
}

// ---------------------------------------------------------------------------
// Token finder: scan the token table for an identifier matching a literal name.
// Returns token index or 0 if not found (0 is the first token, but function
// names never appear as the first token since it's a keyword).
// ---------------------------------------------------------------------------
fn ir_find_fn_tok(uint64 name, uint64 nlen) -> uint64 {
    uint64 i = 0
    while i < p_tok_count {
        if tok_matches(i, name, nlen) != 0 { return i }
        i = i + 1
    }
    return 0
}

// ---------------------------------------------------------------------------
// Instruction helpers (internal)
// ---------------------------------------------------------------------------

// Return the base pointer for instruction at index `idx` (0-based).
fn ir_insn_base(uint64 idx) -> uint64 {
    return ir_insn_buf + idx * 32
}

// ---------------------------------------------------------------------------
// Instruction field accessors
// ---------------------------------------------------------------------------

// Read the opcode (offset 0, uint32) of instruction `idx`.
@export
@export
fn ir_insn_src_tok_at(uint64 idx) -> uint64 {
    if ir_insn_src_tok == 0 { return 0 }
    uint64 slot = ir_insn_src_tok + idx * 4
    uint32 v = 0
    unsafe { *(slot as uint32) -> v }
    return v
}

fn ir_insn_opcode(uint64 idx) -> uint64 {
    uint64 p = ir_insn_base(idx)
    uint32 val = 0
    unsafe { *(p as uint32) -> val }
    return val
}

// Read the destination vreg (offset 4, uint32) of instruction `idx`.
@export
fn ir_insn_dest(uint64 idx) -> uint64 {
    uint64 p = ir_insn_base(idx) + 4
    uint32 val = 0
    unsafe { *(p as uint32) -> val }
    return val
}

// Read src1 (offset 8, uint32) of instruction `idx`.
@export
fn ir_insn_src1(uint64 idx) -> uint64 {
    uint64 p = ir_insn_base(idx) + 8
    uint32 val = 0
    unsafe { *(p as uint32) -> val }
    return val
}

// Read src2 (offset 12, uint32) of instruction `idx`.
@export
fn ir_insn_src2(uint64 idx) -> uint64 {
    uint64 p = ir_insn_base(idx) + 12
    uint32 val = 0
    unsafe { *(p as uint32) -> val }
    return val
}

// Read the 64-bit immediate (offset 16, uint64) of instruction `idx`.
@export
fn ir_insn_imm(uint64 idx) -> uint64 {
    uint64 p = ir_insn_base(idx) + 16
    uint64 val = 0
    unsafe { *(p as uint64) -> val }
    return val
}

// Read the owning basic block index (offset 24, uint32) of instruction `idx`.
@export
fn ir_insn_bb(uint64 idx) -> uint64 {
    uint64 p = ir_insn_base(idx) + 24
    uint32 val = 0
    unsafe { *(p as uint32) -> val }
    return val
}

// Read the next-instruction link (offset 28, uint32) of instruction `idx`.
@export
fn ir_insn_next(uint64 idx) -> uint64 {
    uint64 p = ir_insn_base(idx) + 28
    uint32 val = 0
    unsafe { *(p as uint32) -> val }
    return val
}

// ---------------------------------------------------------------------------
// Instruction field setters (used by optimization passes)
// ---------------------------------------------------------------------------

fn ir_insn_set_opcode(uint64 idx, uint64 op) {
    uint64 p = ir_insn_base(idx)
    uint32 v = op
    unsafe { *(p as uint32) = v }
}

fn ir_insn_set_src1(uint64 idx, uint64 val) {
    uint64 p = ir_insn_base(idx) + 8
    uint32 v = val
    unsafe { *(p as uint32) = v }
}

fn ir_insn_set_src2(uint64 idx, uint64 val) {
    uint64 p = ir_insn_base(idx) + 12
    uint32 v = val
    unsafe { *(p as uint32) = v }
}

fn ir_insn_set_imm(uint64 idx, uint64 val) {
    uint64 p = ir_insn_base(idx) + 16
    unsafe { *(p as uint64) = val }
}

// ---------------------------------------------------------------------------
// Emit an instruction
// ---------------------------------------------------------------------------

// Create a new instruction, append it to the given basic block, and return
// the instruction index (0-based).
@export
fn ir_emit(uint64 opcode, uint64 dest, uint64 src1, uint64 src2, uint64 imm64, uint64 bb) -> uint64 {
    if ir_insn_count >= ir_insn_cap {
        write(2, "error: IR instruction overflow\n", 31)
        exit(1)
    }

    uint64 idx = ir_insn_count
    // Parallel-table the current statement's source token. Per-insn
    // granularity would be nicer but statement-level is enough for
    // file:line mapping and keeps the insn layout untouched.
    uint64 st_slot = ir_insn_src_tok + idx * 4
    uint32 st = ir_current_src_tok
    unsafe { *(st_slot as uint32) = st }
    ir_insn_count = ir_insn_count + 1
    uint64 base = ir_insn_base(idx)

    // opcode  [0..4)
    uint32 op32 = opcode
    unsafe { *(base as uint32) = op32 }

    // dest_vreg [4..8)
    uint64 p4 = base + 4
    uint32 d32 = dest
    unsafe { *(p4 as uint32) = d32 }

    // src1 [8..12)
    uint64 p8 = base + 8
    uint32 s1 = src1
    unsafe { *(p8 as uint32) = s1 }

    // src2 [12..16)
    uint64 p12 = base + 12
    uint32 s2 = src2
    unsafe { *(p12 as uint32) = s2 }

    // imm64 [16..24)
    uint64 p16 = base + 16
    unsafe { *(p16 as uint64) = imm64 }

    // bb_idx [24..28)
    uint64 p24 = base + 24
    uint32 bb32 = bb
    unsafe { *(p24 as uint32) = bb32 }

    // next [28..32) — end of list sentinel
    uint64 p28 = base + 28
    uint32 sentinel = 0xFFFFFFFF
    unsafe { *(p28 as uint32) = sentinel }

    // Append this instruction to the basic block's list
    ir_bb_append_insn(bb, idx)

    return idx
}

// ---------------------------------------------------------------------------
// Basic block helpers (internal)
// ---------------------------------------------------------------------------

// Return the base pointer for basic block at index `idx` (0-based).
fn ir_bb_base(uint64 idx) -> uint64 {
    return ir_bb_buf + idx * 16
}

// ---------------------------------------------------------------------------
// Basic block creation
// ---------------------------------------------------------------------------

// Create a new empty basic block and return its index (0-based).
@export
fn ir_new_bb() -> uint64 {
    if ir_bb_count >= ir_bb_cap {
        write(2, "error: IR basic block overflow\n", 31)
        exit(1)
    }

    uint64 idx = ir_bb_count
    ir_bb_count = ir_bb_count + 1
    uint64 base = ir_bb_base(idx)

    // first_insn = 0xFFFFFFFF (empty)
    uint32 sentinel = 0xFFFFFFFF
    unsafe { *(base as uint32) = sentinel }

    // last_insn = 0xFFFFFFFF (empty)
    uint64 p4 = base + 4
    unsafe { *(p4 as uint32) = sentinel }

    // succ0 = 0xFFFFFFFF (none)
    uint64 p8 = base + 8
    unsafe { *(p8 as uint32) = sentinel }

    // succ1 = 0xFFFFFFFF (none)
    uint64 p12 = base + 12
    unsafe { *(p12 as uint32) = sentinel }

    return idx
}

// ---------------------------------------------------------------------------
// Basic block field accessors
// ---------------------------------------------------------------------------

// Read first_insn (offset 0, uint32) of block `bb`.
@export
fn ir_bb_first_insn(uint64 bb) -> uint64 {
    uint64 p = ir_bb_base(bb)
    uint32 val = 0
    unsafe { *(p as uint32) -> val }
    return val
}

// Read last_insn (offset 4, uint32) of block `bb`.
@export
fn ir_bb_last_insn(uint64 bb) -> uint64 {
    uint64 p = ir_bb_base(bb) + 4
    uint32 val = 0
    unsafe { *(p as uint32) -> val }
    return val
}

// Read succ0 (offset 8, uint32) of block `bb`.
@export
fn ir_bb_succ0(uint64 bb) -> uint64 {
    uint64 p = ir_bb_base(bb) + 8
    uint32 val = 0
    unsafe { *(p as uint32) -> val }
    return val
}

// Read succ1 (offset 12, uint32) of block `bb`.
@export
fn ir_bb_succ1(uint64 bb) -> uint64 {
    uint64 p = ir_bb_base(bb) + 12
    uint32 val = 0
    unsafe { *(p as uint32) -> val }
    return val
}

// ---------------------------------------------------------------------------
// Basic block successor setter
// ---------------------------------------------------------------------------

// Set the two successors of block `bb`.
@export
fn ir_bb_set_succ(uint64 bb, uint64 succ0, uint64 succ1) {
    uint64 base = ir_bb_base(bb)

    uint64 p8 = base + 8
    uint32 s0 = succ0
    unsafe { *(p8 as uint32) = s0 }

    uint64 p12 = base + 12
    uint32 s1 = succ1
    unsafe { *(p12 as uint32) = s1 }
}

// ---------------------------------------------------------------------------
// Append instruction to basic block
// ---------------------------------------------------------------------------

// Remove the BB's currently-last instruction from the linked list so
// it can be re-spliced elsewhere (LICM hoisting). Caller is responsible
// for re-linking the orphan; we do not zero its `next` field.
fn ir_bb_remove_last(uint64 bb) {
    uint64 base = ir_bb_base(bb)
    uint64 p_first = base
    uint64 p_last = base + 4
    uint32 first = 0
    uint32 last = 0
    unsafe { *(p_first as uint32) -> first }
    unsafe { *(p_last as uint32) -> last }
    if first == 0xFFFFFFFF { return }
    if first == last {
        // Only one insn — BB becomes empty.
        uint32 sentinel = 0xFFFFFFFF
        unsafe { *(p_first as uint32) = sentinel }
        unsafe { *(p_last as uint32) = sentinel }
        return
    }
    // Walk to the second-to-last, set its next to sentinel, update p_last.
    uint64 cur = first
    uint64 done = 0
    while done == 0 {
        uint32 nxt = 0
        uint64 cur_next_ptr = ir_insn_base(cur) + 28
        unsafe { *(cur_next_ptr as uint32) -> nxt }
        if nxt == last {
            uint32 sentinel = 0xFFFFFFFF
            unsafe { *(cur_next_ptr as uint32) = sentinel }
            uint32 cur32 = cur
            unsafe { *(p_last as uint32) = cur32 }
            done = 1
        } else {
            cur = nxt
        }
    }
}

// Splice an instruction into a BB just before its current last
// instruction (which is the BB's terminator under our IR conventions).
// Used by LICM: hoisted insns must be in the *executed* portion of the
// preheader, not after the IR_BR — otherwise liveness analysis treats
// them as dead code and the regalloc may over-coalesce their dests.
fn ir_bb_insert_before_terminator(uint64 bb, uint64 insn_idx) {
    uint64 base = ir_bb_base(bb)
    uint64 p_first = base
    uint64 p_last = base + 4

    uint32 first = 0
    uint32 last = 0
    unsafe { *(p_first as uint32) -> first }
    unsafe { *(p_last as uint32) -> last }

    if first == 0xFFFFFFFF {
        // BB is empty — fall back to plain append.
        ir_bb_append_insn(bb, insn_idx)
        return
    }

    // Make the new insn's next pointer point to the terminator.
    uint64 new_next_ptr = ir_insn_base(insn_idx) + 28
    uint32 last32 = last
    unsafe { *(new_next_ptr as uint32) = last32 }

    if first == last {
        // Only insn in BB is the terminator. New insn becomes first;
        // first → new → terminator.
        uint32 idx32 = insn_idx
        unsafe { *(p_first as uint32) = idx32 }
        return
    }

    // Walk from first to find the predecessor of the terminator.
    uint64 cur = first
    uint64 done = 0
    while done == 0 {
        uint32 nxt = 0
        uint64 cur_next_ptr = ir_insn_base(cur) + 28
        unsafe { *(cur_next_ptr as uint32) -> nxt }
        if nxt == last {
            // cur is the predecessor: rewire cur → new → terminator.
            uint32 idx32 = insn_idx
            unsafe { *(cur_next_ptr as uint32) = idx32 }
            done = 1
        } else {
            cur = nxt
        }
    }
}

// Link instruction `insn_idx` into block `bb`'s instruction list.
// Updates the block's first_insn/last_insn and the previous tail's
// next pointer.
@export
fn ir_bb_append_insn(uint64 bb, uint64 insn_idx) {
    uint64 base = ir_bb_base(bb)
    uint64 p_first = base
    uint64 p_last = base + 4

    uint32 first = 0
    unsafe { *(p_first as uint32) -> first }

    if first == 0xFFFFFFFF {
        // Block is empty — this is the first instruction.
        uint32 ii = insn_idx
        unsafe { *(p_first as uint32) = ii }
        unsafe { *(p_last as uint32) = ii }
        return
    }

    // Block is non-empty — link previous last instruction's next to this one.
    uint32 last = 0
    unsafe { *(p_last as uint32) -> last }

    // Set previous last instruction's next pointer to insn_idx
    uint64 prev_next_ptr = ir_insn_base(last) + 28
    uint32 ii = insn_idx
    unsafe { *(prev_next_ptr as uint32) = ii }

    // Update block's last_insn
    unsafe { *(p_last as uint32) = ii }
}

// ---------------------------------------------------------------------------
// Variable name → vreg mapping for current function
// ---------------------------------------------------------------------------

static uint64 ir_var_map = 0       // [name_tok(4), vreg(4)] × 1024
static uint64 ir_var_map_count = 0

// Slice length vreg table: [name_tok(4), len_vreg(4)] × 32
static uint64 ir_slice_len_map = 0
static uint64 ir_slice_len_count = 0

fn ir_slice_len_set(uint64 name_tok, uint64 len_vreg) {
    if ir_slice_len_map == 0 { ir_slice_len_map = alloc(32 * 8) }
    if ir_slice_len_count >= 32 { return }
    uint64 entry = ir_slice_len_map + ir_slice_len_count * 8
    uint32 nt = name_tok
    unsafe { *(entry as uint32) = nt }
    uint64 e4 = entry + 4
    uint32 vr = len_vreg
    unsafe { *(e4 as uint32) = vr }
    ir_slice_len_count = ir_slice_len_count + 1
}

fn ir_slice_len_get(uint64 name_tok) -> uint64 {
    uint64 i = 0
    while i < ir_slice_len_count {
        uint64 entry = ir_slice_len_map + i * 8
        uint32 stored = 0
        unsafe { *(entry as uint32) -> stored }
        uint64 ws = stored
        if tok_text_eq(ws, name_tok) != 0 {
            uint64 e4 = entry + 4
            uint32 vr = 0
            unsafe { *(e4 as uint32) -> vr }
            return vr
        }
        i = i + 1
    }
    return 0xFFFFFFFF
}

fn ir_var_map_init() {
    if ir_var_map == 0 { ir_var_map = alloc(1024 * 8) }
    ir_var_map_count = 0
    ir_slice_len_count = 0
}

fn ir_var_set(uint64 name_tok, uint64 vreg) {
    // Update existing or add new
    uint64 i = 0
    while i < ir_var_map_count {
        uint64 entry = ir_var_map + i * 8
        uint32 stored = 0
        unsafe { *(entry as uint32) -> stored }
        uint64 ws = stored
        if tok_text_eq(ws, name_tok) != 0 {
            uint64 e4 = entry + 4
            uint32 vr = vreg
            unsafe { *(e4 as uint32) = vr }
            return
        }
        i = i + 1
    }
    // Add new entry
    if ir_var_map_count >= 1024 { return }
    uint64 entry = ir_var_map + ir_var_map_count * 8
    uint32 nt = name_tok
    unsafe { *(entry as uint32) = nt }
    uint64 e4 = entry + 4
    uint32 vr = vreg
    unsafe { *(e4 as uint32) = vr }
    ir_var_map_count = ir_var_map_count + 1
}

// Snapshot the IR var map into the DWARF debug_var_table. Called
// from ir_emit_{x86,arm64}_function AFTER regalloc has decided each
// vreg's physical register (or spill slot). fn_count-1 is the index
// of the currently-emitting function since fn_register() ran just
// before us.
@export
fn ir_snapshot_debug_vars() {
    if debug_info_mode == 0 { return }
    uint64 cur_fn = 0
    if fn_count > 0 { cur_fn = fn_count - 1 }
    uint64 i = 0
    while i < ir_var_map_count {
        uint64 entry = ir_var_map + i * 8
        uint32 nt = 0
        unsafe { *(entry as uint32) -> nt }
        uint64 wnt = nt
        uint64 e4 = entry + 4
        uint32 vr = 0
        unsafe { *(e4 as uint32) -> vr }
        uint64 wvr = vr
        uint64 phys = ir_get_phys_reg(wvr)
        if phys != 0xFFFFFFFF {
            // kind 1: physical register; map KernRift's 0-9 colour IDs
            // through ir_phys_regs to the real ARM/x86 register number
            // and emit as DW_OP_reg<N> later. debug writer reads the
            // raw value and maps arch-specific.
            debug_var_record_loc(cur_fn, wnt, phys, 1)
        } else {
            // kind 0: fbreg — use arch-specific spill offset.
            uint64 off = 0
            if target_arch == 1 {
                off = ir_a64_spill_offset(wvr)
            } else {
                off = ir_spill_offset(wvr)
            }
            debug_var_record_loc(cur_fn, wnt, off, 0)
        }
        i = i + 1
    }
}

fn ir_var_get(uint64 name_tok) -> uint64 {
    uint64 i = 0
    while i < ir_var_map_count {
        uint64 entry = ir_var_map + i * 8
        uint32 stored = 0
        unsafe { *(entry as uint32) -> stored }
        uint64 ws = stored
        if tok_text_eq(ws, name_tok) != 0 {
            uint64 e4 = entry + 4
            uint32 vr = 0
            unsafe { *(e4 as uint32) -> vr }
            return vr
        }
        i = i + 1
    }
    return 0xFFFFFFFF
}

// Emit COPY instructions from current var map vregs to snapshot vregs,
// using a two-phase approach to avoid read-after-write hazards.
// Phase 1: snapshot all changed values into fresh vregs (reads before writes).
// Phase 2: copy from fresh vregs to target vregs.
fn ir_emit_copy_to_snapshot(uint64 snap_buf, uint64 snap_count, uint64 bb) {
    uint64 pairs = alloc(snap_count * 16)
    uint64 pcnt = 0
    uint64 ci = 0
    while ci < snap_count {
        uint64 sp = snap_buf + ci * 8 + 4
        uint32 snap_vreg = 0
        unsafe { *(sp as uint32) -> snap_vreg }
        uint64 cp = ir_var_map + ci * 8 + 4
        uint32 cur_vreg = 0
        unsafe { *(cp as uint32) -> cur_vreg }
        uint64 wsv = snap_vreg
        uint64 wcv = cur_vreg
        if wsv != wcv && wsv != 0xFFFFFFFF {
            uint64 fresh = ir_new_vreg()
            ir_emit(IR_COPY, fresh, wcv, 0, 0, bb)
            uint64 pp = pairs + pcnt * 16
            unsafe { *(pp as uint64) = wsv }
            uint64 pp8 = pp + 8
            unsafe { *(pp8 as uint64) = fresh }
            pcnt = pcnt + 1
        }
        ci = ci + 1
    }
    ci = 0
    while ci < pcnt {
        uint64 pp = pairs + ci * 16
        uint64 target = 0
        unsafe { *(pp as uint64) -> target }
        uint64 pp8 = pp + 8
        uint64 source = 0
        unsafe { *(pp8 as uint64) -> source }
        ir_emit(IR_COPY, target, source, 0, 0, bb)
        ci = ci + 1
    }
    dealloc(pairs)
}

// ---------------------------------------------------------------------------
// Current basic block tracking
// ---------------------------------------------------------------------------

static uint64 ir_current_bb = 0

// Loop context stack for break/continue
static uint64 ir_loop_exit_stack = 0       // bb indices for break targets

// LICM bookkeeping: per-loop tuple (preheader_bb, header_bb,
// body_first_bb) populated during `while` lowering. The body range
// is [header_bb+1 .. ir_bb_count_at_loop_close-1] — recorded after
// the body is fully emitted in `kind == 14` lowering.
//
// 16 bytes per loop: 4 u32 fields. 256 loops max in any one function
// (way more than any sane KernRift source needs).
static uint64 ir_loops = 0
static uint64 ir_loop_count = 0
static uint64 ir_loop_cap = 0
static uint64 ir_loop_header_stack = 0     // bb indices for continue targets
static uint64 ir_loop_hdr_buf_stack = 0    // header vreg snapshot pointers
static uint64 ir_loop_hdr_count_stack = 0  // header vreg snapshot counts
static uint64 ir_loop_depth = 0

// Nested field access tracking: set by ir_lower_expr FieldAccess (kind 36)
// when the accessed field is itself a struct type.
// 0xFFFFFFFF = not a struct field, otherwise = struct index of the field type.
static uint64 ir_fa_struct_idx = 0xFFFFFFFF

// ---------------------------------------------------------------------------
// Nested field chain helper
// ---------------------------------------------------------------------------

// Evaluate a FieldAccess chain (e.g. a.b) and return the address (pointer)
// of the innermost struct field. Sets ir_fa_struct_idx to the struct index
// of the resulting field's type so the outer access can use it.
fn ir_lower_field_chain(uint64 node) -> uint64 {
    uint32 field_tok = ast_data2(node)
    uint32 child_idx = ast_child(node)
    uint64 wchild = child_idx
    uint32 ck = ast_kind(wchild)

    if ck == 36 {
        // Child is another FieldAccess — recurse
        uint64 inner_addr = ir_lower_field_chain(wchild)
        uint64 inner_si = ir_fa_struct_idx
        if inner_si != 0xFFFFFFFF {
            uint64 foff = struct_field_offset(inner_si, field_tok)
            uint64 addr_v = inner_addr
            if foff != 0 {
                uint64 off_v = ir_new_vreg()
                ir_emit(IR_CONST, off_v, 0, 0, foff, ir_current_bb)
                addr_v = ir_new_vreg()
                ir_emit(IR_ADD, addr_v, inner_addr, off_v, 0, ir_current_bb)
            }
            uint64 ftk = struct_field_type_kind_by_tok(inner_si, field_tok)
            if ftk >= 256 {
                ir_fa_struct_idx = ftk - 256
            } else {
                ir_fa_struct_idx = 0xFFFFFFFF
            }
            return addr_v
        }
        ir_fa_struct_idx = 0xFFFFFFFF
        return inner_addr
    }

    // Base case: child is an Ident
    if ck == 32 {
        uint32 obj_tok = ast_data1(wchild)
        uint64 wobj = obj_tok
        uint64 si = struct_var_lookup(wobj)
        if si != 0xFFFFFFFF {
            uint64 base_v = ir_var_get(obj_tok)
            uint64 foff = struct_field_offset(si, field_tok)
            uint64 addr_v = base_v
            if foff != 0 {
                uint64 off_v = ir_new_vreg()
                ir_emit(IR_CONST, off_v, 0, 0, foff, ir_current_bb)
                addr_v = ir_new_vreg()
                ir_emit(IR_ADD, addr_v, base_v, off_v, 0, ir_current_bb)
            }
            uint64 ftk = struct_field_type_kind_by_tok(si, field_tok)
            if ftk >= 256 {
                ir_fa_struct_idx = ftk - 256
            } else {
                ir_fa_struct_idx = 0xFFFFFFFF
            }
            return addr_v
        }
    }
    ir_fa_struct_idx = 0xFFFFFFFF
    uint64 zero = ir_new_vreg()
    ir_emit(IR_CONST, zero, 0, 0, 0, ir_current_bb)
    return zero
}

// ---------------------------------------------------------------------------
// Expression lowering
// ---------------------------------------------------------------------------

fn ir_lower_expr(uint64 node) -> uint64 {
    if node == 0 { return 0xFFFFFFFF }
    uint32 kind = ast_kind(node)

    // IntLit (30)
    if kind == 30 {
        uint32 tok = ast_data1(node)
        uint64 val = parse_int_token(tok)
        uint64 dest = ir_new_vreg()
        ir_emit(IR_CONST, dest, 0, 0, val, ir_current_bb)
        uint32 d4 = ast_data4(node)
        uint64 wd4 = d4
        if wd4 == 98 { ir_vreg_fkind_set(dest, 3) }
        if wd4 == 99 { ir_vreg_fkind_set(dest, 4) }
        return dest
    }

    // FloatLit (46): parse integer+fraction[+exponent], emit ITOF + arithmetic.
    // Supports scientific notation: `1e-3`, `5.5e-4`, `3.14E+10`, `2e5f`.
    if kind == 46 {
        uint32 lit_tok = ast_data1(node)
        uint64 wlt = lit_tok
        uint64 tstart = tok_text_start(wlt)
        uint64 tlen = tok_text_len(wlt)
        // Parse integer part and fractional part
        uint64 int_val = 0
        uint64 frac_val = 0
        uint64 frac_divisor = 1
        uint64 past_dot = 0
        uint64 is_f32 = 0
        uint64 in_exp = 0
        uint64 exp_neg = 0
        uint64 exp_val = 0
        uint64 fi = 0
        while fi < tlen {
            uint64 ch = tok_source_byte(wlt, fi)
            if ch == 46 { past_dot = 1; fi = fi + 1; continue }
            if ch == 102 { is_f32 = 1; fi = fi + 1; continue }
            if ch == 101 || ch == 69 {
                // 'e' or 'E' — switch to exponent parsing for the rest.
                in_exp = 1
                fi = fi + 1
                if fi < tlen {
                    uint64 sign_ch = tok_source_byte(wlt, fi)
                    if sign_ch == 45 { exp_neg = 1; fi = fi + 1 }
                    else if sign_ch == 43 { fi = fi + 1 }
                }
                continue
            }
            if ch >= 48 && ch <= 57 {
                if in_exp != 0 {
                    exp_val = exp_val * 10 + (ch - 48)
                } else if past_dot == 0 {
                    int_val = int_val * 10 + (ch - 48)
                } else {
                    frac_val = frac_val * 10 + (ch - 48)
                    frac_divisor = frac_divisor * 10
                }
            }
            fi = fi + 1
        }
        // Convert integer part to f64
        uint64 int_c = ir_new_vreg()
        ir_emit(IR_CONST, int_c, 0, 0, int_val, ir_current_bb)
        uint64 int_f = ir_new_vreg()
        ir_emit(IR_ITOF, int_f, int_c, 0, 0, ir_current_bb)
        ir_vreg_fkind_set(int_f, 1)
        uint64 result = int_f
        if frac_val != 0 {
            // Convert frac_val to f64
            uint64 frac_c = ir_new_vreg()
            ir_emit(IR_CONST, frac_c, 0, 0, frac_val, ir_current_bb)
            uint64 frac_f = ir_new_vreg()
            ir_emit(IR_ITOF, frac_f, frac_c, 0, 0, ir_current_bb)
            ir_vreg_fkind_set(frac_f, 1)
            // Convert frac_divisor to f64
            uint64 div_c = ir_new_vreg()
            ir_emit(IR_CONST, div_c, 0, 0, frac_divisor, ir_current_bb)
            uint64 div_f = ir_new_vreg()
            ir_emit(IR_ITOF, div_f, div_c, 0, 0, ir_current_bb)
            ir_vreg_fkind_set(div_f, 1)
            // frac = frac_val / frac_divisor
            uint64 frac_r = ir_new_vreg()
            ir_emit(IR_FDIV, frac_r, frac_f, div_f, 1, ir_current_bb)
            ir_vreg_fkind_set(frac_r, 1)
            // result = int_part + frac
            result = ir_new_vreg()
            ir_emit(IR_FADD, result, int_f, frac_r, 1, ir_current_bb)
            ir_vreg_fkind_set(result, 1)
        }
        // Apply exponent: multiply (or divide) by 10^exp_val. Compile-time
        // compute pow10 as a uint64 for |exp| <= 18 (covers the entire f64
        // normal range minus a tiny edge) and emit ONE ITOF + ONE FMUL/FDIV.
        if exp_val != 0 {
            if exp_val > 18 {
                write(2, "error: float exponent too large (max 1e18)\n", 44)
                exit(1)
            }
            uint64 pow10_u = 1
            uint64 ei = 0
            while ei < exp_val {
                pow10_u = pow10_u * 10
                ei = ei + 1
            }
            uint64 pow10_c = ir_new_vreg()
            ir_emit(IR_CONST, pow10_c, 0, 0, pow10_u, ir_current_bb)
            uint64 pow10_f = ir_new_vreg()
            ir_emit(IR_ITOF, pow10_f, pow10_c, 0, 0, ir_current_bb)
            ir_vreg_fkind_set(pow10_f, 1)
            uint64 scaled = ir_new_vreg()
            if exp_neg != 0 {
                ir_emit(IR_FDIV, scaled, result, pow10_f, 1, ir_current_bb)
            } else {
                ir_emit(IR_FMUL, scaled, result, pow10_f, 1, ir_current_bb)
            }
            ir_vreg_fkind_set(scaled, 1)
            result = scaled
        }
        if is_f32 != 0 {
            // Narrow f64 to f32
            uint64 f32_v = ir_new_vreg()
            ir_emit(IR_F64TOF32, f32_v, result, 0, 0, ir_current_bb)
            ir_vreg_fkind_set(f32_v, 2)
            return f32_v
        }
        return result
    }

    // StrLit (31) — store string in str_buf, emit lea rip-relative
    if kind == 31 {
        uint32 tok = ast_data1(node)
        uint64 wtok = tok
        uint64 tstart = tok_text_start(wtok)
        uint64 tlen = tok_text_len(wtok)
        if str_len + tlen >= 65536 {
            write(2, "error: str_buf overflow (max 65536)\n", 36)
            exit(1)
        }
        uint64 str_offset = str_len
        // Copy string bytes (skip quotes, process escapes). Escape table
        // lives in codegen.kr via escape_char_to_byte + hex_digit_pair_to_byte;
        // the legacy codegen and the aarch64 emitter share the same helpers.
        uint64 si = 1
        while si < tlen - 1 {
            uint64 ch = tok_source_byte(wtok, si)
            if ch == 92 {
                si = si + 1
                uint64 esc = tok_source_byte(wtok, si)
                if esc == 120 && si + 2 < tlen {
                    ch = hex_digit_pair_to_byte(tok_source_byte(wtok, si + 1),
                                                tok_source_byte(wtok, si + 2))
                    si = si + 2
                } else {
                    uint64 mapped = escape_char_to_byte(esc)
                    if mapped != 0xFFFFFFFFFFFFFFFF { ch = mapped }
                    else { ch = esc }
                }
            }
            uint64 sp = str_buf + str_len
            uint8 cb = ch
            unsafe { *(sp as uint8) = cb }
            str_len = str_len + 1
            si = si + 1
        }
        // Null-terminate
        uint64 sp = str_buf + str_len
        uint8 zero = 0
        unsafe { *(sp as uint8) = zero }
        str_len = str_len + 1
        uint64 dest = ir_new_vreg()
        ir_emit(IR_STR_CONST, dest, 0, 0, str_offset, ir_current_bb)
        return dest
    }

    // Ident (32)
    if kind == 32 {
        uint32 tok = ast_data1(node)
        uint64 vreg = ir_var_get(tok)
        if vreg != 0xFFFFFFFF { return vreg }
        // Check if it's a static variable
        uint64 wt = tok
        uint64 st_off = static_lookup(wt)
        if st_off != 0xFFFFFFFF {
            // Static arrays decay to their base address when used as
            // an rvalue (bare identifier), matching C semantics. This
            // lets callers pass arrays to helper functions as uint64
            // pointers — `vec_f64_decay_inplace(buf, n, f)` with
            // `static f64[N] buf` now Just Works. Indexing `arr[i]`
            // uses a separate AST kind (Index=37) that has always
            // emitted IR_STATIC_ADDR, so that path stays unchanged.
            uint64 sasz = static_array_size_of(wt)
            if sasz != 0 && sasz != 0xFFFFFFFF {
                uint64 addr_dest = ir_new_vreg()
                ir_emit(IR_STATIC_ADDR, addr_dest, 0, 0, st_off, ir_current_bb)
                return addr_dest
            }
            uint64 dest = ir_new_vreg()
            ir_emit(IR_STATIC_LOAD, dest, 0, 0, st_off, ir_current_bb)
            // Propagate f64/f32 type-flow from the static's declared
            // type so downstream `+`, `*` etc. lower to IR_FADD/FMUL
            // rather than integer ops.
            uint64 sfk = static_fkind_of(wt)
            if sfk != 0 { ir_vreg_fkind_set(dest, sfk) }
            return dest
        }
        // Unknown identifier — report error
        write(2, "error: use of undeclared identifier '", 36)
        uint64 ts = tok_text_start(wt)
        uint64 tl = tok_text_len(wt)
        write(2, cg_source + ts, tl)
        write(2, "'\n", 2)
        exit(1)
    }

    // BinOp (33)
    if kind == 33 {
        uint32 op_tok = ast_data1(node)
        uint32 lhs_node = ast_child(node)
        uint32 rhs_node = ast_data2(node)
        uint64 lhs = ir_lower_expr(lhs_node)
        uint64 rhs = ir_lower_expr(rhs_node)
        uint64 dest = ir_new_vreg()
        uint64 op_kind = tok_kind_at_raw(op_tok)
        // Check if LHS is float-typed
        uint64 lhs_fk = ir_vreg_fkind_get(lhs)
        if lhs_fk != 0 {
            // Float arithmetic. Mirror the float-compare fix: f32 OP f64 in
            // the same expression must share an fkind, otherwise the f32
            // ADDSS/SUBSS/MULSS/DIVSS reads only the low 32 bits of the
            // f64 bit pattern in the GPR and silently zeros operands like
            // 1.0/2.0 (whose low 32 bits are 0). Widen the narrower side
            // to f64 — VarDecl/Assign narrow back to f32 if the LHS was
            // declared f32 (see vd_fk==2 && fk_from_val==1 path).
            uint64 rhs_fk = ir_vreg_fkind_get(rhs)
            if lhs_fk == 2 && rhs_fk == 1 {
                uint64 lhs_w = ir_new_vreg()
                ir_emit(IR_F32TOF64, lhs_w, lhs, 0, 0, ir_current_bb)
                ir_vreg_fkind_set(lhs_w, 1)
                lhs = lhs_w
                lhs_fk = 1
            } else if lhs_fk == 1 && rhs_fk == 2 {
                uint64 rhs_w = ir_new_vreg()
                ir_emit(IR_F32TOF64, rhs_w, rhs, 0, 0, ir_current_bb)
                ir_vreg_fkind_set(rhs_w, 1)
                rhs = rhs_w
            }
            uint64 ir_op = IR_FADD
            if op_kind == 30 || op_kind == 45 { ir_op = IR_FADD }   // + +=
            if op_kind == 31 || op_kind == 46 { ir_op = IR_FSUB }   // - -=
            if op_kind == 22 || op_kind == 47 { ir_op = IR_FMUL }   // * *=
            if op_kind == 32 || op_kind == 48 { ir_op = IR_FDIV }   // / /=
            ir_emit(ir_op, dest, lhs, rhs, lhs_fk, ir_current_bb)
            ir_vreg_fkind_set(dest, lhs_fk)
            return dest
        }
        // Pick signed variants for div/mod when either operand is
        // signed. ADD/SUB/MUL produce identical bits in two's complement,
        // so they keep using the unsigned ops; only div/mod and ordered
        // compares actually need a separate instruction.
        uint64 lhs_s = ir_vreg_signed_get(lhs)
        uint64 rhs_s = ir_vreg_signed_get(rhs)
        uint64 use_signed = 0
        if lhs_s != 0 || rhs_s != 0 { use_signed = 1 }
        uint64 ir_op = IR_ADD
        if op_kind == 30 || op_kind == 45 { ir_op = IR_ADD }     // + +=
        if op_kind == 31 || op_kind == 46 { ir_op = IR_SUB }     // - -=
        if op_kind == 22 || op_kind == 47 { ir_op = IR_MUL }     // * *=
        if op_kind == 32 || op_kind == 48 {
            if use_signed != 0 { ir_op = IR_SDIV } else { ir_op = IR_DIV }   // / /=
        }
        if op_kind == 33 || op_kind == 49 {
            if use_signed != 0 { ir_op = IR_SMOD } else { ir_op = IR_MOD }   // % %=
        }
        if op_kind == 23 || op_kind == 50 { ir_op = IR_AND }     // & &=
        if op_kind == 24 || op_kind == 51 { ir_op = IR_OR }      // | |=
        if op_kind == 25 || op_kind == 52 { ir_op = IR_XOR }     // ^ ^=
        if op_kind == 43 || op_kind == 53 { ir_op = IR_SHL }     // << <<=
        if op_kind == 44 || op_kind == 54 {
            if use_signed != 0 { ir_op = IR_SAR } else { ir_op = IR_SHR }   // >> >>=
        }
        ir_emit(ir_op, dest, lhs, rhs, 0, ir_current_bb)
        // Propagate signed-int flag: if either operand is signed, the
        // result of arithmetic stays signed for downstream comparisons.
        // (ADD/SUB/MUL produce identical bits regardless of signedness;
        // we only need the flag so a later `< 0` picks IR_SCMP_LT.)
        if use_signed != 0 {
            ir_vreg_signed_set(dest, 1)
        }
        return dest
    }

    // Compare (38)
    if kind == 38 {
        uint32 op_tok = ast_data1(node)
        uint32 lhs_node = ast_child(node)
        uint32 rhs_node = ast_data2(node)
        uint64 op_kind = tok_kind_at_raw(op_tok)
        // Check for struct comparison (== or !=)
        if op_kind == 35 || op_kind == 36 {
            uint64 lhs_si = 0xFFFFFFFF
            uint64 rhs_si = 0xFFFFFFFF
            uint64 wlhs_n = lhs_node
            uint64 wrhs_n = rhs_node
            if wlhs_n != 0 {
                uint32 lk = ast_kind(wlhs_n)
                if lk == 32 {
                    uint32 lt = ast_data1(wlhs_n)
                    uint64 wlt = lt
                    lhs_si = struct_var_lookup(wlt)
                }
            }
            if lhs_si != 0xFFFFFFFF && wrhs_n != 0 {
                uint32 rk = ast_kind(wrhs_n)
                if rk == 32 {
                    uint32 rt = ast_data1(wrhs_n)
                    uint64 wrt = rt
                    rhs_si = struct_var_lookup(wrt)
                }
            }
            if lhs_si != 0xFFFFFFFF && rhs_si != 0xFFFFFFFF {
                // Struct comparison: memcmp both pointers
                uint64 lhs = ir_lower_expr(lhs_node)
                uint64 rhs = ir_lower_expr(rhs_node)
                uint64 ssize = struct_total_size(lhs_si)
                uint64 eq_v = ir_new_vreg()
                ir_emit(IR_MEMCMP, eq_v, lhs, rhs, ssize, ir_current_bb)
                if op_kind == 36 {
                    // != : invert the result
                    uint64 zero_v = ir_new_vreg()
                    ir_emit(IR_CONST, zero_v, 0, 0, 0, ir_current_bb)
                    uint64 ne_v = ir_new_vreg()
                    ir_emit(IR_CMP_EQ, ne_v, eq_v, zero_v, 0, ir_current_bb)
                    return ne_v
                }
                return eq_v
            }
        }
        uint64 lhs = ir_lower_expr(lhs_node)
        uint64 rhs = ir_lower_expr(rhs_node)
        uint64 dest = ir_new_vreg()
        // Check if LHS is float-typed
        uint64 cmp_fk = ir_vreg_fkind_get(lhs)
        if cmp_fk != 0 {
            // Float compare: operands must share an fkind or ucomiss/ucomisd
            // reads the wrong bit width. `f32 a == 1.0` previously compared
            // a 32-bit f32 (0x3F800000) against the low 32 bits of an f64
            // (which are zero for 1.0), so the equality always failed.
            // Widen the narrower side to f64 — no loss, and it matches the
            // C-style promotion users expect.
            uint64 rhs_fk = ir_vreg_fkind_get(rhs)
            if cmp_fk == 2 && rhs_fk == 1 {
                uint64 lhs_w = ir_new_vreg()
                ir_emit(IR_F32TOF64, lhs_w, lhs, 0, 0, ir_current_bb)
                ir_vreg_fkind_set(lhs_w, 1)
                lhs = lhs_w
                cmp_fk = 1
            } else if cmp_fk == 1 && rhs_fk == 2 {
                uint64 rhs_w = ir_new_vreg()
                ir_emit(IR_F32TOF64, rhs_w, rhs, 0, 0, ir_current_bb)
                ir_vreg_fkind_set(rhs_w, 1)
                rhs = rhs_w
            }
            uint64 ir_op = IR_FCMP_EQ
            if op_kind == 35 { ir_op = IR_FCMP_EQ }  // ==
            if op_kind == 36 { ir_op = IR_FCMP_NE }  // !=
            if op_kind == 37 { ir_op = IR_FCMP_LT }  // <
            if op_kind == 38 { ir_op = IR_FCMP_LE }  // <=
            if op_kind == 39 { ir_op = IR_FCMP_GT }  // >
            if op_kind == 40 { ir_op = IR_FCMP_GE }  // >=
            ir_emit(ir_op, dest, lhs, rhs, cmp_fk, ir_current_bb)
            return dest
        }
        // For ordered ints, pick signed variants if either operand is
        // explicitly signed (int8/16/32/64 declared, or f64_to_int / negate
        // result). Equality/inequality are bitwise, so they stay on the
        // unsigned ops regardless. Without this, `int64 k = -3; if k < 0`
        // lowers to `setb` (unsigned setb) and never fires — the bit
        // pattern 0xFFFFFFFFFFFFFFFD compares as huge-positive.
        uint64 lhs_s = ir_vreg_signed_get(lhs)
        uint64 rhs_s = ir_vreg_signed_get(rhs)
        uint64 use_signed = 0
        if lhs_s != 0 || rhs_s != 0 { use_signed = 1 }
        uint64 ir_op = IR_CMP_EQ
        if op_kind == 35 { ir_op = IR_CMP_EQ }  // ==
        if op_kind == 36 { ir_op = IR_CMP_NE }  // !=
        if op_kind == 37 {
            if use_signed != 0 { ir_op = IR_SCMP_LT } else { ir_op = IR_CMP_LT }
        }
        if op_kind == 38 {
            if use_signed != 0 { ir_op = IR_SCMP_LE } else { ir_op = IR_CMP_LE }
        }
        if op_kind == 39 {
            if use_signed != 0 { ir_op = IR_SCMP_GT } else { ir_op = IR_CMP_GT }
        }
        if op_kind == 40 {
            if use_signed != 0 { ir_op = IR_SCMP_GE } else { ir_op = IR_CMP_GE }
        }
        ir_emit(ir_op, dest, lhs, rhs, 0, ir_current_bb)
        return dest
    }

    // UnaryOp (34)
    if kind == 34 {
        uint32 op_tok = ast_data1(node)
        uint32 operand = ast_child(node)
        uint64 src = ir_lower_expr(operand)
        uint64 dest = ir_new_vreg()
        uint64 op_kind = tok_kind_at_raw(op_tok)
        if op_kind == 31 {
            // - (negate). For floats, lower as FSUB(0.0, src) — IR_NEG does
            // integer two's-complement which corrupts IEEE 754 bits.
            uint64 src_fk = ir_vreg_fkind_get(src)
            if src_fk != 0 {
                uint64 fzero = ir_new_vreg()
                ir_emit(IR_CONST, fzero, 0, 0, 0, ir_current_bb)
                ir_vreg_fkind_set(fzero, src_fk)
                ir_emit(IR_FSUB, dest, fzero, src, src_fk, ir_current_bb)
                ir_vreg_fkind_set(dest, src_fk)
            } else {
                ir_emit(IR_NEG, dest, src, 0, 0, ir_current_bb)
            }
        } else if op_kind == 27 {
            // ! (logical NOT) — compare src == 0
            uint64 zero = ir_new_vreg()
            ir_emit(IR_CONST, zero, 0, 0, 0, ir_current_bb)
            ir_emit(IR_CMP_EQ, dest, src, zero, 0, ir_current_bb)
        } else if op_kind == 26 {
            // ~ (bitwise NOT)
            ir_emit(IR_NOT, dest, src, 0, 0, ir_current_bb)
        } else {
            ir_emit(IR_COPY, dest, src, 0, 0, ir_current_bb)
        }
        return dest
    }

    // Call (35)
    if kind == 35 {
        uint32 callee_tok = ast_data1(node)
        uint64 wct = callee_tok
        // Check for exit() builtin — shadowed by a `@dynamic extern fn
        // exit` so the user can route through libc's exit when linking
        // dynamically (libc's exit flushes stdio, ours just calls
        // exit_group directly).
        if tok_matches(wct, "exit", 4) != 0 && dyn_sym_lookup(wct) == 0xFFFFFFFF {
            uint32 arg = ast_child(node)
            uint64 av = ir_lower_expr(arg)
            ir_emit(IR_ARG, 0, av, 0, 0, ir_current_bb)
            uint64 dest = ir_new_vreg()
            ir_emit(IR_SYSCALL, dest, 0, 0, 231, ir_current_bb)
            return dest
        }
        // write(fd, buf, len) → syscall 1
        if tok_matches(wct, "write", 5) != 0 {
            uint32 arg1 = ast_child(node)
            uint64 fd = ir_lower_expr(arg1)
            uint32 arg2 = ast_next(arg1)
            uint64 buf = ir_lower_expr(arg2)
            uint32 arg3 = ast_next(arg2)
            uint64 len = ir_lower_expr(arg3)
            ir_emit(IR_ARG, 0, fd, 0, 0, ir_current_bb)
            ir_emit(IR_ARG, 0, buf, 0, 1, ir_current_bb)
            ir_emit(IR_ARG, 0, len, 0, 2, ir_current_bb)
            uint64 dest = ir_new_vreg()
            ir_emit(IR_SYSCALL, dest, 0, 0, 1, ir_current_bb)
            return dest
        }
        // alloc(size) → IR_ALLOC
        if tok_matches(wct, "alloc", 5) != 0 {
            uint32 arg1 = ast_child(node)
            uint64 size_v = ir_lower_expr(arg1)
            uint64 dest = ir_new_vreg()
            ir_emit(IR_ALLOC, dest, size_v, 0, 0, ir_current_bb)
            return dest
        }
        // dealloc(ptr) → IR_DEALLOC
        if tok_matches(wct, "dealloc", 7) != 0 {
            uint32 arg1 = ast_child(node)
            uint64 ptr_v = ir_lower_expr(arg1)
            ir_emit(IR_DEALLOC, 0, ptr_v, 0, 0, ir_current_bb)
            uint64 dest = ir_new_vreg()
            ir_emit(IR_CONST, dest, 0, 0, 0, ir_current_bb)
            return dest
        }
        // store64(ptr, val) → IR_STORE
        if tok_matches(wct, "store64", 7) != 0 {
            uint32 arg1 = ast_child(node)
            uint64 ptr_v = ir_lower_expr(arg1)
            uint32 arg2 = ast_next(arg1)
            uint64 val_v = ir_lower_expr(arg2)
            ir_emit(IR_STORE, 8, ptr_v, val_v, 0, ir_current_bb)
            uint64 dest = ir_new_vreg()
            ir_emit(IR_CONST, dest, 0, 0, 0, ir_current_bb)
            return dest
        }
        // load64(ptr) → IR_LOAD
        if tok_matches(wct, "load64", 6) != 0 {
            uint32 arg1 = ast_child(node)
            uint64 ptr_v = ir_lower_expr(arg1)
            uint64 dest = ir_new_vreg()
            ir_emit(IR_LOAD, dest, ptr_v, 0, 8, ir_current_bb)
            return dest
        }
        // store32(ptr, val) → IR_STORE width 4
        if tok_matches(wct, "store32", 7) != 0 {
            uint32 arg1 = ast_child(node)
            uint64 ptr_v = ir_lower_expr(arg1)
            uint32 arg2 = ast_next(arg1)
            uint64 val_v = ir_lower_expr(arg2)
            ir_emit(IR_STORE, 4, ptr_v, val_v, 0, ir_current_bb)
            uint64 dest = ir_new_vreg()
            ir_emit(IR_CONST, dest, 0, 0, 0, ir_current_bb)
            return dest
        }
        // load32(ptr) → IR_LOAD width 4
        if tok_matches(wct, "load32", 6) != 0 {
            uint32 arg1 = ast_child(node)
            uint64 ptr_v = ir_lower_expr(arg1)
            uint64 dest = ir_new_vreg()
            ir_emit(IR_LOAD, dest, ptr_v, 0, 4, ir_current_bb)
            return dest
        }
        // store8(ptr, val) → IR_STORE width 1
        if tok_matches(wct, "store8", 6) != 0 {
            uint32 arg1 = ast_child(node)
            uint64 ptr_v = ir_lower_expr(arg1)
            uint32 arg2 = ast_next(arg1)
            uint64 val_v = ir_lower_expr(arg2)
            ir_emit(IR_STORE, 1, ptr_v, val_v, 0, ir_current_bb)
            uint64 dest = ir_new_vreg()
            ir_emit(IR_CONST, dest, 0, 0, 0, ir_current_bb)
            return dest
        }
        // load8(ptr) → IR_LOAD width 1
        if tok_matches(wct, "load8", 5) != 0 {
            uint32 arg1 = ast_child(node)
            uint64 ptr_v = ir_lower_expr(arg1)
            uint64 dest = ir_new_vreg()
            ir_emit(IR_LOAD, dest, ptr_v, 0, 1, ir_current_bb)
            return dest
        }
        // store16(ptr, val) → IR_STORE width 2
        if tok_matches(wct, "store16", 7) != 0 {
            uint32 arg1 = ast_child(node)
            uint64 ptr_v = ir_lower_expr(arg1)
            uint32 arg2 = ast_next(arg1)
            uint64 val_v = ir_lower_expr(arg2)
            ir_emit(IR_STORE, 2, ptr_v, val_v, 0, ir_current_bb)
            uint64 dest = ir_new_vreg()
            ir_emit(IR_CONST, dest, 0, 0, 0, ir_current_bb)
            return dest
        }
        // load16(ptr) → IR_LOAD width 2
        if tok_matches(wct, "load16", 6) != 0 {
            uint32 arg1 = ast_child(node)
            uint64 ptr_v = ir_lower_expr(arg1)
            uint64 dest = ir_new_vreg()
            ir_emit(IR_LOAD, dest, ptr_v, 0, 2, ir_current_bb)
            return dest
        }
        // vstore32(ptr, val) → IR_VSTORE width 4
        if tok_matches(wct, "vstore32", 8) != 0 {
            uint32 arg1 = ast_child(node)
            uint64 ptr_v = ir_lower_expr(arg1)
            uint32 arg2 = ast_next(arg1)
            uint64 val_v = ir_lower_expr(arg2)
            ir_emit(IR_VSTORE, 4, ptr_v, val_v, 0, ir_current_bb)
            uint64 dest = ir_new_vreg()
            ir_emit(IR_CONST, dest, 0, 0, 0, ir_current_bb)
            return dest
        }
        // vstore64(ptr, val) → IR_VSTORE width 8
        if tok_matches(wct, "vstore64", 8) != 0 {
            uint32 arg1 = ast_child(node)
            uint64 ptr_v = ir_lower_expr(arg1)
            uint32 arg2 = ast_next(arg1)
            uint64 val_v = ir_lower_expr(arg2)
            ir_emit(IR_VSTORE, 8, ptr_v, val_v, 0, ir_current_bb)
            uint64 dest = ir_new_vreg()
            ir_emit(IR_CONST, dest, 0, 0, 0, ir_current_bb)
            return dest
        }
        // vload32(ptr) → IR_VLOAD width 4
        if tok_matches(wct, "vload32", 7) != 0 {
            uint32 arg1 = ast_child(node)
            uint64 ptr_v = ir_lower_expr(arg1)
            uint64 dest = ir_new_vreg()
            ir_emit(IR_VLOAD, dest, ptr_v, 0, 4, ir_current_bb)
            return dest
        }
        // vload64(ptr) → IR_VLOAD width 8
        if tok_matches(wct, "vload64", 7) != 0 {
            uint32 arg1 = ast_child(node)
            uint64 ptr_v = ir_lower_expr(arg1)
            uint64 dest = ir_new_vreg()
            ir_emit(IR_VLOAD, dest, ptr_v, 0, 8, ir_current_bb)
            return dest
        }
        // atomic_store(ptr, val) → IR_ATOMIC_STORE
        if tok_matches(wct, "atomic_store", 12) != 0 {
            uint32 arg1 = ast_child(node)
            uint64 ptr_v = ir_lower_expr(arg1)
            uint32 arg2 = ast_next(arg1)
            uint64 val_v = ir_lower_expr(arg2)
            ir_emit(IR_ATOMIC_STORE, 0, ptr_v, val_v, 0, ir_current_bb)
            uint64 dest = ir_new_vreg()
            ir_emit(IR_CONST, dest, 0, 0, 0, ir_current_bb)
            return dest
        }
        // atomic_load(ptr) → IR_ATOMIC_LOAD
        if tok_matches(wct, "atomic_load", 11) != 0 {
            uint32 arg1 = ast_child(node)
            uint64 ptr_v = ir_lower_expr(arg1)
            uint64 dest = ir_new_vreg()
            ir_emit(IR_ATOMIC_LOAD, dest, ptr_v, 0, 0, ir_current_bb)
            return dest
        }
        // atomic_add(ptr, val) → IR_ATOMIC_ADD (returns old value)
        if tok_matches(wct, "atomic_add", 10) != 0 {
            uint32 arg1 = ast_child(node)
            uint64 ptr_v = ir_lower_expr(arg1)
            uint32 arg2 = ast_next(arg1)
            uint64 val_v = ir_lower_expr(arg2)
            uint64 dest = ir_new_vreg()
            ir_emit(IR_ATOMIC_ADD, dest, ptr_v, val_v, 0, ir_current_bb)
            return dest
