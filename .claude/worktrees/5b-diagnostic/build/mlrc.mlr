        // positive and also fails, which is exactly what we want).
        uint64 idx_r = ir_resolve_src(s1_v, 0)
        if idx_r != 0 {
            ir_emit_mov_r64_r64(0, idx_r)
        }
        emit_byte(0x48); emit_byte(0x3D)
        emit_u32_le(imm)
        emit_byte(0x72)
        uint64 bchk_jb = out_len
        emit_byte(0)
        emit_mov_rax_imm(1)
        emit_mov_rdi_rax()
        if target_os == 2 { emit_mov_rcx_rax(); emit_win_alloc_stack(0x20); emit_win_call_iat(0) }
        else if target_os == 1 { emit_mov_rax_imm(0x2000001); emit_byte(0x0F); emit_byte(0x05) }
        else { emit_mov_rax_imm(231); emit_byte(0x0F); emit_byte(0x05) }
        uint64 bchk_skip = out_len - bchk_jb - 1
        uint8 bchk_s = bchk_skip
        uint64 bchk_pp = out_buf + bchk_jb
        unsafe { *(bchk_pp as uint8) = bchk_s }
        return
    }

    // ---------------------------------------------------------------
    // Float opcodes
    // ---------------------------------------------------------------

    if op == 26 {
        // IR_ITOF: cvtsi2sd xmm0, rax; movq rax, xmm0
        uint64 a_reg = ir_resolve_src(s1_v, 0)
        ir_emit_mov_r64_r64(0, a_reg)
        // cvtsi2sd xmm0, rax: F2 48 0F 2A C0
        emit_byte(0xF2); emit_byte(0x48); emit_byte(0x0F); emit_byte(0x2A); emit_byte(0xC0)
        // movq rax, xmm0: 66 48 0F 7E C0
        emit_byte(0x66); emit_byte(0x48); emit_byte(0x0F); emit_byte(0x7E); emit_byte(0xC0)
        if dst_r != 0xFFFFFFFF {
            ir_emit_mov_r64_r64(dst_r, 0)
        } else {
            ir_emit_store_spill(0, dest_v)
        }
        return
    }

    if op == 27 {
        // IR_FTOI: movq xmm0, rax; cvttsd2si rax, xmm0
        uint64 a_reg = ir_resolve_src(s1_v, 0)
        ir_emit_mov_r64_r64(0, a_reg)
        // movq xmm0, rax: 66 48 0F 6E C0
        emit_byte(0x66); emit_byte(0x48); emit_byte(0x0F); emit_byte(0x6E); emit_byte(0xC0)
        // cvttsd2si rax, xmm0: F2 48 0F 2C C0
        emit_byte(0xF2); emit_byte(0x48); emit_byte(0x0F); emit_byte(0x2C); emit_byte(0xC0)
        if dst_r != 0xFFFFFFFF {
            ir_emit_mov_r64_r64(dst_r, 0)
        } else {
            ir_emit_store_spill(0, dest_v)
        }
        return
    }

    if op == 107 {
        // IR_ITOF32: cvtsi2ss xmm0, rax; movd eax, xmm0; zero-extend
        uint64 a_reg = ir_resolve_src(s1_v, 0)
        ir_emit_mov_r64_r64(0, a_reg)
        // cvtsi2ss xmm0, rax: F3 48 0F 2A C0
        emit_byte(0xF3); emit_byte(0x48); emit_byte(0x0F); emit_byte(0x2A); emit_byte(0xC0)
        // movq rax, xmm0: 66 48 0F 7E C0
        emit_byte(0x66); emit_byte(0x48); emit_byte(0x0F); emit_byte(0x7E); emit_byte(0xC0)
        if dst_r != 0xFFFFFFFF {
            ir_emit_mov_r64_r64(dst_r, 0)
        } else {
            ir_emit_store_spill(0, dest_v)
        }
        return
    }

    if op == 108 {
        // IR_FTOI32: movq xmm0, rax; cvttss2si rax, xmm0
        uint64 a_reg = ir_resolve_src(s1_v, 0)
        ir_emit_mov_r64_r64(0, a_reg)
        // movq xmm0, rax: 66 48 0F 6E C0
        emit_byte(0x66); emit_byte(0x48); emit_byte(0x0F); emit_byte(0x6E); emit_byte(0xC0)
        // cvttss2si rax, xmm0: F3 48 0F 2C C0
        emit_byte(0xF3); emit_byte(0x48); emit_byte(0x0F); emit_byte(0x2C); emit_byte(0xC0)
        if dst_r != 0xFFFFFFFF {
            ir_emit_mov_r64_r64(dst_r, 0)
        } else {
            ir_emit_store_spill(0, dest_v)
        }
        return
