        // single use, stash the jcc code and stop here. The terminator will
        // emit `0F <jcc> disp32` directly on the flags we just set.
        uint64 fuse = ir_cmp_fuse_code(ii)
        if fuse != 0 {
            ir_fused_jcc_code = fuse
            return
        }
