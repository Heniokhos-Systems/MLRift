// Phase 3c-8 — gemv_coop_bf16_f32 (cooperative-row gemv, bf16 weights).
//
// Recognises a kernel of the form:
//
//   @kernel fn name(uint64 a_ptr, uint64 b_ptr, uint64 c_ptr,
//                   uint64 m, uint64 k_dim) {
//       uint64 row = block_idx_x()
//       uint64 lane = tid_local_x()
//       if row < m {
//           ... while j<k_dim { u16 a; bf16 dequant; partial+=a*b } ...
//           f32 total = lds_reduce_sum_f32(partial)
//           if lane == 0 { c[row] = total }
//       }
//   }
//
// Discriminator vs 3c-7 (gemv_coop_f32): presence of a u16 PtrLoad
// (data1=2, data3=0) — the bf16 weight load.  Routing places 3c-8
// BEFORE 3c-7 so bf16 wins.
//
// Returns 0 on success; non-zero means "doesn't match the 3c-8 shape".
fn amdgpu_lower_gemv_coop_bf16_f32_3c(uint64 fn_node, uint64 source,
                                       uint64 kname_ptr, uint64 nl) -> uint64 {
    uint64 n_params = 0
    uint64 wp = ast_child(fn_node)
    while wp != 0 {
        n_params = n_params + 1
        wp = ast_next(wp)
    }
    if n_params != 5 { return 1 }

    uint32 body = ast_data3(fn_node)
    if body == 0 { return 1 }
    if ast_kind(body) != 15 { return 1 }

    // Recursive search: must have lds_reduce_sum_f32 AND a u16 PtrLoad.
    uint64 saw_lds_reduce = 0
    uint64 saw_u16 = 0
    uint32 walk = ast_child(body)
    while walk != 0 {
        if ast_kind(walk) == 41 {
            if ast_data1(walk) == 2 {
                if ast_data3(walk) == 0 { saw_u16 = 1 }
            }
        }
        if ast_kind(walk) == 35 {
            uint32 callee = ast_data1(walk)
            if tok_matches(callee, "lds_reduce_sum_f32", 18) != 0 { saw_lds_reduce = 1 }
        }
        if ast_kind(walk) == 10 {
            uint32 init = ast_child(walk)
            if init != 0 && ast_kind(init) == 35 {
                uint32 callee = ast_data1(init)
                if tok_matches(callee, "lds_reduce_sum_f32", 18) != 0 { saw_lds_reduce = 1 }
            }
        }
        if ast_kind(walk) == 13 {
            uint32 tblk = ast_data1(walk)
            if tblk != 0 && ast_kind(tblk) == 15 {
                uint32 tw = ast_child(tblk)
                while tw != 0 {
                    if ast_kind(tw) == 41 {
                        if ast_data1(tw) == 2 {
                            if ast_data3(tw) == 0 { saw_u16 = 1 }
                        }
                    }
                    if ast_kind(tw) == 10 {
                        uint32 i2 = ast_child(tw)
                        if i2 != 0 && ast_kind(i2) == 35 {
                            uint32 c2 = ast_data1(i2)
                            if tok_matches(c2, "lds_reduce_sum_f32", 18) != 0 { saw_lds_reduce = 1 }
                        }
                    }
                    if ast_kind(tw) == 35 {
                        uint32 c2 = ast_data1(tw)
                        if tok_matches(c2, "lds_reduce_sum_f32", 18) != 0 { saw_lds_reduce = 1 }
                    }
                    if ast_kind(tw) == 14 {
                        uint32 wbody = ast_data1(tw)
                        if wbody != 0 && ast_kind(wbody) == 15 {
                            uint32 ws = ast_child(wbody)
                            while ws != 0 {
                                if ast_kind(ws) == 41 {
                                    if ast_data1(ws) == 2 {
                                        if ast_data3(ws) == 0 { saw_u16 = 1 }
                                    }
                                }
                                ws = ast_next(ws)
                            }
                        }
                    }
                    tw = ast_next(tw)
                }
            }
        }
        walk = ast_next(walk)
    }
    if saw_lds_reduce == 0 { return 1 }
    if saw_u16 == 0 { return 1 }

    // ── emit ISA ─────────────────────────────────────────────────
    // Delegate to the production hand-tuned `_emit_gemv_coop_bf16_f32_body`.
    uint64 args_desc = alloc(10 * 16)
    _emit_gemv_coop_bf16_f32_body(args_desc)

    uint64 k_text_size = asm_text_len
    uint64 k_text_buf  = alloc(k_text_size)
    uint64 ci = 0
    while ci < k_text_size {
        uint64 sp = asm_text_buf + ci
        uint64 b = 0
        unsafe { *(sp as uint8) -> b }
        uint64 dp = k_text_buf + ci
        uint8 b8 = b
        unsafe { *(dp as uint8) = b8 }
        ci = ci + 1
    }

    // KD identical to the gemv_coop_bf16_f32 blob.
    uint64 rsrc1 = 0xE0AF0003
    uint64 rsrc2 = 0x0000009E
    uint64 rsrc3 = 0x00000010
    uint64 props = 0x0408

    kt_push_lds(kname_ptr, nl, k_text_buf, k_text_size,
                args_desc, 5, 40,
                18, 32,
                rsrc1, rsrc2, rsrc3, props,
                128)
    return 0
}

// Phase 3c-3 — gemm_f32 (16x16 tile, one lane per cell, serial K-loop).
//
// Recognises a kernel of the form:
//
//   @kernel fn name(uint64 a_ptr, uint64 b_ptr, uint64 c_ptr,
//                   uint64 m, uint64 n, uint64 k_dim) {
//       ... derive (row, col) from lane id ...
//       if row < m {
//           if col < n {
//               while t < k_dim { sum += a*b; t++ }
//               c[row, col] = sum
//           }
//       }
//   }
//
// Discriminator: 6 params + body contains at least one While stmt.
// 6 params is unique among current recognisers (gemv has 5, rmsnorm/
// rope have 5).
//
// Returns 0 on success; non-zero means "doesn't match the 3c-3 shape".
fn amdgpu_lower_gemm_f32_3c(uint64 fn_node, uint64 source,
                             uint64 kname_ptr, uint64 nl) -> uint64 {
    uint64 n_params = 0
    uint64 wp = ast_child(fn_node)
    while wp != 0 {
        n_params = n_params + 1
        wp = ast_next(wp)
    }
    if n_params != 6 { return 1 }

    // Body must be a Block with at least one While reachable from
    // the top level (transitively — via the nested If-If-While).
    uint32 body = ast_data3(fn_node)
    if body == 0 { return 1 }
    if ast_kind(body) != 15 { return 1 }
    // Recursive search for any While in the body subtree.
    uint64 saw_while = 0
    uint32 walk = ast_child(body)
    while walk != 0 {
        if ast_kind(walk) == 14 { saw_while = 1 }
        if ast_kind(walk) == 13 {
            // descend into If's then-block
            uint32 tblk = ast_data1(walk)
            if tblk != 0 && ast_kind(tblk) == 15 {
                uint32 tw = ast_child(tblk)
                while tw != 0 {
                    if ast_kind(tw) == 14 { saw_while = 1 }
                    if ast_kind(tw) == 13 {
                        uint32 tb2 = ast_data1(tw)
                        if tb2 != 0 && ast_kind(tb2) == 15 {
                            uint32 tw2 = ast_child(tb2)
                            while tw2 != 0 {
                                if ast_kind(tw2) == 14 { saw_while = 1 }
                                tw2 = ast_next(tw2)
                            }
                        }
                    }
                    tw = ast_next(tw)
                }
            }
        }
        walk = ast_next(walk)
    }
    if saw_while == 0 { return 1 }

    // 60-dword gemm_f32 body via asm_u32_arch pair-picker.  New pairs
    // this slice: s_branch (SOPP op 0x20 → 0x02), s_and_b32 (SOP2 op
    // 0x0B → 0x07).  Stashes WG_ID_X (s15) into s3 before kernarg load
    // since s_load_b64 s[14:15] 0x28 would clobber s15.
    asm_init()
    asm_u32_arch(0xBE83000F, 0xBE83030F) // s_mov_b32 s3, s15
    asm_u32_arch(0xF40C0100, 0xF40C0100); asm_u32_arch(0xF8000000, 0xFA000000)
    asm_u32_arch(0xF4040300, 0xF4040300); asm_u32_arch(0xF8000020, 0xFA000020)
    asm_u32_arch(0xF4040380, 0xF4040380); asm_u32_arch(0xF8000028, 0xFA000028)
    asm_u32_arch(0xBF89FC07, 0xBF8CC07F)
    asm_u32_arch(0x32020084, 0x2C020084) // v_lshrrev_b32 v1, 4, v0
    asm_u32     (0x3604008F)             // v_and_b32 v2, 15, v0 (VOP2 stable)
    asm_u32     (0x80108F0C)             // s_add_u32 s16, s12, s15 (SOP2 stable)
    asm_u32_arch(0x85108410, 0x90108410) // s_lshr_b32 s16, s16, 4
    asm_u32_arch(0xBE910003, 0xBE910303) // s_mov_b32 s17, s3
    asm_u32_arch(0xBE920080, 0xBE920380) // s_mov_b32 s18, 0
    asm_u32     (0xBF0A1011)             // s_cmp_lt_u32 s17, s16 (SOPC stable)
    asm_u32_arch(0xBFA20003, 0xBF850003) // s_cbranch_scc1 +3
    asm_u32     (0x80911011)             // s_sub_u32 s17, s17, s16 (SOP2 stable)
    asm_u32     (0x80128112)             // s_add_u32 s18, s18, 1
    asm_u32_arch(0xBFA0FFFB, 0xBF82FFFB) // s_branch -5
    asm_u32_arch(0x84138412, 0x8F138412) // s_lshl_b32 s19, s18, 4
    asm_u32_arch(0x84148411, 0x8F148411) // s_lshl_b32 s20, s17, 4
    asm_u32     (0x4A060213)             // v_add_nc_u32 v3, s19, v0 (VOP2 stable)
    asm_u32     (0x4A080414)             // v_add_nc_u32 v4, s20, v1
    asm_u32_arch(0xBE82007E, 0xBE82037E) // s_mov_b32 s2, exec_lo
    asm_u32_arch(0x7C98060A, 0x7D88060A) // v_cmp_gt_u32 vcc_lo, s10, v3
    asm_u32_arch(0x8B7E6A7E, 0x877E6A7E) // s_and_b32 exec_lo, exec_lo, vcc_lo
    asm_u32_arch(0x7C98080C, 0x7D88080C) // v_cmp_gt_u32 vcc_lo, s12, v4
    asm_u32_arch(0x8B7E6A7E, 0x877E6A7E) // s_and_b32 exec_lo, exec_lo, vcc_lo
    asm_u32_arch(0xBFA50032, 0xBF880032) // s_cbranch_execz +50
    asm_u32_arch(0xD72C0008, 0xD5690008); asm_u32(0x00001D03) // v_mul_lo_u32 v8, s3, v3
    asm_u32     (0x7E120280)             // v_mov_b32 v9, 0
    asm_u32_arch(0xD73C0008, 0xD6FF0008); asm_u32(0x00021082) // v_lshlrev_b64 v[8:9], 2, v[8:9]
    asm_u32_arch(0xD7006A08, 0xD70F6A08); asm_u32(0x00021004) // v_add_co_u32 v8, vcc_lo, s4, v8
    asm_u32_arch(0xD5207C09, 0xD5287D09); asm_u32(0x01AA1205) // v_add_co_ci_u32 v9, null, s5, v9, vcc_lo
    asm_u32_arch(0x30140882, 0x34140882) // v_lshlrev_b32 v10, 2, v4
    asm_u32     (0x7E160280)             // v_mov_b32 v11, 0
    asm_u32_arch(0xD7006A0A, 0xD70F6A0A); asm_u32(0x00021406) // v_add_co_u32 v10, vcc_lo, s6, v10
    asm_u32_arch(0xD5207C0B, 0xD5287D0B); asm_u32(0x01AA1607) // v_add_co_ci_u32 v11, null, s7, v11, vcc_lo
    asm_u32_arch(0x8411820C, 0x8F11820C) // s_lshl_b32 s17, s12, 2
    asm_u32     (0x7E180280)             // v_mov_b32 v12, 0
    asm_u32_arch(0xBE900080, 0xBE900380) // s_mov_b32 s16, 0  (loop counter)
    asm_u32     (0xBF090E10)             // s_cmp_ge_u32 s14, s16  (SOPC stable)
    asm_u32_arch(0xBFA20011, 0xBF850011) // s_cbranch_scc1 +17  (skip loop)
    asm_u32_arch(0xDC520000, 0xDC308000); asm_u32_arch(0x0D7C0008, 0x0D7D0008) // global_load_b32 v13, v[8:9]
    asm_u32_arch(0xDC520000, 0xDC308000); asm_u32_arch(0x0E7C000A, 0x0E7D000A) // global_load_b32 v14, v[10:11]
    asm_u32_arch(0xBF8903F7, 0xBF8C3F70) // s_waitcnt vmcnt(0)
    asm_u32     (0x56181D0D)             // v_fmac_f32 v12, v13, v14 (VOP2 stable)
    asm_u32_arch(0xD7006A08, 0xD70F6A08); asm_u32(0x00010908) // v_add_co_u32 v8, vcc_lo, v8, 4
    asm_u32_arch(0xD5207C09, 0xD5287D09); asm_u32(0x01AA1280) // v_add_co_ci_u32 v9, null, 0, v9, vcc_lo
    asm_u32_arch(0xD7006A0A, 0xD70F6A0A); asm_u32(0x0000230A) // v_add_co_u32 v10, vcc_lo, v10, s17
    asm_u32_arch(0xD5207C0B, 0xD5287D0B); asm_u32(0x01AA1680) // v_add_co_ci_u32 v11, null, 0, v11, vcc_lo
    asm_u32     (0x80108110)             // s_add_u32 s16, s16, 1 (stable)
    asm_u32     (0xBF0A0E10)             // s_cmp_lt_u32 s14, s16 (stable)
    asm_u32_arch(0xBFA2FFEF, 0xBF85FFEF) // s_cbranch_scc1 -17
    asm_u32_arch(0xD72C0008, 0xD5690008); asm_u32(0x00001903) // v_mul_lo_u32 v8, s3, v1
    asm_u32     (0x4A100908)             // v_add_nc_u32 v8, s8, v8 (VOP2 stable)
    asm_u32     (0x7E120280)             // v_mov_b32 v9, 0
    asm_u32_arch(0xD73C0008, 0xD6FF0008); asm_u32(0x00021082) // v_lshlrev_b64 v[8:9], 2, v[8:9]
    asm_u32_arch(0xD7006A08, 0xD70F6A08); asm_u32(0x00021008) // v_add_co_u32 v8, vcc_lo, s8, v8
    asm_u32_arch(0xD5207C09, 0xD5287D09); asm_u32(0x01AA1209) // v_add_co_ci_u32 v9, null, s9, v9, vcc_lo
    asm_u32_arch(0xDC6A0000, 0xDC708000); asm_u32_arch(0x007C0C08, 0x007D0C08) // global_store_b32 v[8:9], v12
    asm_u32_arch(0xBC7C0000, 0xBBFD0000) // s_waitcnt_vscnt
    asm_u32_arch(0xBFB00000, 0xBF810000) // s_endpgm

    uint64 args_desc = alloc(12 * 16)
    uint64 a0  = args_desc +  0;  unsafe { *(a0  as uint64) = 8 }
    uint64 a1  = args_desc +  8;  unsafe { *(a1  as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a2  = args_desc + 16;  unsafe { *(a2  as uint64) = 8 }
    uint64 a3  = args_desc + 24;  unsafe { *(a3  as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a4  = args_desc + 32;  unsafe { *(a4  as uint64) = 8 }
    uint64 a5  = args_desc + 40;  unsafe { *(a5  as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a6  = args_desc + 48;  unsafe { *(a6  as uint64) = 8 }
    uint64 a7  = args_desc + 56;  unsafe { *(a7  as uint64) = AMD_ARG_KIND_BY_VALUE }
    uint64 a8  = args_desc + 64;  unsafe { *(a8  as uint64) = 8 }
    uint64 a9  = args_desc + 72;  unsafe { *(a9  as uint64) = AMD_ARG_KIND_BY_VALUE }
    uint64 a10 = args_desc + 80;  unsafe { *(a10 as uint64) = 8 }
    uint64 a11 = args_desc + 88;  unsafe { *(a11 as uint64) = AMD_ARG_KIND_BY_VALUE }

    uint64 k_text_size = asm_text_len
    uint64 k_text_buf  = alloc(k_text_size)
    uint64 ci = 0
    while ci < k_text_size {
        uint64 sp = asm_text_buf + ci
        uint64 b = 0
        unsafe { *(sp as uint8) -> b }
        uint64 dp = k_text_buf + ci
        uint8 b8 = b
        unsafe { *(dp as uint8) = b8 }
        ci = ci + 1
    }

    // KD identical to legacy hand-tuned gemm_f32: 21 SGPRs / 13 VGPRs,
    // USER_SGPR_COUNT=15, no LDS, rsrc1=0xE0AF0001.
    uint64 rsrc1 = 0xE0AF0001
    uint64 rsrc2 = 0x0000009E
    uint64 rsrc3 = 0x00000010
    uint64 props = 0x0408

    kt_push(kname_ptr, nl, k_text_buf, k_text_size,
            args_desc, 6, 48,
            21, 13,
            rsrc1, rsrc2, rsrc3, props)
    return 0
}

// Phase 3c-4 — gemm_f32_lds (16x16 tile, LDS double-buffer, K-loop).
//
// Recognises a kernel with:
//   - 6 params (a, b, c, m, n, k_dim) — same as gemm_f32
//   - Calls to LDS intrinsics: sync_block, lds_load_f32, lds_store_f32
//
// Discriminator: presence of LDS-intrinsic calls (vs plain gemm_f32
// which has neither).  Routing places 3c-4 BEFORE 3c-3 so LDS wins
// when the @kernel uses shared memory.
//
// Returns 0 on success; non-zero means "doesn't match the 3c-4 shape".
fn amdgpu_lower_gemm_f32_lds_3c(uint64 fn_node, uint64 source,
                                 uint64 kname_ptr, uint64 nl) -> uint64 {
    uint64 n_params = 0
    uint64 wp = ast_child(fn_node)
    while wp != 0 {
        n_params = n_params + 1
        wp = ast_next(wp)
    }
    if n_params != 6 { return 1 }

    uint32 body = ast_data3(fn_node)
    if body == 0 { return 1 }
    if ast_kind(body) != 15 { return 1 }

    // Recursive search for any Call to {sync_block, lds_load_f32,
    // lds_store_f32} in the body subtree (top-level + nested if/while).
    uint64 saw_lds = 0
    uint32 walk = ast_child(body)
    while walk != 0 {
        if ast_kind(walk) == 35 {
            uint32 callee = ast_data1(walk)
            if tok_matches(callee, "sync_block",     10) != 0 { saw_lds = 1 }
            if tok_matches(callee, "lds_load_f32",   12) != 0 { saw_lds = 1 }
            if tok_matches(callee, "lds_store_f32",  13) != 0 { saw_lds = 1 }
        }
        if ast_kind(walk) == 10 {
            uint32 init = ast_child(walk)
            if init != 0 && ast_kind(init) == 35 {
                uint32 callee = ast_data1(init)
                if tok_matches(callee, "sync_block",     10) != 0 { saw_lds = 1 }
                if tok_matches(callee, "lds_load_f32",   12) != 0 { saw_lds = 1 }
                if tok_matches(callee, "lds_store_f32",  13) != 0 { saw_lds = 1 }
            }
        }
        if ast_kind(walk) == 13 {
            uint32 tblk = ast_data1(walk)
            if tblk != 0 && ast_kind(tblk) == 15 {
                uint32 tw = ast_child(tblk)
                while tw != 0 {
                    if ast_kind(tw) == 35 {
                        uint32 c2 = ast_data1(tw)
                        if tok_matches(c2, "sync_block",    10) != 0 { saw_lds = 1 }
                        if tok_matches(c2, "lds_load_f32",  12) != 0 { saw_lds = 1 }
                        if tok_matches(c2, "lds_store_f32", 13) != 0 { saw_lds = 1 }
                    }
                    if ast_kind(tw) == 10 {
                        uint32 i2 = ast_child(tw)
                        if i2 != 0 && ast_kind(i2) == 35 {
                            uint32 c3 = ast_data1(i2)
                            if tok_matches(c3, "sync_block",    10) != 0 { saw_lds = 1 }
                            if tok_matches(c3, "lds_load_f32",  12) != 0 { saw_lds = 1 }
                            if tok_matches(c3, "lds_store_f32", 13) != 0 { saw_lds = 1 }
                        }
                    }
                    tw = ast_next(tw)
                }
            }
        }
        walk = ast_next(walk)
    }
    if saw_lds == 0 { return 1 }

    // ── emit ISA ─────────────────────────────────────────────────
    // Sequence ported verbatim from `_emit_gemm_f32_lds_body`.
    asm_init()
    asm_u32(0xF40C0100); asm_u32(0xF8000000)
    asm_u32(0xF4040300); asm_u32(0xF8000020)
    asm_u32(0xF4040380); asm_u32(0xF8000028)
    asm_u32(0xBF89FC07)
    asm_u32(0xD6100001); asm_u32(0x02291500)
    asm_u32(0x360000FF); asm_u32(0x000003FF)
    asm_u32(0x84108403)
    asm_u32(0x84118402)
    asm_u32(0x4A060210)
    asm_u32(0x4A080011)
    asm_u32(0xBE82007E)
    asm_u32(0x7C98060A)
    asm_u32(0x8B7E6A7E)
    asm_u32(0x7C98080C)
    asm_u32(0x8B7E6A7E)
    asm_u32(0xBFA50054)
    asm_u32(0x8512840E)
    asm_u32(0x7E0C0280)
    asm_u32(0xBE930080)
    asm_u32(0x300A0284)
    asm_u32(0x4A0A0105)
    asm_u32(0x300A0A82)
    asm_u32(0x30220286)
    asm_u32(0x30240082)
    asm_u32(0xD5250012); asm_u32(0x0001FF12); asm_u32(0x00000400)
    asm_u32(0xBF068012)
    asm_u32(0xBFA2003D)
    asm_u32(0x84148413)
    asm_u32(0x4A0E0014)
    asm_u32(0xD72C0008); asm_u32(0x00001D03)
    asm_u32(0x4A100F08)
    asm_u32(0x7E120280)
    asm_u32(0xD73C0008); asm_u32(0x00021082)
    asm_u32(0xD7006A08); asm_u32(0x00021004)
    asm_u32(0xD5207C09); asm_u32(0x01AA1205)
    asm_u32(0xBF870001)
    asm_u32(0xDC520000); asm_u32(0x0A7C0008)
    asm_u32(0x4A160214)
    asm_u32(0xD72C000C); asm_u32(0x0000190B)
    asm_u32(0x4A18090C)
    asm_u32(0x7E1A0280)
    asm_u32(0xD73C000C); asm_u32(0x00021882)
    asm_u32(0xD7006A0C); asm_u32(0x00021806)
    asm_u32(0xD5207C0D); asm_u32(0x01AA1A07)
    asm_u32(0xBF870001)
    asm_u32(0xDC520000); asm_u32(0x0E7C000C)
    asm_u32(0xBF8903F7)
    asm_u32(0xD8340000); asm_u32(0x00000A05)
    asm_u32(0xD8340400); asm_u32(0x00000E05)
    asm_u32(0xBF89FC07)
    asm_u32(0xBFBD0000)
    asm_u32(0xE0AC0000); asm_u32(0x00000000)
    asm_u32(0xBE940080)
    asm_u32(0x7E1E0311)
    asm_u32(0x7E200312)
    asm_u32(0xBF870002)
    asm_u32(0xD8D80000); asm_u32(0x0900000F)
    asm_u32(0xD8D80000); asm_u32(0x0A000010)
    asm_u32(0xBF89FC07)
    asm_u32(0x560C1509)
    asm_u32(0xD525000F); asm_u32(0x0001090F)
    asm_u32(0xD5250010); asm_u32(0x00018110)
    asm_u32(0x80148114)
    asm_u32(0xBF0A9014)
    asm_u32(0xBFA2FFF2)
    asm_u32(0xBFBD0000)
    asm_u32(0xE0AC0000); asm_u32(0x00000000)
    asm_u32(0x80138113)
    asm_u32(0xBF0A1213)
    asm_u32(0xBFA2FFC3)
    asm_u32(0xD72C0008); asm_u32(0x00001903)
    asm_u32(0x4A100908)
    asm_u32(0x7E120280)
    asm_u32(0xD73C0008); asm_u32(0x00021082)
    asm_u32(0xD7006A08); asm_u32(0x00021008)
    asm_u32(0xD5207C09); asm_u32(0x01AA1209)
    asm_u32(0xDC6A0000); asm_u32(0x007C0608)
    asm_u32(0xBC7C0000)
    asm_u32(0xBFB00000)

    uint64 args_desc = alloc(12 * 16)
    uint64 a0  = args_desc +  0;  unsafe { *(a0  as uint64) = 8 }
    uint64 a1  = args_desc +  8;  unsafe { *(a1  as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a2  = args_desc + 16;  unsafe { *(a2  as uint64) = 8 }
    uint64 a3  = args_desc + 24;  unsafe { *(a3  as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a4  = args_desc + 32;  unsafe { *(a4  as uint64) = 8 }
    uint64 a5  = args_desc + 40;  unsafe { *(a5  as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a6  = args_desc + 48;  unsafe { *(a6  as uint64) = 8 }
    uint64 a7  = args_desc + 56;  unsafe { *(a7  as uint64) = AMD_ARG_KIND_BY_VALUE }
    uint64 a8  = args_desc + 64;  unsafe { *(a8  as uint64) = 8 }
    uint64 a9  = args_desc + 72;  unsafe { *(a9  as uint64) = AMD_ARG_KIND_BY_VALUE }
    uint64 a10 = args_desc + 80;  unsafe { *(a10 as uint64) = 8 }
    uint64 a11 = args_desc + 88;  unsafe { *(a11 as uint64) = AMD_ARG_KIND_BY_VALUE }

    uint64 k_text_size = asm_text_len
    uint64 k_text_buf  = alloc(k_text_size)
    uint64 ci = 0
    while ci < k_text_size {
        uint64 sp = asm_text_buf + ci
        uint64 b = 0
        unsafe { *(sp as uint8) -> b }
        uint64 dp = k_text_buf + ci
        uint8 b8 = b
        unsafe { *(dp as uint8) = b8 }
        ci = ci + 1
    }

    // KD matches the existing Phase 2 dispatcher path for gemm_f32_lds:
    // 24 SGPRs / 19 VGPRs, USER_SGPR_COUNT=15 + WG_ID_X + WG_ID_Y
    // (rsrc2=0x019E), LDS=2048 bytes, rsrc1=0xE0AF0001, n_args=6 (full
    // kernarg layout 48 B).  Note: the standalone blob path emits with
    // n_args=4 / sgpr=16 / vgpr=14 / LDS=1024 — production loads the
    // blob output.  Module-emit (this path + Phase 2) has always been a
    // separate, divergent code object; this slice preserves that.
    uint64 rsrc1 = 0xE0AF0001
    uint64 rsrc2 = 0x0000019E
    uint64 rsrc3 = 0x00000010
    uint64 props = 0x0408

    kt_push_lds(kname_ptr, nl, k_text_buf, k_text_size,
                args_desc, 6, 48,
                24, 19,
                rsrc1, rsrc2, rsrc3, props,
                2048)
    return 0
}

// Phase 3c-5 — gemm_f16f32 (f16 storage, f32 accum, LDS double-buffer).
//
// Recognises a kernel with:
//   - 6 params (a, b, c, m, n, k_dim)
//   - LDS-intrinsic Calls (sync_block, lds_load_f32, lds_store_f32)
//   - At least one f16 PtrLoad (data1=2, data3=3) — the f16 weight load.
//
// Discriminator vs gemm_f32_lds (3c-4): f16 PtrLoad presence.  Routing
// places 3c-5 BEFORE 3c-4 so f16 storage wins.
//
// Returns 0 on success; non-zero means "doesn't match the 3c-5 shape".
fn amdgpu_lower_gemm_f16f32_3c(uint64 fn_node, uint64 source,
                                uint64 kname_ptr, uint64 nl) -> uint64 {
    uint64 n_params = 0
    uint64 wp = ast_child(fn_node)
    while wp != 0 {
        n_params = n_params + 1
        wp = ast_next(wp)
    }
    if n_params != 6 { return 1 }

    uint32 body = ast_data3(fn_node)
    if body == 0 { return 1 }
    if ast_kind(body) != 15 { return 1 }

    // Recursive search for any f16 PtrLoad (data3=3) AND any LDS-Call.
    uint64 saw_lds = 0
    uint64 saw_f16 = 0
    uint32 walk = ast_child(body)
    while walk != 0 {
        if ast_kind(walk) == 41 {
            if ast_data3(walk) == 3 { saw_f16 = 1 }
        }
        if ast_kind(walk) == 35 {
            uint32 callee = ast_data1(walk)
            if tok_matches(callee, "sync_block",     10) != 0 { saw_lds = 1 }
            if tok_matches(callee, "lds_load_f32",   12) != 0 { saw_lds = 1 }
            if tok_matches(callee, "lds_store_f32",  13) != 0 { saw_lds = 1 }
        }
        if ast_kind(walk) == 10 {
            uint32 init = ast_child(walk)
            if init != 0 && ast_kind(init) == 35 {
                uint32 callee = ast_data1(init)
                if tok_matches(callee, "sync_block",     10) != 0 { saw_lds = 1 }
                if tok_matches(callee, "lds_load_f32",   12) != 0 { saw_lds = 1 }
                if tok_matches(callee, "lds_store_f32",  13) != 0 { saw_lds = 1 }
            }
        }
        if ast_kind(walk) == 13 {
            uint32 tblk = ast_data1(walk)
            if tblk != 0 && ast_kind(tblk) == 15 {
                uint32 tw = ast_child(tblk)
                while tw != 0 {
                    if ast_kind(tw) == 41 {
                        if ast_data3(tw) == 3 { saw_f16 = 1 }
                    }
                    if ast_kind(tw) == 35 {
                        uint32 c2 = ast_data1(tw)
                        if tok_matches(c2, "sync_block",    10) != 0 { saw_lds = 1 }
                        if tok_matches(c2, "lds_load_f32",  12) != 0 { saw_lds = 1 }
                        if tok_matches(c2, "lds_store_f32", 13) != 0 { saw_lds = 1 }
                    }
                    if ast_kind(tw) == 10 {
                        uint32 i2 = ast_child(tw)
                        if i2 != 0 && ast_kind(i2) == 35 {
                            uint32 c3 = ast_data1(i2)
                            if tok_matches(c3, "sync_block",    10) != 0 { saw_lds = 1 }
                            if tok_matches(c3, "lds_load_f32",  12) != 0 { saw_lds = 1 }
                            if tok_matches(c3, "lds_store_f32", 13) != 0 { saw_lds = 1 }
                        }
                    }
                    if ast_kind(tw) == 13 {
                        uint32 tb3 = ast_data1(tw)
                        if tb3 != 0 && ast_kind(tb3) == 15 {
                            uint32 tw3 = ast_child(tb3)
                            while tw3 != 0 {
                                if ast_kind(tw3) == 41 {
                                    if ast_data3(tw3) == 3 { saw_f16 = 1 }
                                }
                                tw3 = ast_next(tw3)
                            }
                        }
                    }
                    tw = ast_next(tw)
                }
            }
        }
        walk = ast_next(walk)
    }
    if saw_lds == 0 { return 1 }
    if saw_f16 == 0 { return 1 }

    // ── emit ISA ─────────────────────────────────────────────────
    // Sequence ported verbatim from `_emit_gemm_f16f32_body`.
    asm_init()
    asm_u32(0xF40C0100); asm_u32(0xF8000000)
    asm_u32(0xF4040300); asm_u32(0xF8000020)
    asm_u32(0xF4040380); asm_u32(0xF8000028)
    asm_u32(0xBF89FC07)
    asm_u32(0xD6100001); asm_u32(0x02291500)
    asm_u32(0x360000FF); asm_u32(0x000003FF)
    asm_u32(0x84108403)
    asm_u32(0x84118402)
    asm_u32(0x4A060210)
    asm_u32(0x4A080011)
    asm_u32(0xBE82007E)
    asm_u32(0x7C98060A)
    asm_u32(0x8B7E6A7E)
    asm_u32(0x7C98080C)
    asm_u32(0x8B7E6A7E)
    asm_u32(0xBFA5005A)
    asm_u32(0x8512840E)
    asm_u32(0x7E0C0280)
    asm_u32(0xBE930080)
    asm_u32(0x300A0284)
    asm_u32(0x4A0A0105)
    asm_u32(0x300A0A82)
    asm_u32(0x30220286)
    asm_u32(0x30240082)
    asm_u32(0xD5250012); asm_u32(0x0001FF12); asm_u32(0x00000400)
    asm_u32(0xBF068012)
    asm_u32(0xBFA20040)
    asm_u32(0x84148413)
    asm_u32(0x4A0E0014)
    asm_u32(0xD72C0008); asm_u32(0x00001D03)
    asm_u32(0x4A100F08)
    asm_u32(0x7E120280)
    asm_u32(0xD73C0008); asm_u32(0x00021081)
    asm_u32(0xD7006A08); asm_u32(0x00021004)
    asm_u32(0xD5207C09); asm_u32(0x01AA1205)
    asm_u32(0xBF870001)
    asm_u32(0xDC820000); asm_u32(0x0A7C0008)
    asm_u32(0x4A160214)
    asm_u32(0xD72C000C); asm_u32(0x0000190B)
    asm_u32(0x4A18090C)
    asm_u32(0x7E1A0280)
    asm_u32(0xD73C000C); asm_u32(0x00021881)
    asm_u32(0xD7006A0C); asm_u32(0x00021806)
    asm_u32(0xD5207C0D); asm_u32(0x01AA1A07)
    asm_u32(0xBF870001)
    asm_u32(0xDC820000); asm_u32(0x0E7C000C)
    asm_u32(0xBF8903F7)
    asm_u32(0x7E14170A)
    asm_u32(0x7E1C170E)
    asm_u32(0xBF870001)
    asm_u32(0xD8340000); asm_u32(0x00000A05)
    asm_u32(0xD8340400); asm_u32(0x00000E05)
    asm_u32(0xBF89FC07)
    asm_u32(0xBFBD0000)
    asm_u32(0xE0AC0000); asm_u32(0x00000000)
    asm_u32(0xBE940080)
    asm_u32(0x7E1E0311)
    asm_u32(0x7E200312)
    asm_u32(0xBF870002)
    asm_u32(0xD8D80000); asm_u32(0x0900000F)
    asm_u32(0xD8D80000); asm_u32(0x0A000010)
    asm_u32(0xBF89FC07)
    asm_u32(0x560C1509)
    asm_u32(0xD525000F); asm_u32(0x0001090F)
    asm_u32(0xD5250010); asm_u32(0x00018110)
    asm_u32(0x80148114)
    asm_u32(0xBF0A9014)
    asm_u32(0xBFA2FFF2)
    asm_u32(0xBFBD0000)
    asm_u32(0xE0AC0000); asm_u32(0x00000000)
    asm_u32(0x80138113)
    asm_u32(0xBF0A1213)
    asm_u32(0xBFA2FFC0)
    asm_u32(0xD72C0008); asm_u32(0x00001903)
    asm_u32(0x4A100908)
    asm_u32(0x7E120280)
    asm_u32(0xD73C0008); asm_u32(0x00021082)
    asm_u32(0xD7006A08); asm_u32(0x00021008)
    asm_u32(0xD5207C09); asm_u32(0x01AA1209)
    asm_u32(0xDC6A0000); asm_u32(0x007C0608)
    asm_u32(0xBC7C0000)
    asm_u32(0xBFB00000)

    uint64 args_desc = alloc(12 * 16)
    uint64 a0  = args_desc +  0;  unsafe { *(a0  as uint64) = 8 }
    uint64 a1  = args_desc +  8;  unsafe { *(a1  as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a2  = args_desc + 16;  unsafe { *(a2  as uint64) = 8 }
    uint64 a3  = args_desc + 24;  unsafe { *(a3  as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a4  = args_desc + 32;  unsafe { *(a4  as uint64) = 8 }
    uint64 a5  = args_desc + 40;  unsafe { *(a5  as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a6  = args_desc + 48;  unsafe { *(a6  as uint64) = 8 }
    uint64 a7  = args_desc + 56;  unsafe { *(a7  as uint64) = AMD_ARG_KIND_BY_VALUE }
    uint64 a8  = args_desc + 64;  unsafe { *(a8  as uint64) = 8 }
    uint64 a9  = args_desc + 72;  unsafe { *(a9  as uint64) = AMD_ARG_KIND_BY_VALUE }
    uint64 a10 = args_desc + 80;  unsafe { *(a10 as uint64) = 8 }
    uint64 a11 = args_desc + 88;  unsafe { *(a11 as uint64) = AMD_ARG_KIND_BY_VALUE }

    uint64 k_text_size = asm_text_len
    uint64 k_text_buf  = alloc(k_text_size)
    uint64 ci = 0
    while ci < k_text_size {
        uint64 sp = asm_text_buf + ci
        uint64 b = 0
        unsafe { *(sp as uint8) -> b }
        uint64 dp = k_text_buf + ci
        uint8 b8 = b
        unsafe { *(dp as uint8) = b8 }
        ci = ci + 1
    }

    // KD matches the existing Phase 2 dispatcher: 24 SGPRs / 19 VGPRs,
    // LDS=2048, kernarg=48, n_args=6.  Blob path uses different params
    // (sgpr=16, vgpr=14, lds=1024, kernarg=32, n_args=4) — same blob/
    // module divergence as gemm_f32_lds.
    uint64 rsrc1 = 0xE0AF0001
    uint64 rsrc2 = 0x0000009E
    uint64 rsrc3 = 0x00000010
    uint64 props = 0x0408

    kt_push_lds(kname_ptr, nl, k_text_buf, k_text_size,
                args_desc, 6, 48,
                24, 19,
                rsrc1, rsrc2, rsrc3, props,
                2048)
    return 0
}

// Phase 3c-6 — gemm_f16f32_wmma (WMMA tensor-core 16×16×16 f16→f32).
//
// Recognises a kernel with:
//   - 6 params (a, b, c, m, n, k_dim)
//   - NO While in body subtree (vs 3c-3 plain gemm)
//   - NO LDS-intrinsic Calls (vs 3c-4 LDS gemm)
//   - NO f16 PtrLoad (vs 3c-5 mixed-precision LDS)
//
// By elimination, this matches the WMMA stub-body kernel.  Routing
// places 3c-6 AFTER 3c-3/3c-4/3c-5 so the more-specific recognisers
// win first.  The hand-tuned ISA emits v_wmma_f32_16x16x16_f16 via
// opcode 0xCC404011 for the 16-iter K-loop accumulator.
//
// Returns 0 on success; non-zero means "doesn't match the 3c-6 shape".
fn amdgpu_lower_gemm_f16f32_wmma_3c(uint64 fn_node, uint64 source,
                                     uint64 kname_ptr, uint64 nl) -> uint64 {
    uint64 n_params = 0
    uint64 wp = ast_child(fn_node)
    while wp != 0 {
        n_params = n_params + 1
        wp = ast_next(wp)
    }
    if n_params != 6 { return 1 }

    uint32 body = ast_data3(fn_node)
    if body == 0 { return 1 }
    if ast_kind(body) != 15 { return 1 }

    // Reject if body subtree has any While, LDS-intrinsic Call, or
    // f16 PtrLoad — those belong to 3c-3/3c-4/3c-5.
    uint64 reject = 0
    uint32 walk = ast_child(body)
    while walk != 0 {
        if ast_kind(walk) == 14 { reject = 1 }
        if ast_kind(walk) == 41 {
            if ast_data3(walk) == 3 { reject = 1 }
        }
        if ast_kind(walk) == 35 {
            uint32 callee = ast_data1(walk)
            if tok_matches(callee, "sync_block",     10) != 0 { reject = 1 }
            if tok_matches(callee, "lds_load_f32",   12) != 0 { reject = 1 }
            if tok_matches(callee, "lds_store_f32",  13) != 0 { reject = 1 }
        }
        if ast_kind(walk) == 10 {
            uint32 init = ast_child(walk)
            if init != 0 && ast_kind(init) == 35 {
                uint32 callee = ast_data1(init)
                if tok_matches(callee, "sync_block",     10) != 0 { reject = 1 }
                if tok_matches(callee, "lds_load_f32",   12) != 0 { reject = 1 }
                if tok_matches(callee, "lds_store_f32",  13) != 0 { reject = 1 }
            }
        }
        if ast_kind(walk) == 13 {
            uint32 tblk = ast_data1(walk)
            if tblk != 0 && ast_kind(tblk) == 15 {
                uint32 tw = ast_child(tblk)
                while tw != 0 {
                    if ast_kind(tw) == 14 { reject = 1 }
                    if ast_kind(tw) == 41 {
                        if ast_data3(tw) == 3 { reject = 1 }
                    }
                    if ast_kind(tw) == 35 {
                        uint32 c2 = ast_data1(tw)
                        if tok_matches(c2, "sync_block",    10) != 0 { reject = 1 }
                        if tok_matches(c2, "lds_load_f32",  12) != 0 { reject = 1 }
                        if tok_matches(c2, "lds_store_f32", 13) != 0 { reject = 1 }
                    }
                    if ast_kind(tw) == 13 {
                        uint32 tb3 = ast_data1(tw)
                        if tb3 != 0 && ast_kind(tb3) == 15 {
                            uint32 tw3 = ast_child(tb3)
                            while tw3 != 0 {
                                if ast_kind(tw3) == 14 { reject = 1 }
                                if ast_kind(tw3) == 41 {
                                    if ast_data3(tw3) == 3 { reject = 1 }
                                }
                                tw3 = ast_next(tw3)
                            }
                        }
                    }
                    tw = ast_next(tw)
                }
            }
        }
        walk = ast_next(walk)
    }
    if reject != 0 { return 1 }

    // ── emit ISA ─────────────────────────────────────────────────
    // Sequence ported verbatim from `_emit_gemm_f16f32_wmma_body`.
    // Each WG (32 lanes) computes one 16×16 output tile via a single
    // v_wmma_f32_16x16x16_f16 per 16-K-stride iteration.
    asm_init()
    asm_u32(0xF40C0100); asm_u32(0xF8000000)
    asm_u32(0xF4040300); asm_u32(0xF8000020)
    asm_u32(0xF4040380); asm_u32(0xF8000028)
    asm_u32(0xBF89FC07)
    asm_u32(0x84108403)
    asm_u32(0x84118402)
    asm_u32(0xBF090A10)
    asm_u32(0xBFA2007C)
    asm_u32(0xBF090C11)
    asm_u32(0xBFA2007A)
    asm_u32(0x3634008F)
    asm_u32(0x32320084)
    asm_u32(0x8413810C)
    asm_u32(0x8414820C)
    asm_u32(0x8417830C)
    asm_u32(0x4A363410)
    asm_u32(0xD72C001B); asm_u32(0x00001D1B)
    asm_u32(0x30363681)
    asm_u32(0x4A383411)
    asm_u32(0x30383881)
    asm_u32(0x4A3A3813)
    asm_u32(0x4A3C3210)
    asm_u32(0xD72C001E); asm_u32(0x0000191E)
    asm_u32(0x4A3C3C11)
    asm_u32(0x4A3C351E)
    asm_u32(0x303C3C82)
    asm_u32(0x8515840E)
    asm_u32(0xBE960080)
    asm_u32(0x7E220280); asm_u32(0x7E240280)
    asm_u32(0x7E260280); asm_u32(0x7E280280)
    asm_u32(0x7E2A0280); asm_u32(0x7E2C0280)
    asm_u32(0x7E2E0280); asm_u32(0x7E300280)
    asm_u32(0xBF068015)
    asm_u32(0xBFA20044)
    asm_u32(0xBF870001)
    asm_u32(0xDC5E0000); asm_u32(0x0904001B)
    asm_u32(0xDC5E0010); asm_u32(0x0D04001B)
    asm_u32(0xBF870001)
    asm_u32(0xDC820000); asm_u32(0x0106001C)
    asm_u32(0xDC8E0000); asm_u32(0x0106001D)
    asm_u32(0x4A383814); asm_u32(0x4A3A3A14)
    asm_u32(0xBF870001)
    asm_u32(0xDC820000); asm_u32(0x0206001C)
    asm_u32(0xDC8E0000); asm_u32(0x0206001D)
    asm_u32(0x4A383814); asm_u32(0x4A3A3A14)
    asm_u32(0xBF870001)
    asm_u32(0xDC820000); asm_u32(0x0306001C)
    asm_u32(0xDC8E0000); asm_u32(0x0306001D)
    asm_u32(0x4A383814); asm_u32(0x4A3A3A14)
    asm_u32(0xBF870001)
    asm_u32(0xDC820000); asm_u32(0x0406001C)
    asm_u32(0xDC8E0000); asm_u32(0x0406001D)
    asm_u32(0x4A383814); asm_u32(0x4A3A3A14)
    asm_u32(0xBF870001)
    asm_u32(0xDC820000); asm_u32(0x0506001C)
    asm_u32(0xDC8E0000); asm_u32(0x0506001D)
    asm_u32(0x4A383814); asm_u32(0x4A3A3A14)
    asm_u32(0xBF870001)
    asm_u32(0xDC820000); asm_u32(0x0606001C)
    asm_u32(0xDC8E0000); asm_u32(0x0606001D)
    asm_u32(0x4A383814); asm_u32(0x4A3A3A14)
    asm_u32(0xBF870001)
    asm_u32(0xDC820000); asm_u32(0x0706001C)
    asm_u32(0xDC8E0000); asm_u32(0x0706001D)
    asm_u32(0x4A383814); asm_u32(0x4A3A3A14)
    asm_u32(0xBF870001)
    asm_u32(0xDC820000); asm_u32(0x0806001C)
    asm_u32(0xDC8E0000); asm_u32(0x0806001D)
    asm_u32(0x4A383814); asm_u32(0x4A3A3A14)
    asm_u32(0x4A3636A0)
    asm_u32(0xBF8903F7)
    asm_u32(0xCC404011); asm_u32(0x1C460309)
    asm_u32(0x80168116)
    asm_u32(0xBF0A1516)
    asm_u32(0xBFA2FFBC)
    asm_u32(0xDC6A0000); asm_u32(0x0008111E)
    asm_u32(0x4A3C3C17)
    asm_u32(0xDC6A0000); asm_u32(0x0008121E)
    asm_u32(0x4A3C3C17)
    asm_u32(0xDC6A0000); asm_u32(0x0008131E)
    asm_u32(0x4A3C3C17)
    asm_u32(0xDC6A0000); asm_u32(0x0008141E)
    asm_u32(0x4A3C3C17)
    asm_u32(0xDC6A0000); asm_u32(0x0008151E)
    asm_u32(0x4A3C3C17)
    asm_u32(0xDC6A0000); asm_u32(0x0008161E)
    asm_u32(0x4A3C3C17)
    asm_u32(0xDC6A0000); asm_u32(0x0008171E)
    asm_u32(0x4A3C3C17)
    asm_u32(0xDC6A0000); asm_u32(0x0008181E)
    asm_u32(0xBC7C0000)
    asm_u32(0xBFB00000)

    uint64 args_desc = alloc(12 * 16)
    uint64 a0  = args_desc +  0;  unsafe { *(a0  as uint64) = 8 }
    uint64 a1  = args_desc +  8;  unsafe { *(a1  as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a2  = args_desc + 16;  unsafe { *(a2  as uint64) = 8 }
    uint64 a3  = args_desc + 24;  unsafe { *(a3  as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a4  = args_desc + 32;  unsafe { *(a4  as uint64) = 8 }
    uint64 a5  = args_desc + 40;  unsafe { *(a5  as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a6  = args_desc + 48;  unsafe { *(a6  as uint64) = 8 }
    uint64 a7  = args_desc + 56;  unsafe { *(a7  as uint64) = AMD_ARG_KIND_BY_VALUE }
    uint64 a8  = args_desc + 64;  unsafe { *(a8  as uint64) = 8 }
    uint64 a9  = args_desc + 72;  unsafe { *(a9  as uint64) = AMD_ARG_KIND_BY_VALUE }
    uint64 a10 = args_desc + 80;  unsafe { *(a10 as uint64) = 8 }
    uint64 a11 = args_desc + 88;  unsafe { *(a11 as uint64) = AMD_ARG_KIND_BY_VALUE }

    uint64 k_text_size = asm_text_len
    uint64 k_text_buf  = alloc(k_text_size)
    uint64 ci = 0
    while ci < k_text_size {
        uint64 sp = asm_text_buf + ci
        uint64 b = 0
        unsafe { *(sp as uint8) -> b }
        uint64 dp = k_text_buf + ci
        uint8 b8 = b
        unsafe { *(dp as uint8) = b8 }
        ci = ci + 1
    }

    // KD identical to legacy hand-tuned WMMA: 24 SGPRs / 31 VGPRs,
    // USER_SGPR_COUNT=15 + WG_ID_X + WG_ID_Y, no LDS, rsrc1=0xE0AF0083
    // (vgpr_grant=3 → 32), rsrc2=0x019E.
    uint64 rsrc1 = 0xE0AF0083
    uint64 rsrc2 = 0x0000019E
    uint64 rsrc3 = 0x00000010
    uint64 props = 0x0408

    kt_push(kname_ptr, nl, k_text_buf, k_text_size,
            args_desc, 6, 48,
            24, 31,
            rsrc1, rsrc2, rsrc3, props)
    return 0
}

// Phase 3c-23 — silu_mul_f32_batched (multi-stream SwiGLU).
//
// Discriminator: 4 params + silu Call + block_idx_y +
// silu_mul_batched_marker().  Routes BEFORE 3a-3 so the batched
// variant wins.
fn amdgpu_lower_silu_mul_f32_batched_3c(uint64 fn_node, uint64 source,
                                          uint64 kname_ptr, uint64 nl) -> uint64 {
    uint64 n_params = 0
    uint64 wp = ast_child(fn_node)
    while wp != 0 {
        n_params = n_params + 1
        wp = ast_next(wp)
    }
    if n_params != 4 { return 1 }

    uint32 body = ast_data3(fn_node)
    if body == 0 { return 1 }
    if ast_kind(body) != 15 { return 1 }

    uint64 saw_marker = 0
    uint32 walk = ast_child(body)
    while walk != 0 {
        if ast_kind(walk) == 35 {
            uint32 callee = ast_data1(walk)
            if tok_matches(callee, "silu_mul_batched_marker", 23) != 0 { saw_marker = 1 }
        }
        if ast_kind(walk) == 10 {
            uint32 init = ast_child(walk)
            if init != 0 && ast_kind(init) == 35 {
                uint32 callee = ast_data1(init)
                if tok_matches(callee, "silu_mul_batched_marker", 23) != 0 { saw_marker = 1 }
            }
        }
        walk = ast_next(walk)
    }
    if saw_marker == 0 { return 1 }

    uint64 args_desc = alloc(8 * 16)
    _emit_silu_mul_f32_batched_body(args_desc)

    uint64 k_text_size = asm_text_len
    uint64 k_text_buf  = alloc(k_text_size)
    uint64 ci = 0
    while ci < k_text_size {
        uint64 sp = asm_text_buf + ci
        uint64 b = 0
        unsafe { *(sp as uint8) -> b }
        uint64 dp = k_text_buf + ci
        uint8 b8 = b
        unsafe { *(dp as uint8) = b8 }
        ci = ci + 1
    }

    uint64 rsrc1 = 0xE0AF0001
    uint64 rsrc2 = 0x0000019E
    uint64 rsrc3 = 0x00000010
    uint64 props = 0x0408

    kt_push(kname_ptr, nl, k_text_buf, k_text_size,
            args_desc, 4, 32,
            16, 12,
            rsrc1, rsrc2, rsrc3, props)
    return 0
}

// noesis spike_reduce lowering — hand-encoded GFX1100 ISA (verified
// against /tmp/spike_reduce.s via llvm-mc).
//
//   @kernel fn spike_reduce(uint64 spike_ptr, uint64 result_ptr, uint64 n) {
//       uint64 i = tid_x()
//       if i < n {
//           uint64 c = spike_ptr[i]
//           if c > 0 {
//               atomic_add_u64(result_ptr,     c)
//               atomic_add_u64(result_ptr + 8, 1)
//           }
//       }
//   }
//
// Replaces the 480 MB D2H + 60M-iter CPU tally fallback at the end of
// the noesis_60m_gpu launcher; closes the post-sim gap vs HIP.
//
// Kernarg layout (24 bytes):
//   [0x00] uint64 spike_ptr   → s4,s5
//   [0x08] uint64 result_ptr  → s6,s7
//   [0x10] uint64 n           → s8,s9 (only s8 used)
fn amdgpu_lower_noesis_spike_reduce(uint64 kname_ptr, uint64 nl) -> uint64 {
    asm_init()
    asm_u32(0xF4080100); asm_u32(0xF8000000)        // s_load_b128 s[4:7], s[0:1], 0x0
    asm_u32(0xF4040200); asm_u32(0xF8000010)        // s_load_b64  s[8:9], s[0:1], 0x10
    asm_u32(0xBF89FC07)                             // s_waitcnt   lgkmcnt(0)
    asm_u32(0x840A880F)                             // s_lshl_b32  s10, s15, 8
    asm_u32(0x4A02000A)                             // v_add_nc_u32 v1, s10, v0
    asm_u32(0xBE82007E)                             // s_mov_b32   s2, exec_lo
    asm_u32(0xD4C9007E); asm_u32(0x00001101)        // v_cmpx_lt_u32_e64 v1, s8
    asm_u32(0xBFA50019)                             // s_cbranch_execz +25 → s_endpgm
    asm_u32(0x300C0283)                             // v_lshlrev_b32 v6, 3, v1
    asm_u32(0x7E0E0280)                             // v_mov_b32    v7, 0
    asm_u32(0xD7006A02); asm_u32(0x00020C04)        // v_add_co_u32 v2, vcc_lo, s4, v6
    asm_u32(0xD5207C03); asm_u32(0x01AA0E05)        // v_add_co_ci_u32_e64 v3, null, s5, v7, vcc_lo
    asm_u32(0xDC560000); asm_u32(0x047C0002)        // global_load_b64 v[4:5], v[2:3], off
    asm_u32(0xBF8903F7)                             // s_waitcnt vmcnt(0)
    asm_u32(0x7CBA0880)                             // v_cmp_ne_u64 vcc_lo, 0, v[4:5]
    asm_u32(0xBE8B206A)                             // s_and_saveexec_b32 s11, vcc_lo
    asm_u32(0xBFA5000D)                             // s_cbranch_execz +13 → s_endpgm
    asm_u32(0x7E040206)                             // v_mov_b32 v2, s6
    asm_u32(0x7E060207)                             // v_mov_b32 v3, s7
    asm_u32(0xDD0E0000); asm_u32(0x007C0402)        // global_atomic_add_u64 v[2:3], v[4:5], off
    asm_u32(0x7E100281)                             // v_mov_b32 v8, 1
    asm_u32(0x7E120280)                             // v_mov_b32 v9, 0
    asm_u32(0xD7006A02); asm_u32(0x00020488)        // v_add_co_u32 v2, vcc_lo, 8, v2
    asm_u32(0xD5207C03); asm_u32(0x01AA0680)        // v_add_co_ci_u32_e64 v3, null, 0, v3, vcc_lo
    asm_u32(0xDD0E0000); asm_u32(0x007C0802)        // global_atomic_add_u64 v[2:3], v[8:9], off
    asm_u32(0xBC7C0000)                             // s_waitcnt_vscnt null, 0
    asm_u32(0xBFB00000)                             // s_endpgm

    // 3 args, all 8-byte: 2 buffers + 1 by-value u64.
    uint64 args_desc = alloc(3 * 16)
    uint64 a0s = args_desc + 0;   unsafe { *(a0s as uint64) = 8 }
    uint64 a0k = args_desc + 8;   unsafe { *(a0k as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a1s = args_desc + 16;  unsafe { *(a1s as uint64) = 8 }
    uint64 a1k = args_desc + 24;  unsafe { *(a1k as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a2s = args_desc + 32;  unsafe { *(a2s as uint64) = 8 }
    uint64 a2k = args_desc + 40;  unsafe { *(a2k as uint64) = AMD_ARG_KIND_BY_VALUE }

    // Snapshot asm text into its own buffer (next kernel's asm_init clobbers).
    uint64 k_text_size = asm_text_len
    uint64 k_text_buf  = alloc(k_text_size)
    uint64 ci = 0
    while ci < k_text_size {
        uint64 sp = asm_text_buf + ci
        uint64 b = 0
        unsafe { *(sp as uint8) -> b }
        uint64 dp = k_text_buf + ci
        uint8 b8 = b
        unsafe { *(dp as uint8) = b8 }
        ci = ci + 1
    }

    uint64 rsrc1 = 0xE0AF0001        // VGPR granule 1 → 16 VGPRs (uses v0..v9 = 10)
    uint64 rsrc2 = 0x0000009E
    uint64 rsrc3 = 0x00000010
    uint64 props = 0x0408
    kt_push(kname_ptr, nl, k_text_buf, k_text_size,
            args_desc, 3, 24,
            16, 10,
            rsrc1, rsrc2, rsrc3, props)
    return 0
}

// Lower one @kernel fn_node into the kernel table. Returns 0 on
// success, 1 on unsupported shape. Recognises the same two shapes
// the M1d/M1e lowerer already handled:
//
//   M1d (1 arg):
//     @kernel fn name(uint64 out) {
//         unsafe { *(out as uint32) = INT_LITERAL }
//     }
//
//   M1e (2 args):
//     @kernel fn name(uint64 out, uint32 value) {
//         unsafe { *(out as uint32) = value }
//     }
fn amdgpu_lower_kernel_to_table(uint64 fn_node, uint64 source) -> uint64 {
    // Kernel name.
    uint32 name_tok = ast_data1(fn_node)
    uint64 ns = tok_text_start(name_tok)
    uint64 nl = tok_text_len(name_tok)
    uint64 kname_ptr = source + ns

    // ── noesis_60m_gpu @kernel routing ────────────────────────────────
    // The four kernels in examples/noesis_60m_gpu.mlr have rich bodies
    // (atomics, branches, multi-arg layouts) that the structural
    // recognisers below don't cover. Detect them by name and route to
    // dedicated emitters that produce ISA matching the noesis launcher's
    // kernarg packing (see examples/noesis_60m_gpu_launch.mlr).
    //
    // SCOPE NOTE: this branch implements decay_step natively. lif_step,
    // delivery_step, and csr_build still flow through hipcc — they need
    // primitives our gfx1100 encoder doesn't yet have (f64 division
    // via Newton + div_fixup; v_mul_lo_u64 + 64-bit unsigned modulo;
    // global_store_b8; v_add_co_u32 + carry chain for 64-bit address
    // arithmetic; CAS-retry loop with backwards-branch patching). Each
    // is in-scope for a follow-up but not deliverable in one session
    // without high silent-corruption risk. See /tmp/native_lowering_report.md
    // for the design plans of the missing three.
    if tok_matches(name_tok, "decay_step", 10) != 0 {
        return amdgpu_lower_noesis_decay(kname_ptr, nl)
    }
    // For the three not-yet-native kernels we emit a warning and
    // return 2 (= "skip"). emit_amdgpu_from_module turns that into a
    // continue, so the .co contains only the kernels that DO lower.
    // The launcher resolves unsupported kernels from a fallback .co
    // via NOESIS_CSR_CO_PATH (see examples/noesis_60m_gpu_launch.mlr).
    // This dual-.co strategy lets us land the kernels one-by-one
    // without blocking the bench writeup on full coverage.
    if tok_matches(name_tok, "lif_step", 8) != 0 {
        return amdgpu_lower_noesis_lif(kname_ptr, nl)
    }
    if tok_matches(name_tok, "delivery_step", 13) != 0 {
        return amdgpu_lower_noesis_delivery(kname_ptr, nl)
    }
    if tok_matches(name_tok, "csr_build", 9) != 0 {
        return amdgpu_lower_noesis_csr_build(kname_ptr, nl)
    }
    if tok_matches(name_tok, "_kfd_copy_u64", 13) != 0 {
        return amdgpu_lower_kfd_copy_u64(kname_ptr, nl)
    }

    // ── Slice 4.19.11: qwen3 mega-kernel byte-wrapper removed ─────────
    // The byte-wrapper recognizer (slice 4.18 amdgpu_lower_qwen3_megakernel)
    // was deleted along with build/native_megakernel/*.bin; the v2 AST-walker
    // (recognize_megakernel_swiglu_dense_gqa in format_amdgpu_megakernel.mlr)
    // is now the sole emit path, invoked via the dedicated CLI flag
    // `--emit-amdgpu-qwen3-megakernel-v2=PATH` rather than module-level
    // `--target=amdgpu-native` dispatch.

    // ── Phase 3a-2: AST-walking 2-input pointwise recogniser ──────────
    // Catches the (a_ptr, b_ptr, out_ptr, n) shape with `r = a OP b`
    // body — owns residual_add_f32.
    uint64 pw2_rc = amdgpu_lower_pointwise_2in_3a(fn_node, source, kname_ptr, nl)
    if pw2_rc == 0 { return 0 }

    // ── Phase 3c-23: AST-walking silu_mul_f32_batched ─────────────────
    // Runs BEFORE 3a-3 so the batched marker wins.
    uint64 smb_rc = amdgpu_lower_silu_mul_f32_batched_3c(fn_node, source, kname_ptr, nl)
    if smb_rc == 0 { return 0 }

    // ── Phase 3a-3: AST-walking silu(a) * b recogniser ────────────────
    // Catches the 4-param SwiGLU element-wise op — owns silu_mul_f32.
    uint64 sm_rc = amdgpu_lower_silu_mul_3a(fn_node, source, kname_ptr, nl)
    if sm_rc == 0 { return 0 }

    // ── Phase 3a-5: AST-walking silu(x) recogniser ────────────────────
    // Catches the 3-param `out = silu(in)` shape — owns silu_f32.
    uint64 si_rc = amdgpu_lower_silu_f32_3a(fn_node, source, kname_ptr, nl)
    if si_rc == 0 { return 0 }

    // ── Phase 3a-6: AST-walking bf16→f32 type-cast recogniser ─────────
    // Catches the 3-param `out_u32 = u32(in_u16) << 16` shape — owns
    // bf16_to_f32.
    uint64 bf_rc = amdgpu_lower_bf16_to_f32_3a(fn_node, source, kname_ptr, nl)
    if bf_rc == 0 { return 0 }

    // ── Slice 2c: AST-walking fused qknorm + rope_qk (8 params).  Must
    //    run BEFORE qknorm_3b/rope_qwen3_3c so the marker wins.
    uint64 qrf_rc = amdgpu_lower_qknorm_rope_qk_3c(fn_node, source, kname_ptr, nl)
    if qrf_rc == 0 { return 0 }

    // ── Phase 3b-128: AST-walking qknorm (rmsnorm N=128, eps=1e-6) ────
    uint64 qkn_rc = amdgpu_lower_qknorm_f32_3b(fn_node, source, kname_ptr, nl)
    if qkn_rc == 0 { return 0 }

    // ── Phase 3b-5120: AST-walking rmsnorm_f32 at N=5120 (14B) ────────
    uint64 rn5120_rc = amdgpu_lower_rmsnorm_f32_N5120_3b(fn_node, source, kname_ptr, nl)
    if rn5120_rc == 0 { return 0 }

    // ── Phase 3b-1024: AST-walking rmsnorm_f32 at N=1024 ──────────────
    uint64 rn1024_rc = amdgpu_lower_rmsnorm_f32_N1024_3b(fn_node, source, kname_ptr, nl)
    if rn1024_rc == 0 { return 0 }

    // ── Phase 3c-8 (early): gemv_coop_bf16_f32 single-stream ──────────
    // MUST run BEFORE rmsnorm_3b: both are 5-param + body has 3 stmts
    // (row, lane, If) + lds_reduce_sum_f32 Call.  bf16 gemv discriminator
    // is the u16 PtrLoad inside the K-loop (rmsnorm has only f32 loads),
    // but rmsnorm's recogniser is looser and would match first.  Symptom:
    // /tmp/gemv_coop_bf16_f32.co was being emitted as rmsnorm bytes,
    // hanging qwen3 at the first qkv_proj launch.
    uint64 gvcb_early_rc = amdgpu_lower_gemv_coop_bf16_f32_3c(fn_node, source, kname_ptr, nl)
    if gvcb_early_rc == 0 { return 0 }

    // ── Phase 3b: AST-walking rmsnorm recogniser (LDS reduce) ─────────
    // Catches the 5-param rmsnorm shape with an lds_reduce_sum_f32
    // call in the body — owns rmsnorm_f32 (hardcoded N=256, eps=1e-5).
    uint64 rn_rc = amdgpu_lower_rmsnorm_f32_3b(fn_node, source, kname_ptr, nl)
    if rn_rc == 0 { return 0 }

    // ── Phase 3b-4-N128: AST-walking softmax_causal_f32 at N=128 ──────
    uint64 scf128_rc = amdgpu_lower_softmax_causal_f32_N128_3b(fn_node, source, kname_ptr, nl)
    if scf128_rc == 0 { return 0 }

    // ── Phase 3b-4: AST-walking causal softmax recogniser ─────────────
    // Runs BEFORE 3b-2 so causal_mask_f32 presence wins; otherwise 3b-2
    // would catch this kernel and emit the non-causal ISA (wrong).
    uint64 scf_rc = amdgpu_lower_softmax_causal_f32_3b(fn_node, source, kname_ptr, nl)
    if scf_rc == 0 { return 0 }

    // ── Phase 3b-2-N128: AST-walking softmax_f32 at N=128 ─────────────
    uint64 sf128_rc = amdgpu_lower_softmax_f32_N128_3b(fn_node, source, kname_ptr, nl)
    if sf128_rc == 0 { return 0 }

    // ── Phase 3b-2: AST-walking softmax recogniser (max + sum reduces) ─
    // Catches the 4-param softmax shape with both reduce intrinsics —
    // owns softmax_f32 (hardcoded N=256).
    uint64 sf_rc = amdgpu_lower_softmax_f32_3b(fn_node, source, kname_ptr, nl)
    if sf_rc == 0 { return 0 }

    // ── Phase 3b-3-N128: AST-walking layernorm_f32 at N=128 ───────────
    uint64 ln128_rc = amdgpu_lower_layernorm_f32_N128_3b(fn_node, source, kname_ptr, nl)
    if ln128_rc == 0 { return 0 }

    // ── Phase 3b-3: AST-walking layernorm recogniser (mean + var) ─────
    // Catches the 4-param layernorm shape with TWO sum reduces and no
    // max reduce — owns layernorm_f32 (hardcoded N=256, no gamma/beta).
    uint64 ln_rc = amdgpu_lower_layernorm_f32_3b(fn_node, source, kname_ptr, nl)
    if ln_rc == 0 { return 0 }

    // ── Phase 3c-D128: AST-walking rope_qwen3_f32 (parametric D=128) ──
    // Runs BEFORE 3c-1 so the marker variant takes the parametric path.
    uint64 rope128_rc = amdgpu_lower_rope_qwen3_f32_3c(fn_node, source, kname_ptr, nl)
    if rope128_rc == 0 { return 0 }

    // ── Phase 3c-1: AST-walking rope (rotary embedding) recogniser ────
    // Catches the 5-param rope shape with ≥4 PtrLoads and no reduce
    // calls in the if-body — owns rope_f32 (hardcoded D=128).
    uint64 rp_rc = amdgpu_lower_rope_f32_3c(fn_node, source, kname_ptr, nl)
    if rp_rc == 0 { return 0 }

    // ── Phase 3c-19: AST-walking extract_k_qwen3_f32_speck4 ───────────
    // Runs BEFORE 3c-16 so speck4 marker wins.
    uint64 exks_rc = amdgpu_lower_extract_k_qwen3_f32_speck4_3c(fn_node, source, kname_ptr, nl)
    if exks_rc == 0 { return 0 }

    // ── Phase 3c-20: AST-walking insert_k_qwen3_f32_speck4 ────────────
    // Runs BEFORE 3c-15 so speck4 marker wins.
    uint64 inks_rc = amdgpu_lower_insert_k_qwen3_f32_speck4_3c(fn_node, source, kname_ptr, nl)
    if inks_rc == 0 { return 0 }

    // ── Phase 3c-16: AST-walking extract_k_qwen3_f32 (2-param 2D) ─────
    uint64 exk_rc = amdgpu_lower_extract_k_qwen3_f32_3c(fn_node, source, kname_ptr, nl)
    if exk_rc == 0 { return 0 }

    // ── Phase 3c-15: AST-walking insert_k_qwen3_f32 (2-param 2D) ──────
    // Runs BEFORE 3c-11 so insert_k_marker() Call wins for K-cache
    // scatter shape.
    uint64 ink_rc = amdgpu_lower_insert_k_qwen3_f32_3c(fn_node, source, kname_ptr, nl)
    if ink_rc == 0 { return 0 }

    // ── Phase 3c-11: AST-walking extract_q_qwen3_f32 (2-param 2D) ─────
    uint64 exq_rc = amdgpu_lower_extract_q_qwen3_f32_3c(fn_node, source, kname_ptr, nl)
    if exq_rc == 0 { return 0 }

    // ── Phase 3c-25: AST-walking qkv_split_f32_batched_14b ────────────
    uint64 qkvb14_rc = amdgpu_lower_qkv_split_f32_batched_14b_3c(fn_node, source, kname_ptr, nl)
    if qkvb14_rc == 0 { return 0 }

    // ── Phase 3c-18: AST-walking qkv_split_f32_speck4 ─────────────────
    uint64 qkvsp_rc = amdgpu_lower_qkv_split_f32_speck4_3c(fn_node, source, kname_ptr, nl)
    if qkvsp_rc == 0 { return 0 }

    // ── Phase 3c-14: AST-walking qkv_split_f32_batched (3p, 2D grid) ──
    uint64 qkvb_rc = amdgpu_lower_qkv_split_f32_batched_3c(fn_node, source, kname_ptr, nl)
    if qkvb_rc == 0 { return 0 }

    // ── Phase 3c-24: AST-walking qkv_split_f32_14b (Qwen3-14B) ────────
    uint64 qkv14_rc = amdgpu_lower_qkv_split_f32_14b_3c(fn_node, source, kname_ptr, nl)
    if qkv14_rc == 0 { return 0 }

    // ── Phase 3c-12: AST-walking qkv_split_f32 (3-param fused split) ──
    uint64 qkvs_rc = amdgpu_lower_qkv_split_f32_3c(fn_node, source, kname_ptr, nl)
    if qkvs_rc == 0 { return 0 }

    // ── Phase 3c-17: AST-walking attn_decode_f32_speck4 (multi-Q) ─────
    // Runs BEFORE 3c-13 so speck4_marker() Call wins.
    uint64 ads_rc = amdgpu_lower_attn_decode_f32_speck4_3c(fn_node, source, kname_ptr, nl)
    if ads_rc == 0 { return 0 }

    // ── Phase 3c-13: AST-walking attn_decode_f32_batched (2D grid) ────
    // Runs BEFORE 3c-10 so block_idx_y() presence wins for batched.
    uint64 adb_rc = amdgpu_lower_attn_decode_f32_batched_3c(fn_node, source, kname_ptr, nl)
    if adb_rc == 0 { return 0 }

    // ── Phase 3c-26: AST-walking attn_decode_f32_14b (kv_ratio=5) ─────
    uint64 ad14_rc = amdgpu_lower_attn_decode_f32_14b_3c(fn_node, source, kname_ptr, nl)
    if ad14_rc == 0 { return 0 }

    // ── Phase 3c-10: AST-walking attn_decode_f32 ──────────────────────
    // Runs BEFORE the gemv_coop family so lds_reduce_max_f32 presence
    // wins (only attention does max-reduce alongside sum-reduce at 5p).
    uint64 ad_rc = amdgpu_lower_attn_decode_f32_3c(fn_node, source, kname_ptr, nl)
    if ad_rc == 0 { return 0 }

    // ── Phase 3c-22: AST-walking gemv_coop_bf16_f32_batched ───────────
    // Runs BEFORE 3c-21 / 3c-9 so the bf16-batched marker wins.
    uint64 gvcbb_rc = amdgpu_lower_gemv_coop_bf16_f32_batched_3c(fn_node, source, kname_ptr, nl)
    if gvcbb_rc == 0 { return 0 }

    // ── Phase 3c-21: AST-walking gemv_coop_f32_batched (f32 multi-stream) ──
    // Runs BEFORE 3c-9 so gemv_coop_batched_marker() presence wins
    // over the q4_0 path which has the same structural signature.
    uint64 gvcfb_rc = amdgpu_lower_gemv_coop_f32_batched_3c(fn_node, source, kname_ptr, nl)
    if gvcfb_rc == 0 { return 0 }

    // ── Phase 3c-9: AST-walking gemv_coop_q4_0_f32_batched (Q4_0, 2D) ──
    // Runs BEFORE 3c-8/3c-7 so block_idx_y() presence wins for batched
    // q4_0 quant gemv.
    uint64 gvcq_rc = amdgpu_lower_gemv_coop_q4_0_f32_batched_3c(fn_node, source, kname_ptr, nl)
    if gvcq_rc == 0 { return 0 }

    // ── Phase 3c-8: AST-walking gemv_coop_bf16_f32 (bf16 weights) ─────
    // Runs BEFORE 3c-7 so u16 PtrLoad presence wins over f32 weights.
    uint64 gvcb_rc = amdgpu_lower_gemv_coop_bf16_f32_3c(fn_node, source, kname_ptr, nl)
    if gvcb_rc == 0 { return 0 }

    // ── Phase 3c-7: AST-walking gemv_coop_f32 (cooperative-row LDS) ───
    // Runs BEFORE 3c-2 so lds_reduce_sum_f32 presence wins over plain
    // gemv.  Production-critical: drives qwen3 lm_head + every gemv.
    uint64 gvc_rc = amdgpu_lower_gemv_coop_f32_3c(fn_node, source, kname_ptr, nl)
    if gvc_rc == 0 { return 0 }

    // ── Phase 3c-2: AST-walking gemv (one-lane-per-row, K-loop) ───────
    // Catches the 5-param gemv shape (a, b, c, m, k_dim) with a 2-stmt
    // body (row VarDecl + If) and a While inside the if-body — owns
    // gemv_f32.  First control-flow shape under the AST walker.
    uint64 gv_rc = amdgpu_lower_gemv_f32_3c(fn_node, source, kname_ptr, nl)
    if gv_rc == 0 { return 0 }

    // ── Phase 3c-5: AST-walking gemm_f16f32 (f16 storage, f32 accum) ──
    // Runs BEFORE 3c-4 so f16-PtrLoad presence wins.
    uint64 gmf16_rc = amdgpu_lower_gemm_f16f32_3c(fn_node, source, kname_ptr, nl)
    if gmf16_rc == 0 { return 0 }

    // ── Phase 3c-4: AST-walking gemm_f32_lds (LDS double-buffer tile) ──
    // Discriminator: 6 params + LDS-intrinsic Calls (sync_block,
    // lds_load_f32, lds_store_f32) — runs BEFORE 3c-3 so LDS wins.
    // Note: AST output matches the existing Phase 2 dispatcher byte-
    // for-byte (kt_push_lds with n_args=6, kernarg=48, sgpr=24, vgpr=19,
    // LDS=2048).  The standalone `--emit-amdgpu-gemm-f32-lds=` blob
    // path still produces a *different* .co (sgpr=16, vgpr=14, LDS=
    // 1024); that's a pre-existing divergence between blob and module
    // emit for this kernel — production loads the blob output, never
    // the AST/module output.
    uint64 gml_rc = amdgpu_lower_gemm_f32_lds_3c(fn_node, source, kname_ptr, nl)
    if gml_rc == 0 { return 0 }

    // ── Phase 3c-3: AST-walking gemm (16x16 tile, K-loop) ─────────────
    // Catches the 6-param gemm shape (a, b, c, m, n, k_dim) with a
    // While in the body subtree — owns gemm_f32.
    uint64 gm_rc = amdgpu_lower_gemm_f32_3c(fn_node, source, kname_ptr, nl)
    if gm_rc == 0 { return 0 }

    // ── Phase 3c-6: AST-walking gemm_f16f32_wmma (tensor core) ────────
    // Catches the 6-param gemm shape with NO While, NO LDS, NO f16
    // PtrLoad — owns gemm_f16f32_wmma.  Body is structural-only stub.
    uint64 gmw_rc = amdgpu_lower_gemm_f16f32_wmma_3c(fn_node, source, kname_ptr, nl)
    if gmw_rc == 0 { return 0 }

    // ── Phase 2: LLM @kernel name routing ─────────────────────────────
    // Source files in examples/llm/ define @kernel fns whose bodies use
    // HIP intrinsics (tid_local_x/y, sync_block, lds_load_f32, etc.) that
    // the structural recogniser below can't lower. We don't need to —
    // for each well-known LLM kernel name, route directly to the native
    // emitter that produces the hand-tuned ISA milestone (N1..N5). The
    // launcher's kernarg packing matches the corresponding _blob emitter
    // bit-for-bit, so this is a transparent name → ISA dispatch table.
    // Bodies must still parse (so MLRift can validate types and the
    // launcher can take @kernel addresses), but the native target ignores
    // them and emits the hand-tuned ISA instead.
    // gemv_f32 + gemm_f32 + gemm_f32_lds + gemm_f16f32 + gemm_f16f32_wmma
    // routes deleted — Phase 3c-2..3c-6 own AST paths.  Phase 2 LLM
    // dispatch table is now empty.
    // softmax_f32 + layernorm_f32 + rmsnorm_f32 routes deleted —
    // Phase 3b/3b-2/3b-3 own the AST-walker path.
    // silu_f32 + silu_mul_f32 + residual_add_f32 routes deleted —
    // Phase 3a-2/3a-3/3a-5 catch them above via AST shape match.
    // rope_f32 route deleted — Phase 3c-1 owns the AST-walker path.
    // softmax_causal_f32 route deleted — Phase 3b-4 owns the AST-walker path.

    // ── Phase 3a: AST-walking pointwise-binop recogniser ──────────────
    // Handles any @kernel with 3 params + the canonical pointwise body
    // (gid + bounds-check, single-op f32 update via scalar param). This
    // is the first non-name-matched lowerer — body shape alone tells us
    // we can handle it. See docs/PHASE3_DESIGN.md.
    uint64 pw_rc = amdgpu_lower_pointwise_3a(fn_node, source, kname_ptr, nl)
    if pw_rc == 0 { return 0 }
    if tok_matches(name_tok, "spike_reduce", 12) != 0 {
        return amdgpu_lower_noesis_spike_reduce(kname_ptr, nl)
    }

    // Param list — 1 or 2 params. If there are 2, the 2nd is taken
    // as a u32 by-value scalar and its PARAM name is remembered so
    // we can match it against the PtrStore value Ident.
    uint64 n_params = 0
    uint32 param0_tok = 0
    uint32 param1_tok = 0
    uint32 p = ast_child(fn_node)
    uint64 wp = p
    while wp != 0 {
        if n_params == 0 { param0_tok = ast_data2(wp) }
        if n_params == 1 { param1_tok = ast_data2(wp) }
        n_params = n_params + 1
        uint32 np = ast_next(wp)
        wp = np
    }
    if n_params != 1 && n_params != 2 && n_params != 3 && n_params != 4 && n_params != 5 {
        write(2, "mlrc: amdgpu-native lowering supports 1-5 params (got ", 54)
        uint8[24] cbuf
        uint64 clen = fmt_uint(cbuf, n_params)
        write(2, cbuf, clen)
        write(2, ")\n", 2)
        return 1
    }

    // Body — either a single PtrStore (M1d/M1e shapes) or a
    // VarDecl followed by a PtrStore (M1f tid-aware shape) or a
    // single If stmt guarding a tid-aware block (M1g guarded shape).
    uint32 body = ast_data3(fn_node)
    if body == 0 {
        write(2, "mlrc: amdgpu-native: kernel has empty body\n", 43)
        return 1
    }
    uint32 stmt0 = ast_child(body)
    if stmt0 == 0 {
        write(2, "mlrc: amdgpu-native: kernel body has no statements\n", 51)
        return 1
    }

    // M1g guarded shape first — recognises:
    //   if tid_x() < PARAM1 {
    //       uint64 p = PARAM0 + tid_x() * 4
    //       unsafe { *(p as uint32) = tid_x() }
    //   }
    // i.e. the M1f tid body wrapped in an if-bounds check. Used when
    // the launch grid has more threads than buffer slots.
    uint64 is_tid_guarded_shape = 0
    uint64 is_decay_shape        = 0
    uint64 is_grid_decay_shape   = 0
    uint64 is_grid_fill_shape    = 0
    uint64 is_grid_relax_shape   = 0
    uint32 s0_kind = ast_kind(stmt0)
    if s0_kind == 13 {
        uint32 after_if = ast_next(stmt0)
        if after_if != 0 {
            write(2, "mlrc: amdgpu-native: guarded shape: expect exactly one If stmt\n", 63)
            return 1
        }
        if n_params != 2 && n_params != 3 && n_params != 4 && n_params != 5 {
            write(2, "mlrc: amdgpu-native: guarded shape expects 2-5 params\n", 54)
            return 1
        }
        // If AST layout (kind 13, per ir.kr): child=cond expr,
        // data1=then block, data2=optional else body.
        // Validate cond = Compare(LT, Call(tid_x), Ident(param1)).
        uint32 cond_node = ast_child(stmt0)
        uint64 wcond = cond_node
        if ast_kind(wcond) != 38 {
            write(2, "mlrc: amdgpu-native: guarded shape: if cond must be a comparison\n", 65)
            return 1
        }
        uint32 cond_op_tok = ast_data1(wcond)
        uint64 cond_op_kind = tok_kind_at_raw(cond_op_tok)
        if cond_op_kind != 37 {
            // 37 = `<` per ir.kr BinOp LT mapping.
            write(2, "mlrc: amdgpu-native: guarded shape: if cond must use `<`\n", 57)
            return 1
        }
        uint32 cond_lhs = ast_child(wcond)
        uint32 cond_rhs = ast_data2(wcond)
        uint64 wclhs = cond_lhs
        uint64 wcrhs = cond_rhs
        // For 2/3-param shapes the cond LHS must be a direct Call
        // to tid_x(). For the 4+-param grid shapes the LHS is a
        // richer expression — `block_id_x() * bdim + tid_x()` —
        // and we trust the user source rather than walking the
        // BinOp here.
        if n_params != 4 && n_params != 5 {
            if ast_kind(wclhs) != 35 {
                write(2, "mlrc: amdgpu-native: guarded shape: cond lhs must be a Call\n", 60)
                return 1
            }
            uint32 lhs_callee = ast_data1(wclhs)
            if tok_matches(lhs_callee, "tid_x", 5) == 0 {
                write(2, "mlrc: amdgpu-native: guarded shape: cond lhs must be tid_x()\n", 61)
                return 1
            }
        }
        if ast_kind(wcrhs) != 32 {
            write(2, "mlrc: amdgpu-native: guarded shape: cond rhs must be an Ident\n", 62)
            return 1
        }
        uint32 rhs_ident = ast_data1(wcrhs)
        if tok_text_eq(rhs_ident, param1_tok) == 0 {
            write(2, "mlrc: amdgpu-native: guarded shape: cond rhs must name the 2nd param\n", 69)
            return 1
        }
        // The then-block content is *assumed* to match the tid body
        // shape — we trust it here since any mismatch just produces
        // wrong results at runtime, not a crash. Full structural
        // validation of the nested Block can land alongside richer
        // lowering.
        if n_params == 2 { is_tid_guarded_shape = 1 }
        if n_params == 3 { is_decay_shape       = 1 }
        if n_params == 4 {
            // Disambiguate grid-decay vs grid-fill by counting the
            // then-block's statements. Decay is 5 stmts (p, v, load,
            // assign, store); fill is 2 stmts (p, store).
            uint32 then_body = ast_data1(stmt0)
            uint64 wthen = then_body
            uint64 then_stmts = 0
            if wthen != 0 {
                uint32 bc = ast_child(wthen)
                uint64 wbc = bc
                while wbc != 0 {
                    then_stmts = then_stmts + 1
                    uint32 nxtbc = ast_next(wbc)
                    wbc = nxtbc
                }
            }
            if then_stmts <= 2 { is_grid_fill_shape  = 1 }
            if then_stmts >= 3 { is_grid_decay_shape = 1 }
        }
        if n_params == 5 { is_grid_relax_shape = 1 }
    }

    uint32 stmt1 = ast_next(stmt0)
    uint64 is_tid_shape = 0
    if is_tid_guarded_shape == 0 && stmt1 != 0 {
        // Two-stmt body → must be VarDecl then PtrStore. The PtrStore's
        // value must be a Call to tid_x(); the VarDecl's init computes
        // the byte offset via `param0 + tid_x() * SCALE` and is trusted
        // (we don't verify the arithmetic yet — that's next cut).
        uint32 third = ast_next(stmt1)
        if third != 0 {
            write(2, "mlrc: amdgpu-native: kernel body has more than 2 stmts\n", 55)
            return 1
        }
        uint64 ws0 = stmt0
        uint64 ws1 = stmt1
        if ast_kind(ws0) != 10 {
            write(2, "mlrc: amdgpu-native: tid shape: first stmt must be VarDecl\n", 59)
            return 1
        }
        if ast_kind(ws1) != 42 {
            write(2, "mlrc: amdgpu-native: tid shape: second stmt must be PtrStore\n", 61)
            return 1
        }
        uint32 ws1_ts = ast_data1(ws1)
        uint64 ws1_tsz = ws1_ts
        if ws1_tsz != 4 {
            write(2, "mlrc: amdgpu-native: tid shape: only u32 store supported\n", 57)
            return 1
        }
        uint32 ws1_val = ast_data2(ws1)
        uint64 wval1 = ws1_val
        if ast_kind(wval1) != 35 {
            write(2, "mlrc: amdgpu-native: tid shape: store value must be a Call\n", 59)
            return 1
        }
        uint32 callee = ast_data1(wval1)
        if tok_matches(callee, "tid_x", 5) == 0 {
            write(2, "mlrc: amdgpu-native: tid shape: only tid_x() calls supported\n", 61)
            return 1
        }
        if n_params != 1 {
            write(2, "mlrc: amdgpu-native: tid shape expects exactly 1 param\n", 55)
            return 1
        }
        is_tid_shape = 1
    }
    uint64 wstmt = 0
    uint32 skind = 0
    if is_tid_shape == 0 && is_tid_guarded_shape == 0 && is_decay_shape == 0 && is_grid_decay_shape == 0 && is_grid_fill_shape == 0 && is_grid_relax_shape == 0 {
        wstmt = stmt0
        skind = ast_kind(wstmt)
        if skind != 42 {
            write(2, "mlrc: amdgpu-native: first stmt must be PtrStore\n", 49)
            return 1
        }
    }
    uint64 is_lit_shape = 0
    uint64 lit32 = 0
    if is_tid_shape == 0 && is_tid_guarded_shape == 0 && is_decay_shape == 0 && is_grid_decay_shape == 0 && is_grid_fill_shape == 0 && is_grid_relax_shape == 0 {
        uint32 ts = ast_data1(wstmt)
        uint64 type_size = ts
        if type_size != 4 {
            write(2, "mlrc: amdgpu-native: only u32 stores supported\n", 47)
            return 1
        }
        uint32 val_node = ast_data2(wstmt)
        uint64 wvn = val_node
        uint32 vkind = ast_kind(wvn)

        // Decide lowering path: IntLit (1-arg sentinel) vs Ident
        // pointing at the 2nd param (2-arg forwarder).
        if vkind == 30 {
            is_lit_shape = 1
            uint32 lit_tok = ast_data1(wvn)
            lit32 = parse_int_token(lit_tok) & 0xFFFFFFFF
            if n_params != 1 {
                write(2, "mlrc: amdgpu-native: 1-arg sentinel shape expects exactly 1 param\n", 66)
                return 1
            }
        } else if vkind == 32 {
            uint32 ident_tok = ast_data1(wvn)
            if n_params != 2 {
                write(2, "mlrc: amdgpu-native: 2-arg forwarder shape expects exactly 2 params\n", 68)
                return 1
            }
            if tok_text_eq(ident_tok, param1_tok) == 0 {
                write(2, "mlrc: amdgpu-native: store value must reference the 2nd kernel param\n", 69)
                return 1
            }
        } else {
            write(2, "mlrc: amdgpu-native: store value must be an IntLit or a param Ident\n", 68)
            return 1
        }
    }

    // Lower to gfx1100 via the encoders. Resource layout mirrors
    // what clang picks for these kernel classes — safe
    // over-approximation until we derive them from analysis.
    uint64 rsrc1 = 0xE0AF0000
    uint64 rsrc2 = 0x0000009E
    uint64 rsrc3 = 0x00000010
    uint64 props = 0x0408       // KERNARG_SEGMENT_PTR | WAVEFRONT_SIZE32

    asm_init()
    uint64 kernarg_size = 0
    uint64 sgpr_count   = 0
    uint64 n_args       = 0

    // Each kernel owns its own args_desc buffer (alloc instead of
    // stack) because kt_push stores the pointer into the table and
    // reads it back during emit — stack addresses wouldn't survive
    // function return. Same rationale for the kernel text blob.
    // 6 × 16 bytes = up to 6 args × (size, kind); decay uses 3.
    uint64 args_desc = alloc(6 * 16)

    if is_grid_relax_shape != 0 {
        // M1l grid-relax: nv = v + (target - v) * factor.
        // Lowered as  diff = target - v ; nv = fma(factor, diff, v).
        // Kernarg layout (5 args):
        //   0:  buf           u64
        //   8:  n             u32
        //   16: target        f64
        //   24: factor        f64
        //   32: bdim          u32    (= kernarg_size 36)
        //
        //   s_clause 0x1
        //   s_load_b32 s2, s[0:1], 0x20    ; bdim
        //   s_load_b32 s4, s[0:1], 0x8     ; n
        //   s_waitcnt lgkmcnt(0)
        //   v_mad_u32_u24 v1, s2, s15, v0  ; gid
        //   v_cmp_gt_u32 vcc_lo, s4, v1
        //   s_and_saveexec_b32 s3, vcc_lo
        //   s_cbranch_execz 15
        //   s_load_b64 s[2:3], s[0:1], null  ; buf
        //   s_load_b64 s[4:5], s[0:1], 0x10  ; target
        //   s_load_b64_off s[6:7], 0x18       ; factor
        //   v_lshlrev_b32 v4, 3, v1           ; byte offset
        //   s_waitcnt lgkmcnt(0)
        //   global_load_b64 v[0:1], v4, s[2:3]
        //   s_waitcnt vmcnt(0)
        //   v_add_f64 v[2:3], s[4:5], -v[0:1]   ; diff = target - v
        //   v_fma_f64 v[0:1], s[6:7], v[2:3], v[0:1] ; nv = factor*diff + v
        //   global_store_b64 v4, v[0:1], s[2:3]
        //   s_endpgm
        asm_s_clause(1)
        asm_s_load_b32(1, 0, 0x20)                  // s2 = bdim
        asm_s_load_b32(2, 0, 0x8)                   // s4 = n
        asm_s_waitcnt_lgkmcnt_zero()
        asm_v_mad_u32_u24(1, 2, 15, 0)              // v1 = gid
        asm_v_cmp_gt_u32_sgpr_vgpr(4, 1)
        asm_s_and_saveexec_b32_vcc_lo(3)
        asm_s_cbranch_execz(15)                     // 15 dwords to s_endpgm
        asm_s_load_b64(1, 0)                        // s[2:3] <- buf
        asm_s_load_b64_off(2, 0, 0x10)              // s[4:5] <- target
        asm_s_load_b64_off(3, 0, 0x18)              // s[6:7] <- factor
        asm_v_lshlrev_b32_imm(4, 3, 1)              // v4 = v1 << 3
        asm_s_waitcnt_lgkmcnt_zero()
        asm_global_load_b64(0, 4, 2)                // v[0:1] = buf[gid]
        asm_s_waitcnt_vmcnt_zero()
        asm_v_add_f64_s_negv(2, 4, 0)               // v[2:3] = s[4:5] - v[0:1]
        asm_v_fma_f64_s_v_v(0, 6, 2, 0)             // v[0:1] = s[6:7]*v[2:3] + v[0:1]
        asm_global_store_b64(4, 0, 2)               // buf[gid] = v[0:1]
        asm_s_endpgm()

        uint64 adp0 = args_desc + 0;    unsafe { *(adp0 as uint64) = 8 }
        uint64 adp1 = args_desc + 8;    unsafe { *(adp1 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
        uint64 adp2 = args_desc + 16;   unsafe { *(adp2 as uint64) = 4 }
        uint64 adp3 = args_desc + 24;   unsafe { *(adp3 as uint64) = AMD_ARG_KIND_BY_VALUE }
        uint64 adp4 = args_desc + 32;   unsafe { *(adp4 as uint64) = 8 }
        uint64 adp5 = args_desc + 40;   unsafe { *(adp5 as uint64) = AMD_ARG_KIND_BY_VALUE }
        uint64 adp6 = args_desc + 48;   unsafe { *(adp6 as uint64) = 8 }
        uint64 adp7 = args_desc + 56;   unsafe { *(adp7 as uint64) = AMD_ARG_KIND_BY_VALUE }
        uint64 adp8 = args_desc + 64;   unsafe { *(adp8 as uint64) = 4 }
        uint64 adp9 = args_desc + 72;   unsafe { *(adp9 as uint64) = AMD_ARG_KIND_BY_VALUE }
        kernarg_size = 36
        sgpr_count   = 18
        n_args       = 5
    } else if is_grid_fill_shape != 0 {
        // M1k grid-fill: buf[gid] = value for gid < n. Same kernarg
        // layout as grid-decay (buf, n, value, bdim). Body simpler —
        // no load/fma, just a splat from the f64 kernarg pair into
        // v[0:1] and one 8-byte global store.
        //
        //   s_clause 0x1
        //   s_load_b32 s2, s[0:1], 0x18    ; bdim
        //   s_load_b32 s4, s[0:1], 0x8     ; n
        //   s_waitcnt lgkmcnt(0)
        //   v_mad_u32_u24 v1, s2, s15, v0  ; gid
        //   v_cmp_gt_u32 vcc_lo, s4, v1
        //   s_and_saveexec_b32 s3, vcc_lo
        //   s_cbranch_execz 9
        //   s_load_b64 s[2:3], s[0:1], null   ; buf
        //   s_load_b64 s[4:5], s[0:1], 0x10   ; value (f64)
        //   v_lshlrev_b32 v2, 3, v1
        //   s_waitcnt lgkmcnt(0)
        //   v_dual_mov_b32 v0, s4 :: v_dual_mov_b32 v1, s5
        //   global_store_b64 v2, v[0:1], s[2:3]
        //   s_endpgm
        asm_s_clause(1)
        asm_s_load_b32(1, 0, 0x18)                  // s2 = bdim
        asm_s_load_b32(2, 0, 0x8)                   // s4 = n
        asm_s_waitcnt_lgkmcnt_zero()
        asm_v_mad_u32_u24(1, 2, 15, 0)              // v1 = s2 * s15 + v0
        asm_v_cmp_gt_u32_sgpr_vgpr(4, 1)            // vcc_lo = (s4 > v1)
        asm_s_and_saveexec_b32_vcc_lo(3)            // save EXEC
        asm_s_cbranch_execz(10)                     // skip 10 dwords (s_load_b64 + s_load_b64_off + v_lshl + s_waitcnt + v_dual_mov + global_store_b64) to s_endpgm
        asm_s_load_b64(1, 0)                        // s[2:3] <- buf
        asm_s_load_b64_off(2, 0, 0x10)              // s[4:5] <- value f64
        asm_v_lshlrev_b32_imm(2, 3, 1)              // v2 = v1 << 3
        asm_s_waitcnt_lgkmcnt_zero()
        asm_v_dual_mov_b32_sx_sy(0, 1, 4, 5)        // v[0:1] = s[4:5]
        asm_global_store_b64(2, 0, 2)               // buf[gid] = v[0:1]
        asm_s_endpgm()

        uint64 adp0 = args_desc + 0;   unsafe { *(adp0 as uint64) = 8 }
        uint64 adp1 = args_desc + 8;   unsafe { *(adp1 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
        uint64 adp2 = args_desc + 16;  unsafe { *(adp2 as uint64) = 4 }
        uint64 adp3 = args_desc + 24;  unsafe { *(adp3 as uint64) = AMD_ARG_KIND_BY_VALUE }
        uint64 adp4 = args_desc + 32;  unsafe { *(adp4 as uint64) = 8 }
        uint64 adp5 = args_desc + 40;  unsafe { *(adp5 as uint64) = AMD_ARG_KIND_BY_VALUE }
        uint64 adp6 = args_desc + 48;  unsafe { *(adp6 as uint64) = 4 }
        uint64 adp7 = args_desc + 56;  unsafe { *(adp7 as uint64) = AMD_ARG_KIND_BY_VALUE }
        kernarg_size = 28
        sgpr_count   = 18
        n_args       = 4
    } else if is_grid_decay_shape != 0 {
        // M1j grid-decay shape: decay body with a grid-wide tid.
        //     gid = wg_id_x * bdim + threadIdx.x
        // bdim is supplied as an explicit 4th kernarg (u32) —
        // saves us from wiring up hidden-arg / dispatch-ptr reads
        // for this first pass at grid support.
        //
        // Keep rsrc2 = 0x9E (same as all prior native kernels).
        // That places wg_id_x at s15 per the 15-user-sgpr
        // convention clang also uses; s0..s1 stay as kernarg ptr,
        // s2/s4 hold loaded kernargs (b32 dests must be even-SGPR
        // aligned, so sdata_pair=1 → s2, sdata_pair=2 → s4).
        //
        //   s_clause 0x1
        //   s_load_b32 s2, s[0:1], 0x18    ; s2 = bdim
        //   s_load_b32 s4, s[0:1], 0x8     ; s4 = n
        //   s_waitcnt lgkmcnt(0)
        //   v_mad_u32_u24 v1, s2, s15, v0  ; v1 = bdim*wg_id_x + tid
        //   v_cmp_gt_u32_e32 vcc_lo, s4, v1
        //   s_and_saveexec_b32 s3, vcc_lo
        //   s_cbranch_execz 13             ; skip 13 dwords to s_endpgm
        //   s_load_b64 s[2:3], s[0:1], null
        //   v_lshlrev_b32 v2, 3, v1
        //   s_load_b64 s[0:1], s[0:1], 0x10
        //   s_waitcnt lgkmcnt(0)
        //   global_load_b64 v[0:1], v2, s[2:3]
        //   s_waitcnt vmcnt(0)
        //   v_fma_f64 v[0:1], -s[0:1], v[0:1], v[0:1]
        //   global_store_b64 v2, v[0:1], s[2:3]
        //   s_endpgm
        asm_s_clause(1)
        asm_s_load_b32(1, 0, 0x18)                  // s2 = bdim
        asm_s_load_b32(2, 0, 0x8)                   // s4 = n
        asm_s_waitcnt_lgkmcnt_zero()
        asm_v_mad_u32_u24(1, 2, 15, 0)              // v1 = s2 * s15 + v0
        asm_v_cmp_gt_u32_sgpr_vgpr(4, 1)            // vcc_lo = (s4 > v1)
        asm_s_and_saveexec_b32_vcc_lo(3)            // save EXEC in s3
        asm_s_cbranch_execz(13)
        asm_s_load_b64(1, 0)                        // s[2:3] <- buf
        asm_v_lshlrev_b32_imm(2, 3, 1)              // v2 = v1 << 3
        asm_s_load_b64_off(0, 0, 0x10)              // s[0:1] <- factor
        asm_s_waitcnt_lgkmcnt_zero()
        asm_global_load_b64(0, 2, 2)
        asm_s_waitcnt_vmcnt_zero()
        asm_v_fma_f64_neg_s_v_v(0, 0, 0, 0)
        asm_global_store_b64(2, 0, 2)
        asm_s_endpgm()

        uint64 adp0 = args_desc + 0;   unsafe { *(adp0 as uint64) = 8 }
        uint64 adp1 = args_desc + 8;   unsafe { *(adp1 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
        uint64 adp2 = args_desc + 16;  unsafe { *(adp2 as uint64) = 4 }
        uint64 adp3 = args_desc + 24;  unsafe { *(adp3 as uint64) = AMD_ARG_KIND_BY_VALUE }
        uint64 adp4 = args_desc + 32;  unsafe { *(adp4 as uint64) = 8 }
        uint64 adp5 = args_desc + 40;  unsafe { *(adp5 as uint64) = AMD_ARG_KIND_BY_VALUE }
        uint64 adp6 = args_desc + 48;  unsafe { *(adp6 as uint64) = 4 }
        uint64 adp7 = args_desc + 56;  unsafe { *(adp7 as uint64) = AMD_ARG_KIND_BY_VALUE }
        kernarg_size = 28
        sgpr_count   = 18       // s0..s15 + slop — match clang's heuristic
        n_args       = 4
    } else if is_decay_shape != 0 {
        // M1h f64 decay shape — mirrors clang's gfx1100 output for:
        //   @kernel fn decay_step(uint64 buf, uint32 n, f64 factor) {
        //       if tid_x() < n {
        //           uint64 p = buf + tid_x() * 8
        //           f64 v = 0.0
        //           unsafe { *(p as f64) -> v }
        //           v = v - v * factor
        //           unsafe { *(p as f64) = v }
        //       }
        //   }
        //
        // 14 instructions, 76 bytes. Nested body details (the VarDecl
        // ladder and the fma-fused subtract) are trusted; the guard
        // + layout is what we actively match.
        asm_s_load_b32(1, 0, 8)                            // s2 = n
        asm_s_waitcnt_lgkmcnt_zero()
        asm_v_cmp_gt_u32_sgpr_vgpr(2, 0)                   // vcc_lo = (s2 > v0)
        asm_s_and_saveexec_b32_vcc_lo(2)                   // save EXEC, mask
        asm_s_cbranch_execz(13)                            // skip 13 dwords to s_endpgm
        asm_s_load_b64(1, 0)                               // s[2:3] <- kernarg[0..7] (buf)
        asm_v_lshlrev_b32_imm(2, 3, 0)                     // v2 = tid*8
        asm_s_load_b64_off(0, 0, 0x10)                     // s[0:1] <- kernarg[0x10..0x17] (factor)
        asm_s_waitcnt_lgkmcnt_zero()
        // NB: FLAT/GLOBAL saddr is a raw SGPR index (not pair-
        // halved), so s[2:3] encodes as 2 here even though the SMEM
        // loaders above take pair indices.
        asm_global_load_b64(0, 2, 2)                       // v[0:1] = buf[tid]  (saddr=s[2:3])
        asm_s_waitcnt_vmcnt_zero()
        asm_v_fma_f64_neg_s_v_v(0, 0, 0, 0)                // v[0:1] = -s[0:1]*v[0:1] + v[0:1]
        asm_global_store_b64(2, 0, 2)                      // buf[tid] = v[0:1]
        asm_s_endpgm()

        uint64 adp0 = args_desc + 0;   unsafe { *(adp0 as uint64) = 8 }
        uint64 adp1 = args_desc + 8;   unsafe { *(adp1 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
        uint64 adp2 = args_desc + 16;  unsafe { *(adp2 as uint64) = 4 }
        uint64 adp3 = args_desc + 24;  unsafe { *(adp3 as uint64) = AMD_ARG_KIND_BY_VALUE }
        uint64 adp4 = args_desc + 32;  unsafe { *(adp4 as uint64) = 8 }
        uint64 adp5 = args_desc + 40;  unsafe { *(adp5 as uint64) = AMD_ARG_KIND_BY_VALUE }
        kernarg_size = 24
        sgpr_count   = 6
        n_args       = 3
    } else if is_tid_guarded_shape != 0 {
        // Guarded per-thread shape (mirrors clang's gfx1100 output
        // for `if (i < n) { out[i] = i }`):
        //
        //   s_load_b32 s2, s[0:1], 0x8         ; load bound n
        //   s_waitcnt lgkmcnt(0)
        //   v_cmp_gt_u32_e32 vcc_lo, s2, v0    ; vcc_lo[lane] = (n > tid)
        //   s_and_saveexec_b32 s2, vcc_lo      ; mask inactive lanes
        //   s_cbranch_execz 6                  ; skip 6 dwords if none pass
        //   s_load_b64 s[0:1], s[0:1], null    ; load pointer
        //   v_lshlrev_b32 v1, 2, v0            ; v1 = tid*4
        //   s_waitcnt lgkmcnt(0)
        //   global_store_b32 v1, v0, s[0:1]
        //   s_endpgm
        asm_s_load_b32(1, 0, 8)                    // s2 <- kernarg[8] = n
        asm_s_waitcnt_lgkmcnt_zero()
        asm_v_cmp_gt_u32_sgpr_vgpr(2, 0)           // vcc_lo = (s2 > v0)
        asm_s_and_saveexec_b32_vcc_lo(2)           // save EXEC to s2, gate
        asm_s_cbranch_execz(6)                     // 6 dwords = 24 bytes
        asm_s_load_b64(0, 0)                       // s[0:1] <- kernarg[0..7]
        asm_v_lshlrev_b32_imm(1, 2, 0)
        asm_s_waitcnt_lgkmcnt_zero()
        asm_global_store_b32(1, 0, 0)
        asm_s_endpgm()

        uint64 adp0 = args_desc + 0;   unsafe { *(adp0 as uint64) = 8 }
        uint64 adp1 = args_desc + 8;   unsafe { *(adp1 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
        uint64 adp2 = args_desc + 16;  unsafe { *(adp2 as uint64) = 4 }
        uint64 adp3 = args_desc + 24;  unsafe { *(adp3 as uint64) = AMD_ARG_KIND_BY_VALUE }
        kernarg_size = 12
        sgpr_count   = 5       // s0..s4 (kernarg ptr + n + saved exec)
        n_args       = 2
    } else if is_tid_shape != 0 {
        // Per-thread shape: byte_offset = tid * 4, value = tid.
        //
        //   s_load_b64  s[0:1], s[0:1], null
        //   v_lshlrev_b32 v1, 2, v0               ; v1 = tid * 4
        //   s_waitcnt lgkmcnt(0)
        //   global_store_b32 v1, v0, s[0:1]       ; *(s[0:1] + v1) = v0
        //   s_endpgm
        asm_s_load_b64(0, 0)
        asm_v_lshlrev_b32_imm(1, 2, 0)             // vdst=v1, shift=2, src=v0
        asm_s_waitcnt_lgkmcnt_zero()
        asm_global_store_b32(1, 0, 0)              // v_addr=v1, v_data=v0, saddr_pair=0
        asm_s_endpgm()

        uint64 adp0 = args_desc + 0;  unsafe { *(adp0 as uint64) = 8 }
        uint64 adp1 = args_desc + 8;  unsafe { *(adp1 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
        kernarg_size = 8
        sgpr_count   = 2
        n_args       = 1
    } else if is_lit_shape != 0 {
        asm_s_load_b64(0, 0)
        asm_v_dual_mov_b32_mov_b32_lit(0, 1, lit32)
        asm_s_waitcnt_lgkmcnt_zero()
        asm_global_store_b32(0, 1, 0)
        asm_s_endpgm()

        uint64 adp0 = args_desc + 0;  unsafe { *(adp0 as uint64) = 8 }
        uint64 adp1 = args_desc + 8;  unsafe { *(adp1 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
        kernarg_size = 8
        sgpr_count   = 2
        n_args       = 1
    } else {
        asm_s_clause(1)
        asm_s_load_b32(1, 0, 8)
        asm_s_load_b64(0, 0)
        asm_s_waitcnt_lgkmcnt_zero()
        asm_v_dual_mov_b32_mov_b32_sgpr(0, 1, 2)
        asm_global_store_b32(0, 1, 0)
        asm_s_endpgm()

        uint64 adp0 = args_desc + 0;   unsafe { *(adp0 as uint64) = 8 }
        uint64 adp1 = args_desc + 8;   unsafe { *(adp1 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
        uint64 adp2 = args_desc + 16;  unsafe { *(adp2 as uint64) = 4 }
        uint64 adp3 = args_desc + 24;  unsafe { *(adp3 as uint64) = AMD_ARG_KIND_BY_VALUE }
        kernarg_size = 12
        sgpr_count   = 3
        n_args       = 2
    }

    // Copy the just-assembled kernel text into a dedicated buffer —
    // the next kernel's asm_init() will otherwise clobber it.
    uint64 k_text_size = asm_text_len
    uint64 k_text_buf  = alloc(k_text_size)
    uint64 ci = 0
    while ci < k_text_size {
        uint64 sp = asm_text_buf + ci
        uint64 b = 0
        unsafe { *(sp as uint8) -> b }
        uint64 dp = k_text_buf + ci
        uint8 b8 = b
        unsafe { *(dp as uint8) = b8 }
        ci = ci + 1
    }

    uint64 vgpr_count_k = 2
    if is_decay_shape != 0       { vgpr_count_k = 3 }
    if is_grid_decay_shape != 0  { vgpr_count_k = 3 }
    if is_grid_fill_shape != 0   { vgpr_count_k = 3 }
    if is_grid_relax_shape != 0  { vgpr_count_k = 5 }  // v[0:1] v, v[2:3] diff, v4 byte off
    kt_push(kname_ptr, nl, k_text_buf, k_text_size,
            args_desc, n_args, kernarg_size,
            sgpr_count, vgpr_count_k,
            rsrc1, rsrc2, rsrc3, props)
    return 0
}

// ─────────────────────────────────────────────────────────────────────
// Slice 4.2 — qwen3 mega-kernel skeleton (cross-WG barrier scaffold).
//
// Bytewise port of the slice 4.1 hipcc microbench (validated GREEN at
// 0.45 µs/barrier on RX 7800 XT, see docs/SLICE4_MEGAKERNEL_DESIGN.md).
// Native-emitted so subsequent slices (4.3+) can substitute phase
// work between the barriers without going through hipcc.
//
// Kernel signature (matches slice 4.1 microbench so launchers are
// drop-in compatible):
//   void qwen3_megakernel_skeleton(u32 *counter_ptr, u64 n_wgs, u64 n_iters)
//
// The body is bytewise identical to the hipcc -O3 disassembly of
// `examples/llm/mega_barrier_microbench.hip.cpp` for gfx1100.  Each
// raw `asm_u32` call below is annotated with its disassembled
// instruction and offset (relative to text start).
fn _emit_qwen3_megakernel_skeleton_body() {
    asm_init()

    // ── PROLOGUE: lane-0 gating ──
    asm_u32(0xBE82007E)   // 0x00 s_mov_b32 s2, exec_lo  (save full exec)
    asm_u32(0x7D940080)   // 0x04 v_cmpx_eq_u32_e32 0, v0   ⇒ exec_lo &= (v0==0)
    asm_u32(0xBFA5002D)   // 0x08 s_cbranch_execz +45 (skip to s_endpgm)

    // ── PROLOGUE: kernarg load ──
    asm_u32(0xF4040100); asm_u32(0xF8000010)  // 0x0C s_load_b64 s[4:5], s[0:1], 0x10  (n_iters)
    asm_u32(0xBF89FC07)   // 0x14 s_waitcnt lgkmcnt(0)
    asm_u32(0xBF068004)   // 0x18 s_cmp_eq_u32 s4, 0
    asm_u32(0xBFA20028)   // 0x1C s_cbranch_scc1 +40  (n_iters==0 → end)

    asm_u32(0xF4080000); asm_u32(0xF8000000)  // 0x20 s_load_b128 s[0:3], s[0:1], null  (counter_ptr + n_wgs)
    asm_u32(0x7E000280)   // 0x28 v_mov_b32_e32 v0, 0  (vaddr offset)
    asm_u32(0xBF89FC07)   // 0x2C s_waitcnt lgkmcnt(0)
    asm_u32(0xBE830080)   // 0x30 s_mov_b32 s3, 0  (i = 0)
    asm_u32(0xBF800000)   // 0x34 s_nop 0
    asm_u32(0xBF800000)   // 0x38 s_nop 0
    asm_u32(0xBF800000)   // 0x3C s_nop 0

    // ── LOOP_HEAD (offset 0x40): one barrier iteration ──
    asm_u32(0xBE86007E)   // 0x40 s_mov_b32 s6, exec_lo
    asm_u32(0xBE85007E)   // 0x44 s_mov_b32 s5, exec_lo
    asm_u32(0xD71F0001); asm_u32(0x00010006)  // 0x48 v_mbcnt_lo_u32_b32 v1, s6, 0
    asm_u32(0xBF870001)   // 0x50 s_delay_alu instid0(VALU_DEP_1)
    asm_u32(0x7D940280)   // 0x54 v_cmpx_eq_u32_e32 0, v1  (gate to first active lane)
    asm_u32(0xBFA5000A)   // 0x58 s_cbranch_execz +10  (skip atomic if no first-lane)

    asm_u32(0xBE861806)   // 0x5C s_bcnt1_i32_b32 s6, s6  (s6 = popcount of saved exec)
    asm_u32(0xBF870009)   // 0x60 s_delay_alu instid0(SALU_CYCLE_1)
    asm_u32(0x7E020206)   // 0x64 v_mov_b32_e32 v1, s6
    asm_u32(0xDCD60000); asm_u32(0x00000100)  // 0x68 global_atomic_add_u32 v0, v1, s[0:1]
    asm_u32(0xBC7C0000)   // 0x70 s_waitcnt_vscnt null, 0x0
    asm_u32(0xE0B00000); asm_u32(0x00000000)  // 0x74 buffer_gl1_inv
    asm_u32(0xE0AC0000); asm_u32(0x00000000)  // 0x7C buffer_gl0_inv

    // ── SKIP_ATOMIC (offset 0x84): expected-value compute ──
    asm_u32(0x8C7E057E)   // 0x84 s_or_b32 exec_lo, exec_lo, s5  (restore full exec)
    asm_u32(0x81038103)   // 0x88 s_add_i32 s3, s3, 1  (i++)
    asm_u32(0xBF870009)   // 0x8C s_delay_alu instid0(SALU_CYCLE_1)
    asm_u32(0x96050203)   // 0x90 s_mul_i32 s5, s3, s2  (expected = (i+1) * n_wgs … s2=n_wgs from kernarg)

    // ── SPIN (offset 0x94): wait for counter ≥ expected ──
    asm_u32(0xDC524000); asm_u32(0x01000000)  // 0x94 global_load_b32 v1, v0, s[0:1] glc
    asm_u32(0xBF8903F7)   // 0x9C s_waitcnt vmcnt(0)
    asm_u32(0xE0B00000); asm_u32(0x00000000)  // 0xA0 buffer_gl1_inv
    asm_u32(0xE0AC0000); asm_u32(0x00000000)  // 0xA8 buffer_gl0_inv
    asm_u32(0x7C980205)   // 0xB0 v_cmp_gt_u32_e32 vcc_lo, s5, v1  (vcc = expected > value)
    asm_u32(0xBFA4FFF7)   // 0xB4 s_cbranch_vccnz -9  (loop back to global_load_b32)

    // ── LOOP_TAIL (offset 0xB8) ──
    asm_u32(0xBF070403)   // 0xB8 s_cmp_lg_u32 s3, s4
    asm_u32(0xBFA2FFE0)   // 0xBC s_cbranch_scc1 -32  (loop back to LOOP_HEAD)

    // ── END (offset 0xC0) ──
    asm_u32(0xBFB00000)   // 0xC0 s_endpgm
}

// Public emit: writes a code-object containing exactly one kernel
// `qwen3_megakernel_skeleton` with the body above, packaged as a
// gfx1100 amdhsa ELF.  Used by the slice 4.2 launcher to verify the
// native-emit barrier path matches the hipcc reference (timing-wise
// and bytewise after llvm-objdump diff).
fn emit_amdgpu_qwen3_megakernel_skeleton_blob(uint64 out_path) -> uint64 {
    uint64 kname = "qwen3_megakernel_skeleton"
    uint64 klen  = 25

    _emit_qwen3_megakernel_skeleton_body()

    // rsrc1/rsrc2/rsrc3 — match the WMMA / atomic-add precedents.
    // 24 SGPRs (s0..s7 + COv5 hidden args), 7 VGPRs (v0..v6 used).
    // rsrc1 0xE0AF0000: float_round=0, fp denorm modes default, dx10
    // clamp on, ieee=on, priority=0, vgpr_count_field = 0x07/8-1 = 0,
    // sgpr_count_field = 0x16 (24 sgprs).
    // rsrc2 0x9E: enable wg_id_x in s15 (matches gemm_f32 / qknorm).
    // rsrc3 0x10: WGP mode disabled (CU mode), inst_pref_size = 16.
    // properties 0x0408: kernarg_size 64 / 8 = 8 dwords reserved by
    // the wrapper for COv5 hidden args; explicit kernargs = 24 bytes.
    uint64 rsrc1 = 0xE0AF0000
    uint64 rsrc2 = 0x0000009E
    uint64 rsrc3 = 0x00000010
    uint64 props = 0x0408

    // Three explicit kernargs:
    //   [0] counter_ptr  — GLOBAL_BUFFER (u32 *), 8 B
    //   [1] n_wgs        — BY_VALUE u64, 8 B
    //   [2] n_iters      — BY_VALUE u64, 8 B
    uint64[6] args_desc
    uint64 a0 = args_desc + 0;   unsafe { *(a0 as uint64) = 8 }
    uint64 a1 = args_desc + 8;   unsafe { *(a1 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a2 = args_desc + 16;  unsafe { *(a2 as uint64) = 8 }
    uint64 a3 = args_desc + 24;  unsafe { *(a3 as uint64) = AMD_ARG_KIND_BY_VALUE }
    uint64 a4 = args_desc + 32;  unsafe { *(a4 as uint64) = 8 }
    uint64 a5 = args_desc + 40;  unsafe { *(a5 as uint64) = AMD_ARG_KIND_BY_VALUE }

    uint64 size = emit_amdgpu_code_object(kname, klen,
                                           asm_text_buf, asm_text_len,
                                           24,      // explicit kernarg_size (3 × 8 B)
                                           8,       // kernarg_align
                                           24,      // sgpr_count (s0..s23 incl COv5 hidden)
                                           7,       // vgpr_count (v0..v6)
                                           rsrc1, rsrc2, rsrc3, props,
                                           args_desc, 3)

    uint64 fd = file_open(out_path, 1)
    if fd > 0xFFFFFFFFFFFFF000 {
        write(2, "emit_amdgpu_qwen3_megakernel_skeleton_blob: cannot open output\n", 63)
        return 1
    }
    file_write(fd, amd_buf, size)
    file_close(fd)
    return 0
}

// ─────────────────────────────────────────────────────────────────────
// Slice 4.19.11 — emit_amdgpu_qwen3_megakernel_blob (slice 4.18 v1
// byte-wrapper) deleted.  Was: read pre-extracted gfx1100 .text bytes
// from build/native_megakernel/qwen3_layer_megakernel.gfx1100.bin and
// wrap into a .co.  The v2 AST-walker below (slice 4.19.0+) is now the
// sole mega-kernel emit path, validated bit-exact against the v1
// reference at decode lengths 20/50/80/120 in slice 4.19.10.

// ─────────────────────────────────────────────────────────────────────
// Slice 4.19.0 — qwen3-0.6B layer mega-kernel v2 (AST-walker stub).
//
// Emits a stub .co by:
//   1. Parsing examples/llm/qwen3_layer_megakernel.mlr
//   2. Locating the @kernel fn qwen3_layer_megakernel node in the AST
//   3. Calling recognize_megakernel_swiglu_dense_gqa (THE Task-1 deliverable)
//      which validates the 24-parameter signature + Block body shape, then
//      delegates to mega_emit_stub_kernel (9 s_nop phases + 8 working
//      cross-WG barriers + max_phase early-exit guards)
//   4. Wrapping the emitted ISA bytes into a complete .co via the standard
//      multi_code_object path
//
// The recognizer path (step 3) is the AST→ISA path under development;
// invoking it here exercises the actual code, not just the stub directly.
//
// Returns 0 on success, 1 on error.
// MUST be called just before exit; clobbers global parser/AST/codegen state.
// Do not call this mid-pipeline if any other compilation needs to follow.
@export
fn emit_amdgpu_qwen3_megakernel_blob_v2(uint64 out_path) -> uint64 {
    uint64 kname = "qwen3_layer_megakernel"
    uint64 klen  = 22

    // ── Step 1: parse examples/llm/qwen3_layer_megakernel.mlr ──────────
    uint64 mlr_path = "examples/llm/qwen3_layer_megakernel.mlr"
    uint64 mlr_fd = file_open(mlr_path, 0)
    if mlr_fd > 0xFFFFFFFFFFFFF000 {
        write(2, "emit_amdgpu_qwen3_megakernel_blob_v2: cannot open examples/llm/qwen3_layer_megakernel.mlr\n", 89)
        return 1
    }
    uint64 mlr_sz = file_size(mlr_fd)
    if mlr_sz == 0 {
        write(2, "emit_amdgpu_qwen3_megakernel_blob_v2: empty .mlr file\n", 54)
        file_close(mlr_fd)
        return 1
    }
    // Allocate a fresh source buffer; do NOT use import_buf (which may be
    // in use by the caller's main parse pipeline).
    uint64 v2_src = alloc(mlr_sz + 1)
    file_read(mlr_fd, v2_src, mlr_sz)
    file_close(mlr_fd)
    // Null-terminate
    uint64 v2_nul_p = v2_src + mlr_sz
    uint8 v2_nul = 0
    unsafe { *(v2_nul_p as uint8) = v2_nul }

    // Lex the source
    uint64 v2_max_tok = 65536
    uint64 v2_tokens = alloc(v2_max_tok * 16)
    lexer_init(v2_src, mlr_sz, v2_tokens, v2_max_tok)
    uint64 v2_tcount = lexer_run()
    if v2_tcount == 0 {
        write(2, "emit_amdgpu_qwen3_megakernel_blob_v2: lexer produced 0 tokens -- syntax error in .mlr\n", 86)
        return 1
    }

    // Parse into a fresh AST arena (does not disturb the main AST if any)
    ast_init(65536)
    codegen_init(1048576, v2_src, v2_tokens)
    parser_init(v2_tokens, v2_tcount)
    uint64 v2_root = parse_module()
    if v2_root == 0 {
        write(2, "emit_amdgpu_qwen3_megakernel_blob_v2: parse_module returned null -- syntax error in .mlr\n", 89)
        return 1
    }

    // ── Step 2: find the @kernel fn qwen3_layer_megakernel node ────────
    uint64 fn_node = 0
    uint32 wc = ast_child(v2_root)
    while wc != 0 {
        uint32 k = ast_kind(wc)
        if k == 2 {
            if ast_fn_is_kernel(wc) != 0 {
                uint32 name_tok = ast_data1(wc)
                if tok_matches(name_tok, "qwen3_layer_megakernel", 22) != 0 {
                    fn_node = wc
                    wc = 0   // break
                } else {
                    uint32 nxt = ast_next(wc)
                    wc = nxt
                }
            } else {
                uint32 nxt = ast_next(wc)
                wc = nxt
            }
        } else {
            uint32 nxt = ast_next(wc)
            wc = nxt
        }
    }
    if fn_node == 0 {
        write(2, "emit_amdgpu_qwen3_megakernel_blob_v2: @kernel fn qwen3_layer_megakernel not found in .mlr\n", 90)
        return 1
    }

    // ── Step 3: run the recognizer (THE Task-1 deliverable) ────────────
    kt_reset()
    uint64 rec_rc = recognize_megakernel_swiglu_dense_gqa(fn_node, v2_src, kname, klen)
    if rec_rc != 0 {
        write(2, "emit_amdgpu_qwen3_megakernel_blob_v2: recognizer shape mismatch\n", 64)
        return 1
    }

    // ── Step 4: wrap into .co and write ────────────────────────────────
    uint64 size = emit_amdgpu_multi_code_object()

    uint64 fd = file_open(out_path, 1)
    if fd > 0xFFFFFFFFFFFFF000 {
        write(2, "emit_amdgpu_qwen3_megakernel_blob_v2: cannot open output\n", 57)
        return 1
    }
    file_write(fd, amd_buf, size)
    file_close(fd)
    return 0
}

// ─────────────────────────────────────────────────────────────────────
// Slice 4.20.0 — qwen3-0.6B SPECK4 layer mega-kernel v2 (AST-walker stub).
//
// Mirror of emit_amdgpu_qwen3_megakernel_blob_v2 above, but for the
// M_EFF=4 multi-query speck4 variant.  Emits a stub .co by:
//   1. Parsing examples/llm/qwen3_layer_megakernel_speck4.mlr
//   2. Locating the @kernel fn qwen3_layer_megakernel_speck4 node in the AST
//   3. Calling recognize_megakernel_swiglu_dense_gqa_speck4 (THE Task-1
//      deliverable) which validates the 24-parameter signature + Block
//      body shape, then delegates to mega_emit_stub_kernel_speck4
//      (9 s_nop phases + 8 working cross-WG barriers + max_phase
//      early-exit guards, LDS=2080)
//   4. Wrapping the emitted ISA bytes into a complete .co via the standard
//      multi_code_object path
//
// Returns 0 on success, 1 on error.
// MUST be called just before exit; clobbers global parser/AST/codegen state.
@export
fn emit_amdgpu_qwen3_megakernel_speck4_blob_v2(uint64 out_path) -> uint64 {
    uint64 kname = "qwen3_layer_megakernel_speck4"
    uint64 klen  = 29

    // ── Step 1: parse examples/llm/qwen3_layer_megakernel_speck4.mlr ────
    uint64 mlr_path = "examples/llm/qwen3_layer_megakernel_speck4.mlr"
    uint64 mlr_fd = file_open(mlr_path, 0)
    if mlr_fd > 0xFFFFFFFFFFFFF000 {
        write(2, "emit_amdgpu_qwen3_megakernel_speck4_blob_v2: cannot open examples/llm/qwen3_layer_megakernel_speck4.mlr\n", 105)
        return 1
    }
    uint64 mlr_sz = file_size(mlr_fd)
    if mlr_sz == 0 {
        write(2, "emit_amdgpu_qwen3_megakernel_speck4_blob_v2: empty .mlr file\n", 61)
        file_close(mlr_fd)
        return 1
    }
    uint64 v2_src = alloc(mlr_sz + 1)
    file_read(mlr_fd, v2_src, mlr_sz)
    file_close(mlr_fd)
    uint64 v2_nul_p = v2_src + mlr_sz
    uint8 v2_nul = 0
    unsafe { *(v2_nul_p as uint8) = v2_nul }

    // Lex the source
    uint64 v2_max_tok = 65536
    uint64 v2_tokens = alloc(v2_max_tok * 16)
    lexer_init(v2_src, mlr_sz, v2_tokens, v2_max_tok)
    uint64 v2_tcount = lexer_run()
    if v2_tcount == 0 {
        write(2, "emit_amdgpu_qwen3_megakernel_speck4_blob_v2: lexer produced 0 tokens -- syntax error in .mlr\n", 93)
        return 1
    }

    // Parse into a fresh AST arena
    ast_init(65536)
    codegen_init(1048576, v2_src, v2_tokens)
    parser_init(v2_tokens, v2_tcount)
    uint64 v2_root = parse_module()
    if v2_root == 0 {
        write(2, "emit_amdgpu_qwen3_megakernel_speck4_blob_v2: parse_module returned null -- syntax error in .mlr\n", 96)
        return 1
    }

    // ── Step 2: find the @kernel fn qwen3_layer_megakernel_speck4 node ──
    uint64 fn_node = 0
    uint32 wc = ast_child(v2_root)
    while wc != 0 {
        uint32 k = ast_kind(wc)
        if k == 2 {
            if ast_fn_is_kernel(wc) != 0 {
                uint32 name_tok = ast_data1(wc)
                if tok_matches(name_tok, "qwen3_layer_megakernel_speck4", 29) != 0 {
                    fn_node = wc
                    wc = 0   // break
                } else {
                    uint32 nxt = ast_next(wc)
                    wc = nxt
                }
            } else {
                uint32 nxt = ast_next(wc)
                wc = nxt
            }
        } else {
            uint32 nxt = ast_next(wc)
            wc = nxt
        }
    }
    if fn_node == 0 {
        write(2, "emit_amdgpu_qwen3_megakernel_speck4_blob_v2: @kernel fn qwen3_layer_megakernel_speck4 not found in .mlr\n", 105)
        return 1
    }

    // ── Step 3: run the speck4 recognizer ──────────────────────────────
    kt_reset()
    uint64 rec_rc = recognize_megakernel_swiglu_dense_gqa_speck4(fn_node, v2_src, kname, klen)
    if rec_rc != 0 {
        write(2, "emit_amdgpu_qwen3_megakernel_speck4_blob_v2: recognizer shape mismatch\n", 71)
        return 1
    }

    // ── Step 4: wrap into .co and write ────────────────────────────────
    uint64 size = emit_amdgpu_multi_code_object()

    uint64 fd = file_open(out_path, 1)
    if fd > 0xFFFFFFFFFFFFF000 {
        write(2, "emit_amdgpu_qwen3_megakernel_speck4_blob_v2: cannot open output\n", 64)
        return 1
    }
    file_write(fd, amd_buf, size)
    file_close(fd)
    return 0
}

