    // ----- IR_ISB (126): instruction-sync barrier -----
    // Use after writing new code to RAM to make sure the subsequent
    // instruction fetches see the writes. ARM64 I-cache is not
    // kept coherent with D-cache automatically (unlike x86).
    if op == 126 {
        emit_a64(0xD5033FDF)   // ISB
        return
    }

    // ----- IR_DCACHE_FLUSH (127): clean + invalidate one D-cache line to PoC -----
    // Emits: DC CIVAC, Xt ; DSB ISH ; ISB. Safe for post-DMA and
    // pre-handoff uses. Requires EL1+ on real hardware; user-space
    // code on Linux will fault with SIGILL unless the kernel emulates.
    if op == 127 {
        uint64 a_reg = ir_a64_resolve_src(s1_v, 9)
        emit_a64(0xD50B7E20 | a_reg)  // DC CIVAC, Xa
        emit_a64(0xD5033B9F)          // DSB ISH
        emit_a64(0xD5033FDF)          // ISB
        return
    }

    // ----- IR_ICACHE_INV (128): invalidate one I-cache line by VA to PoU -----
    // Emits: IC IVAU, Xt ; DSB ISH ; ISB. Use after writing new code
    // into RAM. IC IVAU is available at EL0.
    if op == 128 {
        uint64 a_reg = ir_a64_resolve_src(s1_v, 9)
        emit_a64(0xD50B7520 | a_reg)  // IC IVAU, Xa
        emit_a64(0xD5033B9F)          // DSB ISH
        emit_a64(0xD5033FDF)          // ISB
        return
    }

    // ----- IR_DSB (129): DSB SY — full-system data-sync barrier -----
    if op == 129 {
        emit_a64(0xD5033F9F)
        return
    }

    // ----- IR_DMB (130): DMB ISH — inner-shareable data-memory barrier -----
    if op == 130 {
        emit_a64(0xD5033BBF)
        return
    }

    // ----- IR_ARR_CHECK (131): trap if idx (s1_v) >= count (imm) -----
    // Emits: MOVZ x9, count ; CMP idx, x9 ; B.LO +<trap> ; trap ; ok:
    // Windows ARM64 uses ExitProcess via IAT which doesn't fit this
    // short-sequence pattern; fall back to no-check there.
    if op == 131 {
        if target_os == 2 { return }                      // Windows — skip
        uint64 idx_r = ir_a64_resolve_src(s1_v, 9)
        // Put count in x10 so idx can stay in its register.
        emit_a64_mov_imm(10, imm)
        emit_a64_cmp(idx_r, 10)
        // Compute trap length in instructions.
        //   Linux / Android: MOVZ x0 + MOVZ x8 + SVC #0 = 3 insns.
        //   macOS:           MOVZ x0 + MOVZ x16 + SVC #0 = 3 insns.
        // B.LO +3 insns (skip trap). Encoding: 0x54 | (3<<5) | 3.
        emit_a64(0x54000063)
        emit_a64_mov_imm(0, 1)
        if target_os == 1 {
            emit_a64_mov_imm(16, 1)                        // macOS: exit = 1 via x16
        } else {
            emit_a64_mov_imm(8, 93)                        // Linux/Android: exit = 93 via x8
        }
        emit_a64(0xD4000001)                               // SVC #0
        return
    }

    // ----- IR_FADD (20), IR_FSUB (21), IR_FMUL (22), IR_FDIV (23) -----
    if op >= 20 && op <= 23 {
        uint64 a = ir_a64_resolve_src(s1_v, 9)
        uint64 b = ir_a64_resolve_src(s2_v, 10)
        uint64 d = dst_r
        if d == 0xFFFFFFFF { d = 9 }
        uint64 fk = imm
        if fk == 2 {
            // f32: fmov s0, wA; fmov s1, wB; op s0, s0, s1; fmov wDst, s0
            emit_a64(0x1E270000 | (a << 5) | 0)       // fmov s0, wA
            emit_a64(0x1E270000 | (b << 5) | 1)       // fmov s1, wB
            if op == 20 { emit_a64(0x1E202800 | (1 << 16) | (0 << 5) | 0) }  // fadd s0, s0, s1
            if op == 21 { emit_a64(0x1E203800 | (1 << 16) | (0 << 5) | 0) }  // fsub s0, s0, s1
            if op == 22 { emit_a64(0x1E200800 | (1 << 16) | (0 << 5) | 0) }  // fmul s0, s0, s1
            if op == 23 { emit_a64(0x1E201800 | (1 << 16) | (0 << 5) | 0) }  // fdiv s0, s0, s1
            emit_a64(0x1E260000 | (0 << 5) | d)       // fmov wDst, s0
        } else {
            // f64: fmov d0, xA; fmov d1, xB; op d0, d0, d1; fmov xDst, d0
            emit_a64(0x9E670000 | (a << 5) | 0)       // fmov d0, xA
            emit_a64(0x9E670000 | (b << 5) | 1)       // fmov d1, xB
            if op == 20 { emit_a64(0x1E602800 | (1 << 16) | (0 << 5) | 0) }  // fadd d0, d0, d1
            if op == 21 { emit_a64(0x1E603800 | (1 << 16) | (0 << 5) | 0) }  // fsub d0, d0, d1
            if op == 22 { emit_a64(0x1E600800 | (1 << 16) | (0 << 5) | 0) }  // fmul d0, d0, d1
            if op == 23 { emit_a64(0x1E601800 | (1 << 16) | (0 << 5) | 0) }  // fdiv d0, d0, d1
            emit_a64(0x9E660000 | (0 << 5) | d)       // fmov xDst, d0
