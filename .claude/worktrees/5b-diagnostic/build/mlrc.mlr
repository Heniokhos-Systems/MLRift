        emit_byte(0x0F); emit_byte(0xAE); emit_byte(0xF0)   // MFENCE
        return
    }

    if op == 128 {
        // IR_ICACHE_INV: no-op on x86. The I-cache is kept coherent
        // with the D-cache by the hardware, so no flush is needed.
        return
    }

    if op == 129 {
        // IR_DSB: MFENCE on x86 — waits for all prior loads and stores
        // to complete before later ones start, matching the "wait for
        // completion" semantics of ARM64 DSB SY.
        emit_byte(0x0F); emit_byte(0xAE); emit_byte(0xF0)
        return
    }

    if op == 130 {
        // IR_DMB: MFENCE on x86 — x86 has no cheaper barrier with the
        // right ordering guarantees, so DMB and DSB lower to the same
        // instruction here. On ARM64 they differ.
        emit_byte(0x0F); emit_byte(0xAE); emit_byte(0xF0)
        return
