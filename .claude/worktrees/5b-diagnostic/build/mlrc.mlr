    asm_u32(0x8B099F0F)
    asm_u32(0x850A8209)
    asm_u32(0x840B8C08)
    asm_u32(0x840C890A)
    asm_u32(0x800B0C0B)
    asm_u32(0x840D890F)
    asm_u32(0x30020082)
    asm_u32(0x7E060280)
    asm_u32(0xD7006A02)
    asm_u32(0x0002020B)
    asm_u32(0xD5207C03)
    asm_u32(0x01AA0680)
    asm_u32(0xD7006A02)
    asm_u32(0x00020404)
    asm_u32(0xD5207C03)
    asm_u32(0x01AA0605)
    asm_u32(0x7E0A0280)
    asm_u32(0xD7006A04)
    asm_u32(0x0002020D)
    asm_u32(0xD5207C05)
    asm_u32(0x01AA0A80)
    asm_u32(0xD7006A04)
    asm_u32(0x00020806)
    asm_u32(0xD5207C05)
    asm_u32(0x01AA0A07)
    asm_u32(0xDC520000)
    asm_u32(0x067C0002)
    asm_u32(0xBF8903F7)
    asm_u32(0xDC6A0000)
    asm_u32(0x007C0604)
    asm_u32(0xBC7C0000)
