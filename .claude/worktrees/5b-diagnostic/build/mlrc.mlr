            ir_emit_mov_r64_r64(2, size_reg)    // rdx = size
            // add rdx, 8
            emit_byte(0x48); emit_byte(0x83); emit_byte(0xC2); emit_byte(0x08)
            ir_emit_mov_r64_imm64(8, 0x3000)    // r8 = MEM_COMMIT|MEM_RESERVE
            ir_emit_mov_r64_imm64(9, 4)          // r9 = PAGE_READWRITE
            emit_win_alloc_stack(0x20)
            emit_win_call_iat(6)                  // VirtualAlloc (IAT slot 6)
            emit_win_free_stack(0x20)
