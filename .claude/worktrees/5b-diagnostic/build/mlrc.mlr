            uint8 ld_rex = 0x40
            if dr >= 8 { ld_rex = ld_rex | 4 }
            if addr_reg >= 8 { ld_rex = ld_rex | 1 }
            if ld_rex != 0x40 { emit_byte(ld_rex) }
            emit_byte(0x0F)
            emit_byte(0xB7)
            uint64 ld_modrm = ((dr & 7) << 3) | (addr_reg & 7)
            if (addr_reg & 7) == 4 {
                uint8 ldm = ld_modrm
                emit_byte(ldm)
                emit_byte(0x24)
            } else if (addr_reg & 7) == 5 {
                uint8 ldm = ld_modrm | 0x40
                emit_byte(ldm)
                emit_byte(0)
            } else {
                uint8 ldm = ld_modrm
                emit_byte(ldm)
            }
        } else {
            // 1-byte load: movzx r32, byte [addr_reg]: REX? 0F B6 modrm
            uint8 ld_rex = 0x40
            if dr >= 8 { ld_rex = ld_rex | 4 }
            if addr_reg >= 8 { ld_rex = ld_rex | 1 }
            if ld_rex != 0x40 { emit_byte(ld_rex) }
            emit_byte(0x0F)
            emit_byte(0xB6)
            uint64 ld_modrm = ((dr & 7) << 3) | (addr_reg & 7)
            if (addr_reg & 7) == 4 {
                uint8 ldm = ld_modrm
                emit_byte(ldm)
                emit_byte(0x24)
            } else if (addr_reg & 7) == 5 {
                uint8 ldm = ld_modrm | 0x40
                emit_byte(ldm)
                emit_byte(0)
            } else {
                uint8 ldm = ld_modrm
                emit_byte(ldm)
            }
