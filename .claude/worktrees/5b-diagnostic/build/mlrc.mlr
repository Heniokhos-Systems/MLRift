                emit_byte(0x8B)
                if overflow_off < 128 {
                    uint8 ovm = 0x44 | ((tgt & 7) << 3)
                    emit_byte(ovm)
                    emit_byte(0x24)
                    uint8 ovo = overflow_off
                    emit_byte(ovo)
                } else {
                    uint8 ovm = 0x84 | ((tgt & 7) << 3)
                    emit_byte(ovm)
                    emit_byte(0x24)
                    emit_u32_le(overflow_off)
                }
                if dst_r == 0xFFFFFFFF {
                    ir_emit_store_spill(0, dest_v)
                }
            }
        }
        return
    }

    if op == 51 {
        // IR_ARG: move src to the correct argument register
        // SysV ABI: rdi(7), rsi(6), rdx(2), rcx(1), r8(8), r9(9)
        // Encoding of imm:
        //   0..5     = SysV integer arg slots (rdi/rsi/rdx/rcx/r8/r9)
        //   6..N     = stack-overflow arg slot N-6 (saved for IR_CALL)
        //   100..    = direct GP physical reg (asm I/O constraint), reg = imm-100
        //   200..207 = SysV float arg slot (xmm0..xmm7) — for libm float
        //              ABI calls, see Call lowering above.
        if imm >= 200 && imm < 208 {
            uint64 xmm_n = imm - 200
            uint64 src_reg = ir_resolve_src(s1_v, 0)
            // movd xmmN, src_reg_low_32  →  66 [REX.B?] 0F 6E modRM
            // ModR/M = 11 (xmm_n) (src_reg & 7); REX.B set when src>=8.
            emit_byte(0x66)
            if src_reg >= 8 { emit_byte(0x41) }
            emit_byte(0x0F)
            emit_byte(0x6E)
            uint8 modRM_arg = 0xC0 | ((xmm_n & 7) << 3) | (src_reg & 7)
            emit_byte(modRM_arg)
            return
        }
        uint64 target = 7
        if imm == 1 { target = 6 }
        if imm == 2 { target = 2 }
        if imm == 3 { target = 1 }
        if imm == 4 { target = 8 }
        if imm == 5 { target = 9 }
        if imm < 6 {
            uint64 src_reg = ir_resolve_src(s1_v, 0)
            ir_emit_mov_r64_r64(target, src_reg)
        }
        if imm >= 100 {
            // Direct register target (used by ASM I/O constraints)
            uint64 phys_target = imm - 100
            uint64 src_reg = ir_resolve_src(s1_v, 0)
            ir_emit_mov_r64_r64(phys_target, src_reg)
        } else if imm >= 6 {
            // Overflow arg: save vreg to overflow buffer for IR_CALL to handle
            uint64 oi = imm - 6
            if oi < 32 {
                uint64 op_ptr = ir_overflow_args + oi * 8
                uint64 sv = s1_v
                unsafe { *(op_ptr as uint64) = sv }
                if oi >= ir_overflow_arg_count { ir_overflow_arg_count = oi + 1 }
            }
        }
        return
    }

    if op == 52 {
        // IR_SYSCALL: dispatch by target_os
        if target_os == 2 {
            ir_emit_x86_win_syscall(imm, dest_v, dst_r)
            return
        }
        // Auto-inject hipkfd_teardown() BEFORE exit_group (syscall 231)
        // under --target=amdgpu-native. The exit code is in rdi (set by
        // the preceding IR_ARG). Stash it in rbx (callee-saved) so the
        // CALL doesn't clobber it. Only inject for syscall 231 — every
        // other syscall site is normal program flow that the teardown
        // would derail.
        if imm == 231 && should_auto_inject_teardown() != 0 {
            // mov rbx, rdi   ; stash exit code across the call
            emit_byte(0x48); emit_byte(0x89); emit_byte(0xFB)
            emit_call_hipkfd_teardown()
            // mov rdi, rbx   ; restore exit code into rdi
            emit_byte(0x48); emit_byte(0x89); emit_byte(0xDF)
        }
        // Linux (0), macOS (1), Android (3): raw syscall with OS-specific numbers
        uint64 real_nr = ir_x86_syscall_nr(imm)
        ir_emit_mov_r64_imm64(0, real_nr)
        emit_byte(0x0F)
        emit_byte(0x05)
        if dst_r != 0xFFFFFFFF && dst_r != 0 {
            ir_emit_mov_r64_r64(dst_r, 0)
        }
        if dst_r == 0xFFFFFFFF {
            ir_emit_store_spill(0, dest_v)
        }
        return
    }

    if op == 50 {
        // IR_CALL: call rel32 (will be resolved by fixup system).
        // src1 encoding (set by Call lowering above):
        //   bits 0..7 = arg_count (0 for old-style calls with <=6 args)
        //   bit 8     = libm float ABI flag — when set, args go to
        //               xmm0..xmm7 via IR_ARG with imm=200+i, and the
        //               return is read from xmm0. We also emit
        //               `sub rsp, 8` / `add rsp, 8` around the call to
        //               guarantee 16-byte stack alignment at the call
        //               site (libm leaf functions can use SSE that
        //               assumes 16-aligned stack).
        uint64 raw_s1 = s1_v
        uint64 call_arg_count = raw_s1 & 0xFF
        uint64 use_libm_call = (raw_s1 >> 8) & 1
        uint64 stack_args = 0
        if call_arg_count > 6 {
            stack_args = call_arg_count - 6
            // Resolve all overflow arg values BEFORE modifying rsp
            // Use sub rsp + mov [rsp+N] approach instead of push to avoid
            // spill offset issues (push changes rsp, making subsequent resolves wrong)
            uint64 aligned_stack = stack_args
            if (aligned_stack & 1) != 0 { aligned_stack = aligned_stack + 1 }
            uint64 stack_bytes = aligned_stack * 8
            // First, resolve all overflow args into a temp buffer (physical values)
            uint64[16] ov_vals
            uint64 oi = 0
            while oi < ir_overflow_arg_count {
                uint64 op_ptr = ir_overflow_args + oi * 8
                uint64 arg_vreg = 0
                unsafe { *(op_ptr as uint64) -> arg_vreg }
                uint64 arg_r = ir_resolve_src(arg_vreg, 0)
                ir_emit_mov_r64_r64(0, arg_r)
                // Store rax value to the temp buf position on the current (unmodified) stack
                // Actually we can't use a temp buffer easily. Use a different approach:
                // resolve to rax and push immediately. The key insight: spill offsets are
                // relative to current rsp. After each push, rsp decreases by 8, so subsequent
                // resolves need adjusted offsets. Instead, let's just resolve all to rax and
                // push in one pass, going from LAST to FIRST. But each push changes rsp...

                // Better approach: sub rsp first, then use mov [rsp+N] with adjusted offsets
                oi = oi + 1
            }
            // Simpler approach: sub rsp, then store. Adjust resolve offsets manually.
            // sub rsp, stack_bytes (imm8 form fits up to 127; use imm32 for
            // larger allocations — needed once the call has enough stack
            // args to push stack_bytes past the signed-byte boundary).
            if stack_bytes < 128 {
                emit_byte(0x48); emit_byte(0x83); emit_byte(0xEC)
                uint8 sb8 = stack_bytes
                emit_byte(sb8)
            } else {
                emit_byte(0x48); emit_byte(0x81); emit_byte(0xEC)
                emit_u32_le(stack_bytes)
            }
            // Now rsp has shifted down. Spill slots are now at rsp + stack_bytes + original_offset
            // We need to re-resolve each overflow arg with the shifted rsp
            oi = 0
            while oi < ir_overflow_arg_count {
                uint64 op_ptr = ir_overflow_args + oi * 8
                uint64 arg_vreg = 0
                unsafe { *(op_ptr as uint64) -> arg_vreg }
                // The vreg might be in a register (fine) or spilled.
                // If spilled, the spill is at [old_rsp + spill_off] = [new_rsp + stack_bytes + spill_off]
                // We need to adjust the spill load. Let's just check the physical reg:
                uint64 arg_r = ir_get_phys_reg(arg_vreg)
                if arg_r != 0xFFFFFFFF {
                    // Value is in a register — just mov to [rsp + oi*8]
                    uint64 soff = oi * 8
                    uint8 st_rex = 0x48
                    if arg_r >= 8 { st_rex = st_rex | 4 }
                    emit_byte(st_rex); emit_byte(0x89)
                    if soff == 0 {
                        uint8 stm = ((arg_r & 7) << 3) | 4
                        emit_byte(stm); emit_byte(0x24)
                    } else if soff < 128 {
                        uint8 stm = 0x44 | ((arg_r & 7) << 3)
                        emit_byte(stm); emit_byte(0x24)
                        uint8 so8 = soff
                        emit_byte(so8)
                    } else {
                        uint8 stm = 0x84 | ((arg_r & 7) << 3)
                        emit_byte(stm); emit_byte(0x24)
                        emit_u32_le(soff)
                    }
                } else {
                    // Value is spilled — need to load from adjusted offset
                    // Original spill at [rsp + spill_off], now at [rsp + stack_bytes + spill_off]
                    uint64 spill_off = (arg_vreg - IR_NUM_REGS - 1) * 8
                    uint64 adj_off = stack_bytes + spill_off
                    // mov rax, [rsp + adj_off]
                    emit_byte(0x48); emit_byte(0x8B)
                    if adj_off < 128 {
                        emit_byte(0x44); emit_byte(0x24)
                        uint8 ao8 = adj_off
                        emit_byte(ao8)
                    } else {
                        emit_byte(0x84); emit_byte(0x24)
                        emit_u32_le(adj_off)
                    }
                    // mov [rsp + oi*8], rax
                    uint64 soff = oi * 8
                    emit_byte(0x48); emit_byte(0x89)
                    if soff == 0 {
                        emit_byte(0x04); emit_byte(0x24)
                    } else if soff < 128 {
                        emit_byte(0x44); emit_byte(0x24)
                        uint8 so8 = soff
                        emit_byte(so8)
                    } else {
                        emit_byte(0x84); emit_byte(0x24)
                        emit_u32_le(soff)
                    }
                }
                oi = oi + 1
            }
        }
        // libm float ABI: keep stack 16-byte aligned at the call site.
        // Caller's rsp is 16-aligned at function entry (after `call`)
        // minus our prologue, but the simplest robust pattern is one
        // `sub rsp, 8` here and the matching `add rsp, 8` after the
        // ret. Skip when libm flag is off so non-libm calls stay
        // unchanged.
        if use_libm_call != 0 {
            emit_byte(0x48); emit_byte(0x83); emit_byte(0xEC); emit_byte(0x08)
        }
        emit_byte(0xE8)
        uint64 call_patch = out_len
        emit_u32_le(0)
        // @dynamic extern: route through the PLT call-site table instead
        // of the fixup_table + fn_lookup resolution path. imm here is the
        // callee token (same as IR_CALL's imm arg). M2a.3.c patches the
        // rel32 at call_patch after format_elf_dyn computes the PLT
        // layout; until then the rel32 stays 0.
        uint64 ir_dyn_idx = dyn_sym_lookup(imm)
        if ir_dyn_idx != 0xFFFFFFFF {
            dyn_call_record(call_patch, ir_dyn_idx)
        } else {
            // Record fixup: imm holds the callee token
            uint64 fentry = fixup_table + fixup_count * 8
            uint32 fo = call_patch
            unsafe { *(fentry as uint32) = fo }
            uint64 fe4 = fentry + 4
            uint32 ct = imm
            unsafe { *(fe4 as uint32) = ct }
            fixup_count = fixup_count + 1
        }
        // Clean up overflow args from stack
        if stack_args > 0 {
            uint64 aligned_stack = stack_args
            if (aligned_stack & 1) != 0 { aligned_stack = aligned_stack + 1 }
            uint64 cleanup = aligned_stack * 8
            if cleanup < 128 {
                emit_byte(0x48); emit_byte(0x83); emit_byte(0xC4)
                uint8 cl8 = cleanup
                emit_byte(cl8)
            } else {
                emit_byte(0x48); emit_byte(0x81); emit_byte(0xC4)
                emit_u32_le(cleanup)
            }
        }
        // Reset overflow arg count
        ir_overflow_arg_count = 0
        // libm float ABI: undo the alignment adjustment we did before
        // the call. Must happen before the dst_r read so any spill
        // stores below see the correct rsp again.
        if use_libm_call != 0 {
            emit_byte(0x48); emit_byte(0x83); emit_byte(0xC4); emit_byte(0x08)
        }
        // Result reg:
        //   * Integer ABI (default): rax has the return; copy/spill it.
        //   * libm float ABI: xmm0 has the f32 return; movd into the
        //     destination GPR (low 32 bits, high zeroed). For spill we
        //     stage into rax first via movd, then spill, since the
        //     spill helpers are GPR-only.
        if use_libm_call != 0 {
            if dst_r != 0xFFFFFFFF {
                emit_byte(0x66)
                if dst_r >= 8 { emit_byte(0x41) }
                emit_byte(0x0F); emit_byte(0x7E)
                uint8 lc_modRM = 0xC0 | ((0 & 7) << 3) | (dst_r & 7)
                emit_byte(lc_modRM)
            } else {
                // movd eax, xmm0
                emit_byte(0x66); emit_byte(0x0F); emit_byte(0x7E); emit_byte(0xC0)
                ir_emit_store_spill(0, dest_v)
            }
        } else {
            if dst_r != 0xFFFFFFFF && dst_r != 0 {
                ir_emit_mov_r64_r64(dst_r, 0)
            }
            if dst_r == 0xFFFFFFFF {
                ir_emit_store_spill(0, dest_v)
            }
        }
        return
    }

    if op == 85 {
        // IR_SYSCALL_RAW: src1 = nr vreg, args already in rdi/rsi/rdx/rcx/r8/r9
        // Syscall uses r10 for arg3 (not rcx), so move rcx -> r10
        // mov r10, rcx (49 89 CA)
        emit_byte(0x49); emit_byte(0x89); emit_byte(0xCA)
        // Move nr to rax
        uint64 nr_r = ir_resolve_src(s1_v, 0)
        ir_emit_mov_r64_r64(0, nr_r)
        // syscall
        emit_byte(0x0F); emit_byte(0x05)
        // Result in rax
        if dst_r != 0xFFFFFFFF && dst_r != 0 {
            ir_emit_mov_r64_r64(dst_r, 0)
        }
        if dst_r == 0xFFFFFFFF {
            ir_emit_store_spill(0, dest_v)
        }
        return
    }

    if op == 86 {
        // IR_FN_ADDR: lea rax, [rip + disp32] — disp resolved by fnaddr fixup
        // Emit: 48 8D 05 disp32
        emit_byte(0x48); emit_byte(0x8D); emit_byte(0x05)
        uint64 fnaddr_patch = out_len
        emit_u32_le(0)
        // Record in fnaddr fixup table
        if fnaddr_fixup_count < 1024 {
            uint64 fentry_fa = fnaddr_fixup_table + fnaddr_fixup_count * 8
            uint32 fa_off = fnaddr_patch
            unsafe { *(fentry_fa as uint32) = fa_off }
            uint64 fe4_fa = fentry_fa + 4
            uint32 fa_tok = imm
            unsafe { *(fe4_fa as uint32) = fa_tok }
            fnaddr_fixup_count = fnaddr_fixup_count + 1
        }
        // Result in rax
        if dst_r != 0xFFFFFFFF && dst_r != 0 {
            ir_emit_mov_r64_r64(dst_r, 0)
        }
        if dst_r == 0xFFFFFFFF {
            ir_emit_store_spill(0, dest_v)
        }
        return
    }

    if op == 87 {
        // IR_CALL_IND: call through function pointer in src1
        uint64 ptr_r = ir_resolve_src(s1_v, 0)
        ir_emit_mov_r64_r64(0, ptr_r)
        // call rax: FF D0
        emit_byte(0xFF); emit_byte(0xD0)
        // Result in rax
        if dst_r != 0xFFFFFFFF && dst_r != 0 {
            ir_emit_mov_r64_r64(dst_r, 0)
        }
        if dst_r == 0xFFFFFFFF {
            ir_emit_store_spill(0, dest_v)
        }
        return
    }

    if op == 88 {
        // IR_MEMCMP: compare imm bytes at [src1] vs [src2], result 1 if equal, 0 if not
        uint64 mc_a = ir_resolve_src(s1_v, 0)
        uint64 mc_b = ir_resolve_src(s2_v, 1)
        ir_emit_mov_r64_r64(6, mc_a)    // rsi = ptr_a
        ir_emit_mov_r64_r64(7, mc_b)    // rdi = ptr_b
        // Load byte count
        ir_emit_mov_r64_imm64(1, imm)   // rcx = count in bytes
        // Compare qword-by-qword, then remaining bytes
        // Start with result = 1 (assume equal)
        // xor eax, eax (31 C0)
        emit_byte(0x31); emit_byte(0xC0)
        // mov eax, 1 (B8 01 00 00 00)
        emit_byte(0xB8); emit_byte(0x01); emit_byte(0x00); emit_byte(0x00); emit_byte(0x00)
        // .loop: test rcx, rcx
        uint64 mc_loop = out_len
        emit_byte(0x48); emit_byte(0x85); emit_byte(0xC9)
        // jz .done
        emit_byte(0x74)
        uint64 mc_jz_off = out_len
        emit_byte(0)
        // cmp rcx, 8
        emit_byte(0x48); emit_byte(0x83); emit_byte(0xF9); emit_byte(0x08)
        // jb .byte_cmp
        emit_byte(0x72)
        uint64 mc_jb_off = out_len
        emit_byte(0)
        // qword compare: mov r10, [rsi]
        emit_byte(0x4C); emit_byte(0x8B); emit_byte(0x16)
        // cmp r10, [rdi]
        emit_byte(0x4C); emit_byte(0x3B); emit_byte(0x17)
        // jne .not_equal
        emit_byte(0x75)
        uint64 mc_jne1_off = out_len
        emit_byte(0)
        // add rsi, 8; add rdi, 8; sub rcx, 8
        emit_byte(0x48); emit_byte(0x83); emit_byte(0xC6); emit_byte(0x08)
        emit_byte(0x48); emit_byte(0x83); emit_byte(0xC7); emit_byte(0x08)
        emit_byte(0x48); emit_byte(0x83); emit_byte(0xE9); emit_byte(0x08)
        // jmp .loop
        emit_byte(0xEB)
        uint64 mc_jmp_back = mc_loop - out_len - 1
        uint8 mc_jb8 = mc_jmp_back
        emit_byte(mc_jb8)
        // .byte_cmp:
        uint64 mc_byte = out_len
        uint64 mc_byte_disp = mc_byte - mc_jb_off - 1
        uint8 mc_bd = mc_byte_disp
        uint64 mc_patch_jb = out_buf + mc_jb_off
        unsafe { *(mc_patch_jb as uint8) = mc_bd }
        // movzx r10d, byte [rsi]
        emit_byte(0x44); emit_byte(0x0F); emit_byte(0xB6); emit_byte(0x16)
        // movzx r11d, byte [rdi]  (44 0F B6 1F)
        emit_byte(0x44); emit_byte(0x0F); emit_byte(0xB6); emit_byte(0x1F)
        // cmp r10d, r11d (45 39 DA)
        emit_byte(0x45); emit_byte(0x39); emit_byte(0xDA)
        // jne .not_equal
        emit_byte(0x75)
        uint64 mc_jne2_off = out_len
        emit_byte(0)
        // inc rsi; inc rdi; dec rcx
        emit_byte(0x48); emit_byte(0xFF); emit_byte(0xC6)
        emit_byte(0x48); emit_byte(0xFF); emit_byte(0xC7)
        emit_byte(0x48); emit_byte(0xFF); emit_byte(0xC9)
        // jmp .loop
        emit_byte(0xEB)
        uint64 mc_jmp_back2 = mc_loop - out_len - 1
        uint8 mc_jb82 = mc_jmp_back2
        emit_byte(mc_jb82)
        // .not_equal: xor eax, eax (result = 0)
        uint64 mc_ne = out_len
        // Patch jne1 and jne2
        uint64 mc_ne1_disp = mc_ne - mc_jne1_off - 1
        uint8 mc_ned1 = mc_ne1_disp
        uint64 mc_p1 = out_buf + mc_jne1_off
        unsafe { *(mc_p1 as uint8) = mc_ned1 }
        uint64 mc_ne2_disp = mc_ne - mc_jne2_off - 1
        uint8 mc_ned2 = mc_ne2_disp
        uint64 mc_p2 = out_buf + mc_jne2_off
        unsafe { *(mc_p2 as uint8) = mc_ned2 }
        emit_byte(0x31); emit_byte(0xC0)
        // jmp .done (skip the equal path)
        emit_byte(0xEB); emit_byte(0x00)
        // .done:
        uint64 mc_done = out_len
        // Patch jz to .done
        uint64 mc_done_disp = mc_done - mc_jz_off - 1
        uint8 mc_dd = mc_done_disp
        uint64 mc_p3 = out_buf + mc_jz_off
        unsafe { *(mc_p3 as uint8) = mc_dd }
        if dst_r != 0xFFFFFFFF {
            ir_emit_mov_r64_r64(dst_r, 0)
        } else {
            ir_emit_store_spill(0, dest_v)
        }
        return
    }

    if op == 96 {
        // IR_ASM_BLOCK: emit inline assembly from AST node
        // src1 = AST node index
        uint64 asm_node = s1_v
        uint32 single_tok = ast_data1(asm_node)
        uint64 ws = single_tok
        if ws != 0 {
            asm_emit_x86(ws)
        }
        uint32 child_str = ast_child(asm_node)
        uint64 wcs = child_str
        while wcs != 0 {
            uint32 stk = ast_data1(wcs)
            uint64 wstk = stk
            asm_emit_x86(wstk)
            uint32 nxt = ast_next(wcs)
            wcs = nxt
        }
        return
    }

    if op == 90 {
        // IR_ATOMIC_STORE: lock xchg [ptr], val
        uint64 ptr_r = ir_resolve_src(s1_v, 0)
        uint64 val_r = ir_resolve_src(s2_v, 1)
        // lock xchg [ptr_r], val_r: F0 REX.W 87 modrm
        emit_byte(0xF0)
        uint8 as_rex = 0x48
        if val_r >= 8 { as_rex = as_rex | 4 }
        if ptr_r >= 8 { as_rex = as_rex | 1 }
        emit_byte(as_rex)
        emit_byte(0x87)
        uint8 as_modrm = ((val_r & 7) << 3) | (ptr_r & 7)
        if (ptr_r & 7) == 4 {
            emit_byte(as_modrm); emit_byte(0x24)
        } else if (ptr_r & 7) == 5 {
            uint8 asm5 = as_modrm | 0x40
            emit_byte(asm5); emit_byte(0)
        } else {
            emit_byte(as_modrm)
        }
        return
    }

    if op == 91 {
        // IR_ATOMIC_LOAD: mov dest, [ptr] + mfence
        uint64 ptr_r = ir_resolve_src(s1_v, 0)
        uint64 dr = dst_r
        if dr == 0xFFFFFFFF { dr = 0 }
        // mov dr, [ptr_r]
        uint8 al_rex = 0x48
        if dr >= 8 { al_rex = al_rex | 4 }
        if ptr_r >= 8 { al_rex = al_rex | 1 }
        emit_byte(al_rex)
        emit_byte(0x8B)
        uint8 al_modrm = ((dr & 7) << 3) | (ptr_r & 7)
        if (ptr_r & 7) == 4 {
            emit_byte(al_modrm); emit_byte(0x24)
        } else if (ptr_r & 7) == 5 {
            uint8 alm5 = al_modrm | 0x40
            emit_byte(alm5); emit_byte(0)
        } else {
            emit_byte(al_modrm)
        }
        // mfence: 0F AE F0
        emit_byte(0x0F); emit_byte(0xAE); emit_byte(0xF0)
        if dst_r == 0xFFFFFFFF {
            ir_emit_store_spill(0, dest_v)
        }
        return
    }

    if op == 92 {
        // IR_ATOMIC_ADD: lock xadd [ptr], val → old value in val_r
        uint64 ptr_r = ir_resolve_src(s1_v, 0)
        uint64 val_r = ir_resolve_src(s2_v, 1)
        // lock xadd [ptr_r], val_r: F0 REX.W 0F C1 modrm
        emit_byte(0xF0)
        uint8 aa_rex = 0x48
        if val_r >= 8 { aa_rex = aa_rex | 4 }
        if ptr_r >= 8 { aa_rex = aa_rex | 1 }
        emit_byte(aa_rex)
        emit_byte(0x0F); emit_byte(0xC1)
        uint8 aa_modrm = ((val_r & 7) << 3) | (ptr_r & 7)
        if (ptr_r & 7) == 4 {
            emit_byte(aa_modrm); emit_byte(0x24)
        } else if (ptr_r & 7) == 5 {
            uint8 aam5 = aa_modrm | 0x40
            emit_byte(aam5); emit_byte(0)
