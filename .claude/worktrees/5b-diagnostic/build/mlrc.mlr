            uint8 ld_rex = 0x48
            if dr >= 8 { ld_rex = ld_rex | 4 }
            if addr_reg >= 8 { ld_rex = ld_rex | 1 }
            emit_byte(ld_rex)
            emit_byte(0x8B)
