            emit_byte(0x48); emit_byte(0x8D); emit_byte(0x44); emit_byte(0x24); emit_byte(0x50)
            emit_byte(0x48); emit_byte(0x89); emit_byte(0x44); emit_byte(0x24); emit_byte(0x40)
            emit_byte(0x48); emit_byte(0x8D); emit_byte(0x84); emit_byte(0x24); emit_u32_le(0xB8)
            emit_byte(0x48); emit_byte(0x89); emit_byte(0x44); emit_byte(0x24); emit_byte(0x48)
            emit_win_call_iat(9)
            emit_byte(0x48); emit_byte(0x8B); emit_byte(0x8C); emit_byte(0x24); emit_u32_le(0xB8)
            emit_byte(0xBA); emit_u32_le(0xFFFFFFFF)
            emit_win_call_iat(10)
            emit_byte(0x48); emit_byte(0x8B); emit_byte(0x8C); emit_byte(0x24); emit_u32_le(0xB8)
            emit_byte(0x48); emit_byte(0x8D); emit_byte(0x54); emit_byte(0x24); emit_byte(0x20)
            emit_win_call_iat(11)
            emit_byte(0x8B); emit_byte(0x4C); emit_byte(0x24); emit_byte(0x20)
            emit_byte(0x48); emit_byte(0x81); emit_byte(0xC4); emit_u32_le(0x4D0)
            emit_win_alloc_stack(0x20)
            emit_win_call_iat(0)
            return
        }
        // Linux/macOS: execve
        // rdi = path
        ir_emit_mov_r64_r64(7, path_r)
        // rsi = argv
        ir_emit_mov_r64_r64(6, argv_r)
        // envp: try to load cli_envp static, else NULL
        uint64 envp_off_a = static_lookup_by_name("cli_envp", 8)
        if envp_off_a != 0xFFFFFFFF {
            emit_static_load(envp_off_a)
            // mov rdx, rax: 48 89 C2
            emit_byte(0x48); emit_byte(0x89); emit_byte(0xC2)
        } else {
            // xor rdx, rdx: 48 31 D2
            emit_byte(0x48); emit_byte(0x31); emit_byte(0xD2)
        }
        // mov rax, 59 (execve) — OS-aware
        uint64 execve_nr_a = ir_x86_syscall_nr(59)
        ir_emit_mov_r64_imm64(0, execve_nr_a)
        // syscall: 0F 05
        emit_byte(0x0F); emit_byte(0x05)
        // Save errno to exec_errno if defined
        uint64 errno_off_a = static_lookup_by_name("exec_errno", 10)
        if errno_off_a != 0xFFFFFFFF {
            emit_static_store(errno_off_a)
        }
        if dst_r != 0xFFFFFFFF && dst_r != 0 {
            ir_emit_mov_r64_r64(dst_r, 0)
        }
        if dst_r == 0xFFFFFFFF {
            ir_emit_store_spill(0, dest_v)
        }
        return
    }

    if op == 115 {
        // IR_SET_EXEC: chmod(path, 0755) via syscall 90
        uint64 path_r = ir_resolve_src(s1_v, 0)
        // rdi = path
        ir_emit_mov_r64_r64(7, path_r)
        // rsi = 0x1ED (0755 octal)
        ir_emit_mov_r64_imm64(6, 0x1ED)
        // rax = 90 (chmod) — OS-aware
        uint64 chmod_nr = ir_x86_syscall_nr(90)
        ir_emit_mov_r64_imm64(0, chmod_nr)
        // syscall: 0F 05
        emit_byte(0x0F); emit_byte(0x05)
        return
    }

    if op == 118 {
        // IR_FSQRT32: movd xmm0, eax; sqrtss xmm0, xmm0; movd eax, xmm0
        uint64 a_reg = ir_resolve_src(s1_v, 0)
        ir_emit_mov_r64_r64(0, a_reg)
        // movd xmm0, eax: 66 0F 6E C0
        emit_byte(0x66); emit_byte(0x0F); emit_byte(0x6E); emit_byte(0xC0)
        // sqrtss xmm0, xmm0: F3 0F 51 C0
        emit_byte(0xF3); emit_byte(0x0F); emit_byte(0x51); emit_byte(0xC0)
        // movd eax, xmm0: 66 0F 7E C0
        emit_byte(0x66); emit_byte(0x0F); emit_byte(0x7E); emit_byte(0xC0)
        if dst_r != 0xFFFFFFFF {
            ir_emit_mov_r64_r64(dst_r, 0)
        } else {
            ir_emit_store_spill(0, dest_v)
        }
        return
    }

    if op == 119 {
        // IR_TIME_NS: monotonic nanosecond counter.
        //   Linux/Android x86_64: clock_gettime(CLOCK_MONOTONIC, &ts) syscall 228
        //   macOS         x86_64: clock_gettime → syscall 0x20000E4 (same layout)
        //   Windows       x86_64: QueryPerformanceCounter + QueryPerformanceFrequency
        //                         via IAT, combined as counter*1e9/freq using a
        //                         64-bit-overflow-safe split-and-recombine.
        // On Windows, the raw `syscall` instruction must never execute — issuing
        // a Linux-style syscall number on Windows used to silently land in the
        // NT dispatcher and return arbitrary stack garbage, which happened to be
        // zero often enough that the bug went unnoticed for a while.
        if target_os == 2 {
            // sub rsp, 0x30  (shadow 0x20 + freq@0x20 + counter@0x28)
            emit_byte(0x48); emit_byte(0x83); emit_byte(0xEC); emit_byte(0x30)
            // lea rcx, [rsp+0x20]
            emit_byte(0x48); emit_byte(0x8D); emit_byte(0x4C); emit_byte(0x24); emit_byte(0x20)
            emit_win_call_iat(15)                                               // QueryPerformanceFrequency
            // lea rcx, [rsp+0x28]
            emit_byte(0x48); emit_byte(0x8D); emit_byte(0x4C); emit_byte(0x24); emit_byte(0x28)
            emit_win_call_iat(14)                                               // QueryPerformanceCounter
            // mov rax, [rsp+0x28]   ; counter
            emit_byte(0x48); emit_byte(0x8B); emit_byte(0x44); emit_byte(0x24); emit_byte(0x28)
            // mov r11, [rsp+0x20]   ; freq
            emit_byte(0x4C); emit_byte(0x8B); emit_byte(0x5C); emit_byte(0x24); emit_byte(0x20)
            // xor edx, edx
            emit_byte(0x31); emit_byte(0xD2)
            // div r11               ; rax = counter/freq, rdx = counter%freq
            emit_byte(0x49); emit_byte(0xF7); emit_byte(0xF3)
            // mov r10, rax          ; r10 = seconds
            emit_byte(0x49); emit_byte(0x89); emit_byte(0xC2)
            // mov rax, rdx          ; rax = fractional ticks
            emit_byte(0x48); emit_byte(0x89); emit_byte(0xD0)
            // mov r9, 1000000000
            emit_byte(0x49); emit_byte(0xC7); emit_byte(0xC1); emit_u32_le(1000000000)
            // mul r9                ; rdx:rax = fractional * 1e9
            emit_byte(0x49); emit_byte(0xF7); emit_byte(0xE1)
            // div r11               ; rax = fractional * 1e9 / freq
            emit_byte(0x49); emit_byte(0xF7); emit_byte(0xF3)
            // imul r10, r9          ; r10 = seconds * 1e9
            emit_byte(0x4D); emit_byte(0x0F); emit_byte(0xAF); emit_byte(0xD1)
            // add rax, r10
            emit_byte(0x4C); emit_byte(0x01); emit_byte(0xD0)
            // add rsp, 0x30
            emit_byte(0x48); emit_byte(0x83); emit_byte(0xC4); emit_byte(0x30)
        } else if target_os == 1 {
            // macOS x86_64: gettimeofday(rdi=&tv, rsi=NULL) via syscall
            // 0x2000074. Darwin's clock_gettime isn't 228 the way Linux's
            // is — syscall 228 on macOS dispatches to some unrelated BSD
            // entry point that silently returns 0 in rax, which is what
            // made time_ns() come back zero on every arm64 and x86_64
            // macOS build until today.
            emit_byte(0x48); emit_byte(0x83); emit_byte(0xEC); emit_byte(16)       // sub rsp, 16
            emit_byte(0x48); emit_byte(0x89); emit_byte(0xE7)                      // mov rdi, rsp
            emit_byte(0x31); emit_byte(0xF6)                                       // xor esi, esi
            ir_emit_mov_r64_imm64(0, 0x2000074)                                    // mov rax, gettimeofday
            emit_byte(0x0F); emit_byte(0x05)                                       // syscall
            emit_byte(0x48); emit_byte(0x8B); emit_byte(0x04); emit_byte(0x24)     // mov rax, [rsp]
            emit_byte(0x48); emit_byte(0x69); emit_byte(0xC0)                      // imul rax, rax, 1e9
            emit_u32_le(1000000000)
            // macOS x86_64 tv_usec is i32 — load 32-bit and zero-extend
            emit_byte(0x8B); emit_byte(0x4C); emit_byte(0x24); emit_byte(8)        // mov ecx, [rsp+8]
            emit_byte(0x48); emit_byte(0x69); emit_byte(0xC9)                      // imul rcx, rcx, 1000
            emit_u32_le(1000)
            emit_byte(0x48); emit_byte(0x01); emit_byte(0xC8)                      // add rax, rcx
            emit_byte(0x48); emit_byte(0x83); emit_byte(0xC4); emit_byte(16)       // add rsp, 16
        } else {
            // Linux / Android x86_64: clock_gettime(CLOCK_MONOTONIC, &ts)
            emit_byte(0x48); emit_byte(0x83); emit_byte(0xEC); emit_byte(16)
            emit_byte(0xBF); emit_byte(1); emit_byte(0); emit_byte(0); emit_byte(0)
            emit_byte(0x48); emit_byte(0x89); emit_byte(0xE6)
            uint64 cgt_nr = ir_x86_syscall_nr(228)
            ir_emit_mov_r64_imm64(0, cgt_nr)
            emit_byte(0x0F); emit_byte(0x05)
            emit_byte(0x48); emit_byte(0x8B); emit_byte(0x04); emit_byte(0x24)
            emit_byte(0x48); emit_byte(0x69); emit_byte(0xC0)
            emit_u32_le(1000000000)
            emit_byte(0x48); emit_byte(0x8B); emit_byte(0x4C); emit_byte(0x24); emit_byte(8)
            emit_byte(0x48); emit_byte(0x01); emit_byte(0xC8)
            emit_byte(0x48); emit_byte(0x83); emit_byte(0xC4); emit_byte(16)
        }
        if dst_r != 0xFFFFFFFF && dst_r != 0 {
            ir_emit_mov_r64_r64(dst_r, 0)
        }
        if dst_r == 0xFFFFFFFF {
            ir_emit_store_spill(0, dest_v)
        }
        return
    }

    if op == 126 {
        // IR_ISB: instruction-sync barrier. On x86_64, D-cache and
        // I-cache are kept coherent by the hardware, so this is a
        // no-op. (The builtin exists so portable code can compile on
        // both archs; on ARM64 it emits a real ISB instruction.)
        return
