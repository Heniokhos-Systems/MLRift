        }

        // file_size(fd) — lseek(fd, 0, SEEK_END) then lseek(fd, 0, SEEK_SET)
        if tok_matches(wct, "file_size", 9) != 0 {
            uint32 arg1 = ast_child(node)
            uint64 fd_v = ir_lower_expr(arg1)
            uint64 zero_v = ir_new_vreg()
            ir_emit(IR_CONST, zero_v, 0, 0, 0, ir_current_bb)
            uint64 two_v = ir_new_vreg()
            ir_emit(IR_CONST, two_v, 0, 0, 2, ir_current_bb)
            // lseek(fd, 0, SEEK_END=2) -> size
            ir_emit(IR_ARG, 0, fd_v, 0, 0, ir_current_bb)
            ir_emit(IR_ARG, 0, zero_v, 0, 1, ir_current_bb)
            ir_emit(IR_ARG, 0, two_v, 0, 2, ir_current_bb)
            uint64 size_v = ir_new_vreg()
            ir_emit(IR_SYSCALL, size_v, 0, 0, 8, ir_current_bb)
            // lseek(fd, 0, SEEK_SET=0) -> rewind
            ir_emit(IR_ARG, 0, fd_v, 0, 0, ir_current_bb)
            ir_emit(IR_ARG, 0, zero_v, 0, 1, ir_current_bb)
            ir_emit(IR_ARG, 0, zero_v, 0, 2, ir_current_bb)
            uint64 dummy = ir_new_vreg()
            ir_emit(IR_SYSCALL, dummy, 0, 0, 8, ir_current_bb)
            return size_v
        }

        // print(arg, ...) / println(arg, ...) — variadic, space-separated args
        if tok_matches(wct, "println", 7) != 0 || tok_matches(wct, "print", 5) != 0 {
            uint64 is_println = tok_matches(wct, "println", 7)
            uint64 buf_v = ir_new_vreg()
            ir_emit(IR_ALLOC, buf_v, 0, 0, 4096, ir_current_bb)
            uint64 off_v = ir_new_vreg()
            ir_emit(IR_CONST, off_v, 0, 0, 0, ir_current_bb)

            uint32 warg = ast_child(node)
            uint64 first = 1
            while warg != 0 {
                if first == 0 {
                    // Write space separator between arguments
                    uint64 space_v = ir_new_vreg()
                    ir_emit(IR_CONST, space_v, 0, 0, 32, ir_current_bb)
                    uint64 sp_addr = ir_new_vreg()
                    ir_emit(IR_ADD, sp_addr, buf_v, off_v, 0, ir_current_bb)
                    ir_emit(IR_STORE, 1, sp_addr, space_v, 0, ir_current_bb)
                    uint64 one_sp = ir_new_vreg()
                    ir_emit(IR_CONST, one_sp, 0, 0, 1, ir_current_bb)
                    uint64 off_sp = ir_new_vreg()
                    ir_emit(IR_ADD, off_sp, off_v, one_sp, 0, ir_current_bb)
                    off_v = off_sp
                }
                first = 0

                uint64 slot_v = ir_new_vreg()
                ir_emit(IR_ADD, slot_v, buf_v, off_v, 0, ir_current_bb)

                uint32 arg_kind = ast_kind(warg)
                uint64 len_v = ir_new_vreg()
                if arg_kind == 31 || arg_kind == 50 {
                    // String literal or FString: lower to pointer, then STRLEN + MEMCPY
                    uint64 s_v = ir_lower_expr(warg)
                    ir_emit(IR_STRLEN, len_v, s_v, 0, 0, ir_current_bb)
                    uint64 mc_dummy = ir_new_vreg()
                    ir_emit(IR_MEMCPY, mc_dummy, slot_v, s_v, len_v, ir_current_bb)
                } else {
                    // Typed value: dispatch on float-kind
                    uint64 val_v = ir_lower_expr(warg)
                    uint64 fk = ir_vreg_fkind_get(val_v)
                    if fk == 1 {
                        // f64
                        ir_emit(IR_FMT_F64, len_v, slot_v, val_v, 0, ir_current_bb)
                    } else if fk == 2 {
                        // f32 -> promote to f64 first
                        uint64 f64v = ir_new_vreg()
                        ir_emit(IR_F32TOF64, f64v, val_v, 0, 0, ir_current_bb)
                        ir_vreg_fkind_set(f64v, 1)
                        ir_emit(IR_FMT_F64, len_v, slot_v, f64v, 0, ir_current_bb)
                    } else if fk == 3 {
                        // bool
                        ir_emit(IR_FMT_BOOL, len_v, slot_v, val_v, 0, ir_current_bb)
                    } else if fk == 4 {
                        // char -> single byte
                        ir_emit(IR_STORE, 1, slot_v, val_v, 0, ir_current_bb)
                        ir_emit(IR_CONST, len_v, 0, 0, 1, ir_current_bb)
                    } else {
                        // integer
                        ir_emit(IR_FMT_UINT, len_v, slot_v, val_v, 0, ir_current_bb)
                    }
                }

                uint64 off_next = ir_new_vreg()
                ir_emit(IR_ADD, off_next, off_v, len_v, 0, ir_current_bb)
                off_v = off_next

                uint32 nxt = ast_next(warg)
                warg = nxt
            }

            if is_println != 0 {
                // Append newline
                uint64 nl_v = ir_new_vreg()
                ir_emit(IR_CONST, nl_v, 0, 0, 10, ir_current_bb)
                uint64 nl_addr = ir_new_vreg()
                ir_emit(IR_ADD, nl_addr, buf_v, off_v, 0, ir_current_bb)
                ir_emit(IR_STORE, 1, nl_addr, nl_v, 0, ir_current_bb)
                uint64 one_nl = ir_new_vreg()
                ir_emit(IR_CONST, one_nl, 0, 0, 1, ir_current_bb)
                uint64 off_nl = ir_new_vreg()
                ir_emit(IR_ADD, off_nl, off_v, one_nl, 0, ir_current_bb)
                off_v = off_nl
            }

            uint64 fd_v = ir_new_vreg()
            ir_emit(IR_CONST, fd_v, 0, 0, 1, ir_current_bb)
            ir_emit(IR_ARG, 0, fd_v, 0, 0, ir_current_bb)
            ir_emit(IR_ARG, 0, buf_v, 0, 1, ir_current_bb)
            ir_emit(IR_ARG, 0, off_v, 0, 2, ir_current_bb)
            uint64 wr = ir_new_vreg()
            ir_emit(IR_SYSCALL, wr, 0, 0, 1, ir_current_bb)
            ir_emit(IR_DEALLOC, 0, buf_v, 0, 0, ir_current_bb)
            uint64 zero = ir_new_vreg()
            ir_emit(IR_CONST, zero, 0, 0, 0, ir_current_bb)
            return zero
        }

        if tok_matches(wct, "str_eq", 6) != 0 {
            uint32 arg1 = ast_child(node)
            uint64 a_v = ir_lower_expr(arg1)
            uint32 arg2 = ast_next(arg1)
            uint64 b_v = ir_lower_expr(arg2)
            uint64 dest = ir_new_vreg()
            ir_emit(IR_STR_EQ, dest, a_v, b_v, 0, ir_current_bb)
            return dest
        }

        // syscall_raw(nr, a0, a1, a2, a3, a4, a5) → raw Linux syscall
        if tok_matches(wct, "syscall_raw", 11) != 0 {
            // Evaluate all 7 args
            uint64[7] sc_vregs
            uint32 sc_arg = ast_child(node)
            uint64 sc_warg = sc_arg
            uint64 sc_i = 0
            while sc_warg != 0 && sc_i < 7 {
                uint64 sv = ir_lower_expr(sc_warg)
                uint64 svp = sc_vregs + sc_i * 8
                unsafe { *(svp as uint64) = sv }
                sc_i = sc_i + 1
                uint32 sc_nxt = ast_next(sc_warg)
                sc_warg = sc_nxt
            }
            // Emit IR_ARG for data args (positions 0-5 = a0-a5)
            uint64 sci = 0
            while sci < 6 && sci + 1 < sc_i {
                uint64 svp = sc_vregs + (sci + 1) * 8
                uint64 sv = 0
                unsafe { *(svp as uint64) -> sv }
                ir_emit(IR_ARG, 0, sv, 0, sci, ir_current_bb)
                sci = sci + 1
            }
            // First arg is syscall number
            uint64 nr_vp = sc_vregs
            uint64 nr_v = 0
            unsafe { *(nr_vp as uint64) -> nr_v }
            uint64 dest = ir_new_vreg()
            ir_emit(IR_SYSCALL_RAW, dest, nr_v, 0, 0, ir_current_bb)
            return dest
        }

        // bit_get(val, pos) → (val >> pos) & 1
        if tok_matches(wct, "bit_get", 7) != 0 {
            uint32 arg1 = ast_child(node)
            uint64 val_v = ir_lower_expr(arg1)
            uint32 arg2 = ast_next(arg1)
            uint64 pos_v = ir_lower_expr(arg2)
            uint64 shifted = ir_new_vreg()
            ir_emit(IR_SHR, shifted, val_v, pos_v, 0, ir_current_bb)
            uint64 one_v = ir_new_vreg()
            ir_emit(IR_CONST, one_v, 0, 0, 1, ir_current_bb)
            uint64 dest = ir_new_vreg()
            ir_emit(IR_AND, dest, shifted, one_v, 0, ir_current_bb)
            return dest
        }

        // bit_set(val, pos) → val | (1 << pos)
        if tok_matches(wct, "bit_set", 7) != 0 {
            uint32 arg1 = ast_child(node)
            uint64 val_v = ir_lower_expr(arg1)
            uint32 arg2 = ast_next(arg1)
            uint64 pos_v = ir_lower_expr(arg2)
            uint64 one_v = ir_new_vreg()
            ir_emit(IR_CONST, one_v, 0, 0, 1, ir_current_bb)
            uint64 mask_v = ir_new_vreg()
            ir_emit(IR_SHL, mask_v, one_v, pos_v, 0, ir_current_bb)
            uint64 dest = ir_new_vreg()
            ir_emit(IR_OR, dest, val_v, mask_v, 0, ir_current_bb)
            return dest
        }

        // bit_clear(val, pos) → val & ~(1 << pos)
        if tok_matches(wct, "bit_clear", 9) != 0 {
            uint32 arg1 = ast_child(node)
            uint64 val_v = ir_lower_expr(arg1)
            uint32 arg2 = ast_next(arg1)
            uint64 pos_v = ir_lower_expr(arg2)
            uint64 one_v = ir_new_vreg()
            ir_emit(IR_CONST, one_v, 0, 0, 1, ir_current_bb)
            uint64 mask_v = ir_new_vreg()
            ir_emit(IR_SHL, mask_v, one_v, pos_v, 0, ir_current_bb)
            uint64 nmask_v = ir_new_vreg()
            ir_emit(IR_NOT, nmask_v, mask_v, 0, 0, ir_current_bb)
            uint64 dest = ir_new_vreg()
            ir_emit(IR_AND, dest, val_v, nmask_v, 0, ir_current_bb)
            return dest
        }

        // bit_toggle(val, pos) → val ^ (1 << pos)
        if tok_matches(wct, "bit_toggle", 10) != 0 {
            uint32 arg1 = ast_child(node)
            uint64 val_v = ir_lower_expr(arg1)
            uint32 arg2 = ast_next(arg1)
            uint64 pos_v = ir_lower_expr(arg2)
            uint64 one_v = ir_new_vreg()
            ir_emit(IR_CONST, one_v, 0, 0, 1, ir_current_bb)
            uint64 mask_v = ir_new_vreg()
            ir_emit(IR_SHL, mask_v, one_v, pos_v, 0, ir_current_bb)
            uint64 dest = ir_new_vreg()
            ir_emit(IR_XOR, dest, val_v, mask_v, 0, ir_current_bb)
            return dest
        }

        // fn_addr("name") → address of named function
        if tok_matches(wct, "fn_addr", 7) != 0 {
            uint32 name_arg = ast_child(node)
            uint64 wna = name_arg
            uint32 str_tok = ast_data1(wna)
            uint64 dest = ir_new_vreg()
            ir_emit(IR_FN_ADDR, dest, 0, 0, str_tok, ir_current_bb)
            return dest
        }

        // call_ptr(fn_ptr, args...) → indirect call through function pointer
        if tok_matches(wct, "call_ptr", 8) != 0 {
            uint32 first_arg = ast_child(node)
            uint64 wfa = first_arg
            // First arg is the function pointer
            uint64 ptr_v = ir_lower_expr(wfa)
            // Remaining args are the actual call arguments
            uint64[6] cp_arg_vregs
            uint32 call_arg = ast_next(wfa)
            uint64 wca = call_arg
            uint64 cp_count = 0
            while wca != 0 && cp_count < 6 {
                uint64 av = ir_lower_expr(wca)
                uint64 avp = cp_arg_vregs + cp_count * 8
                unsafe { *(avp as uint64) = av }
                cp_count = cp_count + 1
                uint32 anxt = ast_next(wca)
                wca = anxt
            }
            // Emit ARGs for call arguments
            uint64 cpi = 0
            while cpi < cp_count {
                uint64 avp = cp_arg_vregs + cpi * 8
                uint64 av = 0
                unsafe { *(avp as uint64) -> av }
                ir_emit(IR_ARG, 0, av, 0, cpi, ir_current_bb)
                cpi = cpi + 1
            }
            uint64 dest = ir_new_vreg()
            ir_emit(IR_CALL_IND, dest, ptr_v, 0, 0, ir_current_bb)
            return dest
        }

        // ---------------------------------------------------------------
        // Float builtins
        // ---------------------------------------------------------------

        // int_to_f64(x): convert integer to f64, return f64 bit pattern
        if tok_matches(wct, "int_to_f64", 10) != 0 {
            uint32 first_arg = ast_child(node)
            uint64 src_v = ir_lower_expr(first_arg)
            uint64 dest = ir_new_vreg()
            ir_emit(IR_ITOF, dest, src_v, 0, 0, ir_current_bb)
            ir_vreg_fkind_set(dest, 1)
            return dest
        }

        // f64_to_int(x): convert f64 bit pattern to integer.
        // Codegen uses cvttsd2si which is a *signed* truncation, so the
        // result vreg is signed for downstream comparison purposes.
        if tok_matches(wct, "f64_to_int", 10) != 0 {
            uint32 first_arg = ast_child(node)
            uint64 src_v = ir_lower_expr(first_arg)
            uint64 dest = ir_new_vreg()
            ir_emit(IR_FTOI, dest, src_v, 0, 0, ir_current_bb)
            ir_vreg_fkind_set(dest, 0)
            ir_vreg_signed_set(dest, 1)
            return dest
        }

        // int_to_f32(x): convert integer to f32, return f32 bit pattern
        if tok_matches(wct, "int_to_f32", 10) != 0 {
            uint32 first_arg = ast_child(node)
            uint64 src_v = ir_lower_expr(first_arg)
            uint64 dest = ir_new_vreg()
            ir_emit(IR_ITOF32, dest, src_v, 0, 0, ir_current_bb)
            ir_vreg_fkind_set(dest, 2)
            return dest
        }

        // f32_to_int(x): convert f32 bit pattern to integer
        if tok_matches(wct, "f32_to_int", 10) != 0 {
            uint32 first_arg = ast_child(node)
            uint64 src_v = ir_lower_expr(first_arg)
            uint64 dest = ir_new_vreg()
            ir_emit(IR_FTOI32, dest, src_v, 0, 0, ir_current_bb)
            ir_vreg_fkind_set(dest, 0)
            return dest
        }

        // sqrt(x) / sqrt_f64(x): f64 square root
        if tok_matches(wct, "sqrt_f64", 8) != 0 || tok_matches(wct, "sqrt", 4) != 0 {
            uint32 first_arg = ast_child(node)
            uint64 src_v = ir_lower_expr(first_arg)
            uint64 dest = ir_new_vreg()
            ir_emit(IR_FSQRT, dest, src_v, 0, 0, ir_current_bb)
            ir_vreg_fkind_set(dest, 1)
            return dest
        }

        // fma_f64(a, b, c): a*b + c in f64
        if tok_matches(wct, "fma_f64", 7) != 0 {
            uint32 arg_a = ast_child(node)
            uint64 wa_a = arg_a
            uint32 arg_b = ast_next(wa_a)
            uint64 wa_b = arg_b
            uint32 arg_c = ast_next(wa_b)
            uint64 wa_c = arg_c
            uint64 a_v = ir_lower_expr(wa_a)
            uint64 b_v = ir_lower_expr(wa_b)
            uint64 c_v = ir_lower_expr(wa_c)
            uint64 dest = ir_new_vreg()
            ir_emit(IR_FFMA, dest, a_v, b_v, c_v, ir_current_bb)
            ir_vreg_fkind_set(dest, 1)
            return dest
        }

        // f32_to_f64(x): widen f32 to f64
        if tok_matches(wct, "f32_to_f64", 10) != 0 {
            uint32 first_arg = ast_child(node)
            uint64 src_v = ir_lower_expr(first_arg)
            uint64 dest = ir_new_vreg()
            ir_emit(IR_F32TOF64, dest, src_v, 0, 0, ir_current_bb)
            ir_vreg_fkind_set(dest, 1)
            return dest
        }

        // f64_to_f32(x): narrow f64 to f32
        if tok_matches(wct, "f64_to_f32", 10) != 0 {
            uint32 first_arg = ast_child(node)
            uint64 src_v = ir_lower_expr(first_arg)
            uint64 dest = ir_new_vreg()
            ir_emit(IR_F64TOF32, dest, src_v, 0, 0, ir_current_bb)
            ir_vreg_fkind_set(dest, 2)
            return dest
        }

        // f32_to_f16(x): convert f32 bits to f16 bits (integer result)
        if tok_matches(wct, "f32_to_f16", 10) != 0 {
            uint32 first_arg = ast_child(node)
            uint64 src_v = ir_lower_expr(first_arg)
            uint64 dest = ir_new_vreg()
            ir_emit(IR_F32TOF16, dest, src_v, 0, 0, ir_current_bb)
            ir_vreg_fkind_set(dest, 0)
            return dest
        }

        // f16_to_f32(x): convert f16 bits to f32 bits
        if tok_matches(wct, "f16_to_f32", 10) != 0 {
            uint32 first_arg = ast_child(node)
            uint64 src_v = ir_lower_expr(first_arg)
            uint64 dest = ir_new_vreg()
            ir_emit(IR_F16TOF32, dest, src_v, 0, 0, ir_current_bb)
            ir_vreg_fkind_set(dest, 2)
            return dest
        }

        // get_target_os() → compile-time OS constant
        if tok_matches(wct, "get_target_os", 13) != 0 {
            uint64 dest = ir_new_vreg()
            ir_emit(IR_CONST, dest, 0, 0, target_os, ir_current_bb)
            return dest
        }

        // get_arch_id() → compile-time arch ID.
        // Matches the legacy codegen IDs. Arch+OS crosstable:
        //   x86_64:  linux=1, windows=3, macos=5, android=8
        //   arm64:   linux=2, windows=4, macos=6, android=7
        // target_arch is 0 for x86_64, 1 for arm64 (set from main.kr).
        if tok_matches(wct, "get_arch_id", 11) != 0 {
            uint64 arch_id = 1
            if target_arch == 1 {
                arch_id = 2
                if target_os == 2 { arch_id = 4 }
                if target_os == 1 { arch_id = 6 }
                if target_os == 3 { arch_id = 7 }
            } else {
                if target_os == 2 { arch_id = 3 }
                if target_os == 1 { arch_id = 5 }
                if target_os == 3 { arch_id = 8 }
            }
            uint64 dest = ir_new_vreg()
            ir_emit(IR_CONST, dest, 0, 0, arch_id, ir_current_bb)
            return dest
        }

        // General call: evaluate all arg exprs first, then emit ARGs + CALL
        // This prevents nested calls from clobbering arg registers.
        // Capacity is 32 args (6 register + up to 26 stack); pushing higher
        // also requires bumping ir_overflow_args / IR_ARG's oi guard below.
        uint64[32] call_arg_vregs
        uint32 arg = ast_child(node)
        uint64 warg = arg
        uint64 arg_count = 0
        while warg != 0 && arg_count < 32 {
            uint64 av = ir_lower_expr(warg)
            // Check if this is a struct variable — copy to avoid aliasing
            uint32 ak = ast_kind(warg)
            if ak == 32 {
                uint32 atk = ast_data1(warg)
                uint64 s_si = struct_var_lookup(atk)
                if s_si != 0xFFFFFFFF {
                    uint64 ssize = struct_total_size(s_si)
                    uint64 copy_v = ir_new_vreg()
                    ir_emit(IR_ALLOC, copy_v, 0, 0, ssize, ir_current_bb)
                    uint64 sz_v = ir_new_vreg()
                    ir_emit(IR_CONST, sz_v, 0, 0, ssize, ir_current_bb)
                    ir_emit(IR_MEMCPY, 0, copy_v, av, sz_v, ir_current_bb)
                    av = copy_v
                }
            }
            uint64 avp = call_arg_vregs + arg_count * 8
            unsafe { *(avp as uint64) = av }
            arg_count = arg_count + 1
            uint32 anxt = ast_next(warg)
            warg = anxt
        }
        // Detect libm float-ABI callees. When matched, IR_ARG slots
        // are tagged with imm 200+i so codegen routes each f32 arg
        // through `movd xmmN, gpreg32` instead of the integer SysV
        // regs, and the IR_CALL handler reads the return from xmm0.
        // See dyn_sym_register / dyn_sym_set_abi in dyn_sym_registry.mlr;
        // parser.mlr flags symbols by name match. Both abi_kind 1
        // (1-arg-1-return) and 2 (2-arg-1-return) take this path —
        // arg_count plus the same imm=200+i scheme handles either
        // shape since IR_ARG already supports xmm0..xmm7 (slots
        // 200..207). Mixed integer + float args would need separate
        // tracking and should branch on abi_kind explicitly.
        uint64 libm_dyn_idx_call = dyn_sym_lookup(callee_tok)
        uint64 use_libm_abi_call = 0
        if libm_dyn_idx_call != 0xFFFFFFFF {
            if dyn_sym_abi_at(libm_dyn_idx_call) != 0 { use_libm_abi_call = 1 }
        }
        // Now emit ARG instructions
        uint64 ai = 0
        while ai < arg_count {
            uint64 avp = call_arg_vregs + ai * 8
            uint64 av = 0
            unsafe { *(avp as uint64) -> av }
            uint64 arg_slot_imm = ai
            if use_libm_abi_call != 0 { arg_slot_imm = 200 + ai }
            ir_emit(IR_ARG, 0, av, 0, arg_slot_imm, ir_current_bb)
            ai = ai + 1
        }
        uint64 dest = ir_new_vreg()
        // src1 carries the libm-ABI flag (bit 8) alongside arg_count
        // (low byte). The IR_CALL handler peels them apart.
        uint64 call_src1 = arg_count
        if use_libm_abi_call != 0 { call_src1 = arg_count | 0x100 }
        ir_emit(IR_CALL, dest, call_src1, 0, callee_tok, ir_current_bb)
        // Propagate the callee's declared float return kind onto the
        // result vreg. Without this, `some_f64_fn() * local_f64` sees
        // fkind=0 on the LHS and picks IR_MUL (integer) instead of
        // IR_FMUL (mulsd), silently producing garbage. Works because
        // float bits live in GPRs throughout (see IR_FMUL codegen),
        // so fkind only gates op selection, not register class.
        uint64 ret_fk_call = fn_ret_float_lookup(callee_tok)
        if ret_fk_call != 0 { ir_vreg_fkind_set(dest, ret_fk_call) }
        // Check if callee returns a struct (small, <=16 bytes, via rax/rdx)
        uint64 ret_si = fn_ret_struct_lookup(callee_tok)
        if ret_si != 0xFFFFFFFF {
            uint64 ret_ssize = struct_total_size(ret_si)
            // Allocate buffer and store rax into first 8 bytes
            uint64 buf_v = ir_new_vreg()
            ir_emit(IR_ALLOC, buf_v, 0, 0, ret_ssize, ir_current_bb)
            // Zero-initialize
            uint64 zero_v = ir_new_vreg()
            ir_emit(IR_CONST, zero_v, 0, 0, 0, ir_current_bb)
            uint64 ret_sz_v = ir_new_vreg()
            ir_emit(IR_CONST, ret_sz_v, 0, 0, ret_ssize, ir_current_bb)
            ir_emit(IR_MEMSET, 0, buf_v, zero_v, ret_sz_v, ir_current_bb)
            // Store first 8 bytes (rax)
            ir_emit(IR_STORE, 8, buf_v, dest, 0, ir_current_bb)
            if ret_ssize > 8 {
                // Extract rdx and store second 8 bytes
                uint64 rdx_v = ir_new_vreg()
                ir_emit(IR_EXTRACT_RDX, rdx_v, 0, 0, 0, ir_current_bb)
                uint64 off8_v = ir_new_vreg()
                ir_emit(IR_CONST, off8_v, 0, 0, 8, ir_current_bb)
                uint64 addr2_v = ir_new_vreg()
                ir_emit(IR_ADD, addr2_v, buf_v, off8_v, 0, ir_current_bb)
                ir_emit(IR_STORE, 8, addr2_v, rdx_v, 0, ir_current_bb)
            }
            return buf_v
        }
        return dest
    }

    // SizeofLit (49)
    if kind == 49 {
        uint32 sz = ast_data1(node)
        uint64 val = sz
        uint64 dest = ir_new_vreg()
        ir_emit(IR_CONST, dest, 0, 0, val, ir_current_bb)
        return dest
    }

    // LogicalAnd (39): short-circuit
    // result = 0 initially; if lhs != 0, result = rhs
    if kind == 39 {
        uint32 lhs_node = ast_child(node)
        uint32 rhs_idx = ast_data2(node)
        uint64 result = ir_new_vreg()
        ir_emit(IR_CONST, result, 0, 0, 0, ir_current_bb)
        uint64 lhs = ir_lower_expr(lhs_node)
        uint64 bb_rhs = ir_new_bb()
        uint64 bb_merge = ir_new_bb()
        ir_emit(IR_BR_COND, 0, lhs, 0, bb_rhs, ir_current_bb)
        ir_bb_set_succ(ir_current_bb, bb_merge, bb_rhs)
        ir_current_bb = bb_rhs
        uint64 rhs = ir_lower_expr(rhs_idx)
        ir_emit(IR_COPY, result, rhs, 0, 0, ir_current_bb)
        ir_emit(IR_BR, 0, 0, 0, bb_merge, ir_current_bb)
        ir_bb_set_succ(ir_current_bb, bb_merge, 0xFFFFFFFF)
        ir_current_bb = bb_merge
        return result
    }

    // LogicalOr (40): short-circuit
    // result = 1 initially; if lhs == 0, result = rhs
    if kind == 40 {
        uint32 lhs_node = ast_child(node)
        uint32 rhs_idx = ast_data2(node)
        uint64 result = ir_new_vreg()
        ir_emit(IR_CONST, result, 0, 0, 1, ir_current_bb)
        uint64 lhs = ir_lower_expr(lhs_node)
        uint64 bb_rhs = ir_new_bb()
        uint64 bb_merge = ir_new_bb()
        // If lhs is nonzero, skip rhs (result stays 1)
        ir_emit(IR_BR_COND, 0, lhs, 0, bb_merge, ir_current_bb)
        ir_bb_set_succ(ir_current_bb, bb_rhs, bb_merge)
        ir_current_bb = bb_rhs
        uint64 rhs = ir_lower_expr(rhs_idx)
        ir_emit(IR_COPY, result, rhs, 0, 0, ir_current_bb)
        ir_emit(IR_BR, 0, 0, 0, bb_merge, ir_current_bb)
        ir_bb_set_succ(ir_current_bb, bb_merge, 0xFFFFFFFF)
        ir_current_bb = bb_merge
        return result
    }

    // FieldAccess (36) — struct field read or enum constant lookup
    if kind == 36 {
        uint32 field_tok = ast_data2(node)
        uint32 child_idx = ast_child(node)
        uint64 wchild_fa = child_idx

        // Nested struct field read: child is another FieldAccess (e.g. a.b.c)
        if wchild_fa != 0 {
            uint32 ck_nested = ast_kind(wchild_fa)
            if ck_nested == 36 {
                // Recursively evaluate the inner chain to get the base address
                // of the inner struct field. ir_lower_field_chain returns the
                // address of the struct and sets ir_fa_struct_idx to the struct
                // index of that field's type.
                uint64 inner_addr = ir_lower_field_chain(wchild_fa)
                uint64 inner_si = ir_fa_struct_idx
                if inner_si != 0xFFFFFFFF {
                    uint64 foff = struct_field_offset(inner_si, field_tok)
                    uint64 fsz = struct_field_size(inner_si, field_tok)
                    uint64 addr_v = inner_addr
                    if foff != 0 {
                        uint64 off_v = ir_new_vreg()
                        ir_emit(IR_CONST, off_v, 0, 0, foff, ir_current_bb)
                        addr_v = ir_new_vreg()
                        ir_emit(IR_ADD, addr_v, inner_addr, off_v, 0, ir_current_bb)
                    }
                    // Check if this field is itself a struct type
                    uint64 ftk = struct_field_type_kind_by_tok(inner_si, field_tok)
                    if ftk >= 256 {
                        // Field is a nested struct — return address, set tracking
                        ir_fa_struct_idx = ftk - 256
                        return addr_v
                    }
                    uint64 dest = ir_new_vreg()
                    ir_emit(IR_LOAD, dest, addr_v, fsz, 0, ir_current_bb)
                    if ftk == 96 { ir_vreg_fkind_set(dest, 1) }
                    if ftk == 95 { ir_vreg_fkind_set(dest, 2) }
                    ir_fa_struct_idx = 0xFFFFFFFF
                    return dest
                }
            }
            // Struct array element field read: child is Index(37)
            if ck_nested == 37 {
                uint32 ai_tok = ast_data1(wchild_fa)
                uint64 wait = ai_tok
                uint64 sia = struct_var_lookup(ai_tok)
                if sia != 0xFFFFFFFF {
                    uint64 stride = struct_total_size(sia)
                    uint64 foff_i = struct_field_offset(sia, field_tok)
                    uint64 fsz_i = struct_field_size(sia, field_tok)
                    // Evaluate index
                    uint32 idx_ch = ast_child(wchild_fa)
                    uint64 idx_v = ir_lower_expr(idx_ch)
                    // addr = base + idx * stride + foff
                    uint64 base_v = ir_var_get(ai_tok)
                    uint64 stride_v = ir_new_vreg()
                    ir_emit(IR_CONST, stride_v, 0, 0, stride, ir_current_bb)
                    uint64 scaled_v = ir_new_vreg()
                    ir_emit(IR_MUL, scaled_v, idx_v, stride_v, 0, ir_current_bb)
                    uint64 elem_v = ir_new_vreg()
                    ir_emit(IR_ADD, elem_v, base_v, scaled_v, 0, ir_current_bb)
                    uint64 addr_v = elem_v
                    if foff_i != 0 {
                        uint64 foff_v = ir_new_vreg()
                        ir_emit(IR_CONST, foff_v, 0, 0, foff_i, ir_current_bb)
                        addr_v = ir_new_vreg()
                        ir_emit(IR_ADD, addr_v, elem_v, foff_v, 0, ir_current_bb)
                    }
                    uint64 dest = ir_new_vreg()
                    ir_emit(IR_LOAD, dest, addr_v, fsz_i, 0, ir_current_bb)
                    // Check struct array field type for float kind
                    uint64 sftk_i = struct_field_type_kind_by_tok(sia, field_tok)
                    if sftk_i == 96 { ir_vreg_fkind_set(dest, 1) }
                    if sftk_i == 95 { ir_vreg_fkind_set(dest, 2) }
                    return dest
                }
            }
        }

        uint32 obj_tok = 0
        if wchild_fa != 0 {
            uint32 ck_fa = ast_kind(wchild_fa)
            if ck_fa == 32 {
                obj_tok = ast_data1(wchild_fa)
            }
        }
        // Check for slice.len access
        if obj_tok != 0 && tok_matches(field_tok, "len", 3) != 0 {
            uint64 len_v = ir_slice_len_get(obj_tok)
            if len_v != 0xFFFFFFFF {
                return len_v
            }
        }
        // Check for device field read: Device.Field
        if obj_tok != 0 {
            uint64 wdt = obj_tok
            uint64 dev_idx = device_lookup(wdt)
            if dev_idx != 0xFFFFFFFF {
                uint64 wft_d = field_tok
                uint64 dev_off = device_field_offset_of(dev_idx, wft_d)
                if dev_off != 0xFFFFFFFF {
                    uint64 dev_sz = device_field_size_of(dev_idx, wft_d)
                    uint64 dev_addr = device_base(dev_idx) + dev_off
                    uint64 addr_v = ir_new_vreg()
                    ir_emit(IR_CONST, addr_v, 0, 0, dev_addr, ir_current_bb)
                    uint64 dest = ir_new_vreg()
                    ir_emit(IR_VLOAD, dest, addr_v, 0, dev_sz, ir_current_bb)
                    return dest
                }
            }
        }
        // Check if obj_tok is a struct variable
        uint64 wobj = obj_tok
        uint64 si = struct_var_lookup(wobj)
        if si != 0xFFFFFFFF {
            // Struct field read: base + offset, load
            uint64 base_v = ir_var_get(obj_tok)
            uint64 foff = struct_field_offset(si, field_tok)
            uint64 fsz = struct_field_size(si, field_tok)
            uint64 addr_v = base_v
            if foff != 0 {
                uint64 off_v = ir_new_vreg()
                ir_emit(IR_CONST, off_v, 0, 0, foff, ir_current_bb)
                addr_v = ir_new_vreg()
                ir_emit(IR_ADD, addr_v, base_v, off_v, 0, ir_current_bb)
            }
            // Check if this field is itself a struct type (nested struct)
            uint64 ftk = struct_field_type_kind_by_tok(si, field_tok)
            if ftk >= 256 {
                // Field is a nested struct — return address (pointer), set tracking
                ir_fa_struct_idx = ftk - 256
                return addr_v
            }
            uint64 dest = ir_new_vreg()
            ir_emit(IR_LOAD, dest, addr_v, fsz, 0, ir_current_bb)
            // Set float kind if field is f64(96) or f32(95)
            if ftk == 96 { ir_vreg_fkind_set(dest, 1) }
            if ftk == 95 { ir_vreg_fkind_set(dest, 2) }
            ir_fa_struct_idx = 0xFFFFFFFF
            return dest
        }
        // Enum constant lookup
        uint64 wfield = field_tok
        uint64 val = enum_lookup(wobj, wfield)
        uint64 dest = ir_new_vreg()
        ir_emit(IR_CONST, dest, 0, 0, val, ir_current_bb)
        return dest
    }

    // Index (37): arr[i] — array element read
    if kind == 37 {
        uint32 arr_tok = ast_data1(node)
        uint64 warrt = arr_tok
        // Get base address: check local var first, then static
        uint64 base_v = ir_var_get(arr_tok)
        if base_v == 0xFFFFFFFF {
            // Check if it's a static array
            uint64 st_off = static_lookup(warrt)
            if st_off != 0xFFFFFFFF {
                base_v = ir_new_vreg()
                ir_emit(IR_STATIC_ADDR, base_v, 0, 0, st_off, ir_current_bb)
            } else {
                base_v = ir_new_vreg()
                ir_emit(IR_CONST, base_v, 0, 0, 0, ir_current_bb)
            }
        }
        // Evaluate index expression
        uint32 idx_child = ast_child(node)
        uint64 idx_v = ir_lower_expr(idx_child)
        // Bounds check under --debug: trap if idx >= count (for arrays
        // whose size is known at compile time).
        if debug_mode != 0 {
            uint64 bchk_count = arr_count_lookup(warrt)
            if bchk_count != 0xFFFFFFFF {
                ir_emit(IR_ARR_CHECK, 0, idx_v, 0, bchk_count, ir_current_bb)
            }
        }
        // Get element size
        uint64 elem_sz = arr_elem_lookup(warrt)
        // addr = base + idx * elem_sz
        uint64 addr_v = base_v
        if elem_sz != 1 {
            uint64 esz_v = ir_new_vreg()
            ir_emit(IR_CONST, esz_v, 0, 0, elem_sz, ir_current_bb)
            uint64 scaled_v = ir_new_vreg()
            ir_emit(IR_MUL, scaled_v, idx_v, esz_v, 0, ir_current_bb)
            addr_v = ir_new_vreg()
            ir_emit(IR_ADD, addr_v, base_v, scaled_v, 0, ir_current_bb)
        } else {
            addr_v = ir_new_vreg()
            ir_emit(IR_ADD, addr_v, base_v, idx_v, 0, ir_current_bb)
        }
        // Load element
        uint64 dest = ir_new_vreg()
        ir_emit(IR_LOAD, dest, addr_v, 0, elem_sz, ir_current_bb)
        // Propagate f64/f32 type-flow from the declared array element
        // type so `arr[i] + x` lowers as float arithmetic.
        uint64 afk = static_fkind_of(warrt)
        if afk != 0 { ir_vreg_fkind_set(dest, afk) }
        return dest
    }

    // StructLit (48): struct literal expression
    if kind == 48 {
        uint32 sname_tok = ast_data1(node)
        uint64 wsn = sname_tok
        uint64 si = struct_lookup(wsn)
        uint64 ssize = struct_total_size(si)
        // Allocate struct on heap
        uint64 buf_v = ir_new_vreg()
        ir_emit(IR_ALLOC, buf_v, 0, 0, ssize, ir_current_bb)
        // Zero-initialize
        uint64 zero_v = ir_new_vreg()
        ir_emit(IR_CONST, zero_v, 0, 0, 0, ir_current_bb)
        uint64 ssz_v = ir_new_vreg()
        ir_emit(IR_CONST, ssz_v, 0, 0, ssize, ir_current_bb)
        ir_emit(IR_MEMSET, 0, buf_v, zero_v, ssz_v, ir_current_bb)
        // Walk field expressions and store each
        uint32 is_named = ast_data2(node)
        uint64 wnamed = is_named
        uint32 fchild = ast_child(node)
        uint64 wfchild = fchild
        uint64 fidx = 0
        while wfchild != 0 {
            uint64 fval_v = ir_lower_expr(wfchild)
            // Determine field offset and size
            uint64 foff = 0
            uint64 fsize = 8
            if wnamed != 0 {
                // Named: field name stored in tok_idx of the child expression
                uint32 fname = ast_tok(wfchild)
                uint64 wfn = fname
                foff = struct_field_offset(si, wfn)
                fsize = struct_field_size(si, wfn)
            } else {
                // Positional: use field index to get offset/size from struct table
                uint64 fbase = struct_table + si * 272 + 16 + fidx * 16
                uint64 foff_addr = fbase + 4
                uint32 fo32 = 0
                unsafe { *(foff_addr as uint32) -> fo32 }
                foff = fo32
                uint64 fs_addr = fbase + 8
                uint32 fs32 = 0
                unsafe { *(fs_addr as uint32) -> fs32 }
                fsize = fs32
            }
            // Store field value at base + offset
            uint64 field_addr_v = buf_v
            if foff != 0 {
                uint64 off_v = ir_new_vreg()
                ir_emit(IR_CONST, off_v, 0, 0, foff, ir_current_bb)
                field_addr_v = ir_new_vreg()
                ir_emit(IR_ADD, field_addr_v, buf_v, off_v, 0, ir_current_bb)
            }
            ir_emit(IR_STORE, fsize, field_addr_v, fval_v, 0, ir_current_bb)
            fidx = fidx + 1
            uint32 fnxt = ast_next(wfchild)
            wfchild = fnxt
        }
        return buf_v
    }

    // FString (50) — build interpolated string in a 4096-byte stack buffer
    if kind == 50 {
        uint64 buf_v = ir_new_vreg()
        ir_emit(IR_ALLOC, buf_v, 0, 0, 4096, ir_current_bb)
        uint64 off_v = ir_new_vreg()
        ir_emit(IR_CONST, off_v, 0, 0, 0, ir_current_bb)

        uint32 fchild = ast_child(node)
        uint64 wfchild = fchild
        while wfchild != 0 {
            uint32 ck = ast_kind(wfchild)
            uint64 slot_v = ir_new_vreg()
            ir_emit(IR_ADD, slot_v, buf_v, off_v, 0, ir_current_bb)
            uint64 len_v = ir_new_vreg()

            if ck == 31 {
                // StrPart (StrLit with data2=1): raw text, no quote stripping
                uint32 fstok = ast_data1(wfchild)
                uint64 wftok = fstok
                uint64 ftstart = tok_text_start(wftok)
                uint64 ftlen = tok_text_len(wftok)
                // Check data2 to detect raw StrPart (data2=1 means no quotes)
                uint32 fraw = ast_data2(wfchild)
                uint64 wfraw = fraw
                if ftlen == 0 {
                    // Empty part: emit zero length
                    ir_emit(IR_CONST, len_v, 0, 0, 0, ir_current_bb)
                } else if wfraw != 0 {
                    // Raw StrPart: copy bytes from source directly (no quote strip)
                    if str_len + ftlen >= 65536 {
                        write(2, "error: str_buf overflow\n", 24)
                        exit(1)
                    }
                    uint64 fstr_offset = str_len
                    uint64 fsi = 0
                    while fsi < ftlen {
                        uint64 fch = tok_source_byte(wftok, fsi)
                        uint64 fsp = str_buf + str_len
                        uint8 fcb = fch
                        unsafe { *(fsp as uint8) = fcb }
                        str_len = str_len + 1
                        fsi = fsi + 1
                    }
                    // Null-terminate
                    uint64 fnsp = str_buf + str_len
                    uint8 fnz = 0
                    unsafe { *(fnsp as uint8) = fnz }
                    str_len = str_len + 1
                    uint64 fstr_v = ir_new_vreg()
                    ir_emit(IR_STR_CONST, fstr_v, 0, 0, fstr_offset, ir_current_bb)
                    ir_emit(IR_STRLEN, len_v, fstr_v, 0, 0, ir_current_bb)
                    uint64 fmc = ir_new_vreg()
                    ir_emit(IR_MEMCPY, fmc, slot_v, fstr_v, len_v, ir_current_bb)
                } else {
                    // Regular StrLit: lower it and strlen+memcpy
                    uint64 s_v = ir_lower_expr(wfchild)
                    ir_emit(IR_STRLEN, len_v, s_v, 0, 0, ir_current_bb)
                    uint64 fmc2 = ir_new_vreg()
                    ir_emit(IR_MEMCPY, fmc2, slot_v, s_v, len_v, ir_current_bb)
                }
            } else {
                // Interpolated expression: same dispatch as variadic print
                uint64 val_v = ir_lower_expr(wfchild)
                uint64 fk = ir_vreg_fkind_get(val_v)
                if fk == 1 {
                    ir_emit(IR_FMT_F64, len_v, slot_v, val_v, 0, ir_current_bb)
                } else if fk == 2 {
                    uint64 f64v = ir_new_vreg()
                    ir_emit(IR_F32TOF64, f64v, val_v, 0, 0, ir_current_bb)
                    ir_vreg_fkind_set(f64v, 1)
                    ir_emit(IR_FMT_F64, len_v, slot_v, f64v, 0, ir_current_bb)
                } else if fk == 3 {
                    ir_emit(IR_FMT_BOOL, len_v, slot_v, val_v, 0, ir_current_bb)
                } else if fk == 4 {
                    ir_emit(IR_STORE, 1, slot_v, val_v, 0, ir_current_bb)
                    ir_emit(IR_CONST, len_v, 0, 0, 1, ir_current_bb)
                } else {
                    ir_emit(IR_FMT_UINT, len_v, slot_v, val_v, 0, ir_current_bb)
                }
            }

            uint64 new_off = ir_new_vreg()
            ir_emit(IR_ADD, new_off, off_v, len_v, 0, ir_current_bb)
            off_v = new_off

            uint32 fnxt = ast_next(wfchild)
            wfchild = fnxt
        }

        // Null-terminate the result
        uint64 fzero = ir_new_vreg()
        ir_emit(IR_CONST, fzero, 0, 0, 0, ir_current_bb)
        uint64 fend_v = ir_new_vreg()
        ir_emit(IR_ADD, fend_v, buf_v, off_v, 0, ir_current_bb)
        ir_emit(IR_STORE, 1, fend_v, fzero, 0, ir_current_bb)

        return buf_v
    }

    // Default: const 0
    uint64 dest = ir_new_vreg()
    ir_emit(IR_CONST, dest, 0, 0, 0, ir_current_bb)
    return dest
}

// ---------------------------------------------------------------------------
// Statement lowering
// ---------------------------------------------------------------------------

fn ir_lower_stmt(uint64 node) {
    if node == 0 { return }
    // Stash the statement's source token so every ir_emit that runs
    // during this stmt's lowering carries the right line for DWARF.
    uint32 stmt_tok = ast_tok(node)
    if stmt_tok == 0 { stmt_tok = ast_data1(node) }
    uint64 wst_tok = stmt_tok
    ir_current_src_tok = wst_tok
    uint32 kind = ast_kind(node)

    // VarDecl (10)
    if kind == 10 {
        uint32 name_tok = ast_data2(node)
        // Check for array declaration (data3 != 0 means array size token)
        uint32 arr_size_tok = ast_data3(node)
        uint64 was = arr_size_tok
        uint32 struct_marker = ast_data4(node)
        uint64 wsm = struct_marker
        if was != 0 && wsm == 0 {
            // Array: allocate N bytes on heap, bind pointer to name
            uint64 arr_size = parse_int_token(was)
            uint32 type_tok_v = ast_data1(node)
            uint64 elem_size_v = type_tok_elem_size(type_tok_v)
            uint64 total_bytes = arr_size * elem_size_v
            uint64 buf_v = ir_new_vreg()
            ir_emit(IR_ALLOC, buf_v, 0, 0, total_bytes, ir_current_bb)
            // Zero-initialize the buffer
            uint64 zero_v = ir_new_vreg()
            ir_emit(IR_CONST, zero_v, 0, 0, 0, ir_current_bb)
            uint64 sz_v = ir_new_vreg()
            ir_emit(IR_CONST, sz_v, 0, 0, total_bytes, ir_current_bb)
            ir_emit(IR_MEMSET, 0, buf_v, zero_v, sz_v, ir_current_bb)
            ir_var_set(name_tok, buf_v)
            // Register element size so array indexing can scale correctly
            arr_elem_register(name_tok, elem_size_v)
            arr_count_set_last(arr_size)
            return
        }
        // Check for struct variable declaration
        if wsm != 0 {
            uint64 struct_idx = wsm - 1
            uint64 struct_size = struct_total_size(struct_idx)
            // Check if there's an init expression (e.g. P p = P { 10, 20 })
            uint32 struct_init = ast_child(node)
            uint64 wstruct_init = struct_init
            uint32 sarr_check = ast_data3(node)
            uint64 wsarr_check = sarr_check
            if wstruct_init != 0 && wsarr_check == 0 {
                // Evaluate init expression (returns ptr to struct data)
                uint64 src_v = ir_lower_expr(wstruct_init)
                // Allocate our own copy and memcpy
                uint64 buf_v = ir_new_vreg()
                ir_emit(IR_ALLOC, buf_v, 0, 0, struct_size, ir_current_bb)
                uint64 sz_v = ir_new_vreg()
                ir_emit(IR_CONST, sz_v, 0, 0, struct_size, ir_current_bb)
                ir_emit(IR_MEMCPY, 0, buf_v, src_v, sz_v, ir_current_bb)
                ir_var_set(name_tok, buf_v)
                struct_var_register(name_tok, struct_idx)
                return
            }
            // No init: allocate and zero-initialize
            // Check if this is a struct array (data3 = array size token)
            uint64 alloc_size = struct_size
            uint64 arr_count = 1
            if wsarr_check != 0 {
                arr_count = parse_int_token(wsarr_check)
                alloc_size = struct_size * arr_count
            }
            uint64 buf_v = ir_new_vreg()
            ir_emit(IR_ALLOC, buf_v, 0, 0, alloc_size, ir_current_bb)
            uint64 zero_v = ir_new_vreg()
            ir_emit(IR_CONST, zero_v, 0, 0, 0, ir_current_bb)
            uint64 asz_v = ir_new_vreg()
            ir_emit(IR_CONST, asz_v, 0, 0, alloc_size, ir_current_bb)
            ir_emit(IR_MEMSET, 0, buf_v, zero_v, asz_v, ir_current_bb)
            ir_var_set(name_tok, buf_v)
            struct_var_register(name_tok, struct_idx)
            // Register element size for struct array indexing
            if arr_count > 1 {
                arr_elem_register(name_tok, struct_size)
                arr_count_set_last(arr_count)
            }
            return
        }
        uint32 init = ast_child(node)
        uint64 winit = init
        // Check if type is float (f64=96, f32=95)
        uint32 vd_type_tok = ast_data1(node)
        uint64 vd_type_kind = tok_kind_at_raw(vd_type_tok)
        uint64 vd_fk = 0
        if vd_type_kind == 96 { vd_fk = 1 }
        if vd_type_kind == 95 { vd_fk = 2 }
        if vd_type_kind == 98 { vd_fk = 3 }
        if vd_type_kind == 99 { vd_fk = 4 }
        // Signed-int types: int8=84, int16=85, int32=86, int64=87 (token
        // kinds from src/lexer.mlr KwInt8..KwInt64). Mark the vreg as
        // signed so Compare lowering picks IR_SCMP_* over IR_CMP_*.
        uint64 vd_signed = 0
        if vd_type_kind == 84 || vd_type_kind == 85 ||
           vd_type_kind == 86 || vd_type_kind == 87 { vd_signed = 1 }
        if winit != 0 {
            uint64 val = ir_lower_expr(winit)
            uint64 fk_from_val = ir_vreg_fkind_get(val)
            // If declared type is f32 but init produced f64 (common for
            // `f32 x = 6.9`), emit a narrowing conversion so the stored
            // bits are an actual f32. Relabel-only would leave the variable
            // holding the upper 32 bits of the f64 bit pattern, which
            // cvtss2sd later interprets as a tiny negative value.
            if vd_fk == 2 && fk_from_val == 1 {
                uint64 f32v = ir_new_vreg()
                ir_emit(IR_F64TOF32, f32v, val, 0, 0, ir_current_bb)
                ir_vreg_fkind_set(f32v, 2)
                val = f32v
                fk_from_val = 2
            }
            // Symmetric widening for `f64 x = 1.5f` style cases.
            if vd_fk == 1 && fk_from_val == 2 {
                uint64 f64v = ir_new_vreg()
                ir_emit(IR_F32TOF64, f64v, val, 0, 0, ir_current_bb)
                ir_vreg_fkind_set(f64v, 1)
                val = f64v
                fk_from_val = 1
            }
            // Integer → f64 conversion for `f64 x = some_int_var`.
            // Restricted to the RHS being a bare Ident (AST kind 32)
            // referring to a known int-typed variable, so call
            // expressions — whose result vreg has fkind=0 even when
            // the callee returns f64 — aren't wrongly ITOF'd.
            if vd_fk == 1 && fk_from_val == 0 {
                uint32 rhs_kind = ast_kind(winit)
                if rhs_kind == 32 {
                    uint64 f64v = ir_new_vreg()
                    ir_emit(IR_ITOF, f64v, val, 0, 0, ir_current_bb)
                    ir_vreg_fkind_set(f64v, 1)
                    val = f64v
                    fk_from_val = 1
                }
            }
            // Always create a fresh vreg for the new variable so it doesn't
            // alias the source. This is critical when the init is a variable
            // reference (e.g., uint64 test = bits) — without the copy, both
            // names share a vreg and modifications to one affect the other.
            uint64 fresh_val = ir_new_vreg()
            ir_emit(IR_COPY, fresh_val, val, 0, 0, ir_current_bb)
            if vd_fk != 0 {
                ir_vreg_fkind_set(fresh_val, vd_fk)
            } else if fk_from_val != 0 {
                ir_vreg_fkind_set(fresh_val, fk_from_val)
            }
            // Signed-int flag: prefer the declared type, fall back to the
            // RHS's flag (e.g., `auto-style int x = signed_var` doesn't
            // apply here since MLRift requires an explicit type, but RHS
            // sign info still helps when declared type is uint64 and RHS
            // came from a signed source — leave declared type authoritative).
            if vd_signed != 0 {
                ir_vreg_signed_set(fresh_val, 1)
            } else if vd_fk == 0 && ir_vreg_signed_get(val) != 0 {
                // Untyped destination (shouldn't happen with explicit decls)
                ir_vreg_signed_set(fresh_val, 1)
            }
            ir_var_set(name_tok, fresh_val)
        } else {
            uint64 zero = ir_new_vreg()
            ir_emit(IR_CONST, zero, 0, 0, 0, ir_current_bb)
            if vd_fk != 0 { ir_vreg_fkind_set(zero, vd_fk) }
            if vd_signed != 0 { ir_vreg_signed_set(zero, 1) }
            ir_var_set(name_tok, zero)
        }
        return
    }

    // Assign (11)
    if kind == 11 {
        uint32 name_tok = ast_data1(node)
        uint32 val_node = ast_child(node)
        uint64 val = ir_lower_expr(val_node)
        uint64 val_fk = ir_vreg_fkind_get(val)
        // Check if the variable exists as a local first (locals shadow statics)
        uint64 wnt = name_tok
        uint64 local_vreg = ir_var_get(wnt)
        if local_vreg != 0xFFFFFFFF {
            // Integer → f64 for `f64_var = some_int_var`. Only
            // triggers when the RHS is a bare Ident (AST kind 32)
            // so we don't misclassify call results. The LHS type
            // comes from the current vreg's fkind. See
            // memory/project_f64_cast_bug.md.
            uint64 lhs_fk = ir_vreg_fkind_get(local_vreg)
            if lhs_fk == 1 && val_fk == 0 {
                uint32 rhs_kind = ast_kind(val_node)
                if rhs_kind == 32 {
                    uint64 f64v = ir_new_vreg()
                    ir_emit(IR_ITOF, f64v, val, 0, 0, ir_current_bb)
                    ir_vreg_fkind_set(f64v, 1)
                    val = f64v
                    val_fk = 1
                }
            }
            // f64 → f32 narrow for `f32_var = f64_expr`. Mirrors VarDecl.
            // Without this, `f32 t = 0.0; t = a - 1.0` would alias t to
            // an f64 vreg (after the BinOp widen-to-f64 fix), and reading
            // t back through anything assuming f32 bit layout reads garbage.
            if lhs_fk == 2 && val_fk == 1 {
                uint64 f32v = ir_new_vreg()
                ir_emit(IR_F64TOF32, f32v, val, 0, 0, ir_current_bb)
                ir_vreg_fkind_set(f32v, 2)
                val = f32v
            }
            // Symmetric f32 → f64 widen for `f64_var = f32_expr`.
            if lhs_fk == 1 && val_fk == 2 {
                uint64 f64v = ir_new_vreg()
                ir_emit(IR_F32TOF64, f64v, val, 0, 0, ir_current_bb)
                ir_vreg_fkind_set(f64v, 1)
                val = f64v
            }
            // When the RHS is a bare Ident (AST kind 32), `val` is the
            // *same* vreg as the source variable — Ident lowering returns
            // the existing vreg without copying. Aliasing the LHS to that
            // vreg means subsequent mutations to LHS (e.g. `t = t + 1`
            // inside a loop) will, via ir_emit_copy_to_snapshot's back-
            // edge IR_COPY, physically clobber the storage of the RHS's
            // source variable. Concretely: `t = t_lo; while t < N { t =
            // t + 1 }` rewrites t_lo to N. Mirror VarDecl's behavior:
            // emit a fresh IR_COPY so the new binding owns its own vreg.
            // Casts above (ITOF / F64TOF32 / F32TOF64) already produce a
            // fresh vreg, so only the no-cast Ident path needs this.
            uint32 rhs_kind_for_alias = ast_kind(val_node)
            if rhs_kind_for_alias == 32 && val == ir_var_get(ast_data1(val_node)) {
                uint64 fresh = ir_new_vreg()
                ir_emit(IR_COPY, fresh, val, 0, 0, ir_current_bb)
                uint64 src_fk = ir_vreg_fkind_get(val)
                if src_fk != 0 { ir_vreg_fkind_set(fresh, src_fk) }
                if ir_vreg_signed_get(val) != 0 { ir_vreg_signed_set(fresh, 1) }
                val = fresh
            }
            // Carry the LHS's signed-int flag onto the assigned vreg.
            // Without this, a `t = -k` assignment that lands a fresh
            // non-signed vreg into `t` would lose the signed flag from
            // the original declaration.
            if ir_vreg_signed_get(local_vreg) != 0 {
                ir_vreg_signed_set(val, 1)
            }
            ir_var_set(name_tok, val)
            return
        }
        // Check if this is a static variable
        uint64 st_off = static_lookup(wnt)
        if st_off != 0xFFFFFFFF {
            ir_emit(IR_STATIC_STORE, 0, val, 0, st_off, ir_current_bb)
            return
        }
        ir_var_set(name_tok, val)
        return
    }

    // Return (12)
    if kind == 12 {
        uint32 expr = ast_child(node)
        uint64 wexpr = expr
        uint32 second_expr = ast_data3(node)
        uint64 wsecond = second_expr
        uint32 third_expr = ast_data4(node)
        uint64 wthird = third_expr
        // Compute return value(s) first so the produced vregs are already
        // in hand before the defer bodies run. The regalloc may spill if
        // the defers touch the same physical regs — that's fine.
        if wthird != 0 && wsecond != 0 {
            uint64 v1 = ir_lower_expr(wexpr)
            uint64 v2 = ir_lower_expr(wsecond)
            uint64 v3 = ir_lower_expr(wthird)
            ir_defer_emit_all()
            ir_emit(IR_RET3, 0, v1, v2, v3, ir_current_bb)
        } else if wsecond != 0 {
            uint64 v1 = ir_lower_expr(wexpr)
            uint64 v2 = ir_lower_expr(wsecond)
            ir_defer_emit_all()
            ir_emit(IR_RET2, 0, v1, v2, 0, ir_current_bb)
        } else if wexpr != 0 {
            uint64 val = ir_lower_expr(wexpr)
            ir_defer_emit_all()
            ir_emit(IR_RET, 0, val, 0, 0, ir_current_bb)
        } else {
            ir_defer_emit_all()
            ir_emit(IR_RET_VOID, 0, 0, 0, 0, ir_current_bb)
        }
        return
    }

    // Defer (51): stash the body on the function-scoped defer stack.
    // Emission is deferred to the next IR_RET* instruction.
    if kind == 51 {
        uint32 body_node = ast_data1(node)
        uint64 wbody = body_node
        ir_defer_push(wbody)
        return
    }

    // ExprStmt (16)
    if kind == 16 {
        uint32 expr = ast_child(node)
        uint64 wexpr = expr
        if wexpr != 0 { ir_lower_expr(wexpr) }
        return
    }

    // If (13)
    if kind == 13 {
        uint32 cond_node = ast_child(node)
        uint64 cond = ir_lower_expr(cond_node)
        uint64 bb_then = ir_new_bb()
        uint64 bb_merge = ir_new_bb()
        uint32 else_body = ast_data2(node)
        uint64 welse = else_body
        uint64 bb_else = bb_merge
        if welse != 0 { bb_else = ir_new_bb() }
        ir_emit(IR_BR_COND, 0, cond, 0, bb_then, ir_current_bb)
        ir_bb_set_succ(ir_current_bb, bb_else, bb_then)
        // Snapshot variable map before then-body
        uint64 if_snap_count = ir_var_map_count
        uint64 if_snap = alloc(if_snap_count * 8)
        uint64 ifi = 0
        while ifi < if_snap_count {
            uint64 ifs = ir_var_map + ifi * 8
            uint64 ifd = if_snap + ifi * 8
            uint64 ifv = 0
            unsafe { *(ifs as uint64) -> ifv }
            unsafe { *(ifd as uint64) = ifv }
            ifi = ifi + 1
        }
        // Then
        ir_current_bb = bb_then
        uint32 then_body = ast_data1(node)
        uint64 wthen = then_body
        if wthen != 0 { ir_lower_block(wthen) }
        // Emit COPY for changed variables (then → merge)
        ir_emit_copy_to_snapshot(if_snap, if_snap_count, ir_current_bb)
        ir_emit(IR_BR, 0, 0, 0, bb_merge, ir_current_bb)
        ir_bb_set_succ(ir_current_bb, bb_merge, 0xFFFFFFFF)
        // Restore var map for else/merge
        ifi = 0
        while ifi < if_snap_count {
            uint64 ifs = if_snap + ifi * 8
            uint64 ifd = ir_var_map + ifi * 8
            uint64 ifv = 0
            unsafe { *(ifs as uint64) -> ifv }
            unsafe { *(ifd as uint64) = ifv }
            ifi = ifi + 1
        }
        ir_var_map_count = if_snap_count
        // Else
        if welse != 0 {
            ir_current_bb = bb_else
            uint32 else_kind = ast_kind(welse)
            if else_kind == 15 {
                ir_lower_block(welse)
            } else {
                ir_lower_stmt(welse)
            }
            // Emit COPY for changed variables (else → merge)
            ir_emit_copy_to_snapshot(if_snap, if_snap_count, ir_current_bb)
            ir_emit(IR_BR, 0, 0, 0, bb_merge, ir_current_bb)
            ir_bb_set_succ(ir_current_bb, bb_merge, 0xFFFFFFFF)
            // Restore var map for merge
            ifi = 0
            while ifi < if_snap_count {
                uint64 ifs = if_snap + ifi * 8
                uint64 ifd = ir_var_map + ifi * 8
                uint64 ifv = 0
                unsafe { *(ifs as uint64) -> ifv }
                unsafe { *(ifd as uint64) = ifv }
                ifi = ifi + 1
            }
            ir_var_map_count = if_snap_count
        }
        ir_current_bb = bb_merge
        dealloc(if_snap)
        return
    }

    // While (14)
    if kind == 14 {
        // Snapshot the preheader BB before any new BBs are created so
        // LICM can hoist invariants right before the loop entry IR_BR.
        uint64 licm_preheader = ir_current_bb
        uint64 bb_header = ir_new_bb()
        uint64 bb_body = ir_new_bb()
        uint64 bb_exit = ir_new_bb()
        ir_emit(IR_BR, 0, 0, 0, bb_header, ir_current_bb)
        ir_bb_set_succ(ir_current_bb, bb_header, 0xFFFFFFFF)
        // Snapshot variable map before header
        uint64 snap_count = ir_var_map_count
        uint64 snap_buf = alloc(snap_count * 8)
        uint64 si = 0
        while si < snap_count {
            uint64 sp = ir_var_map + si * 8
            uint64 dp = snap_buf + si * 8
            uint64 sv = 0
            unsafe { *(sp as uint64) -> sv }
            unsafe { *(dp as uint64) = sv }
            si = si + 1
        }
        ir_current_bb = bb_header
        uint32 cond_node = ast_child(node)
        uint64 cond = ir_lower_expr(cond_node)
        ir_emit(IR_BR_COND, 0, cond, 0, bb_body, ir_current_bb)
        ir_bb_set_succ(ir_current_bb, bb_exit, bb_body)
        // Snapshot variable map after header (to know which vregs header uses)
        uint64 hdr_count = ir_var_map_count
        uint64 hdr_buf = alloc(hdr_count * 8)
        si = 0
        while si < hdr_count {
            uint64 sp = ir_var_map + si * 8
            uint64 dp = hdr_buf + si * 8
            uint64 sv = 0
            unsafe { *(sp as uint64) -> sv }
            unsafe { *(dp as uint64) = sv }
            si = si + 1
        }
        // Push loop context for break/continue
        uint64 lp = ir_loop_exit_stack + ir_loop_depth * 8
        unsafe { *(lp as uint64) = bb_exit }
        uint64 lh = ir_loop_header_stack + ir_loop_depth * 8
        unsafe { *(lh as uint64) = bb_header }
        uint64 lb = ir_loop_hdr_buf_stack + ir_loop_depth * 8
        unsafe { *(lb as uint64) = hdr_buf }
        uint64 lc = ir_loop_hdr_count_stack + ir_loop_depth * 8
        unsafe { *(lc as uint64) = hdr_count }
        ir_loop_depth = ir_loop_depth + 1

        ir_current_bb = bb_body
        uint32 body = ast_data1(node)
        uint64 wbody = body
        if wbody != 0 { ir_lower_block(wbody) }

        ir_loop_depth = ir_loop_depth - 1

        // After body, emit COPY for any variables that changed since header.
        ir_emit_copy_to_snapshot(hdr_buf, hdr_count, ir_current_bb)
        // Record the loop range [bb_body .. ir_bb_count-1] so LICM can
        // walk every body BB. (bb_exit was allocated upfront but is
        // logically AFTER the loop body in BB index, so it's excluded
        // by the IR_BR back-edge.)
        if ir_loop_count < ir_loop_cap {
            uint64 le = ir_loops + ir_loop_count * 16
            uint32 ph32 = licm_preheader
            uint32 hd32 = bb_header
            uint32 fb32 = bb_body
            uint32 lb32 = ir_current_bb
            unsafe { *(le as uint32) = ph32 }
            uint64 le4 = le + 4
            unsafe { *(le4 as uint32) = hd32 }
            uint64 le8 = le + 8
            unsafe { *(le8 as uint32) = fb32 }
            uint64 le12 = le + 12
            unsafe { *(le12 as uint32) = lb32 }
            ir_loop_count = ir_loop_count + 1
        }
        ir_emit(IR_BR, 0, 0, 0, bb_header, ir_current_bb)
        ir_bb_set_succ(ir_current_bb, bb_header, 0xFFFFFFFF)
        // Restore variable map to header vregs for code after the loop.
        // The header vregs are the merge points — they receive values via
        // COPY from the body and hold the correct values on loop exit.
        si = 0
        while si < hdr_count {
            uint64 hs = hdr_buf + si * 8
            uint64 hd = ir_var_map + si * 8
            uint64 hv = 0
            unsafe { *(hs as uint64) -> hv }
            unsafe { *(hd as uint64) = hv }
            si = si + 1
        }
        ir_var_map_count = hdr_count
        ir_current_bb = bb_exit
        dealloc(snap_buf)
        dealloc(hdr_buf)
        return
    }

    // Block (15)
    if kind == 15 {
        ir_lower_block(node)
        return
    }

    // Match (19)
    if kind == 19 {
        uint32 scrutinee = ast_child(node)
        uint64 scrut_v = ir_lower_expr(scrutinee)
        // Snapshot variable map before match
        uint64 match_snap_count = ir_var_map_count
        uint64 match_snap = alloc(match_snap_count * 8)
        uint64 mi = 0
        while mi < match_snap_count {
            uint64 ms = ir_var_map + mi * 8
            uint64 md = match_snap + mi * 8
            uint64 mv = 0
            unsafe { *(ms as uint64) -> mv }
            unsafe { *(md as uint64) = mv }
            mi = mi + 1
        }
        uint32 arm_idx = ast_data1(node)
        uint64 warm = arm_idx
        uint64 bb_exit = ir_new_bb()
        while warm != 0 {
            uint32 ak = ast_kind(warm)
            if ak == 20 {
                uint32 val_expr = ast_data1(warm)
                uint32 body_block = ast_data2(warm)
                // Wildcard: Ident named "_" — always matches. Bypass the
                // compare / BR_COND and just lower the body in place.
                uint64 is_wild = 0
                uint32 vak = ast_kind(val_expr)
                if vak == 32 {
                    uint32 wild_tok = ast_data1(val_expr)
                    uint64 wwt = wild_tok
                    if tok_matches(wwt, "_", 1) != 0 { is_wild = 1 }
                }
                uint64 bb_body = ir_new_bb()
                uint64 bb_next = ir_new_bb()
                if is_wild == 0 {
                    // Walk the comma-separated pattern chain. For each
                    // pattern emit "if matches then body" via a BR_COND
                    // whose false side lands in a fresh BB holding the
                    // next pattern's check. If every check fails we land
                    // in bb_next (the existing "skip arm" BB).
                    uint64 pat = val_expr
                    while pat != 0 {
                        uint32 nxt_pat = ast_next(pat)
                        uint64 is_last_pat = 0
                        if nxt_pat == 0 { is_last_pat = 1 }
                        uint64 bb_on_fail = 0
                        if is_last_pat != 0 { bb_on_fail = bb_next } else { bb_on_fail = ir_new_bb() }
                        uint32 pat_kind_raw = ast_kind(pat)
                        uint64 pat_kind = pat_kind_raw
                        if pat_kind == 52 {
                            // Range pattern: lo <= scrut AND scrut {<,<=} hi
                            uint32 lo_idx = ast_data1(pat)
                            uint32 hi_idx = ast_data2(pat)
                            uint32 inc_flag = ast_data3(pat)
                            uint64 lo_v = ir_lower_expr(lo_idx)
                            uint64 ge_v = ir_new_vreg()
                            ir_emit(IR_CMP_GE, ge_v, scrut_v, lo_v, 0, ir_current_bb)
                            uint64 bb_check_hi = ir_new_bb()
                            ir_emit(IR_BR_COND, 0, ge_v, 0, bb_check_hi, ir_current_bb)
                            ir_bb_set_succ(ir_current_bb, bb_on_fail, bb_check_hi)
                            ir_current_bb = bb_check_hi
                            uint64 hi_v = ir_lower_expr(hi_idx)
                            uint64 cmp_v = ir_new_vreg()
                            uint64 cmp_op = 16              // IR_CMP_LT for .. exclusive
                            if inc_flag != 0 { cmp_op = 17 } // IR_CMP_LE for ..= inclusive
                            ir_emit(cmp_op, cmp_v, scrut_v, hi_v, 0, ir_current_bb)
                            ir_emit(IR_BR_COND, 0, cmp_v, 0, bb_body, ir_current_bb)
                            ir_bb_set_succ(ir_current_bb, bb_on_fail, bb_body)
                        } else {
                            uint64 val_v = ir_lower_expr(pat)
                            uint64 cmp_v = ir_new_vreg()
                            ir_emit(IR_CMP_EQ, cmp_v, scrut_v, val_v, 0, ir_current_bb)
                            ir_emit(IR_BR_COND, 0, cmp_v, 0, bb_body, ir_current_bb)
                            ir_bb_set_succ(ir_current_bb, bb_on_fail, bb_body)
                        }
                        if is_last_pat == 0 { ir_current_bb = bb_on_fail }
                        pat = nxt_pat
                    }
                } else {
                    ir_emit(IR_BR, 0, 0, 0, bb_body, ir_current_bb)
                    ir_bb_set_succ(ir_current_bb, bb_body, 0xFFFFFFFF)
                }
                // Restore variable map to pre-match state for this arm
                mi = 0
                while mi < match_snap_count {
                    uint64 ms = match_snap + mi * 8
                    uint64 md = ir_var_map + mi * 8
                    uint64 mv = 0
                    unsafe { *(ms as uint64) -> mv }
                    unsafe { *(md as uint64) = mv }
                    mi = mi + 1
                }
                ir_var_map_count = match_snap_count
                ir_current_bb = bb_body
                uint64 wbody = body_block
                if wbody != 0 { ir_lower_block(wbody) }
                // Emit COPY for any changed variables back to pre-match vregs
                ir_emit_copy_to_snapshot(match_snap, match_snap_count, ir_current_bb)
                ir_emit(IR_BR, 0, 0, 0, bb_exit, ir_current_bb)
                ir_bb_set_succ(ir_current_bb, bb_exit, 0xFFFFFFFF)
                ir_current_bb = bb_next
            }
            uint32 anxt = ast_next(warm)
            warm = anxt
        }
        ir_emit(IR_BR, 0, 0, 0, bb_exit, ir_current_bb)
        ir_bb_set_succ(ir_current_bb, bb_exit, 0xFFFFFFFF)
        // Restore var map to pre-match state for exit block
        mi = 0
        while mi < match_snap_count {
            uint64 ms = match_snap + mi * 8
            uint64 md = ir_var_map + mi * 8
            uint64 mv = 0
            unsafe { *(ms as uint64) -> mv }
            unsafe { *(md as uint64) = mv }
            mi = mi + 1
        }
        ir_var_map_count = match_snap_count
        ir_current_bb = bb_exit
        dealloc(match_snap)
        return
    }

    // Break (17)
    if kind == 17 {
        if ir_loop_depth > 0 {
            uint64 ld = ir_loop_depth - 1
            // Copy changed vars back to header vregs before jumping
            uint64 lbp = ir_loop_hdr_buf_stack + ld * 8
            uint64 hb = 0
            unsafe { *(lbp as uint64) -> hb }
            uint64 lcp = ir_loop_hdr_count_stack + ld * 8
            uint64 hc = 0
            unsafe { *(lcp as uint64) -> hc }
            ir_emit_copy_to_snapshot(hb, hc, ir_current_bb)
            uint64 lep = ir_loop_exit_stack + ld * 8
            uint64 exit_bb = 0
            unsafe { *(lep as uint64) -> exit_bb }
            ir_emit(IR_BR, 0, 0, 0, exit_bb, ir_current_bb)
            ir_bb_set_succ(ir_current_bb, exit_bb, 0xFFFFFFFF)
            // Create a new unreachable block for any code after break
            ir_current_bb = ir_new_bb()
        }
        return
    }

    // Continue (18)
    if kind == 18 {
        if ir_loop_depth > 0 {
            uint64 ld = ir_loop_depth - 1
            // Copy changed vars back to header vregs before jumping
            uint64 lbp = ir_loop_hdr_buf_stack + ld * 8
            uint64 hb = 0
            unsafe { *(lbp as uint64) -> hb }
            uint64 lcp = ir_loop_hdr_count_stack + ld * 8
            uint64 hc = 0
            unsafe { *(lcp as uint64) -> hc }
            ir_emit_copy_to_snapshot(hb, hc, ir_current_bb)
            uint64 lhp = ir_loop_header_stack + ld * 8
            uint64 header_bb = 0
            unsafe { *(lhp as uint64) -> header_bb }
            ir_emit(IR_BR, 0, 0, 0, header_bb, ir_current_bb)
            ir_bb_set_succ(ir_current_bb, header_bb, 0xFFFFFFFF)
            // Create a new unreachable block for any code after continue
            ir_current_bb = ir_new_bb()
        }
        return
    }

    // PtrLoad (41): unsafe { *(addr as TYPE) -> dest }
    if kind == 41 {
        uint32 ts = ast_data1(node)
        uint64 type_size = ts
        uint32 addr_expr = ast_child(node)
        uint64 addr_v = ir_lower_expr(addr_expr)
        uint64 dest_v = ir_new_vreg()
        ir_emit(IR_LOAD, dest_v, addr_v, type_size, 0, ir_current_bb)
        // Propagate f64/f32 type-flow from the `as TYPE` clause. The
        // parser stashed the fkind in data3 (1=f64, 2=f32, 3=f16,
        // 0=int). Without this, `unsafe { *(p as f64) -> v }` leaves
        // v untyped at the IR level and downstream `v + x` emits
        // integer arithmetic instead of IR_FADD.
        uint32 fk32 = ast_data3(node)
        uint64 fk = fk32
        if fk != 0 { ir_vreg_fkind_set(dest_v, fk) }
        // Bind dest variable
        uint32 dest_tok = ast_data2(node)
        ir_var_set(dest_tok, dest_v)
        return
    }

    // PtrStore (42): unsafe { *(addr as TYPE) = val }
    if kind == 42 {
        uint32 ts = ast_data1(node)
        uint64 type_size = ts
        uint32 addr_expr = ast_child(node)
        uint64 addr_v = ir_lower_expr(addr_expr)
        uint32 val_node = ast_data2(node)
        uint64 val_v = ir_lower_expr(val_node)
        ir_emit(IR_STORE, type_size, addr_v, val_v, 0, ir_current_bb)
        return
    }

    // Indexed assignment: arr[i] = val (kind 37 with data3=1)
    if kind == 37 {
        uint32 idx_d3 = ast_data3(node)
        uint64 wd3 = idx_d3
        if wd3 == 1 {
            // Evaluate value expression
            uint32 rhs_child = ast_data2(node)
            uint64 wrhs = rhs_child
            uint64 val_v = ir_lower_expr(wrhs)
            // Evaluate index expression
            uint32 idx_child = ast_child(node)
            uint64 idx_v = ir_lower_expr(idx_child)
            // Load array base
            uint32 arr_tok = ast_data1(node)
            uint64 warrt = arr_tok
            // Bounds check under --debug for known-size arrays.
            if debug_mode != 0 {
                uint64 bchk_count_s = arr_count_lookup(warrt)
                if bchk_count_s != 0xFFFFFFFF {
                    ir_emit(IR_ARR_CHECK, 0, idx_v, 0, bchk_count_s, ir_current_bb)
                }
            }
            uint64 base_v = ir_var_get(arr_tok)
            if base_v == 0xFFFFFFFF {
                // Check static array
                uint64 st_off = static_lookup(warrt)
                if st_off != 0xFFFFFFFF {
                    base_v = ir_new_vreg()
                    ir_emit(IR_STATIC_ADDR, base_v, 0, 0, st_off, ir_current_bb)
                } else {
                    base_v = ir_new_vreg()
                    ir_emit(IR_CONST, base_v, 0, 0, 0, ir_current_bb)
                }
            }
            // Get element size
            uint64 elem_sz = arr_elem_lookup(warrt)
            // addr = base + idx * elem_sz
            uint64 addr_v = base_v
            if elem_sz != 1 {
                uint64 esz_v = ir_new_vreg()
                ir_emit(IR_CONST, esz_v, 0, 0, elem_sz, ir_current_bb)
                uint64 scaled_v = ir_new_vreg()
                ir_emit(IR_MUL, scaled_v, idx_v, esz_v, 0, ir_current_bb)
                addr_v = ir_new_vreg()
                ir_emit(IR_ADD, addr_v, base_v, scaled_v, 0, ir_current_bb)
            } else {
                addr_v = ir_new_vreg()
                ir_emit(IR_ADD, addr_v, base_v, idx_v, 0, ir_current_bb)
            }
            // Store element with correct width
            ir_emit(IR_STORE, elem_sz, addr_v, val_v, 0, ir_current_bb)
            return
        }
    }

    // TupleDestruct (44): (T1 a, T2 b) = rhs_expr
    // data2=name1_tok, data4=name2_tok, child=rhs (Call expr)
    if kind == 44 {
        uint32 name1_tok = ast_data2(node)
        uint32 name2_tok = ast_data4(node)
        uint32 rhs = ast_child(node)
        uint64 wrhs = rhs
        if wrhs != 0 {
            uint64 call_v = ir_lower_expr(wrhs)
            // call_v holds rax (first return value)
            ir_var_set(name1_tok, call_v)
            // Extract rdx (second return value)
            uint64 rdx_v = ir_new_vreg()
            ir_emit(IR_EXTRACT_RDX, rdx_v, 0, 0, 0, ir_current_bb)
            ir_var_set(name2_tok, rdx_v)
        }
        return
    }

    // TupleDestruct3 (47): (T1 a, T2 b, T3 c) = rhs_expr
    // data2=name1_tok, data4=name2_tok, tok=name3_tok, child=rhs (Call expr)
    if kind == 47 {
        uint32 name1_tok = ast_data2(node)
        uint32 name2_tok = ast_data4(node)
        uint32 name3_tok = ast_tok(node)
        uint32 rhs = ast_child(node)
        uint64 wrhs = rhs
        if wrhs != 0 {
            uint64 call_v = ir_lower_expr(wrhs)
            // call_v holds rax (first return value)
            ir_var_set(name1_tok, call_v)
            // Extract rdx (second return value)
            uint64 rdx_v = ir_new_vreg()
            ir_emit(IR_EXTRACT_RDX, rdx_v, 0, 0, 0, ir_current_bb)
            ir_var_set(name2_tok, rdx_v)
            // Extract r8 (third return value)
            uint64 r8_v = ir_new_vreg()
            ir_emit(IR_EXTRACT_R8, r8_v, 0, 0, 0, ir_current_bb)
            ir_var_set(name3_tok, r8_v)
        }
        return
    }

    // Inline assembly (43): asm block with optional I/O constraints
    if kind == 43 {
        // For ASM blocks, we emit the instructions directly during x86 emission.
        // The IR_ASM_BLOCK carries the AST node index for the x86 emitter.
        // Handle I/O constraints:
        // - in(var -> reg): we need to ensure the var's value is available
        // - out(reg -> var): we need to capture the output
        uint32 cons_head = ast_data3(node)
        uint64 wch = cons_head

        // Collect input constraint vregs
        uint64 wci = wch
        uint64 in_count = 0
        while wci != 0 {
            uint32 ck = ast_data1(wci)
            if ck == 0 {
                // in constraint: load the variable value
                uint32 vtok = ast_data3(wci)
                uint64 var_v = ir_var_get(vtok)
                if var_v == 0xFFFFFFFF {
                    var_v = ir_new_vreg()
                    ir_emit(IR_CONST, var_v, 0, 0, 0, ir_current_bb)
                }
                // Store the vreg as src in the instruction imm (via IR_ARG)
                uint32 rtok = ast_data2(wci)
                uint64 rcode = x86_reg_code(rtok)
                if rcode != 0xFFFF {
                    // Move var value to the target physical register
                    ir_emit(IR_ARG, 0, var_v, 0, rcode + 100, ir_current_bb)
                }
                in_count = in_count + 1
            }
            uint32 nxti = ast_next(wci)
            wci = nxti
        }

        // Emit the ASM block as a passthrough node
        uint64 wnode = node
        ir_emit(IR_ASM_BLOCK, 0, wnode, 0, 0, ir_current_bb)

        // Handle output constraints: create new vregs and bind them
        uint64 wco = wch
        while wco != 0 {
            uint32 ck2 = ast_data1(wco)
            if ck2 == 1 {
                // out constraint: capture register value into variable
                uint32 rtok2 = ast_data2(wco)
                uint32 vtok2 = ast_data3(wco)
                uint64 rcode2 = x86_reg_code(rtok2)
                if rcode2 != 0xFFFF {
                    uint64 out_v = ir_new_vreg()
                    // Use IR_COPY with a special marker: src1=0, imm=rcode+100
                    // to indicate "read from physical register rcode"
                    ir_emit(IR_COPY, out_v, 0, 0, rcode2 + 100, ir_current_bb)
                    ir_var_set(vtok2, out_v)
                }
            }
            uint32 nxto = ast_next(wco)
            wco = nxto
        }
        return
    }

    // FieldAccess (36) as statement — field assignment: p.x = val
    if kind == 36 {
        uint32 fa_d4 = ast_data4(node)
        uint64 wfad4 = fa_d4
        if wfad4 == 1 {
            // Field assignment: data1=obj_tok (via child Ident), data2=field_tok, data3=val_node
            uint32 field_tok = ast_data2(node)
            uint32 val_node = ast_data3(node)
            uint32 child_idx = ast_child(node)
            uint64 wchild_fa = child_idx

            // Nested struct field write: child is another FieldAccess (e.g. l.a.x = val)
            if wchild_fa != 0 {
                uint32 ck_nw = ast_kind(wchild_fa)
                if ck_nw == 36 {
                    uint64 inner_addr = ir_lower_field_chain(wchild_fa)
                    uint64 inner_si = ir_fa_struct_idx
                    if inner_si != 0xFFFFFFFF {
                        uint64 foff = struct_field_offset(inner_si, field_tok)
                        uint64 fsz = struct_field_size(inner_si, field_tok)
                        uint64 addr_v = inner_addr
                        if foff != 0 {
                            uint64 off_v = ir_new_vreg()
                            ir_emit(IR_CONST, off_v, 0, 0, foff, ir_current_bb)
                            addr_v = ir_new_vreg()
                            ir_emit(IR_ADD, addr_v, inner_addr, off_v, 0, ir_current_bb)
                        }
                        uint64 val_v = ir_lower_expr(val_node)
                        ir_emit(IR_STORE, fsz, addr_v, val_v, 0, ir_current_bb)
                    }
                    return
                }
                // Struct array field write: child is Index (e.g. pts[i].x = val)
                if ck_nw == 37 {
                    uint32 ai_tok = ast_data1(wchild_fa)
                    uint64 wait = ai_tok
                    uint64 sia = struct_var_lookup(ai_tok)
                    if sia != 0xFFFFFFFF {
                        uint64 stride = struct_total_size(sia)
                        uint64 foff_i = struct_field_offset(sia, field_tok)
                        uint64 fsz_i = struct_field_size(sia, field_tok)
                        // Evaluate index
                        uint32 idx_ch = ast_child(wchild_fa)
                        uint64 idx_v = ir_lower_expr(idx_ch)
                        // addr = base + idx * stride + foff
                        uint64 base_v = ir_var_get(ai_tok)
                        uint64 stride_v = ir_new_vreg()
                        ir_emit(IR_CONST, stride_v, 0, 0, stride, ir_current_bb)
                        uint64 scaled_v = ir_new_vreg()
                        ir_emit(IR_MUL, scaled_v, idx_v, stride_v, 0, ir_current_bb)
                        uint64 elem_v = ir_new_vreg()
                        ir_emit(IR_ADD, elem_v, base_v, scaled_v, 0, ir_current_bb)
                        uint64 addr_v = elem_v
                        if foff_i != 0 {
                            uint64 foff_v = ir_new_vreg()
                            ir_emit(IR_CONST, foff_v, 0, 0, foff_i, ir_current_bb)
                            addr_v = ir_new_vreg()
                            ir_emit(IR_ADD, addr_v, elem_v, foff_v, 0, ir_current_bb)
                        }
                        uint64 val_v = ir_lower_expr(val_node)
                        ir_emit(IR_STORE, fsz_i, addr_v, val_v, 0, ir_current_bb)
                    }
                    return
                }
            }

            uint32 obj_tok = 0
            if wchild_fa != 0 {
                uint32 ck_fa = ast_kind(wchild_fa)
                if ck_fa == 32 {
                    obj_tok = ast_data1(wchild_fa)
                }
            }
            // Device field write: Device.Field = val
            if obj_tok != 0 {
                uint64 wdtw = obj_tok
                uint64 dev_idx_w = device_lookup(wdtw)
                if dev_idx_w != 0xFFFFFFFF {
                    uint64 wftw_d = field_tok
                    uint64 dev_off_w = device_field_offset_of(dev_idx_w, wftw_d)
                    if dev_off_w != 0xFFFFFFFF {
                        uint64 dev_sz_w = device_field_size_of(dev_idx_w, wftw_d)
                        uint64 dev_addr_w = device_base(dev_idx_w) + dev_off_w
                        uint64 addr_v = ir_new_vreg()
                        ir_emit(IR_CONST, addr_v, 0, 0, dev_addr_w, ir_current_bb)
                        uint64 val_v = ir_lower_expr(val_node)
                        ir_emit(IR_VSTORE, dev_sz_w, addr_v, val_v, 0, ir_current_bb)
                        return
                    }
                }
            }
            uint64 wobj = obj_tok
            uint64 si = struct_var_lookup(wobj)
            if si != 0xFFFFFFFF {
                uint64 base_v = ir_var_get(obj_tok)
                uint64 foff = struct_field_offset(si, field_tok)
                uint64 fsz = struct_field_size(si, field_tok)
                uint64 addr_v = base_v
                if foff != 0 {
                    uint64 off_v = ir_new_vreg()
                    ir_emit(IR_CONST, off_v, 0, 0, foff, ir_current_bb)
                    addr_v = ir_new_vreg()
                    ir_emit(IR_ADD, addr_v, base_v, off_v, 0, ir_current_bb)
                }
                uint64 val_v = ir_lower_expr(val_node)
                ir_emit(IR_STORE, fsz, addr_v, val_v, 0, ir_current_bb)
            }
        }
        return
    }
}

// ---------------------------------------------------------------------------
// IR dump — human-readable text output
// ---------------------------------------------------------------------------

fn ir_opcode_name(uint64 op) -> uint64 {
    if op == 1 { return "const" }
    if op == 2 { return "add" }
    if op == 3 { return "sub" }
    if op == 4 { return "mul" }
    if op == 5 { return "div" }
    if op == 6 { return "mod" }
    if op == 7 { return "and" }
    if op == 8 { return "or" }
    if op == 9 { return "xor" }
    if op == 10 { return "shl" }
    if op == 11 { return "shr" }
    if op == 12 { return "neg" }
    if op == 13 { return "not" }
    if op == 14 { return "cmp_eq" }
    if op == 15 { return "cmp_ne" }
    if op == 16 { return "cmp_lt" }
    if op == 17 { return "cmp_le" }
    if op == 18 { return "cmp_gt" }
    if op == 19 { return "cmp_ge" }
    if op == 20 { return "fadd" }
    if op == 21 { return "fsub" }
    if op == 22 { return "fmul" }
    if op == 23 { return "fdiv" }
    if op == 24 { return "fcmp_eq" }
    if op == 25 { return "fcmp_lt" }
    if op == 26 { return "itof" }
    if op == 27 { return "ftoi" }
    if op == 30 { return "load" }
    if op == 31 { return "store" }
    if op == 32 { return "stack_addr" }
    if op == 40 { return "br" }
    if op == 41 { return "br_cond" }
    if op == 42 { return "ret" }
    if op == 43 { return "ret_void" }
    if op == 50 { return "call" }
    if op == 51 { return "arg" }
    if op == 52 { return "syscall" }
    if op == 60 { return "phi" }
    if op == 61 { return "copy" }
    if op == 70 { return "alloc" }
    if op == 71 { return "dealloc" }
    if op == 72 { return "memcpy" }
    if op == 73 { return "strlen" }
    if op == 74 { return "fmt_uint" }
    if op == 75 { return "str_eq" }
    if op == 76 { return "memset" }
    if op == 77 { return "static_load" }
    if op == 78 { return "static_store" }
    if op == 79 { return "str_const" }
    if op == 80 { return "extract_rdx" }
    if op == 81 { return "extract_r8" }
    if op == 82 { return "ret2" }
    if op == 83 { return "ret3" }
    if op == 84 { return "static_addr" }
    if op == 85 { return "syscall_raw" }
    if op == 86 { return "fn_addr" }
    if op == 87 { return "call_ind" }
    if op == 88 { return "memcmp" }
    if op == 90 { return "atomic_store" }
    if op == 91 { return "atomic_load" }
    if op == 92 { return "atomic_add" }
    if op == 93 { return "atomic_cas" }
    if op == 94 { return "vstore" }
    if op == 95 { return "vload" }
    if op == 96 { return "asm_block" }
    if op == 97 { return "fsqrt" }
    if op == 98 { return "ffma" }
    if op == 99 { return "fcmp_ne" }
    if op == 100 { return "fcmp_le" }
    if op == 101 { return "fcmp_gt" }
    if op == 102 { return "fcmp_ge" }
    if op == 103 { return "f32tof64" }
    if op == 104 { return "f64tof32" }
    if op == 105 { return "f32tof16" }
    if op == 106 { return "f16tof32" }
    if op == 107 { return "itof32" }
    if op == 108 { return "ftoi32" }
    if op == 109 { return "atomic_sub" }
    if op == 110 { return "atomic_and" }
    if op == 111 { return "atomic_or" }
    if op == 112 { return "atomic_xor" }
    if op == 113 { return "exec" }
    if op == 114 { return "exec_argv" }
    if op == 115 { return "set_exec" }
    if op == 118 { return "fsqrt32" }
    if op == 119 { return "time_ns" }
    if op == 126 { return "isb" }
    if op == 127 { return "dcache_flush" }
    if op == 128 { return "icache_invalidate" }
    if op == 129 { return "dsb" }
    if op == 130 { return "dmb" }
    if op == 131 { return "arr_check" }
    if op == 120 { return "scmp_lt" }
    if op == 121 { return "scmp_le" }
    if op == 122 { return "scmp_gt" }
    if op == 123 { return "scmp_ge" }
    if op == 132 { return "sdiv" }
    if op == 133 { return "smod" }
    if op == 134 { return "sar" }
    return "???"
}

@export
fn ir_dump() {
    uint8[24] nbuf
    uint64 bi = 0
    while bi < ir_bb_count {
        write(1, "  bb", 4)
        uint64 nlen = fmt_uint(nbuf, bi)
        write(1, nbuf, nlen)
        write(1, ":\n", 2)
        uint64 ii = ir_bb_first_insn(bi)
        while ii != 0xFFFFFFFF {
            uint64 op = ir_insn_opcode(ii)
            uint64 dest = ir_insn_dest(ii)
            uint64 s1 = ir_insn_src1(ii)
            uint64 s2 = ir_insn_src2(ii)
            uint64 imm = ir_insn_imm(ii)
            write(1, "    ", 4)
            // Print dest for value-producing ops
            if op != 40 && op != 41 && op != 43 && op != 31 && op != 51 {
                write(1, "v", 1)
                nlen = fmt_uint(nbuf, dest)
                write(1, nbuf, nlen)
                write(1, " = ", 3)
            }
            // Print opcode name
            uint64 oname = ir_opcode_name(op)
            write(1, oname, str_len(oname))
            // Print operands based on opcode type
            if op == 1 {
                // const: just immediate
                write(1, " ", 1)
                nlen = fmt_uint(nbuf, imm)
                write(1, nbuf, nlen)
            } else if op == 40 {
                // br: target block
                write(1, " bb", 3)
                nlen = fmt_uint(nbuf, imm)
                write(1, nbuf, nlen)
            } else if op == 41 {
                // br_cond: cond, target block
                write(1, " v", 2)
                nlen = fmt_uint(nbuf, s1)
                write(1, nbuf, nlen)
                write(1, ", bb", 4)
                nlen = fmt_uint(nbuf, imm)
                write(1, nbuf, nlen)
            } else if op == 42 {
                // ret: source
                write(1, " v", 2)
                nlen = fmt_uint(nbuf, s1)
                write(1, nbuf, nlen)
            } else if op == 43 {
                // ret_void: nothing
            } else if op == 51 {
                // arg: source, index
                write(1, " v", 2)
                nlen = fmt_uint(nbuf, s1)
                write(1, nbuf, nlen)
                write(1, " [", 2)
                nlen = fmt_uint(nbuf, imm)
                write(1, nbuf, nlen)
                write(1, "]", 1)
            } else if op == 52 {
                // syscall: number
                write(1, " #", 2)
                nlen = fmt_uint(nbuf, imm)
                write(1, nbuf, nlen)
            } else if op == 50 {
                // call: func token in imm
                write(1, " @", 2)
                nlen = fmt_uint(nbuf, imm)
                write(1, nbuf, nlen)
            } else if op == 61 {
                // copy: source (param index in imm for params)
                if s1 != 0 {
                    write(1, " v", 2)
                    nlen = fmt_uint(nbuf, s1)
                    write(1, nbuf, nlen)
                } else {
                    write(1, " param[", 7)
                    nlen = fmt_uint(nbuf, imm)
                    write(1, nbuf, nlen)
                    write(1, "]", 1)
                }
            } else if op == 72 || op == 76 {
                // memcpy/memset: src1, src2, imm(vreg)
                write(1, " v", 2)
                nlen = fmt_uint(nbuf, s1)
                write(1, nbuf, nlen)
                write(1, ", v", 3)
                nlen = fmt_uint(nbuf, s2)
                write(1, nbuf, nlen)
                write(1, ", v", 3)
                nlen = fmt_uint(nbuf, imm)
                write(1, nbuf, nlen)
            } else {
                // Binary ops: src1, src2
                write(1, " v", 2)
                nlen = fmt_uint(nbuf, s1)
                write(1, nbuf, nlen)
                write(1, ", v", 3)
                nlen = fmt_uint(nbuf, s2)
                write(1, nbuf, nlen)
            }
            write(1, "\n", 1)
            ii = ir_insn_next(ii)
        }
        bi = bi + 1
    }
}

fn ir_lower_block(uint64 block_node) {
    if block_node == 0 { return }
    uint32 child = ast_child(block_node)
    uint64 wchild = child
    while wchild != 0 {
        ir_lower_stmt(wchild)
        uint32 nxt = ast_next(wchild)
        wchild = nxt
    }
}

// ---------------------------------------------------------------------------
// Defer stack — a function-scoped LIFO of `defer { ... }` block AST pointers.
// When we see a Defer stmt we stash the block here instead of lowering it.
// At every function-exit point (return, implicit tail-return) we lower the
// recorded blocks in reverse-declaration order right before the IR_RET*
// instruction is emitted.
// ---------------------------------------------------------------------------
static uint64 ir_defer_stack = 0
static uint64 ir_defer_count = 0
static uint64 ir_defer_cap = 0

fn ir_defer_reset() {
    if ir_defer_stack == 0 {
        ir_defer_cap = 32
        ir_defer_stack = alloc(ir_defer_cap * 4)
    }
    ir_defer_count = 0
}

fn ir_defer_push(uint64 body_node) {
    if ir_defer_count >= ir_defer_cap { return }
    uint64 slot = ir_defer_stack + ir_defer_count * 4
    uint32 b32 = body_node
    unsafe { *(slot as uint32) = b32 }
    ir_defer_count = ir_defer_count + 1
}

// Emit every pending defer body in LIFO order without popping them —
// a function may have multiple return sites, and every one of them must
// see the full defer chain. ir_defer_reset clears the stack between
// functions.
fn ir_defer_emit_all() {
    if ir_defer_count == 0 { return }
    uint64 i = ir_defer_count
    while i > 0 {
        i = i - 1
        uint64 slot = ir_defer_stack + i * 4
        uint32 b32 = 0
        unsafe { *(slot as uint32) -> b32 }
        uint64 body = b32
        if body != 0 { ir_lower_block(body) }
    }
}

// ---------------------------------------------------------------------------
// Function lowering
// ---------------------------------------------------------------------------

fn ir_lower_function(uint64 fn_node) {
    ir_reset()
    ir_var_map_init()
    ir_defer_reset()
    // struct_var_table is per-function: a variable named `w` typed as
    // struct A in fn f() must NOT leak into fn g() where `w` is typed as
    // struct B. Without this reset, struct_var_lookup(w) in g() would
    // return A's struct index (registered first), so g.field accesses
    // would compute the wrong byte offset (or 0xFFFFFFFF if A lacks the
    // field, which then resolves to a garbage offset). See
    // examples/codegen_struct_var_collision.mlr.
    struct_var_count = 0
    ir_current_bb = ir_new_bb()  // entry block

    // Register parameters
    uint32 param = ast_child(fn_node)
    uint64 wparam = param
    uint64 param_idx = 0
    while wparam != 0 {
        uint32 pk = ast_kind(wparam)
        if pk == 3 {
            uint32 pname = ast_data2(wparam)
            uint64 pvreg = ir_new_vreg()
            ir_emit(IR_COPY, pvreg, 0, 0, param_idx, ir_current_bb)
            ir_var_set(pname, pvreg)
            param_idx = param_idx + 1
            // If param type is float, set float kind
            uint32 param_type = ast_data1(wparam)
            uint64 wpt = param_type
            uint64 ptk = tok_kind_at_raw(wpt)
            if ptk == 96 { ir_vreg_fkind_set(pvreg, 1) }
            if ptk == 95 { ir_vreg_fkind_set(pvreg, 2) }
            // If param type is a struct, register it so field access works
            uint64 psi = struct_lookup(wpt)
            if psi != 0xFFFFFFFF {
                struct_var_register(pname, psi)
            }
            // Slice parameter: also register the length from next register
            uint32 pflag = ast_data4(wparam)
            uint64 wpflag = pflag
            if wpflag == 1 {
                uint64 len_vreg = ir_new_vreg()
                ir_emit(IR_COPY, len_vreg, 0, 0, param_idx, ir_current_bb)
                ir_slice_len_set(pname, len_vreg)
                param_idx = param_idx + 1
            }
        }
        uint32 pnxt = ast_next(wparam)
        wparam = pnxt
    }

    // Lower body
    uint32 body = ast_data3(fn_node)
    uint64 wbody = body
    if wbody != 0 { ir_lower_block(wbody) }

    // Ensure the function ends with a return instruction.
    // If the last block doesn't end with IR_RET/IR_RET_VOID/IR_RET2/IR_RET3,
    // run pending defers (in LIFO order) and then add an implicit
    // IR_RET_VOID so the epilogue is always reached.
    uint64 need_tail = 1
    if ir_insn_count > 0 {
        uint64 last_op = ir_insn_opcode(ir_insn_count - 1)
        if last_op == 42 || last_op == 43 || last_op == 82 || last_op == 83 {
            need_tail = 0
        }
    }
    if need_tail != 0 {
        ir_defer_emit_all()
        ir_emit(IR_RET_VOID, 0, 0, 0, 0, ir_current_bb)
    }
}

// ---------------------------------------------------------------------------
// Liveness analysis — iterative dataflow with bitset live-in/live-out
// ---------------------------------------------------------------------------

static uint64 ir_live_in = 0      // bitset per block: ir_live_in + bb * set_bytes
static uint64 ir_live_out = 0     // bitset per block
static uint64 ir_live_tmp = 0     // scratch set, reused per BB in liveness loop
static uint64 ir_live_tmp_cap = 0
static uint64 ir_live_words = 0   // uint64 words per bitset = ceil(vreg_count / 64)
static uint64 ir_live_cap = 0     // bytes allocated for each of live_in/out

fn ir_liveness_init() {
    ir_live_words = (ir_vreg_next + 63) / 64
    if ir_live_words == 0 { ir_live_words = 1 }
    uint64 set_bytes = ir_live_words * 8
    uint64 total = ir_bb_count * set_bytes

    // Oversize once to worst-case: 4096 BBs * 1024 words * 8 B = 32 MB
    // per bitset. In practice per-function peak is far smaller; this fits
    // every krc.kr function at the time of writing.
    if ir_live_cap == 0 {
        ir_live_cap = 4096 * 1024 * 8
        ir_live_in = alloc(ir_live_cap)
        ir_live_out = alloc(ir_live_cap)
    }
    if total > ir_live_cap {
        write(2, "error: liveness bitset overflow\n", 32)
        exit(1)
    }
    memset(ir_live_in, 0, total)
    memset(ir_live_out, 0, total)
}

fn ir_live_set(uint64 base, uint64 bb, uint64 vreg) {
    uint64 set_bytes = ir_live_words * 8
    uint64 word = vreg / 64
    uint64 bit = vreg & 63
    uint64 p = base + bb * set_bytes + word * 8
    uint64 val = 0
    unsafe { *(p as uint64) -> val }
    val = val | (1 << bit)
    unsafe { *(p as uint64) = val }
}

fn ir_live_clear(uint64 base, uint64 bb, uint64 vreg) {
    uint64 set_bytes = ir_live_words * 8
    uint64 word = vreg / 64
    uint64 bit = vreg & 63
    uint64 p = base + bb * set_bytes + word * 8
    uint64 val = 0
    unsafe { *(p as uint64) -> val }
    val = val & ~(1 << bit)
    unsafe { *(p as uint64) = val }
}

fn ir_live_test(uint64 base, uint64 bb, uint64 vreg) -> uint64 {
    uint64 set_bytes = ir_live_words * 8
    uint64 word = vreg / 64
    uint64 bit = vreg & 63
    uint64 p = base + bb * set_bytes + word * 8
    uint64 val = 0
    unsafe { *(p as uint64) -> val }
    return (val >> bit) & 1
}

// Check whether an instruction defines (produces) a vreg.
fn ir_insn_has_def(uint64 ii) -> uint64 {
    uint64 op = ir_insn_opcode(ii)
    if op == 0  { return 0 }   // NOP — LICM blanks hoisted insns by clearing opcode
    if op == 40 { return 0 }   // br
    if op == 41 { return 0 }   // br_cond
    if op == 43 { return 0 }   // ret_void
    if op == 31 { return 0 }   // store
    if op == 51 { return 0 }   // arg (no value produced)
    if op == 71 { return 0 }   // dealloc (no value produced)
    // memset DOES produce a value (returns dst pointer); do NOT mark it as no-def
    if op == 78 { return 0 }   // static_store (no value produced)
    if op == 82 { return 0 }   // ret2 (no value produced)
    if op == 83 { return 0 }   // ret3 (no value produced)
    if op == 90 { return 0 }   // atomic_store (no value produced)
    if op == 94 { return 0 }   // vstore (no value produced)
    return 1
}

// Iterative dataflow: compute live-in and live-out for every basic block.
@export
fn ir_compute_liveness() {
    ir_liveness_init()
    uint64 set_bytes = ir_live_words * 8
    uint64 changed = 1
    while changed != 0 {
        changed = 0
        uint64 bi = ir_bb_count
        while bi > 0 {
            bi = bi - 1
            // Step 1: live_out[bi] = union of live_in[succ] for each successor
            uint64 s0 = ir_bb_succ0(bi)
            uint64 s1 = ir_bb_succ1(bi)
            uint64 wi = 0
            while wi < ir_live_words {
                uint64 out_val = 0
                if s0 != 0xFFFFFFFF {
                    uint64 p_s0 = ir_live_in + s0 * set_bytes + wi * 8
                    uint64 v0 = 0
                    unsafe { *(p_s0 as uint64) -> v0 }
                    out_val = out_val | v0
                }
                if s1 != 0xFFFFFFFF {
                    uint64 p_s1 = ir_live_in + s1 * set_bytes + wi * 8
                    uint64 v1 = 0
                    unsafe { *(p_s1 as uint64) -> v1 }
                    out_val = out_val | v1
                }
                uint64 p_out = ir_live_out + bi * set_bytes + wi * 8
                unsafe { *(p_out as uint64) = out_val }
                wi = wi + 1
            }

            // Step 2: Start with live_out, walk instructions backwards
            // Copy live_out to a temp set. tmp is a static scratch buffer
            // reused across BBs and across liveness iterations — the
            // dataflow loop visits every BB many times before converging,
            // so per-BB alloc/dealloc overhead is significant.
            if set_bytes > ir_live_tmp_cap {
                if ir_live_tmp != 0 { dealloc(ir_live_tmp) }
                ir_live_tmp = alloc(set_bytes)
                ir_live_tmp_cap = set_bytes
            }
            uint64 tmp = ir_live_tmp
            uint64 ci = 0
            while ci < set_bytes {
                uint64 ps = ir_live_out + bi * set_bytes + ci
                uint64 pd = tmp + ci
                uint64 bv = 0
                unsafe { *(ps as uint8) -> bv }
                uint8 bb = bv
                unsafe { *(pd as uint8) = bb }
                ci = ci + 1
            }

            // Walk instructions in reverse order within this block.
            // Used to assume consecutive indices (first_insn..last_insn),
            // but LICM appends hoisted insns to the global tail and just
            // splices them into the BB's linked list. Walk the actual
            // linked list forward into a stack, then unwind.
            uint64 blk_first = ir_bb_first_insn(bi)
            uint64 lv_done = 0
            if blk_first == 0xFFFFFFFF { lv_done = 1 }
            if ir_walk_stack == 0 { ir_walk_stack = alloc(65536 * 4) }
            uint64 lv_stack_n = 0
            uint64 lv_walk = blk_first
            while lv_walk != 0xFFFFFFFF && lv_stack_n < 65536 {
                uint64 sp_ent = ir_walk_stack + lv_stack_n * 4
                uint32 lw32 = lv_walk
                unsafe { *(sp_ent as uint32) = lw32 }
                lv_stack_n = lv_stack_n + 1
                lv_walk = ir_insn_next(lv_walk)
            }
            while lv_stack_n > 0 && lv_done == 0 {
                lv_stack_n = lv_stack_n - 1
                uint64 sp_ent = ir_walk_stack + lv_stack_n * 4
                uint32 cur32 = 0
                unsafe { *(sp_ent as uint32) -> cur32 }
                uint64 cur_ii = cur32

                // Remove def
                if ir_insn_has_def(cur_ii) != 0 {
                    uint64 def_v = ir_insn_dest(cur_ii)
                    if def_v < ir_vreg_next {
                        uint64 dw = def_v / 64
                        uint64 db = def_v & 63
                        uint64 dp = tmp + dw * 8
                        uint64 dv = 0
                        unsafe { *(dp as uint64) -> dv }
                        dv = dv & ~(1 << db)
                        unsafe { *(dp as uint64) = dv }
                    }
                }

                // Add src1 use
                uint64 op = ir_insn_opcode(cur_ii)
                if op == 0 {
                    // LICM-elided slot — no def, no uses.
                    continue
                }
                uint64 use1 = ir_insn_src1(cur_ii)
                if use1 < ir_vreg_next && op != 1 {
                    uint64 uw = use1 / 64
                    uint64 ub = use1 & 63
                    uint64 up = tmp + uw * 8
                    uint64 uv = 0
                    unsafe { *(up as uint64) -> uv }
                    uv = uv | (1 << ub)
                    unsafe { *(up as uint64) = uv }
                }

                // Add src2 use
                uint64 use2 = ir_insn_src2(cur_ii)
                if use2 < ir_vreg_next && op != 1 && op != 12 && op != 13 && op != 30 && op != 42 && op != 61 && op != 135 && op != 136 && op != 138 {
                    uint64 uw = use2 / 64
                    uint64 ub = use2 & 63
                    uint64 up = tmp + uw * 8
                    uint64 uv = 0
                    unsafe { *(up as uint64) -> uv }
                    uv = uv | (1 << ub)
                    unsafe { *(up as uint64) = uv }
                }

                // Add imm-as-vreg use for MEMCPY(72), MEMSET(76), RET3(83), ATOMIC_CAS(93), FFMA(98)
                if op == 72 || op == 76 || op == 83 || op == 93 || op == 98 {
                    uint64 use_imm = ir_insn_imm(cur_ii)
                    if use_imm < ir_vreg_next && use_imm > 0 {
                        uint64 iw = use_imm / 64
                        uint64 ib = use_imm & 63
                        uint64 ip = tmp + iw * 8
                        uint64 iv = 0
                        unsafe { *(ip as uint64) -> iv }
                        iv = iv | (1 << ib)
                        unsafe { *(ip as uint64) = iv }
                    }
                }

            }

            // Check if live_in changed
            ci = 0
            while ci < set_bytes {
                uint64 p_old = ir_live_in + bi * set_bytes + ci
                uint64 p_new = tmp + ci
                uint64 ov = 0
                uint64 nv = 0
                unsafe { *(p_old as uint8) -> ov }
                unsafe { *(p_new as uint8) -> nv }
                if ov != nv { changed = 1 }
                uint8 nb = nv
                unsafe { *(p_old as uint8) = nb }
                ci = ci + 1
            }
        }
    }
}

// Populate ir_use_count_buf with saturating (0..255) counts of how many
// times each vreg is read. Uses the same "is src a vreg?" filter as
// ir_compute_liveness so we don't spuriously count token IDs or immediate
// fields. Runs once per function before x86 emission and is consumed by
// the CMP+JCC fusion peephole.
fn ir_compute_use_count() {
    if ir_use_count_buf == 0 { return }
    memset(ir_use_count_buf, 0, ir_use_count_cap)
    uint64 i = 0
    while i < ir_insn_count {
        uint64 op = ir_insn_opcode(i)
        uint64 s1 = ir_insn_src1(i)
        if s1 != 0 && s1 < ir_vreg_next && s1 < ir_use_count_cap && op != 1 {
            uint64 p = ir_use_count_buf + s1
            uint8 c = 0
            unsafe { *(p as uint8) -> c }
            if c < 255 {
                uint64 nc = c
                nc = nc + 1
                uint8 nc8 = nc
                unsafe { *(p as uint8) = nc8 }
            }
        }
        uint64 s2 = ir_insn_src2(i)
        if s2 != 0 && s2 < ir_vreg_next && s2 < ir_use_count_cap && op != 1 && op != 12 && op != 13 && op != 30 && op != 42 && op != 61 && op != 135 && op != 136 && op != 138 {
            uint64 p = ir_use_count_buf + s2
            uint8 c = 0
            unsafe { *(p as uint8) -> c }
            if c < 255 {
                uint64 nc = c
                nc = nc + 1
                uint8 nc8 = nc
                unsafe { *(p as uint8) = nc8 }
            }
        }
        if op == 72 || op == 76 || op == 83 || op == 93 || op == 98 {
            uint64 s3 = ir_insn_imm(i)
            if s3 != 0 && s3 < ir_vreg_next && s3 < ir_use_count_cap {
                uint64 p = ir_use_count_buf + s3
                uint8 c = 0
                unsafe { *(p as uint8) -> c }
                if c < 255 {
                    uint64 nc = c
                    nc = nc + 1
                    uint8 nc8 = nc
                    unsafe { *(p as uint8) = nc8 }
                }
            }
        }
        i = i + 1
    }
}

fn ir_use_count_get(uint64 vreg) -> uint64 {
    if vreg >= ir_use_count_cap { return 255 }
    uint64 p = ir_use_count_buf + vreg
    uint8 c = 0
    unsafe { *(p as uint8) -> c }
    return c
}

// Returns the short-jcc opcode (0x84..0x8F) if the CMP instruction at
// `cmp_idx` should be fused into a direct conditional branch with the
// BB terminator. Returns 0 if no fusion is possible. Conditions:
//   - cmp_idx's opcode is IR_CMP_EQ..IR_CMP_GE (14..19) or
//     IR_SCMP_LT..IR_SCMP_GE (120..123)
//   - The next instruction in the BB is the terminator, opcode 41
//     (IR_BR_COND), and its src1 equals the cmp's destination
//   - The cmp result has exactly one use (i.e., this BR_COND)
fn ir_cmp_fuse_code(uint64 cmp_idx) -> uint64 {
    uint64 op = ir_insn_opcode(cmp_idx)
    if (op < 14 || op > 19) && (op < 120 || op > 123) { return 0 }
    uint64 nxt = ir_insn_next(cmp_idx)
    if nxt == 0xFFFFFFFF { return 0 }
    uint64 nop = ir_insn_opcode(nxt)
    if nop != 41 { return 0 }
    uint64 dst = ir_insn_dest(cmp_idx)
    uint64 cond_v = ir_insn_src1(nxt)
    if cond_v != dst { return 0 }
    if ir_use_count_get(dst) != 1 { return 0 }
    // Map cmp opcode → short jcc opcode (second byte after 0x0F).
    // Unsigned:  EQ(14)→0x84, NE(15)→0x85, LT(16)→0x82, LE(17)→0x86,
    //            GT(18)→0x87, GE(19)→0x83
    // Signed:    LT(120)→0x8C, LE(121)→0x8E, GT(122)→0x8F, GE(123)→0x8D
    if op == 14  { return 0x84 }
    if op == 15  { return 0x85 }
    if op == 16  { return 0x82 }
    if op == 17  { return 0x86 }
    if op == 18  { return 0x87 }
    if op == 19  { return 0x83 }
    if op == 120 { return 0x8C }
    if op == 121 { return 0x8E }
    if op == 122 { return 0x8F }
    if op == 123 { return 0x8D }
    return 0
}

// ---------------------------------------------------------------------------
// Register allocator — greedy coloring
// ---------------------------------------------------------------------------

static uint64 IR_NUM_REGS = 6

// Map color index -> physical register code
// Colors 0-5 -> rbx(3), r12(12), r13(13), r14(14), r15(15), rbp(5)
// Only callee-saved registers — safe across function calls.
static uint64 ir_phys_regs = 0

// Bitmask of callee-saved colours actually used by the current
// function — populated by the prologue, consumed by the epilogue so
// the pop sequence mirrors the push sequence.
static uint64 ir_used_callee_mask = 0

// Bytes pushed by the prologue's callee-save sequence (popcount(mask)*8).
// Caller-arg overflow loads (param index >= 6) need to skip past these
// bytes plus the return address to reach the caller's stack args.
static uint64 ir_callee_save_bytes = 0

// Briggs-conservative copy coalescing. A candidate `dst = src` is
// merged only if the combined interference set has fewer than
// K = IR_NUM_REGS neighbours of significant degree (>= K). That keeps
// the merged node K-colourable in isolation, so coalescing never forces
// a spill that wouldn't have happened otherwise. ir_uf_deg caches
// per-vreg neighbour counts and is updated incrementally as merges
// happen. Enabled by default; --no-coalesce disables.
static uint64 ir_uf_parent = 0
static uint64 ir_uf_cap = 0
static uint64 ir_uf_deg = 0
static uint64 ir_uf_deg_cap = 0
static uint64 ir_coalesce_enabled = 1

@export fn ir_set_coalesce(uint64 v) { ir_coalesce_enabled = v }

// Popcount of one 64-bit word, branchless.
fn ir_popcount64(uint64 x) -> uint64 {
    x = x - ((x >> 1) & 0x5555555555555555)
    x = (x & 0x3333333333333333) + ((x >> 2) & 0x3333333333333333)
    x = (x + (x >> 4)) & 0x0F0F0F0F0F0F0F0F
    return (x * 0x0101010101010101) >> 56
}

fn ir_uf_find(uint64 v) -> uint64 {
    uint64 cur = v
    while 1 == 1 {
        uint64 pp = ir_uf_parent + cur * 4
        uint32 pw = 0
        unsafe { *(pp as uint32) -> pw }
        uint64 par = pw
        if par == cur { break }
        cur = par
    }
    // Path compression — flatten so future lookups are O(1).
    uint64 walk = v
    while walk != cur {
        uint64 pp2 = ir_uf_parent + walk * 4
        uint32 pw2 = 0
        unsafe { *(pp2 as uint32) -> pw2 }
        uint64 next = pw2
        uint32 cw = cur
        unsafe { *(pp2 as uint32) = cw }
        walk = next
    }
    return cur
}

fn ir_regalloc_init() {
    if ir_phys_regs == 0 { ir_phys_regs = alloc(10 * 8) }
    uint64 p0 = ir_phys_regs
    unsafe { *(p0 as uint64) = 3 }
    uint64 p1 = ir_phys_regs + 8
    unsafe { *(p1 as uint64) = 12 }
    uint64 p2 = ir_phys_regs + 16
    unsafe { *(p2 as uint64) = 13 }
    uint64 p3 = ir_phys_regs + 24
    unsafe { *(p3 as uint64) = 14 }
    uint64 p4 = ir_phys_regs + 32
    unsafe { *(p4 as uint64) = 15 }
    uint64 p5 = ir_phys_regs + 40
    unsafe { *(p5 as uint64) = 5 }       // rbp
}

// Register assignment table: [color(4)] x vreg_count. 0xFFFFFFFF = spilled
static uint64 ir_reg_assign = 0
static uint64 ir_reg_assign_cap = 0
static uint64 ir_ig_buf = 0
static uint64 ir_ig_cap = 0
static uint64 ir_color_tmp_buf = 0
static uint64 ir_color_tmp_cap = 0

fn ir_get_phys_reg(uint64 vreg) -> uint64 {
    if vreg == 0 { return 0xFFFFFFFF }
    if vreg >= ir_vreg_next { return 0xFFFFFFFF }
    uint64 p = ir_reg_assign + vreg * 4
    uint32 color = 0
    unsafe { *(p as uint32) -> color }
    uint64 wcolor = color
    if wcolor >= IR_NUM_REGS { return 0xFFFFFFFF }
    uint64 rp = ir_phys_regs + wcolor * 8
    uint64 phys = 0
    unsafe { *(rp as uint64) -> phys }
    return phys
}

// Used-callee-save mask. After regalloc, returns a 6-bit set with bit i
// set iff some vreg got color i (= one of rbx/r12/r13/r14/r15/rbp). Lets
// the prologue/epilogue push only what's actually used — fib(40) burns
// ~330M calls, each with 5 push+pop pairs even when only 3 colours are
// live. Trimming the prologue saves ~2 stack writes + 2 reads per call.
fn ir_used_color_mask() -> uint64 {
    uint64 mask = 0
    uint64 v = 1
    while v < ir_vreg_next {
        uint64 p = ir_reg_assign + v * 4
        uint32 color = 0
        unsafe { *(p as uint32) -> color }
        uint64 wc = color
        if wc < IR_NUM_REGS {
            mask = mask | (1 << wc)
        }
        v = v + 1
    }
    return mask
}

// Interference-based register allocator using liveness data.
// Uses the already-computed live-in/live-out bitsets to build an interference
// graph, then greedily colors vregs. Two vregs interfere if they're both
// live at any instruction point (def interferes with all live-out except itself).
fn ir_graph_color() {
    uint64 vcount = ir_vreg_next
    if vcount == 0 { return }

    // Register-assignment table — oversized to 65536 vregs once (256 KB).
    if ir_reg_assign_cap == 0 {
        ir_reg_assign_cap = 65536
        ir_reg_assign = alloc(ir_reg_assign_cap * 4)
    }
    if vcount > ir_reg_assign_cap {
        write(2, "error: vreg count exceeds ir_reg_assign capacity\n", 49)
        exit(1)
    }

    // Interference bitmatrix — vreg x vreg bits. Oversized once to
    // 65536 * 1024 words = 512 MB worst case. Per-function peak is far
    // smaller; only zero the region actually in use.
    uint64 row_words = (vcount + 63) / 64
    uint64 row_bytes = row_words * 8
    uint64 ig_needed = vcount * row_bytes
    if ir_ig_buf == 0 {
        ir_ig_cap = 65536 * 1024 * 8
        ir_ig_buf = alloc(ir_ig_cap)
    }
    if ig_needed > ir_ig_cap {
        write(2, "error: interference graph overflow\n", 35)
        exit(1)
    }
    uint64 ig = ir_ig_buf
    memset(ig, 0, ig_needed)

    // Live-set scratch buffer — 1024 words * 8 B = 8 KB once.
    uint64 set_bytes = ir_live_words * 8
    if ir_color_tmp_buf == 0 {
        ir_color_tmp_cap = 1024 * 8
        ir_color_tmp_buf = alloc(ir_color_tmp_cap)
    }
    if set_bytes > ir_color_tmp_cap {
        write(2, "error: color tmp buffer overflow\n", 33)
        exit(1)
    }
    uint64 tmp = ir_color_tmp_buf

    uint64 bi = 0
    while bi < ir_bb_count {
        // Start with live_out for this block
        uint64 wi = 0
        while wi < ir_live_words {
            uint64 sp = ir_live_out + bi * set_bytes + wi * 8
            uint64 dp = tmp + wi * 8
            uint64 v = 0
            unsafe { *(sp as uint64) -> v }
            unsafe { *(dp as uint64) = v }
            wi = wi + 1
        }

        // Walk instructions in reverse order within this block.
        // Walk linked list forward into a stack, then unwind — LICM
        // hoists out-of-order in the global insn array, so consecutive
        // index ranges don't reflect the BB membership.
        uint64 first = ir_bb_first_insn(bi)
        if first != 0xFFFFFFFF {
            if ir_walk_stack == 0 { ir_walk_stack = alloc(65536 * 4) }
            uint64 ig_stack_n = 0
            uint64 ig_walk = first
            while ig_walk != 0xFFFFFFFF && ig_stack_n < 65536 {
                uint64 sp_ent = ir_walk_stack + ig_stack_n * 4
                uint32 lw32 = ig_walk
                unsafe { *(sp_ent as uint32) = lw32 }
                ig_stack_n = ig_stack_n + 1
                ig_walk = ir_insn_next(ig_walk)
            }
            uint64 ig_done = 0
            while ig_stack_n > 0 && ig_done == 0 {
                ig_stack_n = ig_stack_n - 1
                uint64 sp_ent = ir_walk_stack + ig_stack_n * 4
                uint32 ii32 = 0
                unsafe { *(sp_ent as uint32) -> ii32 }
                uint64 ii = ii32

                // At this instruction, the dest vreg interferes with
                // everything currently live (except itself and copy sources)
                uint64 op = ir_insn_opcode(ii)
                if op == 0 { continue }   // LICM-elided slot
                if ir_insn_has_def(ii) != 0 {
                    uint64 dv = ir_insn_dest(ii)
                    if dv > 0 && dv < vcount {
                        // Add interference: dv <-> each live vreg
                        uint64 lw = 0
                        while lw < ir_live_words {
                            uint64 lp = tmp + lw * 8
                            uint64 lbits = 0
                            unsafe { *(lp as uint64) -> lbits }
                            // For each set bit, add interference
                            uint64 bits = lbits
                            while bits != 0 {
                                // Find lowest set bit
                                uint64 bit_pos = 0
                                uint64 test = bits
                                while (test & 1) == 0 {
                                    test = test >> 1
                                    bit_pos = bit_pos + 1
                                }
                                uint64 other = lw * 64 + bit_pos
                                if other != dv && other < vcount {
                                    // Set ig[dv][other] and ig[other][dv]
                                    uint64 r1 = ig + dv * row_bytes + (other / 64) * 8
                                    uint64 v1 = 0
                                    unsafe { *(r1 as uint64) -> v1 }
                                    v1 = v1 | (1 << (other & 63))
                                    unsafe { *(r1 as uint64) = v1 }
                                    uint64 r2 = ig + other * row_bytes + (dv / 64) * 8
                                    uint64 v2 = 0
                                    unsafe { *(r2 as uint64) -> v2 }
                                    v2 = v2 | (1 << (dv & 63))
                                    unsafe { *(r2 as uint64) = v2 }
                                }
                                // Clear this bit
                                bits = bits & ~(1 << bit_pos)
                            }
                            lw = lw + 1
                        }
                        // Remove dv from live set
                        uint64 dw = dv / 64
                        uint64 db = dv & 63
                        uint64 dp = tmp + dw * 8
                        uint64 dval = 0
                        unsafe { *(dp as uint64) -> dval }
                        dval = dval & ~(1 << db)
                        unsafe { *(dp as uint64) = dval }
                    }
                }

                // Add uses to live set
                uint64 u1 = ir_insn_src1(ii)
                if u1 > 0 && u1 < vcount && op != 1 && op != 79 {
                    uint64 uw = u1 / 64
                    uint64 ub = u1 & 63
                    uint64 up = tmp + uw * 8
                    uint64 uv = 0
                    unsafe { *(up as uint64) -> uv }
                    uv = uv | (1 << ub)
                    unsafe { *(up as uint64) = uv }
                }
                uint64 u2 = ir_insn_src2(ii)
                if u2 > 0 && u2 < vcount && op != 1 && op != 12 && op != 13 && op != 30 && op != 42 && op != 61 && op != 135 && op != 136 && op != 138 {
                    uint64 uw = u2 / 64
                    uint64 ub = u2 & 63
                    uint64 up = tmp + uw * 8
                    uint64 uv = 0
                    unsafe { *(up as uint64) -> uv }
                    uv = uv | (1 << ub)
                    unsafe { *(up as uint64) = uv }
                }

                // Add imm-as-vreg use for MEMCPY(72), MEMSET(76), RET3(83), ATOMIC_CAS(93), FFMA(98)
                if op == 72 || op == 76 || op == 83 || op == 93 || op == 98 {
                    uint64 uimm = ir_insn_imm(ii)
                    if uimm > 0 && uimm < vcount {
                        uint64 uw = uimm / 64
                        uint64 ub = uimm & 63
                        uint64 up = tmp + uw * 8
                        uint64 uv = 0
                        unsafe { *(up as uint64) -> uv }
                        uv = uv | (1 << ub)
                        unsafe { *(up as uint64) = uv }
                    }
                }

            }
        }
        bi = bi + 1
    }

    // ----- Copy coalescing (Briggs + George, default-on) -----
    // For each IR_COPY (op 61) with a real src1 (i.e. reg-reg copy, not
    // a param load), if dest and src1 don't already interfere AND the
    // Briggs/George heuristic would let the merged class stay
    // K-colourable, union them in ir_uf_parent so the greedy colorer
    // assigns them the same colour. The redundant `mov rN, rN` is
    // dropped by the emitter's dst==src short-circuit.
    if ir_uf_cap < vcount {
        if ir_uf_parent != 0 { dealloc(ir_uf_parent) }
        ir_uf_cap = vcount
        if ir_uf_cap < 64 { ir_uf_cap = 64 }
        ir_uf_parent = alloc(ir_uf_cap * 4)
    }
    uint64 ufi = 0
    while ufi < vcount {
        uint64 ufp = ir_uf_parent + ufi * 4
        uint32 ufv = ufi
        unsafe { *(ufp as uint32) = ufv }
        ufi = ufi + 1
    }

    // Degree cache for Briggs: deg[v] = popcount(row[v]). Followers'
    // entries are kept in sync with their rep until they're absorbed.
    if ir_uf_deg_cap < vcount {
        if ir_uf_deg != 0 { dealloc(ir_uf_deg) }
        ir_uf_deg_cap = vcount
        if ir_uf_deg_cap < 64 { ir_uf_deg_cap = 64 }
        ir_uf_deg = alloc(ir_uf_deg_cap * 4)
    }
    uint64 dgi = 0
    while dgi < vcount {
        uint64 dsum = 0
        uint64 dw = 0
        while dw < row_words {
            uint64 dpp = ig + dgi * row_bytes + dw * 8
            uint64 dvv = 0
            unsafe { *(dpp as uint64) -> dvv }
            dsum = dsum + ir_popcount64(dvv)
            dw = dw + 1
        }
        uint64 dgp = ir_uf_deg + dgi * 4
        uint32 dg32 = dsum
        unsafe { *(dgp as uint32) = dg32 }
        dgi = dgi + 1
    }

    uint64 cii = 0
    while cii < ir_insn_count && ir_coalesce_enabled != 0 {
        uint64 cop = ir_insn_opcode(cii)
        if cop == 61 {
            uint64 cdv = ir_insn_dest(cii)
            uint64 csv = ir_insn_src1(cii)
            if cdv != 0 && csv != 0 && cdv < vcount && csv < vcount {
                uint64 crd = ir_uf_find(cdv)
                uint64 crs = ir_uf_find(csv)
                if crd != crs {
                    // Test interference: bit (crs & 63) in row[crd] word (crs/64).
                    uint64 cip = ig + crd * row_bytes + (crs / 64) * 8
                    uint64 civ = 0
                    unsafe { *(cip as uint64) -> civ }
                    uint64 inter = (civ >> (crs & 63)) & 1
                    if inter == 0 {
                        // Always make the LOWER vreg the rep so it gets
                        // coloured first in the sequential walk below.
                        // Otherwise, when greedy colours an intermediate
                        // vreg vN with crs < vN < crd as a neighbour of
                        // crs, ir_uf_find(crs) returns crd which is still
                        // 0xFFFFFFFF — the constraint is missed and vN
                        // can collide with crd's eventual colour.
                        uint64 keep = crd
                        uint64 drop = crs
                        if crs < crd { keep = crs; drop = crd }

                        // Briggs conservative gate: count neighbours of
                        // (row[keep] | row[drop]) whose current degree is
                        // >= K. If fewer than K such neighbours, the merged
                        // node is K-colourable on its own — safe to merge.
                        // Followers' own deg slots are stale (zeroed at
                        // drop time), so every degree lookup goes through
                        // ir_uf_find first.
                        uint64 hd = 0
                        uint64 bw = 0
                        while bw < row_words {
                            uint64 ba = ig + keep * row_bytes + bw * 8
                            uint64 bav = 0
                            unsafe { *(ba as uint64) -> bav }
                            uint64 bb = ig + drop * row_bytes + bw * 8
                            uint64 bbv = 0
                            unsafe { *(bb as uint64) -> bbv }
                            uint64 cb = bav | bbv
                            if (bw == keep / 64) { cb = cb & ~(1 << (keep & 63)) }
                            if (bw == drop / 64) { cb = cb & ~(1 << (drop & 63)) }
                            while cb != 0 {
                                uint64 sp = 0
                                uint64 st = cb
                                while (st & 1) == 0 { st = st >> 1; sp = sp + 1 }
                                uint64 nidx = bw * 64 + sp
                                if nidx < vcount {
                                    uint64 nrep = ir_uf_find(nidx)
                                    uint64 ndp = ir_uf_deg + nrep * 4
                                    uint32 ndg32 = 0
                                    unsafe { *(ndp as uint32) -> ndg32 }
                                    if ndg32 >= IR_NUM_REGS { hd = hd + 1 }
                                }
                                cb = cb & ~(1 << sp)
                            }
                            bw = bw + 1
                        }
                        if hd >= IR_NUM_REGS {
                            // George fallback: less conservative than Briggs.
                            // Skip when K is small (x86: K=6) — empirically
                            // George's extra merges cost more than they save
                            // when K < 8.
                            if IR_NUM_REGS < 8 {
                                cii = cii + 1
                                continue
                            }
                            uint64 g_a = keep; uint64 g_b = drop
                            uint64 g_pass = 0
                            uint64 g_try = 0
                            while g_try < 2 {
                                uint64 ok = 1
                                uint64 gw = 0
                                while gw < row_words {
                                    uint64 gap = ig + g_a * row_bytes + gw * 8
                                    uint64 gav = 0
                                    unsafe { *(gap as uint64) -> gav }
                                    uint64 gbp = ig + g_b * row_bytes + gw * 8
                                    uint64 gbv = 0
                                    unsafe { *(gbp as uint64) -> gbv }
                                    if gw == g_b / 64 { gav = gav & ~(1 << (g_b & 63)) }
                                    if gw == g_a / 64 { gav = gav & ~(1 << (g_a & 63)) }
                                    while gav != 0 && ok != 0 {
                                        uint64 sp = 0
                                        uint64 st = gav
                                        while (st & 1) == 0 { st = st >> 1; sp = sp + 1 }
                                        uint64 nidx = gw * 64 + sp
                                        if nidx < vcount {
                                            uint64 in_b = (gbv >> sp) & 1
                                            uint64 nrep = ir_uf_find(nidx)
                                            uint64 ndp = ir_uf_deg + nrep * 4
                                            uint32 ndg = 0
                                            unsafe { *(ndp as uint32) -> ndg }
                                            if in_b == 0 && ndg >= IR_NUM_REGS { ok = 0 }
                                        }
                                        gav = gav & ~(1 << sp)
                                    }
                                    if ok == 0 { gw = row_words } else { gw = gw + 1 }
                                }
                                if ok != 0 { g_pass = 1; g_try = 2 }
                                else {
                                    g_a = drop; g_b = keep
                                    g_try = g_try + 1
                                }
                            }
                            if g_pass == 0 {
                                cii = cii + 1
                                continue
                            }
                        }

                        // Merge: row[keep] |= row[drop]; for every neighbor
                        // n in row[drop], set IG[n][keep] so foreign rows
                        // also see keep as a neighbor. Update degree cache:
                        // for each common neighbour, decrement deg[n] (the
                        // two edges to keep and drop collapse to one).
                        uint64 new_keep_deg = 0
                        uint64 mw = 0
                        while mw < row_words {
                            uint64 sa = ig + drop * row_bytes + mw * 8
                            uint64 sav = 0
                            unsafe { *(sa as uint64) -> sav }
                            uint64 da = ig + keep * row_bytes + mw * 8
                            uint64 dav = 0
                            unsafe { *(da as uint64) -> dav }
                            uint64 common = sav & dav
                            if sav != 0 {
                                unsafe { *(da as uint64) = dav | sav }
                                uint64 sb = sav
                                while sb != 0 {
                                    uint64 sp = 0
                                    uint64 st = sb
                                    while (st & 1) == 0 { st = st >> 1; sp = sp + 1 }
                                    uint64 nidx = mw * 64 + sp
                                    if nidx != keep && nidx < vcount {
                                        uint64 nrp = ig + nidx * row_bytes + (keep / 64) * 8
                                        uint64 nrv = 0
                                        unsafe { *(nrp as uint64) -> nrv }
                                        nrv = nrv | (1 << (keep & 63))
                                        unsafe { *(nrp as uint64) = nrv }
                                        if ((common >> sp) & 1) != 0 {
                                            uint64 ndp = ir_uf_deg + nidx * 4
                                            uint32 ndg = 0
                                            unsafe { *(ndp as uint32) -> ndg }
                                            if ndg > 0 { ndg = ndg - 1 }
                                            unsafe { *(ndp as uint32) = ndg }
                                        }
                                    }
                                    sb = sb & ~(1 << sp)
                                }
                            }
                            uint64 da2 = ig + keep * row_bytes + mw * 8
                            uint64 da2v = 0
                            unsafe { *(da2 as uint64) -> da2v }
                            new_keep_deg = new_keep_deg + ir_popcount64(da2v)
                            mw = mw + 1
                        }
                        uint64 dkp = ir_uf_deg + keep * 4
                        uint32 dk32 = new_keep_deg
                        unsafe { *(dkp as uint32) = dk32 }
                        uint64 ddp = ir_uf_deg + drop * 4
                        uint32 dd32 = 0
                        unsafe { *(ddp as uint32) = dd32 }

                        // Union: parent[drop] = keep (high → low)
                        uint64 ufpp = ir_uf_parent + drop * 4
                        uint32 ufpw = keep
                        unsafe { *(ufpp as uint32) = ufpw }
                    }
                }
            }
        }
        cii = cii + 1
    }

    // Greedy coloring: for each vreg, assign the lowest color not used
    // by any interfering neighbor. Followers (uf_find(vi) != vi) are
    // skipped; their colour is propagated from their rep below.
    uint64 vi = 0
    while vi < vcount {
        uint64 rp = ir_reg_assign + vi * 4
        uint32 spill = 0xFFFFFFFF
        unsafe { *(rp as uint32) = spill }
        vi = vi + 1
    }

    vi = 1
    while vi < vcount {
        if ir_uf_find(vi) != vi {
            vi = vi + 1
            continue
        }
        // Collect colors used by interfering neighbors
        uint64 used_colors = 0
        uint64 nw = 0
        while nw < row_words {
            uint64 np = ig + vi * row_bytes + nw * 8
            uint64 nbits = 0
            unsafe { *(np as uint64) -> nbits }
            while nbits != 0 {
                uint64 bp = 0
                uint64 bt = nbits
                while (bt & 1) == 0 { bt = bt >> 1; bp = bp + 1 }
                uint64 neighbor = nw * 64 + bp
                if neighbor < vcount {
                    // Look up rep's colour — followers haven't been
                    // assigned yet but their rep may have been.
                    uint64 nrep = ir_uf_find(neighbor)
                    uint64 nrp = ir_reg_assign + nrep * 4
                    uint32 nc = 0
                    unsafe { *(nrp as uint32) -> nc }
                    uint64 wnc = nc
                    if wnc < IR_NUM_REGS {
                        used_colors = used_colors | (1 << wnc)
                    }
                }
                nbits = nbits & ~(1 << bp)
            }
            nw = nw + 1
        }

        // Find lowest available color
        uint64 color = 0
        while color < IR_NUM_REGS {
            if (used_colors & (1 << color)) == 0 {
                uint64 arp = ir_reg_assign + vi * 4
                uint32 cv = color
                unsafe { *(arp as uint32) = cv }
                color = IR_NUM_REGS  // break
            }
            color = color + 1
        }

        vi = vi + 1
    }

    // Propagate rep colours to followers so ir_get_phys_reg works
    // uniformly for every vreg.
    vi = 1
    while vi < vcount {
        uint64 rep = ir_uf_find(vi)
        if rep != vi {
            uint64 rrp = ir_reg_assign + rep * 4
            uint32 rc = 0
            unsafe { *(rrp as uint32) -> rc }
            uint64 frp = ir_reg_assign + vi * 4
            unsafe { *(frp as uint32) = rc }
        }
        vi = vi + 1
    }

}

// ---------------------------------------------------------------------------
// x86_64 machine code emission helpers
// ---------------------------------------------------------------------------

// REX prefix: W=1 always. R=1 if reg1>=8. B=1 if reg2>=8.
fn ir_x86_rex(uint64 reg1, uint64 reg2) -> uint8 {
    uint8 rex = 0x48
    if reg1 >= 8 { rex = rex | 4 }
    if reg2 >= 8 { rex = rex | 1 }
    return rex
}

fn ir_x86_modrm_rr(uint64 reg, uint64 rm) -> uint8 {
    uint64 v = 0xC0 | ((reg & 7) << 3) | (rm & 7)
    uint8 r = v
    return r
}

fn ir_emit_mov_r64_r64(uint64 dst, uint64 src) {
    if dst == src { return }
    emit_byte(ir_x86_rex(src, dst))
    emit_byte(0x89)
    emit_byte(ir_x86_modrm_rr(src, dst))
}

fn ir_emit_mov_r64_imm64(uint64 dst, uint64 imm) {
    // Encoding choices, smallest first:
    //   imm fits in uint32               → B8+r imm32          (5 or 6 bytes, zero-extends)
    //   imm fits in sign-extended int32  → REX.W C7 /0 imm32   (7 bytes, sign-extends)
    //   otherwise                        → REX.W B8+r imm64    (10 bytes, full movabsq)
    if imm <= 0xFFFFFFFF {
        if dst >= 8 { emit_byte(0x41) }              // REX.B only (no W — 32-bit op zero-extends)
        uint64 opc32 = 0xB8 | (dst & 7)
        uint8 op32 = opc32
        emit_byte(op32)
        emit_u32_le(imm)
        return
    }
    if (imm >> 31) == 0x1FFFFFFFF {
        uint8 rex = 0x48
        if dst >= 8 { rex = rex | 1 }
        emit_byte(rex)
        emit_byte(0xC7)
        uint64 modrm = 0xC0 | (dst & 7)
        uint8 m = modrm
        emit_byte(m)
        emit_u32_le(imm & 0xFFFFFFFF)
        return
    }
    uint8 rex = 0x48
    if dst >= 8 { rex = rex | 1 }
    emit_byte(rex)
    uint64 opc = 0xB8 | (dst & 7)
    uint8 opcode = opc
    emit_byte(opcode)
    emit_u64_le(imm)
}

fn ir_emit_add_r64_r64(uint64 dst, uint64 src) {
    emit_byte(ir_x86_rex(src, dst))
    emit_byte(0x01)
    emit_byte(ir_x86_modrm_rr(src, dst))
}

fn ir_emit_sub_r64_r64(uint64 dst, uint64 src) {
    emit_byte(ir_x86_rex(src, dst))
    emit_byte(0x29)
    emit_byte(ir_x86_modrm_rr(src, dst))
}

fn ir_emit_cmp_r64_r64(uint64 a, uint64 b) {
    emit_byte(ir_x86_rex(b, a))
    emit_byte(0x39)
    emit_byte(ir_x86_modrm_rr(b, a))
}

// Emit `cmp r64, imm` with the smallest applicable encoding:
//   imm == 0                        → `test r,r`     (3 bytes)
//   -128 <= signed(imm) <= 127      → `cmp r/m64, imm8`  (4 bytes)
//   otherwise (signed-32 fits)      → `cmp r/m64, imm32` (7 bytes)
// Caller must have already verified the imm fits in signed 32 bits.
fn ir_emit_cmp_r64_imm(uint64 a, uint64 imm) {
    if imm == 0 {
        // test r/m64, r64 = REX.W 85 /r — same opcode as the helper.
        ir_emit_test_r64_r64(a, a)
        return
    }
    uint8 rex = 0x48
    if a >= 8 { rex = rex | 1 }
    uint64 use_imm8 = 0
    if imm <= 127 { use_imm8 = 1 }
    if imm >= 0xFFFFFFFFFFFFFF80 { use_imm8 = 1 }
    if use_imm8 != 0 {
        // 83 /7 ib
        emit_byte(rex)
        emit_byte(0x83)
        uint64 mv = 0xC0 | (7 << 3) | (a & 7)
        uint8 modrm = mv
        emit_byte(modrm)
        uint8 d8 = imm
        emit_byte(d8)
    } else {
        // 81 /7 id
        emit_byte(rex)
        emit_byte(0x81)
        uint64 mv = 0xC0 | (7 << 3) | (a & 7)
        uint8 modrm = mv
        emit_byte(modrm)
        emit_u32_le(imm)
    }
}

fn ir_emit_test_r64_r64(uint64 a, uint64 b) {
    emit_byte(ir_x86_rex(b, a))
    emit_byte(0x85)
    emit_byte(ir_x86_modrm_rr(b, a))
}

fn ir_emit_imul_r64_r64(uint64 dst, uint64 src) {
    emit_byte(ir_x86_rex(dst, src))
    emit_byte(0x0F)
    emit_byte(0xAF)
    emit_byte(ir_x86_modrm_rr(dst, src))
}

// Emit `lea dst, [src + disp]` where disp is a signed-32-bit displacement
// stored in a uint64. Handles RSP/R12 base registers (which require a SIB
// byte) and picks disp8 vs disp32 to minimize bytes. Caller must have
// verified disp fits in signed 32-bit and is non-zero (zero disp would
// emit LEA-as-copy which is pointless — caller should rewrite to MOV).
fn ir_emit_lea_disp(uint64 dst, uint64 src, uint64 disp) {
    uint8 rex = 0x48
    if dst >= 8 { rex = rex | 4 }
    if src >= 8 { rex = rex | 1 }
    emit_byte(rex)
    emit_byte(0x8D)

    uint64 src_lo = src & 7
    uint64 dst_lo = dst & 7

    // disp8 if disp is in [-128, 127] as a signed value.
    uint64 use_disp8 = 0
    if disp <= 127 { use_disp8 = 1 }
    if disp >= 0xFFFFFFFFFFFFFF80 { use_disp8 = 1 }

    if src_lo == 4 {
        // base register encoded as RSP (rsp/r12) — ModRM r/m=100 means a
        // SIB byte follows. SIB 0x24 = scale=00, index=100 (no index),
        // base=100 (the actual base register).
        if use_disp8 != 0 {
            uint64 mv = 0x44 | (dst_lo << 3)
            uint8 modrm = mv
            emit_byte(modrm)
            emit_byte(0x24)
            uint8 d8 = disp
            emit_byte(d8)
        } else {
            uint64 mv = 0x84 | (dst_lo << 3)
            uint8 modrm = mv
            emit_byte(modrm)
            emit_byte(0x24)
            emit_u32_le(disp)
        }
        return
    }

    // base register encoded as RBP (rbp/r13) with no displacement collides
    // with the RIP-relative encoding (mod=00, r/m=101). Force a disp8 of 0
    // when disp would otherwise be elided. Our caller guarantees disp != 0,
    // so the disp8 path is always safe — no special case needed.

    if use_disp8 != 0 {
        uint64 mv = 0x40 | (dst_lo << 3) | src_lo
        uint8 modrm = mv
        emit_byte(modrm)
        uint8 d8 = disp
        emit_byte(d8)
    } else {
        uint64 mv = 0x80 | (dst_lo << 3) | src_lo
        uint8 modrm = mv
        emit_byte(modrm)
        emit_u32_le(disp)
    }
}

fn ir_emit_neg_r64(uint64 reg) {
    uint8 rex = 0x48
    if reg >= 8 { rex = rex | 1 }
    emit_byte(rex)
    emit_byte(0xF7)
    uint64 v = 0xC0 | (3 << 3) | (reg & 7)
    uint8 modrm = v
    emit_byte(modrm)
}

fn ir_emit_not_r64(uint64 reg) {
    uint8 rex = 0x48
    if reg >= 8 { rex = rex | 1 }
    emit_byte(rex)
    emit_byte(0xF7)
    uint64 v = 0xC0 | (2 << 3) | (reg & 7)
    uint8 modrm = v
    emit_byte(modrm)
}

// ---------------------------------------------------------------------------
// Spill helpers
// ---------------------------------------------------------------------------

static uint64 ir_spill_base = 0
static uint64 ir_spill_count = 0

fn ir_spill_offset(uint64 vreg) -> uint64 {
    // vreg >= (IR_NUM_REGS+1) are spilled (vregs are 1-based)
    uint64 slot = vreg - IR_NUM_REGS - 1
    return ir_spill_base + slot * 8
}

// Peephole: track the most recent `store_spill reg, vreg` so an
// immediately-following `load_spill reg, same-vreg` (with no other
// bytes emitted in between) can be elided — the value is already in
// that register. Cleared by invalidating the end position whenever
// any non-tracking byte emitter runs; here we rely on out_len being
// stable between the two calls to signal "nothing else happened".
static uint64 ir_last_spill_vreg = 0xFFFFFFFF
static uint64 ir_last_spill_reg = 0xFFFFFFFF
static uint64 ir_last_spill_end = 0xFFFFFFFFFFFFFFFF

@export
fn ir_peephole_reset() {
    ir_last_spill_vreg = 0xFFFFFFFF
    ir_last_spill_reg = 0xFFFFFFFF
    ir_last_spill_end = 0xFFFFFFFFFFFFFFFF
}

fn ir_emit_load_spill(uint64 dst_reg, uint64 vreg) {
    // Peephole: if the last emission was exactly `store_spill
    // src_reg=dst_reg, src_vreg=vreg` and nothing was emitted after
    // it, the value is still in dst_reg — skip the reload entirely.
    if vreg == ir_last_spill_vreg && dst_reg == ir_last_spill_reg && out_len == ir_last_spill_end {
        ir_last_spill_end = 0xFFFFFFFFFFFFFFFF   // one-shot: don't re-apply
        return
    }
    // Same vreg, different reg — the value is in `ir_last_spill_reg`
    // already; emit a reg-reg move instead of a memory load. Saves one
    // memory cycle per spill round-trip in matmul-style hot paths
    // where intermediate vregs flow through different scratch regs.
    if vreg == ir_last_spill_vreg && out_len == ir_last_spill_end &&
       ir_last_spill_reg != 0xFFFFFFFF && ir_last_spill_reg != dst_reg {
        uint64 src_reg = ir_last_spill_reg
        // Update ir_last_spill_end inside the helper would invalidate
        // the next peephole check incorrectly — but we're emitting only
        // one mov, so updating last_spill_reg to dst_reg keeps the
        // chain "value lives in dst_reg" valid for any subsequent
        // store_spill→load_spill pair targeting the same vreg.
        ir_emit_mov_r64_r64(dst_reg, src_reg)
        ir_last_spill_reg = dst_reg
        ir_last_spill_end = out_len
        return
    }
    // mov dst_reg, [rsp + spill_offset]
    uint64 off = ir_spill_offset(vreg)
    uint8 rex = 0x48
    if dst_reg >= 8 { rex = rex | 4 }
    emit_byte(rex)
    emit_byte(0x8B)
    if off < 128 {
        uint64 v = 0x44 | ((dst_reg & 7) << 3)
        uint8 modrm = v
        emit_byte(modrm)
        emit_byte(0x24)
        uint8 o8 = off
        emit_byte(o8)
    } else {
        uint64 v = 0x84 | ((dst_reg & 7) << 3)
        uint8 modrm = v
        emit_byte(modrm)
        emit_byte(0x24)
        emit_u32_le(off)
    }
}

fn ir_emit_store_spill(uint64 src_reg, uint64 vreg) {
    // mov [rsp + spill_offset], src_reg
    uint64 off = ir_spill_offset(vreg)
    uint8 rex = 0x48
    if src_reg >= 8 { rex = rex | 4 }
    emit_byte(rex)
    emit_byte(0x89)
    if off < 128 {
        uint64 v = 0x44 | ((src_reg & 7) << 3)
        uint8 modrm = v
        emit_byte(modrm)
        emit_byte(0x24)
        uint8 o8 = off
        emit_byte(o8)
    } else {
        uint64 v = 0x84 | ((src_reg & 7) << 3)
        uint8 modrm = v
        emit_byte(modrm)
        emit_byte(0x24)
        emit_u32_le(off)
    }
    // Record for the peephole check above. Captures (src_reg, vreg)
    // and the out_len after emission. The next emit that bumps
    // out_len without matching those parameters invalidates this
    // via the position check.
    ir_last_spill_vreg = vreg
    ir_last_spill_reg = src_reg
    ir_last_spill_end = out_len
}

// ---------------------------------------------------------------------------
// Scratch register helpers: resolve vreg to physical reg or load spill
// ---------------------------------------------------------------------------

fn ir_resolve_src(uint64 vreg, uint64 scratch) -> uint64 {
    // Returns the physical register holding the value of vreg.
    // If vreg is spilled, loads it into scratch (0=rax, 1=rcx) and returns scratch.
    if vreg == 0 { return scratch }
    uint64 phys = ir_get_phys_reg(vreg)
    if phys != 0xFFFFFFFF { return phys }
    ir_emit_load_spill(scratch, vreg)
    return scratch
}

// ---------------------------------------------------------------------------
// OS-aware syscall number mapping (x86_64)
// ---------------------------------------------------------------------------

fn ir_x86_syscall_nr(uint64 abstract_nr) -> uint64 {
    if target_os == 1 {
        // macOS x86_64: prefix 0x2000000
        if abstract_nr == 231 { return 0x2000001 }  // exit → 1
        if abstract_nr == 1 { return 0x2000004 }    // write → 4
        if abstract_nr == 0 { return 0x2000003 }    // read → 3
        if abstract_nr == 2 { return 0x2000005 }    // open → 5
        if abstract_nr == 3 { return 0x2000006 }    // close → 6
        if abstract_nr == 8 { return 0x20000C7 }    // lseek → 199
        if abstract_nr == 9 { return 0x20000C5 }    // mmap → 197
        if abstract_nr == 11 { return 0x2000049 }   // munmap → 73
        if abstract_nr == 59 { return 0x200003B }   // execve → 59
        if abstract_nr == 228 { return 0x20000E4 }  // clock_gettime → 228
        if abstract_nr == 15 { return 0x200000F }   // chmod → 15
        if abstract_nr == 90 { return 0x200000F }   // fchmod(Linux 90) → chmod(macOS 15)
        if abstract_nr == 257 { return 0x2000005 }  // openat → open (macOS uses open, not openat)
        return 0x2000000 | abstract_nr               // fallback
    }
    // Linux (0) and Android (3) use the same x86_64 syscall numbers
    return abstract_nr
}

// ---------------------------------------------------------------------------
// Windows PE syscall emitter — translates abstract syscall numbers to IAT calls
// ---------------------------------------------------------------------------

fn ir_emit_x86_win_syscall(uint64 abstract_nr, uint64 dest_v, uint64 dst_r) {
    if abstract_nr == 231 {
        // exit(code): IR_ARG placed code in rdi (SysV slot 0).
        // Windows: ExitProcess(UINT uExitCode) — rcx = exit code
        ir_emit_mov_r64_r64(1, 7)   // mov rcx, rdi
        emit_win_alloc_stack(0x20)    // sub rsp, 32 (shadow space)
        emit_win_call_iat(0)          // call ExitProcess
        emit_win_free_stack(0x20)     // add rsp, 32
        return
    }

    if abstract_nr == 1 {
        // write(fd, buf, len): SysV args in rdi=fd, rsi=buf, rdx=len
        // Windows: if fd <= 2, call GetStdHandle to convert fd to a handle;
        // otherwise fd is already a native Windows HANDLE (from CreateFileA/file_open).
        // Then call WriteFile(handle, buf, len, NULL, NULL).

        // Save buf(rsi) and len(rdx) — two pushes keep stack aligned
        emit_byte(0x56)  // push rsi (buf)
        emit_byte(0x52)  // push rdx (len)

        // Check if fd <= 2 (stdin/stdout/stderr need GetStdHandle)
        // cmp rdi, 2
        emit_byte(0x48); emit_byte(0x83); emit_byte(0xFF); emit_byte(0x02)
        // ja skip_getstdhandle (fd > 2 means it's a file handle)
        emit_byte(0x77)
        // The GetStdHandle block is: mov rcx,rdi(3) + add rcx,10(4) + neg rcx(3) +
        //   sub rsp,0x20(4) + call[rip+disp32](6) + add rsp,0x20(4) + mov rdi,rax(3) = 27 bytes
        emit_byte(0x1B)  // ja +27

        // GetStdHandle path: rcx = -(fd + 10) -> -11 for stdout, -12 for stderr
        ir_emit_mov_r64_r64(1, 7)   // mov rcx, rdi (fd)
        // add rcx, 10
        emit_byte(0x48); emit_byte(0x83); emit_byte(0xC1); emit_byte(0x0A)
        // neg rcx
        emit_byte(0x48); emit_byte(0xF7); emit_byte(0xD9)
        emit_win_alloc_stack(0x20)
        emit_win_call_iat(1)          // call GetStdHandle -> rax = handle
        emit_win_free_stack(0x20)
        // Move handle to rdi so the rest of the code uses it uniformly
        ir_emit_mov_r64_r64(7, 0)    // mov rdi, rax (handle)
        // skip_getstdhandle:

        // Pop len and buf (reverse order)
        emit_byte(0x5A)  // pop rdx (len)
        emit_byte(0x5E)  // pop rsi (buf)

        // WriteFile(handle=rcx, buf=rdx, len=r8, lpBytesWritten=r9=0, lpOverlapped=[rsp+32]=0)
        // Save len from rdx into r8 BEFORE overwriting rdx
        emit_byte(0x49); emit_byte(0x89); emit_byte(0xD0)  // mov r8, rdx (len)
        ir_emit_mov_r64_r64(1, 7)    // mov rcx, rdi (handle — either GetStdHandle result or original fd)
        ir_emit_mov_r64_r64(2, 6)    // mov rdx, rsi (buf)
        // r8 already has len
        ir_emit_mov_r64_imm64(9, 0)  // r9 = NULL (lpNumberOfBytesWritten)

        // sub rsp, 48 (32 shadow + 8 for 5th arg, 16-aligned)
        emit_win_alloc_stack(0x30)
        // mov qword [rsp+32], 0 (lpOverlapped = NULL, 5th arg on stack)
        emit_byte(0x48); emit_byte(0xC7); emit_byte(0x44); emit_byte(0x24); emit_byte(0x20)
        emit_u32_le(0)
        emit_win_call_iat(2)          // call WriteFile
        emit_win_free_stack(0x30)
    }

    if abstract_nr == 0 {
        // read(fd, buf, len): SysV rdi=fd, rsi=buf, rdx=len
        // Windows: ReadFile(handle, buf, len, &bytesRead, NULL)
        // If fd <= 2, convert via GetStdHandle; otherwise fd is already a handle.
        emit_byte(0x56)  // push rsi (buf)
        emit_byte(0x52)  // push rdx (len)

        // cmp rdi, 2
        emit_byte(0x48); emit_byte(0x83); emit_byte(0xFF); emit_byte(0x02)
        // ja +27 (skip GetStdHandle)
        emit_byte(0x77); emit_byte(0x1B)
        // GetStdHandle: rcx = -(fd + 10) -> -10 for stdin
        ir_emit_mov_r64_r64(1, 7)
        emit_byte(0x48); emit_byte(0x83); emit_byte(0xC1); emit_byte(0x0A)
        emit_byte(0x48); emit_byte(0xF7); emit_byte(0xD9)
        emit_win_alloc_stack(0x20)
        emit_win_call_iat(1)          // GetStdHandle
        emit_win_free_stack(0x20)
        ir_emit_mov_r64_r64(7, 0)    // mov rdi, rax (handle)

        emit_byte(0x5A)              // pop rdx -> len
        emit_byte(0x5E)              // pop rsi -> buf
        emit_byte(0x49); emit_byte(0x89); emit_byte(0xD0)  // mov r8, rdx (len)
        ir_emit_mov_r64_r64(1, 7)    // rcx = handle
        ir_emit_mov_r64_r64(2, 6)    // rdx = buf
        emit_win_alloc_stack(0x30)
        // [rsp+0x20] = NULL (lpOverlapped, 5th arg on stack)
        emit_byte(0x48); emit_byte(0xC7); emit_byte(0x44); emit_byte(0x24); emit_byte(0x20)
        emit_u32_le(0)
        // lea r9, [rsp+0x28] (&bytesRead, in our scratch area)
        emit_byte(0x4C); emit_byte(0x8D); emit_byte(0x4C); emit_byte(0x24); emit_byte(0x28)
        emit_win_call_iat(4)          // ReadFile (IAT slot 4)
        // rax = BOOL, actual bytes read (DWORD) at [rsp+0x28]
        // Load bytes read into eax (zero-extends to rax)
        emit_byte(0x8B); emit_byte(0x44); emit_byte(0x24); emit_byte(0x28)  // mov eax, [rsp+0x28]
        emit_win_free_stack(0x30)
    }

    if abstract_nr == 2 {
        // open(path, flags): SysV rdi=path, rsi=flags
        // Windows: CreateFileA(path, access, share, NULL, disposition, flags, NULL)
        // flags: 0=read(O_RDONLY), nonzero=write(O_WRONLY/O_CREAT)
        emit_byte(0x56)  // push rsi (flags)
        ir_emit_mov_r64_r64(1, 7)    // rcx = path
        emit_byte(0x5E)              // pop rsi (flags)
        // rdx = GENERIC_READ (0x80000000) or GENERIC_WRITE (0x40000000)
        ir_emit_mov_r64_imm64(2, 0x80000000)  // default: GENERIC_READ
        // test rsi, rsi; if nonzero, use GENERIC_WRITE
        emit_byte(0x48); emit_byte(0x85); emit_byte(0xF6)  // test rsi, rsi
        // jz rel8 — skip the GENERIC_WRITE override. Patched after the
        // mov emits so this survives changes to mov r64 imm64's encoding
        // (e.g., the compact imm32 form that fits uint32 values in 5 bytes).
        emit_byte(0x74)
        uint64 co_jz_patch = out_len
        emit_byte(0)                            // rel8 placeholder
        ir_emit_mov_r64_imm64(2, 0x40000000)  // GENERIC_WRITE
        uint8 co_jz_disp = out_len - co_jz_patch - 1
        uint64 co_jz_p = out_buf + co_jz_patch
        unsafe { *(co_jz_p as uint8) = co_jz_disp }
        // r8 = FILE_SHARE_READ (1)
        ir_emit_mov_r64_imm64(8, 1)
        // r9 = NULL (security attrs)
        ir_emit_mov_r64_imm64(9, 0)
        // Stack args: [rsp+32]=disposition, [rsp+40]=FILE_ATTRIBUTE_NORMAL, [rsp+48]=NULL
        // Need 32 shadow + 3*8=24 stack args = 56, round up to 64 (0x40) for 16-byte alignment
        emit_win_alloc_stack(0x40)
        // Default OPEN_EXISTING
        emit_byte(0x48); emit_byte(0xC7); emit_byte(0x44); emit_byte(0x24); emit_byte(0x20)
        emit_u32_le(3)  // OPEN_EXISTING
        // if write mode, patch to CREATE_ALWAYS
        emit_byte(0x48); emit_byte(0x85); emit_byte(0xF6)  // test rsi, rsi
        emit_byte(0x74); emit_byte(0x09)  // jz +9 (skip 9-byte mov qword [rsp+0x20])
        emit_byte(0x48); emit_byte(0xC7); emit_byte(0x44); emit_byte(0x24); emit_byte(0x20)
        emit_u32_le(2)  // CREATE_ALWAYS
        // [rsp+40] = FILE_ATTRIBUTE_NORMAL (0x80)
        emit_byte(0x48); emit_byte(0xC7); emit_byte(0x44); emit_byte(0x24); emit_byte(0x28)
        emit_u32_le(0x80)
        // [rsp+48] = NULL (template)
        emit_byte(0x48); emit_byte(0xC7); emit_byte(0x44); emit_byte(0x24); emit_byte(0x30)
        emit_u32_le(0)
        emit_win_call_iat(3)  // CreateFileA (IAT slot 3)
        emit_win_free_stack(0x40)
        // rax = handle (or INVALID_HANDLE_VALUE on error)
    }

    if abstract_nr == 3 {
        // close(fd): SysV rdi=fd
        // Windows: CloseHandle(handle)
        ir_emit_mov_r64_r64(1, 7)    // rcx = handle
        emit_win_alloc_stack(0x20)
        emit_win_call_iat(5)          // CloseHandle (IAT slot 5)
        emit_win_free_stack(0x20)
    }

    if abstract_nr == 8 {
        // lseek(fd, offset, whence): SysV rdi=fd, rsi=offset, rdx=whence
        // Windows: GetFileSizeEx(handle, &size) — used by file_size() builtin
        // This returns the file size regardless of whence. For the SEEK_SET rewind
        // call, the return value is unused so this is safe.
        ir_emit_mov_r64_r64(1, 7)    // rcx = handle
        // sub rsp, 0x30 (shadow + space for output)
        emit_win_alloc_stack(0x30)
        // lea rdx, [rsp+32] (&size output)
        emit_byte(0x48); emit_byte(0x8D); emit_byte(0x54); emit_byte(0x24); emit_byte(0x20)
        emit_win_call_iat(8)          // GetFileSizeEx (IAT slot 8)
        // Load the size from [rsp+32]
        emit_byte(0x48); emit_byte(0x8B); emit_byte(0x44); emit_byte(0x24); emit_byte(0x20)
        emit_win_free_stack(0x30)
    }

    // Move result to dest
    if dst_r != 0xFFFFFFFF && dst_r != 0 {
        ir_emit_mov_r64_r64(dst_r, 0)
    }
    if dst_r == 0xFFFFFFFF {
        ir_emit_store_spill(0, dest_v)
    }
}

// ---------------------------------------------------------------------------
// Per-instruction emitter
// ---------------------------------------------------------------------------

fn ir_emit_x86_insn(uint64 ii) {
    uint64 op = ir_insn_opcode(ii)
    uint64 dest_v = ir_insn_dest(ii)
    uint64 s1_v = ir_insn_src1(ii)
    uint64 s2_v = ir_insn_src2(ii)
    uint64 imm = ir_insn_imm(ii)

    // Record DWARF line-table entry at the start of each instruction
    // that carries a source token. The line_table_record helper itself
    // deduplicates same-line entries and no-ops when -g is off.
    uint64 ir_src_tok = ir_insn_src_tok_at(ii)
    if ir_src_tok != 0 { line_table_record(ir_src_tok) }

    // Get physical registers (0xFFFFFFFF = spilled)
    uint64 dst_r = ir_get_phys_reg(dest_v)

    if op == 79 {
        // IR_STR_CONST: dst = lea string data (imm = str_offset)
        uint64 str_offset = imm
        uint64 lea_dst = dst_r
        if lea_dst == 0xFFFFFFFF { lea_dst = 0 }
        uint8 lea_rex = 0x48
        if lea_dst >= 8 { lea_rex = lea_rex | 4 }
        emit_byte(lea_rex)
        emit_byte(0x8D)
        uint64 lea_modrm = 0x05 | ((lea_dst & 7) << 3)
        uint8 lea_m = lea_modrm
        emit_byte(lea_m)
        if str_fixup_count >= 4096 {
            write(2, "error: str_fixups overflow (max 4096)\n", 38)
            exit(1)
        }
        uint64 fentry = str_fixups + str_fixup_count * 8
        uint32 cp = out_len
        unsafe { *(fentry as uint32) = cp }
        uint64 fe4 = fentry + 4
        uint32 so = str_offset
        unsafe { *(fe4 as uint32) = so }
        str_fixup_count = str_fixup_count + 1
        emit_u32_le(0)
        if dst_r == 0xFFFFFFFF {
            ir_emit_store_spill(0, dest_v)
        }
        return
    }

    if op == 1 {
        // IR_CONST: dst = imm64
        if dst_r != 0xFFFFFFFF {
            ir_emit_mov_r64_imm64(dst_r, imm)
        } else {
            ir_emit_mov_r64_imm64(0, imm)
            ir_emit_store_spill(0, dest_v)
        }
        return
    }

    if op == 2 {
        // IR_ADD (commutative — swap if dst==src2)
        uint64 a_reg = ir_resolve_src(s1_v, 0)
        uint64 b_reg = ir_resolve_src(s2_v, 1)
        if dst_r != 0xFFFFFFFF && dst_r == b_reg && a_reg != b_reg {
            uint64 tmp_r = a_reg; a_reg = b_reg; b_reg = tmp_r
        }
        if dst_r != 0xFFFFFFFF {
            ir_emit_mov_r64_r64(dst_r, a_reg)
            ir_emit_add_r64_r64(dst_r, b_reg)
        } else {
            ir_emit_mov_r64_r64(0, a_reg)
            ir_emit_add_r64_r64(0, b_reg)
            ir_emit_store_spill(0, dest_v)
        }
        return
    }

    if op == 3 {
        // IR_SUB: dst = src1 - src2
        // Handle case where dst == src2: use rax as temporary
        uint64 a_reg = ir_resolve_src(s1_v, 0)
        uint64 b_reg = ir_resolve_src(s2_v, 1)
        if dst_r != 0xFFFFFFFF {
            if dst_r == b_reg && a_reg != b_reg {
                // dst and src2 share a register — mov would clobber src2
                ir_emit_mov_r64_r64(0, a_reg)        // rax = src1
                ir_emit_sub_r64_r64(0, b_reg)        // rax = src1 - src2
                ir_emit_mov_r64_r64(dst_r, 0)        // dst = rax
            } else {
                ir_emit_mov_r64_r64(dst_r, a_reg)
                ir_emit_sub_r64_r64(dst_r, b_reg)
            }
        } else {
            ir_emit_mov_r64_r64(0, a_reg)
            ir_emit_sub_r64_r64(0, b_reg)
            ir_emit_store_spill(0, dest_v)
        }
        return
    }

    if op == 135 || op == 136 {
        // IR_ADD_IMM / IR_SUB_IMM: dst = src1 ± imm via `lea dst, [src1+disp]`.
        // For SUB_IMM, negate the displacement so we can share the LEA path.
        uint64 a_reg = ir_resolve_src(s1_v, 0)
        uint64 disp = imm
        if op == 136 { disp = 0 - imm }
        uint64 lea_dst = dst_r
        if lea_dst == 0xFFFFFFFF { lea_dst = 0 }
        ir_emit_lea_disp(lea_dst, a_reg, disp)
        if dst_r == 0xFFFFFFFF {
            ir_emit_store_spill(0, dest_v)
        }
        return
    }

    if op == 139 {
        // IR_LEA_BIS: dst = base + idx * scale  (scale ∈ {1,2,4,8})
        // Encoding: REX.W [+R/X/B] + 0x8D + ModRM(mod, reg=dst, r/m=100)
        //                   + SIB(scale_bits, idx, base) [+ disp8 if base=rbp/r13]
        uint64 base_reg = ir_resolve_src(s1_v, 0)
        uint64 idx_reg = ir_resolve_src(s2_v, 1)
        uint64 dst = dst_r
        if dst == 0xFFFFFFFF { dst = 0 }
        uint8 rex = 0x48
        if dst >= 8 { rex = rex | 4 }
        if idx_reg >= 8 { rex = rex | 2 }
        if base_reg >= 8 { rex = rex | 1 }
        emit_byte(rex)
        emit_byte(0x8D)
        uint64 scale_bits = 0
        if imm == 2 { scale_bits = 1 }
        if imm == 4 { scale_bits = 2 }
        if imm == 8 { scale_bits = 3 }
        uint64 base_lo = base_reg & 7
        uint64 idx_lo = idx_reg & 7
        uint64 dst_lo = dst & 7
        // RBP/R13 base requires explicit disp8=0 (mod=00 r/m=101 means
        // RIP-relative which is incompatible with SIB-base semantics).
        if base_lo == 5 {
            uint64 mv = 0x40 | (dst_lo << 3) | 4
            uint8 modrm = mv
            emit_byte(modrm)
            uint64 sv = (scale_bits << 6) | (idx_lo << 3) | base_lo
            uint8 sib = sv
            emit_byte(sib)
            emit_byte(0)
        } else {
            uint64 mv = (dst_lo << 3) | 4
            uint8 modrm = mv
            emit_byte(modrm)
            uint64 sv = (scale_bits << 6) | (idx_lo << 3) | base_lo
            uint8 sib = sv
            emit_byte(sib)
        }
        if dst_r == 0xFFFFFFFF {
            ir_emit_store_spill(0, dest_v)
        }
        return
    }

    if op == 138 {
        // IR_MUL_IMM: dst = src1 * imm via three-operand `imul`.
        // Encoding: REX.W + 6B /r ib    (imm fits in int8)   = 4 bytes
        //           REX.W + 69 /r id    (imm fits in int32)  = 7 bytes
        // Result sign-extends src1*imm into a full 64-bit register.
        uint64 a_reg = ir_resolve_src(s1_v, 0)
        uint64 dst = dst_r
        if dst == 0xFFFFFFFF { dst = 0 }
        uint8 rex = 0x48
        if dst >= 8 { rex = rex | 4 }       // REX.R for dst (the reg field)
        if a_reg >= 8 { rex = rex | 1 }     // REX.B for src1 (r/m)
        emit_byte(rex)
        uint64 use_imm8 = 0
        if imm <= 127 { use_imm8 = 1 }
        if imm >= 0xFFFFFFFFFFFFFF80 { use_imm8 = 1 }
        if use_imm8 != 0 {
            emit_byte(0x6B)
        } else {
            emit_byte(0x69)
        }
        uint64 mv = 0xC0 | ((dst & 7) << 3) | (a_reg & 7)
        uint8 modrm = mv
        emit_byte(modrm)
        if use_imm8 != 0 {
            uint8 d8 = imm
            emit_byte(d8)
        } else {
            emit_u32_le(imm)
        }
        if dst_r == 0xFFFFFFFF {
            ir_emit_store_spill(0, dest_v)
        }
        return
    }

    if op == 137 {
        // IR_ROR: dst = right-rotate(src1, src2 mod imm). imm is the
        // rotation width (32 for `ROR r32, cl`; 64 reserved for future
        // 64-bit rotations). The 32-bit form auto-zero-extends the
        // upper 32 bits, making the result w32-clean — so a downstream
        // `& 0xFFFFFFFF` mask gets elided by const-fold.
        uint64 a_reg = ir_resolve_src(s1_v, 0)
        uint64 b_reg = ir_resolve_src(s2_v, 1)
        // ROR's count operand is fixed to CL (rcx low byte) in the
        // variable-shift encoding. Move src2 there if needed.
        if b_reg != 1 { ir_emit_mov_r64_r64(1, b_reg) }
        uint64 dst = dst_r
        if dst == 0xFFFFFFFF { dst = 0 }
        // 32-bit MOV dst, a (no REX.W; auto-zero-extends to 64-bit).
        if dst != a_reg {
            uint64 need_rex = 0
            if a_reg >= 8 { need_rex = 1 }
            if dst >= 8 { need_rex = 1 }
            if need_rex != 0 {
                uint8 rex32 = 0x40
                if a_reg >= 8 { rex32 = rex32 | 4 }
                if dst >= 8 { rex32 = rex32 | 1 }
                emit_byte(rex32)
            }
            emit_byte(0x89)
            uint64 modrm_v = 0xC0 | ((a_reg & 7) << 3) | (dst & 7)
            uint8 modrm = modrm_v
            emit_byte(modrm)
        }
        // ROR r/m32, CL  =  D3 /1
        if dst >= 8 { emit_byte(0x41) }    // REX.B for r8d-r15d
        emit_byte(0xD3)
        uint64 ror_modrm_v = 0xC8 | (dst & 7)
        uint8 ror_modrm = ror_modrm_v
        emit_byte(ror_modrm)
        if dst_r == 0xFFFFFFFF {
            ir_emit_store_spill(0, dest_v)
        }
        return
    }

    if op == 4 {
        // IR_MUL: imul dst, src (commutative — swap if dst==src2)
        uint64 a_reg = ir_resolve_src(s1_v, 0)
        uint64 b_reg = ir_resolve_src(s2_v, 1)
        if dst_r != 0xFFFFFFFF && dst_r == b_reg && a_reg != b_reg {
            uint64 tmp_r = a_reg; a_reg = b_reg; b_reg = tmp_r
        }
        if dst_r != 0xFFFFFFFF {
            ir_emit_mov_r64_r64(dst_r, a_reg)
            ir_emit_imul_r64_r64(dst_r, b_reg)
        } else {
            ir_emit_mov_r64_r64(0, a_reg)
            ir_emit_imul_r64_r64(0, b_reg)
            ir_emit_store_spill(0, dest_v)
        }
        return
    }

    if op == 5 {
        // IR_DIV: rax = dividend / divisor, result in rax
        uint64 a_reg = ir_resolve_src(s1_v, 0)
        uint64 b_reg = ir_resolve_src(s2_v, 1)
        ir_emit_mov_r64_r64(0, a_reg)
        // xor rdx, rdx (zero-extend dividend)
        emit_byte(0x48)
        emit_byte(0x31)
        emit_byte(0xD2)
        // Ensure divisor is not in rax or rdx
        if b_reg == 0 || b_reg == 2 {
            ir_emit_mov_r64_r64(1, b_reg)
            b_reg = 1
        }
        // div b_reg: REX.W + F7 /6
        uint8 div_rex = 0x48
        if b_reg >= 8 { div_rex = div_rex | 1 }
        emit_byte(div_rex)
        emit_byte(0xF7)
        uint64 div_modrm = 0xF0 | (b_reg & 7)
        uint8 div_m = div_modrm
        emit_byte(div_m)
        // Result in rax -> move to dst
        if dst_r != 0xFFFFFFFF {
            ir_emit_mov_r64_r64(dst_r, 0)
        } else {
            ir_emit_store_spill(0, dest_v)
        }
        return
    }

    if op == 6 {
        // IR_MOD: rax = dividend / divisor, remainder in rdx
        uint64 a_reg = ir_resolve_src(s1_v, 0)
        uint64 b_reg = ir_resolve_src(s2_v, 1)
        ir_emit_mov_r64_r64(0, a_reg)
        // xor rdx, rdx
        emit_byte(0x48)
        emit_byte(0x31)
        emit_byte(0xD2)
        if b_reg == 0 || b_reg == 2 {
            ir_emit_mov_r64_r64(1, b_reg)
            b_reg = 1
        }
        uint8 mod_rex = 0x48
        if b_reg >= 8 { mod_rex = mod_rex | 1 }
        emit_byte(mod_rex)
        emit_byte(0xF7)
        uint64 mod_modrm = 0xF0 | (b_reg & 7)
        uint8 mod_m = mod_modrm
        emit_byte(mod_m)
        // Remainder in rdx -> move to dst
        if dst_r != 0xFFFFFFFF {
            ir_emit_mov_r64_r64(dst_r, 2)
        } else {
            ir_emit_store_spill(2, dest_v)
        }
        return
    }

    if op == 132 {
        // IR_SDIV: signed 64-bit division. mov rax, dividend; cqo
        // (sign-extend rax → rdx:rax); idiv r/m64; result in rax.
        // Without cqo, rdx stays as whatever-was-there and idiv
        // returns garbage; without idiv (using div instead), -10/3
        // becomes (2^64-10)/3 ≈ 6.15e18 instead of -3.
        uint64 a_reg = ir_resolve_src(s1_v, 0)
        uint64 b_reg = ir_resolve_src(s2_v, 1)
        ir_emit_mov_r64_r64(0, a_reg)
        // cqo: 48 99
        emit_byte(0x48); emit_byte(0x99)
        if b_reg == 0 || b_reg == 2 {
            ir_emit_mov_r64_r64(1, b_reg)
            b_reg = 1
        }
        // idiv b_reg: REX.W + F7 /7  (modrm 0xF8 | b)
        uint8 sdiv_rex = 0x48
        if b_reg >= 8 { sdiv_rex = sdiv_rex | 1 }
        emit_byte(sdiv_rex)
        emit_byte(0xF7)
        uint64 sdiv_modrm = 0xF8 | (b_reg & 7)
        uint8 sdiv_m = sdiv_modrm
        emit_byte(sdiv_m)
        if dst_r != 0xFFFFFFFF {
            ir_emit_mov_r64_r64(dst_r, 0)
        } else {
            ir_emit_store_spill(0, dest_v)
        }
        return
    }

    if op == 133 {
        // IR_SMOD: signed 64-bit remainder. Same as SDIV but result
        // is in rdx (high half of the cqo+idiv pair).
        uint64 a_reg = ir_resolve_src(s1_v, 0)
        uint64 b_reg = ir_resolve_src(s2_v, 1)
        ir_emit_mov_r64_r64(0, a_reg)
        emit_byte(0x48); emit_byte(0x99)    // cqo
        if b_reg == 0 || b_reg == 2 {
            ir_emit_mov_r64_r64(1, b_reg)
            b_reg = 1
        }
        uint8 smod_rex = 0x48
        if b_reg >= 8 { smod_rex = smod_rex | 1 }
        emit_byte(smod_rex)
        emit_byte(0xF7)
        uint64 smod_modrm = 0xF8 | (b_reg & 7)
        uint8 smod_m = smod_modrm
        emit_byte(smod_m)
        if dst_r != 0xFFFFFFFF {
            ir_emit_mov_r64_r64(dst_r, 2)
        } else {
            ir_emit_store_spill(2, dest_v)
        }
        return
    }

    if op == 7 {
        // IR_AND (commutative — swap if dst==src2)
        uint64 a_reg = ir_resolve_src(s1_v, 0)
        uint64 b_reg = ir_resolve_src(s2_v, 1)
        if dst_r != 0xFFFFFFFF && dst_r == b_reg && a_reg != b_reg {
            uint64 tmp_r = a_reg; a_reg = b_reg; b_reg = tmp_r
        }
        if dst_r != 0xFFFFFFFF {
            ir_emit_mov_r64_r64(dst_r, a_reg)
            // and dst, src: REX + 21 /r
            emit_byte(ir_x86_rex(b_reg, dst_r))
            emit_byte(0x21)
            emit_byte(ir_x86_modrm_rr(b_reg, dst_r))
        } else {
            ir_emit_mov_r64_r64(0, a_reg)
            emit_byte(ir_x86_rex(b_reg, 0))
            emit_byte(0x21)
            emit_byte(ir_x86_modrm_rr(b_reg, 0))
            ir_emit_store_spill(0, dest_v)
        }
        return
    }

    if op == 8 {
        // IR_OR (commutative — swap if dst==src2)
        uint64 a_reg = ir_resolve_src(s1_v, 0)
        uint64 b_reg = ir_resolve_src(s2_v, 1)
        if dst_r != 0xFFFFFFFF && dst_r == b_reg && a_reg != b_reg {
            uint64 tmp_r = a_reg; a_reg = b_reg; b_reg = tmp_r
        }
        if dst_r != 0xFFFFFFFF {
            ir_emit_mov_r64_r64(dst_r, a_reg)
            emit_byte(ir_x86_rex(b_reg, dst_r))
            emit_byte(0x09)
            emit_byte(ir_x86_modrm_rr(b_reg, dst_r))
        } else {
            ir_emit_mov_r64_r64(0, a_reg)
            emit_byte(ir_x86_rex(b_reg, 0))
            emit_byte(0x09)
            emit_byte(ir_x86_modrm_rr(b_reg, 0))
            ir_emit_store_spill(0, dest_v)
        }
        return
    }

    if op == 9 {
        // IR_XOR (commutative — swap if dst==src2)
        uint64 a_reg = ir_resolve_src(s1_v, 0)
        uint64 b_reg = ir_resolve_src(s2_v, 1)
        if dst_r != 0xFFFFFFFF && dst_r == b_reg && a_reg != b_reg {
            uint64 tmp_r = a_reg; a_reg = b_reg; b_reg = tmp_r
        }
        if dst_r != 0xFFFFFFFF {
            ir_emit_mov_r64_r64(dst_r, a_reg)
            emit_byte(ir_x86_rex(b_reg, dst_r))
            emit_byte(0x31)
            emit_byte(ir_x86_modrm_rr(b_reg, dst_r))
        } else {
            ir_emit_mov_r64_r64(0, a_reg)
            emit_byte(ir_x86_rex(b_reg, 0))
            emit_byte(0x31)
            emit_byte(ir_x86_modrm_rr(b_reg, 0))
            ir_emit_store_spill(0, dest_v)
        }
        return
    }

    if op == 10 {
        // IR_SHL: shl dst, cl — shift count must be in cl (rcx low byte)
        uint64 a_reg = ir_resolve_src(s1_v, 0)
        uint64 b_reg = ir_resolve_src(s2_v, 1)
        if b_reg != 1 { ir_emit_mov_r64_r64(1, b_reg) }
        if dst_r != 0xFFFFFFFF {
            if dst_r == 1 && a_reg != 1 {
                // dst is rcx which holds shift count — use rax as temporary
                ir_emit_mov_r64_r64(0, a_reg)
                emit_byte(0x48)
                emit_byte(0xD3)
                emit_byte(0xE0)
                ir_emit_mov_r64_r64(dst_r, 0)
            } else {
                ir_emit_mov_r64_r64(dst_r, a_reg)
                uint8 shl_rex = 0x48
                if dst_r >= 8 { shl_rex = shl_rex | 1 }
                emit_byte(shl_rex)
                emit_byte(0xD3)
                uint64 shl_modrm = 0xE0 | (dst_r & 7)
                uint8 shl_m = shl_modrm
                emit_byte(shl_m)
            }
        } else {
            ir_emit_mov_r64_r64(0, a_reg)
            emit_byte(0x48)
            emit_byte(0xD3)
            emit_byte(0xE0)
            ir_emit_store_spill(0, dest_v)
        }
        return
    }

    if op == 11 {
        // IR_SHR: shr dst, cl
        uint64 a_reg = ir_resolve_src(s1_v, 0)
        uint64 b_reg = ir_resolve_src(s2_v, 1)
        if b_reg != 1 { ir_emit_mov_r64_r64(1, b_reg) }
        if dst_r != 0xFFFFFFFF {
            if dst_r == 1 && a_reg != 1 {
                // dst is rcx which holds shift count — use rax as temporary
                ir_emit_mov_r64_r64(0, a_reg)
                emit_byte(0x48)
                emit_byte(0xD3)
                emit_byte(0xE8)
                ir_emit_mov_r64_r64(dst_r, 0)
            } else {
                ir_emit_mov_r64_r64(dst_r, a_reg)
                uint8 shr_rex = 0x48
                if dst_r >= 8 { shr_rex = shr_rex | 1 }
                emit_byte(shr_rex)
                emit_byte(0xD3)
                uint64 shr_modrm = 0xE8 | (dst_r & 7)
                uint8 shr_m = shr_modrm
                emit_byte(shr_m)
            }
        } else {
            ir_emit_mov_r64_r64(0, a_reg)
            emit_byte(0x48)
            emit_byte(0xD3)
            emit_byte(0xE8)
            ir_emit_store_spill(0, dest_v)
        }
        return
    }

    if op == 134 {
        // IR_SAR: arithmetic shift right (sign-fill). Identical encoding
        // to SHR except modrm /7 (0xF8 base) instead of /5 (0xE8 base).
        // Without this, `int64 x = -8; x >> 1` would lower to logical
        // SHR and produce (2^64-8)/2 instead of -4.
        uint64 a_reg = ir_resolve_src(s1_v, 0)
        uint64 b_reg = ir_resolve_src(s2_v, 1)
        if b_reg != 1 { ir_emit_mov_r64_r64(1, b_reg) }
        if dst_r != 0xFFFFFFFF {
            if dst_r == 1 && a_reg != 1 {
                ir_emit_mov_r64_r64(0, a_reg)
                emit_byte(0x48)
                emit_byte(0xD3)
                emit_byte(0xF8)
                ir_emit_mov_r64_r64(dst_r, 0)
            } else {
                ir_emit_mov_r64_r64(dst_r, a_reg)
                uint8 sar_rex = 0x48
                if dst_r >= 8 { sar_rex = sar_rex | 1 }
                emit_byte(sar_rex)
                emit_byte(0xD3)
                uint64 sar_modrm = 0xF8 | (dst_r & 7)
                uint8 sar_m = sar_modrm
                emit_byte(sar_m)
            }
        } else {
            ir_emit_mov_r64_r64(0, a_reg)
            emit_byte(0x48)
            emit_byte(0xD3)
            emit_byte(0xF8)
            ir_emit_store_spill(0, dest_v)
        }
        return
    }

    if op == 12 {
        // IR_NEG
        uint64 a_reg = ir_resolve_src(s1_v, 0)
        if dst_r != 0xFFFFFFFF {
            ir_emit_mov_r64_r64(dst_r, a_reg)
            ir_emit_neg_r64(dst_r)
        } else {
            ir_emit_mov_r64_r64(0, a_reg)
            ir_emit_neg_r64(0)
            ir_emit_store_spill(0, dest_v)
        }
        return
    }

    if op == 13 {
        // IR_NOT
        uint64 a_reg = ir_resolve_src(s1_v, 0)
        if dst_r != 0xFFFFFFFF {
            ir_emit_mov_r64_r64(dst_r, a_reg)
            ir_emit_not_r64(dst_r)
        } else {
            ir_emit_mov_r64_r64(0, a_reg)
            ir_emit_not_r64(0)
            ir_emit_store_spill(0, dest_v)
        }
        return
    }

    if op >= 14 && op <= 19 {
        // IR_CMP_EQ through IR_CMP_GE: cmp + setcc + movzx
        uint64 a_reg = ir_resolve_src(s1_v, 0)
        // src2 == 0 is the sentinel for cmp-imm mode (set by const-fold
        // when src2 was a known constant fitting in signed 32-bit).
        if s2_v == 0 {
            ir_emit_cmp_r64_imm(a_reg, imm)
        } else {
