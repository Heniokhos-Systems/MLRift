        emit_a64_str(path_r, 11, 0)      // argv[0] = path
        emit_a64_mov_imm(10, 0)
        emit_a64_str(10, 11, 8)           // argv[1] = NULL
        // x0 = path
        emit_a64_mov(0, path_r)
        // x1 = argv (X11)
        emit_a64_mov(1, 11)
        // x2 = envp: try cli_envp static, else NULL
        uint64 envp_off = static_lookup_by_name("cli_envp", 8)
        if envp_off != 0xFFFFFFFF {
            emit_a64_static_load(envp_off)
            emit_a64_mov(2, 0)
            emit_a64_mov(0, path_r)       // restore x0 (clobbered by static_load)
        } else {
            emit_a64_mov_imm(2, 0)
        }
        // syscall execve
        uint64 execve_nr = ir_a64_syscall_nr(59)
        emit_a64_syscall_nr(execve_nr)
        emit_a64_svc()
