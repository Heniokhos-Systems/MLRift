// Phase 3c-12 — qkv_split_f32 (3-param fused QKV split).
//
// Discriminator (by elimination among 3-param kernels): 3 params + no
// silu_f32 / lds_reduce_*_f32 / block_idx_y Calls + no u16 PtrLoad.
// What remains is qkv_split-shape kernels.  Delegates ISA emission
// to `_emit_qkv_split_f32_body` (q_dim=2048 hardcoded).
fn amdgpu_lower_qkv_split_f32_3c(uint64 fn_node, uint64 source,
                                  uint64 kname_ptr, uint64 nl) -> uint64 {
    uint64 n_params = 0
    uint64 wp = ast_child(fn_node)
    while wp != 0 {
        n_params = n_params + 1
        wp = ast_next(wp)
    }
    if n_params != 3 { return 1 }

    uint32 body = ast_data3(fn_node)
    if body == 0 { return 1 }
    if ast_kind(body) != 15 { return 1 }

    uint64 reject = 0
    uint32 walk = ast_child(body)
    while walk != 0 {
        if ast_kind(walk) == 41 {
            // u16 PtrLoad → bf16_to_f32 (3a-6) territory.
            if ast_data1(walk) == 2 {
                if ast_data3(walk) == 0 { reject = 1 }
            }
        }
        if ast_kind(walk) == 35 {
            uint32 callee = ast_data1(walk)
            if tok_matches(callee, "silu",                4) != 0 { reject = 1 }
            if tok_matches(callee, "silu_f32",            8) != 0 { reject = 1 }
            if tok_matches(callee, "lds_reduce_sum_f32", 18) != 0 { reject = 1 }
            if tok_matches(callee, "lds_reduce_max_f32", 18) != 0 { reject = 1 }
            if tok_matches(callee, "block_idx_y",        11) != 0 { reject = 1 }
        }
        if ast_kind(walk) == 10 {
            uint32 init = ast_child(walk)
            if init != 0 && ast_kind(init) == 35 {
                uint32 callee = ast_data1(init)
                if tok_matches(callee, "silu",                4) != 0 { reject = 1 }
                if tok_matches(callee, "silu_f32",            8) != 0 { reject = 1 }
                if tok_matches(callee, "lds_reduce_sum_f32", 18) != 0 { reject = 1 }
                if tok_matches(callee, "lds_reduce_max_f32", 18) != 0 { reject = 1 }
                if tok_matches(callee, "block_idx_y",        11) != 0 { reject = 1 }
            }
        }
        walk = ast_next(walk)
    }
    if reject != 0 { return 1 }

    // ── emit ISA ─────────────────────────────────────────────────
    uint64 args_desc = alloc(6 * 16)
    _emit_qkv_split_f32_body(args_desc)

    uint64 k_text_size = asm_text_len
    uint64 k_text_buf  = alloc(k_text_size)
    uint64 ci = 0
    while ci < k_text_size {
        uint64 sp = asm_text_buf + ci
        uint64 b = 0
        unsafe { *(sp as uint8) -> b }
        uint64 dp = k_text_buf + ci
        uint8 b8 = b
        unsafe { *(dp as uint8) = b8 }
        ci = ci + 1
    }

    // KD identical to qkv_split_f32 blob.
    uint64 rsrc1 = 0xE0AF0001
    uint64 rsrc2 = 0x0000009E
    uint64 rsrc3 = 0x00000010
    uint64 props = 0x0408

    kt_push(kname_ptr, nl, k_text_buf, k_text_size,
            args_desc, 3, 24,
            16, 24,
            rsrc1, rsrc2, rsrc3, props)
    return 0
}

// Phase 3c-14 — qkv_split_f32_batched (3p, 2D grid).
//
