// MLRift — built on KernRift — Lexer (Tokenizer)
//
// Converts source text (uint8 bytes) into a flat token array.
// Each token is 16 bytes:
//   [0..4)   kind  (uint32, see TokenKind enum)
//   [4..8)   start (uint32, byte offset in source)
//   [8..12)  len   (uint32, byte length of token text)
//   [12..16) line  (uint32, 1-based line number)

// ---------------------------------------------------------------------------
// Token kinds
// ---------------------------------------------------------------------------

enum TokenKind {
    Eof = 0
    Ident = 1
    IntLit = 2
    StrLit = 3
    CharLit = 4
    FloatLit = 5

    // Punctuation
    LParen = 10
    RParen = 11
    LBrace = 12
    RBrace = 13
    LBracket = 14
    RBracket = 15
    Comma = 16
    Dot = 17
    Semicolon = 18
    Colon = 19
    Arrow = 20
    At = 21
    Star = 22
    Ampersand = 23
    Pipe = 24
    Caret = 25
    Tilde = 26
    Bang = 27
    Question = 28

    // Operators
    Plus = 30
    Minus = 31
    Slash = 32
    Percent = 33
    Eq = 34
    EqEq = 35
    BangEq = 36
    Lt = 37
    LtEq = 38
    Gt = 39
    GtEq = 40
    AmpAmp = 41
    PipePipe = 42
    LtLt = 43
    GtGt = 44
    PlusEq = 45
    MinusEq = 46
    StarEq = 47
    SlashEq = 48
    PercentEq = 49
    AmpEq = 50
    PipeEq = 51
    CaretEq = 52
    LtLtEq = 53
    GtGtEq = 54

    // Keywords
    KwFn = 60
    KwReturn = 61
    KwIf = 62
    KwElse = 63
    KwWhile = 64
    KwFor = 65
    KwIn = 66
    KwBreak = 67
    KwContinue = 68
    KwLoop = 69
    KwDefer = 79
    KwConst = 70
    KwStatic = 71
    KwStruct = 72
    KwEnum = 73
    KwExtern = 74
    KwImport = 75
    KwUnsafe = 76
    KwTrue = 77
    KwFalse = 78

    // Type keywords
    KwUint8 = 80
    KwUint16 = 81
    KwUint32 = 82
    KwUint64 = 83
    KwInt8 = 84
    KwInt16 = 85
    KwInt32 = 86
    KwInt64 = 87

    // Extended keywords
    KwMatch = 88
    KwType = 89
    FatArrow = 29    // =>
    KwAsm = 90
    KwVolatile = 91
    KwDevice = 92
    KwAt = 93

    // Float type keywords
    KwFloat16 = 94
    KwFloat32 = 95
    KwFloat64 = 96
    KwSizeof = 97
    KwBool = 98
    KwChar = 99

    // F-string tokens
    FStrBegin = 100
    StrPart = 101
    FStrEnd = 102

    // Error
    Error = 255
}

// ---------------------------------------------------------------------------
// Lexer state (static globals)
// ---------------------------------------------------------------------------

static uint64 src_ptr = 0       // pointer to source bytes
static uint64 src_len = 0       // source length
static uint64 pos = 0           // current byte position
static uint64 line = 1          // current line number

static uint64 tok_buf = 0       // pointer to token output buffer
static uint64 tok_count = 0     // number of tokens emitted
static uint64 tok_capacity = 0  // max tokens in buffer

// Language profile (versioned surface layer from the Living Compiler blueprint)
// 0 = stable  — default; production-safe features only
// 1 = experimental — allows features under active development
static uint64 lang_profile = 0

// ---------------------------------------------------------------------------
// Lexer API
// ---------------------------------------------------------------------------

@export
fn lexer_init(uint64 source, uint64 length, uint64 tokens, uint64 capacity) {
    src_ptr = source
    src_len = length
    pos = 0
    line = 1
    tok_buf = tokens
    tok_count = 0
    tok_capacity = capacity
    lang_profile = 0
}

// Parse an optional #lang directive at the very start of a file.
// Recognized forms:
//   #lang stable
//   #lang experimental
// Anything else is silently ignored (forward-compat with future profiles).
// The directive must be on the first line; otherwise it's treated as normal
// source (but #lang is not valid KernRift tokens, so this is an error path).
fn lexer_parse_lang_directive() {
    if src_len < 6 { return }
    uint64 p0 = src_ptr
    uint64 c0 = 0
    unsafe { *(p0 as uint8) -> c0 }
    if c0 != 35 { return }  // '#'
    uint64 p1 = src_ptr + 1
    uint64 c1 = 0
    unsafe { *(p1 as uint8) -> c1 }
    uint64 p2 = src_ptr + 2
    uint64 c2 = 0
    unsafe { *(p2 as uint8) -> c2 }
    uint64 p3 = src_ptr + 3
    uint64 c3 = 0
    unsafe { *(p3 as uint8) -> c3 }
    uint64 p4 = src_ptr + 4
    uint64 c4 = 0
    unsafe { *(p4 as uint8) -> c4 }
    // Match "#lang"
    if c1 != 108 { return }  // 'l'
    if c2 != 97 { return }   // 'a'
    if c3 != 110 { return }  // 'n'
    if c4 != 103 { return }  // 'g'
    // Skip spaces after "#lang"
    uint64 dp = 5
    while dp < src_len {
        uint64 psp = src_ptr + dp
        uint64 csp = 0
        unsafe { *(psp as uint8) -> csp }
        if csp != 32 && csp != 9 { break }
        dp = dp + 1
    }
    // Read the profile name up to end of line
    uint64 name_start = dp
    while dp < src_len {
        uint64 pnm = src_ptr + dp
        uint64 cnm = 0
        unsafe { *(pnm as uint8) -> cnm }
        if cnm == 10 || cnm == 13 { break }
        dp = dp + 1
    }
    uint64 name_len = dp - name_start
    // Trim trailing whitespace
    while name_len > 0 {
        uint64 lp = src_ptr + name_start + name_len - 1
        uint64 lc = 0
        unsafe { *(lp as uint8) -> lc }
        if lc != 32 && lc != 9 { break }
        name_len = name_len - 1
    }
    // Compare against known profile names
    if name_len == 6 {
        uint64 sp6 = src_ptr + name_start
        uint64 b0 = 0
        unsafe { *(sp6 as uint8) -> b0 }
        if b0 == 115 { lang_profile = 0 }   // 'stable' (starts with 's')
    }
    if name_len == 12 {
        uint64 sp12 = src_ptr + name_start
        uint64 b0x = 0
        unsafe { *(sp12 as uint8) -> b0x }
        if b0x == 101 { lang_profile = 1 }  // 'experimental'
    }
    // Skip the whole first line (including the newline) so the lexer
    // doesn't try to tokenize '#lang stable' as source.
    pos = dp
    if pos < src_len {
        uint64 pnl = src_ptr + pos
        uint64 cnl = 0
        unsafe { *(pnl as uint8) -> cnl }
        if cnl == 13 {
            pos = pos + 1
            if pos < src_len {
                uint64 pnl2 = src_ptr + pos
                uint64 cnl2 = 0
                unsafe { *(pnl2 as uint8) -> cnl2 }
                if cnl2 == 10 { pos = pos + 1 }
            }
        } else if cnl == 10 {
            pos = pos + 1
        }
        line = 2
    }
}

@export
fn get_lang_profile() -> uint64 {
    return lang_profile
}

@export
fn lexer_run() -> uint64 {
    // Optional #lang directive on the first line sets the language profile
    lexer_parse_lang_directive()
    while pos < src_len {
        skip_whitespace_and_comments()
        // Check again after skipping (avoid break-in-if)
        if pos < src_len {
            lex_one_token()
        }
    }
    // Emit EOF token
    emit_token(TokenKind.Eof, pos, 0, line)
    return tok_count
}

@export
fn lexer_token_count() -> uint64 {
    return tok_count
}

// ---------------------------------------------------------------------------
// Internal helpers
// ---------------------------------------------------------------------------

fn peek() -> uint64 {
    if pos >= src_len { return 0 }
    uint64 ptr_addr = src_ptr + pos
    uint64 result = 0
    unsafe { *(ptr_addr as uint8) -> result }
    return result & 0xFF
}

fn advance() -> uint64 {
    uint64 ch = peek()
    if ch == 10 { line = line + 1 }
    pos = pos + 1
    return ch
}

fn peek_at(uint64 offset) -> uint64 {
    uint64 idx = pos + offset
    if idx >= src_len { return 0 }
    uint64 ptr_addr = src_ptr + idx
    uint64 result = 0
    unsafe { *(ptr_addr as uint8) -> result }
    return result & 0xFF
}

fn emit_token(uint64 kind, uint64 start, uint64 len, uint64 tok_line) {
    if tok_count >= tok_capacity { return }
    uint64 base = tok_count * 16
    uint64 buf = tok_buf
    // Write kind (4 bytes LE)
    uint64 a0 = buf + base
    unsafe { *(a0 as uint32) = kind }
    // Write start (4 bytes LE)
    uint64 a1 = buf + base + 4
    uint32 s32 = start
    unsafe { *(a1 as uint32) = s32 }
    // Write len (4 bytes LE)
    uint64 a2 = buf + base + 8
    uint32 l32 = len
    unsafe { *(a2 as uint32) = l32 }
    // Write line (4 bytes LE)
    uint64 a3 = buf + base + 12
    unsafe { *(a3 as uint32) = tok_line }
    tok_count = tok_count + 1
}

fn skip_whitespace_and_comments() {
    uint64 done = 0
    while pos < src_len && done == 0 {
        uint64 ch = peek()
        uint64 handled = 0
        // Whitespace: space, tab, CR, LF
        if ch == 32 || ch == 9 || ch == 13 || ch == 10 {
            advance()
            handled = 1
        }
        // Line comment: //
        if handled == 0 && ch == 47 && peek_at(1) == 47 {
            // Skip to end of line
            while pos < src_len && peek() != 10 {
                advance()
            }
            if pos < src_len { advance() }
            handled = 1
        }
        if handled == 0 {
            done = 1
        }
    }
}

fn is_alpha(uint64 ch) -> uint64 {
    if ch >= 65 && ch <= 90 { return 1 }
    if ch >= 97 && ch <= 122 { return 1 }
    if ch == 95 { return 1 }
    return 0
}

fn is_digit(uint64 ch) -> uint64 {
    if ch >= 48 && ch <= 57 { return 1 }
    return 0
}

fn is_alnum(uint64 ch) -> uint64 {
    if is_alpha(ch) != 0 { return 1 }
    if is_digit(ch) != 0 { return 1 }
    return 0
}

// Check if source[start..start+len] equals a keyword string
fn match_keyword(uint64 start, uint64 len, uint64 kw_ptr, uint64 kw_len) -> uint64 {
    if len != kw_len { return 0 }
    uint64 i = 0
    while i < len {
        uint64 sa = src_ptr + start + i
        uint64 sc = 0
        unsafe { *(sa as uint8) -> sc }
        uint64 ka = kw_ptr + i
        uint64 kc = 0
        unsafe { *(ka as uint8) -> kc }
        if sc != kc { return 0 }
        i = i + 1
    }
    return 1
}

fn classify_keyword(uint64 start, uint64 len) -> uint32 {
    // Check each keyword
    if match_keyword(start, len, "fn", 2) != 0 { return TokenKind.KwFn }
    if match_keyword(start, len, "return", 6) != 0 { return TokenKind.KwReturn }
    if match_keyword(start, len, "if", 2) != 0 { return TokenKind.KwIf }
    if match_keyword(start, len, "else", 4) != 0 { return TokenKind.KwElse }
    if match_keyword(start, len, "while", 5) != 0 { return TokenKind.KwWhile }
    if match_keyword(start, len, "for", 3) != 0 { return TokenKind.KwFor }
    if match_keyword(start, len, "in", 2) != 0 { return TokenKind.KwIn }
    if match_keyword(start, len, "break", 5) != 0 { return TokenKind.KwBreak }
    if match_keyword(start, len, "continue", 8) != 0 { return TokenKind.KwContinue }
    if match_keyword(start, len, "loop", 4) != 0 { return TokenKind.KwLoop }
    if match_keyword(start, len, "defer", 5) != 0 { return TokenKind.KwDefer }
    if match_keyword(start, len, "const", 5) != 0 { return TokenKind.KwConst }
    if match_keyword(start, len, "static", 6) != 0 { return TokenKind.KwStatic }
    if match_keyword(start, len, "struct", 6) != 0 { return TokenKind.KwStruct }
    if match_keyword(start, len, "enum", 4) != 0 { return TokenKind.KwEnum }
    if match_keyword(start, len, "extern", 6) != 0 { return TokenKind.KwExtern }
    if match_keyword(start, len, "import", 6) != 0 { return TokenKind.KwImport }
    if match_keyword(start, len, "unsafe", 6) != 0 { return TokenKind.KwUnsafe }
    if match_keyword(start, len, "true", 4) != 0 { return TokenKind.KwTrue }
    if match_keyword(start, len, "false", 5) != 0 { return TokenKind.KwFalse }
    if match_keyword(start, len, "match", 5) != 0 { return TokenKind.KwMatch }
    if match_keyword(start, len, "type", 4) != 0 { return TokenKind.KwType }
    // Type keywords (long forms)
    if match_keyword(start, len, "uint8", 5) != 0 { return TokenKind.KwUint8 }
    if match_keyword(start, len, "uint16", 6) != 0 { return TokenKind.KwUint16 }
    if match_keyword(start, len, "uint32", 6) != 0 { return TokenKind.KwUint32 }
    if match_keyword(start, len, "uint64", 6) != 0 { return TokenKind.KwUint64 }
    if match_keyword(start, len, "int8", 4) != 0 { return TokenKind.KwInt8 }
    if match_keyword(start, len, "int16", 5) != 0 { return TokenKind.KwInt16 }
    if match_keyword(start, len, "int32", 5) != 0 { return TokenKind.KwInt32 }
    if match_keyword(start, len, "int64", 5) != 0 { return TokenKind.KwInt64 }
    // Type keywords (short aliases)
    // Note: `byte` and `addr` are NOT keywords — they're common variable
    // names in real code, and making them reserved breaks existing programs.
    if match_keyword(start, len, "u8", 2) != 0 { return TokenKind.KwUint8 }
    if match_keyword(start, len, "u16", 3) != 0 { return TokenKind.KwUint16 }
    if match_keyword(start, len, "u32", 3) != 0 { return TokenKind.KwUint32 }
    if match_keyword(start, len, "u64", 3) != 0 { return TokenKind.KwUint64 }
    if match_keyword(start, len, "i8", 2) != 0 { return TokenKind.KwInt8 }
    if match_keyword(start, len, "i16", 3) != 0 { return TokenKind.KwInt16 }
    if match_keyword(start, len, "i32", 3) != 0 { return TokenKind.KwInt32 }
    if match_keyword(start, len, "i64", 3) != 0 { return TokenKind.KwInt64 }
    if match_keyword(start, len, "asm", 3) != 0 { return TokenKind.KwAsm }
    if match_keyword(start, len, "volatile", 8) != 0 { return TokenKind.KwVolatile }
    if match_keyword(start, len, "device", 6) != 0 { return TokenKind.KwDevice }
    if match_keyword(start, len, "at", 2) != 0 { return TokenKind.KwAt }
    if match_keyword(start, len, "f16", 3) != 0 { return TokenKind.KwFloat16 }
    if match_keyword(start, len, "f32", 3) != 0 { return TokenKind.KwFloat32 }
    if match_keyword(start, len, "f64", 3) != 0 { return TokenKind.KwFloat64 }
    // `float` aliases `f32` (single-precision, matches C/C++/Java convention).
    // `double` aliases `f64` so the C-style pair stays consistent.
    if match_keyword(start, len, "float", 5) != 0 { return TokenKind.KwFloat32 }
    if match_keyword(start, len, "double", 6) != 0 { return TokenKind.KwFloat64 }
    if match_keyword(start, len, "sizeof", 6) != 0 { return TokenKind.KwSizeof }
    if match_keyword(start, len, "bool", 4) != 0 { return TokenKind.KwBool }
    if match_keyword(start, len, "char", 4) != 0 { return TokenKind.KwChar }
    return TokenKind.Ident
}

fn lex_one_token() {
    uint64 ch = peek()
    uint64 start = pos
    uint32 tok_line = line

    // F-string: f"..." — prefix ASCII 'f' (102) followed by '"' (34)
    if ch == 102 {
        uint64 fstr_next = peek_at(1)
        if fstr_next == 34 {
            advance()  // consume 'f'
            advance()  // consume '"'
            emit_token(TokenKind.FStrBegin, start, 2, tok_line)

            uint64 part_start = pos
            uint64 fstr_running = 1
            while pos < src_len && fstr_running != 0 {
                uint64 fch = peek()
                if fch == 34 {
                    fstr_running = 0
                } else if fch == 123 {
                    // '{' — check for literal '{{'
                    uint64 fch2 = peek_at(1)
                    if fch2 == 123 {
                        advance()
                        advance()
                    } else {
                        // Flush accumulated StrPart before '{'
                        if pos > part_start {
                            uint64 plen = pos - part_start
                            emit_token(TokenKind.StrPart, part_start, plen, tok_line)
                        }
                        advance()  // consume '{'
                        // Lex inner expression tokens until matching '}' at depth 1
                        // (nested braces not supported in v1 f-string expressions)
                        uint64 depth = 1
                        while pos < src_len && depth > 0 {
                            skip_whitespace_and_comments()
                            if pos < src_len {
                                uint64 ic = peek()
                                if ic == 125 {
                                    advance()  // consume '}'
                                    depth = depth - 1
                                } else if ic == 123 {
                                    depth = depth + 1
                                    lex_one_token()
                                } else {
                                    lex_one_token()
                                }
                            } else {
                                depth = 0
                            }
                        }
                        part_start = pos
                    }
                } else if fch == 125 {
                    // '}' — literal '}}' means one '}'
                    uint64 fch2b = peek_at(1)
                    if fch2b == 125 {
                        advance()
                        advance()
                    } else {
                        advance()
                    }
                } else {
                    advance()
                }
            }
            // Flush trailing StrPart
            if pos > part_start {
                uint64 plen2 = pos - part_start
                emit_token(TokenKind.StrPart, part_start, plen2, tok_line)
            }
            if pos < src_len { advance() }  // consume closing '"'
            emit_token(TokenKind.FStrEnd, pos, 0, tok_line)
            return
        }
    }

    // Identifier or keyword
    if is_alpha(ch) != 0 {
        while pos < src_len && is_alnum(peek()) != 0 {
            advance()
        }
        uint64 len = pos - start
        uint32 kind = classify_keyword(start, len)
        emit_token(kind, start, len, tok_line)
        return
    }

    // Integer literal (decimal or 0x hex)
    if is_digit(ch) != 0 {
        if ch == 48 && peek_at(1) == 120 {
            // 0x hex literal
            advance()
            advance()
            // Consume hex digits (avoid break-in-if: use condition in while)
            uint64 hex_ok = 1
            while pos < src_len && hex_ok != 0 {
                uint64 c = peek()
                if is_digit(c) != 0 || (c >= 97 && c <= 102) || (c >= 65 && c <= 70) {
                    advance()
                } else {
                    hex_ok = 0
                }
            }
        } else {
            while pos < src_len && is_digit(peek()) != 0 {
                advance()
            }
            // Float literal: either digits.digits[exp][f] or digits exp [f].
            // Scientific-notation exponent: (e|E)(+|-)? digits — enables
            // ML-style literals (1e-3, 5.5e-4, 3.14E+10) without forcing
            // users to write 0.001. Both lower- and upper-case 'e'.
            uint64 is_float = 0
            if pos < src_len && peek() == 46 {
                uint64 after_dot = peek_at(1)
                if after_dot >= 48 && after_dot <= 57 {
                    advance()
                    while pos < src_len && is_digit(peek()) != 0 {
                        advance()
                    }
                    is_float = 1
                }
            }
            if pos < src_len && (peek() == 101 || peek() == 69) {
                // 'e' or 'E' — but only if at least one exponent digit follows
                // (optionally preceded by + or -). This avoids eating a
                // trailing 'e' that's actually the start of an identifier.
                uint64 exp_probe = 1
                uint64 c1 = peek_at(exp_probe)
                if c1 == 43 || c1 == 45 { exp_probe = exp_probe + 1; c1 = peek_at(exp_probe) }
                if c1 >= 48 && c1 <= 57 {
                    advance()                                // consume e/E
                    if peek() == 43 || peek() == 45 { advance() }
                    while pos < src_len && is_digit(peek()) != 0 {
                        advance()
                    }
                    is_float = 1
                }
            }
            if is_float != 0 {
                if pos < src_len && peek() == 102 { advance() }
                emit_token(TokenKind.FloatLit, start, pos - start, tok_line)
                return
            }
        }
        emit_token(TokenKind.IntLit, start, pos - start, tok_line)
        return
    }

    // String literal
    if ch == 34 {
        advance()
        while pos < src_len && peek() != 34 {
            if peek() == 92 { advance() }
            advance()
        }
        if pos < src_len { advance() }
        emit_token(TokenKind.StrLit, start, pos - start, tok_line)
        return
    }

    // Char literal. Scan up to the closing ' so that escapes longer than two
    // bytes ('\\xAB', '\\n', …) all fit inside one CharLit token. parse_int_token
    // validates the content.
    if ch == 39 {
        advance()
        while pos < src_len && peek() != 39 {
            if peek() == 92 { advance() }
            advance()
        }
        if pos < src_len { advance() }
        emit_token(TokenKind.CharLit, start, pos - start, tok_line)
        return
    }

    // Two-char operators (check before single-char)
    uint64 next = peek_at(1)
    advance()

    if ch == 61 && next == 61 { advance(); emit_token(TokenKind.EqEq, start, 2, tok_line); return }
    if ch == 61 && next == 62 { advance(); emit_token(TokenKind.FatArrow, start, 2, tok_line); return }
    if ch == 33 && next == 61 { advance(); emit_token(TokenKind.BangEq, start, 2, tok_line); return }
    if ch == 60 && next == 61 { advance(); emit_token(TokenKind.LtEq, start, 2, tok_line); return }
    if ch == 62 && next == 61 { advance(); emit_token(TokenKind.GtEq, start, 2, tok_line); return }
    if ch == 38 && next == 38 { advance(); emit_token(TokenKind.AmpAmp, start, 2, tok_line); return }
    if ch == 124 && next == 124 { advance(); emit_token(TokenKind.PipePipe, start, 2, tok_line); return }
    if ch == 60 && next == 60 { advance(); emit_token(TokenKind.LtLt, start, 2, tok_line); return }
    if ch == 62 && next == 62 { advance(); emit_token(TokenKind.GtGt, start, 2, tok_line); return }
    if ch == 45 && next == 62 { advance(); emit_token(TokenKind.Arrow, start, 2, tok_line); return }
    if ch == 43 && next == 61 { advance(); emit_token(TokenKind.PlusEq, start, 2, tok_line); return }
    if ch == 45 && next == 61 { advance(); emit_token(TokenKind.MinusEq, start, 2, tok_line); return }
    if ch == 42 && next == 61 { advance(); emit_token(TokenKind.StarEq, start, 2, tok_line); return }
    if ch == 47 && next == 61 { advance(); emit_token(TokenKind.SlashEq, start, 2, tok_line); return }
    if ch == 37 && next == 61 { advance(); emit_token(TokenKind.PercentEq, start, 2, tok_line); return }
    if ch == 38 && next == 61 { advance(); emit_token(TokenKind.AmpEq, start, 2, tok_line); return }
    if ch == 124 && next == 61 { advance(); emit_token(TokenKind.PipeEq, start, 2, tok_line); return }
    if ch == 94 && next == 61 { advance(); emit_token(TokenKind.CaretEq, start, 2, tok_line); return }

    // Single-char tokens
    if ch == 40 { emit_token(TokenKind.LParen, start, 1, tok_line); return }
    if ch == 41 { emit_token(TokenKind.RParen, start, 1, tok_line); return }
    if ch == 123 { emit_token(TokenKind.LBrace, start, 1, tok_line); return }
    if ch == 125 { emit_token(TokenKind.RBrace, start, 1, tok_line); return }
    if ch == 91 { emit_token(TokenKind.LBracket, start, 1, tok_line); return }
    if ch == 93 { emit_token(TokenKind.RBracket, start, 1, tok_line); return }
    if ch == 44 { emit_token(TokenKind.Comma, start, 1, tok_line); return }
    if ch == 46 { emit_token(TokenKind.Dot, start, 1, tok_line); return }
    if ch == 59 { emit_token(TokenKind.Semicolon, start, 1, tok_line); return }
    if ch == 58 { emit_token(TokenKind.Colon, start, 1, tok_line); return }
    if ch == 64 { emit_token(TokenKind.At, start, 1, tok_line); return }
    if ch == 42 { emit_token(TokenKind.Star, start, 1, tok_line); return }
    if ch == 43 { emit_token(TokenKind.Plus, start, 1, tok_line); return }
    if ch == 45 { emit_token(TokenKind.Minus, start, 1, tok_line); return }
    if ch == 47 { emit_token(TokenKind.Slash, start, 1, tok_line); return }
    if ch == 37 { emit_token(TokenKind.Percent, start, 1, tok_line); return }
    if ch == 61 { emit_token(TokenKind.Eq, start, 1, tok_line); return }
    if ch == 60 { emit_token(TokenKind.Lt, start, 1, tok_line); return }
    if ch == 62 { emit_token(TokenKind.Gt, start, 1, tok_line); return }
    if ch == 38 { emit_token(TokenKind.Ampersand, start, 1, tok_line); return }
    if ch == 124 { emit_token(TokenKind.Pipe, start, 1, tok_line); return }
    if ch == 94 { emit_token(TokenKind.Caret, start, 1, tok_line); return }
    if ch == 126 { emit_token(TokenKind.Tilde, start, 1, tok_line); return }
    if ch == 33 { emit_token(TokenKind.Bang, start, 1, tok_line); return }
    if ch == 63 { emit_token(TokenKind.Question, start, 1, tok_line); return }

    // Unknown character
    emit_token(TokenKind.Error, start, 1, tok_line)
}
// MLRift — built on KernRift — AST node definitions
//
// Arena-based flat AST. Each node is 32 bytes:
//   [0..4)   node_kind (uint32)
//   [4..8)   data1     (uint32) — meaning depends on kind
//   [8..12)  data2     (uint32)
//   [12..16) data3     (uint32)
//   [16..20) data4     (uint32)
//   [20..24) tok_idx   (uint32) — index of the primary token
//   [24..28) child     (uint32) — first child node index (0 = none)
//   [28..32) next      (uint32) — next sibling node index (0 = none)

// ---------------------------------------------------------------------------
// AST node kinds
// ---------------------------------------------------------------------------

enum AstKind {
    None = 0

    // Top-level
    Module = 1         // children: list of function/struct/enum/static decls
    FnDecl = 2         // data1=name_tok, data2=return_type_tok (0=void), child=first param, next=body
    Param = 3          // data1=type_tok, data2=name_tok
    StaticDecl = 4     // data1=type_tok, data2=name_tok, data3=init_value

    // Statements
    VarDecl = 10       // data1=type_tok, data2=name_tok, child=init_expr (0=none)
    Assign = 11        // data1=name_tok, child=value_expr
    Return = 12        // child=expr (0=void return)
    If = 13            // child=condition_expr, data1=then_body_idx, data2=else_body_idx (0=none)
    While = 14         // child=condition_expr, data1=body_idx
    Block = 15         // child=first statement
    ExprStmt = 16      // child=expression
    Break = 17
    Continue = 18
    Match = 19         // child=scrutinee_expr, data1=first_arm_idx
    MatchArm = 20      // data1=value_expr_idx, data2=body_block_idx, next=next_arm

    // Expressions
    IntLit = 30        // data1=tok_idx (for the value)
    StrLit = 31        // data1=tok_idx
    Ident = 32         // data1=tok_idx
    BinOp = 33         // data1=operator_tok, child=lhs, data2=rhs_idx
    UnaryOp = 34       // data1=operator_tok, child=operand
    Call = 35          // data1=callee_tok, child=first_arg
    FieldAccess = 36   // data1=object_tok, data2=field_tok
    Index = 37         // child=array_expr, data1=index_expr_idx
    Compare = 38       // data1=operator_tok, child=lhs, data2=rhs_idx
    LogicalAnd = 39    // child=lhs, data1=rhs_idx
    LogicalOr = 40     // child=lhs, data1=rhs_idx

    // Inline assembly
    AsmBlock = 43      // data1=first_str_tok, child=linked list of string nodes (each StrLit)

    // 2-tuple destructuring assignment: `(T1 a, T2 b) = rhs_expr`
    // Scoped to two elements for now. Returns are signalled by Return.data3
    // holding the second expression index (child is still the first).
    TupleDestruct = 44 // data1=type1_tok, data2=name1_tok, data3=type2_tok,
                       // data4=name2_tok, child=rhs_expr

    // Inline-assembly I/O constraint — a single entry in the in/out/clobber
    // list attached to an AsmBlock. AsmBlock.data3 holds the head of a
    // `next`-linked list of these.
    //
    //   data1 = kind (0 = in, 1 = out, 2 = clobber)
    //   data2 = register-name token (e.g. "rax", "x0")
    //   data3 = variable-name token (0 for clobber entries)
    AsmConstraint = 45

    FloatLitNode = 46    // data1=tok_idx

    // 3-tuple destructuring assignment: `(T1 a, T2 b, T3 c) = rhs_expr`
    // data1=type1_tok, data2=name1_tok, data3=type2_tok, data4=name2_tok
    // tok_idx=name3_tok, child=rhs_expr
    TupleDestruct3 = 47
    StructLit = 48       // (reserved for struct literals)
    SizeofLit = 49       // data1=resolved_size (low 32 bits)
    FString = 50         // f-string: child=first segment (StrLit or expr), ...
    Defer = 51           // defer { body }; data1=body_block_idx — codegen
                         // emits body (LIFO) before every return/fall-through
    RangePat = 52        // match range pattern: data1=lo_expr, data2=hi_expr,
                         // data3=inclusive_flag (1 = ..= inclusive, 0 = .. exclusive)
}

// ---------------------------------------------------------------------------
// AST arena
// ---------------------------------------------------------------------------

static uint64 ast_buf = 0       // pointer to node arena
static uint64 ast_count = 0     // number of nodes allocated
static uint64 ast_capacity = 0  // max nodes

// Node size in bytes
// const uint64 NODE_SIZE = 32  -- can't use const with uint64 yet, hardcode 32

@export
fn ast_init(uint64 max_nodes) {
    ast_buf = alloc(max_nodes * 32)
    ast_count = 0
    ast_capacity = max_nodes
}

// Allocate a new AST node. Returns the node index (1-based, 0 = null).
@export
fn ast_alloc(uint64 kind) -> uint64 {
    if ast_count >= ast_capacity { return 0 }
    ast_count = ast_count + 1
    uint64 idx = ast_count
    uint64 base = ast_buf + (idx - 1) * 32

    // Zero-fill
    uint64 i = 0
    while i < 32 {
        uint64 p = base + i
        unsafe { *(p as uint8) = 0 }
        i = i + 1
    }

    // Set kind
    uint32 k32 = kind
    unsafe { *(base as uint32) = k32 }

    return idx
}

// Accessors — read/write node fields by index
fn node_base(uint64 idx) -> uint64 {
    return ast_buf + (idx - 1) * 32
}

@export
fn ast_kind(uint64 idx) -> uint32 {
    uint64 p = node_base(idx)
    uint32 val = 0
    unsafe { *(p as uint32) -> val }
    return val
}

@export
fn ast_set_data1(uint64 idx, uint32 val) {
    uint64 p = node_base(idx) + 4
    unsafe { *(p as uint32) = val }
}

@export
fn ast_data1(uint64 idx) -> uint32 {
    uint64 p = node_base(idx) + 4
    uint32 val = 0
    unsafe { *(p as uint32) -> val }
    return val
}

@export
fn ast_set_data2(uint64 idx, uint32 val) {
    uint64 p = node_base(idx) + 8
    unsafe { *(p as uint32) = val }
}

@export
fn ast_data2(uint64 idx) -> uint32 {
    uint64 p = node_base(idx) + 8
    uint32 val = 0
    unsafe { *(p as uint32) -> val }
    return val
}

@export
fn ast_data3(uint64 idx) -> uint32 {
    uint64 p = node_base(idx) + 12
    uint32 val = 0
    unsafe { *(p as uint32) -> val }
    return val
}

@export
fn ast_set_data3(uint64 idx, uint32 val) {
    uint64 p = node_base(idx) + 12
    unsafe { *(p as uint32) = val }
}

@export
fn ast_set_data4(uint64 idx, uint32 val) {
    uint64 p = node_base(idx) + 16
    unsafe { *(p as uint32) = val }
}

@export
fn ast_data4(uint64 idx) -> uint32 {
    uint64 p = node_base(idx) + 16
    uint32 val = 0
    unsafe { *(p as uint32) -> val }
    return val
}

// Predicate: bit 4 of an FnDecl's data4 — set by parser when `@kernel`
// annotation is present. Used by format_hip.kr to identify GPU kernel
// functions; CPU backends may eventually skip them. See src/ir_hip.kr
// and docs/GPU_BACKEND.md.
@export
fn ast_fn_is_kernel(uint64 fn_node) -> uint64 {
    uint32 flags = ast_data4(fn_node)
    uint64 f = flags
    return (f >> 4) & 1
}

@export
fn ast_set_tok(uint64 idx, uint32 tok) {
    uint64 p = node_base(idx) + 20
    unsafe { *(p as uint32) = tok }
}

@export
fn ast_tok(uint64 idx) -> uint32 {
    uint64 p = node_base(idx) + 20
    uint32 val = 0
    unsafe { *(p as uint32) -> val }
    return val
}

@export
fn ast_set_child(uint64 idx, uint32 child) {
    uint64 p = node_base(idx) + 24
    unsafe { *(p as uint32) = child }
}

@export
fn ast_child(uint64 idx) -> uint32 {
    uint64 p = node_base(idx) + 24
    uint32 val = 0
    unsafe { *(p as uint32) -> val }
    return val
}

@export
fn ast_set_next(uint64 idx, uint32 next_sib) {
    uint64 p = node_base(idx) + 28
    unsafe { *(p as uint32) = next_sib }
}

@export
fn ast_next(uint64 idx) -> uint32 {
    uint64 p = node_base(idx) + 28
    uint32 val = 0
    unsafe { *(p as uint32) -> val }
    return val
}

// Append a sibling to the end of a linked list
@export
fn ast_append_child(uint64 parent_idx, uint64 child_idx) {
    uint32 c32 = child_idx
    uint32 existing = ast_child(parent_idx)
    if existing == 0 {
        ast_set_child(parent_idx, c32)
        return
    }
    // Walk to last sibling
    uint64 cur = existing
    uint32 n = ast_next(cur)
    while n != 0 {
        cur = n
        n = ast_next(cur)
    }
    ast_set_next(cur, c32)
}
// MLRift — built on KernRift — Parser
//
// Recursive descent parser. Reads tokens produced by the lexer
// and builds a flat AST using the arena in ast.kr.

// Token buffer access (shared with lexer)
static uint64 p_tok_buf = 0
static uint64 p_tok_count = 0
static uint64 p_tok_pos = 0       // current token index

// Read a token field
fn tok_kind_at(uint64 idx) -> uint32 {
    uint64 p = p_tok_buf + idx * 16
    uint32 val = 0
    unsafe { *(p as uint32) -> val }
    return val
}

fn tok_start_at(uint64 idx) -> uint32 {
    uint64 p = p_tok_buf + idx * 16 + 4
    uint32 val = 0
    unsafe { *(p as uint32) -> val }
    return val
}

fn tok_len_at(uint64 idx) -> uint32 {
    uint64 p = p_tok_buf + idx * 16 + 8
    uint32 val = 0
    unsafe { *(p as uint32) -> val }
    return val
}

// Current token helpers
fn cur_kind() -> uint32 {
    return tok_kind_at(p_tok_pos)
}

fn cur_tok() -> uint64 {
    return p_tok_pos
}

fn advance_tok() -> uint64 {
    uint64 prev = p_tok_pos
    p_tok_pos = p_tok_pos + 1
    return prev
}

fn tok_line_at(uint64 idx) -> uint32 {
    uint64 p = p_tok_buf + idx * 16 + 12
    uint32 val = 0
    unsafe { *(p as uint32) -> val }
    return val
}

fn tok_kind_name(uint64 kind) -> uint64 {
    if kind == 0 { return "end of file" }
    if kind == 1 { return "identifier" }
    if kind == 2 { return "integer" }
    if kind == 3 { return "string" }
    if kind == 10 { return "'('" }
    if kind == 11 { return "')'" }
    if kind == 12 { return "'{'" }
    if kind == 13 { return "'}'" }
    if kind == 14 { return "'['" }
    if kind == 15 { return "']'" }
    if kind == 16 { return "','" }
    if kind == 17 { return "'.'" }
    if kind == 18 { return "';'" }
    if kind == 29 { return "'=>'" }
    if kind == 34 { return "'='" }
    if kind == 60 { return "'fn'" }
    if kind == 61 { return "'if'" }
    if kind == 62 { return "'else'" }
    if kind == 63 { return "'while'" }
    if kind == 65 { return "'for'" }
    if kind == 67 { return "'break'" }
    if kind == 68 { return "'continue'" }
    if kind == 69 { return "'return'" }
    if kind == 70 { return "'const'" }
    if kind == 71 { return "'static'" }
    if kind == 72 { return "'struct'" }
    if kind == 73 { return "'enum'" }
    if kind == 75 { return "'import'" }
    if kind == 76 { return "'unsafe'" }
    if kind == 77 { return "'true'" }
    if kind == 78 { return "'false'" }
    if kind == 80 { return "'uint8'" }
    if kind == 83 { return "'uint64'" }
    if kind == 98 { return "'bool'" }
    if kind == 99 { return "'char'" }
    if kind == 88 { return "'match'" }
    if kind == 89 { return "'type'" }
    if kind == 90 { return "'asm'" }
    if kind == 91 { return "'volatile'" }
    if kind == 94 { return "'f16'" }
    if kind == 95 { return "'f32'" }
    if kind == 96 { return "'f64'" }
    return "token"
}

fn expect(uint32 kind) -> uint64 {
    if cur_kind() != kind {
        uint8[32] nb
        uint32 line_num = tok_line_at(p_tok_pos)
        uint64 wln = line_num
        write(2, "error at line ", 14)
        uint64 l = fmt_uint(nb, wln)
        write(2, nb, l)
        write(2, ": expected ", 11)
        uint64 ename = tok_kind_name(kind)
        write(2, ename, str_len(ename))
        write(2, ", got ", 6)
        uint64 gname = tok_kind_name(cur_kind())
        write(2, gname, str_len(gname))
        // Show the actual text of the unexpected token
        if cur_kind() == 1 || cur_kind() == 2 || cur_kind() == 3 {
            write(2, " '", 2)
            uint64 ts = tok_text_start(p_tok_pos)
            uint64 tl = tok_text_len(p_tok_pos)
            write(2, cg_source + ts, tl)
            write(2, "'", 1)
        }
        write(2, "\n", 1)
        exit(1)
    }
    return advance_tok()
}

fn at_kind(uint32 kind) -> uint64 {
    if cur_kind() == kind { return 1 }
    return 0
}

fn eat(uint32 kind) -> uint64 {
    if cur_kind() == kind {
        advance_tok()
        return 1
    }
    return 0
}

// ---------------------------------------------------------------------------
// Parser init
// ---------------------------------------------------------------------------

@export
fn parser_init(uint64 tokens, uint64 count_val) {
    p_tok_buf = tokens
    p_tok_count = count_val
    p_tok_pos = 0
}

// ---------------------------------------------------------------------------
// Expression parsing (Pratt-style precedence climbing)
// ---------------------------------------------------------------------------

fn parse_primary() -> uint64 {
    uint32 kind = cur_kind()

    // Unary operators: !, -, ~
    if kind == 27 || kind == 31 || kind == 26 {
        uint64 op_tok = advance_tok()
        uint64 operand = parse_primary()
        uint64 node = ast_alloc(AstKind.UnaryOp)
        uint32 ot = op_tok
        ast_set_data1(node, ot)
        uint32 op32 = operand
        ast_set_child(node, op32)
        ast_set_tok(node, ot)
        return node
    }

    // sizeof(Type) or sizeof(StructName) → compile-time integer
    if kind == 97 {
        uint64 sz_tok = advance_tok()
        expect(10)
        uint64 arg_tok = advance_tok()
        uint32 arg_kind = tok_kind_at(arg_tok)
        expect(11)
        uint64 size = 8
        if arg_kind == 80 || arg_kind == 84 || arg_kind == 98 || arg_kind == 99 { size = 1 }
        else if arg_kind == 81 || arg_kind == 85 { size = 2 }
        else if arg_kind == 82 || arg_kind == 86 { size = 4 }
        else if arg_kind == 83 || arg_kind == 87 { size = 8 }
        else if arg_kind == 94 { size = 2 }
        else if arg_kind == 95 { size = 4 }
        else if arg_kind == 96 { size = 8 }
        else {
            uint64 si = struct_lookup(arg_tok)
            if si != 0xFFFFFFFF {
                size = struct_total_size(si)
            }
        }
        uint64 node = ast_alloc(49)
        uint32 sz32 = size
        ast_set_data1(node, sz32)
        uint32 st32 = sz_tok
        ast_set_tok(node, st32)
        return node
    }

    // Integer literal
    if kind == 2 {
        uint64 tok = advance_tok()
        uint64 node = ast_alloc(AstKind.IntLit)
        uint32 t32 = tok
        ast_set_data1(node, t32)
        ast_set_tok(node, t32)
        return node
    }

    // Float literal
    if kind == 5 {
        uint64 tok = advance_tok()
        uint64 node = ast_alloc(46)
        uint32 t32 = tok
        ast_set_data1(node, t32)
        ast_set_tok(node, t32)
        return node
    }

    // String literal
    if kind == 3 {
        uint64 tok = advance_tok()
        uint64 node = ast_alloc(AstKind.StrLit)
        uint32 t32 = tok
        ast_set_data1(node, t32)
        ast_set_tok(node, t32)
        return node
    }

    // Char literal → convert to integer value, tag with KwChar (99) for sema
    if kind == 4 {
        uint64 tok = advance_tok()
        uint64 node = ast_alloc(AstKind.IntLit)
        uint32 t32 = tok
        ast_set_data1(node, t32)
        ast_set_tok(node, t32)
        // Tag with char type so sema can enforce strict char/int separation
        uint32 char_tag = 99
        ast_set_data4(node, char_tag)
        return node
    }

    // Identifier (may be followed by ( for call, . for field, [ for index)
    if kind == 1 {
        uint64 tok = advance_tok()
        uint32 t32 = tok

        // Generic call: ident<Type>(args...) or ident<T, U>(args...)
        // Lookahead: if < is followed by tokens ending with > then (, skip the <...>
        if cur_kind() == 37 {
            uint64 la = p_tok_pos + 1
            uint64 is_generic = 0
            while tok_kind_at(la) != 0 {
                if tok_kind_at(la) == 39 {
                    if tok_kind_at(la + 1) == 10 {
                        is_generic = 1
                    }
                    la = la + 1
                    break
                }
                // Only type keywords, identifiers, and commas allowed inside <...>
                uint32 lk = tok_kind_at(la)
                if is_type_keyword(lk) != 0 || lk == 1 || lk == 16 {
                    la = la + 1
                } else {
                    break
                }
            }
            if is_generic != 0 {
                // Skip < ... > tokens
                advance_tok()
                while cur_kind() != 39 && cur_kind() != 0 {
                    advance_tok()
                }
                if cur_kind() == 39 {
                    advance_tok()
                }
            }
        }

        // Function call: ident(args...)
        if cur_kind() == 10 {
            advance_tok()
            uint64 call_node = ast_alloc(AstKind.Call)
            ast_set_data1(call_node, t32)
            ast_set_tok(call_node, t32)

            if cur_kind() != 11 {
                uint64 arg = parse_expr()
                uint32 a32 = arg
                ast_append_child(call_node, arg)
                while eat(16) != 0 {
                    arg = parse_expr()
                    ast_append_child(call_node, arg)
                }
            }
            expect(11)
            return call_node
        }

        // Array indexing: ident[expr]  (optionally followed by .field for struct arrays)
        if cur_kind() == 14 {
            advance_tok()
            uint64 idx_expr = parse_expr()
            expect(15)
            uint64 idx_node = ast_alloc(AstKind.Index)
            ast_set_data1(idx_node, t32)
            uint32 ie = idx_expr
            ast_set_child(idx_node, ie)
            ast_set_tok(idx_node, t32)
            // Optional .field access (for struct arrays: pts[i].field)
            if cur_kind() == 17 {
                advance_tok()
                uint64 sfield_tok = advance_tok()
                uint64 fa_node = ast_alloc(AstKind.FieldAccess)
                uint32 ic = idx_node
                ast_set_child(fa_node, ic)
                uint32 sft = sfield_tok
                ast_set_data2(fa_node, sft)
                ast_set_tok(fa_node, sft)
                return fa_node
            }
            return idx_node
        }

        // Field access (possibly chained): ident.field or ident.field.field2...
        // Or method call: ident.method(args) — sugar for method(ident, args)
        // Guard against the range operator `..` — `x..y` must parse as two
        // separate expressions bracketing a range, not as `x.y` field
        // access. If the next two tokens are both dots, bail out here and
        // let the outer for-loop / range context consume them.
        if cur_kind() == 17 && tok_kind_at(p_tok_pos + 1) == 17 {
            uint64 range_node = ast_alloc(AstKind.Ident)
            ast_set_data1(range_node, t32)
            ast_set_tok(range_node, t32)
            return range_node
        }
        if cur_kind() == 17 {
            // Build initial Ident node for the base object
            uint64 obj_node = ast_alloc(AstKind.Ident)
            ast_set_data1(obj_node, t32)
            ast_set_tok(obj_node, t32)

            // Track the last field token and its object, so we can turn the
            // final .field into a method call if followed by '('
            uint64 last_field_tok = 0
            uint64 last_obj = 0

            while cur_kind() == 17 {
                advance_tok()
                uint64 field_tok = advance_tok()

                // If this is the last field in the chain AND followed by '(',
                // treat it as a method call, not a field access.
                if cur_kind() == 10 {
                    // Method call: field_tok is the method name, obj_node is self
                    advance_tok()
                    uint64 call_node = ast_alloc(AstKind.Call)
                    uint32 mt = field_tok
                    ast_set_data1(call_node, mt)
                    ast_set_tok(call_node, mt)
                    // Append self (obj_node) as the first argument
                    uint32 sc = obj_node
                    ast_append_child(call_node, sc)
                    // Then parse any additional arguments
                    if cur_kind() != 11 {
                        uint64 arg = parse_expr()
                        ast_append_child(call_node, arg)
                        while eat(16) != 0 {
                            arg = parse_expr()
                            ast_append_child(call_node, arg)
                        }
                    }
                    expect(11)
                    obj_node = call_node
                    // After the method call, may be followed by more .field or .method()
                    // Continue the outer while loop to handle chaining
                } else {
                    uint64 field_node = ast_alloc(AstKind.FieldAccess)
                    uint32 oc = obj_node
                    ast_set_child(field_node, oc)
                    uint32 ft = field_tok
                    ast_set_data2(field_node, ft)
                    ast_set_tok(field_node, ft)
                    obj_node = field_node
                    last_field_tok = field_tok
                    last_obj = obj_node
                }
            }
            return obj_node
        }

        // Struct literal: StructName { field_values... }
        if cur_kind() == 12 {
            uint64 si = struct_lookup(tok)
            if si != 0xFFFFFFFF {
                advance_tok()  // consume '{'
                uint64 slit = ast_alloc(48)  // StructLit
                ast_set_data1(slit, t32)     // struct name token
                // Detect named vs positional
                // Named: Ident followed by ':' (Colon = 19)
                uint64 is_named = 0
                if cur_kind() == 1 {
                    uint32 k_after = tok_kind_at(p_tok_pos + 1)
                    uint64 wka = k_after
                    if wka == 19 { is_named = 1 }
                }
                uint32 named32 = is_named
                ast_set_data2(slit, named32)
                // Parse field values
                while cur_kind() != 13 && cur_kind() != 0 {
                    if is_named != 0 {
                        uint64 field_name = advance_tok()
                        expect(19)  // ':'
                        uint64 val_expr = parse_expr()
                        uint32 fn32 = field_name
                        ast_set_tok(val_expr, fn32)
                        ast_append_child(slit, val_expr)
                    } else {
                        uint64 val_expr = parse_expr()
                        ast_append_child(slit, val_expr)
                    }
                    eat(16)  // optional ','
                }
                expect(13)  // '}'
                return slit
            }
        }

        // Plain identifier
        uint64 node = ast_alloc(AstKind.Ident)
        ast_set_data1(node, t32)
        ast_set_tok(node, t32)
        return node
    }

    // Boolean literals: true → 1, false → 0
    if kind == 77 || kind == 78 {
        uint64 tok = advance_tok()
        uint64 node = ast_alloc(AstKind.IntLit)
        uint32 t32 = tok
        ast_set_data1(node, t32)
        ast_set_tok(node, t32)
        // Tag with bool type so sema can enforce strict bool/int separation
        uint32 bool_tag = 98
        ast_set_data4(node, bool_tag)
        return node
    }

    // F-string: FStrBegin(100) [StrPart(101) | expr]* FStrEnd(102)
    if kind == 100 {
        uint64 fstr_tok = advance_tok()  // consume FStrBegin
        uint64 fstr_node = ast_alloc(50)  // AstKind.FString = 50
        uint32 ft32 = fstr_tok
        ast_set_tok(fstr_node, ft32)

        uint32 cur = cur_kind()
        uint64 wcur = cur
        while wcur != 102 && wcur != 0 {
            if wcur == 101 {
                // StrPart: store as StrLit node with data1=tok_index
                uint64 part_tok = advance_tok()
                uint64 part_node = ast_alloc(AstKind.StrLit)
                uint32 pt32 = part_tok
                ast_set_data1(part_node, pt32)
                ast_set_tok(part_node, pt32)
                // Mark as raw (no quotes): data2 = 1
                uint32 raw_mark = 1
                ast_set_data2(part_node, raw_mark)
                ast_append_child(fstr_node, part_node)
            } else {
                uint64 expr_node = parse_expr()
                ast_append_child(fstr_node, expr_node)
            }
            cur = cur_kind()
            wcur = cur
        }
        if wcur == 102 { advance_tok() }  // consume FStrEnd
        return fstr_node
    }

    // Parenthesized expression
    if kind == 10 {
        advance_tok()
        uint64 inner = parse_expr()
        expect(11)
        return inner
    }

    // Error
    uint8[32] nb
    uint32 err_line = tok_line_at(p_tok_pos)
    uint64 werr = err_line
    write(2, "error at line ", 14)
    uint64 l = fmt_uint(nb, werr)
    write(2, nb, l)
    write(2, ": unexpected ", 13)
    uint64 ename = tok_kind_name(kind)
    write(2, ename, str_len(ename))
    if kind == 1 || kind == 2 || kind == 3 {
        write(2, " '", 2)
        uint64 ts = tok_text_start(p_tok_pos)
        uint64 tl = tok_text_len(p_tok_pos)
        write(2, cg_source + ts, tl)
        write(2, "'", 1)
    }
    write(2, " in expression\n", 15)
    exit(1)
    return 0
}

fn binop_precedence(uint32 kind) -> uint32 {
    // ||
    if kind == 42 { return 1 }
    // &&
    if kind == 41 { return 2 }
    // == !=
    if kind == 35 { return 3 }
    if kind == 36 { return 3 }
    // < <= > >=
    if kind == 37 { return 4 }
    if kind == 38 { return 4 }
    if kind == 39 { return 4 }
    if kind == 40 { return 4 }
    // + -
    if kind == 30 { return 5 }
    if kind == 31 { return 5 }
    // * / %
    if kind == 22 { return 6 }
    if kind == 32 { return 6 }
    if kind == 33 { return 6 }
    // << >>
    if kind == 43 { return 7 }
    if kind == 44 { return 7 }
    // & | ^
    if kind == 23 { return 8 }
    if kind == 24 { return 8 }
    if kind == 25 { return 8 }
    return 0
}

fn is_comparison(uint32 kind) -> uint64 {
    if kind == 35 { return 1 }
    if kind == 36 { return 1 }
    if kind == 37 { return 1 }
    if kind == 38 { return 1 }
    if kind == 39 { return 1 }
    if kind == 40 { return 1 }
    return 0
}

@export
fn parse_expr() -> uint64 {
    return parse_expr_prec(1)
}

fn parse_expr_prec(uint32 min_prec) -> uint64 {
    uint64 lhs = parse_primary()

    while binop_precedence(cur_kind()) >= min_prec {
        uint32 op_kind = cur_kind()
        uint32 prec = binop_precedence(op_kind)
        uint64 op_tok = advance_tok()
        uint64 rhs = parse_expr_prec(prec + 1)

        uint64 node = 0
        if op_kind == 42 {
            node = ast_alloc(AstKind.LogicalOr)
        } else if op_kind == 41 {
            node = ast_alloc(AstKind.LogicalAnd)
        } else if is_comparison(op_kind) != 0 {
            node = ast_alloc(AstKind.Compare)
        } else {
            node = ast_alloc(AstKind.BinOp)
        }

        uint32 o32 = op_tok
        ast_set_data1(node, o32)
        ast_set_tok(node, o32)
        uint32 l32 = lhs
        ast_set_child(node, l32)
        uint32 r32 = rhs
        ast_set_data2(node, r32)

        lhs = node
    }

    return lhs
}

// ---------------------------------------------------------------------------
// Statement parsing
// ---------------------------------------------------------------------------

fn is_type_keyword(uint32 kind) -> uint64 {
    if kind >= 80 && kind <= 87 { return 1 }
    if kind >= 94 && kind <= 96 { return 1 }
    if kind == 98 { return 1 }
    if kind == 99 { return 1 }
    return 0
}

// Parse one match-arm pattern. Most patterns are bare expressions
// (IntLits, Idents, `_`). A range pattern takes the form `lo .. hi` or
// `lo ..= hi` and gets wrapped in a RangePat (kind 52) AST node so
// codegen knows to emit two bounds checks instead of a single equality
// comparison.
fn parse_match_pattern() -> uint64 {
    uint64 lo_expr = parse_expr()
    // If the next token isn't `.`, this is a plain pattern.
    if cur_kind() != 17 { return lo_expr }
    advance_tok()                          // first `.`
    if cur_kind() != 17 {
        // Only one dot — not a range. Parser shouldn't reach here for
        // anything valid; treat as plain and leave the stray dot for
        // the caller's expect() to error on.
        return lo_expr
    }
    advance_tok()                          // second `.`
    uint64 inclusive = 0
    if cur_kind() == 34 {                  // optional `=`
        advance_tok()
        inclusive = 1
    }
    uint64 hi_expr = parse_expr()
    uint64 rp = ast_alloc(52)
    uint32 lo32 = lo_expr
    ast_set_data1(rp, lo32)
    uint32 hi32 = hi_expr
    ast_set_data2(rp, hi32)
    uint32 inc32 = inclusive
    ast_set_data3(rp, inc32)
    return rp
}

fn parse_stmt() -> uint64 {
    uint32 kind = cur_kind()

    // No special assignment handling here — it's handled below
    // after parsing the expression (check for = after LHS).

    // 2-tuple destructure: `(T1 a, T2 b) = rhs_expr`
    // Pattern: `(` TYPE IDENT `,` TYPE IDENT `)` `=`
    // We fully validate the 8-token shape before committing so any
    // unrelated `(`-led expression statement still parses normally.
    if kind == 10 {
        uint32 k1 = tok_kind_at(p_tok_pos + 1)
        uint32 k2 = tok_kind_at(p_tok_pos + 2)
        uint32 k3 = tok_kind_at(p_tok_pos + 3)
        uint32 k4 = tok_kind_at(p_tok_pos + 4)
        uint32 k5 = tok_kind_at(p_tok_pos + 5)
        uint32 k6 = tok_kind_at(p_tok_pos + 6)
        uint32 k7 = tok_kind_at(p_tok_pos + 7)
        uint32 k8 = tok_kind_at(p_tok_pos + 8)
        uint32 k9 = tok_kind_at(p_tok_pos + 9)
        uint32 k10 = tok_kind_at(p_tok_pos + 10)
        // 3-tuple destructure: `(T1 a, T2 b, T3 c) = rhs_expr`
        // Pattern: ( TYPE IDENT , TYPE IDENT , TYPE IDENT ) =
        if is_type_keyword(k1) != 0 && k2 == 1 && k3 == 16
           && is_type_keyword(k4) != 0 && k5 == 1 && k6 == 16
           && is_type_keyword(k7) != 0 && k8 == 1 && k9 == 11 && k10 == 34 {
            advance_tok()                   // (
            uint64 type1_tok = advance_tok()
            uint64 name1_tok = advance_tok()
            advance_tok()                   // ,
            uint64 type2_tok = advance_tok()
            uint64 name2_tok = advance_tok()
            advance_tok()                   // ,
            uint64 type3_tok = advance_tok()
            uint64 name3_tok = advance_tok()
            advance_tok()                   // )
            advance_tok()                   // =
            uint64 rhs = parse_expr()
            uint64 node = ast_alloc(47)     // TupleDestruct3
            uint32 tt1 = type1_tok
            uint32 nt1 = name1_tok
            uint32 tt2 = type2_tok
            uint32 nt2 = name2_tok
            ast_set_data1(node, tt1)
            ast_set_data2(node, nt1)
            ast_set_data3(node, tt2)
            ast_set_data4(node, nt2)
            uint32 nt3 = name3_tok
            ast_set_tok(node, nt3)
            uint32 rc = rhs
            ast_set_child(node, rc)
            return node
        }
        // 2-tuple destructure: `(T1 a, T2 b) = rhs_expr`
        if is_type_keyword(k1) != 0 && k2 == 1 && k3 == 16
           && is_type_keyword(k4) != 0 && k5 == 1 && k6 == 11 && k7 == 34 {
            advance_tok()                   // (
            uint64 type1_tok = advance_tok()
            uint64 name1_tok = advance_tok()
            advance_tok()                   // ,
            uint64 type2_tok = advance_tok()
            uint64 name2_tok = advance_tok()
            advance_tok()                   // )
            advance_tok()                   // =
            uint64 rhs = parse_expr()
            uint64 node = ast_alloc(AstKind.TupleDestruct)
            uint32 tt1 = type1_tok
            uint32 nt1 = name1_tok
            uint32 tt2 = type2_tok
            uint32 nt2 = name2_tok
            ast_set_data1(node, tt1)
            ast_set_data2(node, nt1)
            ast_set_data3(node, tt2)
            ast_set_data4(node, nt2)
            ast_set_tok(node, tt1)
            uint32 rc = rhs
            ast_set_child(node, rc)
            return node
        }
    }

    // Variable declaration: TYPE name = expr  OR  TYPE[SIZE] name
    if is_type_keyword(kind) != 0 {
        uint64 type_tok = advance_tok()

        // Check for array syntax: TYPE[SIZE] name
        if cur_kind() == 14 {
            advance_tok()
            uint64 size_tok = advance_tok()
            expect(15)
            uint64 name_tok = expect(1)
            // Create VarDecl with data3 = array size (stored as token index)
            uint64 node = ast_alloc(AstKind.VarDecl)
            uint32 tt = type_tok
            uint32 nt = name_tok
            ast_set_data1(node, tt)
            ast_set_data2(node, nt)
            ast_set_tok(node, tt)
            uint32 st = size_tok
            ast_set_data3(node, st)
            return node
        }

        uint64 name_tok = expect(1)
        uint64 node = ast_alloc(AstKind.VarDecl)
        uint32 tt = type_tok
        uint32 nt = name_tok
        ast_set_data1(node, tt)
        ast_set_data2(node, nt)
        ast_set_tok(node, tt)

        if eat(34) != 0 {
            uint64 init_expr = parse_expr()
            uint32 ie = init_expr
            ast_set_child(node, ie)
        }
        return node
    }

    // Return statement
    if kind == 61 {
        uint64 tok = advance_tok()
        uint64 node = ast_alloc(AstKind.Return)
        uint32 t32 = tok
        ast_set_tok(node, t32)
        // Check if there's a return value (not } or EOF)
        if cur_kind() != 13 && cur_kind() != 0 {
            // `return (a, b)` — 2-tuple return. Distinguish from the
            // parenthesized single-expression form `return (a + 1)` by
            // saving the token position, trying the tuple path, and
            // rewinding to normal parsing if there is no comma.
            if cur_kind() == 10 {
                uint64 save_pos = p_tok_pos
                advance_tok()  // consume (
                uint64 first = parse_expr()
                if cur_kind() == 16 {
                    advance_tok()  // consume ,
                    uint64 second = parse_expr()
                    if cur_kind() == 16 {
                        advance_tok()  // consume second ,
                        uint64 third = parse_expr()
                        expect(11)     // )
                        uint32 e32 = first
                        ast_set_child(node, e32)
                        uint32 e32b = second
                        ast_set_data3(node, e32b)
                        uint32 e32c = third
                        ast_set_data4(node, e32c)
                        return node
                    }
                    expect(11)     // )
                    uint32 e32 = first
                    ast_set_child(node, e32)
                    uint32 e32b = second
                    ast_set_data3(node, e32b)
                    return node
                }
                // Not a tuple — rewind and parse as a normal expression
                // so the grouping form still works.
                p_tok_pos = save_pos
            }
            uint64 expr = parse_expr()
            uint32 e32 = expr
            ast_set_child(node, e32)
        }
        return node
    }

    // If statement
    if kind == 62 {
        uint64 tok = advance_tok()
        uint64 node = ast_alloc(AstKind.If)
        uint32 t32 = tok
        ast_set_tok(node, t32)

        uint64 cond = parse_expr()
        uint32 c32 = cond
        ast_set_child(node, c32)

        uint64 then_body = parse_block()
        uint32 tb = then_body
        ast_set_data1(node, tb)

        if eat(63) != 0 {
            uint64 else_body = 0
            if cur_kind() == 62 {
                else_body = parse_stmt()
            } else {
                else_body = parse_block()
            }
            uint32 eb = else_body
            ast_set_data2(node, eb)
        }
        return node
    }

    // While statement
    if kind == 64 {
        uint64 tok = advance_tok()
        uint64 node = ast_alloc(AstKind.While)
        uint32 t32 = tok
        ast_set_tok(node, t32)

        uint64 cond = parse_expr()
        uint32 c32 = cond
        ast_set_child(node, c32)

        uint64 body = parse_block()
        uint32 b32 = body
        ast_set_data1(node, b32)
        return node
    }

    // Break
    if kind == 67 {
        uint64 tok = advance_tok()
        uint64 node = ast_alloc(AstKind.Break)
        uint32 t32 = tok
        ast_set_tok(node, t32)
        return node
    }

    // loop { body } — desugar to while 1 == 1 { body }. Reuses the loop
    // token's text position to synthesize the literal '1' by rewriting
    // its first source byte; the token's kind is flipped to IntLit.
    if kind == 69 {
        uint64 loop_tok = advance_tok()
        uint64 body_block = parse_block()
        // Write a '1' byte at the start of the 'loop' keyword's source
        // range — safe because no other AST node references that range
        // after we're done here.
        uint64 loop_text_start = tok_text_start(loop_tok)
        uint64 src_p = cg_source + loop_text_start
        uint8 one_ch = 49
        unsafe { *(src_p as uint8) = one_ch }
        // Flip the loop_tok slot into an IntLit with length 1.
        uint64 lp = p_tok_buf + loop_tok * 16
        uint32 il_kind = 2
        unsafe { *(lp as uint32) = il_kind }
        uint64 lp8 = lp + 8
        uint32 one_len = 1
        unsafe { *(lp8 as uint32) = one_len }
        // Build: Compare(==, IntLit(1), IntLit(1))
        uint64 lit_a = ast_alloc(AstKind.IntLit)
        uint32 lt = loop_tok
        ast_set_data1(lit_a, lt)
        ast_set_tok(lit_a, lt)
        uint64 lit_b = ast_alloc(AstKind.IntLit)
        ast_set_data1(lit_b, lt)
        ast_set_tok(lit_b, lt)
        uint64 cmp_node = ast_alloc(AstKind.Compare)
        uint32 eq_kind = 35   // ==
        ast_set_data1(cmp_node, eq_kind)
        uint32 la = lit_a
        ast_set_child(cmp_node, la)
        uint32 lb = lit_b
        ast_set_data2(cmp_node, lb)
        // Build While wrapping the cmp + user body.
        uint64 while_node = ast_alloc(AstKind.While)
        uint32 cn = cmp_node
        ast_set_child(while_node, cn)
        uint32 bn = body_block
        ast_set_data1(while_node, bn)
        return while_node
    }

    // Defer: `defer { ... }` — runs the body in LIFO order at every
    // function exit (return, exit, fall-through). Function-scoped:
    // a defer lexically inside a nested block is still part of the
    // enclosing function's defer stack.
    if kind == 79 {
        uint64 defer_tok = advance_tok()
        uint64 body = parse_block()
        uint64 node = ast_alloc(51)
        uint32 t32 = defer_tok
        ast_set_tok(node, t32)
        uint32 b32 = body
        ast_set_data1(node, b32)
        return node
    }

    // Continue
    if kind == 68 {
        uint64 tok = advance_tok()
        uint64 node = ast_alloc(AstKind.Continue)
        uint32 t32 = tok
        ast_set_tok(node, t32)
        return node
    }

    // Match statement: match expr { val => { body } val => { body } ... }
    if kind == 88 {
        advance_tok()
        uint64 match_node = ast_alloc(19)
        uint64 scrutinee = parse_expr()
        uint32 s32 = scrutinee
        ast_set_child(match_node, s32)
        expect(12)  // {
        uint64 first_arm = 0
        uint64 last_arm = 0
        while cur_kind() != 13 && cur_kind() != 0 {
            // Parse one-or-more comma-separated patterns. Each pattern
            // is either a bare expression, "_" (wildcard), or a range
            // form: lo ".." hi or lo "..=" hi.
            //   match b {
            //       0..=31 => { ... }          # inclusive range
            //       32..126 => { ... }         # exclusive range
            //       1, 2, 3 => { ... }
            //       _ => { ... }
            //   }
            // The first pattern sits in data1; any additional patterns
            // are chained via the `next` field on the first pattern node.
            uint64 first_pat = parse_match_pattern()
            uint64 last_pat = first_pat
            while cur_kind() == 16 {                // comma
                advance_tok()
                uint64 more_pat = parse_match_pattern()
                uint32 m32 = more_pat
                ast_set_next(last_pat, m32)
                last_pat = more_pat
            }
            expect(29)  // =>
            uint64 arm_body = parse_block()
            uint64 arm = ast_alloc(20)
            uint32 ve = first_pat
            ast_set_data1(arm, ve)
            uint32 ab = arm_body
            ast_set_data2(arm, ab)
            if first_arm == 0 {
                first_arm = arm
            } else {
                uint32 a32 = arm
                ast_set_next(last_arm, a32)
            }
            last_arm = arm
        }
        expect(13)  // }
        uint32 fa32 = first_arm
        ast_set_data1(match_node, fa32)
        return match_node
    }

    // For loop: for IDENT ['in'] START ('..' | '..=') END { body }
    // The 'in' keyword is optional; both `for i in 0..10` and
    // `for i 0..10` are accepted. `..=` makes the range inclusive.
    // Desugared to: { uint64 IDENT = START; while IDENT < END { body; IDENT = IDENT + 1 } }
    // For `..=`, the compare becomes `<=` so END is visited too.
    if kind == 65 {
        uint64 for_tok = p_tok_pos          // save 'for' slot; we reuse it below
        advance_tok()
        uint64 iter_tok = expect(1)
        // Optional `in` keyword.
        if cur_kind() == 66 { advance_tok() }
        uint64 start_expr = parse_expr()
        uint64 dot_tok = expect(17)
        uint64 dot2_tok = expect(17)
        // Inclusive form: `..= end`. Consume the '=' and remember the flag.
        uint64 inclusive = 0
        if cur_kind() == 34 {
            advance_tok()
            inclusive = 1
        }
        uint64 end_expr = parse_expr()
        uint64 body_block = parse_block()

        // Repurpose dot tokens for desugared AST:
        //   dot_tok  → '<' or '<=' operator token for the comparison
        //   dot2_tok → '+' operator token for the increment
        //   for_tok  → synthesized IntLit(1) (the 'for' keyword is never read again)
        uint64 dot_p = p_tok_buf + dot_tok * 16
        uint32 cmp_kind = 37
        if inclusive != 0 { cmp_kind = 38 }
        unsafe { *(dot_p as uint32) = cmp_kind }

        uint64 dot2_p = p_tok_buf + dot2_tok * 16
        uint32 plus_kind = 30
        unsafe { *(dot2_p as uint32) = plus_kind }

        // Overwrite the first dot's source byte with '1' so the synthetic
        // IntLit has a valid text range to read from. Using for_tok as the
        // storage slot means we're independent of whether the user wrote
        // `in` or not.
        uint64 dot_text_start = tok_text_start(dot_tok)
        uint64 src_p = cg_source + dot_text_start
        uint8 one_ch = 49
        unsafe { *(src_p as uint8) = one_ch }
        uint64 in_tok = for_tok
        uint64 in_p = p_tok_buf + in_tok * 16
        uint32 intlit_kind = 2
        unsafe { *(in_p as uint32) = intlit_kind }
        uint64 in_p4 = in_p + 4
        uint32 dts = dot_text_start
        unsafe { *(in_p4 as uint32) = dts }
        uint64 in_p8 = in_p + 8
        uint32 one_len = 1
        unsafe { *(in_p8 as uint32) = one_len }

        // Build desugared AST: Block containing VarDecl + While
        uint64 outer_block = ast_alloc(AstKind.Block)

        // VarDecl: uint64 IDENT = START
        uint64 var_node = ast_alloc(AstKind.VarDecl)
        uint32 tt = iter_tok
        ast_set_data2(var_node, tt)
        uint32 se = start_expr
        ast_set_child(var_node, se)
        ast_append_child(outer_block, var_node)

        // Compare: IDENT < END
        uint64 iter_ident = ast_alloc(AstKind.Ident)
        ast_set_data1(iter_ident, tt)
        uint64 cmp_node = ast_alloc(AstKind.Compare)
        uint32 ii = iter_ident
        ast_set_child(cmp_node, ii)
        uint32 ee = end_expr
        ast_set_data2(cmp_node, ee)
        uint32 dt = dot_tok
        ast_set_data1(cmp_node, dt)

        // While node: while cmp { body; IDENT = IDENT + 1 }
        uint64 while_node = ast_alloc(AstKind.While)
        uint32 cn = cmp_node
        ast_set_child(while_node, cn)

        // Increment: IDENT = IDENT + 1
        uint64 inc_ident = ast_alloc(AstKind.Ident)
        ast_set_data1(inc_ident, tt)
        uint64 one_lit = ast_alloc(AstKind.IntLit)
        uint32 in_tok32 = in_tok
        ast_set_data1(one_lit, in_tok32)
        uint64 inc_add = ast_alloc(AstKind.BinOp)
        uint32 d2t = dot2_tok
        ast_set_data1(inc_add, d2t)
        uint32 inci = inc_ident
        ast_set_child(inc_add, inci)
        uint32 ol = one_lit
        ast_set_data2(inc_add, ol)
        uint64 inc_assign = ast_alloc(AstKind.Assign)
        ast_set_data1(inc_assign, tt)
        uint32 ia = inc_add
        ast_set_child(inc_assign, ia)

        // Append increment to body
        ast_append_child(body_block, inc_assign)

        // Set while body
        uint32 bb = body_block
        ast_set_data1(while_node, bb)

        ast_append_child(outer_block, while_node)
        return outer_block
    }

    // Asm block: asm("instruction") or asm { "instr1"; "instr2"; ... }
    // Optionally followed by one or more I/O constraint clauses:
    //   in(<var> -> <reg>, ...)
    //   out(<reg> -> <var>, ...)
    //   clobbers(<reg>, ...)
    if kind == 90 {
        advance_tok()
        uint64 asm_node = ast_alloc(43)
        if cur_kind() == 10 {
            // Single-line: asm("string")
            advance_tok()
            uint64 str_tok = expect(3)
            expect(11)
            uint32 st32 = str_tok
            ast_set_data1(asm_node, st32)
        } else if cur_kind() == 12 {
            // Multi-line: asm { "str1"; "str2"; ... }
            advance_tok()
            uint64 first_str = 0
            uint64 last_str = 0
            while cur_kind() != 13 && cur_kind() != 0 {
                uint64 s_tok = expect(3)
                uint64 s_node = ast_alloc(31)
                uint32 st = s_tok
                ast_set_data1(s_node, st)
                if first_str == 0 {
                    first_str = s_node
                } else {
                    uint32 sn = s_node
                    ast_set_next(last_str, sn)
                }
                last_str = s_node
                eat(18)
            }
            expect(13)
            if first_str != 0 {
                uint32 fs = first_str
                ast_set_child(asm_node, fs)
            }
        }

        // Parse optional constraint clauses. Stops at the first token that
        // is not the start of a clause, leaving the next statement intact.
        uint64 first_cons = 0
        uint64 last_cons = 0
        while 1 == 1 {
            uint64 clause_kind = 0xFFFFFFFFFFFFFFFF
            // `in` is the language-level for-range keyword (66); we
            // reuse it here since it can't start a regular statement.
            if cur_kind() == 66 {
                clause_kind = 0
            } else if cur_kind() == 1 {
                uint64 ident_pos = p_tok_pos
                if tok_matches(ident_pos, "out", 3) != 0 {
                    clause_kind = 1
                } else if tok_matches(ident_pos, "clobbers", 8) != 0 {
                    clause_kind = 2
                }
            }
            if clause_kind == 0xFFFFFFFFFFFFFFFF { break }
            if tok_kind_at(p_tok_pos + 1) != 10 { break }
            advance_tok()                 // in / out / clobbers
            advance_tok()                 // (
            // Comma-separated list of entries until the closing ')'
            while cur_kind() != 11 && cur_kind() != 0 {
                uint64 left_tok = expect(1)
                uint64 right_tok = 0
                if clause_kind != 2 {
                    expect(20)            // -> token
                    right_tok = expect(1)
                }
                uint64 cons_node = ast_alloc(AstKind.AsmConstraint)
                uint32 ck32 = clause_kind
                ast_set_data1(cons_node, ck32)
                // Normalise storage so codegen can emit loads/stores
                // uniformly: data2 = register token, data3 = variable
                // token (0 for clobbers).
                if clause_kind == 0 {
                    // in(var -> reg)
                    uint32 rt = right_tok
                    uint32 vt = left_tok
                    ast_set_data2(cons_node, rt)
                    ast_set_data3(cons_node, vt)
                } else if clause_kind == 1 {
                    // out(reg -> var)
                    uint32 rt = left_tok
                    uint32 vt = right_tok
                    ast_set_data2(cons_node, rt)
                    ast_set_data3(cons_node, vt)
                } else {
                    // clobbers(reg)
                    uint32 rt = left_tok
                    ast_set_data2(cons_node, rt)
                }
                if first_cons == 0 {
                    first_cons = cons_node
                } else {
                    uint32 cn = cons_node
                    ast_set_next(last_cons, cn)
                }
                last_cons = cons_node
                if cur_kind() == 16 { advance_tok() }  // eat ,
            }
            expect(11)                    // )
        }
        if first_cons != 0 {
            uint32 fc32 = first_cons
            ast_set_data3(asm_node, fc32)
        }
        return asm_node
    }

    // Volatile block: volatile { ... } — treated same as unsafe for now
    if kind == 91 {
        advance_tok()
        expect(12)
        expect(22)
        expect(10)
        uint64 addr_expr = parse_expr()
        expect(1)
        uint32 type_kind = cur_kind()
        advance_tok()
        uint64 type_size = 8
        if type_kind == 80 || type_kind == 84 || type_kind == 98 || type_kind == 99 { type_size = 1 }
        if type_kind == 81 || type_kind == 85 { type_size = 2 }
        if type_kind == 82 || type_kind == 86 { type_size = 4 }
        if type_kind == 83 || type_kind == 87 { type_size = 8 }
        // Float casts: KwFloat16=94 (size 2), KwFloat32=95 (size 4), KwFloat64=96 (size 8).
        // Without these, `unsafe { *(p as f32) = v }` fell through to the u64
        // default and emitted an 8-byte store, clobbering addr+4..+7.
        if type_kind == 94 { type_size = 2 }
        if type_kind == 95 { type_size = 4 }
        if type_kind == 96 { type_size = 8 }
        expect(11)
        if cur_kind() == 20 {
            advance_tok()
            uint64 dest_tok = advance_tok()
            expect(13)
            uint64 node = ast_alloc(41)
            uint32 ts = type_size
            ast_set_data1(node, ts)
            uint32 ae = addr_expr
            ast_set_child(node, ae)
            uint32 dt = dest_tok
            ast_set_data2(node, dt)
            uint32 vf = 1
            ast_set_data3(node, vf)
            return node
        }
        if cur_kind() == 34 {
            advance_tok()
            uint64 val_expr = parse_expr()
            expect(13)
            uint64 node = ast_alloc(42)
            uint32 ts = type_size
            ast_set_data1(node, ts)
            uint32 ae = addr_expr
            ast_set_child(node, ae)
            uint32 ve = val_expr
            ast_set_data2(node, ve)
            uint32 vf = 1
            ast_set_data3(node, vf)
            return node
        }
        expect(13)
    }

    // Unsafe block: unsafe { *(addr as TYPE) -> val } or unsafe { *(addr as TYPE) = val }
    if kind == 76 {
        advance_tok()
        expect(12)
        expect(22)
        expect(10)
        uint64 addr_expr = parse_expr()
        // expect "as" identifier
        expect(1)
        // Parse type keyword → determine size
        uint32 type_kind = cur_kind()
        advance_tok()
        uint64 type_size = 8
        if type_kind == 80 || type_kind == 84 || type_kind == 98 || type_kind == 99 { type_size = 1 }
        if type_kind == 81 || type_kind == 85 { type_size = 2 }
        if type_kind == 82 || type_kind == 86 { type_size = 4 }
        if type_kind == 83 || type_kind == 87 { type_size = 8 }
        // Float casts: KwFloat16=94 (size 2), KwFloat32=95 (size 4), KwFloat64=96 (size 8).
        // Without these, `unsafe { *(p as f32) = v }` fell through to the u64
        // default and emitted an 8-byte store, clobbering addr+4..+7.
        if type_kind == 94 { type_size = 2 }
        if type_kind == 95 { type_size = 4 }
        if type_kind == 96 { type_size = 8 }
        expect(11)

        if cur_kind() == 20 {
            // PtrLoad: -> dest
            advance_tok()
            uint64 dest_tok = advance_tok()
            expect(13)
            // Use kind 41 for PtrLoad
            uint64 node = ast_alloc(41)
            uint32 ts = type_size
            ast_set_data1(node, ts)
            uint32 ae = addr_expr
            ast_set_child(node, ae)
            uint32 dt = dest_tok
            ast_set_data2(node, dt)
            // Stash fkind in data3 so IR lowering can mark the
            // destination vreg with f64/f32 type. Otherwise
            // `unsafe { *(p as f64) -> v }` produces a vreg the
            // IR treats as integer, breaking downstream float math.
            //   1 = f64 (KwFloat64 = 96)
            //   2 = f32 (KwFloat32 = 95)
            //   3 = f16 (KwFloat16 = 94)
            //   0 = integer / other
            uint32 fk = 0
            if type_kind == 96 { fk = 1 }
            else if type_kind == 95 { fk = 2 }
            else if type_kind == 94 { fk = 3 }
            ast_set_data3(node, fk)
            return node
        }
        if cur_kind() == 34 {
            // PtrStore: = value
            advance_tok()
            uint64 val_expr = parse_expr()
            expect(13)
            // Use kind 42 for PtrStore
            uint64 node = ast_alloc(42)
            uint32 ts = type_size
            ast_set_data1(node, ts)
            uint32 ae = addr_expr
            ast_set_child(node, ae)
            uint32 ve = val_expr
            ast_set_data2(node, ve)
            // Mirror PtrLoad: stash fkind so downstream emitters
            // (notably format_hip.kr's body translator) can pick the
            // right C++ cast type for float stores instead of
            // defaulting to uint64*.
            uint32 fks = 0
            if type_kind == 96 { fks = 1 }
            else if type_kind == 95 { fks = 2 }
            else if type_kind == 94 { fks = 3 }
            ast_set_data3(node, fks)
            return node
        }
        expect(13)
    }

    // Struct variable declaration: StructName varName  OR  StructName[N] arrName
    // Check if current token is an identifier that names a known struct
    if kind == 1 {
        uint64 maybe_struct = struct_lookup(p_tok_pos)
        if maybe_struct != 0xFFFFFFFF {
            uint64 type_tok = advance_tok()
            // Check for struct array: StructName[N] name
            if cur_kind() == 14 {
                advance_tok()
                uint64 size_tok = advance_tok()
                expect(15)
                uint64 name_tok = expect(1)
                uint64 node = ast_alloc(AstKind.VarDecl)
                uint32 tt = type_tok
                uint32 nt = name_tok
                ast_set_data1(node, tt)
                ast_set_data2(node, nt)
                ast_set_tok(node, tt)
                uint32 st = size_tok
                ast_set_data3(node, st)
                // Mark as struct: data4 = struct_idx + 1
                uint32 si4 = maybe_struct + 1
                ast_set_data4(node, si4)
                return node
            }
            uint64 name_tok = expect(1)
            uint64 node = ast_alloc(AstKind.VarDecl)
            uint32 tt = type_tok
            uint32 nt = name_tok
            ast_set_data1(node, tt)
            ast_set_data2(node, nt)
            ast_set_tok(node, tt)
            // Mark as struct: data4 = struct_idx + 1 (0 = not struct)
            uint32 si4 = maybe_struct + 1
            ast_set_data4(node, si4)
            // Optional heap-struct initializer:  Node n = alloc(24)
            // When present, the slot holds the pointer returned by the
            // init expression (instead of pointing at stack-allocated
            // storage). Field access already reads the slot as a base
            // address + field offset, so n.next = other Just Works.
            if eat(34) != 0 {
                uint64 init_expr = parse_expr()
                uint32 ie = init_expr
                ast_set_child(node, ie)
            }
            return node
        }
        // Check if current token is a type alias
        uint64 alias_size = type_alias_lookup(p_tok_pos)
        if alias_size != 0xFFFFFFFF {
            uint64 type_tok = advance_tok()
            uint64 name_tok = expect(1)
            uint64 node = ast_alloc(AstKind.VarDecl)
            uint32 tt = type_tok
            uint32 nt = name_tok
            ast_set_data1(node, tt)
            ast_set_data2(node, nt)
            ast_set_tok(node, tt)
            if eat(34) != 0 {
                uint64 init_expr = parse_expr()
                uint32 ie = init_expr
                ast_set_child(node, ie)
            }
            return node
        }
    }

    // Expression statement (assignment or bare call)
    uint64 expr = parse_expr()

    // Check for assignment: expr = value (or arr[i] = value)
    if eat(34) != 0 {
        uint64 rhs = parse_expr()
        uint32 expr_kind = ast_kind(expr)
        uint64 wek = expr_kind
        if wek == 37 {
            // Indexed assignment: arr[i] = value
            uint32 r32 = rhs
            ast_set_data2(expr, r32)
            uint32 one = 1
            ast_set_data3(expr, one)
            return expr
        }
        if wek == 36 {
            // Field assignment: var.field = value
            uint32 r32 = rhs
            ast_set_data3(expr, r32)
            // Mark as field assign by setting data4 = 1
            uint32 one = 1
            ast_set_data4(expr, one)
            return expr
        }
        uint64 node = ast_alloc(AstKind.Assign)
        uint32 lhs_tok = ast_data1(expr)
        ast_set_data1(node, lhs_tok)
        ast_set_tok(node, lhs_tok)
        uint32 r32 = rhs
        ast_set_child(node, r32)
        return node
    }

    // Compound assignment: += -= *= /= %= &= |= ^= <<= >>=
    // Desugar: x OP= val → x = x OP val. Also supports p.field OP= val
    // and arr[i] OP= val by building the matching FieldAssign / indexed
    // assign node instead of a plain Assign.
    uint32 ck = cur_kind()
    uint64 wck = ck
    if wck >= 45 && wck <= 54 {
        uint64 op_tok = advance_tok()
        uint64 rhs = parse_expr()
        uint32 expr_kind_c = ast_kind(expr)
        uint64 wek_c = expr_kind_c

        // p.field OP= val → FieldAccess with data3 = BinOp(op, p.field, rhs)
        if wek_c == 36 {
            uint64 lhs_copy = ast_alloc(AstKind.FieldAccess)
            uint32 fobj = ast_child(expr)
            ast_set_child(lhs_copy, fobj)
            uint32 fname = ast_data2(expr)
            ast_set_data2(lhs_copy, fname)
            ast_set_tok(lhs_copy, fname)
            uint64 binop = ast_alloc(AstKind.BinOp)
            uint32 ot32 = op_tok
            ast_set_data1(binop, ot32)
            uint32 lc32 = lhs_copy
            ast_set_child(binop, lc32)
            uint32 r32 = rhs
            ast_set_data2(binop, r32)
            // Overlay the original FieldAccess to carry the store:
            // data3 = rhs (the binop), data4 = 1 signals field-assign.
            uint32 bp32 = binop
            ast_set_data3(expr, bp32)
            uint32 one = 1
            ast_set_data4(expr, one)
            return expr
        }

        // arr[i] OP= val → Index with data3=1 + data2 = BinOp(op, arr[i], rhs)
        if wek_c == 37 {
            // Build a fresh copy of the Index node for the read side so
            // the store side can reuse the existing node as its AST home.
            uint64 idx_copy = ast_alloc(AstKind.Index)
            uint32 arr_tok = ast_data1(expr)
            ast_set_data1(idx_copy, arr_tok)
            uint32 idx_child = ast_child(expr)
            ast_set_child(idx_copy, idx_child)
            ast_set_tok(idx_copy, arr_tok)
            uint64 binop2 = ast_alloc(AstKind.BinOp)
            uint32 ot32b = op_tok
            ast_set_data1(binop2, ot32b)
            uint32 ic32 = idx_copy
            ast_set_child(binop2, ic32)
            uint32 r32b = rhs
            ast_set_data2(binop2, r32b)
            // Store form: data2 = BinOp, data3 = 1 (indexed-assign marker).
            uint32 bp32b = binop2
            ast_set_data2(expr, bp32b)
            uint32 one_b = 1
            ast_set_data3(expr, one_b)
            return expr
        }

        // Plain identifier OP= val.
        uint32 lhs_tok = ast_data1(expr)
        uint64 lhs_copy = ast_alloc(AstKind.Ident)
        ast_set_data1(lhs_copy, lhs_tok)
        uint64 binop = ast_alloc(AstKind.BinOp)
        uint32 ot32 = op_tok
        ast_set_data1(binop, ot32)
        uint32 lc32 = lhs_copy
        ast_set_child(binop, lc32)
        uint32 r32 = rhs
        ast_set_data2(binop, r32)
        uint64 node = ast_alloc(AstKind.Assign)
        ast_set_data1(node, lhs_tok)
        ast_set_tok(node, lhs_tok)
        uint32 bp32 = binop
        ast_set_child(node, bp32)
        return node
    }

    // Bare expression statement
    uint64 node = ast_alloc(AstKind.ExprStmt)
    uint32 e32 = expr
    ast_set_child(node, e32)
    return node
}

fn parse_block() -> uint64 {
    expect(12)
    uint64 block = ast_alloc(AstKind.Block)
    while cur_kind() != 13 && cur_kind() != 0 {
        // Skip semicolons (statement separators)
        while cur_kind() == 18 {
            advance_tok()
        }
        if cur_kind() != 13 && cur_kind() != 0 {
            uint64 stmt = parse_stmt()
            ast_append_child(block, stmt)
        }
    }
    expect(13)
    return block
}

// ---------------------------------------------------------------------------
// Top-level parsing
// ---------------------------------------------------------------------------

fn parse_param_list() -> uint64 {
    // Returns first param node (linked via next)
    uint64 first = 0
    uint64 last = 0

    expect(10)
    while cur_kind() != 11 && cur_kind() != 0 {
        // Slice parameter: [TYPE] name — a fat pointer (ptr, len)
        if cur_kind() == 14 {
            advance_tok()
            uint64 elem_type_tok = advance_tok()
            expect(15)
            uint64 name_tok = expect(1)
            uint64 param = ast_alloc(AstKind.Param)
            uint32 tt = elem_type_tok
            uint32 nt = name_tok
            ast_set_data1(param, tt)
            ast_set_data2(param, nt)
            // Mark as slice: data4 = 1
            uint32 one = 1
            ast_set_data4(param, one)
            if first == 0 {
                first = param
            } else {
                uint32 p32 = param
                ast_set_next(last, p32)
            }
            last = param
            eat(16)
            continue
        }
        uint64 type_tok = 0
        if is_type_keyword(cur_kind()) != 0 {
            type_tok = advance_tok()
        } else {
            type_tok = advance_tok()
        }
        uint64 name_tok = expect(1)

        uint64 param = ast_alloc(AstKind.Param)
        uint32 tt = type_tok
        uint32 nt = name_tok
        ast_set_data1(param, tt)
        ast_set_data2(param, nt)

        if first == 0 {
            first = param
        } else {
            uint32 p32 = param
            ast_set_next(last, p32)
        }
        last = param

        eat(16)
    }
    expect(11)
    return first
}

fn parse_fn_decl() -> uint64 {
    expect(60)
    uint64 name_tok = expect(1)

    // Generic type parameters: fn name<T>(...) or fn name<T, U>(...)
    // Skip the <...> — generics are purely syntactic (all types are uint64)
    if cur_kind() == 37 {
        advance_tok()
        while cur_kind() != 39 && cur_kind() != 0 {
            advance_tok()
        }
        if cur_kind() == 39 {
            advance_tok()
        }
    }

    // Method syntax: fn StructName.method(...) -> registered as method
    if cur_kind() == 17 {
        advance_tok()
        uint64 method_tok = expect(1)
        name_tok = method_tok
    }

    uint64 node = ast_alloc(AstKind.FnDecl)
    uint32 nt = name_tok
    ast_set_data1(node, nt)
    ast_set_tok(node, nt)

    uint64 params = parse_param_list()
    uint32 p32 = params
    ast_set_child(node, p32)

    // Return type: -> TYPE
    if eat(20) != 0 {
        uint64 ret_tok = advance_tok()
        uint32 rt = ret_tok
        ast_set_data2(node, rt)
    }

    // Body
    uint64 body = parse_block()
    uint32 b32 = body
    ast_set_data3(node, b32)

    return node
}

@export
fn parse_module() -> uint64 {
    uint64 mod_node = ast_alloc(AstKind.Module)

    while cur_kind() != 0 {
        uint32 kind = cur_kind()

        // Parse annotations (@export, @noreturn, @naked, @packed, @section, @kernel, @dynamic, etc)
        uint64 ann_noreturn = 0
        uint64 ann_naked = 0
        uint64 ann_packed = 0
        uint64 ann_export = 0
        uint64 ann_kernel = 0
        uint64 ann_dynamic = 0
        uint64 ann_section_start = 0
        uint64 ann_section_len = 0
        while kind == 21 {
            advance_tok()
            // Read annotation name
            uint64 ann_tok = p_tok_pos
            advance_tok()
            // Check for known annotations
            uint64 ann_start = tok_start_at(ann_tok)
            uint64 ann_len_v = tok_len_at(ann_tok)
            // Check noreturn (8 chars)
            if ann_len_v == 8 {
                uint64 ann_a = src_ptr + ann_start
                uint64 ann_ch = 0
                unsafe { *(ann_a as uint8) -> ann_ch }
                if ann_ch == 110 { ann_noreturn = 1 }
            }
            // Check naked (5 chars, starts with 'n')
            if ann_len_v == 5 {
                uint64 ann_a2 = src_ptr + ann_start
                uint64 ann_ch2 = 0
                unsafe { *(ann_a2 as uint8) -> ann_ch2 }
                uint64 ann_a3 = src_ptr + ann_start + 1
                uint64 ann_ch3 = 0
                unsafe { *(ann_a3 as uint8) -> ann_ch3 }
                if ann_ch2 == 110 && ann_ch3 == 97 { ann_naked = 1 }
            }
            // Check packed (6 chars, starts with 'p')
            if ann_len_v == 6 {
                uint64 ann_a4 = src_ptr + ann_start
                uint64 ann_ch4 = 0
                unsafe { *(ann_a4 as uint8) -> ann_ch4 }
                if ann_ch4 == 112 { ann_packed = 1 }
                // Check export (6 chars, starts with 'e' = 101)
                if ann_ch4 == 101 { ann_export = 1 }
                // Check kernel (6 chars, starts with 'k' = 107) — marks a
                // function as a GPU kernel for format_hip.kr to emit. See
                // docs/GPU_BACKEND.md and src/ir_hip.kr.
                if ann_ch4 == 107 { ann_kernel = 1 }
            }
            // Check section (7 chars, starts with 's') and dynamic (7 chars, starts with 'd')
            uint64 is_section = 0
            if ann_len_v == 7 {
                uint64 ann_a5 = src_ptr + ann_start
                uint64 ann_ch5 = 0
                unsafe { *(ann_a5 as uint8) -> ann_ch5 }
                if ann_ch5 == 115 { is_section = 1 }       // 's' = 115
                // @dynamic — marks an extern fn for dynamic linking via
                // PLT/GOT (see src/format_elf_dyn.kr and M2a.2 plan in
                // docs/GPU_BACKEND.md).
                if ann_ch5 == 100 { ann_dynamic = 1 }      // 'd' = 100
            }
            // Annotation arguments: for @section, capture the string
            // literal (minus its quotes). For everything else, skip.
            if eat(10) != 0 {
                if is_section != 0 && cur_kind() == 3 {
                    uint64 str_tok = advance_tok()
                    uint64 st_s = tok_start_at(str_tok)
                    uint64 st_l = tok_len_at(str_tok)
                    // Token text includes the leading and trailing "; trim them.
                    if st_l >= 2 {
                        ann_section_start = st_s + 1
                        ann_section_len = st_l - 2
                    }
                }
                while cur_kind() != 11 && cur_kind() != 0 {
                    advance_tok()
                }
                eat(11)
            }
            kind = cur_kind()
        }

        if kind == 60 {
            uint64 fn_node = parse_fn_decl()
            // Annotation flags in data4:
            //   bit 0 = noreturn, bit 1 = naked, bit 2 = export,
            //   bit 3 = extern (set by the `extern fn` path below, not here),
            //   bit 4 = kernel (@kernel; see src/format_hip.kr),
            //   bit 5 = dynamic (@dynamic; set by the extern fn path).
            uint32 ann_flags = ann_noreturn | (ann_naked << 1) | (ann_export << 2) | (ann_kernel << 4)
            if ann_flags != 0 {
                ast_set_data4(fn_node, ann_flags)
            }
            // If the user wrote `@section("name")`, stash the (start, len)
            // pair in the side-table keyed by the function's name token.
            // The ELF relocatable writer will read this when it supports
            // multi-section emission.
            if ann_section_len != 0 {
                uint32 fn_name_tok = ast_data1(fn_node)
                uint64 wfn_name = fn_name_tok
                fn_section_set(wfn_name, ann_section_start, ann_section_len)
            }
            ast_append_child(mod_node, fn_node)
        } else if kind == 74 {
            // extern fn name(params) -> rettype;
            //
            // Declared but not defined — the function is resolved at link time
            // by the system linker. Valid only with --emit=obj output (or
            // equivalent relocatable targets); executable targets can't handle
            // unresolved symbols without a dynamic linker, which KernRift
            // doesn't emit yet.
            //
            // We build a FnDecl AST node with no body AND a parameter list so
            // the semantic analyzer (collect_function_signatures) picks it up
            // for arg count checking. The extern flag is set in data4 bit 3 so
            // codegen can emit a relocation at each call site.
            advance_tok()
            expect(60)  // `fn`
            uint64 ext_name_tok = expect(1)

            // Register the extern symbol so gen_expr's Call handler can detect it
            extern_fn_register(ext_name_tok)

            // Build a normal FnDecl node with empty body
            uint64 ext_fn_node = ast_alloc(AstKind.FnDecl)
            uint32 extnt = ext_name_tok
            ast_set_data1(ext_fn_node, extnt)
            ast_set_tok(ext_fn_node, extnt)

            uint64 ext_params = parse_param_list()
            uint32 ep32 = ext_params
            ast_set_child(ext_fn_node, ep32)

            // Optional return type
            if eat(20) != 0 {
                uint64 ret_tok = advance_tok()
                uint32 rt = ret_tok
                ast_set_data2(ext_fn_node, rt)
            }

            // data3 = body (0 for extern). data4 bit 3 = extern,
            // bit 5 = @dynamic (when set by an annotation preceding the
            // extern decl). @dynamic also registers the symbol in the
            // dyn-symbol table so format_elf_dyn's emitter + codegen's
            // call-through-PLT path can find it later.
            ast_set_data3(ext_fn_node, 0)
            uint32 ext_flag = 8 | (ann_dynamic << 5)
            ast_set_data4(ext_fn_node, ext_flag)

            if ann_dynamic != 0 {
                dyn_sym_register(ext_name_tok)
                // libm float-ABI detection: hardcoded list of known
                // f32 libm functions. When matched, the symbol is
                // flagged with abi_kind so codegen routes args through
                // xmm0..xmmN and reads the return from xmm0 (System V
                // f32 calling convention) instead of the integer
                // registers. Driver also adds libm.so.6 to DT_NEEDED
                // via dyn_sym_any_libm() in the lib_list pass.
                //   kind 1 = 1-arg-1-return f32 (xmm0 in/out)
                //   kind 2 = 2-arg-1-return f32 (xmm0+xmm1 in, xmm0 out)
                // Extend the lists below as more libm names are needed.
                if tok_matches(ext_name_tok, "tanhf",  5) != 0 { dyn_sym_set_abi(ext_name_tok, 1) }
                if tok_matches(ext_name_tok, "sinf",   4) != 0 { dyn_sym_set_abi(ext_name_tok, 1) }
                if tok_matches(ext_name_tok, "cosf",   4) != 0 { dyn_sym_set_abi(ext_name_tok, 1) }
                if tok_matches(ext_name_tok, "expf",   4) != 0 { dyn_sym_set_abi(ext_name_tok, 1) }
                if tok_matches(ext_name_tok, "logf",   4) != 0 { dyn_sym_set_abi(ext_name_tok, 1) }
                if tok_matches(ext_name_tok, "sqrtf",  5) != 0 { dyn_sym_set_abi(ext_name_tok, 1) }
                if tok_matches(ext_name_tok, "erff",   4) != 0 { dyn_sym_set_abi(ext_name_tok, 1) }
                if tok_matches(ext_name_tok, "fabsf",  5) != 0 { dyn_sym_set_abi(ext_name_tok, 1) }
                if tok_matches(ext_name_tok, "floorf", 6) != 0 { dyn_sym_set_abi(ext_name_tok, 1) }
                if tok_matches(ext_name_tok, "ceilf",  5) != 0 { dyn_sym_set_abi(ext_name_tok, 1) }
                // 2-arg-1-return f32 libm functions.
                if tok_matches(ext_name_tok, "powf",      4) != 0 { dyn_sym_set_abi(ext_name_tok, 2) }
                if tok_matches(ext_name_tok, "atan2f",    6) != 0 { dyn_sym_set_abi(ext_name_tok, 2) }
                if tok_matches(ext_name_tok, "fminf",     5) != 0 { dyn_sym_set_abi(ext_name_tok, 2) }
                if tok_matches(ext_name_tok, "fmaxf",     5) != 0 { dyn_sym_set_abi(ext_name_tok, 2) }
                if tok_matches(ext_name_tok, "copysignf", 9) != 0 { dyn_sym_set_abi(ext_name_tok, 2) }
                if tok_matches(ext_name_tok, "fmodf",     5) != 0 { dyn_sym_set_abi(ext_name_tok, 2) }
                if tok_matches(ext_name_tok, "hypotf",    6) != 0 { dyn_sym_set_abi(ext_name_tok, 2) }
            }

            ast_append_child(mod_node, ext_fn_node)
            eat(18)  // optional trailing semicolon
        } else if kind == 70 {
            // const TYPE name = value — treat as a scalar static with a
            // compile-time integer initializer. Only integer literal, hex
            // literal, char literal, and boolean keyword initializers are
            // supported; everything else is skipped (value stays 0).
            advance_tok()
            advance_tok()
            uint64 name_tok = expect(1)
            static_declare(name_tok)
            if eat(34) != 0 {
                // Accept literal initializers, including leading unary - or ~.
                // Anything else (calls, named constants, expressions) is
                // skipped with a zero value — tracked by issue #53.
                uint64 init_neg = 0
                uint64 init_inv = 0
                if cur_kind() == 31 { init_neg = 1; advance_tok() }
                else if cur_kind() == 26 { init_inv = 1; advance_tok() }
                uint32 init_kind = cur_kind()
                if init_kind == 2 || init_kind == 4 || init_kind == 77 || init_kind == 78 {
                    uint64 init_tok = advance_tok()
                    uint64 init_val = parse_int_token(init_tok)
                    if init_neg != 0 { init_val = 0 - init_val }
                    if init_inv != 0 { init_val = ~init_val }
                    static_set_init_last(init_val)
                } else {
                    // Skip unsupported initializer (function calls, etc.) — value stays 0.
                    while cur_kind() != 60 && cur_kind() != 71 && cur_kind() != 70 && cur_kind() != 72 && cur_kind() != 73 && cur_kind() != 21 && cur_kind() != 89 && cur_kind() != 0 {
                        advance_tok()
                    }
                }
            }
        } else if kind == 71 {
            // static TYPE name = value  OR  static TYPE[N] name
            advance_tok()
            // Type keyword
            uint64 stype_tok = advance_tok()
            // Check for array syntax: static TYPE[N] name
            if cur_kind() == 14 {
                advance_tok()
                uint64 size_tok = advance_tok()
                // Parse the integer literal from the token text
                uint64 stsz_start = tok_start_at(size_tok)
                uint64 stsz_len = tok_len_at(size_tok)
                uint64 stsz_val = 0
                uint64 stsz_i = 0
                // Support decimal and 0x hex
                uint64 sbp0 = src_ptr + stsz_start
                uint64 sbc0 = 0
                unsafe { *(sbp0 as uint8) -> sbc0 }
                uint64 sbp1 = src_ptr + stsz_start + 1
                uint64 sbc1 = 0
                if stsz_len > 1 { unsafe { *(sbp1 as uint8) -> sbc1 } }
                if sbc0 == 48 && sbc1 == 120 {
                    // 0x... hex
                    stsz_i = 2
                    while stsz_i < stsz_len {
                        uint64 sbpx = src_ptr + stsz_start + stsz_i
                        uint64 sbcx = 0
                        unsafe { *(sbpx as uint8) -> sbcx }
                        uint64 dv = 0
                        if sbcx >= 48 && sbcx <= 57 { dv = sbcx - 48 }
                        else if sbcx >= 97 && sbcx <= 102 { dv = sbcx - 87 }
                        else if sbcx >= 65 && sbcx <= 70 { dv = sbcx - 55 }
                        stsz_val = stsz_val * 16 + dv
                        stsz_i = stsz_i + 1
                    }
                } else {
                    while stsz_i < stsz_len {
                        uint64 sbp = src_ptr + stsz_start + stsz_i
                        uint64 sbc = 0
                        unsafe { *(sbp as uint8) -> sbc }
                        stsz_val = stsz_val * 10 + (sbc - 48)
                        stsz_i = stsz_i + 1
                    }
                }
                expect(15)
                uint64 name_tok = expect(1)
                // Compute element size from type keyword kind
                uint32 stk = tok_kind_at(stype_tok)
                uint64 wstk = stk
                uint64 elem_sz = 8
                if wstk == 80 || wstk == 84 || wstk == 98 || wstk == 99 { elem_sz = 1 }
                if wstk == 81 || wstk == 85 { elem_sz = 2 }
                if wstk == 82 || wstk == 86 { elem_sz = 4 }
                if wstk == 83 || wstk == 87 { elem_sz = 8 }
                static_declare_array(name_tok, stsz_val * elem_sz)
                static_set_elem_size_last(elem_sz)
                // Record fkind so index reads propagate f64/f32 type-flow.
                // KwFloat16=94, KwFloat32=95, KwFloat64=96.
                if wstk == 96 { static_set_fkind_last(1) }
                else if wstk == 95 { static_set_fkind_last(2) }
                else if wstk == 94 { static_set_fkind_last(3) }
                // Optional initializer — skip for now (zero-initialized by BSS)
                if eat(34) != 0 {
                    while cur_kind() != 60 && cur_kind() != 71 && cur_kind() != 72 && cur_kind() != 73 && cur_kind() != 21 && cur_kind() != 89 && cur_kind() != 0 {
                        advance_tok()
                    }
                }
            } else {
                // Name token
                uint64 name_tok = expect(1)
                // Register the static variable
                static_declare(name_tok)
                // Record fkind so reads propagate f64/f32 type-flow.
                // KwFloat16=94, KwFloat32=95, KwFloat64=96.
                uint32 stk_s = tok_kind_at(stype_tok)
                uint64 wstk_s = stk_s
                if wstk_s == 96 { static_set_fkind_last(1) }
                else if wstk_s == 95 { static_set_fkind_last(2) }
                else if wstk_s == 94 { static_set_fkind_last(3) }
                // Capture literal initializer if present
                if eat(34) != 0 {
                    uint64 sinit_neg = 0
                    uint64 sinit_inv = 0
                    if cur_kind() == 31 { sinit_neg = 1; advance_tok() }
                    else if cur_kind() == 26 { sinit_inv = 1; advance_tok() }
                    uint32 sinit_kind = cur_kind()
                    if sinit_kind == 2 || sinit_kind == 4 || sinit_kind == 77 || sinit_kind == 78 {
                        uint64 sinit_tok = advance_tok()
                        uint64 sinit_val = parse_int_token(sinit_tok)
                        if sinit_neg != 0 { sinit_val = 0 - sinit_val }
                        if sinit_inv != 0 { sinit_val = ~sinit_val }
                        static_set_init_last(sinit_val)
                    } else if sinit_kind == 5 {
                        // FloatLit: parse digits+dot into int_val, frac_val,
                        // frac_divisor; compute as f64; pack bits via the
                        // unsafe memory-cast trick. Mirrors the runtime
                        // IR FloatLit lowering in src/ir.kr.
                        uint64 flit_tok = advance_tok()
                        uint64 wft = flit_tok
                        uint64 ft_start = tok_start_at(wft)
                        uint64 ft_len = tok_len_at(wft)
                        uint64 fint = 0
                        uint64 ffrac = 0
                        uint64 fdiv = 1
                        uint64 fpast = 0
                        uint64 fin_exp = 0
                        uint64 fexp_neg = 0
                        uint64 fexp_val = 0
                        uint64 fi2 = 0
                        while fi2 < ft_len {
                            uint64 fbp = src_ptr + ft_start + fi2
                            uint64 fch = 0
                            unsafe { *(fbp as uint8) -> fch }
                            if fch == 46 { fpast = 1 }
                            else if fch == 102 { }   // trailing 'f' — narrowing is driven by the static's declared type, not the literal suffix
                            else if fch == 101 || fch == 69 {
                                // 'e' or 'E' — switch to exponent mode.
                                fin_exp = 1
                                fi2 = fi2 + 1
                                if fi2 < ft_len {
                                    uint64 sbp = src_ptr + ft_start + fi2
                                    uint64 sch = 0
                                    unsafe { *(sbp as uint8) -> sch }
                                    if sch == 45 { fexp_neg = 1; fi2 = fi2 + 1 }
                                    else if sch == 43 { fi2 = fi2 + 1 }
                                }
                                continue
                            }
                            else if fch >= 48 && fch <= 57 {
                                if fin_exp != 0 {
                                    fexp_val = fexp_val * 10 + (fch - 48)
                                } else if fpast == 0 {
                                    fint = fint * 10 + (fch - 48)
                                } else {
                                    ffrac = ffrac * 10 + (fch - 48)
                                    fdiv = fdiv * 10
                                }
                            }
                            fi2 = fi2 + 1
                        }
                        // Compute f64 value.
                        f64 fv = int_to_f64(fint) + int_to_f64(ffrac) / int_to_f64(fdiv)
                        if fexp_val != 0 {
                            if fexp_val > 18 {
                                write(2, "error: float exponent too large (max 1e18)\n", 44)
                                exit(1)
                            }
                            uint64 fpow10 = 1
                            uint64 fei = 0
                            while fei < fexp_val {
                                fpow10 = fpow10 * 10
                                fei = fei + 1
                            }
                            f64 fscale = int_to_f64(fpow10)
                            if fexp_neg != 0 { fv = fv / fscale }
                            else { fv = fv * fscale }
                        }
                        if sinit_neg != 0 { fv = 0.0 - fv }
                        // Pack bits according to the static's declared type.
                        // emit_static_data writes 8 bytes per scalar slot; for
                        // f32 the runtime load is 4-byte movss, so the f32
                        // bits must sit in the low 4 bytes (and we zero the
                        // high 4 bytes by passing a uint64 with high zero).
                        uint64 fbits_buf = alloc(8)
                        uint64 fbits = 0
                        if wstk_s == 95 {
                            // f32 static: narrow then pack as 32-bit IEEE-754.
                            f32 fv32 = f64_to_f32(fv)
                            unsafe { *(fbits_buf as f32) = fv32 }
                            uint32 fbits32 = 0
                            unsafe { *(fbits_buf as uint32) -> fbits32 }
                            fbits = fbits32
                        } else {
                            // f64 (or other) static: store the full 8 bytes.
                            unsafe { *(fbits_buf as f64) = fv }
                            unsafe { *(fbits_buf as uint64) -> fbits }
                        }
                        static_set_init_last(fbits)
                    } else {
                        while cur_kind() != 60 && cur_kind() != 71 && cur_kind() != 72 && cur_kind() != 73 && cur_kind() != 21 && cur_kind() != 89 && cur_kind() != 0 {
                            advance_tok()
                        }
                    }
                }
            }
        } else if kind == 72 {
            // struct NAME { TYPE field; TYPE field; ... }
            advance_tok()
            uint64 struct_name_tok = expect(1)
            uint64 sidx = struct_register(struct_name_tok)
            expect(12)
            while cur_kind() != 13 && cur_kind() != 0 {
                uint64 field_type_tok = advance_tok()
                uint64 field_name_tok = expect(1)
                // Determine field size from type
                uint32 ftk = tok_kind_at(field_type_tok)
                uint64 fsize = 8
                uint64 wftk = ftk
                if wftk == 80 { fsize = 1 }
                if wftk == 81 { fsize = 2 }
                if wftk == 82 { fsize = 4 }
                if wftk == 83 { fsize = 8 }
                if wftk == 84 { fsize = 1 }
                if wftk == 85 { fsize = 2 }
                if wftk == 86 { fsize = 4 }
                if wftk == 87 { fsize = 8 }
                if wftk == 98 { fsize = 1 }
                if wftk == 99 { fsize = 1 }
                if wftk == 1 {
                    uint64 nested_si = struct_lookup(field_type_tok)
                    if nested_si != 0xFFFFFFFF {
                        fsize = struct_total_size(nested_si)
                        wftk = 256 + nested_si
                    }
                }
                struct_add_field(sidx, field_name_tok, fsize, wftk)
                eat(18)
                eat(16)
            }
            expect(13)
            struct_classify_abi(sidx)
        } else if kind == 73 {
            // enum NAME { FIELD = VALUE, ... }
            advance_tok()
            uint64 enum_name_tok = expect(1)
            expect(12)
            uint64 next_val = 0
            while cur_kind() != 13 && cur_kind() != 0 {
                uint64 field_tok = expect(1)
                if eat(34) != 0 {
                    // explicit value
                    uint64 val_tok = advance_tok()
                    uint64 tstart = tok_start_at(val_tok)
                    uint64 tlen = tok_len_at(val_tok)
                    // Parse integer from token
                    uint64 val = 0
                    uint64 vi = 0
                    while vi < tlen {
                        uint64 sp = p_tok_buf
                        // Actually need to read from source, but we don't have source ptr here
                        // Use parse_int_token from codegen? No, it uses cg_source/cg_tokens
                        // Simplest: just use the token text from the source
                        // We can compute the value from the token buffer
                        vi = tlen
                    }
                    // For now, use a simpler approach: read digits from source
                    // Actually, call parse_int_token-like logic inline
                    next_val = 0
                    vi = 0
                    while vi < tlen {
                        // Read byte from source via src_ptr
                        uint64 baddr = src_ptr + tstart + vi
                        uint64 ch = 0
                        unsafe { *(baddr as uint8) -> ch }
                        next_val = next_val * 10 + ch - 48
                        vi = vi + 1
                    }
                }
                enum_register(enum_name_tok, field_tok, next_val)
                next_val = next_val + 1
                eat(16)
            }
            expect(13)
        } else if kind == 89 {
            // type AliasName = TargetType
            advance_tok()
            uint64 alias_tok = expect(1)
            expect(34)
            // Parse target type keyword — determine size
            uint32 target_kind = cur_kind()
            advance_tok()
            uint64 tsize = 8
            uint64 wtk = target_kind
            if wtk == 80 { tsize = 1 }
            if wtk == 81 { tsize = 2 }
            if wtk == 82 { tsize = 4 }
            if wtk == 83 { tsize = 8 }
            if wtk == 84 { tsize = 1 }
            if wtk == 85 { tsize = 2 }
            if wtk == 86 { tsize = 4 }
            if wtk == 87 { tsize = 8 }
            if wtk == 98 { tsize = 1 }
            if wtk == 99 { tsize = 1 }
            type_alias_register(alias_tok, tsize)
        } else if kind == 92 {
            // device NAME at ADDR { FIELD at OFF : TYPE [rw|ro|wo] ... }
            advance_tok()
            uint64 dev_name = expect(1)
            expect(93)  // `at`
            // Parse base address literal
            uint64 base_tok = advance_tok()
            uint64 base_start = tok_start_at(base_tok)
            uint64 base_len = tok_len_at(base_tok)
            uint64 base_val = 0
            uint64 bi = 0
            uint64 bp0 = src_ptr + base_start
            uint64 bc0 = 0
            unsafe { *(bp0 as uint8) -> bc0 }
            uint64 bp1 = src_ptr + base_start + 1
            uint64 bc1 = 0
            if base_len > 1 { unsafe { *(bp1 as uint8) -> bc1 } }
            if bc0 == 48 && bc1 == 120 {
                bi = 2
                while bi < base_len {
                    uint64 bpx = src_ptr + base_start + bi
                    uint64 bcx = 0
                    unsafe { *(bpx as uint8) -> bcx }
                    uint64 dv = 0
                    if bcx >= 48 && bcx <= 57 { dv = bcx - 48 }
                    else if bcx >= 97 && bcx <= 102 { dv = bcx - 87 }
                    else if bcx >= 65 && bcx <= 70 { dv = bcx - 55 }
                    base_val = base_val * 16 + dv
                    bi = bi + 1
                }
            } else {
                while bi < base_len {
                    uint64 bp = src_ptr + base_start + bi
                    uint64 bc = 0
                    unsafe { *(bp as uint8) -> bc }
                    base_val = base_val * 10 + (bc - 48)
                    bi = bi + 1
                }
            }
            uint64 dev_idx = device_register(dev_name, base_val)
            expect(12)
            while cur_kind() != 13 && cur_kind() != 0 {
                uint64 fname_tok = expect(1)
                expect(93)  // `at`
                // Parse field offset literal
                uint64 off_tok = advance_tok()
                uint64 off_start = tok_start_at(off_tok)
                uint64 off_len = tok_len_at(off_tok)
                uint64 off_val = 0
                uint64 oi = 0
                uint64 op0 = src_ptr + off_start
                uint64 oc0 = 0
                unsafe { *(op0 as uint8) -> oc0 }
                uint64 op1 = src_ptr + off_start + 1
                uint64 oc1 = 0
                if off_len > 1 { unsafe { *(op1 as uint8) -> oc1 } }
                if oc0 == 48 && oc1 == 120 {
                    oi = 2
                    while oi < off_len {
                        uint64 opx = src_ptr + off_start + oi
                        uint64 ocx = 0
                        unsafe { *(opx as uint8) -> ocx }
                        uint64 dv2 = 0
                        if ocx >= 48 && ocx <= 57 { dv2 = ocx - 48 }
                        else if ocx >= 97 && ocx <= 102 { dv2 = ocx - 87 }
                        else if ocx >= 65 && ocx <= 70 { dv2 = ocx - 55 }
                        off_val = off_val * 16 + dv2
                        oi = oi + 1
                    }
                } else {
                    while oi < off_len {
                        uint64 op = src_ptr + off_start + oi
                        uint64 oc = 0
                        unsafe { *(op as uint8) -> oc }
                        off_val = off_val * 10 + (oc - 48)
                        oi = oi + 1
                    }
                }
                expect(19)  // `:`
                // Parse field type keyword
                uint64 ft_tok = advance_tok()
                uint32 ftk = tok_kind_at(ft_tok)
                uint64 wftk = ftk
                uint64 fsize = 8
                if wftk == 80 || wftk == 84 || wftk == 98 || wftk == 99 { fsize = 1 }
                if wftk == 81 || wftk == 85 { fsize = 2 }
                if wftk == 82 || wftk == 86 { fsize = 4 }
                if wftk == 83 || wftk == 87 { fsize = 8 }
                // Optional access spec: consume only if the next token is literally rw, ro, or wo
                if cur_kind() == 1 {
                    uint64 acc_s = tok_start_at(p_tok_pos)
                    uint64 acc_l = tok_len_at(p_tok_pos)
                    if acc_l == 2 {
                        uint64 ac0p = src_ptr + acc_s
                        uint64 ac0 = 0
                        unsafe { *(ac0p as uint8) -> ac0 }
                        uint64 ac1p = src_ptr + acc_s + 1
                        uint64 ac1 = 0
                        unsafe { *(ac1p as uint8) -> ac1 }
                        if (ac0 == 114 && ac1 == 119) || (ac0 == 114 && ac1 == 111) || (ac0 == 119 && ac1 == 111) {
                            advance_tok()
                        }
                    }
                }
                device_add_field(dev_idx, fname_tok, off_val, fsize)
                eat(18)
                eat(16)
            }
            expect(13)
        } else {
            advance_tok()
        }
    }

    return mod_node
}
// MLRift — built on KernRift — Code Generator (x86_64 ELF)
//
// Strategy: register-based codegen. Expressions evaluate into %rax.
// Variables live on the stack. Function calls use SysV ABI.
//
// Stack frame layout (per function):
//   [rsp + 0]          local variable 0
//   [rsp + 8]          local variable 1
//   ...
//   Frame size = n_locals * 8 (aligned to 16)

// Output buffer
static uint64 out_buf = 0
static uint64 out_len = 0
static uint64 out_cap = 0

// Source + token buffer (for reading token text)
static uint64 cg_source = 0
static uint64 cg_tokens = 0

// Variable table: maps variable name token → stack offset
// Simple flat array: [name_tok_idx(4), stack_offset(4)] × 256
static uint64 var_table = 0
static uint64 var_count = 0
static uint64 var_frame_size = 0

// Temp slot offset within frame (for expression evaluation)
// Reserved at function start, used by BinOp and function call arg staging
static uint64 temp_slot_0 = 0
static uint64 temp_slot_1 = 0

// Float tracking: 0 = result in rax (integer), 1 = result in xmm0 (f64), 2 = result in xmm0 (f32)
static uint64 expr_is_float = 0
// Struct literal tracking: 0xFFFFFFFF = not a struct, otherwise struct index
static uint64 expr_is_struct = 0xFFFFFFFF

// Struct pass-by-value ABI flag: 0 = pass pointer (legacy), 1 = pass eightbytes in registers
// Set to 1 when BOTH caller (Task 5) and callee (Task 6) changes are in place.
static uint64 abi_struct_pass_by_val = 1

// Debug mode: emit runtime safety checks (division by zero, etc.)
static uint64 debug_mode = 0

// Function table: maps function name → code offset in output
// [name_tok_idx(4), code_offset(4)] × 256
static uint64 fn_table = 0
static uint64 fn_count = 0

// Extern function table — functions declared with `extern fn name(params)`
// that are resolved at link time by the system linker. Each entry is
// 8 bytes: [name_tok(4), pad(4)]. Max 256 externs.
static uint64 extern_fn_table = 0
static uint64 extern_fn_count = 0

// Extern call sites — per-call-site record of where to emit a linker
// relocation. Each entry is 16 bytes:
//   [code_off(4), extern_idx(4), pad(8)]
// code_off is the byte offset of the instruction (ARM64) or of the
// 4-byte displacement (x86_64) inside the .text section.
static uint64 extern_call_sites = 0
static uint64 extern_call_count = 0

// Return fixup table: jmp offsets that need patching to epilogue
// [patch_offset(4)] × 64
static uint64 ret_fixups = 0
static uint64 ret_fixup_count = 0

// Loop context for break/continue
// [loop_start_offset(8), break_fixup_start(8)] × 16 deep
static uint64 loop_stack = 0
static uint64 loop_depth = 0
// Break fixup list: [patch_offset(4)] × 256
static uint64 break_fixups = 0
static uint64 break_fixup_count = 0

// Fixup table: call sites that need patching after all functions emitted
// [patch_offset(4), target_name_tok(4)] × 1024
static uint64 fixup_table = 0
static uint64 fixup_count = 0

// fn_addr fixup table: LEA instructions that need patching to function addresses
// [patch_offset(4), str_tok(4)] × 256
static uint64 fnaddr_fixup_table = 0
static uint64 fnaddr_fixup_count = 0

// Teardown fixup table: call sites synthesized by the compiler that target
// `hipkfd_teardown` by NAME (no real token in the source). Resolved at the
// same site as resolve_fixups via fn_lookup_by_str. Used by the
// --target=amdgpu-native auto-injection at main epilogue + exit() builtin.
// [patch_offset(4), unused(4)] × 1024
static uint64 teardown_fixup_table = 0
static uint64 teardown_fixup_count = 0
static uint64 teardown_fixup_cap = 1024

// Static variable table: maps name token → data offset in data section
// [name_tok_idx(4), data_offset(4)] × 256
static uint64 static_table = 0
static uint64 static_count = 0
static uint64 static_data_size = 0
// Parallel byte array: 0 = scalar static, >0 = array static (byte size)
static uint64 static_array_sizes = 0

// Struct metadata table
// For each struct: [name_tok(4), field_count(4), total_size(4), pad(4)]
// Followed by field entries: [field_name_tok(4), field_offset(4), field_size(4), pad(4)]
// Max 64 structs, each with max 16 fields
static uint64 struct_table = 0
static uint64 struct_count = 0

// Struct variable type tracking: maps var name_tok → struct index
// [var_name_tok(4), struct_idx(4)] × 1024
static uint64 struct_var_table = 0
static uint64 struct_var_count = 0

// Enum value table: maps (enum_name_tok, field_name_tok) → value
// [enum_name_tok(4), field_name_tok(4), value(8)] × 512
static uint64 enum_table = 0
static uint64 enum_count = 0

// Per-static-array element size (parallel to static_table, not reset per fn).
// Allows Index read/write to scale correctly for `static u64[N]`, `u32[N]`, `u16[N]`.
static uint64 static_elem_sizes = 0

// Static access fixup table: RIP-relative displacements to patch
// [code_patch_offset(4), static_data_offset(4)] × 2048
static uint64 static_fixups = 0
static uint64 static_fixup_count = 0

// String literal table: raw string bytes stored contiguously
static uint64 str_buf = 0
static uint64 str_len = 0
// String fixup table: [code_patch_offset(4), str_data_offset(4)] × 1024
static uint64 str_fixups = 0
static uint64 str_fixup_count = 0

// Target OS: 0=linux, 1=macos, 2=windows
static uint64 target_os = 0
// Active target arch: 0 = x86_64, 1 = arm64. Settable from main.kr
// via set_target_arch so ir.kr's get_arch_id lowering can pick the
// right constant without having to thread the value through every
// function call.
static uint64 target_arch = 0

@export
fn set_target_arch(uint64 v) { target_arch = v }

// Windows IAT call fixups: [patch_offset(4), iat_slot(4)] × 1024
static uint64 win_iat_fixups = 0
static uint64 win_iat_fixup_count = 0
// ARM64 Windows IAT fixups (same format)
static uint64 a64_win_iat_fixups = 0
static uint64 a64_win_iat_fixup_count = 0
// PE IAT RVA (set during PE header emission)
static uint64 pe_iat_rva = 0

// Per-scalar-static initial values (u64 each) — parallel to static_table.
// Written by static_set_init_last, read by emit_static_data.
static uint64 static_init_values = 0

// Per-static float kind (u32 each) — parallel to static_table.
//   0 = int/other (default), 1 = f64, 2 = f32, 3 = f16
// Set by the parser on declaration; read by the IR lowering to
// propagate f64/f32 type-flow through STATIC_LOAD and array Index
// reads so downstream `+`, `*` etc. pick IR_FADD/IR_FMUL instead
// of emitting integer arithmetic.
static uint64 static_fkinds = 0

// Local array element size table — records the per-element size of each
// local `TYPE[N] name` declaration so that index reads/writes can scale the
// index and use the right load/store width. Without this, u64[N]/u32[N]/
// u16[N] arrays silently miscompile (byte indexing with byte load/store).
// Keyed by variable name token; [name_tok(4), elem_size(4)] × 512.
static uint64 arr_elem_table = 0
static uint64 arr_elem_count = 0

// Type alias table: [alias_name_tok(4), target_size(4)] × 64
static uint64 type_alias_table = 0
static uint64 type_alias_count = 0

// Parameter pinning: read-only params pinned to callee-saved registers
// pin_param0_offset = stack offset of pinned param 0 (rbx), 0xFFFFFFFF = not pinned
// pin_param1_offset = stack offset of pinned param 1 (r12), 0xFFFFFFFF = not pinned
static uint64 pin_param0_offset = 0xFFFFFFFF
static uint64 pin_param1_offset = 0xFFFFFFFF
static uint64 pin_param0_tok = 0
static uint64 pin_param1_tok = 0

// Slice parameter length slot table
// Maps a slice param's ptr-slot offset → its len-slot offset.
// Used by FieldAccess to resolve `slice.len` to a load from the len slot.
// Max 32 slice params per function (way more than needed).
// Format: [ptr_off(4), len_off(4)] × 32
static uint64 slice_len_table = 0
static uint64 slice_len_count = 0

// Device block table (MMIO registers)
// Format: [name_tok(4), pad(4), base_addr(8)] × 64  (16 bytes each)
static uint64 device_table = 0
static uint64 device_count = 0
// Device field table
// Format: [dev_idx(4), field_tok(4), offset(4), size(4)] × 256  (16 bytes each)
static uint64 device_field_table = 0
static uint64 device_field_count = 0
// Binary op register spill: use r12 instead of stack for outermost binary op
static uint64 r12_in_use = 0
static uint64 r12_save_slot = 0

// sret hidden pointer slot: when a function returns a MEMORY-class struct
// (>16 bytes), the caller passes the return address as a hidden first arg
// in rdi (SysV) or rcx (Windows).  The callee saves it here at entry so
// the return path can copy the struct data to the caller-supplied buffer.
// 0xFFFFFFFF means "not an sret function".
static uint64 sret_slot = 0xFFFFFFFF

// Function return-type float table: maps fn name_tok → float kind (1=f64, 2=f32)
// [name_tok(4), float_kind(4)] × 512
static uint64 fn_ret_float_table = 0
static uint64 fn_ret_float_count = 0

// Function return-type struct table: maps fn name_tok → struct index
// [name_tok(4), struct_idx(4)] × 512
static uint64 fn_ret_struct_table = 0
static uint64 fn_ret_struct_count = 0

// IR backend mode: when 1, use SSA IR + register allocator + x86_64 emitter
static uint64 emit_ir_mode = 1

// Debug info: DWARF line table infrastructure
static uint64 debug_info_mode = 0
static uint64 line_table = 0
static uint64 line_table_count = 0
static uint64 last_recorded_line = 0
static uint64 current_file_id = 0
static uint64 debug_file_table = 0
static uint64 debug_file_count = 0

// Debug var table — persists across functions. Each 16-byte entry:
//   [0..4)   fn_idx (u32) into fn_table
//   [4..8)   name_tok (u32)
//   [8..12)  loc_value (u32) — stack_offset if kind=0, phys_reg if kind=1
//   [12..16) loc_kind (u32) — 0 = DW_OP_fbreg, 1 = DW_OP_regN
static uint64 debug_var_table = 0
static uint64 debug_var_count = 0
static uint64 debug_var_cap = 4096

@export
fn debug_var_record(uint64 fn_idx, uint64 name_tok, uint64 stack_offset) {
    debug_var_record_loc(fn_idx, name_tok, stack_offset, 0)
}

@export
fn debug_var_record_loc(uint64 fn_idx, uint64 name_tok, uint64 loc_value, uint64 loc_kind) {
    if debug_info_mode == 0 { return }
    if debug_var_table == 0 { debug_var_table = alloc(debug_var_cap * 16) }
    if debug_var_count >= debug_var_cap { return }
    uint64 entry = debug_var_table + debug_var_count * 16
    uint32 fi = fn_idx
    unsafe { *(entry as uint32) = fi }
    uint64 e4 = entry + 4
    uint32 nt = name_tok
    unsafe { *(e4 as uint32) = nt }
    uint64 e8 = entry + 8
    uint32 lv = loc_value
    unsafe { *(e8 as uint32) = lv }
    uint64 e12 = entry + 12
    uint32 lk = loc_kind
    unsafe { *(e12 as uint32) = lk }
    debug_var_count = debug_var_count + 1
}

@export
fn codegen_init(uint64 capacity, uint64 source, uint64 tokens) {
    out_buf = alloc(capacity)
    out_len = 0
    out_cap = capacity
    cg_source = source
    cg_tokens = tokens
    var_table = alloc(4096 * 8)
    var_count = 0
    fn_table = alloc(2048 * 8)
    fn_count = 0
    fixup_table = alloc(32768 * 8)
    fixup_count = 0
    ret_fixups = alloc(256 * 4)
    ret_fixup_count = 0
    struct_table = alloc(64 * 272)
    struct_count = 0
    struct_var_table = alloc(1024 * 8)
    struct_var_count = 0
    loop_stack = alloc(16 * 16)
    loop_depth = 0
    break_fixups = alloc(256 * 4)
    break_fixup_count = 0
    enum_table = alloc(512 * 16)
    enum_count = 0
    static_table = alloc(1024 * 8)
    static_array_sizes = alloc(1024 * 4)
    static_init_values = alloc(1024 * 8)
    static_elem_sizes = alloc(1024 * 4)
    static_fkinds = alloc(1024 * 4)
    slice_len_table = alloc(32 * 8)
    device_table = alloc(64 * 16)
    device_field_table = alloc(256 * 16)
    extern_fn_table = alloc(256 * 8)
    extern_fn_count = 0
    extern_call_sites = alloc(1024 * 16)
    extern_call_count = 0
    static_count = 0
    static_data_size = 0
    static_fixups = alloc(8192 * 8)
    static_fixup_count = 0
    str_buf = alloc(65536)
    str_len = 0
    str_fixups = alloc(4096 * 8)
    str_fixup_count = 0
    a64_var_base = 32
    win_iat_fixups = alloc(4096 * 8)
    win_iat_fixup_count = 0
    a64_win_iat_fixups = alloc(4096 * 8)
    a64_win_iat_fixup_count = 0
    a64_digit_buf = alloc(32)
    type_alias_table = alloc(64 * 8)
    type_alias_count = 0
    arr_elem_table = alloc(512 * 16)
    arr_elem_count = 0
    fnaddr_fixup_table = alloc(1024 * 8)
    fnaddr_fixup_count = 0
    teardown_fixup_table = alloc(1024 * 8)
    teardown_fixup_count = 0
    pin_param0_offset = 0xFFFFFFFF
    pin_param1_offset = 0xFFFFFFFF
    fn_ret_float_table = alloc(512 * 8)
    fn_ret_float_count = 0
    fn_ret_struct_table = alloc(512 * 8)
    fn_ret_struct_count = 0
    line_table = alloc(65536 * 16)
    line_table_count = 0
    debug_file_table = alloc(256 * 8)
    debug_file_count = 0
}

// ---------------------------------------------------------------------------
// Emit helpers
// ---------------------------------------------------------------------------

fn emit_byte(uint8 b) {
    if out_len >= out_cap {
        // Grow the output buffer geometrically — doubling the cap and
        // memcpying the existing bytes — so callers can size codegen_init
        // for the common case (a few MB per slice) without paying a 512
        // MB virtual reservation up front. The Pi 400's 4 GB of RAM hits
        // hard swap with the old fixed cap.
        uint64 new_cap = out_cap * 2
        if new_cap < 4096 { new_cap = 4096 }
        uint64 new_buf = alloc(new_cap)
        memcpy(new_buf, out_buf, out_len)
        dealloc(out_buf)
        out_buf = new_buf
        out_cap = new_cap
    }
    uint64 p = out_buf + out_len
    unsafe { *(p as uint8) = b }
    out_len = out_len + 1
}

fn emit_u32_le(uint64 val) {
    uint8 b0 = val & 0xFF
    uint8 b1 = (val >> 8) & 0xFF
    uint8 b2 = (val >> 16) & 0xFF
    uint8 b3 = (val >> 24) & 0xFF
    emit_byte(b0)
    emit_byte(b1)
    emit_byte(b2)
    emit_byte(b3)
}

fn emit_u64_le(uint64 val) {
    uint64 lo = val & 0xFFFFFFFF
    uint64 hi = (val >> 32) & 0xFFFFFFFF
    emit_u32_le(lo)
    emit_u32_le(hi)
}

fn emit_u16_le(uint64 val) {
    uint8 b0 = val & 0xFF
    uint8 b1 = (val >> 8) & 0xFF
    emit_byte(b0)
    emit_byte(b1)
}

fn patch_u32(uint64 offset, uint64 val) {
    uint64 p = out_buf + offset
    uint8 b0 = val & 0xFF
    uint8 b1 = (val >> 8) & 0xFF
    uint8 b2 = (val >> 16) & 0xFF
    uint8 b3 = (val >> 24) & 0xFF
    unsafe { *(p as uint8) = b0 }
    uint64 p1 = p + 1
    unsafe { *(p1 as uint8) = b1 }
    uint64 p2 = p + 2
    unsafe { *(p2 as uint8) = b2 }
    uint64 p3 = p + 3
    unsafe { *(p3 as uint8) = b3 }
}

fn patch_u16(uint64 offset, uint64 val) {
    uint64 p = out_buf + offset
    uint8 b0 = val & 0xFF
    uint8 b1 = (val >> 8) & 0xFF
    unsafe { *(p as uint8) = b0 }
    uint64 p1 = p + 1
    unsafe { *(p1 as uint8) = b1 }
}

fn patch_u64(uint64 offset, uint64 val) {
    patch_u32(offset, val & 0xFFFFFFFF)
    patch_u32(offset + 4, (val >> 32) & 0xFFFFFFFF)
}

// ---------------------------------------------------------------------------
// DWARF line table recording
// ---------------------------------------------------------------------------

// Flag set by `line_table_record_fn_entry` so the next distinct line
// recording emits DW_LNS_set_prologue_end. GDB uses that flag to stop
// at the first real statement on 'break <fn>'.
static uint64 line_prologue_pending = 0

fn line_table_record(uint64 tok_idx) {
    if debug_info_mode == 0 { return }
    if tok_idx == 0 { return }
    uint64 line = tok_line_at(tok_idx)
    if line == last_recorded_line && line_table_count > 0 { return }
    if line_table_count >= 65536 { return }
    // Entry layout (16 bytes):
    //   [0..4)   code offset (u32)
    //   [4..6)   file id (u16)
    //   [6..8)   line (u16)
    //   [8..9)   flags (bit 0 = prologue_end)
    //   [9..16)  reserved
    uint64 entry = line_table + line_table_count * 16
    uint32 off = out_len
    unsafe { *(entry as uint32) = off }
    uint64 e4 = entry + 4
    uint16 fid = current_file_id
    unsafe { *(e4 as uint16) = fid }
    uint64 e6 = entry + 6
    uint16 ln = line
    unsafe { *(e6 as uint16) = ln }
    uint64 e8 = entry + 8
    uint8 fl = 0
    if line_prologue_pending != 0 {
        fl = 1
        line_prologue_pending = 0
    }
    unsafe { *(e8 as uint8) = fl }
    line_table_count = line_table_count + 1
    last_recorded_line = line
}

// Record a function's entry address and arm the prologue_end flag for
// the next line recording. Callers (main.kr fn dispatch) invoke this
// right after fn_register(). The next time line_table_record fires
// with a different line, that entry is marked so DW_LNS_set_prologue_end
// is emitted for it.
@export
fn line_table_record_fn_entry(uint64 fn_tok) {
    line_table_record(fn_tok)
    line_prologue_pending = 1
}

// LEB128 encoding helpers (for DWARF)

fn emit_uleb128(uint64 val) {
    uint64 v = val
    while v >= 128 {
        uint8 b = (v & 0x7F) | 0x80
        emit_byte(b)
        v = v >> 7
    }
    uint8 b = v & 0x7F
    emit_byte(b)
}

fn emit_sleb128(uint64 val) {
    uint64 more = 1
    uint64 v = val
    while more != 0 {
        uint8 b = v & 0x7F
        v = v >> 7
        if (b & 0x40) != 0 {
            if v == 0xFFFFFFFFFFFFFFFF { more = 0 }
        } else {
            if v == 0 { more = 0 }
        }
        if more != 0 { b = b | 0x80 }
        emit_byte(b)
    }
}

// ---------------------------------------------------------------------------
// Token text helpers
// ---------------------------------------------------------------------------

fn tok_text_start(uint64 tok_idx) -> uint64 {
    uint64 p = cg_tokens + tok_idx * 16 + 4
    uint32 val = 0
    unsafe { *(p as uint32) -> val }
    return val
}

fn tok_text_len(uint64 tok_idx) -> uint64 {
    uint64 p = cg_tokens + tok_idx * 16 + 8
    uint32 val = 0
    unsafe { *(p as uint32) -> val }
    return val
}

fn tok_source_byte(uint64 tok_idx, uint64 offset) -> uint64 {
    uint64 start = tok_text_start(tok_idx)
    uint64 p = cg_source + start + offset
    uint64 val = 0
    unsafe { *(p as uint8) -> val }
    return val & 0xFF
}

// Translate a single-byte escape character (the byte following `\`) to its
// resolved value. Returns 0xFFFFFFFFFFFFFFFF when the escape isn't known
// (callers pass the escape byte through verbatim in that case). Keeps the
// same table used by string-literal lowering and by the `parse_int_token`
// char-literal parser — if you add one here, mirror it in both places.
@export
fn escape_char_to_byte(uint64 esc) -> uint64 {
    if esc == 110 { return 10 }    // \n — line feed
    if esc == 116 { return 9 }     // \t — horizontal tab
    if esc == 114 { return 13 }    // \r — carriage return
    if esc == 48  { return 0 }     // \0 — null
    if esc == 92  { return 92 }    // \\ — backslash
    if esc == 34  { return 34 }    // \" — double quote
    if esc == 39  { return 39 }    // \' — single quote
    if esc == 98  { return 8 }     // \b — backspace
    if esc == 102 { return 12 }    // \f — form feed
    if esc == 118 { return 11 }    // \v — vertical tab
    if esc == 97  { return 7 }     // \a — alert / bell
    if esc == 101 { return 27 }    // \e — ESC (ANSI colour sequences)
    return 0xFFFFFFFFFFFFFFFF
}

// Parse a two-digit hex byte for `\xHH` escapes. Returns 0 when either
// digit is out of range — callers shouldn't land here unless the source
// already matched `\x`.
@export
fn hex_digit_pair_to_byte(uint64 h1, uint64 h2) -> uint64 {
    uint64 v1 = 0
    uint64 v2 = 0
    if h1 >= 48 && h1 <= 57 { v1 = h1 - 48 }
    else if h1 >= 97 && h1 <= 102 { v1 = h1 - 87 }
    else if h1 >= 65 && h1 <= 70 { v1 = h1 - 55 }
    if h2 >= 48 && h2 <= 57 { v2 = h2 - 48 }
    else if h2 >= 97 && h2 <= 102 { v2 = h2 - 87 }
    else if h2 >= 65 && h2 <= 70 { v2 = h2 - 55 }
    return v1 * 16 + v2
}

// Parse integer or char literal from token text
fn parse_int_token(uint64 tok_idx) -> uint64 {
    uint64 len = tok_text_len(tok_idx)
    // Check for boolean keywords: true → 1, false → 0
    if len == 4 && tok_source_byte(tok_idx, 0) == 116 { return 1 }
    if len == 5 && tok_source_byte(tok_idx, 0) == 102 { return 0 }
    // Check for char literal: 'x' or '\n' or '\xAB'
    if len >= 3 && tok_source_byte(tok_idx, 0) == 39 {
        if tok_source_byte(tok_idx, 1) == 92 {
            uint64 esc = tok_source_byte(tok_idx, 2)
            // \xHH — two-digit hex byte. Token shape is '\xHH' = 5 source bytes.
            if esc == 120 && len >= 5 {
                return hex_digit_pair_to_byte(tok_source_byte(tok_idx, 3),
                                              tok_source_byte(tok_idx, 4))
            }
            uint64 mapped = escape_char_to_byte(esc)
            if mapped != 0xFFFFFFFFFFFFFFFF { return mapped }
            return esc
        }
        return tok_source_byte(tok_idx, 1)
    }
    uint64 result = 0
    uint64 i = 0
    // Check for 0x prefix
    if len > 2 && tok_source_byte(tok_idx, 0) == 48 && tok_source_byte(tok_idx, 1) == 120 {
        i = 2
        while i < len {
            uint64 ch = tok_source_byte(tok_idx, i)
            result = result * 16
            if ch >= 48 && ch <= 57 { result = result + ch - 48 }
            if ch >= 97 && ch <= 102 { result = result + ch - 87 }
            if ch >= 65 && ch <= 70 { result = result + ch - 55 }
            i = i + 1
        }
    } else {
        while i < len {
            uint64 ch = tok_source_byte(tok_idx, i)
            result = result * 10 + ch - 48
            i = i + 1
        }
    }
    return result
}

// Compare two token texts for equality
fn tok_text_eq(uint64 tok_a, uint64 tok_b) -> uint64 {
    uint64 la = tok_text_len(tok_a)
    uint64 lb = tok_text_len(tok_b)
    if la != lb { return 0 }
    uint64 i = 0
    while i < la {
        if tok_source_byte(tok_a, i) != tok_source_byte(tok_b, i) { return 0 }
        i = i + 1
    }
    return 1
}

// Check if token text matches a string
fn tok_matches(uint64 tok_idx, uint64 str_ptr, uint64 str_len) -> uint64 {
    uint64 tlen = tok_text_len(tok_idx)
    if tlen != str_len { return 0 }
    uint64 start = tok_text_start(tok_idx)
    uint64 i = 0
    while i < tlen {
        uint64 sp = cg_source + start + i
        uint64 sc = 0
        unsafe { *(sp as uint8) -> sc }
        uint64 kp = str_ptr + i
        uint64 kc = 0
        unsafe { *(kp as uint8) -> kc }
        if sc != kc { return 0 }
        i = i + 1
    }
    return 1
}

// ---------------------------------------------------------------------------
// Variable table
// ---------------------------------------------------------------------------

static uint64 var_table_size = 0

static uint64 var_type_table = 0
static uint64 var_type_count = 0

fn var_reset() {
    var_count = 0
    var_frame_size = 0
    var_table_size = 0
    arr_elem_count = 0
    var_type_count = 0
    // struct_var_table is per-function: a variable named `w` typed as
    // struct A in fn f() must NOT leak into fn g() where `w` is typed as
    // struct B. Without this reset, struct_var_lookup(w) in g() would
    // return A's struct index (registered first), and struct_field_offset
    // would compute the wrong byte offset for fields shared by both
    // structs — producing silent garbage reads.
    struct_var_count = 0
}

fn var_type_init() {
    if var_type_table == 0 {
        var_type_table = alloc(8192)
    }
}

fn var_type_register(uint64 name_tok, uint64 type_kind) {
    var_type_init()
    if var_type_count >= 1024 {
        write(2, "error: var_type_table overflow (max 1024)\n", 42)
        exit(1)
    }
    uint64 entry = var_type_table + var_type_count * 8
    uint32 nt = name_tok
    unsafe { *(entry as uint32) = nt }
    uint64 e4 = entry + 4
    uint32 tk = type_kind
    unsafe { *(e4 as uint32) = tk }
    var_type_count = var_type_count + 1
}

fn var_type_lookup(uint64 name_tok) -> uint64 {
    var_type_init()
    uint64 i = 0
    while i < var_type_count {
        uint64 entry = var_type_table + i * 8
        uint32 nt = 0
        unsafe { *(entry as uint32) -> nt }
        uint64 wnt = nt
        if tok_text_eq(wnt, name_tok) != 0 {
            uint64 e4 = entry + 4
            uint32 tk = 0
            unsafe { *(e4 as uint32) -> tk }
            uint64 wtk = tk
            return wtk
        }
        i = i + 1
    }
    return 0
}

fn var_declare(uint64 name_tok) -> uint64 {
    // Check if variable already declared in this function (handles shadowing)
    uint64 existing = var_lookup(name_tok)
    if existing != 0xFFFFFFFF {
        return existing
    }
    if var_table_size >= 4096 {
        write(2, "error: var_table overflow (max 4096)\n", 37)
        exit(1)
    }
    uint64 offset = var_count * 8
    uint64 entry = var_table + var_table_size * 8
    uint32 nt = name_tok
    unsafe { *(entry as uint32) = nt }
    uint64 e4 = entry + 4
    uint32 off32 = offset
    unsafe { *(e4 as uint32) = off32 }
    var_table_size = var_table_size + 1
    var_count = var_count + 1
    var_frame_size = var_count * 8
    // Align frame to 16 bytes
    uint64 rem = var_frame_size & 15
    if rem != 0 {
        var_frame_size = var_frame_size + 16 - rem
    }
    // Persist in the DWARF debug-var table (no-op unless -g is active).
    // fn_count is the CURRENT function's index — it's incremented by
    // fn_register at the start of each function, so the current fn
    // lives at fn_count - 1 when var_declare is called.
    uint64 cur_fn_idx = 0
    if fn_count > 0 { cur_fn_idx = fn_count - 1 }
    debug_var_record(cur_fn_idx, name_tok, offset)
    return offset
}

fn var_lookup(uint64 name_tok) -> uint64 {
    uint64 i = 0
    while i < var_table_size {
        uint64 entry = var_table + i * 8
        uint32 stored_tok = 0
        unsafe { *(entry as uint32) -> stored_tok }
        uint64 ws = stored_tok
        if tok_text_eq(ws, name_tok) != 0 {
            uint64 e4 = entry + 4
            uint32 off = 0
            unsafe { *(e4 as uint32) -> off }
            return off
        }
        i = i + 1
    }
    return 0xFFFFFFFF
}

// ---------------------------------------------------------------------------
// Struct metadata
// ---------------------------------------------------------------------------

// Each struct entry is 16 bytes header + 16 bytes per field = 16 + 16*16 = 272 max
@export
fn struct_register(uint64 name_tok) -> uint64 {
    if struct_count >= 64 {
        write(2, "error: struct_table overflow (max 64)\n", 38)
        exit(1)
    }
    uint64 base = struct_table + struct_count * 272
    uint32 nt = name_tok
    unsafe { *(base as uint32) = nt }
    // field_count = 0 initially
    uint64 fc_addr = base + 4
    uint32 zero = 0
    unsafe { *(fc_addr as uint32) = zero }
    uint64 idx = struct_count
    struct_count = struct_count + 1
    return idx
}

@export
fn struct_add_field(uint64 struct_idx, uint64 field_tok, uint64 field_size, uint64 field_type_kind) {
    uint64 base = struct_table + struct_idx * 272
    uint64 fc_addr = base + 4
    uint32 fc = 0
    unsafe { *(fc_addr as uint32) -> fc }
    uint64 wfc = fc
    // Compute field offset = current total_size (uint16 at offset 8)
    uint64 ts_addr = base + 8
    uint16 ts = 0
    unsafe { *(ts_addr as uint16) -> ts }
    uint64 wts = ts
    // Write field entry at header(16) + field_idx * 16
    uint64 fentry = base + 16 + wfc * 16
    uint32 ft = field_tok
    unsafe { *(fentry as uint32) = ft }
    uint64 fo_addr = fentry + 4
    uint32 fo = wts
    unsafe { *(fo_addr as uint32) = fo }
    uint64 fs_addr = fentry + 8
    uint32 fs = field_size
    unsafe { *(fs_addr as uint32) = fs }
    // Store field type kind at fentry + 12
    uint64 ftk_addr = fentry + 12
    uint32 ftk32 = field_type_kind
    unsafe { *(ftk_addr as uint32) = ftk32 }
    // Update field_count and total_size
    uint32 new_fc = wfc + 1
    unsafe { *(fc_addr as uint32) = new_fc }
    uint16 new_ts = wts + field_size
    unsafe { *(ts_addr as uint16) = new_ts }
}

fn struct_lookup(uint64 name_tok) -> uint64 {
    uint64 i = 0
    while i < struct_count {
        uint64 base = struct_table + i * 272
        uint32 stored = 0
        unsafe { *(base as uint32) -> stored }
        uint64 ws = stored
        if tok_text_eq(ws, name_tok) != 0 {
            return i
        }
        i = i + 1
    }
    return 0xFFFFFFFF
}

fn struct_total_size(uint64 struct_idx) -> uint64 {
    uint64 base = struct_table + struct_idx * 272 + 8
    uint16 ts = 0
    unsafe { *(base as uint16) -> ts }
    return ts
}

fn struct_field_offset(uint64 struct_idx, uint64 field_tok) -> uint64 {
    uint64 base = struct_table + struct_idx * 272
    uint64 fc_addr = base + 4
    uint32 fc = 0
    unsafe { *(fc_addr as uint32) -> fc }
    uint64 wfc = fc
    uint64 fi = 0
    while fi < wfc {
        uint64 fentry = base + 16 + fi * 16
        uint32 ft = 0
        unsafe { *(fentry as uint32) -> ft }
        uint64 wft = ft
        if tok_text_eq(wft, field_tok) != 0 {
            uint64 fo_addr = fentry + 4
            uint32 fo = 0
            unsafe { *(fo_addr as uint32) -> fo }
            return fo
        }
        fi = fi + 1
    }
    return 0xFFFFFFFF
}

fn struct_field_size(uint64 struct_idx, uint64 field_tok) -> uint64 {
    uint64 base = struct_table + struct_idx * 272
    uint64 fc_addr = base + 4
    uint32 fc = 0
    unsafe { *(fc_addr as uint32) -> fc }
    uint64 wfc = fc
    uint64 fi = 0
    while fi < wfc {
        uint64 fentry = base + 16 + fi * 16
        uint32 ft = 0
        unsafe { *(fentry as uint32) -> ft }
        uint64 wft = ft
        if tok_text_eq(wft, field_tok) != 0 {
            uint64 fs_addr = fentry + 8
            uint32 fs = 0
            unsafe { *(fs_addr as uint32) -> fs }
            return fs
        }
        fi = fi + 1
    }
    return 0
}

fn struct_field_type_kind(uint64 struct_idx, uint64 field_idx) -> uint64 {
    uint64 base = struct_table + struct_idx * 272
    uint64 fentry = base + 16 + field_idx * 16 + 12
    uint32 val = 0
    unsafe { *(fentry as uint32) -> val }
    return val
}

fn struct_field_type_kind_by_tok(uint64 struct_idx, uint64 field_tok) -> uint64 {
    uint64 base = struct_table + struct_idx * 272
    uint64 fc_addr = base + 4
    uint32 fc = 0
    unsafe { *(fc_addr as uint32) -> fc }
    uint64 wfc = fc
    uint64 fi = 0
    while fi < wfc {
        uint64 fentry = base + 16 + fi * 16
        uint32 ft = 0
        unsafe { *(fentry as uint32) -> ft }
        uint64 wft = ft
        if tok_text_eq(wft, field_tok) != 0 {
            uint64 ftk_addr = fentry + 12
            uint32 ftk = 0
            unsafe { *(ftk_addr as uint32) -> ftk }
            return ftk
        }
        fi = fi + 1
    }
    return 0
}

@export
fn struct_classify_abi(uint64 struct_idx) {
    uint64 base = struct_table + struct_idx * 272
    uint64 size = struct_total_size(struct_idx)

    if size > 16 {
        // MEMORY class
        uint64 c0_addr = base + 12
        uint16 mem = 3
        unsafe { *(c0_addr as uint16) = mem }
        uint64 c1_addr = base + 14
        unsafe { *(c1_addr as uint16) = mem }
        return
    }

    uint64 class0 = 0
    uint64 class1 = 0
    uint64 fc_addr = base + 4
    uint32 fc = 0
    unsafe { *(fc_addr as uint32) -> fc }
    uint64 wfc = fc
    uint64 fi = 0
    while fi < wfc {
        uint64 fentry = base + 16 + fi * 16
        uint64 fo_addr = fentry + 4
        uint32 fo = 0
        unsafe { *(fo_addr as uint32) -> fo }
        uint64 field_off = fo
        uint64 eightbyte = field_off / 8
        uint64 ftk = struct_field_type_kind(struct_idx, fi)
        uint64 is_float = 0
        if ftk == 94 || ftk == 95 || ftk == 96 { is_float = 1 }
        if eightbyte == 0 {
            if is_float != 0 && class0 == 0 { class0 = 2 }
            if is_float == 0 { class0 = 1 }
        }
        if eightbyte == 1 {
            if is_float != 0 && class1 == 0 { class1 = 2 }
            if is_float == 0 { class1 = 1 }
        }
        fi = fi + 1
    }
    uint64 c0_addr = base + 12
    uint16 c0_16 = class0
    unsafe { *(c0_addr as uint16) = c0_16 }
    uint64 c1_addr = base + 14
    uint16 c1_16 = class1
    unsafe { *(c1_addr as uint16) = c1_16 }

    // ARM64 HFA detection
    uint64 flags = 0
    if wfc >= 1 && wfc <= 4 {
        uint64 first_ftk = struct_field_type_kind(struct_idx, 0)
        uint64 all_same_float = 0
        if first_ftk == 95 || first_ftk == 96 { all_same_float = 1 }
        uint64 ci = 1
        while ci < wfc {
            uint64 ci_ftk = struct_field_type_kind(struct_idx, ci)
            if ci_ftk != first_ftk { all_same_float = 0 }
            ci = ci + 1
        }
        if all_same_float != 0 {
            uint64 hfa_type = 0
            if first_ftk == 96 { hfa_type = 1 }
            flags = 1 | ((wfc - 1) << 1) | (hfa_type << 3)
        }
    }
    uint64 flags_addr = base + 10
    uint16 fl16 = flags
    unsafe { *(flags_addr as uint16) = fl16 }
}

fn struct_abi_class0(uint64 struct_idx) -> uint64 {
    uint64 base = struct_table + struct_idx * 272 + 12
    uint16 val = 0
    unsafe { *(base as uint16) -> val }
    return val
}

fn struct_abi_class1(uint64 struct_idx) -> uint64 {
    uint64 base = struct_table + struct_idx * 272 + 14
    uint16 val = 0
    unsafe { *(base as uint16) -> val }
    return val
}

fn struct_abi_flags(uint64 struct_idx) -> uint64 {
    uint64 base = struct_table + struct_idx * 272 + 10
    uint16 val = 0
    unsafe { *(base as uint16) -> val }
    return val
}

// Track which variables are struct-typed
fn struct_var_register(uint64 var_tok, uint64 struct_idx) {
    if struct_var_count >= 1024 {
        write(2, "error: struct_var_table overflow (max 1024)\n", 44)
        exit(1)
    }
    uint64 entry = struct_var_table + struct_var_count * 8
    uint32 vt = var_tok
    unsafe { *(entry as uint32) = vt }
    uint64 e4 = entry + 4
    uint32 si = struct_idx
    unsafe { *(e4 as uint32) = si }
    struct_var_count = struct_var_count + 1
}

fn struct_var_lookup(uint64 var_tok) -> uint64 {
    uint64 i = 0
    while i < struct_var_count {
        uint64 entry = struct_var_table + i * 8
        uint32 stored = 0
        unsafe { *(entry as uint32) -> stored }
        uint64 ws = stored
        if tok_text_eq(ws, var_tok) != 0 {
            uint64 e4 = entry + 4
            uint32 si = 0
            unsafe { *(e4 as uint32) -> si }
            return si
        }
        i = i + 1
    }
    return 0xFFFFFFFF
}

// ---------------------------------------------------------------------------
// Enum value table
// ---------------------------------------------------------------------------

@export
fn enum_register(uint64 enum_tok, uint64 field_tok, uint64 value) {
    if enum_count >= 512 {
        write(2, "error: enum_table overflow (max 512)\n", 37)
        exit(1)
    }
    uint64 entry = enum_table + enum_count * 16
    uint32 et = enum_tok
    unsafe { *(entry as uint32) = et }
    uint64 e4 = entry + 4
    uint32 ft = field_tok
    unsafe { *(e4 as uint32) = ft }
    uint64 e8 = entry + 8
    unsafe { *(e8 as uint64) = value }
    enum_count = enum_count + 1
}

fn enum_lookup(uint64 enum_tok, uint64 field_tok) -> uint64 {
    uint64 i = 0
    while i < enum_count {
        uint64 entry = enum_table + i * 16
        uint32 stored_enum = 0
        unsafe { *(entry as uint32) -> stored_enum }
        uint64 we = stored_enum
        if tok_text_eq(we, enum_tok) != 0 {
            uint64 e4 = entry + 4
            uint32 stored_field = 0
            unsafe { *(e4 as uint32) -> stored_field }
            uint64 wf = stored_field
            if tok_text_eq(wf, field_tok) != 0 {
                uint64 e8 = entry + 8
                uint64 val = 0
                unsafe { *(e8 as uint64) -> val }
                return val
            }
        }
        i = i + 1
    }
    return 0
}

// ---------------------------------------------------------------------------
// Static variable table
// ---------------------------------------------------------------------------

@export
fn static_declare(uint64 name_tok) -> uint64 {
    if static_count >= 1024 {
        write(2, "error: static_table overflow (max 1024)\n", 40)
        exit(1)
    }
    uint64 offset = static_data_size
    uint64 entry = static_table + static_count * 8
    uint32 nt = name_tok
    unsafe { *(entry as uint32) = nt }
    uint64 e4 = entry + 4
    uint32 off32 = offset
    unsafe { *(e4 as uint32) = off32 }
    // Mark as scalar (0 in array_sizes)
    uint64 ae = static_array_sizes + static_count * 4
    uint32 zero32 = 0
    unsafe { *(ae as uint32) = zero32 }
    // Default initial value = 0
    uint64 iv = static_init_values + static_count * 8
    unsafe { *(iv as uint64) = 0 }
    // Default fkind = 0 (int/other)
    uint64 fk = static_fkinds + static_count * 4
    unsafe { *(fk as uint32) = zero32 }
    static_count = static_count + 1
    static_data_size = static_data_size + 8
    return offset
}

// Set the initial 8-byte value for the most recently declared scalar static.
// Called by the parser for `const TYPE name = LITERAL` and `static TYPE name = LITERAL`.
@export
fn static_set_init_last(uint64 value) {
    if static_count == 0 { return }
    uint64 idx = static_count - 1
    uint64 iv = static_init_values + idx * 8
    unsafe { *(iv as uint64) = value }
}

// Mark the most recently declared static as f64 (fk=1), f32 (fk=2),
// etc. — called by the parser when it sees `static f64 x` / `static f32 x`
// / `static f64[N] arr`. Fixes the f64 type-flow bug where reads of
// a declared-float static otherwise produce uint64-typed vregs that
// downstream arithmetic mis-interprets as integer ops.
@export
fn static_set_fkind_last(uint64 fk) {
    if static_count == 0 { return }
    uint64 idx = static_count - 1
    uint64 ep = static_fkinds + idx * 4
    uint32 fk32 = fk
    unsafe { *(ep as uint32) = fk32 }
}

// Look up the fkind (0/1/2/3) of a static by its name_tok. Returns 0
// if not found or if the static isn't a float type.
@export
fn static_fkind_of(uint64 name_tok) -> uint64 {
    uint64 i = 0
    while i < static_count {
        uint64 entry = static_table + i * 8
        uint32 stored_tok = 0
        unsafe { *(entry as uint32) -> stored_tok }
        uint64 ws = stored_tok
        if tok_text_eq(ws, name_tok) != 0 {
            uint64 ep = static_fkinds + i * 4
            uint32 fk = 0
            unsafe { *(ep as uint32) -> fk }
            return fk
        }
        i = i + 1
    }
    return 0
}

// Device table helpers: device_register returns the new device index.
@export
fn device_register(uint64 name_tok, uint64 base_addr) -> uint64 {
    if device_count >= 64 {
        write(2, "error: device_table overflow (max 64)\n", 38)
        exit(1)
    }
    uint64 entry = device_table + device_count * 16
    uint32 nt = name_tok
    unsafe { *(entry as uint32) = nt }
    uint64 e8 = entry + 8
    unsafe { *(e8 as uint64) = base_addr }
    uint64 idx = device_count
    device_count = device_count + 1
    return idx
}

@export
fn device_add_field(uint64 dev_idx, uint64 field_tok, uint64 offset, uint64 size) {
    if device_field_count >= 256 {
        write(2, "error: device_field_table overflow (max 256)\n", 45)
        exit(1)
    }
    uint64 entry = device_field_table + device_field_count * 16
    uint32 di = dev_idx
    unsafe { *(entry as uint32) = di }
    uint64 e4 = entry + 4
    uint32 ft = field_tok
    unsafe { *(e4 as uint32) = ft }
    uint64 e8 = entry + 8
    uint32 off32 = offset
    unsafe { *(e8 as uint32) = off32 }
    uint64 ec = entry + 12
    uint32 sz32 = size
    unsafe { *(ec as uint32) = sz32 }
    device_field_count = device_field_count + 1
}

// Look up device by name_tok. Returns 0xFFFFFFFF if not found.
fn device_lookup(uint64 name_tok) -> uint64 {
    uint64 i = 0
    while i < device_count {
        uint64 entry = device_table + i * 16
        uint32 stored = 0
        unsafe { *(entry as uint32) -> stored }
        uint64 ws = stored
        if tok_text_eq(ws, name_tok) != 0 { return i }
        i = i + 1
    }
    return 0xFFFFFFFF
}

// Get base address of a device
fn device_base(uint64 dev_idx) -> uint64 {
    uint64 entry = device_table + dev_idx * 16
    uint64 e8 = entry + 8
    uint64 base = 0
    unsafe { *(e8 as uint64) -> base }
    return base
}

// Look up a device field. Returns offset OR 0xFFFFFFFF if not found.
fn device_field_offset_of(uint64 dev_idx, uint64 field_tok) -> uint64 {
    uint64 i = 0
    while i < device_field_count {
        uint64 entry = device_field_table + i * 16
        uint32 stored_dev = 0
        unsafe { *(entry as uint32) -> stored_dev }
        uint64 wsd = stored_dev
        if wsd == dev_idx {
            uint64 e4 = entry + 4
            uint32 stored_field = 0
            unsafe { *(e4 as uint32) -> stored_field }
            uint64 wsf = stored_field
            if tok_text_eq(wsf, field_tok) != 0 {
                uint64 e8 = entry + 8
                uint32 off = 0
                unsafe { *(e8 as uint32) -> off }
                return off
            }
        }
        i = i + 1
    }
    return 0xFFFFFFFF
}

fn device_field_size_of(uint64 dev_idx, uint64 field_tok) -> uint64 {
    uint64 i = 0
    while i < device_field_count {
        uint64 entry = device_field_table + i * 16
        uint32 stored_dev = 0
        unsafe { *(entry as uint32) -> stored_dev }
        uint64 wsd = stored_dev
        if wsd == dev_idx {
            uint64 e4 = entry + 4
            uint32 stored_field = 0
            unsafe { *(e4 as uint32) -> stored_field }
            uint64 wsf = stored_field
            if tok_text_eq(wsf, field_tok) != 0 {
                uint64 ec = entry + 12
                uint32 sz = 0
                unsafe { *(ec as uint32) -> sz }
                return sz
            }
        }
        i = i + 1
    }
    return 0
}

// Record a slice parameter's length slot. Per-function, cleared on function entry.
fn slice_len_register(uint64 ptr_off, uint64 len_off) {
    if slice_len_count >= 32 {
        write(2, "error: slice_len_table overflow (max 32)\n", 41)
        exit(1)
    }
    uint64 entry = slice_len_table + slice_len_count * 8
    uint32 po = ptr_off
    unsafe { *(entry as uint32) = po }
    uint64 e4 = entry + 4
    uint32 lo = len_off
    unsafe { *(e4 as uint32) = lo }
    slice_len_count = slice_len_count + 1
}

// Look up a slice's length slot offset by its ptr slot offset. Returns 0xFFFFFFFF if not a slice.
fn slice_len_lookup(uint64 ptr_off) -> uint64 {
    uint64 i = 0
    while i < slice_len_count {
        uint64 entry = slice_len_table + i * 8
        uint32 stored = 0
        unsafe { *(entry as uint32) -> stored }
        uint64 ws = stored
        if ws == ptr_off {
            uint64 e4 = entry + 4
            uint32 lo = 0
            unsafe { *(e4 as uint32) -> lo }
            return lo
        }
        i = i + 1
    }
    return 0xFFFFFFFF
}

@export
fn static_declare_array(uint64 name_tok, uint64 byte_size) -> uint64 {
    if static_count >= 1024 {
        write(2, "error: static_table overflow (max 1024)\n", 40)
        exit(1)
    }
    // Align static_data_size up to 8 for clean placement
    uint64 rem = static_data_size & 7
    if rem != 0 { static_data_size = static_data_size + 8 - rem }
    uint64 offset = static_data_size
    uint64 entry = static_table + static_count * 8
    uint32 nt = name_tok
    unsafe { *(entry as uint32) = nt }
    uint64 e4 = entry + 4
    uint32 off32 = offset
    unsafe { *(e4 as uint32) = off32 }
    // Mark as array by storing byte_size in parallel table
    uint64 ae = static_array_sizes + static_count * 4
    uint32 bs32 = byte_size
    unsafe { *(ae as uint32) = bs32 }
    // Default element size = 1 (byte); parser calls static_set_elem_size_last
    // right after this for wider element types.
    uint64 es = static_elem_sizes + static_count * 4
    uint32 one32 = 1
    unsafe { *(es as uint32) = one32 }
    // Default fkind = 0 (int/other); parser calls static_set_fkind_last
    // right after this for f32/f64 arrays.
    uint64 fkp = static_fkinds + static_count * 4
    uint32 zero_fk = 0
    unsafe { *(fkp as uint32) = zero_fk }
    static_count = static_count + 1
    // Allocate byte_size bytes, padded to 8-byte boundary
    uint64 padded = byte_size
    uint64 brem = byte_size & 7
    if brem != 0 { padded = byte_size + 8 - brem }
    static_data_size = static_data_size + padded
    return offset
}

// Record the element size for the most recently declared static array.
// Called by the parser right after static_declare_array when the array's
// element type is wider than u8.
@export
fn static_set_elem_size_last(uint64 elem_size) {
    if static_count == 0 { return }
    uint64 idx = static_count - 1
    uint64 es = static_elem_sizes + idx * 4
    uint32 sz = elem_size
    unsafe { *(es as uint32) = sz }
}

// Look up a static array's element size by name_tok. Returns 1 (byte) if
// the name isn't a static array.
@export
fn static_elem_size_of(uint64 name_tok) -> uint64 {
    uint64 i = 0
    while i < static_count {
        uint64 entry = static_table + i * 8
        uint32 stored = 0
        unsafe { *(entry as uint32) -> stored }
        uint64 ws = stored
        if tok_text_eq(ws, name_tok) != 0 {
            uint64 es = static_elem_sizes + i * 4
            uint32 sz = 0
            unsafe { *(es as uint32) -> sz }
            return sz
        }
        i = i + 1
    }
    return 1
}

// Return byte size if name_tok refers to a static array, 0 if scalar, 0xFFFFFFFF if not found
fn static_array_size_of(uint64 name_tok) -> uint64 {
    uint64 i = 0
    while i < static_count {
        uint64 entry = static_table + i * 8
        uint32 stored_tok = 0
        unsafe { *(entry as uint32) -> stored_tok }
        uint64 ws = stored_tok
        if tok_text_eq(ws, name_tok) != 0 {
            uint64 ae = static_array_sizes + i * 4
            uint32 sz = 0
            unsafe { *(ae as uint32) -> sz }
            return sz
        }
        i = i + 1
    }
    return 0xFFFFFFFF
}

fn static_lookup(uint64 name_tok) -> uint64 {
    uint64 i = 0
    while i < static_count {
        uint64 entry = static_table + i * 8
        uint32 stored_tok = 0
        unsafe { *(entry as uint32) -> stored_tok }
        uint64 ws = stored_tok
        if tok_text_eq(ws, name_tok) != 0 {
            uint64 e4 = entry + 4
            uint32 off = 0
            unsafe { *(e4 as uint32) -> off }
            return off
        }
        i = i + 1
    }
    return 0xFFFFFFFF
}

// Look up a static by literal name (for generated code, not user code)
fn static_lookup_by_name(uint64 name_str, uint64 name_len) -> uint64 {
    uint64 i = 0
    while i < static_count {
        uint64 entry = static_table + i * 8
        uint32 stored_tok = 0
        unsafe { *(entry as uint32) -> stored_tok }
        uint64 ws = stored_tok
        if tok_matches(ws, name_str, name_len) != 0 {
            uint64 e4 = entry + 4
            uint32 off = 0
            unsafe { *(e4 as uint32) -> off }
            return off
        }
        i = i + 1
    }
    return 0xFFFFFFFF
}

// ---------------------------------------------------------------------------
// Type alias table
// ---------------------------------------------------------------------------

@export
fn type_alias_register(uint64 name_tok, uint64 target_size) {
    if type_alias_count >= 64 {
        write(2, "error: type_alias_table overflow (max 64)\n", 42)
        exit(1)
    }
    uint64 entry = type_alias_table + type_alias_count * 8
    uint32 nt = name_tok
    unsafe { *(entry as uint32) = nt }
    uint64 e4 = entry + 4
    uint32 ts = target_size
    unsafe { *(e4 as uint32) = ts }
    type_alias_count = type_alias_count + 1
}

@export
fn type_alias_lookup(uint64 name_tok) -> uint64 {
    uint64 i = 0
    while i < type_alias_count {
        uint64 entry = type_alias_table + i * 8
        uint32 stored_tok = 0
        unsafe { *(entry as uint32) -> stored_tok }
        uint64 ws = stored_tok
        if tok_text_eq(ws, name_tok) != 0 {
            uint64 e4 = entry + 4
            uint32 ts = 0
            unsafe { *(e4 as uint32) -> ts }
            return ts
        }
        i = i + 1
    }
    return 0xFFFFFFFF
}

// Map a type keyword token (u8..u64 / i8..i64 / uint8..uint64) to its byte size.
// Default 1 (byte) for anything else, so legacy u8 arrays keep working.
fn type_tok_elem_size(uint64 type_tok) -> uint64 {
    uint64 p = cg_tokens + type_tok * 16
    uint32 k = 0
    unsafe { *(p as uint32) -> k }
    uint64 wk = k
    if wk == 80 { return 1 }
    if wk == 98 { return 1 }
    if wk == 99 { return 1 }
    if wk == 81 { return 2 }
    if wk == 82 { return 4 }
    if wk == 83 { return 8 }
    if wk == 84 { return 1 }
    if wk == 85 { return 2 }
    if wk == 86 { return 4 }
    if wk == 87 { return 8 }
    if wk == 94 { return 2 }
    if wk == 95 { return 4 }
    if wk == 96 { return 8 }
    return 1
}

// Register a local array's element size so that index ops can scale correctly.
fn arr_elem_register(uint64 name_tok, uint64 elem_size) {
    if arr_elem_count >= 512 {
        write(2, "error: arr_elem_table overflow (max 512)\n", 41)
        exit(1)
    }
    uint64 entry = arr_elem_table + arr_elem_count * 16
    uint32 nt = name_tok
    unsafe { *(entry as uint32) = nt }
    uint64 e4 = entry + 4
    uint32 es = elem_size
    unsafe { *(e4 as uint32) = es }
    // Default count = 0 means "unknown / unchecked" for bounds.
    uint64 e8 = entry + 8
    uint32 zero32 = 0
    unsafe { *(e8 as uint32) = zero32 }
    arr_elem_count = arr_elem_count + 1
}

// Record the element count for the most recently declared array.
// Callers invoke this after arr_elem_register with the literal size.
// A count of 0 leaves the slot as "unknown" — no bounds check emitted.
@export
fn arr_count_set_last(uint64 count) {
    if arr_elem_count == 0 { return }
    uint64 entry = arr_elem_table + (arr_elem_count - 1) * 16
    uint64 e8 = entry + 8
    uint32 c32 = count
    unsafe { *(e8 as uint32) = c32 }
}

// Look up an array's element size. Checks local (per-function) array
// declarations first, then falls through to module-level static arrays.
// Returns 1 (byte) for anything else — keeps raw alloc + byte-indexed code
// paths unchanged.
fn arr_elem_lookup(uint64 name_tok) -> uint64 {
    uint64 i = 0
    while i < arr_elem_count {
        uint64 entry = arr_elem_table + i * 16
        uint32 stored = 0
        unsafe { *(entry as uint32) -> stored }
        uint64 ws = stored
        if tok_text_eq(ws, name_tok) != 0 {
            uint64 e4 = entry + 4
            uint32 es = 0
            unsafe { *(e4 as uint32) -> es }
            return es
        }
        i = i + 1
    }
    return static_elem_size_of(name_tok)
}

// Return the declared element count of an array, or 0xFFFFFFFF if
// the size is not known at compile time. Looks at stack-array
// declarations first, then derives the count for static arrays
// from their byte size and element size.
@export
fn arr_count_lookup(uint64 name_tok) -> uint64 {
    uint64 i = 0
    while i < arr_elem_count {
        uint64 entry = arr_elem_table + i * 16
        uint32 stored = 0
        unsafe { *(entry as uint32) -> stored }
        uint64 ws = stored
        if tok_text_eq(ws, name_tok) != 0 {
            uint64 e8 = entry + 8
            uint32 c = 0
            unsafe { *(e8 as uint32) -> c }
            uint64 wc = c
            if wc == 0 { return 0xFFFFFFFF }
            return wc
        }
        i = i + 1
    }
    // Static array path: bytes / elem_size.
    uint64 bytes = static_array_size_of(name_tok)
    if bytes == 0xFFFFFFFF || bytes == 0 { return 0xFFFFFFFF }
    uint64 es = static_elem_size_of(name_tok)
    if es == 0 { return 0xFFFFFFFF }
    return bytes / es
}

// Emit: load static at data_offset into rax (RIP-relative, placeholder)
fn emit_static_load(uint64 data_offset) {
    if static_fixup_count >= 8192 {
        write(2, "error: static_fixups overflow (max 8192)\n", 41)
        exit(1)
    }
    // mov disp32(%rip), %rax → 48 8B 05 [disp32]
    emit_byte(0x48)
    emit_byte(0x8B)
    emit_byte(0x05)
    // Record fixup: patch this disp32 later
    uint64 fentry = static_fixups + static_fixup_count * 8
    uint32 cp = out_len
    unsafe { *(fentry as uint32) = cp }
    uint64 fe4 = fentry + 4
    uint32 dp = data_offset
    unsafe { *(fe4 as uint32) = dp }
    static_fixup_count = static_fixup_count + 1
    emit_u32_le(0)
}

// Emit: lea rax, [rip + disp32] — RIP-relative address of a static
// Used for static arrays to put the address of the data in rax.
fn emit_static_lea(uint64 data_offset) {
    if static_fixup_count >= 8192 {
        write(2, "error: static_fixups overflow (max 8192)\n", 41)
        exit(1)
    }
    // lea rax, [rip + disp32] → 48 8D 05 [disp32]
    emit_byte(0x48)
    emit_byte(0x8D)
    emit_byte(0x05)
    uint64 fentry = static_fixups + static_fixup_count * 8
    uint32 cp = out_len
    unsafe { *(fentry as uint32) = cp }
    uint64 fe4 = fentry + 4
    uint32 dp = data_offset
    unsafe { *(fe4 as uint32) = dp }
    static_fixup_count = static_fixup_count + 1
    emit_u32_le(0)
    // Invalidate the rax cache: rax now holds a static address, not [rsp+*]
    rax_cache = 0
}

// Emit: store rax to static at data_offset (RIP-relative, placeholder)
fn emit_static_store(uint64 data_offset) {
    if static_fixup_count >= 8192 {
        write(2, "error: static_fixups overflow (max 8192)\n", 41)
        exit(1)
    }
    // mov %rax, disp32(%rip) → 48 89 05 [disp32]
    emit_byte(0x48)
    emit_byte(0x89)
    emit_byte(0x05)
    // Record fixup
    uint64 fentry = static_fixups + static_fixup_count * 8
    uint32 cp = out_len
    unsafe { *(fentry as uint32) = cp }
    uint64 fe4 = fentry + 4
    uint32 dp = data_offset
    unsafe { *(fe4 as uint32) = dp }
    static_fixup_count = static_fixup_count + 1
    emit_u32_le(0)
}

// Resolve all static RIP-relative fixups. Call after all code is emitted.
// data_start = out_len at the time statics are placed.
@export
fn resolve_static_fixups(uint64 data_start) {
    uint64 i = 0
    while i < static_fixup_count {
        uint64 fentry = static_fixups + i * 8
        uint32 code_off = 0
        unsafe { *(fentry as uint32) -> code_off }
        uint64 fe4 = fentry + 4
        uint32 data_off = 0
        unsafe { *(fe4 as uint32) -> data_off }
        // RIP = code_off + 4 (past the disp32 bytes)
        // target = data_start + data_off
        // disp = target - RIP
        uint64 rip = code_off + 4
        uint64 wdo = data_off
        uint64 target = data_start + wdo
        uint64 disp = target - rip
        patch_u32(code_off, disp)
        i = i + 1
    }
}

// Emit string literal data
@export
fn emit_string_data() {
    uint64 i = 0
    while i < str_len {
        uint64 sp = str_buf + i
        uint8 b = 0
        unsafe { *(sp as uint8) -> b }
        emit_byte(b)
        i = i + 1
    }
}

// Resolve string literal RIP-relative fixups
@export
fn resolve_string_fixups(uint64 str_data_start) {
    uint64 i = 0
    while i < str_fixup_count {
        uint64 fentry = str_fixups + i * 8
        uint32 code_off = 0
        unsafe { *(fentry as uint32) -> code_off }
        uint64 fe4 = fentry + 4
        uint32 str_off = 0
        unsafe { *(fe4 as uint32) -> str_off }
        uint64 rip = code_off + 4
        uint64 wso = str_off
        uint64 target = str_data_start + wso
        uint64 disp = target - rip
        patch_u32(code_off, disp)
        i = i + 1
    }
}

// Emit zero-initialized data for all statics
@export
fn emit_static_data() {
    // Walk the static table in declaration order. Scalar slots (array_size==0)
    // get their recorded init value; array slots stay zero.
    uint64 emitted = 0
    uint64 si = 0
    while si < static_count {
        // offset of this slot within the static data segment
        uint64 entry = static_table + si * 8
        uint64 e4 = entry + 4
        uint32 slot_off = 0
        unsafe { *(e4 as uint32) -> slot_off }
        // Pad with zeros up to this slot's offset
        while emitted < slot_off {
            emit_byte(0)
            emitted = emitted + 1
        }
        uint64 asp = static_array_sizes + si * 4
        uint32 asz = 0
        unsafe { *(asp as uint32) -> asz }
        if asz == 0 {
            // Scalar: 8 bytes of init value
            uint64 ivp = static_init_values + si * 8
            uint64 val = 0
            unsafe { *(ivp as uint64) -> val }
            uint64 bi = 0
            while bi < 8 {
                uint8 b = (val >> (bi * 8)) & 0xFF
                emit_byte(b)
                bi = bi + 1
            }
            emitted = emitted + 8
        } else {
            // Array: emit `asz` zero bytes
            uint64 ai = 0
            while ai < asz {
                emit_byte(0)
                ai = ai + 1
            }
            emitted = emitted + asz
        }
        si = si + 1
    }
    // Final tail of zeros (alignment/padding)
    while emitted < static_data_size {
        emit_byte(0)
        emitted = emitted + 1
    }
}

// ---------------------------------------------------------------------------
// Static fixup accessors — used by format_elf_dyn to repoint static
// RIP-relative patches into the RW segment (the dyn-ELF path keeps
// writable static data out of the executable RX segment).
// ---------------------------------------------------------------------------

@export
fn codegen_static_data_size_get() -> uint64 { return static_data_size }

@export
fn codegen_static_fixup_count_get() -> uint64 { return static_fixup_count }

@export
fn codegen_static_fixup_code_off_at(uint64 i) -> uint64 {
    uint64 entry = static_fixups + i * 8
    uint32 co = 0
    unsafe { *(entry as uint32) -> co }
    uint64 wco = co
    return wco
}

@export
fn codegen_static_fixup_data_off_at(uint64 i) -> uint64 {
    uint64 entry = static_fixups + i * 8 + 4
    uint32 dof = 0
    unsafe { *(entry as uint32) -> dof }
    uint64 wdo = dof
    return wdo
}

// ---------------------------------------------------------------------------
// Function table
// ---------------------------------------------------------------------------

fn fn_register(uint64 name_tok, uint64 code_offset) {
    if fn_count >= 2048 {
        write(2, "error: fn_table overflow (max 2048)\n", 36)
        exit(1)
    }
    uint64 entry = fn_table + fn_count * 8
    uint32 nt = name_tok
    unsafe { *(entry as uint32) = nt }
    uint64 e4 = entry + 4
    uint32 co = code_offset
    unsafe { *(e4 as uint32) = co }
    fn_count = fn_count + 1
}

// Per-function `@section("name")` annotation storage. Each entry is 16
// bytes: u32 fn_name_tok, u32 section_text_start, u32 section_text_len,
// u32 reserved. Keyed by the function's name token (not its index in
// fn_table because this may be populated before fn_register runs).
static uint64 fn_section_table = 0
static uint64 fn_section_count = 0

fn fn_section_init() {
    if fn_section_table == 0 {
        fn_section_table = alloc(1024 * 16)
    }
}

@export
fn fn_section_set(uint64 name_tok, uint64 str_start, uint64 str_len) {
    fn_section_init()
    if fn_section_count >= 1024 { return }
    uint64 entry = fn_section_table + fn_section_count * 16
    uint32 nt = name_tok
    unsafe { *(entry as uint32) = nt }
    uint64 e4 = entry + 4
    uint32 ss = str_start
    unsafe { *(e4 as uint32) = ss }
    uint64 e8 = entry + 8
    uint32 sl = str_len
    unsafe { *(e8 as uint32) = sl }
    fn_section_count = fn_section_count + 1
}

// Returns the section string's byte range as (start << 32) | len, or
// 0 if the function has no @section annotation.
@export
fn fn_section_lookup(uint64 name_tok) -> uint64 {
    uint64 i = 0
    while i < fn_section_count {
        uint64 entry = fn_section_table + i * 16
        uint32 stored = 0
        unsafe { *(entry as uint32) -> stored }
        uint64 ws = stored
        if tok_text_eq(ws, name_tok) != 0 {
            uint64 e4 = entry + 4
            uint32 ss = 0
            unsafe { *(e4 as uint32) -> ss }
            uint64 e8 = entry + 8
            uint32 sl = 0
            unsafe { *(e8 as uint32) -> sl }
            uint64 wss = ss
            uint64 wsl = sl
            return (wss << 32) | wsl
        }
        i = i + 1
    }
    return 0
}

fn fn_lookup(uint64 name_tok) -> uint64 {
    uint64 i = 0
    while i < fn_count {
        uint64 entry = fn_table + i * 8
        uint32 stored_tok = 0
        unsafe { *(entry as uint32) -> stored_tok }
        uint64 ws = stored_tok
        if tok_text_eq(ws, name_tok) != 0 {
            uint64 e4 = entry + 4
            uint32 off = 0
            unsafe { *(e4 as uint32) -> off }
            return off
        }
        i = i + 1
    }
    return 0xFFFFFFFF
}

// Look up a function in the fn_table by literal name string (not token).
// Used by the compiler-synthesized hipkfd_teardown auto-injection — the
// CALL site doesn't correspond to any source token, so the regular
// token-keyed fixup machinery doesn't apply. Returns 0xFFFFFFFF if not
// found.
@export
fn fn_lookup_by_str(uint64 name_ptr, uint64 name_len) -> uint64 {
    uint64 i = 0
    while i < fn_count {
        uint64 entry = fn_table + i * 8
        uint32 stored_tok = 0
        unsafe { *(entry as uint32) -> stored_tok }
        uint64 ws = stored_tok
        uint64 fn_tlen = tok_text_len(ws)
        if fn_tlen == name_len {
            uint64 fn_tstart = tok_text_start(ws)
            uint64 eq = 1
            uint64 ci = 0
            while ci < name_len {
                uint64 ap = cg_source + fn_tstart + ci
                uint64 av = 0
                unsafe { *(ap as uint8) -> av }
                uint64 bp = name_ptr + ci
                uint64 bv = 0
                unsafe { *(bp as uint8) -> bv }
                if av != bv { eq = 0 }
                ci = ci + 1
            }
            if eq != 0 {
                uint64 e4 = entry + 4
                uint32 off = 0
                unsafe { *(e4 as uint32) -> off }
                return off
            }
        }
        i = i + 1
    }
    return 0xFFFFFFFF
}

// Predicate: should the compiler auto-inject a `call hipkfd_teardown`
// before this exit path? Returns 1 iff
//   1. --target=amdgpu-native was passed (so the KFD shim drives the
//      4 KFD queues that need draining), AND
//   2. --no-auto-teardown was NOT passed (user opt-out), AND
//   3. `hipkfd_teardown` is actually defined in the link set (the
//      function exists in fn_table). Without (3) the synthesized CALL
//      would patch to an undefined offset.
// Reads cross-file statics target_amdgpu_native (format_amdgpu.mlr) and
// auto_teardown_disabled (main.mlr). target_os is also checked to keep
// the injection Linux-only — amdgpu-native is /dev/kfd, Linux-only by
// construction, but the belt-and-braces guard means a future port to
// another OS won't silently inject calls that don't make sense.
@export
fn should_auto_inject_teardown() -> uint64 {
    if target_amdgpu_native == 0 { return 0 }
    if auto_teardown_disabled != 0 { return 0 }
    if target_os != 0 { return 0 }
    uint64 td_name = "hipkfd_teardown"
    uint64 off = fn_lookup_by_str(td_name, 15)
    if off == 0xFFFFFFFF { return 0 }
    return 1
}

// Emit `call hipkfd_teardown` (5 bytes: E8 + rel32). The rel32 placeholder
// is patched at resolve time by resolve_teardown_fixups. Callers should
// guard with should_auto_inject_teardown() == 1 first.
@export
fn emit_call_hipkfd_teardown() {
    emit_byte(0xE8)
    uint64 patch_off = out_len
    emit_u32_le(0)
    if teardown_fixup_count >= teardown_fixup_cap {
        write(2, "error: teardown_fixup_table overflow (max 1024)\n", 48)
        exit(1)
    }
    uint64 entry = teardown_fixup_table + teardown_fixup_count * 8
    uint32 po = patch_off
    unsafe { *(entry as uint32) = po }
    teardown_fixup_count = teardown_fixup_count + 1
    // CALL clobbers rax (return value of the callee), so invalidate the
    // cache. Teardown is `fn hipkfd_teardown() { ... }` with no return,
    // but the codegen treats every CALL as rax-clobbering anyway.
    rax_invalidate()
}

// Resolve all synthesized `call hipkfd_teardown` fixups to the real
// function offset. Called at the same site as resolve_fixups() in main.mlr.
@export
fn resolve_teardown_fixups() {
    if teardown_fixup_count == 0 { return }
    uint64 td_name = "hipkfd_teardown"
    uint64 target_off = fn_lookup_by_str(td_name, 15)
    if target_off == 0xFFFFFFFF {
        // Should be impossible — emit_call_hipkfd_teardown is gated on
        // should_auto_inject_teardown which already checked. Belt-and-
        // braces: hard error rather than silent garbage CALL.
        write(2, "error: hipkfd_teardown auto-inject fixups recorded but symbol not defined\n", 75)
        exit(1)
    }
    uint64 i = 0
    while i < teardown_fixup_count {
        uint64 entry = teardown_fixup_table + i * 8
        uint32 patch_off = 0
        unsafe { *(entry as uint32) -> patch_off }
        uint64 wpo = patch_off
        uint64 disp = target_off - wpo - 4
        patch_u32(wpo, disp)
        i = i + 1
    }
}

// Register an extern function. Returns its extern index for later use.
@export
fn extern_fn_register(uint64 name_tok) -> uint64 {
    if extern_fn_count >= 256 {
        write(2, "error: extern_fn_table overflow (max 256)\n", 42)
        exit(1)
    }
    uint64 idx = extern_fn_count
    uint64 entry = extern_fn_table + extern_fn_count * 8
    uint32 nt = name_tok
    unsafe { *(entry as uint32) = nt }
    extern_fn_count = extern_fn_count + 1
    return idx
}

// Return the extern index for a given name_tok, or 0xFFFFFFFF if not extern.
@export
fn extern_fn_lookup(uint64 name_tok) -> uint64 {
    uint64 i = 0
    while i < extern_fn_count {
        uint64 entry = extern_fn_table + i * 8
        uint32 stored_tok = 0
        unsafe { *(entry as uint32) -> stored_tok }
        uint64 ws = stored_tok
        if tok_text_eq(ws, name_tok) != 0 { return i }
        i = i + 1
    }
    return 0xFFFFFFFF
}

// Record an extern call site for later relocation emission.
// code_off is the byte offset inside the .text section:
//   x86_64: the start of the 4-byte disp32 (call site + 1)
//   ARM64:  the start of the BL instruction
fn extern_call_record(uint64 code_off, uint64 extern_idx) {
    if extern_call_count >= 1024 {
        write(2, "error: extern_call_sites overflow (max 1024)\n", 45)
        exit(1)
    }
    uint64 entry = extern_call_sites + extern_call_count * 16
    uint32 co = code_off
    unsafe { *(entry as uint32) = co }
    uint64 e4 = entry + 4
    uint32 xi = extern_idx
    unsafe { *(e4 as uint32) = xi }
    extern_call_count = extern_call_count + 1
}

// ---------------------------------------------------------------------------
// x86_64 code emission
// ---------------------------------------------------------------------------

// emit: mov rax, imm64
fn emit_mov_rax_imm(uint64 val) {
    rax_invalidate()
    if val == 0 {
        // xor eax, eax (2 bytes, zero-extends to rax)
        emit_byte(0x31)
        emit_byte(0xC0)
        return
    }
    if val <= 0x7FFFFFFF {
        // mov eax, imm32 (5 bytes, zero-extends)
        emit_byte(0xB8)
        emit_u32_le(val)
    } else {
        // movabs rax, imm64 (10 bytes)
        emit_byte(0x48)
        emit_byte(0xB8)
        emit_u64_le(val)
    }
}

// emit: mov [rsp+off], rax
// Register cache: tracks if rax already holds a stack slot value
// rax_cache = 0 means not cached, rax_cache = offset+1 means rax holds [rsp+offset]
static uint64 rax_cache = 0

fn rax_invalidate() {
    rax_cache = 0
}

fn emit_store_rax_to_stack(uint64 offset) {
    emit_byte(0x48)
    emit_byte(0x89)
    if offset == 0 {
        emit_byte(0x04)
        emit_byte(0x24)
    } else if offset < 128 {
        emit_byte(0x44)
        emit_byte(0x24)
        uint8 off8 = offset
        emit_byte(off8)
    } else {
        emit_byte(0x84)
        emit_byte(0x24)
        emit_u32_le(offset)
    }
    // After store, rax still holds the value for this offset
    rax_cache = offset + 1
}

// Store rdx into [rsp+offset]. ModR/M reg field = rdx (2), so the middle
// byte differs from the rax version by 0x10. Used for 2-tuple destructure.
fn emit_store_rdx_to_stack(uint64 offset) {
    emit_byte(0x48)
    emit_byte(0x89)
    if offset == 0 {
        emit_byte(0x14)
        emit_byte(0x24)
    } else if offset < 128 {
        emit_byte(0x54)
        emit_byte(0x24)
        uint8 off8 = offset
        emit_byte(off8)
    } else {
        emit_byte(0x94)
        emit_byte(0x24)
        emit_u32_le(offset)
    }
}

// movsd xmm0, [rsp+offset] — load f64 from stack
fn emit_load_xmm0_f64(uint64 offset) {
    emit_byte(0xF2); emit_byte(0x0F); emit_byte(0x10)
    if offset < 128 {
        emit_byte(0x44); emit_byte(0x24)
        uint8 off8 = offset
        emit_byte(off8)
    } else {
        emit_byte(0x84); emit_byte(0x24)
        emit_u32_le(offset)
    }
}

// movsd [rsp+offset], xmm0 — store f64 to stack
fn emit_store_xmm0_f64(uint64 offset) {
    emit_byte(0xF2); emit_byte(0x0F); emit_byte(0x11)
    if offset < 128 {
        emit_byte(0x44); emit_byte(0x24)
        uint8 off8 = offset
        emit_byte(off8)
    } else {
        emit_byte(0x84); emit_byte(0x24)
        emit_u32_le(offset)
    }
}

// movss xmm0, [rsp+offset] — load f32 from stack
fn emit_load_xmm0_f32(uint64 offset) {
    emit_byte(0xF3); emit_byte(0x0F); emit_byte(0x10)
    if offset < 128 {
        emit_byte(0x44); emit_byte(0x24)
        uint8 off8 = offset
        emit_byte(off8)
    } else {
        emit_byte(0x84); emit_byte(0x24)
        emit_u32_le(offset)
    }
}

// movss [rsp+offset], xmm0 — store f32 to stack
fn emit_store_xmm0_f32(uint64 offset) {
    emit_byte(0xF3); emit_byte(0x0F); emit_byte(0x11)
    if offset < 128 {
        emit_byte(0x44); emit_byte(0x24)
        uint8 off8 = offset
        emit_byte(off8)
    } else {
        emit_byte(0x84); emit_byte(0x24)
        emit_u32_le(offset)
    }
}

// movsd xmm1, [rsp+offset] — load f64 into temp register
fn emit_load_xmm1_f64(uint64 offset) {
    emit_byte(0xF2); emit_byte(0x0F); emit_byte(0x10)
    if offset < 128 {
        emit_byte(0x4C); emit_byte(0x24)
        uint8 off8 = offset
        emit_byte(off8)
    } else {
        emit_byte(0x8C); emit_byte(0x24)
        emit_u32_le(offset)
    }
}

// movss xmm1, [rsp+offset] — load f32 into temp register
fn emit_load_xmm1_f32(uint64 offset) {
    emit_byte(0xF3); emit_byte(0x0F); emit_byte(0x10)
    if offset < 128 {
        emit_byte(0x4C); emit_byte(0x24)
        uint8 off8 = offset
        emit_byte(off8)
    } else {
        emit_byte(0x8C); emit_byte(0x24)
        emit_u32_le(offset)
    }
}

// movsd xmm1, [rsp+offset] — store f64 from temp register
fn emit_store_xmm1_f64(uint64 offset) {
    emit_byte(0xF2); emit_byte(0x0F); emit_byte(0x11)
    if offset < 128 {
        emit_byte(0x4C); emit_byte(0x24)
        uint8 off8 = offset
        emit_byte(off8)
    } else {
        emit_byte(0x8C); emit_byte(0x24)
        emit_u32_le(offset)
    }
}

// movsd xmmN, [rsp+offset] — load f64 into xmmN (N=0..7)
fn emit_load_xmmN_f64(uint64 reg, uint64 offset) {
    emit_byte(0xF2); emit_byte(0x0F); emit_byte(0x10)
    uint8 reg3 = reg << 3
    if offset < 128 {
        uint8 mb = 0x44 | reg3
        emit_byte(mb); emit_byte(0x24)
        uint8 off8 = offset
        emit_byte(off8)
    } else {
        uint8 mb = 0x84 | reg3
        emit_byte(mb); emit_byte(0x24)
        emit_u32_le(offset)
    }
}

// movsd [rsp+offset], xmmN — store f64 from xmmN (N=0..7)
fn emit_store_xmmN_f64(uint64 reg, uint64 offset) {
    emit_byte(0xF2); emit_byte(0x0F); emit_byte(0x11)
    uint8 reg3 = reg << 3
    if offset < 128 {
        uint8 mb = 0x44 | reg3
        emit_byte(mb); emit_byte(0x24)
        uint8 off8 = offset
        emit_byte(off8)
    } else {
        uint8 mb = 0x84 | reg3
        emit_byte(mb); emit_byte(0x24)
        emit_u32_le(offset)
    }
}

// Register a function's float return type
fn fn_ret_float_register(uint64 name_tok, uint64 float_kind) {
    if fn_ret_float_count >= 512 {
        write(2, "error: fn_ret_float_table overflow (max 512)\n", 45)
        exit(1)
    }
    uint64 entry = fn_ret_float_table + fn_ret_float_count * 8
    uint32 nt = name_tok
    unsafe { *(entry as uint32) = nt }
    uint64 e4 = entry + 4
    uint32 fk = float_kind
    unsafe { *(e4 as uint32) = fk }
    fn_ret_float_count = fn_ret_float_count + 1
}

// Look up a function's float return type: 0=int, 1=f64, 2=f32
fn fn_ret_float_lookup(uint64 name_tok) -> uint64 {
    uint64 i = 0
    while i < fn_ret_float_count {
        uint64 entry = fn_ret_float_table + i * 8
        uint32 nt = 0
        unsafe { *(entry as uint32) -> nt }
        uint64 wnt = nt
        if tok_text_eq(wnt, name_tok) != 0 {
            uint64 e4 = entry + 4
            uint32 fk = 0
            unsafe { *(e4 as uint32) -> fk }
            uint64 wfk = fk
            return wfk
        }
        i = i + 1
    }
    return 0
}

// Register a function's struct return type
fn fn_ret_struct_register(uint64 name_tok, uint64 struct_idx) {
    if fn_ret_struct_count >= 512 {
        write(2, "error: fn_ret_struct_table overflow (max 512)\n", 46)
        exit(1)
    }
    uint64 entry = fn_ret_struct_table + fn_ret_struct_count * 8
    uint32 nt = name_tok
    unsafe { *(entry as uint32) = nt }
    uint64 e4 = entry + 4
    uint32 si = struct_idx
    unsafe { *(e4 as uint32) = si }
    fn_ret_struct_count = fn_ret_struct_count + 1
}

// Look up a function's struct return type: 0xFFFFFFFF = not struct, else struct_idx
fn fn_ret_struct_lookup(uint64 name_tok) -> uint64 {
    uint64 i = 0
    while i < fn_ret_struct_count {
        uint64 entry = fn_ret_struct_table + i * 8
        uint32 nt = 0
        unsafe { *(entry as uint32) -> nt }
        uint64 wnt = nt
        if tok_text_eq(wnt, name_tok) != 0 {
            uint64 e4 = entry + 4
            uint32 si = 0
            unsafe { *(e4 as uint32) -> si }
            uint64 wsi = si
            return wsi
        }
        i = i + 1
    }
    return 0xFFFFFFFF
}

// Helper: is this type token a float type?
fn is_float_type(uint64 type_kind) -> uint64 {
    if type_kind == 95 { return 1 }
    if type_kind == 96 { return 1 }
    return 0
}

fn is_f32_type(uint64 type_kind) -> uint64 {
    if type_kind == 95 { return 1 }
    return 0
}

// Helper: get token kind from token index (reads from token array)
fn tok_kind_at_raw(uint64 tok_idx) -> uint64 {
    uint64 p = cg_tokens + tok_idx * 16
    uint32 k = 0
    unsafe { *(p as uint32) -> k }
    uint64 wk = k
    return wk
}

// Walk an AST node to determine if its value should be treated as a
// signed int. Used by the legacy backend to pick setl/setle/setg/setge
// over setb/setbe/seta/setae for ordered compares, idiv over div, and
// SAR over SHR. The IR backend has its own per-vreg signed-flag
// tracking; legacy has to introspect the AST each time.
//
// Recognises: bare Idents declared as int8/16/32/64, recursive BinOps
// where either operand is signed, UnaryOp negate (always signed), and
// the f64_to_int builtin call (cvttsd2si is signed).
fn legacy_node_is_signed(uint64 node) -> uint64 {
    if node == 0 { return 0 }
    uint32 kind_u32 = ast_kind(node)
    uint64 nk = kind_u32
    if nk == 32 {
        // Ident — check declared type
        uint32 tok = ast_data1(node)
        uint64 wtok = tok
        uint64 tk = var_type_lookup(wtok)
        if tk == 84 || tk == 85 || tk == 86 || tk == 87 { return 1 }
        return 0
    }
    if nk == 33 {
        // BinOp — signed if either operand is signed
        uint32 lhs = ast_child(node)
        uint32 rhs = ast_data2(node)
        uint64 wlhs = lhs
        uint64 wrhs = rhs
        if legacy_node_is_signed(wlhs) != 0 { return 1 }
        if legacy_node_is_signed(wrhs) != 0 { return 1 }
        return 0
    }
    if nk == 34 {
        // UnaryOp — `-x` produces a signed result
        uint32 op_tok = ast_data1(node)
        uint64 wop = op_tok
        uint64 op_kind = tok_kind_at_raw(wop)
        if op_kind == 31 { return 1 }   // negate
        uint32 child = ast_child(node)
        uint64 wc = child
        return legacy_node_is_signed(wc)
    }
    if nk == 35 {
        // Call — recognise f64_to_int (cvttsd2si is signed truncation)
        uint32 callee_tok = ast_data1(node)
        uint64 wct = callee_tok
        if tok_matches(wct, "f64_to_int", 10) != 0 { return 1 }
        return 0
    }
    return 0
}

// Parse an x86_64 register name token into a 4-bit register code.
// Returns 0..15 for recognised names, 0xFFFF for unknown.
// Recognised: rax..rdi (0..7), r8..r15 (8..15).
fn x86_reg_code(uint64 name_tok) -> uint64 {
    if tok_matches(name_tok, "rax", 3) != 0 { return 0 }
    if tok_matches(name_tok, "rcx", 3) != 0 { return 1 }
    if tok_matches(name_tok, "rdx", 3) != 0 { return 2 }
    if tok_matches(name_tok, "rbx", 3) != 0 { return 3 }
    if tok_matches(name_tok, "rsp", 3) != 0 { return 4 }
    if tok_matches(name_tok, "rbp", 3) != 0 { return 5 }
    if tok_matches(name_tok, "rsi", 3) != 0 { return 6 }
    if tok_matches(name_tok, "rdi", 3) != 0 { return 7 }
    if tok_matches(name_tok, "r8", 2)  != 0 { return 8 }
    if tok_matches(name_tok, "r9", 2)  != 0 { return 9 }
    if tok_matches(name_tok, "r10", 3) != 0 { return 10 }
    if tok_matches(name_tok, "r11", 3) != 0 { return 11 }
    if tok_matches(name_tok, "r12", 3) != 0 { return 12 }
    if tok_matches(name_tok, "r13", 3) != 0 { return 13 }
    if tok_matches(name_tok, "r14", 3) != 0 { return 14 }
    if tok_matches(name_tok, "r15", 3) != 0 { return 15 }
    return 0xFFFF
}

// Emit `mov dst, src` for any two 64-bit registers (0..15).
// ModR/M: mod=3, reg=src, rm=dst. REX.W always; REX.R if src>=8; REX.B if dst>=8.
fn emit_mov_reg_reg(uint64 dst, uint64 src) {
    uint8 rex = 0x48
    if src >= 8 { rex = rex | 0x04 }   // REX.R
    if dst >= 8 { rex = rex | 0x01 }   // REX.B
    emit_byte(rex)
    emit_byte(0x89)
    uint8 mb = 0xC0 | ((src & 7) << 3) | (dst & 7)
    emit_byte(mb)
}

// Emit `mov reg, [rsp+offset]` for any 64-bit reg (0..15). Used to load
// an asm-block input variable into the register named by the constraint.
// Handles pinned params (rbx/r12) by emitting a reg-reg move instead.
fn emit_mov_reg_from_stack(uint64 reg, uint64 offset) {
    if offset == pin_param0_offset && pin_param0_offset != 0xFFFFFFFF {
        emit_mov_reg_reg(reg, 3)   // mov reg, rbx
        return
    }
    if offset == pin_param1_offset && pin_param1_offset != 0xFFFFFFFF {
        emit_mov_reg_reg(reg, 12)  // mov reg, r12
        return
    }
    uint8 rex = 0x48
    if reg >= 8 { rex = 0x4C }
    emit_byte(rex)
    emit_byte(0x8B)
    uint64 reg3 = (reg & 7) << 3
    if offset < 128 {
        uint8 mb = 0x44 | reg3
        emit_byte(mb)
        emit_byte(0x24)
        uint8 off8 = offset
        emit_byte(off8)
    } else {
        uint8 mb = 0x84 | reg3
        emit_byte(mb)
        emit_byte(0x24)
        emit_u32_le(offset)
    }
}

// Emit `mov [rsp+offset], reg` for any 64-bit reg (0..15). Used to store
// an asm-block output register into the destination variable slot.
fn emit_mov_reg_to_stack(uint64 reg, uint64 offset) {
    uint8 rex = 0x48
    if reg >= 8 { rex = 0x4C }
    emit_byte(rex)
    emit_byte(0x89)
    uint64 reg3 = (reg & 7) << 3
    if offset < 128 {
        uint8 mb = 0x44 | reg3
        emit_byte(mb)
        emit_byte(0x24)
        uint8 off8 = offset
        emit_byte(off8)
    } else {
        uint8 mb = 0x84 | reg3
        emit_byte(mb)
        emit_byte(0x24)
        emit_u32_le(offset)
    }
}

// emit: mov rax, [rsp+off] — skipped if rax already holds this value
fn emit_load_rax_from_stack(uint64 offset) {
    // Pinned param0: use rbx instead of stack
    if offset == pin_param0_offset && pin_param0_offset != 0xFFFFFFFF {
        if rax_cache == offset + 1 { return }
        // mov rax, rbx (48 89 D8)
        emit_byte(0x48); emit_byte(0x89); emit_byte(0xD8)
        rax_cache = offset + 1
        return
    }
    // Check cache: if rax already holds [rsp+offset], skip the load
    if rax_cache == offset + 1 { return }
    emit_byte(0x48)
    emit_byte(0x8B)
    if offset == 0 {
        emit_byte(0x04)
        emit_byte(0x24)
    } else if offset < 128 {
        emit_byte(0x44)
        emit_byte(0x24)
        uint8 off8 = offset
        emit_byte(off8)
    } else {
        emit_byte(0x84)
        emit_byte(0x24)
        emit_u32_le(offset)
    }
    rax_cache = offset + 1
}

// emit: push rax
fn emit_push_rax() {
    rax_invalidate()
    emit_byte(0x50)
}

// emit: pop rcx
fn emit_pop_rcx() {
    emit_byte(0x59)
}

// emit: add rax, rcx
fn emit_add_rax_rcx() {
    rax_invalidate()
    emit_byte(0x48)
    emit_byte(0x01)
    emit_byte(0xC8)
}

// emit: sub rax, rcx  (rax = rax - rcx)
fn emit_sub_rax_rcx() {
    rax_invalidate()
    emit_byte(0x48)
    emit_byte(0x29)
    emit_byte(0xC8)
}

// emit: imul rax, rcx
fn emit_mul_rax_rcx() {
    rax_invalidate()
    emit_byte(0x48)
    emit_byte(0x0F)
    emit_byte(0xAF)
    emit_byte(0xC1)
}

// emit: mov rdi, rax (first arg)
fn emit_mov_rdi_rax() {
    emit_byte(0x48)
    emit_byte(0x89)
    emit_byte(0xC7)
}

// emit: mov rsi, rax (second arg)
fn emit_mov_rsi_rax() {
    emit_byte(0x48)
    emit_byte(0x89)
    emit_byte(0xC6)
}

// emit: mov rdx, rax (third arg)
fn emit_mov_rdx_rax() {
    emit_byte(0x48)
    emit_byte(0x89)
    emit_byte(0xC2)
}

// ---------------------------------------------------------------------------
// Windows x64 ABI helpers
// ---------------------------------------------------------------------------

fn win_fixup_add(uint64 patch_off, uint64 slot) {
    if win_iat_fixup_count >= 4096 {
        write(2, "error: win_iat_fixups overflow (max 4096)\n", 42)
        exit(1)
    }
    uint64 entry = win_iat_fixups + win_iat_fixup_count * 8
    uint32 po = patch_off
    unsafe { *(entry as uint32) = po }
    uint64 e4 = entry + 4
    uint32 sl = slot
    unsafe { *(e4 as uint32) = sl }
    win_iat_fixup_count = win_iat_fixup_count + 1
}

// sub rsp, N for Windows API calls (N must keep RSP 16-byte aligned)
// After prologue (push rbx + sub rsp, frame), RSP is 16-aligned
// So we need N divisible by 16 for alignment
// Use 0x20 (32) for <=4 args, 0x30 (48) for 5 args, 0x40 (64) for 7 args
fn emit_win_alloc_stack(uint64 nbytes) {
    emit_byte(0x48)
    emit_byte(0x83)
    emit_byte(0xEC)
    uint8 nb = nbytes
    emit_byte(nb)
}

fn emit_win_free_stack(uint64 nbytes) {
    emit_byte(0x48)
    emit_byte(0x83)
    emit_byte(0xC4)
    uint8 nb = nbytes
    emit_byte(nb)
}

// mov rcx, rax (Windows 1st arg)
fn emit_mov_rcx_rax() {
    emit_byte(0x48)
    emit_byte(0x89)
    emit_byte(0xC1)
}

// mov r8, rax (Windows 3rd arg)
fn emit_mov_r8_rax() {
    emit_byte(0x49)
    emit_byte(0x89)
    emit_byte(0xC0)
}

// mov r9, imm32 (sign-extended, Windows 4th arg)
fn emit_mov_r9_imm(uint64 val) {
    emit_byte(0x49)
    emit_byte(0xC7)
    emit_byte(0xC1)
    emit_u32_le(val)
}

// call qword [rip + disp32] — IAT indirect call
// All 13 entries are loader-resolved; slot 0-12 maps directly to IAT[0..12]
fn emit_win_call_iat(uint64 slot) {
    rax_invalidate()
    emit_byte(0xFF)
    emit_byte(0x15)
    uint64 patch_off = out_len
    emit_u32_le(0)
    win_fixup_add(patch_off, slot)
}

// mov [rip + disp32], rax — store resolved fn ptr to IAT slot
fn emit_win_store_iat(uint64 slot) {
    emit_byte(0x48)
    emit_byte(0x89)
    emit_byte(0x05)
    uint64 patch_off = out_len
    emit_u32_le(0)
    win_fixup_add(patch_off, slot)
}

// ABI helper: which register holds integer arg N?
// Returns register code: 0=rax, 1=rcx, 2=rdx, 3=rbx, 6=rsi, 7=rdi, 8=r8, 9=r9
// Returns 0xFFFF if the arg goes on the stack.
fn abi_arg_register(uint64 idx, uint64 os) -> uint64 {
    if os == 2 {
        if idx == 0 { return 1 }
        if idx == 1 { return 2 }
        if idx == 2 { return 8 }
        if idx == 3 { return 9 }
        return 0xFFFF
    }
    if idx == 0 { return 7 }
    if idx == 1 { return 6 }
    if idx == 2 { return 2 }
    if idx == 3 { return 1 }
    if idx == 4 { return 8 }
    if idx == 5 { return 9 }
    return 0xFFFF
}

fn abi_reg_count(uint64 os) -> uint64 {
    if os == 2 { return 4 }
    return 6
}

// Stack offset for overflow arg idx, from callee's rsp after prologue.
// frame_adjust = var_frame_size + 8 (push rbx)
fn abi_overflow_offset(uint64 idx, uint64 os, uint64 frame_adjust) -> uint64 {
    if os == 2 {
        return frame_adjust + 8 + 32 + (idx - 4) * 8
    }
    return frame_adjust + 8 + (idx - 6) * 8
}

// Helper: add a null-terminated string to str_buf, return its offset
fn resolver_add_str(uint64 s) -> uint64 {
    uint64 soff = str_len
    uint64 i = 0
    uint64 p = s + i
    uint64 ch = 0
    unsafe { *(p as uint8) -> ch }
    while ch != 0 {
        if str_len >= 65536 {
            write(2, "error: str_buf overflow (max 65536)\n", 36)
            exit(1)
        }
        uint8 cb = ch
        uint64 dp = str_buf + str_len
        unsafe { *(dp as uint8) = cb }
        str_len = str_len + 1
        i = i + 1
        p = s + i
        unsafe { *(p as uint8) -> ch }
    }
    if str_len >= 65536 {
        write(2, "error: str_buf overflow (max 65536)\n", 36)
        exit(1)
    }
    uint64 dp = str_buf + str_len
    uint8 nz = 0
    unsafe { *(dp as uint8) = nz }
    str_len = str_len + 1
    return soff
}

// Helper: emit lea rdx, [rip+disp32] with string fixup
fn emit_lea_rdx_str(uint64 str_offset) {
    if str_fixup_count >= 4096 {
        write(2, "error: str_fixups overflow (max 4096)\n", 38)
        exit(1)
    }
    emit_byte(0x48); emit_byte(0x8D); emit_byte(0x15)
    uint64 fentry = str_fixups + str_fixup_count * 8
    uint32 cp = out_len
    unsafe { *(fentry as uint32) = cp }
    uint64 fe4 = fentry + 4
    uint32 so = str_offset
    unsafe { *(fe4 as uint32) = so }
    str_fixup_count = str_fixup_count + 1
    emit_u32_le(0)
}

// Helper: emit lea rcx, [rip+disp32] with string fixup
fn emit_lea_rcx_str(uint64 str_offset) {
    if str_fixup_count >= 4096 {
        write(2, "error: str_fixups overflow (max 4096)\n", 38)
        exit(1)
    }
    emit_byte(0x48); emit_byte(0x8D); emit_byte(0x0D)
    uint64 fentry = str_fixups + str_fixup_count * 8
    uint32 cp = out_len
    unsafe { *(fentry as uint32) = cp }
    uint64 fe4 = fentry + 4
    uint32 so = str_offset
    unsafe { *(fe4 as uint32) = so }
    str_fixup_count = str_fixup_count + 1
    emit_u32_le(0)
}

// neg rax
fn emit_neg_rax() {
    rax_invalidate()
    emit_byte(0x48)
    emit_byte(0xF7)
    emit_byte(0xD8)
}

// sub rax, imm8
fn emit_sub_rax_imm8(uint64 val) {
    rax_invalidate()
    emit_byte(0x48)
    emit_byte(0x83)
    emit_byte(0xE8)
    uint8 b = val
    emit_byte(b)
}

// mov [rsp+32], imm32 (5th arg on stack for Windows calls)
fn emit_win_stack_arg5(uint64 val) {
    emit_byte(0x48)
    emit_byte(0xC7)
    emit_byte(0x44)
    emit_byte(0x24)
    emit_byte(0x20)
    emit_u32_le(val)
}

// Resolve Windows IAT fixups: patch call [rip+disp32] with correct displacement
// text_start: offset of code within file, iat_rva: RVA of IAT in .idata section
@export
fn resolve_win_iat_fixups(uint64 text_start, uint64 iat_rva) {
    // PE image base = 0x140000000, text section RVA = 0x1000
    // Code at file offset text_start corresponds to RVA 0x1000
    // So code at file offset X has RVA = 0x1000 + (X - text_start)
    // RIP at end of call instruction = RVA of byte after the disp32
    // Target = iat_rva + slot * 8
    // disp32 = target_rva - rip_rva
    uint64 i = 0
    while i < win_iat_fixup_count {
        uint64 entry = win_iat_fixups + i * 8
        uint32 patch_off = 0
        unsafe { *(entry as uint32) -> patch_off }
        uint64 e4 = entry + 4
        uint32 slot = 0
        unsafe { *(e4 as uint32) -> slot }
        uint64 wpatch = patch_off
        uint64 wslot = slot
        // RIP at end of this instruction = RVA of (patch_off + 4)
        uint64 rip_rva = 0x1000 + (wpatch + 4 - text_start)
        uint64 target_rva = iat_rva + wslot * 8
        // disp32 = target_rva - rip_rva (signed 32-bit)
        uint64 disp = target_rva - rip_rva
        patch_u32(wpatch, disp & 0xFFFFFFFF)
        i = i + 1
    }
}

// emit: setCC al + movzx eax, al (flags already set by caller).
// `is_signed` selects setl/setle/setg/setge over the unsigned variants
// for ordered compares; equality/inequality are bitwise so they stay
// on sete/setne regardless.
fn emit_setcc_typed(uint64 op_tok_kind, uint64 is_signed) {
    emit_byte(0x0F)
    if op_tok_kind == 35 { emit_byte(0x94) }
    else if op_tok_kind == 36 { emit_byte(0x95) }
    else if op_tok_kind == 37 {
        if is_signed != 0 { emit_byte(0x9C) } else { emit_byte(0x92) }   // setl / setb
    }
    else if op_tok_kind == 38 {
        if is_signed != 0 { emit_byte(0x9E) } else { emit_byte(0x96) }   // setle / setbe
    }
    else if op_tok_kind == 39 {
        if is_signed != 0 { emit_byte(0x9F) } else { emit_byte(0x97) }   // setg / seta
    }
    else if op_tok_kind == 40 {
        if is_signed != 0 { emit_byte(0x9D) } else { emit_byte(0x93) }   // setge / setae
    }
    else { emit_byte(0x94) }
    emit_byte(0xC0)
    emit_byte(0x0F); emit_byte(0xB6); emit_byte(0xC0) // movzx eax, al
}

// Legacy entry point — kept for callers that don't have AST context
// to detect signedness (e.g., float compares synthesise a setcc on
// already-set ucomi flags). Defaults to unsigned, which is correct
// for those cases since float ucomi sets CF/ZF as unsigned-like
// flags that map onto the existing setb/setae mapping.
fn emit_setcc(uint64 op_tok_kind) { emit_setcc_typed(op_tok_kind, 0) }

// emit: cmp rax, rcx + setCC al + movzx eax, al
fn emit_compare(uint64 op_tok_kind) {
    rax_invalidate()
    // cmp rax, rcx
    emit_byte(0x48)
    emit_byte(0x39)
    emit_byte(0xC8)

    emit_setcc(op_tok_kind)
}

fn emit_compare_typed(uint64 op_tok_kind, uint64 is_signed) {
    rax_invalidate()
    // cmp rax, rcx
    emit_byte(0x48)
    emit_byte(0x39)
    emit_byte(0xC8)
    emit_setcc_typed(op_tok_kind, is_signed)
}


// ---------------------------------------------------------------------------
// AST code generation (recursive)
// ---------------------------------------------------------------------------

// Generate code for an expression. Result is in %rax.
@export
fn gen_expr(uint64 node) {
    // Invalidate rax cache — gen_expr will put a new value in rax
    rax_invalidate()
    expr_is_struct = 0xFFFFFFFF

    // Record line for debug info
    uint32 dbg_tok = ast_tok(node)
    if dbg_tok == 0 { dbg_tok = ast_data1(node) }
    uint64 wdbg = dbg_tok
    if wdbg != 0 { line_table_record(wdbg) }

    uint32 kind = ast_kind(node)

    // Unary operator: !, -, ~
    if kind == 34 {
        uint32 operand_idx = ast_child(node)
        uint64 wop = operand_idx
        gen_expr(wop)
        // Determine op from token kind
        uint32 op_tok = ast_data1(node)
        uint64 wot = op_tok
        uint64 p = cg_tokens + wot * 16
        uint32 op_kind = 0
        unsafe { *(p as uint32) -> op_kind }
        uint64 wok = op_kind
        if wok == 27 {
            // ! logical NOT: test rax, rax; sete al; movzbl al, eax
            emit_byte(0x48); emit_byte(0x85); emit_byte(0xC0)
            emit_byte(0x0F); emit_byte(0x94); emit_byte(0xC0)
            emit_byte(0x0F); emit_byte(0xB6); emit_byte(0xC0)
        } else if wok == 31 {
            // - negate: neg rax
            emit_byte(0x48); emit_byte(0xF7); emit_byte(0xD8)
        } else if wok == 26 {
            // ~ bitwise NOT: not rax
            emit_byte(0x48); emit_byte(0xF7); emit_byte(0xD0)
        }
        return
    }

    // sizeof literal → mov rax, compile-time size
    if kind == 49 {
        uint32 sz_lo = ast_data1(node)
        uint64 val = sz_lo
        emit_mov_rax_imm(val)
        expr_is_float = 0
        return
    }

    // StructLit — struct literal expression
    if kind == 48 {
        uint32 sname_tok = ast_data1(node)
        uint64 wsn = sname_tok
        uint64 si = struct_lookup(wsn)
        uint64 ssize = struct_total_size(si)
        // Allocate temp stack area for struct
        uint64 slit_base = var_count * 8
        uint64 slots_needed = (ssize + 7) / 8
        var_count = var_count + slots_needed
        var_frame_size = var_count * 8
        uint64 srem = var_frame_size & 15
        if srem != 0 { var_frame_size = var_frame_size + 16 - srem }

        // Walk field expressions and store each
        uint32 is_named = ast_data2(node)
        uint64 wnamed = is_named
        uint32 fchild = ast_child(node)
        uint64 wfchild = fchild
        uint64 fidx = 0
        while wfchild != 0 {
            gen_expr(wfchild)
            // rax = field value
            // Determine field offset and size
            uint64 foff = 0
            uint64 fsize = 8
            if wnamed != 0 {
                // Named: field name stored in tok_idx of the child expression
                uint32 fname = ast_tok(wfchild)
                uint64 wfn = fname
                foff = struct_field_offset(si, wfn)
                fsize = struct_field_size(si, wfn)
            } else {
                // Positional: use field index to get offset/size from struct table
                uint64 fbase = struct_table + si * 272 + 16 + fidx * 16
                uint64 foff_addr = fbase + 4
                uint32 fo32 = 0
                unsafe { *(foff_addr as uint32) -> fo32 }
                foff = fo32
                uint64 fs_addr = fbase + 8
                uint32 fs32 = 0
                unsafe { *(fs_addr as uint32) -> fs32 }
                fsize = fs32
            }
            // If expr produced a float, move xmm0 bits into rax
            if expr_is_float == 1 {
                // movq rax, xmm0: 66 48 0F 7E C0
                emit_byte(0x66); emit_byte(0x48); emit_byte(0x0F)
                emit_byte(0x7E); emit_byte(0xC0)
            }
            if expr_is_float == 2 {
                // movd eax, xmm0: 66 0F 7E C0
                emit_byte(0x66); emit_byte(0x0F)
                emit_byte(0x7E); emit_byte(0xC0)
            }
            // Store rax to [rsp + slit_base + foff] with appropriate width
            uint64 dest = slit_base + foff
            if fsize == 8 {
                emit_store_rax_to_stack(dest)
            } else if fsize == 4 {
                // mov [rsp+dest], eax
                if dest < 128 {
                    emit_byte(0x89); emit_byte(0x44); emit_byte(0x24)
                    uint8 d8 = dest; emit_byte(d8)
                } else {
                    emit_byte(0x89); emit_byte(0x84); emit_byte(0x24)
                    emit_u32_le(dest)
                }
            } else if fsize == 2 {
                // mov [rsp+dest], ax
                if dest < 128 {
                    emit_byte(0x66); emit_byte(0x89); emit_byte(0x44)
                    emit_byte(0x24); uint8 d8 = dest; emit_byte(d8)
                } else {
                    emit_byte(0x66); emit_byte(0x89); emit_byte(0x84)
                    emit_byte(0x24); emit_u32_le(dest)
                }
            } else {
                // mov [rsp+dest], al
                if dest < 128 {
                    emit_byte(0x88); emit_byte(0x44); emit_byte(0x24)
                    uint8 d8 = dest; emit_byte(d8)
                } else {
                    emit_byte(0x88); emit_byte(0x84); emit_byte(0x24)
                    emit_u32_le(dest)
                }
            }
            fidx = fidx + 1
            uint32 fnxt = ast_next(wfchild)
            wfchild = fnxt
        }
        // Result: lea rax, [rsp + slit_base]
        if slit_base < 128 {
            emit_byte(0x48); emit_byte(0x8D); emit_byte(0x44)
            emit_byte(0x24); uint8 sb8 = slit_base; emit_byte(sb8)
        } else {
            emit_byte(0x48); emit_byte(0x8D); emit_byte(0x84)
            emit_byte(0x24); emit_u32_le(slit_base)
        }
        expr_is_struct = si
        expr_is_float = 0
        return
    }

    // Integer literal → mov rax, value
    if kind == 30 {
        uint32 tok = ast_data1(node)
        uint64 val = parse_int_token(tok)
        emit_mov_rax_imm(val)
        expr_is_float = 0
        return
    }

    // Float literal
    if kind == 46 {
        uint32 lit_tok_f = ast_data1(node)
        uint64 tstart_f = tok_text_start(lit_tok_f)
        uint64 tlen_f = tok_text_len(lit_tok_f)

        // Parse integer part (digits before '.') and fractional part (after '.')
        uint64 int_val = 0
        uint64 frac_val = 0
        uint64 frac_divisor = 1
        uint64 past_dot = 0
        uint64 fi = 0
        while fi < tlen_f {
            uint64 cp_f = cg_source + tstart_f + fi
            uint64 ch_f = 0
            unsafe { *(cp_f as uint8) -> ch_f }
            if ch_f == 46 { past_dot = 1; fi = fi + 1; continue }
            if ch_f == 102 { fi = fi + 1; continue }
            if ch_f >= 48 && ch_f <= 57 {
                if past_dot == 0 {
                    int_val = int_val * 10 + (ch_f - 48)
                } else {
                    frac_val = frac_val * 10 + (ch_f - 48)
                    frac_divisor = frac_divisor * 10
                }
            }
            fi = fi + 1
        }

        if frac_val == 0 {
            // No fractional part (e.g., 3.0) — just convert integer
            emit_mov_rax_imm(int_val)
            // cvtsi2sd xmm0, rax: F2 48 0F 2A C0
            emit_byte(0xF2); emit_byte(0x48); emit_byte(0x0F); emit_byte(0x2A); emit_byte(0xC0)
        } else {
            // Full float: int_part + frac_part / 10^digits
            // Step 1: xmm0 = int_to_f64(int_val), save to temp_slot_0
            emit_mov_rax_imm(int_val)
            emit_byte(0xF2); emit_byte(0x48); emit_byte(0x0F); emit_byte(0x2A); emit_byte(0xC0)
            emit_store_xmm0_f64(temp_slot_0)

            // Step 2: xmm0 = int_to_f64(frac_val)
            emit_mov_rax_imm(frac_val)
            emit_byte(0xF2); emit_byte(0x48); emit_byte(0x0F); emit_byte(0x2A); emit_byte(0xC0)

            // Step 3: xmm1 = int_to_f64(frac_divisor)
            emit_store_xmm0_f64(temp_slot_1)
            emit_mov_rax_imm(frac_divisor)
            emit_byte(0xF2); emit_byte(0x48); emit_byte(0x0F); emit_byte(0x2A); emit_byte(0xC0)
            // movsd xmm1, xmm0: F2 0F 10 C8
            emit_byte(0xF2); emit_byte(0x0F); emit_byte(0x10); emit_byte(0xC8)
            emit_load_xmm0_f64(temp_slot_1)

            // Step 4: xmm0 = frac_val / frac_divisor
            // divsd xmm0, xmm1: F2 0F 5E C1
            emit_byte(0xF2); emit_byte(0x0F); emit_byte(0x5E); emit_byte(0xC1)

            // Step 5: xmm0 += int_part (from temp_slot_0)
            emit_load_xmm1_f64(temp_slot_0)
            // addsd xmm0, xmm1: F2 0F 58 C1
            emit_byte(0xF2); emit_byte(0x0F); emit_byte(0x58); emit_byte(0xC1)
        }

        // Check for 'f' suffix → f32
        uint64 last_p = cg_source + tstart_f + tlen_f - 1
        uint64 last_c = 0
        unsafe { *(last_p as uint8) -> last_c }
        if last_c == 102 {
            // cvtsd2ss xmm0, xmm0: F2 0F 5A C0 (narrow f64 → f32)
            emit_byte(0xF2); emit_byte(0x0F); emit_byte(0x5A); emit_byte(0xC0)
            expr_is_float = 2
        } else {
            expr_is_float = 1
        }
        return
    }

    // String literal → store bytes in str_buf, emit LEA rip-relative
    if kind == 31 {
        uint32 tok = ast_data1(node)
        uint64 wtok = tok
        uint64 tstart = tok_text_start(wtok)
        uint64 tlen = tok_text_len(wtok)
        // Check str_buf capacity before copying
        if str_len + tlen >= 65536 {
            write(2, "error: str_buf overflow (max 65536)\n", 36)
            exit(1)
        }
        // String data offset in str_buf
        uint64 str_offset = str_len
        // Copy string bytes (skip opening quote, process escapes, skip closing quote)
        uint64 si = 1
        while si < tlen - 1 {
            uint64 ch = tok_source_byte(wtok, si)
            if ch == 92 {
                si = si + 1
                uint64 esc = tok_source_byte(wtok, si)
                if esc == 120 && si + 2 < tlen {
                    // \xHH — consume two hex digits
                    ch = hex_digit_pair_to_byte(tok_source_byte(wtok, si + 1),
                                                tok_source_byte(wtok, si + 2))
                    si = si + 2
                } else {
                    uint64 mapped = escape_char_to_byte(esc)
                    if mapped != 0xFFFFFFFFFFFFFFFF { ch = mapped }
                    else { ch = esc }
                }
            }
            uint64 sp = str_buf + str_len
            uint8 cb = ch
            unsafe { *(sp as uint8) = cb }
            str_len = str_len + 1
            si = si + 1
        }
        // Null-terminate
        uint64 sp = str_buf + str_len
        uint8 zero = 0
        unsafe { *(sp as uint8) = zero }
        str_len = str_len + 1
        // Emit: lea disp32(%rip), %rax → 48 8D 05 [disp32]
        if str_fixup_count >= 4096 {
            write(2, "error: str_fixups overflow (max 4096)\n", 38)
            exit(1)
        }
        emit_byte(0x48)
        emit_byte(0x8D)
        emit_byte(0x05)
        // Record fixup
        uint64 fentry = str_fixups + str_fixup_count * 8
        uint32 cp = out_len
        unsafe { *(fentry as uint32) = cp }
        uint64 fe4 = fentry + 4
        uint32 so = str_offset
        unsafe { *(fe4 as uint32) = so }
        str_fixup_count = str_fixup_count + 1
        emit_u32_le(0)
        return
    }

    // FString (50) — legacy x86: build interpolated string
    // Concatenates StrPart content (baked to str_buf at compile time) and
    // formats expression values into a stack buffer at var_frame_size.
    // Returns rax = pointer to null-terminated result buffer.
    if kind == 50 {
        uint64 fs_buf_off = var_frame_size  // scratch area above frame
        // zero the running offset: temp_slot_1 = 0
        emit_byte(0x48); emit_byte(0x31); emit_byte(0xC0)  // xor rax, rax
        emit_store_rax_to_stack(temp_slot_1)

        uint32 fs_child = ast_child(node)
        uint64 wfs_child = fs_child
        while wfs_child != 0 {
            uint32 fs_ck = ast_kind(wfs_child)
            if fs_ck == 31 {
                uint32 fs_raw = ast_data2(wfs_child)
                uint64 wfs_raw = fs_raw
                if wfs_raw != 0 {
                    // Raw StrPart: bake into str_buf, emit lea rsi + rep movsb
                    uint32 fs_tok = ast_data1(wfs_child)
                    uint64 wfs_tok = fs_tok
                    uint64 fs_tlen = tok_text_len(wfs_tok)
                    if fs_tlen != 0 {
                        if str_len + fs_tlen >= 65536 {
                            write(2, "error: str_buf overflow\n", 24)
                            exit(1)
                        }
                        uint64 fs_soff = str_len
                        uint64 fs_si = 0
                        while fs_si < fs_tlen {
                            uint64 fs_ch = tok_source_byte(wfs_tok, fs_si)
                            uint64 fs_sp = str_buf + str_len
                            uint8 fs_cb = fs_ch
                            unsafe { *(fs_sp as uint8) = fs_cb }
                            str_len = str_len + 1
                            fs_si = fs_si + 1
                        }
                        uint64 fs_nsp = str_buf + str_len
                        uint8 fs_nz = 0
                        unsafe { *(fs_nsp as uint8) = fs_nz }
                        str_len = str_len + 1
                        if str_fixup_count >= 4096 {
                            write(2, "error: str_fixups overflow\n", 27)
                            exit(1)
                        }
                        // lea rsi, [rip + fs_soff]  (source)
                        emit_byte(0x48); emit_byte(0x8D); emit_byte(0x35)
                        uint64 fs_fe = str_fixups + str_fixup_count * 8
                        uint32 fs_cp = out_len
                        unsafe { *(fs_fe as uint32) = fs_cp }
                        uint64 fs_fe4 = fs_fe + 4
                        uint32 fs_so = fs_soff
                        unsafe { *(fs_fe4 as uint32) = fs_so }
                        str_fixup_count = str_fixup_count + 1
                        emit_u32_le(0)
                        // r10 = rsi (save src), rcx = strlen
                        emit_byte(0x49); emit_byte(0x89); emit_byte(0xF2)  // mov r10, rsi
                        emit_byte(0x48); emit_byte(0x31); emit_byte(0xC9)  // xor rcx, rcx
                        uint64 fs_sl = out_len
                        emit_byte(0x0F); emit_byte(0xB6); emit_byte(0x06)  // movzbl (%rsi), eax
                        emit_byte(0x84); emit_byte(0xC0)                    // test al, al
                        emit_byte(0x74); emit_byte(0x05)                    // jz +5
                        emit_byte(0x48); emit_byte(0xFF); emit_byte(0xC1)   // inc rcx
                        emit_byte(0x48); emit_byte(0xFF); emit_byte(0xC6)   // inc rsi
                        uint64 fs_slb = fs_sl - out_len - 1
                        uint8 fs_slbb = fs_slb; emit_byte(0xEB); emit_byte(fs_slbb)
                        // rcx=len, r10=src. Compute dest = [rsp+fs_buf_off] + offset
                        emit_byte(0x4C); emit_byte(0x89); emit_byte(0xD6)  // mov rsi, r10 (restore src)
                        // lea rdi, [rsp + fs_buf_off]
                        if fs_buf_off < 128 {
                            emit_byte(0x48); emit_byte(0x8D); emit_byte(0x7C); emit_byte(0x24)
                            uint8 fbo1 = fs_buf_off; emit_byte(fbo1)
                        } else {
                            emit_byte(0x48); emit_byte(0x8D); emit_byte(0xBC); emit_byte(0x24)
                            emit_u32_le(fs_buf_off)
                        }
                        // rax = offset from temp_slot_1
                        emit_byte(0x48); emit_byte(0x8B)
                        if temp_slot_1 < 128 {
                            emit_byte(0x44); emit_byte(0x24); uint8 ts1a = temp_slot_1; emit_byte(ts1a)
                        } else {
                            emit_byte(0x84); emit_byte(0x24); emit_u32_le(temp_slot_1)
                        }
                        emit_byte(0x48); emit_byte(0x01); emit_byte(0xC7)  // add rdi, rax
                        // rep movsb (rcx=len, rsi=src, rdi=dest)
                        emit_byte(0xF3); emit_byte(0xA4)
                        // update offset: load temp_slot_1, add rcx (save in r10), store
                        emit_byte(0x49); emit_byte(0x89); emit_byte(0xCA)  // mov r10, rcx
                        emit_byte(0x48); emit_byte(0x8B)
                        if temp_slot_1 < 128 {
                            emit_byte(0x44); emit_byte(0x24); uint8 ts1b = temp_slot_1; emit_byte(ts1b)
                        } else {
                            emit_byte(0x84); emit_byte(0x24); emit_u32_le(temp_slot_1)
                        }
                        emit_byte(0x4C); emit_byte(0x01); emit_byte(0xD0)  // add rax, r10
                        emit_store_rax_to_stack(temp_slot_1)
                    }
                } else {
                    // Regular StrLit: gen_expr -> rax=str ptr
                    gen_expr(wfs_child)
                    emit_byte(0x48); emit_byte(0x89); emit_byte(0xC6)  // mov rsi, rax
                    emit_byte(0x49); emit_byte(0x89); emit_byte(0xF2)  // mov r10, rsi
                    emit_byte(0x48); emit_byte(0x31); emit_byte(0xC9)  // xor rcx, rcx
                    uint64 fs_sl2 = out_len
                    emit_byte(0x0F); emit_byte(0xB6); emit_byte(0x06)
                    emit_byte(0x84); emit_byte(0xC0)
                    emit_byte(0x74); emit_byte(0x05)
                    emit_byte(0x48); emit_byte(0xFF); emit_byte(0xC1)
                    emit_byte(0x48); emit_byte(0xFF); emit_byte(0xC6)
                    uint64 fs_slb2 = fs_sl2 - out_len - 1
                    uint8 fs_slbb2 = fs_slb2; emit_byte(0xEB); emit_byte(fs_slbb2)
                    emit_byte(0x4C); emit_byte(0x89); emit_byte(0xD6)  // mov rsi, r10
                    if fs_buf_off < 128 {
                        emit_byte(0x48); emit_byte(0x8D); emit_byte(0x7C); emit_byte(0x24)
                        uint8 fbo2 = fs_buf_off; emit_byte(fbo2)
                    } else {
                        emit_byte(0x48); emit_byte(0x8D); emit_byte(0xBC); emit_byte(0x24)
                        emit_u32_le(fs_buf_off)
                    }
                    emit_byte(0x48); emit_byte(0x8B)
                    if temp_slot_1 < 128 {
                        emit_byte(0x44); emit_byte(0x24); uint8 ts1c = temp_slot_1; emit_byte(ts1c)
                    } else {
                        emit_byte(0x84); emit_byte(0x24); emit_u32_le(temp_slot_1)
                    }
                    emit_byte(0x48); emit_byte(0x01); emit_byte(0xC7)  // add rdi, rax
                    emit_byte(0xF3); emit_byte(0xA4)                   // rep movsb
                    emit_byte(0x49); emit_byte(0x89); emit_byte(0xCA)  // mov r10, rcx
                    emit_byte(0x48); emit_byte(0x8B)
                    if temp_slot_1 < 128 {
                        emit_byte(0x44); emit_byte(0x24); uint8 ts1d = temp_slot_1; emit_byte(ts1d)
                    } else {
                        emit_byte(0x84); emit_byte(0x24); emit_u32_le(temp_slot_1)
                    }
                    emit_byte(0x4C); emit_byte(0x01); emit_byte(0xD0)  // add rax, r10
                    emit_store_rax_to_stack(temp_slot_1)
                }
            } else {
                // Expression: evaluate and format as decimal integer
                gen_expr(wfs_child)
                emit_store_rax_to_stack(temp_slot_0)
                // dest rdi = [rsp+fs_buf_off] + offset
                if fs_buf_off < 128 {
                    emit_byte(0x48); emit_byte(0x8D); emit_byte(0x7C); emit_byte(0x24)
                    uint8 fbo3 = fs_buf_off; emit_byte(fbo3)
                } else {
                    emit_byte(0x48); emit_byte(0x8D); emit_byte(0xBC); emit_byte(0x24)
                    emit_u32_le(fs_buf_off)
                }
                emit_byte(0x48); emit_byte(0x8B)
                if temp_slot_1 < 128 {
                    emit_byte(0x4C); emit_byte(0x24); uint8 ts1e = temp_slot_1; emit_byte(ts1e)
                } else {
                    emit_byte(0x8C); emit_byte(0x24); emit_u32_le(temp_slot_1)
                }
                emit_byte(0x48); emit_byte(0x01); emit_byte(0xCF)  // add rdi, rcx
                // rdi = dest. Load value.
                emit_load_rax_from_stack(temp_slot_0)
                // zero check
                emit_byte(0x48); emit_byte(0x85); emit_byte(0xC0)
                emit_byte(0x0F); emit_byte(0x85)
                uint64 fs_jnz = out_len; emit_u32_le(0)
                // zero: write '0', len=1
                emit_byte(0xC6); emit_byte(0x07); emit_byte(0x30)
                emit_byte(0x49); emit_byte(0xC7); emit_byte(0xC2); emit_u32_le(1)
                emit_byte(0xE9)
                uint64 fs_jfin = out_len; emit_u32_le(0)
                uint64 fs_jnz_t = out_len - fs_jnz - 4
                uint32 fs_jnz_t32 = fs_jnz_t
                unsafe { *((out_buf + fs_jnz) as uint32) = fs_jnz_t32 }
                // nonzero: push digits, then pop to dest
                emit_byte(0x49); emit_byte(0x89); emit_byte(0xFB)   // r11 = rdi (dest start)
                emit_byte(0x4D); emit_byte(0x31); emit_byte(0xD2)   // xor r10, r10 (count)
                uint64 fs_dl = out_len
                emit_byte(0x48); emit_byte(0x85); emit_byte(0xC0)   // test rax, rax
                emit_byte(0x74); emit_byte(0x0E)                     // jz dl_done
                emit_byte(0x48); emit_byte(0x31); emit_byte(0xD2)   // xor rdx, rdx
                emit_byte(0x48); emit_byte(0xB9); emit_u32_le(10); emit_u32_le(0) // mov rcx, 10
                emit_byte(0x48); emit_byte(0xF7); emit_byte(0xF1)   // div rcx
                emit_byte(0x48); emit_byte(0x83); emit_byte(0xC2); emit_byte(0x30) // add rdx, '0'
                emit_byte(0x52)                                       // push rdx
                emit_byte(0x49); emit_byte(0xFF); emit_byte(0xC2)   // inc r10
                uint64 fs_dlb = fs_dl - out_len - 1
                uint8 fs_dlbb = fs_dlb; emit_byte(0xEB); emit_byte(fs_dlbb)
                // pop digits to rdi in correct order
                uint64 fs_pop = out_len
                emit_byte(0x4D); emit_byte(0x85); emit_byte(0xD2)   // test r10, r10
                emit_byte(0x74); emit_byte(0x07)                     // jz pop_done
                emit_byte(0x59)                                       // pop rcx
                emit_byte(0x88); emit_byte(0x0F)                     // mov [rdi], cl
                emit_byte(0x48); emit_byte(0xFF); emit_byte(0xC7)   // inc rdi
                emit_byte(0x49); emit_byte(0xFF); emit_byte(0xCA)   // dec r10
                uint64 fs_popb = fs_pop - out_len - 1
                uint8 fs_popbb = fs_popb; emit_byte(0xEB); emit_byte(fs_popbb)
                // r10=0 now. len = rdi - r11
                emit_byte(0x4C); emit_byte(0x29); emit_byte(0xDF)   // sub rdi, r11
                emit_byte(0x49); emit_byte(0x89); emit_byte(0xFA)   // r10 = rdi (len)
                uint64 fs_jfin_t = out_len - fs_jfin - 4
                uint32 fs_jfin_t32 = fs_jfin_t
                unsafe { *((out_buf + fs_jfin) as uint32) = fs_jfin_t32 }
                // update offset
                emit_byte(0x48); emit_byte(0x8B)
                if temp_slot_1 < 128 {
                    emit_byte(0x44); emit_byte(0x24); uint8 ts1f = temp_slot_1; emit_byte(ts1f)
                } else {
                    emit_byte(0x84); emit_byte(0x24); emit_u32_le(temp_slot_1)
                }
                emit_byte(0x4C); emit_byte(0x01); emit_byte(0xD0)  // add rax, r10
                emit_store_rax_to_stack(temp_slot_1)
            }
            uint32 fs_nxt = ast_next(wfs_child)
            wfs_child = fs_nxt
        }

        // Null-terminate: buf[offset] = 0
        if fs_buf_off < 128 {
            emit_byte(0x48); emit_byte(0x8D); emit_byte(0x44); emit_byte(0x24)
            uint8 fbo4 = fs_buf_off; emit_byte(fbo4)
        } else {
            emit_byte(0x48); emit_byte(0x8D); emit_byte(0x84); emit_byte(0x24)
            emit_u32_le(fs_buf_off)
        }
        emit_byte(0x48); emit_byte(0x8B)
        if temp_slot_1 < 128 {
            emit_byte(0x4C); emit_byte(0x24); uint8 ts1z = temp_slot_1; emit_byte(ts1z)
        } else {
            emit_byte(0x8C); emit_byte(0x24); emit_u32_le(temp_slot_1)
        }
        emit_byte(0x48); emit_byte(0x01); emit_byte(0xC8)   // add rax, rcx
        emit_byte(0xC6); emit_byte(0x00); emit_byte(0x00)   // mov byte[rax], 0
        // Return pointer to buffer start
        if fs_buf_off < 128 {
            emit_byte(0x48); emit_byte(0x8D); emit_byte(0x44); emit_byte(0x24)
            uint8 fbo5 = fs_buf_off; emit_byte(fbo5)
        } else {
            emit_byte(0x48); emit_byte(0x8D); emit_byte(0x84); emit_byte(0x24)
            emit_u32_le(fs_buf_off)
        }
        rax_invalidate()
        return
    }

    // Array indexing: arr[i] → load elem_size bytes from base + i*elem_size
    if kind == 37 {
        uint32 arr_tok = ast_data1(node)
        uint64 warrt = arr_tok
        uint64 arr_offset = var_lookup(arr_tok)
        uint64 elem_sz = arr_elem_lookup(arr_tok)
        // Evaluate index expression
        uint32 idx_child = ast_child(node)
        uint64 wi = idx_child
        gen_expr(wi)
        // Bounds check under --debug for arrays with a known compile-time
        // length. We treat the index as unsigned — negative-looking values
        // (from signed math) become huge positives and fail the check.
        if debug_mode != 0 {
            uint64 bc_count = arr_count_lookup(warrt)
            if bc_count != 0xFFFFFFFF {
                // cmp rax, imm32 — tolerate counts up to 2^31-1
                emit_byte(0x48); emit_byte(0x3D)
                emit_u32_le(bc_count)
                // jb rel8 — in-range, skip the trap
                emit_byte(0x72)
                uint64 bc_jb = out_len
                emit_byte(0)
                // trap: exit(1)
                emit_mov_rax_imm(1)
                emit_mov_rdi_rax()
                if target_os == 2 { emit_mov_rcx_rax(); emit_win_alloc_stack(0x20); emit_win_call_iat(0) }
                else if target_os == 1 { emit_mov_rax_imm(0x2000001); emit_byte(0x0F); emit_byte(0x05) }
                else { emit_mov_rax_imm(231); emit_byte(0x0F); emit_byte(0x05) }
                uint64 bc_skip = out_len - bc_jb - 1
                uint8 bc_s = bc_skip
                uint64 bc_pp = out_buf + bc_jb
                unsafe { *(bc_pp as uint8) = bc_s }
            }
        }
        // mov rcx, rax (save index)
        emit_byte(0x48); emit_byte(0x89); emit_byte(0xC1)
        if arr_offset != 0xFFFFFFFF {
            emit_load_rax_from_stack(arr_offset)
        } else {
            uint64 sas = static_array_size_of(warrt)
            if sas != 0xFFFFFFFF && sas != 0 {
                uint64 soff_a = static_lookup(warrt)
                emit_static_lea(soff_a)
            } else {
                arr_offset = 0
                emit_load_rax_from_stack(arr_offset)
            }
        }
        // rax = base, rcx = index. Load with scaled SIB addressing.
        // SIB byte = (log2(scale) << 6) | (1 << 3) | 0  where index=rcx, base=rax
        //   scale 1 → 0x08, scale 2 → 0x48, scale 4 → 0x88, scale 8 → 0xC8
        uint8 sib = 0x08
        if elem_sz == 2 { sib = 0x48 }
        if elem_sz == 4 { sib = 0x88 }
        if elem_sz == 8 { sib = 0xC8 }
        if elem_sz == 1 {
            // movzbl (%rax,%rcx,1), %eax
            emit_byte(0x0F); emit_byte(0xB6); emit_byte(0x04); emit_byte(sib)
        } else if elem_sz == 2 {
            // movzwl (%rax,%rcx,2), %eax
            emit_byte(0x0F); emit_byte(0xB7); emit_byte(0x04); emit_byte(sib)
        } else if elem_sz == 4 {
            // movl (%rax,%rcx,4), %eax  (zero-extends to rax)
            emit_byte(0x8B); emit_byte(0x04); emit_byte(sib)
        } else {
            // movq (%rax,%rcx,8), %rax
            emit_byte(0x48); emit_byte(0x8B); emit_byte(0x04); emit_byte(sib)
        }
        return
    }

    // Field access: EnumName.Field (enum constant) or var.field (struct field read)
    // Also: arr[i].field for struct arrays.
    if kind == 36 {
        uint32 child_idx = ast_child(node)
        uint64 wchild = child_idx
        uint32 field_tok = ast_data2(node)
        // Struct array element field read: child is an Index node
        if wchild != 0 {
            uint32 cfk = ast_kind(wchild)
            uint64 wcfk = cfk
            if wcfk == 37 {
                uint32 ai_tok = ast_data1(wchild)
                uint64 wait = ai_tok
                uint64 sia = struct_var_lookup(ai_tok)
                if sia != 0xFFFFFFFF {
                    // Compute struct stride and field offset
                    uint64 stride = struct_total_size(sia)
                    uint64 foff_i = struct_field_offset(sia, field_tok)
                    uint64 fsz_i = struct_field_size(sia, field_tok)
                    // Evaluate index into rax
                    uint32 idx_ch = ast_child(wchild)
                    uint64 widx = idx_ch
                    gen_expr(widx)
                    // rax = index. Multiply by stride: mov rcx, stride; mul rcx → rax*rcx
                    emit_mov_rcx_rax()
                    // Load stride imm into rax
                    emit_mov_rax_imm(stride)
                    // imul rax, rcx (48 0F AF C1)
                    emit_byte(0x48); emit_byte(0x0F); emit_byte(0xAF); emit_byte(0xC1)
                    // Save offset-into-array to rcx
                    emit_mov_rcx_rax()
                    // Load base address of the array
                    uint64 aoff = var_lookup(wait)
                    if aoff != 0xFFFFFFFF {
                        emit_load_rax_from_stack(aoff)
                    }
                    // rax = base, rcx = i*stride. addr = base + rcx + foff_i
                    emit_byte(0x48); emit_byte(0x01); emit_byte(0xC8) // add rax, rcx
                    if foff_i != 0 {
                        emit_byte(0x48); emit_byte(0x05)
                        emit_u32_le(foff_i)
                    }
                    // Load field value based on size
                    if fsz_i == 1 {
                        emit_byte(0x0F); emit_byte(0xB6); emit_byte(0x00)
                    } else if fsz_i == 2 {
                        emit_byte(0x0F); emit_byte(0xB7); emit_byte(0x00)
                    } else if fsz_i == 4 {
                        emit_byte(0x8B); emit_byte(0x00)
                    } else {
                        emit_byte(0x48); emit_byte(0x8B); emit_byte(0x00)
                    }
                    return
                }
            }
        }
        // Nested struct field read: child is another FieldAccess
        if wchild != 0 {
            uint32 cfk2 = ast_kind(wchild)
            uint64 wcfk2 = cfk2
            if wcfk2 == 36 {
                // Evaluate inner field chain — produces pointer in rax, sets expr_is_struct
                gen_expr(wchild)
                uint64 nsi = expr_is_struct
                if nsi != 0xFFFFFFFF {
                    uint64 nfoff = struct_field_offset(nsi, field_tok)
                    uint64 nfsz = struct_field_size(nsi, field_tok)
                    if nfoff != 0 {
                        emit_byte(0x48); emit_byte(0x05)
                        emit_u32_le(nfoff)
                    }
                    uint64 nftk = struct_field_type_kind_by_tok(nsi, field_tok)
                    if nftk >= 256 {
                        expr_is_struct = nftk - 256
                        return
                    }
                    expr_is_struct = 0xFFFFFFFF
                    if nftk == 96 {
                        emit_byte(0xF2); emit_byte(0x0F); emit_byte(0x10); emit_byte(0x00)
                        expr_is_float = 1
                        return
                    }
                    if nftk == 95 {
                        emit_byte(0xF3); emit_byte(0x0F); emit_byte(0x10); emit_byte(0x00)
                        expr_is_float = 2
                        return
                    }
                    if nfsz == 1 {
                        emit_byte(0x0F); emit_byte(0xB6); emit_byte(0x00)
                    } else if nfsz == 4 {
                        emit_byte(0x8B); emit_byte(0x00)
                    } else {
                        emit_byte(0x48); emit_byte(0x8B); emit_byte(0x00)
                    }
                    return
                }
            }
        }
        // Extract object token from child Ident node
        uint32 obj_tok = 0
        if wchild != 0 {
            uint32 child_kind = ast_kind(wchild)
            uint64 wck = child_kind
            if wck == 32 {
                obj_tok = ast_data1(wchild)
            }
        }
        // Slice length access: slice_var.len → load from the slice's length slot
        if obj_tok != 0 {
            uint64 wot_sl = obj_tok
            uint64 ptr_off_sl = var_lookup(wot_sl)
            if ptr_off_sl != 0xFFFFFFFF {
                uint64 len_off_sl = slice_len_lookup(ptr_off_sl)
                if len_off_sl != 0xFFFFFFFF {
                    // Confirm the field name is "len"
                    uint64 wft_sl = field_tok
                    if tok_matches(wft_sl, "len", 3) != 0 {
                        emit_load_rax_from_stack(len_off_sl)
                        return
                    }
                }
            }
        }
        // Device field read: UART0.Data → vloadN(base + offset)
        if obj_tok != 0 {
            uint64 wdt = obj_tok
            uint64 dev_idx = device_lookup(wdt)
            if dev_idx != 0xFFFFFFFF {
                uint64 wft_d = field_tok
                uint64 dev_off = device_field_offset_of(dev_idx, wft_d)
                if dev_off != 0xFFFFFFFF {
                    uint64 dev_sz = device_field_size_of(dev_idx, wft_d)
                    uint64 dev_addr = device_base(dev_idx) + dev_off
                    // rax = address
                    emit_mov_rax_imm(dev_addr)
                    // volatile load width-aware + mfence
                    if dev_sz == 1 {
                        emit_byte(0x48); emit_byte(0x0F); emit_byte(0xB6); emit_byte(0x00)
                    } else if dev_sz == 2 {
                        emit_byte(0x48); emit_byte(0x0F); emit_byte(0xB7); emit_byte(0x00)
                    } else if dev_sz == 4 {
                        emit_byte(0x8B); emit_byte(0x00)
                    } else {
                        emit_byte(0x48); emit_byte(0x8B); emit_byte(0x00)
                    }
                    // mfence (barrier after load)
                    emit_byte(0x0F); emit_byte(0xAE); emit_byte(0xF0)
                    rax_cache = 0
                    return
                }
            }
        }
        // Check if obj_tok is a struct variable
        uint64 si = struct_var_lookup(obj_tok)
        if si != 0xFFFFFFFF {
            // Struct field read: load base + field_offset
            uint64 var_off = var_lookup(obj_tok)
            if var_off == 0xFFFFFFFF { var_off = 0 }
            uint64 foff = struct_field_offset(si, field_tok)
            uint64 fsz = struct_field_size(si, field_tok)
            // Load struct base address
            emit_load_rax_from_stack(var_off)
            // Add field offset
            if foff != 0 {
                emit_byte(0x48); emit_byte(0x05)
                emit_u32_le(foff)
            }
            // Check if field is a float type or nested struct
            uint64 fftk = struct_field_type_kind_by_tok(si, field_tok)
            if fftk >= 256 {
                // Nested struct field: leave address in rax, set expr_is_struct
                expr_is_struct = fftk - 256
                return
            }
            if fftk == 96 {
                // f64 field: movsd xmm0, [rax] — F2 0F 10 00
                emit_byte(0xF2); emit_byte(0x0F); emit_byte(0x10); emit_byte(0x00)
                expr_is_float = 1
                return
            }
            if fftk == 95 {
                // f32 field: movss xmm0, [rax] — F3 0F 10 00
                emit_byte(0xF3); emit_byte(0x0F); emit_byte(0x10); emit_byte(0x00)
                expr_is_float = 2
                return
            }
            // Load field value based on size
            if fsz == 1 {
                emit_byte(0x0F); emit_byte(0xB6); emit_byte(0x00)
            } else if fsz == 4 {
                emit_byte(0x8B); emit_byte(0x00)
            } else {
                emit_byte(0x48); emit_byte(0x8B); emit_byte(0x00)
            }
            return
        }
        // Enum constant
        uint64 val = enum_lookup(obj_tok, field_tok)
        emit_mov_rax_imm(val)
        return
    }

    // Identifier → load from stack variable or static
    if kind == 32 {
        uint32 tok = ast_data1(node)
        uint64 wident_tok = tok
        uint64 offset = var_lookup(tok)
        if offset != 0xFFFFFFFF {
            // Check if this variable is float-typed
            uint64 vtype = var_type_lookup(tok)
            if is_float_type(vtype) != 0 {
                if is_f32_type(vtype) != 0 {
                    emit_load_xmm0_f32(offset)
                    expr_is_float = 2
                } else {
                    emit_load_xmm0_f64(offset)
                    expr_is_float = 1
                }
                return
            }
            emit_load_rax_from_stack(offset)
            expr_is_float = 0
            // Track if this is a struct variable
            uint64 svi = struct_var_lookup(wident_tok)
            if svi != 0xFFFFFFFF {
                expr_is_struct = svi
            }
        } else {
            uint64 soff = static_lookup(tok)
            if soff != 0xFFFFFFFF {
                // Static array: emit LEA (address). Scalar: emit MOV (value).
                uint64 sas_i = static_array_size_of(wident_tok)
                if sas_i != 0xFFFFFFFF && sas_i != 0 {
                    emit_static_lea(soff)
                } else {
                    emit_static_load(soff)
                }
            } else {
                uint64 id_len = tok_text_len(tok)
                if id_len != 0 {
                    write(2, "error: use of undeclared identifier '", 37)
                    write(2, cg_source + tok_text_start(tok), id_len)
                    write(2, "'\n", 2)
                    exit(1)
                }
            }
        }
        return
    }

    // Binary operation: lhs OP rhs
    // Evaluate lhs first into rax, save to a fresh temp slot,
    // then evaluate rhs into rax, move to rcx, restore lhs.
    if kind == 33 {
        // Constant folding: if both operands are IntLit, compute at compile time
        uint32 lhs_idx = ast_child(node)
        uint64 wlhs = lhs_idx
        uint32 rhs_idx_cf = ast_data2(node)
        uint64 wrhs_cf = rhs_idx_cf
        uint32 lhs_kind = ast_kind(wlhs)
        uint32 rhs_kind = ast_kind(wrhs_cf)
        if lhs_kind == 30 && rhs_kind == 30 {
            uint32 l_tok = ast_data1(wlhs)
            uint32 r_tok = ast_data1(wrhs_cf)
            uint64 lv = parse_int_token(l_tok)
            uint64 rv = parse_int_token(r_tok)
            uint32 op_tok_cf = ast_data1(node)
            uint64 wop_cf = op_tok_cf
            uint64 pcf = cg_tokens + wop_cf * 16
            uint32 op_cf = 0
            unsafe { *(pcf as uint32) -> op_cf }
            uint64 result = 0
            if op_cf == 30 { result = lv + rv }
            else if op_cf == 31 { result = lv - rv }
            else if op_cf == 22 { result = lv * rv }
            else if op_cf == 32 { if rv != 0 { result = lv / rv } }
            else if op_cf == 33 { if rv != 0 { result = lv - lv / rv * rv } }
            else if op_cf == 23 { result = lv & rv }
            else if op_cf == 24 { result = lv | rv }
            else if op_cf == 25 { result = lv ^ rv }
            else if op_cf == 43 { result = lv << rv }
            else if op_cf == 44 { result = lv >> rv }
            emit_mov_rax_imm(result)
            return
        }

        uint32 rhs_idx = ast_data2(node)
        uint64 wrhs = rhs_idx
        uint32 rhs_kind_check = ast_kind(wrhs)
        uint64 wrk = rhs_kind_check
        uint32 lhs_kind_check = ast_kind(wlhs)
        uint64 wlk = lhs_kind_check

        // Fast path: pinned_param ± IntLit → lea rax, [rbx ± imm]
        // Eliminates 5 instructions (mov+mov+mov+xchg+op → lea)
        uint64 used_lea = 0
        if wlk == 32 && wrk == 30 && pin_param0_offset != 0xFFFFFFFF {
            uint32 lhs_tok = ast_data1(wlhs)
            uint64 loff = var_lookup(lhs_tok)
            if loff == pin_param0_offset {
                uint32 op_tok_lea = ast_data1(node)
                uint64 opl = cg_tokens + op_tok_lea * 16
                uint32 opk_lea = 0
                unsafe { *(opl as uint32) -> opk_lea }
                if opk_lea == 30 || opk_lea == 31 {
                    // Parse the integer literal. Pick the narrowest LEA
                    // encoding that losslessly represents the signed disp.
                    // The old code unconditionally used disp8 — truncating
                    // and sign-extending a uint64 into an 8-bit field —
                    // so `x + 181` came out as `x + (-75)` and quietly
                    // miscompiled every arithmetic expression with a
                    // literal in [128, 255]. Found by tests/fuzz.
                    uint32 rhs_tok = ast_data1(wrhs)
                    uint64 imm_val = parse_int_token(rhs_tok)
                    uint64 disp = imm_val
                    if opk_lea == 31 { disp = 0 - imm_val }
                    // disp fits in signed int8 if its top 57 bits match
                    // the sign bit (all 0 for [0..127], all 1 for [-128..-1]).
                    uint64 top = disp >> 7
                    uint64 fits_i8 = 0
                    if top == 0 { fits_i8 = 1 }
                    if top == 0x1FFFFFFFFFFFFFF { fits_i8 = 1 }
                    uint64 top32 = disp >> 31
                    uint64 fits_i32 = 0
                    if top32 == 0 { fits_i32 = 1 }
                    if top32 == 0x1FFFFFFFF { fits_i32 = 1 }
                    if fits_i8 != 0 {
                        // lea rax, [rbx + disp8]: 48 8D 43 <disp8>
                        uint8 d8 = disp
                        emit_byte(0x48); emit_byte(0x8D); emit_byte(0x43); emit_byte(d8)
                        rax_cache = 0
                        used_lea = 1
                    } else if fits_i32 != 0 {
                        // lea rax, [rbx + disp32]: 48 8D 83 <disp32>
                        emit_byte(0x48); emit_byte(0x8D); emit_byte(0x83)
                        emit_u32_le(disp & 0xFFFFFFFF)
                        rax_cache = 0
                        used_lea = 1
                    }
                    // imm doesn't fit in int32 — fall through to the
                    // general arithmetic path below, which materialises
                    // the 64-bit constant explicitly.
                }
            }
        }

        // --- Float arithmetic path ---
        // Evaluate LHS, check if float, store to temp, evaluate RHS,
        // then emit SSE ops if both sides are float.
        uint64 lhs_is_float = 0

        if used_lea != 0 {
            // LEA already computed the result — skip all expression evaluation
        } else if wrk == 30 || wrk == 32 {
            // Simple RHS: skip stack temp
            gen_expr(wlhs)
            lhs_is_float = expr_is_float
            if lhs_is_float != 0 {
                // Float LHS: store xmm0 to temp
                uint64 ft0 = var_count * 8
                var_count = var_count + 1
                var_frame_size = var_count * 8
                uint64 ft0r = var_frame_size & 15
                if ft0r != 0 { var_frame_size = var_frame_size + 16 - ft0r }
                if lhs_is_float == 2 {
                    emit_store_xmm0_f32(ft0)
                } else {
                    emit_store_xmm0_f64(ft0)
                }
                gen_expr(wrhs)
                uint64 rhs_is_float = expr_is_float
                if lhs_is_float != 0 && rhs_is_float != 0 {
                    // movsd xmm1, xmm0 (save RHS): F2 0F 10 C8
                    emit_byte(0xF2); emit_byte(0x0F); emit_byte(0x10); emit_byte(0xC8)
                    // Reload LHS from temp
                    if lhs_is_float == 2 {
                        emit_load_xmm0_f32(ft0)
                    } else {
                        emit_load_xmm0_f64(ft0)
                    }
                    uint32 op_tok_fb = ast_data1(node)
                    uint64 wop_fb = op_tok_fb
                    uint64 pfb = cg_tokens + wop_fb * 16
                    uint32 op_kind_fb = 0
                    unsafe { *(pfb as uint32) -> op_kind_fb }
                    if lhs_is_float == 2 {
                        if op_kind_fb == 30 { emit_byte(0xF3); emit_byte(0x0F); emit_byte(0x58); emit_byte(0xC1) } // addss
                        if op_kind_fb == 31 { emit_byte(0xF3); emit_byte(0x0F); emit_byte(0x5C); emit_byte(0xC1) } // subss
                        if op_kind_fb == 22 { emit_byte(0xF3); emit_byte(0x0F); emit_byte(0x59); emit_byte(0xC1) } // mulss
                        if op_kind_fb == 32 { emit_byte(0xF3); emit_byte(0x0F); emit_byte(0x5E); emit_byte(0xC1) } // divss
                    } else {
                        if op_kind_fb == 30 { emit_byte(0xF2); emit_byte(0x0F); emit_byte(0x58); emit_byte(0xC1) } // addsd
                        if op_kind_fb == 31 { emit_byte(0xF2); emit_byte(0x0F); emit_byte(0x5C); emit_byte(0xC1) } // subsd
                        if op_kind_fb == 22 { emit_byte(0xF2); emit_byte(0x0F); emit_byte(0x59); emit_byte(0xC1) } // mulsd
                        if op_kind_fb == 32 { emit_byte(0xF2); emit_byte(0x0F); emit_byte(0x5E); emit_byte(0xC1) } // divsd
                    }
                    expr_is_float = lhs_is_float
                    return
                }
            } else {
                emit_byte(0x48); emit_byte(0x89); emit_byte(0xC1)
                rax_cache = 0
                gen_expr(wrhs)
                emit_byte(0x48); emit_byte(0x87); emit_byte(0xC1)
                rax_cache = 0
            }
        } else if r12_in_use == 0 {
            // Complex RHS: hold lhs in r12 (callee-saved, survives calls)
            gen_expr(wlhs)
            lhs_is_float = expr_is_float
            if lhs_is_float != 0 {
                // Float LHS: store xmm0 to temp (can't use r12 for float)
                uint64 ft1 = var_count * 8
                var_count = var_count + 1
                var_frame_size = var_count * 8
                uint64 ft1r = var_frame_size & 15
                if ft1r != 0 { var_frame_size = var_frame_size + 16 - ft1r }
                if lhs_is_float == 2 {
                    emit_store_xmm0_f32(ft1)
                } else {
                    emit_store_xmm0_f64(ft1)
                }
                gen_expr(wrhs)
                uint64 rhs_is_float2 = expr_is_float
                if lhs_is_float != 0 && rhs_is_float2 != 0 {
                    // movsd xmm1, xmm0 (save RHS): F2 0F 10 C8
                    emit_byte(0xF2); emit_byte(0x0F); emit_byte(0x10); emit_byte(0xC8)
                    if lhs_is_float == 2 {
                        emit_load_xmm0_f32(ft1)
                    } else {
                        emit_load_xmm0_f64(ft1)
                    }
                    uint32 op_tok_fc = ast_data1(node)
                    uint64 wop_fc = op_tok_fc
                    uint64 pfc = cg_tokens + wop_fc * 16
                    uint32 op_kind_fc = 0
                    unsafe { *(pfc as uint32) -> op_kind_fc }
                    if lhs_is_float == 2 {
                        if op_kind_fc == 30 { emit_byte(0xF3); emit_byte(0x0F); emit_byte(0x58); emit_byte(0xC1) }
                        if op_kind_fc == 31 { emit_byte(0xF3); emit_byte(0x0F); emit_byte(0x5C); emit_byte(0xC1) }
                        if op_kind_fc == 22 { emit_byte(0xF3); emit_byte(0x0F); emit_byte(0x59); emit_byte(0xC1) }
                        if op_kind_fc == 32 { emit_byte(0xF3); emit_byte(0x0F); emit_byte(0x5E); emit_byte(0xC1) }
                    } else {
                        if op_kind_fc == 30 { emit_byte(0xF2); emit_byte(0x0F); emit_byte(0x58); emit_byte(0xC1) }
                        if op_kind_fc == 31 { emit_byte(0xF2); emit_byte(0x0F); emit_byte(0x5C); emit_byte(0xC1) }
                        if op_kind_fc == 22 { emit_byte(0xF2); emit_byte(0x0F); emit_byte(0x59); emit_byte(0xC1) }
                        if op_kind_fc == 32 { emit_byte(0xF2); emit_byte(0x0F); emit_byte(0x5E); emit_byte(0xC1) }
                    }
                    expr_is_float = lhs_is_float
                    return
                }
            } else {
                r12_in_use = 1
                emit_byte(0x49); emit_byte(0x89); emit_byte(0xC4) // mov r12, rax
                rax_cache = 0
                gen_expr(wrhs)
                r12_in_use = 0
                emit_byte(0x48); emit_byte(0x89); emit_byte(0xC1) // mov rcx, rax
                emit_byte(0x4C); emit_byte(0x89); emit_byte(0xE0) // mov rax, r12
                rax_cache = 0
            }
        } else {
            // r12 in use (nested): fall back to stack
            gen_expr(wlhs)
            lhs_is_float = expr_is_float
            uint64 binop_temp = var_count * 8
            var_count = var_count + 1
            var_frame_size = var_count * 8
            uint64 brem = var_frame_size & 15
            if brem != 0 { var_frame_size = var_frame_size + 16 - brem }
            if lhs_is_float != 0 {
                if lhs_is_float == 2 {
                    emit_store_xmm0_f32(binop_temp)
                } else {
                    emit_store_xmm0_f64(binop_temp)
                }
                gen_expr(wrhs)
                uint64 rhs_is_float3 = expr_is_float
                if lhs_is_float != 0 && rhs_is_float3 != 0 {
                    // movsd xmm1, xmm0 (save RHS): F2 0F 10 C8
                    emit_byte(0xF2); emit_byte(0x0F); emit_byte(0x10); emit_byte(0xC8)
                    if lhs_is_float == 2 {
                        emit_load_xmm0_f32(binop_temp)
                    } else {
                        emit_load_xmm0_f64(binop_temp)
                    }
                    uint32 op_tok_fd = ast_data1(node)
                    uint64 wop_fd = op_tok_fd
                    uint64 pfd = cg_tokens + wop_fd * 16
                    uint32 op_kind_fd = 0
                    unsafe { *(pfd as uint32) -> op_kind_fd }
                    if lhs_is_float == 2 {
                        if op_kind_fd == 30 { emit_byte(0xF3); emit_byte(0x0F); emit_byte(0x58); emit_byte(0xC1) }
                        if op_kind_fd == 31 { emit_byte(0xF3); emit_byte(0x0F); emit_byte(0x5C); emit_byte(0xC1) }
                        if op_kind_fd == 22 { emit_byte(0xF3); emit_byte(0x0F); emit_byte(0x59); emit_byte(0xC1) }
                        if op_kind_fd == 32 { emit_byte(0xF3); emit_byte(0x0F); emit_byte(0x5E); emit_byte(0xC1) }
                    } else {
                        if op_kind_fd == 30 { emit_byte(0xF2); emit_byte(0x0F); emit_byte(0x58); emit_byte(0xC1) }
                        if op_kind_fd == 31 { emit_byte(0xF2); emit_byte(0x0F); emit_byte(0x5C); emit_byte(0xC1) }
                        if op_kind_fd == 22 { emit_byte(0xF2); emit_byte(0x0F); emit_byte(0x59); emit_byte(0xC1) }
                        if op_kind_fd == 32 { emit_byte(0xF2); emit_byte(0x0F); emit_byte(0x5E); emit_byte(0xC1) }
                    }
                    expr_is_float = lhs_is_float
                    return
                }
            } else {
                emit_store_rax_to_stack(binop_temp)
                gen_expr(wrhs)
                emit_byte(0x48); emit_byte(0x89); emit_byte(0xC1)
                emit_load_rax_from_stack(binop_temp)
            }
        }

        // Determine operation from token kind (skip if LEA already computed)
        if used_lea == 0 {
        uint32 op_tok = ast_data1(node)
        uint64 wop = op_tok
        uint64 p = cg_tokens + wop * 16
        uint32 op_kind = 0
        unsafe { *(p as uint32) -> op_kind }

        // Detect signed-int operands so / / % / >> select the right
        // x86 instruction below. Int compares are routed separately
        // (see Compare emission at line ~4440); arithmetic +-* don't
        // care about signedness in two's complement.
        uint64 binop_is_signed = 0
        if legacy_node_is_signed(wlhs) != 0 { binop_is_signed = 1 }
        if legacy_node_is_signed(wrhs) != 0 { binop_is_signed = 1 }

        if op_kind == 30 {
            emit_add_rax_rcx()
            if debug_mode != 0 {
                // Overflow check: jno rel8 — skip trap if no signed overflow
                // Also catches unsigned carry for unsigned types
                emit_byte(0x71)
                uint64 jo_add = out_len
                emit_byte(0)
                emit_mov_rax_imm(1)
                emit_mov_rdi_rax()
                if target_os == 2 {
                    emit_mov_rcx_rax()
                    emit_win_alloc_stack(0x20)
                    emit_win_call_iat(0)
                } else if target_os == 1 {
                    emit_mov_rax_imm(0x2000001)
                    emit_byte(0x0F); emit_byte(0x05)
                } else {
                    emit_mov_rax_imm(231)
                    emit_byte(0x0F); emit_byte(0x05)
                }
                uint64 jo_add_skip = out_len - jo_add - 1
                uint8 jo_add_s8 = jo_add_skip
                uint64 jo_add_pp = out_buf + jo_add
                unsafe { *(jo_add_pp as uint8) = jo_add_s8 }
            }
        }
        else if op_kind == 31 {
            emit_sub_rax_rcx()
            if debug_mode != 0 {
                emit_byte(0x71)
                uint64 jo_sub = out_len
                emit_byte(0)
                emit_mov_rax_imm(1)
                emit_mov_rdi_rax()
                if target_os == 2 {
                    emit_mov_rcx_rax()
                    emit_win_alloc_stack(0x20)
                    emit_win_call_iat(0)
                } else if target_os == 1 {
                    emit_mov_rax_imm(0x2000001)
                    emit_byte(0x0F); emit_byte(0x05)
                } else {
                    emit_mov_rax_imm(231)
                    emit_byte(0x0F); emit_byte(0x05)
                }
                uint64 jo_sub_skip = out_len - jo_sub - 1
                uint8 jo_sub_s8 = jo_sub_skip
                uint64 jo_sub_pp = out_buf + jo_sub
                unsafe { *(jo_sub_pp as uint8) = jo_sub_s8 }
            }
        }
        else if op_kind == 22 {
            emit_mul_rax_rcx()
            if debug_mode != 0 {
                emit_byte(0x71)
                uint64 jo_mul = out_len
                emit_byte(0)
                emit_mov_rax_imm(1)
                emit_mov_rdi_rax()
                if target_os == 2 {
                    emit_mov_rcx_rax()
                    emit_win_alloc_stack(0x20)
                    emit_win_call_iat(0)
                } else if target_os == 1 {
                    emit_mov_rax_imm(0x2000001)
                    emit_byte(0x0F); emit_byte(0x05)
                } else {
                    emit_mov_rax_imm(231)
                    emit_byte(0x0F); emit_byte(0x05)
                }
                uint64 jo_mul_skip = out_len - jo_mul - 1
                uint8 jo_mul_s8 = jo_mul_skip
                uint64 jo_mul_pp = out_buf + jo_mul
                unsafe { *(jo_mul_pp as uint8) = jo_mul_s8 }
            }
        }
        else if op_kind == 32 {
            // / division: rax / rcx
            if debug_mode != 0 {
                // Division by zero check: test rcx, rcx; jnz +skip; exit(1)
                emit_byte(0x48); emit_byte(0x85); emit_byte(0xC9)  // test rcx, rcx
                emit_byte(0x75)  // jnz rel8
                uint64 dz_jnz_patch = out_len
                emit_byte(0)  // placeholder
                // Divisor is zero — exit(1)
                emit_mov_rax_imm(1)
                emit_mov_rdi_rax()
                if target_os == 2 {
                    emit_mov_rcx_rax()
                    emit_win_alloc_stack(0x20)
                    emit_win_call_iat(0)
                } else if target_os == 1 {
                    emit_mov_rax_imm(0x2000001)
                    emit_byte(0x0F); emit_byte(0x05)
                } else {
                    emit_mov_rax_imm(231)
                    emit_byte(0x0F); emit_byte(0x05)
                }
                // Patch jnz to skip the trap
                uint64 dz_skip = out_len - dz_jnz_patch - 1
                uint8 dz_skip8 = dz_skip
                uint64 dz_pp = out_buf + dz_jnz_patch
                unsafe { *(dz_pp as uint8) = dz_skip8 }
            }
            if binop_is_signed != 0 {
                // cqo (sign-extend rax → rdx:rax); idiv rcx (REX.W F7 /7)
                emit_byte(0x48); emit_byte(0x99)
                emit_byte(0x48); emit_byte(0xF7); emit_byte(0xF9)
            } else {
                // xor rdx, rdx; div rcx → quotient in rax
                emit_byte(0x48); emit_byte(0x31); emit_byte(0xD2)
                emit_byte(0x48); emit_byte(0xF7); emit_byte(0xF1)
            }
        }
        else if op_kind == 33 {
            // % modulo: rax % rcx
            if debug_mode != 0 {
                // Division by zero check: test rcx, rcx; jnz +skip; exit(1)
                emit_byte(0x48); emit_byte(0x85); emit_byte(0xC9)  // test rcx, rcx
                emit_byte(0x75)  // jnz rel8
                uint64 mz_jnz_patch = out_len
                emit_byte(0)  // placeholder
                // Divisor is zero — exit(1)
                emit_mov_rax_imm(1)
                emit_mov_rdi_rax()
                if target_os == 2 {
                    emit_mov_rcx_rax()
                    emit_win_alloc_stack(0x20)
                    emit_win_call_iat(0)
                } else if target_os == 1 {
                    emit_mov_rax_imm(0x2000001)
                    emit_byte(0x0F); emit_byte(0x05)
                } else {
                    emit_mov_rax_imm(231)
                    emit_byte(0x0F); emit_byte(0x05)
                }
                // Patch jnz to skip the trap
                uint64 mz_skip = out_len - mz_jnz_patch - 1
                uint8 mz_skip8 = mz_skip
                uint64 mz_pp = out_buf + mz_jnz_patch
                unsafe { *(mz_pp as uint8) = mz_skip8 }
            }
            if binop_is_signed != 0 {
                // cqo; idiv rcx → remainder in rdx; mov rax, rdx
                emit_byte(0x48); emit_byte(0x99)
                emit_byte(0x48); emit_byte(0xF7); emit_byte(0xF9)
                emit_byte(0x48); emit_byte(0x89); emit_byte(0xD0)
            } else {
                // xor rdx, rdx; div rcx → remainder in rdx; mov rax, rdx
                emit_byte(0x48); emit_byte(0x31); emit_byte(0xD2)
                emit_byte(0x48); emit_byte(0xF7); emit_byte(0xF1)
                emit_byte(0x48); emit_byte(0x89); emit_byte(0xD0)
            }
        }
        else if op_kind == 23 {
            // & bitwise AND: and rcx, rax
            emit_byte(0x48)
            emit_byte(0x21)
            emit_byte(0xC8)
        }
        else if op_kind == 24 {
            // | bitwise OR: or rcx, rax
            emit_byte(0x48)
            emit_byte(0x09)
            emit_byte(0xC8)
        }
        else if op_kind == 25 {
            // ^ bitwise XOR: xor rcx, rax
            emit_byte(0x48)
            emit_byte(0x31)
            emit_byte(0xC8)
        }
        else if op_kind == 43 {
            // << shift left: shl cl, rax (cl = low byte of rcx)
            emit_byte(0x48)
            emit_byte(0xD3)
            emit_byte(0xE0)
        }
        else if op_kind == 44 {
            // >> shift right. SAR (arithmetic, sign-fill) for signed ints
            // so `int64 x = -8; x >> 1` becomes -4 instead of (2^64-8)/2.
            emit_byte(0x48)
            emit_byte(0xD3)
            if binop_is_signed != 0 { emit_byte(0xF8) } else { emit_byte(0xE8) }
        }
        // Compound assignment ops (desugared by parser: x += y → x = x + y)
        else if op_kind == 45 {
            emit_add_rax_rcx()
            if debug_mode != 0 {
                emit_byte(0x71)
                uint64 jo_ca = out_len
                emit_byte(0)
                emit_mov_rax_imm(1)
                emit_mov_rdi_rax()
                if target_os == 2 {
                    emit_mov_rcx_rax()
                    emit_win_alloc_stack(0x20)
                    emit_win_call_iat(0)
                } else if target_os == 1 {
                    emit_mov_rax_imm(0x2000001)
                    emit_byte(0x0F); emit_byte(0x05)
                } else {
                    emit_mov_rax_imm(231)
                    emit_byte(0x0F); emit_byte(0x05)
                }
                uint64 jo_ca_skip = out_len - jo_ca - 1
                uint8 jo_ca_s8 = jo_ca_skip
                uint64 jo_ca_pp = out_buf + jo_ca
                unsafe { *(jo_ca_pp as uint8) = jo_ca_s8 }
            }
        }
        else if op_kind == 46 {
            emit_sub_rax_rcx()
            if debug_mode != 0 {
                emit_byte(0x71)
                uint64 jo_cs = out_len
                emit_byte(0)
                emit_mov_rax_imm(1)
                emit_mov_rdi_rax()
                if target_os == 2 {
                    emit_mov_rcx_rax()
                    emit_win_alloc_stack(0x20)
                    emit_win_call_iat(0)
                } else if target_os == 1 {
                    emit_mov_rax_imm(0x2000001)
                    emit_byte(0x0F); emit_byte(0x05)
                } else {
                    emit_mov_rax_imm(231)
                    emit_byte(0x0F); emit_byte(0x05)
                }
                uint64 jo_cs_skip = out_len - jo_cs - 1
                uint8 jo_cs_s8 = jo_cs_skip
                uint64 jo_cs_pp = out_buf + jo_cs
                unsafe { *(jo_cs_pp as uint8) = jo_cs_s8 }
            }
        }
        else if op_kind == 47 {
            emit_mul_rax_rcx()
            if debug_mode != 0 {
                emit_byte(0x71)
                uint64 jo_cm = out_len
                emit_byte(0)
                emit_mov_rax_imm(1)
                emit_mov_rdi_rax()
                if target_os == 2 {
                    emit_mov_rcx_rax()
                    emit_win_alloc_stack(0x20)
                    emit_win_call_iat(0)
                } else if target_os == 1 {
                    emit_mov_rax_imm(0x2000001)
                    emit_byte(0x0F); emit_byte(0x05)
                } else {
                    emit_mov_rax_imm(231)
                    emit_byte(0x0F); emit_byte(0x05)
                }
                uint64 jo_cm_skip = out_len - jo_cm - 1
                uint8 jo_cm_s8 = jo_cm_skip
                uint64 jo_cm_pp = out_buf + jo_cm
                unsafe { *(jo_cm_pp as uint8) = jo_cm_s8 }
            }
        }
        else if op_kind == 50 {
            emit_byte(0x48); emit_byte(0x21); emit_byte(0xC8) // &=
        }
        else if op_kind == 51 {
            emit_byte(0x48); emit_byte(0x09); emit_byte(0xC8) // |=
        }
        else if op_kind == 52 {
            emit_byte(0x48); emit_byte(0x31); emit_byte(0xC8) // ^=
        }
        } // end if used_lea == 0
        return
    }

    // Comparison: lhs CMP rhs → 0 or 1 in rax
    if kind == 38 {
        // Constant comparison folding
        uint32 lhs_idx = ast_child(node)
        uint64 wlhs = lhs_idx
        uint32 rhs_idx_cc = ast_data2(node)
        uint64 wrhs_cc = rhs_idx_cc
        uint32 lk_cc = ast_kind(wlhs)
        uint32 rk_cc = ast_kind(wrhs_cc)
        if lk_cc == 30 && rk_cc == 30 {
            uint32 lt_cc = ast_data1(wlhs)
            uint32 rt_cc = ast_data1(wrhs_cc)
            uint64 lvc = parse_int_token(lt_cc)
            uint64 rvc = parse_int_token(rt_cc)
            uint32 op_cc = ast_data1(node)
            uint64 pcc = cg_tokens + op_cc * 16
            uint32 okcc = 0
            unsafe { *(pcc as uint32) -> okcc }
            uint64 res = 0
            if okcc == 35 { if lvc == rvc { res = 1 } }
            else if okcc == 36 { if lvc != rvc { res = 1 } }
            else if okcc == 37 { if lvc < rvc { res = 1 } }
            else if okcc == 38 { if lvc <= rvc { res = 1 } }
            else if okcc == 39 { if lvc > rvc { res = 1 } }
            else if okcc == 40 { if lvc >= rvc { res = 1 } }
            emit_mov_rax_imm(res)
            return
        }

        // Struct comparison: == and != on struct values
        uint32 rhs_idx_pre = ast_data2(node)
        uint64 wrhs_pre = rhs_idx_pre
        uint32 lhs_k_pre = ast_kind(wlhs)
        uint32 rhs_k_pre = ast_kind(wrhs_pre)
        uint64 lhs_si_pre = 0xFFFFFFFF
        uint64 rhs_si_pre = 0xFFFFFFFF
        if lhs_k_pre == 32 {
            uint32 lt_pre = ast_data1(wlhs)
            uint64 wlt_pre = lt_pre
            lhs_si_pre = struct_var_lookup(wlt_pre)
        }
        if lhs_si_pre != 0xFFFFFFFF && rhs_k_pre == 32 {
            uint32 rt_pre = ast_data1(wrhs_pre)
            uint64 wrt_pre = rt_pre
            rhs_si_pre = struct_var_lookup(wrt_pre)
        }
        if lhs_si_pre != 0xFFFFFFFF && rhs_si_pre != 0xFFFFFFFF {
            // Both operands are struct variables — emit qword-by-qword comparison
            gen_expr(wlhs)
            uint64 sc_lhs_slot = var_count * 8
            var_count = var_count + 1
            var_frame_size = var_count * 8
            uint64 sc_rem1 = var_frame_size & 15
            if sc_rem1 != 0 { var_frame_size = var_frame_size + 16 - sc_rem1 }
            emit_store_rax_to_stack(sc_lhs_slot)

            gen_expr(wrhs_pre)
            uint64 sc_rhs_slot = var_count * 8
            var_count = var_count + 1
            uint64 sc_acc_slot = var_count * 8
            var_count = var_count + 1
            var_frame_size = var_count * 8
            uint64 sc_rem2 = var_frame_size & 15
            if sc_rem2 != 0 { var_frame_size = var_frame_size + 16 - sc_rem2 }
            emit_store_rax_to_stack(sc_rhs_slot)

            uint64 sc_size = struct_total_size(lhs_si_pre)
            uint64 sc_slots = (sc_size + 7) / 8

            // Start with result = 1 (assume equal)
            emit_mov_rax_imm(1)
            emit_store_rax_to_stack(sc_acc_slot)

            uint64 qi = 0
            while qi < sc_slots {
                // Load lhs qword
                emit_load_rax_from_stack(sc_lhs_slot)
                uint64 qoff = qi * 8
                if qoff == 0 {
                    // mov rax, [rax]
                    emit_byte(0x48); emit_byte(0x8B); emit_byte(0x00)
                } else {
                    if qoff < 128 {
                        // mov rax, [rax+disp8]
                        emit_byte(0x48); emit_byte(0x8B); emit_byte(0x40)
                        uint8 qo8 = qoff; emit_byte(qo8)
                    } else {
                        // mov rax, [rax+disp32]
                        emit_byte(0x48); emit_byte(0x8B); emit_byte(0x80)
                        uint32 qo32 = qoff
                        uint8 qb0 = qo32 & 0xFF; emit_byte(qb0)
                        uint8 qb1 = (qo32 >> 8) & 0xFF; emit_byte(qb1)
                        uint8 qb2 = (qo32 >> 16) & 0xFF; emit_byte(qb2)
                        uint8 qb3 = (qo32 >> 24) & 0xFF; emit_byte(qb3)
                    }
                }
                // mov rcx, rax
                emit_byte(0x48); emit_byte(0x89); emit_byte(0xC1)

                // Load rhs qword
                emit_load_rax_from_stack(sc_rhs_slot)
                if qoff == 0 {
                    emit_byte(0x48); emit_byte(0x8B); emit_byte(0x00)
                } else {
                    if qoff < 128 {
                        emit_byte(0x48); emit_byte(0x8B); emit_byte(0x40)
                        uint8 qo8r = qoff; emit_byte(qo8r)
                    } else {
                        emit_byte(0x48); emit_byte(0x8B); emit_byte(0x80)
                        uint32 qo32r = qoff
                        uint8 qb0r = qo32r & 0xFF; emit_byte(qb0r)
                        uint8 qb1r = (qo32r >> 8) & 0xFF; emit_byte(qb1r)
                        uint8 qb2r = (qo32r >> 16) & 0xFF; emit_byte(qb2r)
                        uint8 qb3r = (qo32r >> 24) & 0xFF; emit_byte(qb3r)
                    }
                }

                // cmp rcx, rax
                emit_byte(0x48); emit_byte(0x39); emit_byte(0xC1)
                // sete al
                emit_byte(0x0F); emit_byte(0x94); emit_byte(0xC0)
                // movzx eax, al
                emit_byte(0x0F); emit_byte(0xB6); emit_byte(0xC0)

                // AND with accumulated result
                // mov rcx, rax
                emit_byte(0x48); emit_byte(0x89); emit_byte(0xC1)
                emit_load_rax_from_stack(sc_acc_slot)
                // and rax, rcx
                emit_byte(0x48); emit_byte(0x21); emit_byte(0xC8)
                emit_store_rax_to_stack(sc_acc_slot)

                qi = qi + 1
            }

            emit_load_rax_from_stack(sc_acc_slot)

            // Check operator: == (35) or != (36)
            uint32 op_tok_sc = ast_data1(node)
            uint64 wop_sc = op_tok_sc
            uint64 p_sc = cg_tokens + wop_sc * 16
            uint32 op_kind_sc = 0
            unsafe { *(p_sc as uint32) -> op_kind_sc }
            if op_kind_sc == 36 {
                // != : invert (xor rax, 1)
                emit_byte(0x48); emit_byte(0x83); emit_byte(0xF0); emit_byte(0x01)
            }

            rax_invalidate()
            expr_is_float = 0
            expr_is_struct = 0xFFFFFFFF
            return
        }

        uint32 rhs_idx = ast_data2(node)
        uint64 wrhs = rhs_idx
        uint32 rhs_kind_cmp = ast_kind(wrhs)
        uint64 wrk_cmp = rhs_kind_cmp
        uint32 lhs_kind_cmp2 = ast_kind(wlhs)
        uint64 wlk_cmp = lhs_kind_cmp2

        // Fast path: cmp pinned_param, imm → cmp rbx, imm8
        uint64 used_direct_cmp = 0
        if wlk_cmp == 32 && wrk_cmp == 30 && pin_param0_offset != 0xFFFFFFFF {
            uint32 lhs_tok_c = ast_data1(wlhs)
            uint64 loff_c = var_lookup(lhs_tok_c)
            if loff_c == pin_param0_offset {
                uint32 rhs_tok_c = ast_data1(wrhs)
                uint64 cmp_imm = parse_int_token(rhs_tok_c)
                // cmp rbx, imm8: 48 83 FB <imm8>
                if cmp_imm < 128 {
                    uint8 ci8 = cmp_imm
                    emit_byte(0x48); emit_byte(0x83); emit_byte(0xFB); emit_byte(ci8)
                    used_direct_cmp = 1
                }
            }
        }

        if used_direct_cmp != 0 {
            // Direct cmp already emitted — skip expression evaluation
        } else if wrk_cmp == 30 || wrk_cmp == 32 {
            // Simple RHS: skip stack temp (for integers)
            gen_expr(wlhs)
            uint64 lhs_is_float_s = expr_is_float
            if lhs_is_float_s != 0 {
                // Float LHS: store xmm0 to temp, eval RHS, ucomisd
                uint64 fcmp_temp_s = var_count * 8
                var_count = var_count + 1
                var_frame_size = var_count * 8
                uint64 fcrem_s = var_frame_size & 15
                if fcrem_s != 0 { var_frame_size = var_frame_size + 16 - fcrem_s }
                if lhs_is_float_s == 2 {
                    emit_store_xmm0_f32(fcmp_temp_s)
                } else {
                    emit_store_xmm0_f64(fcmp_temp_s)
                }
                gen_expr(wrhs)
                // movsd xmm1, xmm0 (RHS): F2 0F 10 C8
                emit_byte(0xF2); emit_byte(0x0F); emit_byte(0x10); emit_byte(0xC8)
                // reload LHS into xmm0
                if lhs_is_float_s == 2 {
                    emit_load_xmm0_f32(fcmp_temp_s)
                } else {
                    emit_load_xmm0_f64(fcmp_temp_s)
                }
                // ucomisd xmm0, xmm1: 66 0F 2E C1  (ucomiss: 0F 2E C1)
                if lhs_is_float_s == 2 {
                    emit_byte(0x0F); emit_byte(0x2E); emit_byte(0xC1)
                } else {
                    emit_byte(0x66); emit_byte(0x0F); emit_byte(0x2E); emit_byte(0xC1)
                }
                uint32 op_tok_fs = ast_data1(node)
                uint64 wop_fs = op_tok_fs
                uint64 p_fs = cg_tokens + wop_fs * 16
                uint32 op_kind_fs = 0
                unsafe { *(p_fs as uint32) -> op_kind_fs }
                rax_invalidate()
                emit_setcc(op_kind_fs)
                expr_is_float = 0
                return
            }
            emit_byte(0x48); emit_byte(0x89); emit_byte(0xC1)
            rax_cache = 0
            gen_expr(wrhs)
            emit_byte(0x48); emit_byte(0x87); emit_byte(0xC1)
            rax_cache = 0
        } else if r12_in_use == 0 {
            gen_expr(wlhs)
            uint64 lhs_is_float_r = expr_is_float
            if lhs_is_float_r != 0 {
                // Float LHS: store xmm0 to temp, eval RHS, ucomisd
                uint64 fcmp_temp_r = var_count * 8
                var_count = var_count + 1
                var_frame_size = var_count * 8
                uint64 fcrem_r = var_frame_size & 15
                if fcrem_r != 0 { var_frame_size = var_frame_size + 16 - fcrem_r }
                if lhs_is_float_r == 2 {
                    emit_store_xmm0_f32(fcmp_temp_r)
                } else {
                    emit_store_xmm0_f64(fcmp_temp_r)
                }
                gen_expr(wrhs)
                // movsd xmm1, xmm0 (RHS): F2 0F 10 C8
                emit_byte(0xF2); emit_byte(0x0F); emit_byte(0x10); emit_byte(0xC8)
                // reload LHS into xmm0
                if lhs_is_float_r == 2 {
                    emit_load_xmm0_f32(fcmp_temp_r)
                } else {
                    emit_load_xmm0_f64(fcmp_temp_r)
                }
                // ucomisd xmm0, xmm1: 66 0F 2E C1  (ucomiss: 0F 2E C1)
                if lhs_is_float_r == 2 {
                    emit_byte(0x0F); emit_byte(0x2E); emit_byte(0xC1)
                } else {
                    emit_byte(0x66); emit_byte(0x0F); emit_byte(0x2E); emit_byte(0xC1)
                }
                uint32 op_tok_fr = ast_data1(node)
                uint64 wop_fr = op_tok_fr
                uint64 p_fr = cg_tokens + wop_fr * 16
                uint32 op_kind_fr = 0
                unsafe { *(p_fr as uint32) -> op_kind_fr }
                rax_invalidate()
                emit_setcc(op_kind_fr)
                expr_is_float = 0
                return
            }
            r12_in_use = 1
            emit_byte(0x49); emit_byte(0x89); emit_byte(0xC4)
            rax_cache = 0
            gen_expr(wrhs)
            r12_in_use = 0
            emit_byte(0x48); emit_byte(0x89); emit_byte(0xC1)
            emit_byte(0x4C); emit_byte(0x89); emit_byte(0xE0)
            rax_cache = 0
        } else {
            gen_expr(wlhs)
            uint64 lhs_is_float_k = expr_is_float
            uint64 cmp_temp = var_count * 8
            var_count = var_count + 1
            var_frame_size = var_count * 8
            uint64 crem = var_frame_size & 15
            if crem != 0 { var_frame_size = var_frame_size + 16 - crem }
            if lhs_is_float_k != 0 {
                // Float LHS: store xmm0 to temp, eval RHS, ucomisd
                if lhs_is_float_k == 2 {
                    emit_store_xmm0_f32(cmp_temp)
                } else {
                    emit_store_xmm0_f64(cmp_temp)
                }
                gen_expr(wrhs)
                // movsd xmm1, xmm0 (RHS): F2 0F 10 C8
                emit_byte(0xF2); emit_byte(0x0F); emit_byte(0x10); emit_byte(0xC8)
                // reload LHS into xmm0
                if lhs_is_float_k == 2 {
                    emit_load_xmm0_f32(cmp_temp)
                } else {
                    emit_load_xmm0_f64(cmp_temp)
                }
                // ucomisd xmm0, xmm1: 66 0F 2E C1  (ucomiss: 0F 2E C1)
                if lhs_is_float_k == 2 {
                    emit_byte(0x0F); emit_byte(0x2E); emit_byte(0xC1)
                } else {
                    emit_byte(0x66); emit_byte(0x0F); emit_byte(0x2E); emit_byte(0xC1)
                }
                uint32 op_tok_fk = ast_data1(node)
                uint64 wop_fk = op_tok_fk
                uint64 p_fk = cg_tokens + wop_fk * 16
                uint32 op_kind_fk = 0
                unsafe { *(p_fk as uint32) -> op_kind_fk }
                rax_invalidate()
                emit_setcc(op_kind_fk)
                expr_is_float = 0
                return
            }
            emit_store_rax_to_stack(cmp_temp)
            gen_expr(wrhs)
            emit_byte(0x48); emit_byte(0x89); emit_byte(0xC1)
            emit_load_rax_from_stack(cmp_temp)
        }

        uint32 op_tok = ast_data1(node)
        uint64 wop = op_tok
        uint64 p = cg_tokens + wop * 16
        uint32 op_kind = 0
        unsafe { *(p as uint32) -> op_kind }

        // Pick signed setcc for ordered compares when either operand is
        // signed-int (int8/16/32/64 declared, or signed-producing
        // expression). Without this, `int64 k = -3; if k < 0` lowered
        // through legacy used setb (unsigned <) and never fired.
        uint64 is_signed_cmp = 0
        if legacy_node_is_signed(wlhs) != 0 { is_signed_cmp = 1 }
        if legacy_node_is_signed(wrhs) != 0 { is_signed_cmp = 1 }

        if used_direct_cmp != 0 {
            // cmp rbx, imm already set flags — just emit setcc
            rax_invalidate()
            emit_setcc_typed(op_kind, is_signed_cmp)
        } else {
            emit_compare_typed(op_kind, is_signed_cmp)
        }
        return
    }

    // LogicalAnd (&&): non-short-circuit, evaluate both, AND results
    if kind == 39 {
        uint32 lhs_idx = ast_child(node)
        uint64 wlhs = lhs_idx
        gen_expr(wlhs)
        uint64 and_temp = var_count * 8
        var_count = var_count + 1
        var_frame_size = var_count * 8
        uint64 arem = var_frame_size & 15
        if arem != 0 { var_frame_size = var_frame_size + 16 - arem }
        emit_store_rax_to_stack(and_temp)
        uint32 rhs_idx = ast_data2(node)
        uint64 wrhs = rhs_idx
        gen_expr(wrhs)
        // test both: rax = (lhs != 0) && (rhs != 0)
        // test rax, rax → set ZF if rhs==0
        emit_byte(0x48)
        emit_byte(0x85)
        emit_byte(0xC0)
        // setne cl
        emit_byte(0x0F)
        emit_byte(0x95)
        emit_byte(0xC1)
        // load lhs, test
        emit_load_rax_from_stack(and_temp)
        emit_byte(0x48)
        emit_byte(0x85)
        emit_byte(0xC0)
        // setne al
        emit_byte(0x0F)
        emit_byte(0x95)
        emit_byte(0xC0)
        // and al, cl
        emit_byte(0x20)
        emit_byte(0xC8)
        // movzbl al, eax
        emit_byte(0x0F)
        emit_byte(0xB6)
        emit_byte(0xC0)
        return
    }

    // LogicalOr (||): non-short-circuit
    if kind == 40 {
        uint32 lhs_idx = ast_child(node)
        uint64 wlhs = lhs_idx
        gen_expr(wlhs)
        uint64 or_temp = var_count * 8
        var_count = var_count + 1
        var_frame_size = var_count * 8
        uint64 orem = var_frame_size & 15
        if orem != 0 { var_frame_size = var_frame_size + 16 - orem }
        emit_store_rax_to_stack(or_temp)
        uint32 rhs_idx = ast_data2(node)
        uint64 wrhs = rhs_idx
        gen_expr(wrhs)
        // or lhs into rax, then test
        emit_byte(0x48)
        emit_byte(0x89)
        emit_byte(0xC1)
        emit_load_rax_from_stack(or_temp)
        // or rcx, rax
        emit_byte(0x48)
        emit_byte(0x09)
        emit_byte(0xC8)
        // test rax, rax; setne al; movzbl
        emit_byte(0x48)
        emit_byte(0x85)
        emit_byte(0xC0)
        emit_byte(0x0F)
        emit_byte(0x95)
        emit_byte(0xC0)
        emit_byte(0x0F)
        emit_byte(0xB6)
        emit_byte(0xC0)
        return
    }

    // Function call: callee(args...)
    if kind == 35 {
        uint32 callee_tok = ast_data1(node)

        // User-declared extern fn shadows builtins by design: if the programmer
        // wrote `extern fn write(...)`, they want libc's write, not the syscall.
        uint64 wct_pre = callee_tok
        uint64 ext_pre = extern_fn_lookup(wct_pre)
        uint64 is_extern_call = 0
        if ext_pre != 0xFFFFFFFF { is_extern_call = 1 }

        // Check for built-in: exit(code)
        uint64 wct = callee_tok
        if is_extern_call == 0 && tok_matches(wct, "exit", 4) != 0 {
            uint32 first_arg = ast_child(node)
            uint64 wfa = first_arg
            gen_expr(wfa)
            // Auto-inject hipkfd_teardown() under --target=amdgpu-native
            // BEFORE the exit syscall. Stash rax (exit code) in rbx
            // across the call; rbx is callee-saved per SysV.
            if should_auto_inject_teardown() != 0 {
                emit_byte(0x48); emit_byte(0x89); emit_byte(0xC3)   // mov rbx, rax
                emit_call_hipkfd_teardown()
                emit_byte(0x48); emit_byte(0x89); emit_byte(0xD8)   // mov rax, rbx
            }
            if target_os == 2 {
                // Windows: ExitProcess(code)
                emit_mov_rcx_rax()
                emit_win_alloc_stack(0x20)
                emit_win_call_iat(0)
            } else {
                emit_mov_rdi_rax()
                if target_os == 1 { emit_mov_rax_imm(0x2000001) } else { emit_mov_rax_imm(231) }
                emit_byte(0x0F)
                emit_byte(0x05)
            }
            return
        }

        // Check for built-in: write(fd, buf, len)
        if is_extern_call == 0 && tok_matches(wct, "write", 5) != 0 {
            uint32 arg1 = ast_child(node)
            uint64 wa1 = arg1
            gen_expr(wa1)
            emit_store_rax_to_stack(temp_slot_0)
            uint32 arg2 = ast_next(wa1)
            uint64 wa2 = arg2
            gen_expr(wa2)
            emit_store_rax_to_stack(temp_slot_1)
            uint32 arg3 = ast_next(wa2)
            uint64 wa3 = arg3
            gen_expr(wa3)
            if target_os == 2 {
