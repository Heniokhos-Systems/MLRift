        emit_byte(0x66); emit_byte(0x48); emit_byte(0x0F); emit_byte(0x7E); emit_byte(0xC0)
        if dst_r != 0xFFFFFFFF {
            ir_emit_mov_r64_r64(dst_r, 0)
        } else {
            ir_emit_store_spill(0, dest_v)
        }
        return
    }

    // Float comparisons: FCMP_EQ(24), FCMP_LT(25), FCMP_NE(99), FCMP_LE(100),
    //                     FCMP_GT(101), FCMP_GE(102)
    // imm holds float kind: 1=f64, 2=f32
    if op == 24 || op == 25 || op == 99 || op == 100 || op == 101 || op == 102 {
        uint64 a_reg = ir_resolve_src(s1_v, 0)
        uint64 b_reg = ir_resolve_src(s2_v, 1)
        uint64 fk = imm
        // movq xmm0, a_reg
        ir_emit_mov_r64_r64(0, a_reg)
        emit_byte(0x66); emit_byte(0x48); emit_byte(0x0F); emit_byte(0x6E); emit_byte(0xC0)
        // movq xmm1, b_reg
        ir_emit_mov_r64_r64(0, b_reg)
        emit_byte(0x66); emit_byte(0x48); emit_byte(0x0F); emit_byte(0x6E); emit_byte(0xC8)
        // ucomisd/ucomiss xmm0, xmm1
        if fk == 2 {
            // ucomiss xmm0, xmm1: 0F 2E C1
            emit_byte(0x0F); emit_byte(0x2E); emit_byte(0xC1)
        } else {
            // ucomisd xmm0, xmm1: 66 0F 2E C1
            emit_byte(0x66); emit_byte(0x0F); emit_byte(0x2E); emit_byte(0xC1)
        }
        // Set result based on comparison kind
        emit_byte(0x0F)
        if op == 24 { emit_byte(0x94) }    // sete  (==)
        if op == 99 { emit_byte(0x95) }    // setne (!=)
        if op == 25 { emit_byte(0x92) }    // setb  (<)
        if op == 100 { emit_byte(0x96) }   // setbe (<=)
        if op == 101 { emit_byte(0x97) }   // seta  (>)
        if op == 102 { emit_byte(0x93) }   // setae (>=)
        emit_byte(0xC0)
        // movzx rax, al: 48 0F B6 C0
        emit_byte(0x48); emit_byte(0x0F); emit_byte(0xB6); emit_byte(0xC0)
        if dst_r != 0xFFFFFFFF {
            ir_emit_mov_r64_r64(dst_r, 0)
        } else {
            ir_emit_store_spill(0, dest_v)
        }
        return
    }

    if op == 97 {
        // IR_FSQRT: movq xmm0, rax; sqrtsd xmm0, xmm0; movq rax, xmm0
        uint64 a_reg = ir_resolve_src(s1_v, 0)
        ir_emit_mov_r64_r64(0, a_reg)
        // movq xmm0, rax: 66 48 0F 6E C0
        emit_byte(0x66); emit_byte(0x48); emit_byte(0x0F); emit_byte(0x6E); emit_byte(0xC0)
        // sqrtsd xmm0, xmm0: F2 0F 51 C0
        emit_byte(0xF2); emit_byte(0x0F); emit_byte(0x51); emit_byte(0xC0)
        // movq rax, xmm0: 66 48 0F 7E C0
        emit_byte(0x66); emit_byte(0x48); emit_byte(0x0F); emit_byte(0x7E); emit_byte(0xC0)
        if dst_r != 0xFFFFFFFF {
            ir_emit_mov_r64_r64(dst_r, 0)
        } else {
            ir_emit_store_spill(0, dest_v)
        }
        return
    }

    if op == 98 {
        // IR_FFMA: a*b + c, all f64 bit patterns in GPRs
        // src1=a, src2=b, imm=c (vreg)
        uint64 a_reg = ir_resolve_src(s1_v, 0)
        uint64 b_reg = ir_resolve_src(s2_v, 1)
        uint64 c_reg = ir_resolve_src(imm, 2)
        // movq xmm0, a_reg
        ir_emit_mov_r64_r64(0, a_reg)
        emit_byte(0x66); emit_byte(0x48); emit_byte(0x0F); emit_byte(0x6E); emit_byte(0xC0)
        // movq xmm1, b_reg
        ir_emit_mov_r64_r64(0, b_reg)
