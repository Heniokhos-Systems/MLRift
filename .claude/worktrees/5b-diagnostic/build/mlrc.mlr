    // ----- IR_ATOMIC_SUB (109): ldaxr/sub/stlxr retry loop -----
    // Returns the OLD value (mirrors x86's xadd-based lowering).
    if op == 109 {
        uint64 ptr_r = ir_a64_resolve_src(s1_v, 10)
        uint64 val_r = ir_a64_resolve_src(s2_v, 11)
        uint64 as_retry = out_len
        emit_a64(0xC85FFC00 | (ptr_r << 5) | 9)       // LDAXR x9 (= old)
        emit_a64_sub(13, 9, val_r)                    // x13 = new
        emit_a64(0xC800FC00 | (12 << 16) | (ptr_r << 5) | 13)  // STLXR w12, x13
        uint64 as_back = as_retry - out_len
        emit_a64(0x35000000 | (((as_back / 4) & 0x7FFFF) << 5) | 12)
        if dst_r != 0xFFFFFFFF {
            emit_a64_mov(dst_r, 9)
        } else {
            ir_a64_emit_store_spill(9, dest_v)
        }
        return
    }

    // ----- IR_ATOMIC_AND (110): ldaxr/and/stlxr retry loop — returns OLD -----
    if op == 110 {
        uint64 ptr_r = ir_a64_resolve_src(s1_v, 10)
        uint64 val_r = ir_a64_resolve_src(s2_v, 11)
        uint64 aand_retry = out_len
        emit_a64(0xC85FFC00 | (ptr_r << 5) | 9)       // LDAXR x9 (= old)
        emit_a64_and(13, 9, val_r)                    // x13 = new
        emit_a64(0xC800FC00 | (12 << 16) | (ptr_r << 5) | 13)
        uint64 aand_back = aand_retry - out_len
        emit_a64(0x35000000 | (((aand_back / 4) & 0x7FFFF) << 5) | 12)
        if dst_r != 0xFFFFFFFF {
            emit_a64_mov(dst_r, 9)
        } else {
            ir_a64_emit_store_spill(9, dest_v)
        }
        return
    }

    // ----- IR_ATOMIC_OR (111): ldaxr/orr/stlxr retry loop — returns OLD -----
    if op == 111 {
        uint64 ptr_r = ir_a64_resolve_src(s1_v, 10)
        uint64 val_r = ir_a64_resolve_src(s2_v, 11)
        uint64 aor_retry = out_len
        emit_a64(0xC85FFC00 | (ptr_r << 5) | 9)       // LDAXR x9 (= old)
        emit_a64_orr(13, 9, val_r)                    // x13 = new
        emit_a64(0xC800FC00 | (12 << 16) | (ptr_r << 5) | 13)
        uint64 aor_back = aor_retry - out_len
        emit_a64(0x35000000 | (((aor_back / 4) & 0x7FFFF) << 5) | 12)
        if dst_r != 0xFFFFFFFF {
            emit_a64_mov(dst_r, 9)
        } else {
            ir_a64_emit_store_spill(9, dest_v)
        }
        return
    }

    // ----- IR_ATOMIC_XOR (112): ldaxr/eor/stlxr retry loop — returns OLD -----
    if op == 112 {
        uint64 ptr_r = ir_a64_resolve_src(s1_v, 10)
        uint64 val_r = ir_a64_resolve_src(s2_v, 11)
        uint64 axor_retry = out_len
        emit_a64(0xC85FFC00 | (ptr_r << 5) | 9)       // LDAXR x9 (= old)
        emit_a64_eor(13, 9, val_r)                    // x13 = new
        emit_a64(0xC800FC00 | (12 << 16) | (ptr_r << 5) | 13)
        uint64 axor_back = axor_retry - out_len
        emit_a64(0x35000000 | (((axor_back / 4) & 0x7FFFF) << 5) | 12)
        if dst_r != 0xFFFFFFFF {
            emit_a64_mov(dst_r, 9)
        } else {
            ir_a64_emit_store_spill(9, dest_v)
        }
        return
    }

    // ----- IR_EXEC (113): execve on Linux/macOS, CreateProcessA on Windows -----
    if op == 113 {
        uint64 path_r = ir_a64_resolve_src(s1_v, 9)
        if target_os == 2 {
            // Windows ARM64: CreateProcessA + WaitForSingleObject + ExitProcess
            // SP shift is safe — ExitProcess never returns.
            emit_a64_sub_sp_imm(0xD0)
            // Zero STARTUPINFOA+PI area: memset [sp+0x40], 0, 128
            emit_a64_mov_imm(9, 0)
            uint64 zi = 0
            while zi < 16 {
                emit_a64_str(9, 31, 0x40 + zi * 8)
                zi = zi + 1
            }
            // STARTUPINFOA.cb = 104 (at sp+0x40)
            emit_a64_mov_imm(9, 104)
            emit_a64_str32(9, 31, 0x40)
            // CreateProcessA(path, NULL, NULL, NULL, 0, 0, NULL, NULL, &si, &pi)
            // x0 = path (lpApplicationName)
            emit_a64_mov(0, path_r)
            // x1 = NULL (lpCommandLine)
            emit_a64_mov_imm(1, 0)
            // x2 = NULL, x3 = NULL
            emit_a64_mov_imm(2, 0)
            emit_a64_mov_imm(3, 0)
            // x4 = 0 (bInheritHandles)
            emit_a64_mov_imm(4, 0)
            // x5 = 0 (dwCreationFlags)
            emit_a64_mov_imm(5, 0)
            // x6 = NULL (lpEnvironment)
            emit_a64_mov_imm(6, 0)
            // x7 = NULL (lpCurrentDirectory)
            emit_a64_mov_imm(7, 0)
            // [sp+0x00] = &si (lpStartupInfo, 9th arg on stack for ARM64)
            emit_a64_add_imm(9, 31, 0x40)
            emit_a64_str(9, 31, 0)
            // [sp+0x08] = &pi (lpProcessInformation, 10th arg)
            emit_a64_add_imm(9, 31, 0xA8)
            emit_a64_str(9, 31, 8)
            emit_a64_win_call_iat(9)   // CreateProcessA
            // WaitForSingleObject(hProcess=[sp+0xA8], INFINITE=-1)
            emit_a64_ldr(0, 31, 0xA8)
            emit_a64_mov_imm(1, 0xFFFFFFFF)
            emit_a64_win_call_iat(10)  // WaitForSingleObject
            // GetExitCodeProcess(hProcess, &exitCode)
            emit_a64_ldr(0, 31, 0xA8)
            emit_a64_add_imm(1, 31, 0x20)
            emit_a64_win_call_iat(11)  // GetExitCodeProcess (slot 11 on ARM64?)
            // ExitProcess(exitCode)
            emit_a64_ldr32(0, 31, 0x20)
            emit_a64_add_sp_imm(0xD0)
            emit_a64_win_call_iat(0)   // ExitProcess
