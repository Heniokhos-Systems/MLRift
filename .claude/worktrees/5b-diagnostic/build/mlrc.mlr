        uint64 path_r = ir_a64_resolve_src(s1_v, 9)
        if target_os == 0 || target_os == 3 {
            // Linux/Android: fchmodat(AT_FDCWD=-100, path, 0755, 0)
            emit_a64_mov_imm(0, 0xFFFFFFFFFFFFFF9C)  // AT_FDCWD = -100
            emit_a64_mov(1, path_r)
            emit_a64_mov_imm(2, 0x1ED)               // 0755 octal
            emit_a64_mov_imm(3, 0)                    // flags = 0
            uint64 chmod_nr = ir_a64_syscall_nr(90)
            emit_a64_syscall_nr(chmod_nr)
            emit_a64_svc()
        } else if target_os == 1 {
            // macOS: chmod(path, 0755) — syscall 15
            emit_a64_mov(0, path_r)
            emit_a64_mov_imm(1, 0x1ED)
            uint64 chmod_nr_m = ir_a64_syscall_nr(15)
            emit_a64_syscall_nr(chmod_nr_m)
            emit_a64_svc()
        }
        return
    }

    // ----- IR_TIME_NS (119): clock_gettime -> nanoseconds -----
    if op == 119 {
        if target_os == 0 || target_os == 3 {
            // Linux / Android arm64: clock_gettime(CLOCK_MONOTONIC=1, &ts)
            // via syscall 113. Returns {tv_sec, tv_nsec} into a 16-byte
            // scratchpad slot.
            emit_a64_mov_imm(1, ir_a64_scratch_off)
            ir_a64_add_sp_reg(1, 1)
            emit_a64_mov_imm(0, 1)
            uint64 cgt_nr = ir_a64_syscall_nr(228)
            emit_a64_syscall_nr(cgt_nr)
            emit_a64_svc()
            emit_a64_mov_imm(11, ir_a64_scratch_off)
            ir_a64_add_sp_reg(11, 11)
            emit_a64_ldr(9, 11, 0)
            emit_a64_ldr(10, 11, 8)
            emit_a64_mov_imm(11, 1000000000)
            emit_a64_mul(9, 9, 11)
            emit_a64_add(0, 9, 10)
        } else if target_os == 1 {
            // macOS arm64: gettimeofday(&tv, NULL), x16=116, svc #0x80.
            // timeval = { tv_sec: i64, tv_usec: i64 }. Matches the
            // legacy codegen at src/codegen_aarch64.kr:3539. Without
            // this, the IR path was issuing clock_gettime-as-Linux
            // syscall 228 on Darwin, which is an invalid syscall that
            // silently returned 0 in x0 — so every time_ns() on
            // native arm64 macOS came back zero and the compiler's
            // '(X.XX ms)' self-timer stayed hidden.
            emit_a64_mov_imm(0, ir_a64_scratch_off)
            ir_a64_add_sp_reg(0, 0)
            emit_a64_mov_imm(1, 0)
            emit_a64_mov_imm(16, 116)
            emit_a64_svc()
            emit_a64_mov_imm(11, ir_a64_scratch_off)
            ir_a64_add_sp_reg(11, 11)
            emit_a64_ldr(9, 11, 0)
            emit_a64_ldr(10, 11, 8)
            emit_a64_mov_imm(11, 1000000000)
            emit_a64_mul(9, 9, 11)
            emit_a64_mov_imm(11, 1000)
            emit_a64_mul(10, 10, 11)
            emit_a64_add(0, 9, 10)
        } else if target_os == 2 {
            // Windows arm64: QueryPerformanceFrequency(&freq),
            // QueryPerformanceCounter(&counter), then counter * 1e9 / freq
            // computed as (counter / freq) * 1e9 + ((counter % freq) * 1e9) / freq
            // so the multiplication can't overflow uint64 (counter on a
            // box with ~29 days of uptime × 1e9 already wraps).
            // Reserve 16 bytes on the scratchpad for the two qwords that
            // QueryPerformance* writes. Same layout the legacy codegen
            // uses — ir_a64_scratch_off points past the spill slots.
            emit_a64_mov_imm(1, ir_a64_scratch_off)
            ir_a64_add_sp_reg(1, 1)               // x1 = &scratch
            emit_a64_mov(0, 1)                    // x0 = &scratch (freq)
            emit_a64_win_call_iat(15)             // QueryPerformanceFrequency
            emit_a64_mov_imm(1, ir_a64_scratch_off + 8)
            ir_a64_add_sp_reg(1, 1)               // x1 = &scratch+8
            emit_a64_mov(0, 1)                    // x0 = &scratch+8 (counter)
            emit_a64_win_call_iat(14)             // QueryPerformanceCounter
            // x11 = &scratch, reload after the IAT clobber (same pattern
            // that bit us in daa1689's file_size fix).
            emit_a64_mov_imm(11, ir_a64_scratch_off)
            ir_a64_add_sp_reg(11, 11)
            emit_a64_ldr(12, 11, 0)               // x12 = freq
            emit_a64_ldr(13, 11, 8)               // x13 = counter
            emit_a64_udiv(9, 13, 12)              // x9  = counter / freq (secs)
            emit_a64_msub(10, 9, 12, 13)          // x10 = counter - secs*freq (frac)
            emit_a64_mov_imm(14, 1000000000)
            emit_a64_mul(9, 9, 14)                // x9  = secs * 1e9
            emit_a64_mul(10, 10, 14)              // x10 = frac * 1e9
            emit_a64_udiv(10, 10, 12)             // x10 = frac*1e9 / freq
            emit_a64_add(0, 9, 10)                // x0  = secs*1e9 + frac*1e9/freq
        } else {
            emit_a64_mov_imm(0, 0)
        }
        if dst_r != 0xFFFFFFFF && dst_r != 0 {
            emit_a64_mov(dst_r, 0)
        }
        if dst_r == 0xFFFFFFFF {
            ir_a64_emit_store_spill(0, dest_v)
        }
        return
