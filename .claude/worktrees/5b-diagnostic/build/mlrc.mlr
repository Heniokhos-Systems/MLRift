    }

    // ----- IR_VSTORE (94): volatile store — stlr on ARM64 -----
    if op == 94 {
        uint64 addr_reg = ir_a64_resolve_src(s1_v, 9)
        uint64 val_reg = ir_a64_resolve_src(s2_v, 10)
        // STLR Xt, [Xn]: 0xC89FFC00 | (Xn << 5) | Xt
        uint64 vs = 0xC89FFC00 | (addr_reg << 5) | val_reg
        emit_a64(vs)
        return
    }

    // ----- IR_VLOAD (95): volatile load — ldar on ARM64 -----
    if op == 95 {
        uint64 addr_reg = ir_a64_resolve_src(s1_v, 9)
        uint64 d = dst_r
        if d == 0xFFFFFFFF { d = 9 }
        // LDAR Xt, [Xn]: 0xC8DFFC00 | (Xn << 5) | Xt
        uint64 vl = 0xC8DFFC00 | (addr_reg << 5) | d
        emit_a64(vl)
