        // dropped us onto the unconditional `B done` and skipped the
        // MOVZ d=0, so memcmp always returned the pre-loop value 1
        // (thus == true for every non-equal struct).
        emit_a64(0x54000081)    // B.NE +4
        emit_a64(0xD1000442)    // SUB x2, x2, #1
        uint64 mc_back = mc_loop - out_len
        emit_a64(0x14000000 | ((mc_back / 4) & 0x3FFFFFF))
        // B done (+2)
        emit_a64(0x14000002)
        // not_equal:
        emit_a64_mov_imm(d, 0)
        // done:
        if dst_r == 0xFFFFFFFF {
            ir_a64_emit_store_spill(9, dest_v)
        }
        return
