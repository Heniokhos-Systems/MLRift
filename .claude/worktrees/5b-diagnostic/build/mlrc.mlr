    uint64 a1 = args_desc + 8;   unsafe { *(a1 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a2 = args_desc + 16;  unsafe { *(a2 as uint64) = 8 }
    uint64 a3 = args_desc + 24;  unsafe { *(a3 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a4 = args_desc + 32;  unsafe { *(a4 as uint64) = 8 }
    uint64 a5 = args_desc + 40;  unsafe { *(a5 as uint64) = AMD_ARG_KIND_BY_VALUE }
    uint64 a6 = args_desc + 48;  unsafe { *(a6 as uint64) = 8 }
    uint64 a7 = args_desc + 56;  unsafe { *(a7 as uint64) = AMD_ARG_KIND_BY_VALUE }
}

@export
fn emit_amdgpu_transpose_f32_blob(uint64 out_path) -> uint64 {
    uint64[8] args_desc
    _emit_transpose_f32_body(args_desc)
    // group_segment_size = 1088 bytes (17 × 16 × 4 LDS tile with +1 padding).
    uint64 size = emit_amdgpu_code_object_lds("transpose_f32", 13,
                                               asm_text_buf, asm_text_len,
                                               32, 8, 24, 10,
                                               0xE0AF0001, 0x0000009E, 0x00000010, 0x0408,
                                               args_desc, 4,
                                               1088)
    uint64 fd = file_open(out_path, 1)
    if fd > 0xFFFFFFFFFFFFF000 {
        write(2, "emit_amdgpu_transpose_f32_blob: cannot open output\n", 51)
        return 1
    }
    file_write(fd, amd_buf, size)
    file_close(fd)
    return 0
}
@export
fn emit_amdgpu_embedding_lookup_f32_blob(uint64 out_path) -> uint64 {
    uint64[8] args_desc
    _emit_embedding_lookup_f32_body(args_desc)
    uint64 size = emit_amdgpu_code_object_lds("embedding_lookup_f32", 20,
                                               asm_text_buf, asm_text_len,
                                               32, 8, 18, 7,
                                               0xE0AF0001, 0x0000009E, 0x00000010, 0x0408,
                                               args_desc, 4,
                                               0)
    uint64 fd = file_open(out_path, 1)
    if fd > 0xFFFFFFFFFFFFF000 {
        write(2, "emit_amdgpu_embedding_lookup_f32_blob: cannot open output\n", 58)
        return 1
    }
    file_write(fd, amd_buf, size)
    file_close(fd)
    return 0
}


// LLM Phase 2 — argmax_logits_f32: out[seq] = argmax_v(logits[seq, V]).
// One workgroup per row, single wave32 (block=32).  Each lane scans a
// strided slice of V; lane 0 then collects per-lane (best_val, best_idx)
// via 31× v_readlane and emits the row-global argmax.  No LDS, no
// s_barrier.  Sufficient for batch-of-1 generation; for V≥1M or
// batch≫1, a 256-way LDS reduction would be more efficient.
//
// Kernarg layout (32 bytes, 4 args):
//   [0x00] uint64 logits_ptr  (f32[seq, V])  → s4,s5
//   [0x08] uint64 out_ptr     (uint32[seq])  → s6,s7
//   [0x10] uint64 V                          → s8 (low 32 used)
//   [0x18] uint64 unused                     → padding for arg-slot alignment
