    // Float arithmetic: FADD(20), FSUB(21), FMUL(22), FDIV(23)
    // imm holds float kind: 1=f64, 2=f32
    // Values are bit patterns in GPRs; move to xmm for computation, back to GPR
    if op >= 20 && op <= 23 {
        uint64 a_reg = ir_resolve_src(s1_v, 0)
        uint64 b_reg = ir_resolve_src(s2_v, 1)
        uint64 fk = imm
        // movq xmm0, a_reg: 66 48 0F 6E C0 (rax->xmm0)
        ir_emit_mov_r64_r64(0, a_reg)
        emit_byte(0x66); emit_byte(0x48); emit_byte(0x0F); emit_byte(0x6E); emit_byte(0xC0)
        // movq xmm1, b_reg: 66 48 0F 6E C8 (rax->xmm1)
        ir_emit_mov_r64_r64(0, b_reg)
        emit_byte(0x66); emit_byte(0x48); emit_byte(0x0F); emit_byte(0x6E); emit_byte(0xC8)
        // Perform operation
        if fk == 2 {
            // f32 ops: prefix F3
            if op == 20 { emit_byte(0xF3); emit_byte(0x0F); emit_byte(0x58); emit_byte(0xC1) } // addss
            if op == 21 { emit_byte(0xF3); emit_byte(0x0F); emit_byte(0x5C); emit_byte(0xC1) } // subss
            if op == 22 { emit_byte(0xF3); emit_byte(0x0F); emit_byte(0x59); emit_byte(0xC1) } // mulss
            if op == 23 { emit_byte(0xF3); emit_byte(0x0F); emit_byte(0x5E); emit_byte(0xC1) } // divss
        } else {
            // f64 ops: prefix F2
            if op == 20 { emit_byte(0xF2); emit_byte(0x0F); emit_byte(0x58); emit_byte(0xC1) } // addsd
            if op == 21 { emit_byte(0xF2); emit_byte(0x0F); emit_byte(0x5C); emit_byte(0xC1) } // subsd
            if op == 22 { emit_byte(0xF2); emit_byte(0x0F); emit_byte(0x59); emit_byte(0xC1) } // mulsd
            if op == 23 { emit_byte(0xF2); emit_byte(0x0F); emit_byte(0x5E); emit_byte(0xC1) } // divsd
        }
