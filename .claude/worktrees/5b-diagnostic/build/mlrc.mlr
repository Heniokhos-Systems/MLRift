    // ----- IR_PHI (60): no-op (handled by regalloc) -----

    // ----- IR_ATOMIC_STORE (90): stlr Xt, [Xn] (store-release) -----
    if op == 90 {
        uint64 ptr_r = ir_a64_resolve_src(s1_v, 9)
        uint64 val_r = ir_a64_resolve_src(s2_v, 10)
        // STLR Xt, [Xn]: 0xC89FFC00 | (Xn << 5) | Xt
        uint64 stlr = 0xC89FFC00 | (ptr_r << 5) | val_r
        emit_a64(stlr)
        return
    }

    // ----- IR_ATOMIC_LOAD (91): ldar Xt, [Xn] (load-acquire) -----
    if op == 91 {
        uint64 ptr_r = ir_a64_resolve_src(s1_v, 9)
        uint64 d = dst_r
        if d == 0xFFFFFFFF { d = 9 }
        // LDAR Xt, [Xn]: 0xC8DFFC00 | (Xn << 5) | Xt
        uint64 ldar = 0xC8DFFC00 | (ptr_r << 5) | d
        emit_a64(ldar)
        if dst_r == 0xFFFFFFFF {
            ir_a64_emit_store_spill(9, dest_v)
        }
        return
    }

    // ----- IR_ATOMIC_ADD (92): ldaxr/add/stlxr retry loop -----
    if op == 92 {
        uint64 ptr_r = ir_a64_resolve_src(s1_v, 10)
        uint64 val_r = ir_a64_resolve_src(s2_v, 11)
        // retry:
        uint64 aa_retry = out_len
        // LDAXR x9, [ptr_r] — x9 holds the OLD value (what we must return)
        emit_a64(0xC85FFC00 | (ptr_r << 5) | 9)
        // Compute new value in x13. x86's `xadd` returns the pre-add value;
        // the old code wrote the new value into x9 and returned that,
        // flipping the semantic (atomic_add(40,10) returned 50 instead of 40).
        emit_a64_add(13, 9, val_r)
        // STLXR w12, x13, [ptr_r] — store the NEW value back
        emit_a64(0xC800FC00 | (12 << 16) | (ptr_r << 5) | 13)
        // CBNZ w12, retry (32-bit CBNZ for status register)
        uint64 aa_back = aa_retry - out_len
        emit_a64(0x35000000 | (((aa_back / 4) & 0x7FFFF) << 5) | 12)
        // x9 still holds the old value — that's the return.
        if dst_r != 0xFFFFFFFF {
            emit_a64_mov(dst_r, 9)
        } else {
            ir_a64_emit_store_spill(9, dest_v)
        }
        return
    }

    // ----- IR_ATOMIC_CAS (93): ldaxr/cmp/b.ne/stlxr retry loop -----
    if op == 93 {
        uint64 ptr_r = ir_a64_resolve_src(s1_v, 10)
        uint64 exp_r = ir_a64_resolve_src(s2_v, 11)
        // desired is in imm (vreg index)
        uint64 des_r = 0
        if imm > 0 && imm < ir_vreg_next {
            des_r = ir_get_phys_reg(imm)
            if des_r == 0xFFFFFFFF {
                ir_a64_load_spill(13, imm)
                des_r = 13
            }
        }
        // retry:
        uint64 cas_retry = out_len
        // LDAXR x9, [ptr_r]                                    (+0)
        emit_a64(0xC85FFC00 | (ptr_r << 5) | 9)
        // CMP x9, exp_r (SUBS xzr, x9, exp_r)                  (+1)
        emit_a64_cmp(9, exp_r)
        // B.NE fail — need +5 insns (STLXR, CBNZ, MOVZ d=1,
        // B done, then FAIL = MOVZ d=0). imm19=5 → 0x540000A1.
        // The old constant 0x54000061 encoded imm19=3, which landed
        // exactly on "Success: MOVZ d=1" — so CAS always reported
        // success, even when the compare mismatched.
        emit_a64(0x540000A1)                                    // (+2)
        // STLXR w12, des_r, [ptr_r]                            (+3)
        emit_a64(0xC800FC00 | (12 << 16) | (ptr_r << 5) | des_r)
        // CBNZ w12, retry                                      (+4)
        uint64 cas_back = cas_retry - out_len
        emit_a64(0x35000000 | (((cas_back / 4) & 0x7FFFF) << 5) | 12)
        // Success: result = 1                                  (+5)
        uint64 cas_d = dst_r
        if cas_d == 0xFFFFFFFF { cas_d = 9 }
        emit_a64_mov_imm(cas_d, 1)
        // B done (+2 insns = 8 bytes)                          (+6)
        emit_a64(0x14000002)
        // fail: result = 0                                     (+7)
        emit_a64_mov_imm(cas_d, 0)
        // done:                                                (+8)
        if dst_r == 0xFFFFFFFF {
            ir_a64_emit_store_spill(9, dest_v)
