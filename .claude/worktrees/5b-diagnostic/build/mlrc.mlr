            emit_a64_mov(20, argv_r)
            emit_a64_sub_sp_imm(0x4D0)
            emit_a64_mov_imm(9, 0)
            uint64 zi2 = 0
            while zi2 < 16 {
                emit_a64_str(9, 31, 0x40 + zi2 * 8)
                zi2 = zi2 + 1
            }
            emit_a64_mov_imm(9, 104)
            emit_a64_str32(9, 31, 0x40)
            // ---- Build space-separated cmdline at sp+0xD0 ----
            // No quoting — our child parser splits on 0x20 without
            // stripping quotes (src/main.kr:21 win_init_args).
            // x9 = write ptr, x20 = argv walk, x10 = arg*, x11 = byte
            emit_a64_add_imm(9, 31, 0xD0)
            // L_outer (+0): ldr x10,[x20]; cbz x10,L_done (+48)
            emit_a64_ldr(10, 20, 0)
            emit_a64_cbz(10, 48)
            // L_inner (+8): ldrb w11,[x10]; cbz x11,L_end_copy (+20)
            emit_a64_ldrb(11, 10, 0)
            emit_a64_cbz(11, 20)
            emit_a64_strb(11, 9, 0)
            emit_a64_add_imm(10, 10, 1)
            emit_a64_add_imm(9, 9, 1)
            emit_a64(0x17FFFFFB)                // b L_inner (-20)
            // L_end_copy (+32): space + advance
            emit_a64_mov_imm(11, 0x20)
            emit_a64_strb(11, 9, 0)
            emit_a64_add_imm(9, 9, 1)
            emit_a64_add_imm(20, 20, 8)
            emit_a64(0x17FFFFF4)                // b L_outer (-48)
            // L_done (+52): null-terminate
            emit_a64_strb(31, 9, 0)
            // ---- CreateProcessA ----
            emit_a64_mov(0, 19)                 // x0 = path
            emit_a64_add_imm(1, 31, 0xD0)       // x1 = cmdline
            emit_a64_mov_imm(2, 0)
            emit_a64_mov_imm(3, 0)
            emit_a64_mov_imm(4, 0)
            emit_a64_mov_imm(5, 0)
            emit_a64_mov_imm(6, 0)
            emit_a64_mov_imm(7, 0)
            emit_a64_add_imm(9, 31, 0x40)
            emit_a64_str(9, 31, 0)
            emit_a64_add_imm(9, 31, 0xA8)
            emit_a64_str(9, 31, 8)
            emit_a64_win_call_iat(9)
            emit_a64_ldr(0, 31, 0xA8)
            emit_a64_mov_imm(1, 0xFFFFFFFF)
            emit_a64_win_call_iat(10)
            emit_a64_ldr(0, 31, 0xA8)
            emit_a64_add_imm(1, 31, 0x20)
            emit_a64_win_call_iat(11)
            emit_a64_ldr32(0, 31, 0x20)
            emit_a64_add_sp_imm(0x4D0)
            emit_a64_win_call_iat(0)
