        emit_byte(0x0F)
        if op == 14 { emit_byte(0x94) }  // sete
        if op == 15 { emit_byte(0x95) }  // setne
        if op == 16 { emit_byte(0x92) }  // setb  (unsigned <)
        if op == 17 { emit_byte(0x96) }  // setbe (unsigned <=)
        if op == 18 { emit_byte(0x97) }  // seta  (unsigned >)
        if op == 19 { emit_byte(0x93) }  // setae (unsigned >=)
        emit_byte(0xC0)
        // movzx rax, al: 48 0F B6 C0
        emit_byte(0x48)
        emit_byte(0x0F)
        emit_byte(0xB6)
        emit_byte(0xC0)
        // Move result to dst
        if dst_r != 0xFFFFFFFF {
            ir_emit_mov_r64_r64(dst_r, 0)
        } else {
            ir_emit_store_spill(0, dest_v)
        }
        return
    }

    // Signed comparisons (IR_SCMP_LT=120 through IR_SCMP_GE=123)
    if op >= 120 && op <= 123 {
        uint64 a_reg = ir_resolve_src(s1_v, 0)
        if s2_v == 0 {
            ir_emit_cmp_r64_imm(a_reg, imm)
        } else {
            uint64 b_reg = ir_resolve_src(s2_v, 1)
            ir_emit_cmp_r64_r64(a_reg, b_reg)
        }
        uint64 fuse_s = ir_cmp_fuse_code(ii)
        if fuse_s != 0 {
            ir_fused_jcc_code = fuse_s
            return
        }
        emit_byte(0x0F)
        if op == 120 { emit_byte(0x9C) }  // setl  (signed <)
        if op == 121 { emit_byte(0x9E) }  // setle (signed <=)
        if op == 122 { emit_byte(0x9F) }  // setg  (signed >)
        if op == 123 { emit_byte(0x9D) }  // setge (signed >=)
        emit_byte(0xC0)
        emit_byte(0x48); emit_byte(0x0F); emit_byte(0xB6); emit_byte(0xC0)
        if dst_r != 0xFFFFFFFF {
            ir_emit_mov_r64_r64(dst_r, 0)
        } else {
            ir_emit_store_spill(0, dest_v)
        }
        return
    }

    if op == 30 {
        // IR_LOAD: dest = *(src1), width in imm or src2 (1, 2, 4, or 8)
        uint64 addr_reg = ir_resolve_src(s1_v, 1)
        // Width can be in imm or src2 (for struct field loads)
        if imm == 0 && s2_v != 0 { imm = s2_v }
