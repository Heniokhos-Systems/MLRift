        return
    }

    // ----- IR_FMT_F64 (125): format f64 as "[sign][int].[6frac]" -----
    // src1=buf, src2=f64-bits, dest=length
    // Registers: x9=buf_ptr, x10=len, x11=temp/int_part, x12=digit_scratch,
    //            x13=divisor10, x14=digit_count/pad, x15=saved_count
    // Float: d0=working_val, d1=constant, d2=saved abs_val
    if op == 125 {
        uint64 ff_buf  = ir_a64_resolve_src(s1_v, 9)
        uint64 ff_val  = ir_a64_resolve_src(s2_v, 10)
        uint64 d = dst_r
        if d == 0xFFFFFFFF { d = 9 }

        // Set x9 = buf (safe, ff_val might be in x10 — do NOT set x10 yet)
        emit_a64_mov(9, ff_buf)

        // Load f64 bits into d0: fmov d0, ff_val (before possibly clobbering ff_val)
        emit_a64(0x9E670000 | (ff_val << 5) | 0)   // fmov d0, ff_val

        // Extract bits back to x11 for sign check: fmov x11, d0
        emit_a64(0x9E660000 | (0 << 5) | 11)        // fmov x11, d0

        // Now safe to set x10 = len = 0 (ff_val bits are in x11 and d0)
        emit_a64_mov_imm(10, 0)

        // Sign check via bit 63 of x11: TST x11, sign_mask
        // Load sign mask 0x8000000000000000 into x13 (2 insns: MOVZ+MOVK)
        emit_a64_mov_imm(13, 0x8000000000000000)    // 2 insns; x13 reused as divisor10 later
        // ANDS XZR, x11, x13 — sets flags; ZR==1 means non-negative
        emit_a64(0xEA000000 | (13 << 16) | (11 << 5) | 31)  // TST x11, x13
        // B.EQ .ff_pos (cond=0=EQ, non-negative → skip neg path)
        // neg path = FNEG(1)+mov_imm_minus(1)+strb(1)+add9(1)+add10(1) = 5 insns=20 bytes
        // .ff_pos is at B_PC + 4 + 20 = B_PC + 24
        emit_a64_bcond(0, 24)                       // B.EQ .ff_pos
        // Negative: negate d0, write '-', update x9 and x10
        emit_a64(0x1E614000)                        // FNEG d0, d0
        emit_a64_mov_imm(11, 0x2D)                  // '-' = 45 (1 insn)
        emit_a64_strb(11, 9, 0)                     // STRB W11, [X9]
        emit_a64_add_imm(9, 9, 1)                   // x9++
        emit_a64_add_imm(10, 10, 1)                 // x10++
        // .ff_pos: check for big value
        // Load 1e18 = 0x4DE0B6B3A7640000 into x11, fmov d1, x11 (4+1=5 insns)
        emit_a64_mov_imm(11, 0x43ABC16D674EC800)    // 1e18 IEEE bits; 4 insns
        emit_a64(0x9E670000 | (11 << 5) | 1)        // fmov d1, x11
        // FCMP d0, d1
        emit_a64(0x1E602000 | (1 << 16) | (0 << 5)) // fcmp d0, d1
        // B.HS .ff_big (cond=2=HS=C set): val>=1e18 or NaN → big. PATCH LATER.
        emit_a64_bcond(2, 0)                        // placeholder; patched below
        uint64 ff_bhs_off = out_len - 4

        // .ff_normal path starts here
        // Integer part: FCVTZS x11, d0 (truncate to int)
        emit_a64(0x9E780000 | (0 << 5) | 11)        // fcvtzs x11, d0
        // Save abs_val in d2: FMOV d2, d0 (1E604002)
        emit_a64(0x1E604000 | (0 << 5) | 2)         // fmov d2, d0

        // Setup integer formatting: x12=digit_scratch, x13=10, x14=0
        emit_a64_mov_imm(12, ir_a64_scratch_off)
        ir_a64_add_sp_reg(12, 12)
        emit_a64_mov_imm(13, 10)
        emit_a64_mov_imm(14, 0)

        // Digit extraction loop: divide by 10, store remainder+0x30 at [x12+x14]
        uint64 ff_uint_loop = out_len
        emit_a64_udiv(4, 11, 13)                    // x4 = x11 / 10
        emit_a64_msub(5, 4, 13, 11)                 // x5 = x11 - x4*10 (digit)
        emit_a64_add_imm(5, 5, 48)                  // x5 += '0'
        // STRB W5, [X12, X14] — register offset (unscaled)
        emit_a64(0x38206800 | (14 << 16) | (12 << 5) | 5)
        emit_a64_add_imm(14, 14, 1)
        emit_a64_mov(11, 4)
        uint64 ff_uint_back = ff_uint_loop - out_len
        emit_a64(0xB5000000 | (((ff_uint_back / 4) & 0x7FFFF) << 5) | 11)  // CBNZ x11, loop

        // Reverse copy to [x9]: x15 = digit count
        emit_a64_mov(15, 14)
        uint64 ff_copy_loop = out_len
        emit_a64_cbz(14, 20)                        // CBZ x14, copy_done (5 insns=20 bytes)
        emit_a64(0xD1000400 | (14 << 5) | 14)       // SUB x14, x14, #1
        emit_a64(0x38606800 | (14 << 16) | (12 << 5) | 5)  // LDRB W5, [X12, X14]
        emit_a64(0x38001525)                        // STRB W5, [X9], #1 (post-index x9)
        uint64 ff_copy_back = ff_copy_loop - out_len
        emit_a64(0x14000000 | ((ff_copy_back / 4) & 0x3FFFFFF))  // B copy_loop
        // copy_done:
        emit_a64_add(10, 10, 15)                    // x10 += int_len (x15)

        // Write '.' at [x9], then x9++, x10++
        emit_a64_mov_imm(11, 0x2E)
        emit_a64_strb(11, 9, 0)
        emit_a64_add_imm(9, 9, 1)
        emit_a64_add_imm(10, 10, 1)

        // Recompute frac: fcvtzs x11, d2 → scvtf d1, x11 → fsub d0, d2, d1
        emit_a64(0x9E780000 | (2 << 5) | 11)        // fcvtzs x11, d2
        emit_a64(0x9E620000 | (11 << 5) | 1)        // scvtf d1, x11
        emit_a64(0x1E603800 | (1 << 16) | (2 << 5) | 0)  // fsub d0, d2, d1

        // Multiply by 1e6, truncate to int → frac_int in x11
        emit_a64_mov_imm(11, 0x412E848000000000)    // 1e6 IEEE bits; 4 insns
        emit_a64(0x9E670000 | (11 << 5) | 1)        // fmov d1, x11
        emit_a64(0x1E600800 | (1 << 16) | (0 << 5) | 0)  // fmul d0, d0, d1
        emit_a64(0x9E780000 | (0 << 5) | 11)        // fcvtzs x11, d0  → frac_int

        // Count digits in x11: x4=working, x14=count
        emit_a64_mov(4, 11)
        emit_a64_mov_imm(14, 0)
        emit_a64_cbz(4, 24)                         // CBZ x4, .ff_fz (5 insns+B = 24 bytes to .ff_fz)
        uint64 ff_cnt_loop = out_len
        emit_a64_udiv(5, 4, 13)
        emit_a64_add_imm(14, 14, 1)
        emit_a64_mov(4, 5)
        uint64 ff_cnt_back = ff_cnt_loop - out_len
        emit_a64(0xB5000000 | (((ff_cnt_back / 4) & 0x7FFFF) << 5) | 4)  // CBNZ x4, cnt_loop
        emit_a64_b(8)                               // B .ff_have_digits (skip .ff_fz = 1 insn = 8 bytes from B)
        // .ff_fz: frac_int=0 → digit_count=1
        emit_a64_mov_imm(14, 1)                     // 1 insn
        // .ff_have_digits: pad = 6 - x14 (always 0..5; no need for neg check since count ∈ 1..6)
        emit_a64_mov_imm(15, 6)
        emit_a64_sub(15, 15, 14)                    // x15 = pad
        // Pad zero loop. Body = 5 insns (mov+strb+add+sub+b). Use x3 as
        // the byte-constant scratch rather than x11: x11 holds frac_int
        // and is re-read by the fi_loop below. The earlier version used
        // `mov_imm x11, 48` which clobbered frac_int with the ASCII code
        // 0x30, so fi_loop then decomposed 48 into "84" — visible in
        // `println(1.0)` as "1.000004" (the trailing '8' got sliced off
        // by the `write(len)` call but the '4' landed). Also DO NOT
        // `add x10, x10, 1` here; the final `add x10, x10, 6` below
        // already accounts for every fraction byte.
        uint64 ff_pad_loop = out_len
        emit_a64_cbz(15, 24)                        // CBZ x15, pad_done (6 insns=24 bytes)
        emit_a64_mov_imm(3, 0x30)                   // x3 = '0'
        emit_a64_strb(3, 9, 0)
        emit_a64_add_imm(9, 9, 1)
        emit_a64(0xD1000400 | (15 << 5) | 15)       // SUB x15, x15, #1
        uint64 ff_pad_back = ff_pad_loop - out_len
        emit_a64(0x14000000 | ((ff_pad_back / 4) & 0x3FFFFFF))  // B pad_loop
        // pad_done:

        // Format frac_int (x11) into [x9]: digit extract + reverse copy
        emit_a64_mov_imm(14, 0)
        uint64 ff_fi_loop = out_len
        emit_a64_udiv(4, 11, 13)
        emit_a64_msub(5, 4, 13, 11)
        emit_a64_add_imm(5, 5, 48)
        emit_a64(0x38206800 | (14 << 16) | (12 << 5) | 5)
        emit_a64_add_imm(14, 14, 1)
        emit_a64_mov(11, 4)
        uint64 ff_fi_back = ff_fi_loop - out_len
        emit_a64(0xB5000000 | (((ff_fi_back / 4) & 0x7FFFF) << 5) | 11)  // CBNZ x11, fi_loop

        uint64 ff_fi_copy = out_len
        emit_a64_cbz(14, 20)                        // CBZ x14, fi_done (5 insns=20 bytes)
        emit_a64(0xD1000400 | (14 << 5) | 14)       // SUB x14, x14, #1
        emit_a64(0x38606800 | (14 << 16) | (12 << 5) | 5)  // LDRB W5, [X12, X14]
        emit_a64(0x38001525)                        // STRB W5, [X9], #1
        uint64 ff_fi_back2 = ff_fi_copy - out_len
        emit_a64(0x14000000 | ((ff_fi_back2 / 4) & 0x3FFFFFF))
        // fi_done: x10 += 6 (pad + frac digits always total 6)
        emit_a64_add_imm(10, 10, 6)

        // Jump over big path: big path = 7 insns × 4 = 28 bytes, then .ff_end
        // B at PC, big path at PC+4 (7 insns=28 bytes), ff_end at PC+32
        emit_a64_b(32)                              // B .ff_end

        // .ff_big: patch B.HS, then write "big", add 3 to len
        uint64 ff_big = out_len
        uint64 ff_bhs_disp = ff_big - ff_bhs_off
        uint64 ff_bhs_p = out_buf + ff_bhs_off
        uint64 ff_bhs_rel19 = (ff_bhs_disp / 4) & 0x7FFFF
        uint64 ff_bhs_insn = 0x54000002 | (ff_bhs_rel19 << 5)  // B.HS, cond=2
        uint32 ff_bhs_insn32 = ff_bhs_insn
        unsafe { *(ff_bhs_p as uint32) = ff_bhs_insn32 }
        // Write 'b', 'i', 'g'
        emit_a64_mov_imm(11, 0x62)
        emit_a64_strb(11, 9, 0)
        emit_a64_mov_imm(11, 0x69)
        emit_a64_strb(11, 9, 1)
        emit_a64_mov_imm(11, 0x67)
        emit_a64_strb(11, 9, 2)
        emit_a64_add_imm(10, 10, 3)
        // .ff_end:
        emit_a64_mov(d, 10)
        if dst_r == 0xFFFFFFFF { ir_a64_emit_store_spill(9, dest_v) }
        return
    }
}

// ---------------------------------------------------------------------------
// Function-level emitter
// ---------------------------------------------------------------------------

@export
fn ir_emit_arm64_function(uint64 fn_node) {
    // Check for @naked attribute
    uint32 ann_flags = ast_data4(fn_node)
    uint64 is_naked = ann_flags & 2

    // Extern declarations: skip codegen (see ir_emit_x86_function).
    uint64 is_extern_ir_a = ann_flags & 8
    if is_extern_ir_a != 0 { return }

    // 1. Lower AST to IR
    ir_lower_function(fn_node)

    // 1a. Optimize
    if ir_opt_level > 0 {
        ir_optimize()
    }

    // 2. Compute liveness
    ir_compute_liveness()

    // 3. Set up ARM64 register allocator (10 regs)
    uint64 saved_num_regs = IR_NUM_REGS
    IR_NUM_REGS = 10
    ir_regalloc_init_arm64()
    ir_graph_color()

    // 4. Compute spill count
    ir_spill_count = 0
    if ir_vreg_next > IR_NUM_REGS + 1 {
        ir_spill_count = ir_vreg_next - IR_NUM_REGS - 1
    }

    // 4a. Snapshot the function's var map for DWARF (if -g)
    ir_snapshot_debug_vars()

    // NOTE: IR_NUM_REGS must stay at 10 through emission — ir_get_phys_reg()
    // uses it to distinguish colors from spills. Restore AFTER emission completes.

    // 5. Compute frame size
    // Callee-saved area: x29/x30 (16) + x19-x28 (80) = 96 bytes
    uint64 callee_save_size = 96
    uint64 spill_size = ir_spill_count * 8
    // 32-byte scratchpad for mid-function temp buffers (fmt_uint digits,
    // clock_gettime timespec, execve argv, etc). Using a fixed offset avoids
    // dynamic SP shifts that invalidate spill slot addresses.
    uint64 scratch_size = 32
    // Total frame = spill + scratch + callee save, must be 16-aligned
    // Layout from SP upward:
    //   [SP + 0 .. IR_A64_OVERFLOW_RESERVE)  — stack slots for outgoing calls' args 9+
    //   [spills ...]
    //   [scratchpad ...]
    //   [saved callee regs]
    // With the overflow reserve at the bottom, the caller can STR
    // outgoing args to [SP + offset] without any SUB — the callee
    // reads [SP + callee_frame + (idx-8)*8] = caller's arg slots.
    uint64 total_frame = IR_A64_OVERFLOW_RESERVE + spill_size + scratch_size + callee_save_size
    if (total_frame & 15) != 0 { total_frame = total_frame + 16 - (total_frame & 15) }
    if is_naked != 0 { total_frame = 0 }

    ir_frame_size = total_frame
    // Scratchpad sits right after spill slots (which start at the overflow reserve).
    ir_a64_scratch_off = IR_A64_OVERFLOW_RESERVE + spill_size

    // 5a. For main(): set up argc/argv BEFORE prologue
    uint32 fn_name_tok = ast_data1(fn_node)
    if tok_matches(fn_name_tok, "main", 4) != 0 && freestanding == 0 && target_os != 2 {
        if target_os == 1 {
            // macOS Mach-O: _main receives argc in x0, argv in x1 as function params
            uint64 argc_off_m = static_lookup_by_name("cli_argc", 8)
            if argc_off_m != 0xFFFFFFFF {
                emit_a64_static_store(argc_off_m)  // store x0 (argc)
            }
            emit_a64_mov(0, 1)  // x0 = argv (x1)
            uint64 argv_off_m = static_lookup_by_name("cli_argv", 8)
            if argv_off_m != 0xFFFFFFFF {
                emit_a64_static_store(argv_off_m)  // store x0 (was x1 = argv)
            }
        } else {
            // Linux/Android ELF: argc/argv on stack. [SP]=argc, [SP+8]=&argv[0]
            emit_a64_ldr(0, 31, 0)
            uint64 argc_off = static_lookup_by_name("cli_argc", 8)
            if argc_off != 0xFFFFFFFF {
                emit_a64_static_store(argc_off)
            }
            emit_a64_add_imm(0, 31, 8)
            uint64 argv_off = static_lookup_by_name("cli_argv", 8)
            if argv_off != 0xFFFFFFFF {
                emit_a64_static_store(argv_off)
            }
        }
        // envp: Linux/Android = sp + 8 + (argc+1)*8; macOS = argv + (argc+1)*8.
        // The legacy codegen populates this; the IR path was silently leaving
        // cli_envp at 0, so exec_process() forwarded envp=NULL — fine on plain
        // Linux but breaks Android bionic which needs at least LD_* vars to
        // start the child process.
        uint64 envp_off_main = static_lookup_by_name("cli_envp", 8)
        if envp_off_main != 0xFFFFFFFF {
            if target_os == 1 {
                uint64 argc_off_env = static_lookup_by_name("cli_argc", 8)
                if argc_off_env != 0xFFFFFFFF { emit_a64_static_load(argc_off_env) }
                emit_a64_mov(9, 0)
                emit_a64_add_imm(9, 9, 1)
                emit_a64_mov_imm(10, 8)
                emit_a64_mul(9, 9, 10)
                uint64 argv_off_env = static_lookup_by_name("cli_argv", 8)
                if argv_off_env != 0xFFFFFFFF { emit_a64_static_load(argv_off_env) }
                emit_a64_add(0, 0, 9)
            } else {
                emit_a64_ldr(9, 31, 0)
                emit_a64_add_imm(9, 9, 1)
                emit_a64_mov_imm(10, 8)
                emit_a64_mul(9, 9, 10)
                emit_a64_add_imm(0, 31, 8)
                emit_a64_add(0, 0, 9)
            }
            emit_a64_static_store(envp_off_main)
        }
    }
    if tok_matches(fn_name_tok, "main", 4) != 0 && freestanding == 0 && target_os == 2 {
        // Windows ARM64: GetCommandLineA via IAT
        emit_a64_win_call_iat(7)
        uint64 argv_off_w = static_lookup_by_name("cli_argv", 8)
        if argv_off_w != 0xFFFFFFFF {
            emit_a64_static_store(argv_off_w)
        }
        emit_a64_mov_imm(0, 0xFFFFFFFF)
        uint64 argc_off_w = static_lookup_by_name("cli_argc", 8)
        if argc_off_w != 0xFFFFFFFF {
            emit_a64_static_store(argc_off_w)
        }
    }

    // 6. Emit prologue (skip for @naked)
    if is_naked == 0 {
        // SUB SP, SP, #total_frame
        emit_a64_sub_sp_imm(total_frame)
        // Save FP/LR and callee-saved regs after spill+scratch area.
        // Pair them with STP — halves the instruction count vs per-reg
        // STRs. STP's offset is imm7 scaled by 8, capped at 504; fall
        // back to individual STR for large frames to stay correct.
        uint64 cs_base = IR_A64_OVERFLOW_RESERVE + spill_size + scratch_size
        uint64 fp_off = cs_base + 80
        if fp_off + 8 <= 504 {
            ir_a64_stp_sp(19, 20, cs_base)
            ir_a64_stp_sp(21, 22, cs_base + 16)
            ir_a64_stp_sp(23, 24, cs_base + 32)
            ir_a64_stp_sp(25, 26, cs_base + 48)
            ir_a64_stp_sp(27, 28, cs_base + 64)
            ir_a64_stp_sp(29, 30, fp_off)
        } else {
            ir_a64_str_sp(29, fp_off)
            ir_a64_str_sp(30, fp_off + 8)
            ir_a64_str_sp(19, cs_base)
            ir_a64_str_sp(20, cs_base + 8)
            ir_a64_str_sp(21, cs_base + 16)
            ir_a64_str_sp(22, cs_base + 24)
            ir_a64_str_sp(23, cs_base + 32)
            ir_a64_str_sp(24, cs_base + 40)
            ir_a64_str_sp(25, cs_base + 48)
            ir_a64_str_sp(26, cs_base + 56)
            ir_a64_str_sp(27, cs_base + 64)
            ir_a64_str_sp(28, cs_base + 72)
        }
    }

    // 7. Allocate branch/return fixup tracking
    //    Buffers are reused across functions — only re-alloc if a function
    //    needs more capacity than previously allocated. Without this guard
    //    every emitted function leaked ~52 KB.
    uint64 bo_need = ir_bb_count
    if bo_need < 4096 { bo_need = 4096 }
    if bo_need > ir_block_offsets_cap {
        if ir_block_offsets != 0 { dealloc(ir_block_offsets) }
        ir_block_offsets = alloc(bo_need * 8)
        ir_block_offsets_cap = bo_need
    }
    uint64 br_need = ir_bb_count * 4
    if br_need < 2048 { br_need = 2048 }
    if br_need > ir_br_fixups_cap {
        if ir_br_fixups != 0 { dealloc(ir_br_fixups) }
        ir_br_fixups = alloc(br_need * 8)
        ir_br_fixups_cap = br_need
    }
    uint64 ret_need = ir_bb_count
    if ret_need < 1024 { ret_need = 1024 }
    if ret_need > ir_ret_fixups_cap {
        if ir_ret_fixups != 0 { dealloc(ir_ret_fixups) }
        ir_ret_fixups = alloc(ret_need * 4)
        ir_ret_fixups_cap = ret_need
    }
    ir_br_fixup_count = 0
    ir_ret_fixup_count = 0

    // 8. Emit all basic blocks
    uint64 bi = 0
    while bi < ir_bb_count {
        // Record this block's code offset
        uint64 bop = ir_block_offsets + bi * 8
        unsafe { *(bop as uint64) = out_len }
        // Reset the spill-reload peephole at every BB boundary so a
        // branch target never lands mid-pattern.
        ir_a64_peephole_reset()

        // Emit non-terminator instructions
        uint64 ii = ir_bb_first_insn(bi)
        while ii != 0xFFFFFFFF {
            uint64 iop = ir_insn_opcode(ii)
            if iop != 40 && iop != 41 {
                ir_emit_arm64_insn(ii)
            }
            ii = ir_insn_next(ii)
        }

        // Emit block terminator
        uint64 last = ir_bb_last_insn(bi)
        if last != 0xFFFFFFFF {
            uint64 last_op = ir_insn_opcode(last)
            if last_op == 40 {
                // IR_BR: unconditional branch to target_bb
                uint64 target = ir_insn_imm(last)
                if target != bi + 1 {
                    // Record fixup [patch_offset, target_bb]
                    uint64 fp = ir_br_fixups + ir_br_fixup_count * 8
                    uint32 po = out_len
                    unsafe { *(fp as uint32) = po }
                    uint64 fp4 = fp + 4
                    uint32 tb = target
                    unsafe { *(fp4 as uint32) = tb }
                    ir_br_fixup_count = ir_br_fixup_count + 1
                    emit_a64(0x14000000)    // B #0 (placeholder)
                }
            }
            if last_op == 41 {
                // IR_BR_COND: cbnz cond_vreg, true_target; fallthrough or B false_target
                uint64 cond_v = ir_insn_src1(last)
                uint64 cond_r = ir_a64_resolve_src(cond_v, 9)
                uint64 target_true = ir_insn_imm(last)
                // Record fixup for CBNZ -> true target
                // We encode type=1 (CBNZ) in high bit of target_bb
                uint64 fp = ir_br_fixups + ir_br_fixup_count * 8
                uint32 po = out_len
                unsafe { *(fp as uint32) = po }
                uint64 fp4 = fp + 4
                // Encode: bit 31 = 1 for CBNZ, bits 0-30 = target_bb, store cond_r in the insn
                uint32 tb = target_true | 0x80000000
                unsafe { *(fp4 as uint32) = tb }
                ir_br_fixup_count = ir_br_fixup_count + 1
                // CBNZ cond_r, #0 (placeholder)
                emit_a64(0xB5000000 | cond_r)
                // Emit B to false target if not fall-through
                uint64 target_false = ir_bb_succ0(bi)
                if target_false != 0xFFFFFFFF && target_false != bi + 1 {
                    uint64 fp2 = ir_br_fixups + ir_br_fixup_count * 8
                    uint32 po2 = out_len
                    unsafe { *(fp2 as uint32) = po2 }
                    uint64 fp24 = fp2 + 4
                    uint32 tb2 = target_false
                    unsafe { *(fp24 as uint32) = tb2 }
                    ir_br_fixup_count = ir_br_fixup_count + 1
                    emit_a64(0x14000000)    // B #0 (placeholder)
                }
            }
        }

        bi = bi + 1
    }

    // 9. Patch branch fixups
    uint64 fi = 0
    while fi < ir_br_fixup_count {
        uint64 fp = ir_br_fixups + fi * 8
        uint32 patch_off = 0
        unsafe { *(fp as uint32) -> patch_off }
        uint64 fp4 = fp + 4
        uint32 target_bb_raw = 0
        unsafe { *(fp4 as uint32) -> target_bb_raw }
        uint64 wraw = target_bb_raw
        uint64 is_cbnz = wraw & 0x80000000
        uint64 wtb = wraw & 0x7FFFFFFF
        // Get target block offset
        uint64 tbp = ir_block_offsets + wtb * 8
        uint64 target_off = 0
        unsafe { *(tbp as uint64) -> target_off }
        uint64 wpo = patch_off
        uint64 disp = target_off - wpo
        uint64 rel = disp / 4
        if is_cbnz != 0 {
            // Patch CBNZ: read existing instruction to get Rt
            uint64 insn_addr = out_buf + wpo
            uint32 old_insn = 0
            unsafe { *(insn_addr as uint32) -> old_insn }
            uint64 wo = old_insn
            uint64 rt = wo & 0x1F
            uint64 new_insn = 0xB5000000 | ((rel & 0x7FFFF) << 5) | rt
            patch_u32(wpo, new_insn)
        } else {
            // Patch B
            uint64 new_insn = 0x14000000 | (rel & 0x3FFFFFF)
            patch_u32(wpo, new_insn)
        }
        fi = fi + 1
    }

    // 10. Patch return fixups — all point to epilogue
    uint64 epilogue_off = out_len
    uint64 ri2 = 0
    while ri2 < ir_ret_fixup_count {
        uint64 rfp = ir_ret_fixups + ri2 * 4
        uint32 rpatch = 0
        unsafe { *(rfp as uint32) -> rpatch }
        uint64 wrp = rpatch
        uint64 rdisp = epilogue_off - wrp
        uint64 rrel = rdisp / 4
        uint64 new_insn = 0x14000000 | (rrel & 0x3FFFFFF)
        patch_u32(wrp, new_insn)
        ri2 = ri2 + 1
    }

    // 11. Epilogue (skip for @naked)
    if is_naked == 0 {
        // For main(): auto-insert exit(x0) syscall. Without this, returning
        // from main() jumps to an undefined LR -> segfault. x0 already
        // holds main's return value; only zero it for void main so
        // fall-through still produces exit(0).
        if tok_matches(fn_name_tok, "main", 4) != 0 && freestanding == 0 {
            uint32 ret_type_tok_a64 = ast_data2(fn_node)
            if ret_type_tok_a64 == 0 {
                emit_a64_mov_imm(0, 0)
            }
            if target_os == 2 {
                emit_a64_win_call_iat(0)
            } else {
                if target_os == 1 { emit_a64_syscall_nr(1) } else { emit_a64_syscall_nr(93) }
                emit_a64_svc()
            }
        }
        // Restore callee-saved registers. Mirror the prologue: LDP
        // pairs when the frame fits, individual LDRs otherwise.
        uint64 cs_base_e = IR_A64_OVERFLOW_RESERVE + spill_size + scratch_size
        uint64 fp_off_e = cs_base_e + 80
        if fp_off_e + 8 <= 504 {
            ir_a64_ldp_sp(19, 20, cs_base_e)
            ir_a64_ldp_sp(21, 22, cs_base_e + 16)
            ir_a64_ldp_sp(23, 24, cs_base_e + 32)
            ir_a64_ldp_sp(25, 26, cs_base_e + 48)
            ir_a64_ldp_sp(27, 28, cs_base_e + 64)
            ir_a64_ldp_sp(29, 30, fp_off_e)
        } else {
            ir_a64_ldr_sp(19, cs_base_e)
            ir_a64_ldr_sp(20, cs_base_e + 8)
            ir_a64_ldr_sp(21, cs_base_e + 16)
            ir_a64_ldr_sp(22, cs_base_e + 24)
            ir_a64_ldr_sp(23, cs_base_e + 32)
            ir_a64_ldr_sp(24, cs_base_e + 40)
            ir_a64_ldr_sp(25, cs_base_e + 48)
            ir_a64_ldr_sp(26, cs_base_e + 56)
            ir_a64_ldr_sp(27, cs_base_e + 64)
            ir_a64_ldr_sp(28, cs_base_e + 72)
            ir_a64_ldr_sp(29, fp_off_e)
            ir_a64_ldr_sp(30, fp_off_e + 8)
        }
        // ADD SP, SP, #total_frame
        emit_a64_add_sp_imm(total_frame)
        // RET
        emit_a64_ret()
    }

    // Restore IR_NUM_REGS for x86_64 functions compiled later
    IR_NUM_REGS = saved_num_regs
}
// MLRift -- built on KernRift -- HIP (AMD/NVIDIA GPU) IR backend
//
// GPU opcode declarations for the forthcoming `format_hip.kr` emitter.
// See docs/GPU_BACKEND.md for the wider architecture; this file is the
// IR-layer counterpart to `ir_aarch64.kr` (aarch64 CPU) and the x86_64
// path in `ir.kr`.
//
// Opcodes occupy a contiguous 140-147 block. The 132-139 gap above is
// intentional — leaves CPU-side barrier/bounds ops (IR_DMB, IR_ARR_CHECK
// ending at 131) visually separate from the GPU family so the opcode
// table reads as distinct classes rather than a packed sequence.
//
// IR_KERNEL is NOT an opcode — "this function is a GPU kernel" is a
// function-level attribute set by the frontend `@kernel` parser path,
// not an instruction. It lives on the Fn struct alongside the existing
// entry/export flags. `format_hip.kr` walks kernel-flagged fns during
// codegen; x86_64/aarch64 backends skip them.

// ---------------------------------------------------------------------------
// GPU memory ops
// ---------------------------------------------------------------------------

static uint64 IR_GPU_ALLOC = 140    // dest = device ptr; src1 = byte count (hipMalloc)
static uint64 IR_GPU_FREE = 141     // free device ptr src1 (hipFree)
static uint64 IR_GPU_H2D = 142      // host->device memcpy (dst_dev, src_host, nbytes)
static uint64 IR_GPU_D2H = 143      // device->host memcpy (dst_host, src_dev, nbytes)
static uint64 IR_GPU_D2D = 144      // device->device memcpy (dst_dev, src_dev, nbytes)

// ---------------------------------------------------------------------------
// GPU control
// ---------------------------------------------------------------------------

// Variadic launch. Fixed-shape portion mirrors IR_CALL:
//   imm              = kernel fn name token (same encoding as IR_FN_ADDR)
//   src1, src2, src3 = gridX, gridY, gridZ vregs
// Preceding IR_ARG slots carry, in order:
//   blockX, blockY, blockZ, shared_bytes, stream_ptr, kernel_arg_0, ...
// This reuses the existing IR_CALL + IR_ARG variadic convention instead
// of inventing a new one for kernel launches.
static uint64 IR_KERNEL_LAUNCH = 145

static uint64 IR_GPU_SYNC = 146     // hipDeviceSynchronize (host-side)
static uint64 IR_GPU_BARRIER = 147  // __syncthreads() inside a kernel body
// MLRift — built on KernRift — Mach-O output format
//
// x86_64: Uses LC_UNIXTHREAD for direct kernel entry (no dyld dependency).
// ARM64:  Uses LC_UNIXTHREAD for direct kernel entry (no dyld dependency).
// On Apple Silicon, binaries must be ad-hoc signed with codesign -s -

// Emit Mach-O x86_64 executable header
@export
fn emit_macho_headers_x64(uint64 code_size) -> uint64 {
    uint64 header_size = 4096

    // Mach-O header (32 bytes)
    emit_u32_le(0xFEEDFACF)
    emit_u32_le(0x01000007)       // X86_64
    emit_u32_le(0x00000003)
    emit_u32_le(0x00000002)       // MH_EXECUTE
    emit_u32_le(3)                // ncmds
    emit_u32_le(72 + 72 + 184)   // sizeofcmds = 328
    emit_u32_le(0x00000001)       // flags (NOUNDEFS)
    emit_u32_le(0)

    // __PAGEZERO
    emit_u32_le(0x19); emit_u32_le(72)
    emit_byte(95); emit_byte(95); emit_byte(80); emit_byte(65)
    emit_byte(71); emit_byte(69); emit_byte(90); emit_byte(69)
    emit_byte(82); emit_byte(79); emit_byte(0); emit_byte(0)
    emit_byte(0); emit_byte(0); emit_byte(0); emit_byte(0)
    emit_u64_le(0); emit_u64_le(0x100000000)
    emit_u64_le(0); emit_u64_le(0)
    emit_u32_le(0); emit_u32_le(0); emit_u32_le(0); emit_u32_le(0)

    // __TEXT (RWX for statics)
    emit_u32_le(0x19); emit_u32_le(72)
    emit_byte(95); emit_byte(95); emit_byte(84); emit_byte(69)
    emit_byte(88); emit_byte(84); emit_byte(0); emit_byte(0)
    emit_byte(0); emit_byte(0); emit_byte(0); emit_byte(0)
    emit_byte(0); emit_byte(0); emit_byte(0); emit_byte(0)
    emit_u64_le(0x100000000)
    emit_u64_le(0)                // vmsize (patched)
    emit_u64_le(0)
    emit_u64_le(0)                // filesize (patched)
    emit_u32_le(7); emit_u32_le(7)
    emit_u32_le(0); emit_u32_le(0)

    // LC_UNIXTHREAD — x86_64 thread state (184 bytes)
    emit_u32_le(5)                // cmd = LC_UNIXTHREAD
    emit_u32_le(184)
    emit_u32_le(4)                // flavor = x86_THREAD_STATE64
    emit_u32_le(42)               // count
    // 21 uint64 registers: rax..gs, rip at index 16
    uint64 ri = 0
    while ri < 21 {
        if ri == 16 {
            emit_u64_le(0x100000000 + header_size)  // rip (patched)
        } else {
            emit_u64_le(0)
        }
        ri = ri + 1
    }

    while out_len < header_size { emit_byte(0) }
    return header_size
}

// Emit Mach-O AArch64 executable header — LC_MAIN + libSystem layout.
//
// macOS 14 arm64 refuses LC_UNIXTHREAD binaries. Needs the full dyld path:
// LC_LOAD_DYLINKER + LC_LOAD_DYLIB libSystem + LC_MAIN + LC_SYMTAB +
// LC_DYLD_CHAINED_FIXUPS + LC_BUILD_VERSION + LC_UUID. Our code still uses
// direct svc 0x80 for exit; libSystem is just listed so dyld loads us via
// the trusted boot path.
//
// Load command layout:
//   [32]   __PAGEZERO       (72)  → 104
//   [104]  __TEXT + section (152) → 256
//   [256]  __DATA           (72)  → 328
//   [328]  __LINKEDIT       (72)  → 400
//   [400]  CHAINED_FIXUPS   (16)  → 416
//   [416]  LC_SYMTAB        (24)  → 440
//   [440]  LC_DYSYMTAB      (80)  → 520
//   [520]  LC_LOAD_DYLINKER (32)  → 552
//   [552]  LC_UUID          (24)  → 576
//   [576]  LC_BUILD_VERSION (24)  → 600
//   [600]  LC_MAIN          (24)  → 624
//   [624]  LC_LOAD_DYLIB    (56)  → 680
// sizeofcmds = 648, ncmds = 12
@export
fn emit_macho_headers_a64(uint64 code_size) -> uint64 {
    uint64 header_size = 16384

    // Mach-O header (32 bytes)
    emit_u32_le(0xFEEDFACF)
    emit_u32_le(0x0100000C)       // ARM64
    emit_u32_le(0x00000000)
    emit_u32_le(0x00000002)       // MH_EXECUTE
    emit_u32_le(12)               // ncmds
    emit_u32_le(648)              // sizeofcmds
    emit_u32_le(0x00200085)       // NOUNDEFS|DYLDLINK|TWOLEVEL|PIE
    emit_u32_le(0)

    // __PAGEZERO (72 bytes, offset 32)
    emit_u32_le(0x19); emit_u32_le(72)
    emit_byte(95); emit_byte(95); emit_byte(80); emit_byte(65)
    emit_byte(71); emit_byte(69); emit_byte(90); emit_byte(69)
    emit_byte(82); emit_byte(79); emit_byte(0); emit_byte(0)
    emit_byte(0); emit_byte(0); emit_byte(0); emit_byte(0)
    emit_u64_le(0); emit_u64_le(0x100000000)
    emit_u64_le(0); emit_u64_le(0)
    emit_u32_le(0); emit_u32_le(0); emit_u32_le(0); emit_u32_le(0)

    // __TEXT segment (152 bytes = 72 header + 80 section, offset 104) — RX
    emit_u32_le(0x19); emit_u32_le(152)
    emit_byte(95); emit_byte(95); emit_byte(84); emit_byte(69)
    emit_byte(88); emit_byte(84); emit_byte(0); emit_byte(0)
    emit_byte(0); emit_byte(0); emit_byte(0); emit_byte(0)
    emit_byte(0); emit_byte(0); emit_byte(0); emit_byte(0)
    emit_u64_le(0x100000000)
    emit_u64_le(0)                // vmsize (patched at 136)
    emit_u64_le(0)
    emit_u64_le(0)                // filesize (patched at 152)
    emit_u32_le(5); emit_u32_le(5)  // maxprot=RX, initprot=RX
    emit_u32_le(1); emit_u32_le(0)  // nsects=1, flags=0

    // __text section within __TEXT (80 bytes, offset 176)
    // sectname "__text"
    emit_byte(95); emit_byte(95); emit_byte(116); emit_byte(101)
    emit_byte(120); emit_byte(116); emit_byte(0); emit_byte(0)
    emit_byte(0); emit_byte(0); emit_byte(0); emit_byte(0)
    emit_byte(0); emit_byte(0); emit_byte(0); emit_byte(0)
    // segname "__TEXT"
    emit_byte(95); emit_byte(95); emit_byte(84); emit_byte(69)
    emit_byte(88); emit_byte(84); emit_byte(0); emit_byte(0)
    emit_byte(0); emit_byte(0); emit_byte(0); emit_byte(0)
    emit_byte(0); emit_byte(0); emit_byte(0); emit_byte(0)
    emit_u64_le(0x100000000 + header_size)  // addr (patched at 208)
    emit_u64_le(0)                            // size (patched at 216)
    emit_u32_le(header_size)                  // offset (patched at 224)
    emit_u32_le(2)                            // align = 2^2 = 4 bytes
    emit_u32_le(0)                            // reloff
    emit_u32_le(0)                            // nreloc
    emit_u32_le(0x80000400)                   // flags: S_ATTR_PURE_INSTRUCTIONS | S_ATTR_SOME_INSTRUCTIONS
    emit_u32_le(0); emit_u32_le(0); emit_u32_le(0) // reserved

    // __DATA (72 bytes, offset 256) — RW statics
    emit_u32_le(0x19); emit_u32_le(72)
    emit_byte(95); emit_byte(95); emit_byte(68); emit_byte(65)
    emit_byte(84); emit_byte(65); emit_byte(0); emit_byte(0)
    emit_byte(0); emit_byte(0); emit_byte(0); emit_byte(0)
    emit_byte(0); emit_byte(0); emit_byte(0); emit_byte(0)
    emit_u64_le(0)                // vmaddr (patched at 280)
    emit_u64_le(0)                // vmsize (patched at 288)
    emit_u64_le(0)                // fileoff (patched at 296)
    emit_u64_le(0)                // filesize (patched at 304)
    emit_u32_le(3); emit_u32_le(3)  // maxprot=RW, initprot=RW
    emit_u32_le(0); emit_u32_le(0)

    // __LINKEDIT (72 bytes, offset 328) — for codesign
    emit_u32_le(0x19); emit_u32_le(72)
    emit_byte(95); emit_byte(95); emit_byte(76); emit_byte(73)
    emit_byte(78); emit_byte(75); emit_byte(69); emit_byte(68)
    emit_byte(73); emit_byte(84); emit_byte(0); emit_byte(0)
    emit_byte(0); emit_byte(0); emit_byte(0); emit_byte(0)
    emit_u64_le(0)                // vmaddr (patched at 352)
    emit_u64_le(0)                // vmsize (patched at 360)
    emit_u64_le(0)                // fileoff (patched at 368)
    emit_u64_le(0)                // filesize (patched at 376)
    emit_u32_le(1); emit_u32_le(1)  // maxprot=R, initprot=R
    emit_u32_le(0); emit_u32_le(0)

    // LC_DYLD_CHAINED_FIXUPS (16 bytes, offset 400)
    emit_u32_le(0x80000034)
    emit_u32_le(16)
    emit_u32_le(0)                // dataoff (patched at 408)
    emit_u32_le(0)                // datasize (patched at 412)

    // LC_SYMTAB (24 bytes, offset 416)
    emit_u32_le(2)
    emit_u32_le(24)
    emit_u32_le(0)                // symoff (patched at 424)
    emit_u32_le(0)                // nsyms (patched at 428)
    emit_u32_le(0)                // stroff (patched at 432)
    emit_u32_le(0)                // strsize (patched at 436)

    // LC_DYSYMTAB (80 bytes, offset 440)
    emit_u32_le(0xB)
    emit_u32_le(80)
    emit_u32_le(0); emit_u32_le(0)  // ilocalsym, nlocalsym
    emit_u32_le(0); emit_u32_le(0)  // iextdefsym, nextdefsym (patched at 460)
    emit_u32_le(0); emit_u32_le(0)  // iundefsym (patched at 464), nundefsym
    emit_u32_le(0); emit_u32_le(0); emit_u32_le(0); emit_u32_le(0)
    emit_u32_le(0); emit_u32_le(0); emit_u32_le(0); emit_u32_le(0)
    emit_u32_le(0); emit_u32_le(0); emit_u32_le(0); emit_u32_le(0)

    // LC_LOAD_DYLINKER (32 bytes, offset 520)
    emit_u32_le(0xE)
    emit_u32_le(32)
    emit_u32_le(12)               // name offset
    emit_byte(47); emit_byte(117); emit_byte(115); emit_byte(114)
    emit_byte(47); emit_byte(108); emit_byte(105); emit_byte(98)
    emit_byte(47); emit_byte(100); emit_byte(121); emit_byte(108)
    emit_byte(100); emit_byte(0)
    emit_byte(0); emit_byte(0); emit_byte(0); emit_byte(0); emit_byte(0); emit_byte(0)

    // LC_UUID (24 bytes, offset 552)
    emit_u32_le(0x1B)
    emit_u32_le(24)
    emit_byte(0x4B); emit_byte(0x52); emit_byte(0x4E); emit_byte(0x52)
    emit_byte(0x49); emit_byte(0x46); emit_byte(0x54); emit_byte(0x00)
    emit_byte(0xA6); emit_byte(0x4B); emit_byte(0x00); emit_byte(0x01)
    emit_byte(0x02); emit_byte(0x03); emit_byte(0x04); emit_byte(0x05)

    // LC_BUILD_VERSION (24 bytes, offset 576)
    emit_u32_le(0x32)
    emit_u32_le(24)
    emit_u32_le(1)
    emit_u32_le(0x000B0000)
    emit_u32_le(0x000B0000)
    emit_u32_le(0)

    // LC_MAIN (24 bytes, offset 600)
    emit_u32_le(0x80000028)
    emit_u32_le(24)
    emit_u64_le(0)                // entryoff (patched at 608)
    emit_u64_le(0)                // stacksize

    // LC_LOAD_DYLIB /usr/lib/libSystem.B.dylib (56 bytes, offset 624)
    emit_u32_le(0xC)
    emit_u32_le(56)
    emit_u32_le(24)
    emit_u32_le(2)
    emit_u32_le(0x051C7802)
    emit_u32_le(0x00010000)
    emit_byte(47); emit_byte(117); emit_byte(115); emit_byte(114)
    emit_byte(47); emit_byte(108); emit_byte(105); emit_byte(98)
    emit_byte(47); emit_byte(108); emit_byte(105); emit_byte(98)
    emit_byte(83); emit_byte(121); emit_byte(115); emit_byte(116)
    emit_byte(101); emit_byte(109); emit_byte(46); emit_byte(66)
    emit_byte(46); emit_byte(100); emit_byte(121); emit_byte(108)
    emit_byte(105); emit_byte(98); emit_byte(0); emit_byte(0)
    emit_byte(0); emit_byte(0); emit_byte(0); emit_byte(0)

    while out_len < header_size { emit_byte(0) }
    return header_size
}


// Emit arm64 __LINKEDIT content (chained fixups + symtab + strtab) and patch
// the LC_DYLD_CHAINED_FIXUPS, LC_SYMTAB, LC_DYSYMTAB, LC_MAIN header fields.
// Keeps emit-site count low via a loop to sidestep a krc 2.6.1 codegen
// issue where enough individual emit_byte calls in one function trigger a
// memory corruption.
@export
fn emit_macho_linkedit_a64(uint64 linkedit_off, uint64 main_file_off) {
    // Chained fixups: 48 zero bytes with a few fields set.
    // header (32) + starts (4 seg_count = 0) + 4 pad + 4 imports + 4 symbols
    uint64 off = linkedit_off
    // 48 bytes of zero
    uint64 zi = 0
    while zi < 48 {
        emit_byte(0)
        zi = zi + 1
    }
    // Now write non-zero fields by patching:
    //   [off+0]  fixups_version  = 0 (already)
    //   [off+4]  starts_offset   = 32
    //   [off+8]  imports_offset  = 40
    //   [off+12] symbols_offset  = 48
    //   [off+20] imports_format  = 1
    patch_u32(off + 4, 32)
    patch_u32(off + 8, 40)
    patch_u32(off + 12, 48)
    patch_u32(off + 20, 1)
    patch_u32(408, off & 0xFFFFFFFF)
    patch_u32(412, 48)

    // Symbol table: 16 bytes for _main.
    uint64 sym_off = codegen_output_len()
    uint64 si = 0
    while si < 16 {
        emit_byte(0)
        si = si + 1
    }
    patch_u32(sym_off + 0, 1)                        // n_strx
    // n_type = 0x0F at sym_off+4 (byte)
    uint64 ntp = sym_off + 4
    uint8 nt = 0x0F
    unsafe { *(out_buf + ntp as uint8) = nt }
    // n_sect = 1 at sym_off+5
    uint64 nsp = sym_off + 5
    uint8 ns = 1
    unsafe { *(out_buf + nsp as uint8) = ns }
    // n_value (u64 at sym_off+8)
    uint64 nvp = sym_off + 8
    uint64 nv = 0x100000000 + main_file_off
    patch_u32(nvp, nv & 0xFFFFFFFF)
    patch_u32(nvp + 4, (nv >> 32) & 0xFFFFFFFF)
    patch_u32(424, sym_off & 0xFFFFFFFF)
    patch_u32(428, 1)

    // String table: "\0_main\0" padded to 8.
    uint64 strt = codegen_output_len()
    uint64 ii = 0
    while ii < 8 {
        emit_byte(0)
        ii = ii + 1
    }
    // Write 5 chars at offset 1: _main
    uint64 p1 = strt + 1
    uint8 c95 = 95
    unsafe { *(out_buf + p1 as uint8) = c95 }
    uint64 p2 = strt + 2
    uint8 c109 = 109
    unsafe { *(out_buf + p2 as uint8) = c109 }
    uint64 p3 = strt + 3
    uint8 c97 = 97
    unsafe { *(out_buf + p3 as uint8) = c97 }
    uint64 p4 = strt + 4
    uint8 c105 = 105
    unsafe { *(out_buf + p4 as uint8) = c105 }
    uint64 p5 = strt + 5
    uint8 c110 = 110
    unsafe { *(out_buf + p5 as uint8) = c110 }
    patch_u32(432, strt & 0xFFFFFFFF)
    patch_u32(436, 8)

    // DYSYMTAB: nextdefsym=1, iundefsym=1
    patch_u32(460, 1)
    patch_u32(464, 1)

    // LC_MAIN entryoff
    patch_u32(608, main_file_off & 0xFFFFFFFF)
    patch_u32(612, (main_file_off >> 32) & 0xFFFFFFFF)
}

// Patch offsets (new arm64 layout):
// __TEXT vmsize=136, filesize=152
// __text size=216
// __DATA vmaddr=280, vmsize=288, fileoff=296, filesize=304
// __LINKEDIT vmaddr=352, vmsize=360, fileoff=368, filesize=376
// DYLD_CHAINED_FIXUPS dataoff=408, datasize=412
// LC_SYMTAB symoff=424, nsyms=428, stroff=432, strsize=436
// LC_DYSYMTAB nextdefsym=460, iundefsym=464
// LC_MAIN entryoff=608 (u64)
// x86_64 LC_UNIXTHREAD rip at 176+16+16*8 = 320
// MLRift — built on KernRift — PE/COFF output format (Windows)
//
// PE32+ with .text + .idata sections for Windows x86_64 and AArch64
// Import table provides: ExitProcess, GetStdHandle, WriteFile,
// CreateFileA, ReadFile, CloseHandle, VirtualAlloc

// ---------------------------------------------------------------------------
// PE import table (IAT) layout
// ---------------------------------------------------------------------------
// .idata section contains:
//   Import Directory Table (IDT): one entry per DLL + null terminator
//   Import Lookup Table (ILT): one entry per function + null terminator
//   Import Address Table (IAT): same as ILT, patched by loader
//   Hint/Name entries: hint(2) + name string + padding
//   DLL name string

// IAT slot indices (used by codegen to generate indirect calls)
static uint64 IAT_ExitProcess = 0
static uint64 IAT_GetStdHandle = 1
static uint64 IAT_WriteFile = 2
static uint64 IAT_CreateFileA = 3
static uint64 IAT_ReadFile = 4
static uint64 IAT_CloseHandle = 5
static uint64 IAT_VirtualAlloc = 6
static uint64 IAT_GetCommandLineA = 7
static uint64 IAT_GetFileSizeEx = 8
static uint64 IAT_CreateProcessA = 9
static uint64 IAT_WaitForSingleObject = 10
static uint64 IAT_GetExitCodeProcess = 11
static uint64 IAT_GetModuleFileNameA = 12
static uint64 IAT_VirtualFree = 13
static uint64 IAT_QueryPerformanceCounter = 14
static uint64 IAT_QueryPerformanceFrequency = 15
static uint64 IAT_ENTRY_COUNT = 16

// Compute .idata section size
fn pe_idata_size() -> uint64 {
    // IDT: 1 entry (20 bytes) + null terminator (20 bytes) = 40
    // ILT: 16 entries × 8 + null (8) = 136
    // IAT: same = 136
    // Hint/Name table: 16 × 32 = 512  (32-byte slots accommodate the longest
    //   kernel32 names we import, QueryPerformanceFrequency at 25 chars)
    // DLL name: "kernel32.dll\0" = 13
    // Total: 40 + 136 + 136 + 512 + 13 = 837, padded to 1024
    return 1024
}

// Emit the .idata section content at the current output position
// Returns the RVA of the IAT (for code to reference)
@export
fn emit_pe_idata(uint64 idata_rva) -> uint64 {
    uint64 base = out_len

    // Layout offsets within .idata (16 IAT entries, 32-byte hint/name slots):
    uint64 idt_off = 0
    uint64 ilt_off = 40
    uint64 iat_off = 176
    uint64 hints_off = 312
    uint64 dllname_off = 824

    // IDT entry for kernel32.dll (20 bytes)
    emit_u32_le(idata_rva + ilt_off)     // OriginalFirstThunk → ILT
    emit_u32_le(0)                        // TimeDateStamp
    emit_u32_le(0)                        // ForwarderChain
    emit_u32_le(idata_rva + dllname_off)  // Name → "kernel32.dll"
    emit_u32_le(idata_rva + iat_off)      // FirstThunk → IAT

    // Null IDT terminator (20 bytes)
    uint64 z = 0
    while z < 20 { emit_byte(0); z = z + 1 }

    // ILT: 16 entries + null (each is 8 bytes = RVA to hint/name)
    uint64 h = 0
    while h < 16 {
        emit_u64_le(idata_rva + hints_off + h * 32)
        h = h + 1
    }
    emit_u64_le(0)  // null terminator

    // IAT: identical to ILT (loader patches this at runtime)
    h = 0
    while h < 16 {
        emit_u64_le(idata_rva + hints_off + h * 32)
        h = h + 1
    }
    emit_u64_le(0)

    // Hint/Name entries (32 bytes each, padded)
    // 0: ExitProcess
    emit_u16_le(0)
    emit_byte(69); emit_byte(120); emit_byte(105); emit_byte(116)
    emit_byte(80); emit_byte(114); emit_byte(111); emit_byte(99)
    emit_byte(101); emit_byte(115); emit_byte(115); emit_byte(0)
    uint64 pe_pad_i = 0
    while pe_pad_i < 18 { emit_byte(0); pe_pad_i = pe_pad_i + 1 }

    // 1: GetStdHandle
    emit_u16_le(0)
    emit_byte(71); emit_byte(101); emit_byte(116); emit_byte(83)
    emit_byte(116); emit_byte(100); emit_byte(72); emit_byte(97)
    emit_byte(110); emit_byte(100); emit_byte(108); emit_byte(101); emit_byte(0)
    pe_pad_i = 0
    while pe_pad_i < 17 { emit_byte(0); pe_pad_i = pe_pad_i + 1 }

    // 2: WriteFile
    emit_u16_le(0)
    emit_byte(87); emit_byte(114); emit_byte(105); emit_byte(116)
    emit_byte(101); emit_byte(70); emit_byte(105); emit_byte(108)
    emit_byte(101); emit_byte(0)
    pe_pad_i = 0
    while pe_pad_i < 20 { emit_byte(0); pe_pad_i = pe_pad_i + 1 }

    // 3: CreateFileA
    emit_u16_le(0)
    emit_byte(67); emit_byte(114); emit_byte(101); emit_byte(97)
    emit_byte(116); emit_byte(101); emit_byte(70); emit_byte(105)
    emit_byte(108); emit_byte(101); emit_byte(65); emit_byte(0)
    pe_pad_i = 0
    while pe_pad_i < 18 { emit_byte(0); pe_pad_i = pe_pad_i + 1 }

    // 4: ReadFile
    emit_u16_le(0)
    emit_byte(82); emit_byte(101); emit_byte(97); emit_byte(100)
    emit_byte(70); emit_byte(105); emit_byte(108); emit_byte(101); emit_byte(0)
    pe_pad_i = 0
    while pe_pad_i < 21 { emit_byte(0); pe_pad_i = pe_pad_i + 1 }

    // 5: CloseHandle
    emit_u16_le(0)
    emit_byte(67); emit_byte(108); emit_byte(111); emit_byte(115)
    emit_byte(101); emit_byte(72); emit_byte(97); emit_byte(110)
    emit_byte(100); emit_byte(108); emit_byte(101); emit_byte(0)
    pe_pad_i = 0
    while pe_pad_i < 18 { emit_byte(0); pe_pad_i = pe_pad_i + 1 }

    // 6: VirtualAlloc
    emit_u16_le(0)
    emit_byte(86); emit_byte(105); emit_byte(114); emit_byte(116)
    emit_byte(117); emit_byte(97); emit_byte(108); emit_byte(65)
    emit_byte(108); emit_byte(108); emit_byte(111); emit_byte(99); emit_byte(0)
    pe_pad_i = 0
    while pe_pad_i < 17 { emit_byte(0); pe_pad_i = pe_pad_i + 1 }

    // 7: GetCommandLineA
    emit_u16_le(0)
    emit_byte(71); emit_byte(101); emit_byte(116); emit_byte(67)
    emit_byte(111); emit_byte(109); emit_byte(109); emit_byte(97)
    emit_byte(110); emit_byte(100); emit_byte(76); emit_byte(105)
    emit_byte(110); emit_byte(101); emit_byte(65); emit_byte(0)
    pe_pad_i = 0
    while pe_pad_i < 14 { emit_byte(0); pe_pad_i = pe_pad_i + 1 }

    // 8: GetFileSizeEx
    emit_u16_le(0)
    emit_byte(71); emit_byte(101); emit_byte(116); emit_byte(70)
    emit_byte(105); emit_byte(108); emit_byte(101); emit_byte(83)
    emit_byte(105); emit_byte(122); emit_byte(101); emit_byte(69)
    emit_byte(120); emit_byte(0)
    pe_pad_i = 0
    while pe_pad_i < 16 { emit_byte(0); pe_pad_i = pe_pad_i + 1 }

    // 9: CreateProcessA
    emit_u16_le(0)
    emit_byte(67); emit_byte(114); emit_byte(101); emit_byte(97)
    emit_byte(116); emit_byte(101); emit_byte(80); emit_byte(114)
    emit_byte(111); emit_byte(99); emit_byte(101); emit_byte(115)
    emit_byte(115); emit_byte(65); emit_byte(0)
    pe_pad_i = 0
    while pe_pad_i < 15 { emit_byte(0); pe_pad_i = pe_pad_i + 1 }

    // 10: WaitForSingleObject
    emit_u16_le(0)
    emit_byte(87); emit_byte(97); emit_byte(105); emit_byte(116)
    emit_byte(70); emit_byte(111); emit_byte(114); emit_byte(83)
    emit_byte(105); emit_byte(110); emit_byte(103); emit_byte(108)
    emit_byte(101); emit_byte(79); emit_byte(98); emit_byte(106)
    emit_byte(101); emit_byte(99); emit_byte(116); emit_byte(0)
    pe_pad_i = 0
    while pe_pad_i < 10 { emit_byte(0); pe_pad_i = pe_pad_i + 1 }

    // 11: GetExitCodeProcess
    emit_u16_le(0)
    emit_byte(71); emit_byte(101); emit_byte(116); emit_byte(69)
    emit_byte(120); emit_byte(105); emit_byte(116); emit_byte(67)
    emit_byte(111); emit_byte(100); emit_byte(101); emit_byte(80)
    emit_byte(114); emit_byte(111); emit_byte(99); emit_byte(101)
    emit_byte(115); emit_byte(115); emit_byte(0)
    pe_pad_i = 0
    while pe_pad_i < 11 { emit_byte(0); pe_pad_i = pe_pad_i + 1 }

    // 12: GetModuleFileNameA
    emit_u16_le(0)
    emit_byte(71); emit_byte(101); emit_byte(116); emit_byte(77)
    emit_byte(111); emit_byte(100); emit_byte(117); emit_byte(108)
    emit_byte(101); emit_byte(70); emit_byte(105); emit_byte(108)
    emit_byte(101); emit_byte(78); emit_byte(97); emit_byte(109)
    emit_byte(101); emit_byte(65); emit_byte(0)
    pe_pad_i = 0
    while pe_pad_i < 11 { emit_byte(0); pe_pad_i = pe_pad_i + 1 }

    // 13: VirtualFree
    emit_u16_le(0)
    emit_byte(86); emit_byte(105); emit_byte(114); emit_byte(116)
    emit_byte(117); emit_byte(97); emit_byte(108); emit_byte(70)
    emit_byte(114); emit_byte(101); emit_byte(101); emit_byte(0)
    pe_pad_i = 0
    while pe_pad_i < 18 { emit_byte(0); pe_pad_i = pe_pad_i + 1 }

    // 14: QueryPerformanceCounter
    emit_u16_le(0)
    emit_byte(81); emit_byte(117); emit_byte(101); emit_byte(114)
    emit_byte(121); emit_byte(80); emit_byte(101); emit_byte(114)
    emit_byte(102); emit_byte(111); emit_byte(114); emit_byte(109)
    emit_byte(97); emit_byte(110); emit_byte(99); emit_byte(101)
    emit_byte(67); emit_byte(111); emit_byte(117); emit_byte(110)
    emit_byte(116); emit_byte(101); emit_byte(114); emit_byte(0)
    pe_pad_i = 0
    while pe_pad_i < 6 { emit_byte(0); pe_pad_i = pe_pad_i + 1 }

    // 15: QueryPerformanceFrequency
    emit_u16_le(0)
    emit_byte(81); emit_byte(117); emit_byte(101); emit_byte(114)
    emit_byte(121); emit_byte(80); emit_byte(101); emit_byte(114)
    emit_byte(102); emit_byte(111); emit_byte(114); emit_byte(109)
    emit_byte(97); emit_byte(110); emit_byte(99); emit_byte(101)
    emit_byte(70); emit_byte(114); emit_byte(101); emit_byte(113)
    emit_byte(117); emit_byte(101); emit_byte(110); emit_byte(99)
    emit_byte(121); emit_byte(0)
    pe_pad_i = 0
    while pe_pad_i < 4 { emit_byte(0); pe_pad_i = pe_pad_i + 1 }

    // DLL name: "kernel32.dll\0"
    emit_byte(107); emit_byte(101); emit_byte(114); emit_byte(110)
    emit_byte(101); emit_byte(108); emit_byte(51); emit_byte(50)
    emit_byte(46); emit_byte(100); emit_byte(108); emit_byte(108)
    emit_byte(0)

    // Pad to 512 bytes
    while out_len - base < 1024 { emit_byte(0) }

    // Return IAT RVA (for call [rip+disp] to use)
    return idata_rva + iat_off
}

// ---------------------------------------------------------------------------
// PE header emission with .text + .idata
// ---------------------------------------------------------------------------

@export
fn emit_pe_headers_x64(uint64 code_size) -> uint64 {
    uint64 text_aligned = (code_size + 0x1FF) & ~0x1FF
    uint64 idata_size = pe_idata_size()

    // DOS header (64 bytes)
    emit_byte(0x4D); emit_byte(0x5A)
    uint64 i = 0
    while i < 58 { emit_byte(0); i = i + 1 }
    emit_u32_le(0x40)

    // PE signature
    emit_byte(0x50); emit_byte(0x45); emit_byte(0); emit_byte(0)

    // COFF header
    emit_u16_le(0x8664)
    emit_u16_le(2)          // 2 sections: .text + .idata
    emit_u32_le(0); emit_u32_le(0); emit_u32_le(0)
    emit_u16_le(240)
    emit_u16_le(0x0022)

    // Optional header PE32+
    emit_u16_le(0x020B)
    emit_byte(14); emit_byte(0)
    emit_u32_le(text_aligned)
    emit_u32_le(idata_size)
    emit_u32_le(0)
    emit_u32_le(0x1000)     // EntryPoint RVA
    emit_u32_le(0x1000)

    emit_u64_le(0x140000000)
    emit_u32_le(0x1000)
    emit_u32_le(0x200)
    emit_u16_le(6); emit_u16_le(0)
    emit_u16_le(0); emit_u16_le(0)
    emit_u16_le(6); emit_u16_le(0)
    emit_u32_le(0)

    uint64 idata_rva = 0x2000
    uint64 image_size = 0x3000
    emit_u32_le(image_size)
    emit_u32_le(0x200)      // SizeOfHeaders
    emit_u32_le(0)
    emit_u16_le(3)           // CONSOLE
    emit_u16_le(0x8100)
    emit_u64_le(0x800000); emit_u64_le(0x800000)  // StackReserve=8MB, StackCommit=8MB
    emit_u64_le(0x100000); emit_u64_le(0x1000)
    emit_u32_le(0); emit_u32_le(16)

    // Data directories
    // Import table at index 1
    i = 0
    while i < 16 {
        if i == 1 {
            emit_u32_le(idata_rva)   // Import Directory RVA
            emit_u32_le(idata_size)  // Import Directory Size
        } else {
            emit_u32_le(0)
            emit_u32_le(0)
        }
        i = i + 1
    }

    // .text section header
    emit_byte(0x2E); emit_byte(0x74); emit_byte(0x65); emit_byte(0x78)
    emit_byte(0x74); emit_byte(0); emit_byte(0); emit_byte(0)
    emit_u32_le(code_size)
    emit_u32_le(0x1000)
    emit_u32_le(text_aligned)
    emit_u32_le(0x200)
    emit_u32_le(0); emit_u32_le(0)
    emit_u16_le(0); emit_u16_le(0)
    emit_u32_le(0xE0000020)  // CODE|EXECUTE|READ|WRITE (statics in .text)

    // .idata section header
    emit_byte(0x2E); emit_byte(0x69); emit_byte(0x64); emit_byte(0x61)
    emit_byte(0x74); emit_byte(0x61); emit_byte(0); emit_byte(0)
    emit_u32_le(idata_size)
    emit_u32_le(idata_rva)
    emit_u32_le(idata_size)
    uint64 idata_file_off = 0x200 + text_aligned
    emit_u32_le(idata_file_off)
    emit_u32_le(0); emit_u32_le(0)
    emit_u16_le(0); emit_u16_le(0)
    emit_u32_le(0xC0000040)  // INITIALIZED_DATA|READ

    // Pad to file alignment
    while out_len < 0x200 { emit_byte(0) }

    return 0x200
}

// PE AArch64 variant (same structure, different machine type)
@export
fn emit_pe_headers_a64(uint64 code_size) -> uint64 {
    // Same as x64 but with machine=0xAA64
    uint64 text_aligned = (code_size + 0x1FF) & ~0x1FF
    uint64 idata_size = pe_idata_size()

    emit_byte(0x4D); emit_byte(0x5A)
    uint64 i = 0
    while i < 58 { emit_byte(0); i = i + 1 }
    emit_u32_le(0x40)
    emit_byte(0x50); emit_byte(0x45); emit_byte(0); emit_byte(0)
    emit_u16_le(0xAA64)     // ARM64
    emit_u16_le(3)          // 3 sections: .text + .data + .idata
    emit_u32_le(0); emit_u32_le(0); emit_u32_le(0)
    emit_u16_le(240); emit_u16_le(0x0022)
    emit_u16_le(0x020B); emit_byte(14); emit_byte(0)
    emit_u32_le(text_aligned); emit_u32_le(idata_size); emit_u32_le(0)
    emit_u32_le(0x1000); emit_u32_le(0x1000)
    emit_u64_le(0x140000000)
    emit_u32_le(0x1000); emit_u32_le(0x200)
    emit_u16_le(6); emit_u16_le(0); emit_u16_le(0); emit_u16_le(0)
    emit_u16_le(6); emit_u16_le(0); emit_u32_le(0)
    emit_u32_le(0x3000); emit_u32_le(0x200); emit_u32_le(0)
    emit_u16_le(3); emit_u16_le(0x8160)  // DYNAMIC_BASE + NX_COMPAT + HIGH_ENTROPY_VA (required on ARM64 Windows)
    emit_u64_le(0x800000); emit_u64_le(0x800000)  // StackReserve=8MB, StackCommit=8MB
    emit_u64_le(0x100000); emit_u64_le(0x1000)
    emit_u32_le(0); emit_u32_le(16)
    i = 0
    while i < 16 {
        if i == 1 { emit_u32_le(0x2000); emit_u32_le(idata_size) }
        else if i == 5 { emit_u32_le(0); emit_u32_le(0) }  // BaseReloc: empty (PC-relative code, no fixups)
        else { emit_u32_le(0); emit_u32_le(0) }
        i = i + 1
    }
    // .text (RX only — ARM64 W^X enforcement)
    emit_byte(0x2E); emit_byte(0x74); emit_byte(0x65); emit_byte(0x78)
    emit_byte(0x74); emit_byte(0); emit_byte(0); emit_byte(0)
    emit_u32_le(0); emit_u32_le(0x1000); emit_u32_le(0)  // VirtSize+RawSize patched later
    emit_u32_le(0x200); emit_u32_le(0); emit_u32_le(0)
    emit_u16_le(0); emit_u16_le(0); emit_u32_le(0x60000020)  // CODE|EXECUTE|READ (no write)
    // .data (RW — for static variables)
    emit_byte(0x2E); emit_byte(0x64); emit_byte(0x61); emit_byte(0x74)
    emit_byte(0x61); emit_byte(0); emit_byte(0); emit_byte(0)
    emit_u32_le(0); emit_u32_le(0); emit_u32_le(0)  // all patched later
    emit_u32_le(0); emit_u32_le(0); emit_u32_le(0)
    emit_u16_le(0); emit_u16_le(0); emit_u32_le(0xC0000040)  // INITIALIZED_DATA|READ|WRITE
    // .idata
    emit_byte(0x2E); emit_byte(0x69); emit_byte(0x64); emit_byte(0x61)
    emit_byte(0x74); emit_byte(0x61); emit_byte(0); emit_byte(0)
    emit_u32_le(0); emit_u32_le(0); emit_u32_le(0)  // patched later
    emit_u32_le(0); emit_u32_le(0); emit_u32_le(0)
    emit_u16_le(0); emit_u16_le(0); emit_u32_le(0xC0000040)  // INITIALIZED_DATA|READ|WRITE
    while out_len < 0x200 { emit_byte(0) }
    return 0x200
}
// MLRift -- built on KernRift -- HIP (AMD/NVIDIA GPU) source emitter
//
// Walks the parsed module AST and emits HIP C++ source for every
// function marked `@kernel` (ast bit 4 of data4 — see src/ast.kr's
// `ast_fn_is_kernel`). The resulting text is written to `<output>.hip`
// as a side-file alongside the normal CPU binary.
//
// M1b scope (this landing):
//   - Header + MLRift-style typedefs (uint64 etc.)
//   - One `extern "C" __global__` declaration per @kernel fn with
//     verbatim parameter types copied from the source text
//   - Function body is a placeholder ("TODO") — AST-to-C++ body
//     translation is a separate follow-up (M1.5). The generated
//     file still compiles with hipcc, which is what M1c needs.
//
// Opcode vocabulary when the body walker lands: see `ir_hip.kr`
// (IR_GPU_ALLOC, IR_KERNEL_LAUNCH, IR_GPU_BARRIER, ...).

// ---------------------------------------------------------------------------
// HIP text buffer
// ---------------------------------------------------------------------------
// Separate from codegen.kr's `out_buf` — the main binary and the HIP
// source are independent outputs. 256 KB is generous for the kinds of
// kernel signatures we expect through M2; grow it in `hip_init` if a
// real workload hits the ceiling.

static uint64 hip_buf = 0
static uint64 hip_len = 0
static uint64 hip_cap = 0

// Set to 1 by main.kr when `--target=hip-amd` is present on the CLI.
// When non-zero, the driver runs emit_hip_artifacts() alongside the
// normal CPU codegen path. 0 (default) = no GPU emission.
static uint64 target_gpu = 0

// Source text pointer stashed on each emit so downstream helpers can
// slice out param/fn-name text without threading the pointer through
// every call. Set by `emit_hip_artifacts` at entry.
static uint64 hip_src = 0

@export
fn hip_init() {
    if hip_buf == 0 {
        hip_buf = alloc(262144)
        hip_cap = 262144
    }
    hip_len = 0
}

// ---------------------------------------------------------------------------
// Low-level append helpers
// ---------------------------------------------------------------------------

fn hip_emit_byte(uint8 b) {
    if hip_len >= hip_cap {
        write(2, "format_hip: hip_buf overflow\n", 29)
        exit(1)
    }
    uint64 p = hip_buf + hip_len
    unsafe { *(p as uint8) = b }
    hip_len = hip_len + 1
}

fn hip_emit_str(uint64 ptr, uint64 len) {
    uint64 i = 0
    while i < len {
        uint64 ap = ptr + i
        uint64 b = 0
        unsafe { *(ap as uint8) -> b }
        uint8 b8 = b
        hip_emit_byte(b8)
        i = i + 1
    }
}

fn hip_emit_cstr(uint64 ptr) {
    uint64 n = str_len(ptr)
    hip_emit_str(ptr, n)
}

fn hip_emit_u64(uint64 val) {
    uint8[24] lbuf
    uint64 ln = fmt_uint(lbuf, val)
    hip_emit_str(lbuf, ln)
}

// ---------------------------------------------------------------------------
// Header + typedefs
// ---------------------------------------------------------------------------

fn hip_emit_header() {
    hip_emit_cstr("// AUTO-GENERATED by MLRift — do not edit by hand.\n")
    hip_emit_cstr("// Source: emitted from a `.mlr` input by src/format_hip.kr.\n\n")
    hip_emit_cstr("#include <hip/hip_runtime.h>\n")
    hip_emit_cstr("#include <stdint.h>\n\n")
    hip_emit_cstr("// MLRift -> C++ type aliases (lets us drop KernRift type\n")
    hip_emit_cstr("// names directly into the kernel signature without rewriting).\n")
    hip_emit_cstr("typedef uint8_t  uint8;\n")
    hip_emit_cstr("typedef uint16_t uint16;\n")
    hip_emit_cstr("typedef uint32_t uint32;\n")
    hip_emit_cstr("typedef uint64_t uint64;\n")
    hip_emit_cstr("typedef int8_t   int8;\n")
    hip_emit_cstr("typedef int16_t  int16;\n")
    hip_emit_cstr("typedef int32_t  int32;\n")
    hip_emit_cstr("typedef int64_t  int64;\n")
    hip_emit_cstr("typedef float    f32;\n")
    hip_emit_cstr("typedef double   f64;\n")
    hip_emit_cstr("typedef _Float16 f16;\n\n")
}

// ---------------------------------------------------------------------------
// Body translation (AST -> HIP C++)
// ---------------------------------------------------------------------------
// Supports the AST subset that appears in kernel bodies today:
//   Block (15), VarDecl (10), Assign (11), Return (12), If (13),
//   While (14), ExprStmt (16), Break (17), Continue (18),
//   PtrLoad (41), PtrStore (42),
//   IntLit (30), Ident (32), BinOp (33), Compare (38).
// Anything else emits a `// unsupported` marker so hipcc produces a
// clear diagnostic rather than silently skipping structural code.

fn hip_emit_indent(uint64 depth) {
    uint64 i = 0
    while i < depth {
        hip_emit_cstr("    ")
        i = i + 1
    }
}

// KernRift operator token kind -> C operator. Falls back to /*op?*/
// for anything unmapped (logical &&/|| deliberately skipped — short-
// circuit semantics warrant an explicit translation pass, not a naive
// emit).
fn hip_emit_bin_op(uint32 op_kind) {
    if op_kind == 22 { hip_emit_cstr(" * ") }
    else if op_kind == 30 { hip_emit_cstr(" + ") }
    else if op_kind == 31 { hip_emit_cstr(" - ") }
    else if op_kind == 32 { hip_emit_cstr(" / ") }
    else if op_kind == 33 { hip_emit_cstr(" % ") }
    else if op_kind == 35 { hip_emit_cstr(" == ") }
    else if op_kind == 36 { hip_emit_cstr(" != ") }
    else if op_kind == 37 { hip_emit_cstr(" < ") }
    else if op_kind == 38 { hip_emit_cstr(" <= ") }
    else if op_kind == 39 { hip_emit_cstr(" > ") }
    else if op_kind == 40 { hip_emit_cstr(" >= ") }
    else if op_kind == 43 { hip_emit_cstr(" << ") }
    else if op_kind == 44 { hip_emit_cstr(" >> ") }
    else if op_kind == 23 { hip_emit_cstr(" & ") }
    else if op_kind == 24 { hip_emit_cstr(" | ") }
    else if op_kind == 25 { hip_emit_cstr(" ^ ") }
    else { hip_emit_cstr(" /*op?*/ ") }
}

// PtrLoad/PtrStore carry size (1/2/4/8), not a type name. Map back
// to the KernRift integer typedef we declared in the header. Float
// pointer loads carry a separate float-kind in data3.
fn hip_emit_type_for_size(uint64 size) {
    if size == 1 { hip_emit_cstr("uint8") }
    else if size == 2 { hip_emit_cstr("uint16") }
    else if size == 4 { hip_emit_cstr("uint32") }
    else { hip_emit_cstr("uint64") }
}

fn hip_emit_ptr_elem_type(uint64 size, uint32 float_kind) {
    if float_kind == 1 { hip_emit_cstr("f64") }
    else if float_kind == 2 { hip_emit_cstr("f32") }
    else if float_kind == 3 { hip_emit_cstr("f16") }
    else { hip_emit_type_for_size(size) }
}

fn hip_emit_expr(uint64 node) {
    uint32 k = ast_kind(node)
    if k == 30 {
        // IntLit: data1 = token index — just copy source text verbatim
        // so hex/bin/decimal literals all survive.
        uint32 tok = ast_data1(node)
        uint64 ts = tok_text_start(tok)
        uint64 tl = tok_text_len(tok)
        hip_emit_str(hip_src + ts, tl)
        return
    }
    if k == 32 {
        // Ident: data1 = name token
        uint32 tok = ast_data1(node)
        uint64 ts = tok_text_start(tok)
        uint64 tl = tok_text_len(tok)
        hip_emit_str(hip_src + ts, tl)
        return
    }
    if k == 46 {
        // FloatLitNode: data1 = token — float literals like 0.0 / 1.5e-3
        // come through as source text; C++ parses them the same way.
        uint32 tok = ast_data1(node)
        uint64 ts = tok_text_start(tok)
        uint64 tl = tok_text_len(tok)
        hip_emit_str(hip_src + ts, tl)
        return
    }
    if k == 33 {
        // BinOp: child=lhs, data1=op_tok, data2=rhs
        hip_emit_byte(40)
        uint32 lhs = ast_child(node)
        uint64 wl = lhs
        hip_emit_expr(wl)
        uint32 op_tok = ast_data1(node)
        uint32 op_kind = tok_kind_at(op_tok)
        hip_emit_bin_op(op_kind)
        uint32 rhs = ast_data2(node)
        uint64 wr = rhs
        hip_emit_expr(wr)
        hip_emit_byte(41)
        return
    }
    if k == 38 {
        // Compare: same layout as BinOp
        hip_emit_byte(40)
        uint32 lhs = ast_child(node)
        uint64 wl = lhs
        hip_emit_expr(wl)
        uint32 op_tok = ast_data1(node)
        uint32 op_kind = tok_kind_at(op_tok)
        hip_emit_bin_op(op_kind)
        uint32 rhs = ast_data2(node)
        uint64 wr = rhs
        hip_emit_expr(wr)
        hip_emit_byte(41)
        return
    }
    if k == 35 {
        // Call: a handful of call-site intrinsics map to HIP built-in
        // expressions (threadIdx / blockIdx math). Everything else is
        // unsupported inside a @kernel body for now — device-side
        // function calls need their own codegen story.
        uint32 callee_tok = ast_data1(node)
        if tok_matches(callee_tok, "tid_x", 5) != 0 {
            hip_emit_cstr("(blockIdx.x * blockDim.x + threadIdx.x)")
            return
        }
        if tok_matches(callee_tok, "tid_y", 5) != 0 {
            hip_emit_cstr("(blockIdx.y * blockDim.y + threadIdx.y)")
            return
        }
        if tok_matches(callee_tok, "tid_z", 5) != 0 {
            hip_emit_cstr("(blockIdx.z * blockDim.z + threadIdx.z)")
            return
        }
        if tok_matches(callee_tok, "block_dim_x", 11) != 0 {
            hip_emit_cstr("blockDim.x")
            return
        }
        if tok_matches(callee_tok, "grid_dim_x", 10) != 0 {
            hip_emit_cstr("gridDim.x")
            return
        }
        // Workgroup-local thread / block IDs. tid_x()/y()/z() above
        // collapse blockIdx*blockDim+threadIdx into one global id; for
        // tile-shaped kernels (LDS GEMM, fused attention) we need the
        // pieces separately.
        if tok_matches(callee_tok, "tid_local_x", 11) != 0 {
            hip_emit_cstr("threadIdx.x")
            return
        }
        if tok_matches(callee_tok, "tid_local_y", 11) != 0 {
            hip_emit_cstr("threadIdx.y")
            return
        }
        if tok_matches(callee_tok, "tid_local_z", 11) != 0 {
            hip_emit_cstr("threadIdx.z")
            return
        }
        if tok_matches(callee_tok, "block_idx_x", 11) != 0 {
            hip_emit_cstr("blockIdx.x")
            return
        }
        if tok_matches(callee_tok, "block_idx_y", 11) != 0 {
            hip_emit_cstr("blockIdx.y")
            return
        }
        if tok_matches(callee_tok, "block_idx_z", 11) != 0 {
            hip_emit_cstr("blockIdx.z")
            return
        }
        if tok_matches(callee_tok, "block_dim_y", 11) != 0 {
            hip_emit_cstr("blockDim.y")
            return
        }
        if tok_matches(callee_tok, "block_dim_z", 11) != 0 {
            hip_emit_cstr("blockDim.z")
            return
        }
        // Workgroup barrier — every lane in the block must reach this
        // call before any lane proceeds. Required between LDS writes
        // and reads in tiled GEMM, attention, etc. Returns void; we
        // emit it as a comma expression yielding 0 so it can be used
        // as a statement (`sync_block()`) without grammar pain.
        if tok_matches(callee_tok, "sync_block", 10) != 0 {
            hip_emit_cstr("(__syncthreads(), 0)")
            return
        }
        // Shared-memory (LDS) accessors. All static @lds buffers live
        // in a single 8 KiB f32 array `_lds_f32_buf` declared by the
        // kernel header emitter; the user picks an offset/index. This
        // keeps us out of the language-level "named __shared__ var"
        // problem — we just give every kernel one big buffer it can
        // partition however it likes.
        if tok_matches(callee_tok, "lds_load_f32", 12) != 0 {
            uint32 lla = ast_child(node)
            hip_emit_cstr("_lds_f32_buf[")
            hip_emit_expr(lla)
            hip_emit_byte(93)
            return
        }
        if tok_matches(callee_tok, "lds_store_f32", 13) != 0 {
            uint32 lsa = ast_child(node)
            uint32 lsv = ast_next(lsa)
            hip_emit_cstr("(_lds_f32_buf[")
            hip_emit_expr(lsa)
            hip_emit_cstr("] = ")
            hip_emit_expr(lsv)
            hip_emit_cstr(", 0)")
            return
        }
        // Atomic adds — map MLRift `atomic_add_<ty>(ptr, val)` onto
        // HIP's overloaded atomicAdd. Return value is the pre-update
        // memory contents (C11 atomic_fetch_add semantics); kernel
        // code that ignores it just produces an expression statement.
        if tok_matches(callee_tok, "atomic_add_f64", 14) != 0 {
            uint32 aa1 = ast_child(node)
            uint32 aa2 = ast_next(aa1)
            uint64 waa1 = aa1
            uint64 waa2 = aa2
            hip_emit_cstr("atomicAdd((double*)")
            hip_emit_expr(waa1)
            hip_emit_cstr(", ")
            hip_emit_expr(waa2)
            hip_emit_byte(41)
            return
        }
        if tok_matches(callee_tok, "atomic_add_u64", 14) != 0 {
            uint32 ab1 = ast_child(node)
            uint32 ab2 = ast_next(ab1)
            uint64 wab1 = ab1
            uint64 wab2 = ab2
            hip_emit_cstr("atomicAdd((unsigned long long*)")
            hip_emit_expr(wab1)
            hip_emit_cstr(", (unsigned long long)(")
            hip_emit_expr(wab2)
            hip_emit_cstr("))")
            return
        }
        if tok_matches(callee_tok, "atomic_add_u32", 14) != 0 {
            uint32 ac1 = ast_child(node)
            uint32 ac2 = ast_next(ac1)
            uint64 wac1 = ac1
            uint64 wac2 = ac2
            hip_emit_cstr("atomicAdd((unsigned int*)")
            hip_emit_expr(wac1)
            hip_emit_cstr(", (unsigned int)(")
            hip_emit_expr(wac2)
            hip_emit_cstr("))")
            return
        }
        hip_emit_cstr("/* unsupported kernel call: ")
        uint64 cs = tok_text_start(callee_tok)
        uint64 cl = tok_text_len(callee_tok)
        hip_emit_str(hip_src + cs, cl)
        hip_emit_cstr(" */")
        return
    }
    hip_emit_cstr("/* unsupported expr kind=")
    hip_emit_u64(k)
    hip_emit_cstr(" */")
}

// Forward-declare the mutually-recursive pair so Block -> Stmt -> Block
// works during codegen. KernRift concatenates all sources, so order of
// definition within this file is all that matters.
fn hip_emit_block(uint64 node, uint64 depth) {
    hip_emit_cstr("{\n")
    uint32 ch = ast_child(node)
    uint64 wc = ch
    while wc != 0 {
        hip_emit_stmt(wc, depth + 1)
        uint32 n = ast_next(wc)
        wc = n
    }
    hip_emit_indent(depth)
    hip_emit_cstr("}\n")
}

fn hip_emit_stmt(uint64 node, uint64 depth) {
    uint32 k = ast_kind(node)
    if k == 15 {
        hip_emit_indent(depth)
        hip_emit_block(node, depth)
        return
    }
    if k == 10 {
        // VarDecl: data1=type_tok, data2=name_tok, child=init_expr (0 if none)
        hip_emit_indent(depth)
        uint32 type_tok = ast_data1(node)
        uint64 tts = tok_text_start(type_tok)
        uint64 ttl = tok_text_len(type_tok)
        hip_emit_str(hip_src + tts, ttl)
        hip_emit_byte(32)
        uint32 name_tok = ast_data2(node)
        uint64 nns = tok_text_start(name_tok)
        uint64 nnl = tok_text_len(name_tok)
        hip_emit_str(hip_src + nns, nnl)
        uint32 init = ast_child(node)
        if init != 0 {
            hip_emit_cstr(" = ")
            uint64 wi = init
            hip_emit_expr(wi)
        }
        hip_emit_cstr(";\n")
        return
    }
    if k == 11 {
        // Assign: data1=name_tok, child=value_expr
        hip_emit_indent(depth)
        uint32 name_tok = ast_data1(node)
        uint64 ns = tok_text_start(name_tok)
        uint64 nl = tok_text_len(name_tok)
        hip_emit_str(hip_src + ns, nl)
        hip_emit_cstr(" = ")
        uint32 val = ast_child(node)
        uint64 wv = val
        hip_emit_expr(wv)
        hip_emit_cstr(";\n")
        return
    }
    if k == 12 {
        // Return: child = expr (0 = void return)
        hip_emit_indent(depth)
        uint32 val = ast_child(node)
        if val == 0 {
            hip_emit_cstr("return;\n")
        } else {
            hip_emit_cstr("return ")
            uint64 wv = val
            hip_emit_expr(wv)
            hip_emit_cstr(";\n")
        }
        return
    }
    if k == 13 {
        // If: child=cond, data1=then_body (Block), data2=else_body (0, Block, or If)
        hip_emit_indent(depth)
        hip_emit_cstr("if (")
        uint32 cond = ast_child(node)
        uint64 wc = cond
        hip_emit_expr(wc)
        hip_emit_cstr(") ")
        uint32 then_body = ast_data1(node)
        uint64 wt = then_body
        hip_emit_block(wt, depth)
        uint32 else_body = ast_data2(node)
        if else_body != 0 {
            hip_emit_indent(depth)
            hip_emit_cstr("else ")
            uint64 we = else_body
            uint32 ek = ast_kind(we)
            if ek == 15 {
                hip_emit_block(we, depth)
            } else {
                // else-if cascade: write the nested If on the same line.
                // hip_emit_stmt would re-indent; we want contiguous output.
                hip_emit_stmt_inline(we, depth)
            }
        }
        return
    }
    if k == 14 {
        // While: child=cond, data1=body (Block)
        hip_emit_indent(depth)
        hip_emit_cstr("while (")
        uint32 cond = ast_child(node)
        uint64 wc = cond
        hip_emit_expr(wc)
        hip_emit_cstr(") ")
        uint32 body = ast_data1(node)
        uint64 wb = body
        hip_emit_block(wb, depth)
        return
    }
    if k == 16 {
        // ExprStmt
        hip_emit_indent(depth)
        uint32 e = ast_child(node)
        uint64 we = e
        hip_emit_expr(we)
        hip_emit_cstr(";\n")
        return
    }
    if k == 17 {
        hip_emit_indent(depth)
        hip_emit_cstr("break;\n")
        return
    }
    if k == 18 {
        hip_emit_indent(depth)
        hip_emit_cstr("continue;\n")
        return
    }
    if k == 41 {
        // PtrLoad: data1=size, data2=dest_tok, data3=float_kind, child=addr_expr
        // MLRift idiom is `f64 v = 0.0; unsafe { *(p as f64) -> v }`,
        // i.e. the destination has already been declared via VarDecl.
        // Emit a plain assignment — re-declaring would be a C++ error.
        hip_emit_indent(depth)
        uint32 dest_tok = ast_data2(node)
        uint64 ds = tok_text_start(dest_tok)
        uint64 dl = tok_text_len(dest_tok)
        hip_emit_str(hip_src + ds, dl)
        hip_emit_cstr(" = *((")
        uint64 size = ast_data1(node)
        uint32 fk = ast_data3(node)
        hip_emit_ptr_elem_type(size, fk)
        hip_emit_cstr("*)")
        uint32 addr = ast_child(node)
        uint64 wa = addr
        hip_emit_expr(wa)
        hip_emit_cstr(");\n")
        return
    }
    if k == 42 {
        // PtrStore: data1=size, child=addr_expr, data2=val_expr,
        // data3=float_kind (0=int, 1=f64, 2=f32, 3=f16). Using the
        // float kind lets f64 stores emit `*((f64*)p) = v` instead of
        // the type-mismatched `*((uint64*)p) = v` that falls out of
        // pure size-based dispatch.
        hip_emit_indent(depth)
        uint64 size = ast_data1(node)
        uint32 fk_store = ast_data3(node)
        hip_emit_cstr("*((")
        hip_emit_ptr_elem_type(size, fk_store)
        hip_emit_cstr("*)")
        uint32 addr = ast_child(node)
        uint64 wa = addr
        hip_emit_expr(wa)
        hip_emit_cstr(") = ")
        uint32 val = ast_data2(node)
        uint64 wv = val
        hip_emit_expr(wv)
        hip_emit_cstr(";\n")
        return
    }
    hip_emit_indent(depth)
    hip_emit_cstr("// unsupported stmt kind=")
    hip_emit_u64(k)
    hip_emit_byte(10)
}

// Variant that skips the leading indent (for else-if cascades where
// the `if` must sit right after the `else` keyword).
fn hip_emit_stmt_inline(uint64 node, uint64 depth) {
    uint32 k = ast_kind(node)
    if k == 13 {
        hip_emit_cstr("if (")
        uint32 cond = ast_child(node)
        uint64 wc = cond
        hip_emit_expr(wc)
        hip_emit_cstr(") ")
        uint32 then_body = ast_data1(node)
        uint64 wt = then_body
        hip_emit_block(wt, depth)
        uint32 else_body = ast_data2(node)
        if else_body != 0 {
            hip_emit_indent(depth)
            hip_emit_cstr("else ")
            uint64 we = else_body
            uint32 ek = ast_kind(we)
            if ek == 15 {
                hip_emit_block(we, depth)
            } else {
                hip_emit_stmt_inline(we, depth)
            }
        }
        return
    }
    // Fall back — this path only triggers for an `else SOMETHING` where
    // SOMETHING isn't If or Block, which the parser doesn't produce.
    hip_emit_stmt(node, depth)
}

// ---------------------------------------------------------------------------
// Kernel signature emission
// ---------------------------------------------------------------------------

// Emit one `Param` node: "TYPE NAME". `is_first` controls the comma.
fn hip_emit_param(uint64 param_node, uint64 is_first) {
    if is_first == 0 {
        hip_emit_cstr(", ")
    }
    uint32 type_tok = ast_data1(param_node)
    uint32 name_tok = ast_data2(param_node)
    uint64 ts = tok_text_start(type_tok)
    uint64 tl = tok_text_len(type_tok)
    hip_emit_str(hip_src + ts, tl)
    hip_emit_byte(32)  // ' '
    uint64 ns = tok_text_start(name_tok)
    uint64 nl = tok_text_len(name_tok)
    hip_emit_str(hip_src + ns, nl)
}

// Emit a full kernel declaration for one @kernel FnDecl node.
fn hip_emit_kernel(uint64 fn_node) {
    uint32 name_tok = ast_data1(fn_node)
    uint64 ns = tok_text_start(name_tok)
    uint64 nl = tok_text_len(name_tok)

    hip_emit_cstr("extern \"C\" __global__\n")
    hip_emit_cstr("void ")
    hip_emit_str(hip_src + ns, nl)
    hip_emit_byte(40)  // '('

    // Walk param list (children of the FnDecl node via ast_child + ast_next)
    uint32 p = ast_child(fn_node)
    uint64 wp = p
    uint64 first = 1
    while wp != 0 {
        hip_emit_param(wp, first)
        first = 0
        uint32 np = ast_next(wp)
        wp = np
    }

    hip_emit_cstr(") ")

    // Walk the body Block and emit C++. FnDecl.data3 holds the body's
    // Block node index (see parser.kr parse_fn_decl).
    uint32 body_node = ast_data3(fn_node)
    if body_node == 0 {
        hip_emit_cstr("{\n}\n\n")
        return
    }
    // Emit body open brace + LDS scratch buffer (every kernel gets a
    // 8 KiB f32 LDS pool addressable via lds_load_f32 / lds_store_f32),
    // then walk statements directly. Skipping the regular hip_emit_block
    // wrapper because we need to inject the __shared__ decl right after
    // the opening brace.
    hip_emit_cstr("{\n")
    hip_emit_cstr("    __shared__ float _lds_f32_buf[2048];\n")
    uint32 ch = ast_child(body_node)
    uint64 wch = ch
    while wch != 0 {
        hip_emit_stmt(wch, 1)
        uint32 nch = ast_next(wch)
        wch = nch
    }
    hip_emit_cstr("}\n")
    hip_emit_byte(10)  // trailing blank line between kernels
}

// ---------------------------------------------------------------------------
// Top-level entry
// ---------------------------------------------------------------------------

// Walk a parsed module, emit .hip source to <base_path>.hip on disk.
// `base_path` is a null-terminated C string. Returns:
//   0  — success, at least one kernel written
//   1  — no @kernel functions found (no file written)
//   2  — I/O error opening the output file
@export
fn emit_hip_artifacts(uint64 mod_node, uint64 source, uint64 base_path) -> uint64 {
    hip_init()
    hip_src = source

    // First pass: count kernels so we can skip emission if there are none.
    uint64 kernel_count = 0
    uint32 c0 = ast_child(mod_node)
    uint64 wc0 = c0
    while wc0 != 0 {
        uint32 k = ast_kind(wc0)
        if k == 2 {
            if ast_fn_is_kernel(wc0) != 0 { kernel_count = kernel_count + 1 }
        }
        uint32 n0 = ast_next(wc0)
        wc0 = n0
    }
    if kernel_count == 0 {
        return 1
    }

    // Second pass: emit.
    hip_emit_header()
    uint32 c1 = ast_child(mod_node)
    uint64 wc1 = c1
    while wc1 != 0 {
        uint32 k = ast_kind(wc1)
        if k == 2 {
            if ast_fn_is_kernel(wc1) != 0 {
                hip_emit_kernel(wc1)
            }
        }
        uint32 n1 = ast_next(wc1)
        wc1 = n1
    }

    // Build "<base_path>.hip" as a new C string in a fixed buffer.
    uint64 base_len = str_len(base_path)
    uint8[1024] out_path
    uint64 i = 0
    while i < base_len {
        uint64 sp = base_path + i
        uint64 b = 0
        unsafe { *(sp as uint8) -> b }
        uint64 dp = out_path + i
        uint8 b8 = b
        unsafe { *(dp as uint8) = b8 }
        i = i + 1
    }
    uint8 dot = 46   // '.'
    uint8 h = 104    // 'h'
    uint8 ii = 105   // 'i'
    uint8 pp = 112   // 'p'
    uint8 z = 0
    uint64 dp0 = out_path + base_len
    unsafe { *(dp0 as uint8) = dot }
    uint64 dp1 = out_path + base_len + 1
    unsafe { *(dp1 as uint8) = h }
    uint64 dp2 = out_path + base_len + 2
    unsafe { *(dp2 as uint8) = ii }
    uint64 dp3 = out_path + base_len + 3
    unsafe { *(dp3 as uint8) = pp }
    uint64 dp4 = out_path + base_len + 4
    unsafe { *(dp4 as uint8) = z }

    uint64 fd = file_open(out_path, 1)
    if fd == 0 {
        return 2
    }
    file_write(fd, hip_buf, hip_len)
    file_close(fd)

    return 0
}

// Accessor so main.kr can report the byte count to stdout after emission.
@export
fn emit_hip_len() -> uint64 {
    return hip_len
}

// ---------------------------------------------------------------------------
// hipcc invocation (M1c)
// ---------------------------------------------------------------------------
// Writes "<base>.<ext>\0" into `dst`. Caller must ensure `dst` has room
// for base_len + ext_len + 2 bytes. Returns total length (excluding NUL).
fn hip_build_ext_path(uint64 dst, uint64 base, uint64 ext) -> uint64 {
    uint64 blen = str_len(base)
    uint64 elen = str_len(ext)
    uint64 i = 0
    while i < blen {
        uint64 sp = base + i
        uint64 b = 0
        unsafe { *(sp as uint8) -> b }
        uint64 dp = dst + i
        uint8 b8 = b
        unsafe { *(dp as uint8) = b8 }
        i = i + 1
    }
    uint8 dot = 46
    uint64 dpd = dst + blen
    unsafe { *(dpd as uint8) = dot }
    uint64 j = 0
    while j < elen {
        uint64 sp2 = ext + j
        uint64 b2 = 0
        unsafe { *(sp2 as uint8) -> b2 }
        uint64 dp2 = dst + blen + 1 + j
        uint8 b28 = b2
        unsafe { *(dp2 as uint8) = b28 }
        j = j + 1
    }
    uint8 z = 0
    uint64 dpz = dst + blen + 1 + elen
    unsafe { *(dpz as uint8) = z }
    return blen + 1 + elen
}

// Fork + execve /opt/rocm/bin/hipcc to compile `<base>.hip` into
// `<base>.co` with --offload-arch=gfx1100 (AMD 7800XT, phase 1). Parent
// waits for the child; returns its exit code or >=1000 on fork/exec
// failure. x86_64 Linux host only — syscall numbers (57 fork, 61 wait4)
// are hard-coded. See docs/GPU_BACKEND.md.
@export
fn invoke_hipcc(uint64 base_path) -> uint64 {
    uint64 hipcc_path = "/opt/rocm/bin/hipcc"

    // Probe: open read-only. `file_open` returns a negative errno
    // encoded in the top of uint64 on failure.
    uint64 probe_fd = file_open(hipcc_path, 0)
    if probe_fd > 0xFFFFFFFFFFFFF000 {
        write(2, "mlrc: ", 6)
        uint64 hpl = str_len(hipcc_path)
        write(2, hipcc_path, hpl)
        write(2, " not found — install ROCm 6+ (amdgpu-install --usecase=hip)\n", 60)
        return 1001
    }
    file_close(probe_fd)

    uint8[1024] hip_path
    hip_build_ext_path(hip_path, base_path, "hip")
    uint8[1024] co_path
    hip_build_ext_path(co_path, base_path, "co")

    // argv: hipcc --genco --offload-arch=gfx1100 <hip_path> -o <co_path> NULL
    uint64 nargv = alloc(7 * 8)
    store64(nargv, hipcc_path)
    store64(nargv + 8, "--genco")
    store64(nargv + 16, "--offload-arch=gfx1100")
    store64(nargv + 24, hip_path)
    store64(nargv + 32, "-o")
    store64(nargv + 40, co_path)
    store64(nargv + 48, 0)

    // fork() — x86_64 Linux syscall 57
    uint64 pid = syscall_raw(57, 0, 0, 0, 0, 0, 0)
    if pid > 0xFFFFFFFFFFFFF000 {
        write(2, "mlrc: fork() failed\n", 20)
        return 1002
    }
    if pid == 0 {
        // Child: replace with hipcc. If execve returns we exit(127).
        exec_process_argv(hipcc_path, nargv)
        syscall_raw(60, 127, 0, 0, 0, 0, 0)
    }

    // Parent: wait4(pid, &status, 0, NULL) — x86_64 Linux syscall 61
    uint64 status_buf = alloc(8)
    syscall_raw(61, pid, status_buf, 0, 0, 0, 0)
    uint64 status = 0
    unsafe { *(status_buf as uint64) -> status }
    // Unix WEXITSTATUS: (status >> 8) & 0xFF when the child exit()'d
    // normally. Signal-exit produces 0..127 in the low byte and ignores
    // the high-byte decoding — good enough for "did it work?" gating.
    return (status >> 8) & 0xFF
}
// MLRift — AMDGPU code-object ELF emitter (Stage 1, milestone M1a).
//
// Produces a ROCm-loadable code object (raw amdgcn ELF, NOT a clang
// offload bundle) for a single handcrafted kernel. The target
// scenario for M1a is: write a no-op kernel (just `s_endpgm`),
// hand the blob to hipModuleLoadData, and confirm the loader
// accepts it plus hipModuleGetFunction resolves the kernel symbol.
//
// This is the scaffolding for Stage 1 as described in
// docs/GPU_ZERO_DEPENDENCY.md — it still keeps the existing
// --target=hip-amd (hipcc-driven) path intact. A new CLI flag
// `--target=amdgpu-native` drives this emitter instead.
//
// Layout mirrors what hipcc emits (stripped of the clang offload
// bundle wrapper), trimmed to the minimum the ROCm loader checks
// for code-object v4. References: /tmp/gpu_decay_amdgcn.co (from
// hipcc --genco, bundle-stripped) and the AMDGPU-ABI doc
// (https://llvm.org/docs/AMDGPUUsage.html#code-object-v4-metadata).
//
// File layout (matches hipcc's structural pattern):
//
//   0x000  ELF64 header
//   0x040  program headers (6 phdrs × 56 bytes)
//   0x1A0  .note                 (AMDGPU metadata, MsgPack)
//   ...    .dynsym               (3 entries: null, kernel, kernel.kd)
//   ...    .dynstr               (kernel name + ".kd" variant)
//   ...    .rodata               (64-byte kernel descriptor)
//   0x900  .text                 (page-aligned virtually)
//   ...    section headers
//   ...    .shstrtab
//
// Virtual addresses keep RX's page alignment modulo 0x1000:
// .text sits at vaddr = file_offset + 0x1000 so the RX PT_LOAD is
// a 0x1000-aligned page segment.

// ---------------------------------------------------------------------------
// Output buffer
// ---------------------------------------------------------------------------

static uint64 amd_buf = 0
static uint64 amd_len = 0
static uint64 amd_cap = 0

// Set to 1 by main.kr when `--target=amdgpu-native` is on the CLI.
// Gates the M1d emission path (see emit_amdgpu_from_module below).
static uint64 target_amdgpu_native = 0

// ---------------------------------------------------------------------------
// Kernel table (M1f)
//
// emit_amdgpu_code_object used to be a single-kernel path — everything
// from .dynsym to .rodata to .note hard-wired two symbols and one
// kernel body. M1f pluralises that: callers push entries into this
// table, then emit_amdgpu_multi_code_object walks them once to lay
// out every section.
//
// Entry layout (13 u64 fields × 8 bytes = 104 bytes/entry):
//   0: name_ptr      (host pointer to the kernel name string)
//   1: name_len
//   2: bytes_ptr     (host pointer to assembled kernel text)
//   3: bytes_len
//   4: args_desc     (host pointer to args descriptor, see amd_arg_*)
//   5: n_args
//   6: kernarg_size
//   7: sgpr_count
//   8: vgpr_count
//   9: rsrc1
//   10: rsrc2
//   11: rsrc3
//   12: props
//
// Plus per-kernel computed offsets filled in during emit (kept in
// parallel arrays because they're only relevant during the emit):
//   kt_kd_off[i]     — .rodata byte offset of kernel i's descriptor
//   kt_text_off[i]   — .text   byte offset of kernel i's first instr
//   kt_text_vaddr[i] — kd-to-entry delta lives in KD offset 0x10

static uint64 KT_STRIDE = 112
static uint64 KT_MAX    = 32
static uint64 kt_buf    = 0
static uint64 kt_count  = 0

// Per-kernel computed offsets, filled during emit_amdgpu_multi_code_object.
static uint64 kt_kd_off       = 0
static uint64 kt_text_off     = 0
static uint64 kt_text_vaddr   = 0

fn kt_reset() {
    if kt_buf == 0 {
        kt_buf        = alloc(KT_MAX * KT_STRIDE)
        kt_kd_off     = alloc(KT_MAX * 8)
        kt_text_off   = alloc(KT_MAX * 8)
        kt_text_vaddr = alloc(KT_MAX * 8)
    }
    kt_count = 0
}

fn kt_push(uint64 name_ptr, uint64 name_len,
           uint64 bytes_ptr, uint64 bytes_len,
           uint64 args_desc, uint64 n_args,
           uint64 kernarg_size,
           uint64 sgpr_count, uint64 vgpr_count,
           uint64 rsrc1, uint64 rsrc2, uint64 rsrc3, uint64 props) {
    // Thin wrapper: existing emitters call kt_push with 13 fields and
    // expect group_segment_fixed_size = 0 (no LDS). LDS-using emitters
    // call kt_push_lds instead.
    kt_push_lds(name_ptr, name_len, bytes_ptr, bytes_len,
                args_desc, n_args, kernarg_size,
                sgpr_count, vgpr_count, rsrc1, rsrc2, rsrc3, props,
                0)
}

fn kt_push_lds(uint64 name_ptr, uint64 name_len,
               uint64 bytes_ptr, uint64 bytes_len,
               uint64 args_desc, uint64 n_args,
               uint64 kernarg_size,
               uint64 sgpr_count, uint64 vgpr_count,
               uint64 rsrc1, uint64 rsrc2, uint64 rsrc3, uint64 props,
               uint64 group_segment_size) {
    if kt_count >= KT_MAX {
        write(2, "format_amdgpu: kernel table overflow\n", 37)
        exit(1)
    }
    uint64 base = kt_buf + kt_count * KT_STRIDE
    uint64 p0  = base +   0; unsafe { *(p0  as uint64) = name_ptr }
    uint64 p1  = base +   8; unsafe { *(p1  as uint64) = name_len }
    uint64 p2  = base +  16; unsafe { *(p2  as uint64) = bytes_ptr }
    uint64 p3  = base +  24; unsafe { *(p3  as uint64) = bytes_len }
    uint64 p4  = base +  32; unsafe { *(p4  as uint64) = args_desc }
    uint64 p5  = base +  40; unsafe { *(p5  as uint64) = n_args }
    uint64 p6  = base +  48; unsafe { *(p6  as uint64) = kernarg_size }
    uint64 p7  = base +  56; unsafe { *(p7  as uint64) = sgpr_count }
    uint64 p8  = base +  64; unsafe { *(p8  as uint64) = vgpr_count }
    uint64 p9  = base +  72; unsafe { *(p9  as uint64) = rsrc1 }
    uint64 p10 = base +  80; unsafe { *(p10 as uint64) = rsrc2 }
    uint64 p11 = base +  88; unsafe { *(p11 as uint64) = rsrc3 }
    uint64 p12 = base +  96; unsafe { *(p12 as uint64) = props }
    uint64 p13 = base + 104; unsafe { *(p13 as uint64) = group_segment_size }
    kt_count = kt_count + 1
}

fn kt_get(uint64 idx, uint64 field_idx) -> uint64 {
    uint64 p = kt_buf + idx * KT_STRIDE + field_idx * 8
    uint64 v = 0
    unsafe { *(p as uint64) -> v }
    return v
}

fn kt_set_u64_arr(uint64 arr, uint64 idx, uint64 v) {
    uint64 p = arr + idx * 8
    unsafe { *(p as uint64) = v }
}

fn kt_get_u64_arr(uint64 arr, uint64 idx) -> uint64 {
    uint64 p = arr + idx * 8
    uint64 v = 0
    unsafe { *(p as uint64) -> v }
    return v
}

@export
fn amd_buf_ptr() -> uint64 { return amd_buf }

@export
fn amd_buf_len() -> uint64 { return amd_len }

fn amd_init() {
    if amd_buf == 0 {
        amd_cap = 65536   // 64 KB is plenty for M1a/M1b
        amd_buf = alloc(amd_cap)
    }
    amd_len = 0
    // zero the buffer — we rely on zero-init for reserved fields
    uint64 i = 0
    while i < amd_cap {
        uint64 p = amd_buf + i
        uint8 z = 0
        unsafe { *(p as uint8) = z }
        i = i + 1
    }
}

fn amd_byte(uint64 v) {
    if amd_len >= amd_cap {
        write(2, "format_amdgpu: output buffer overflow\n", 38)
        exit(1)
    }
    uint64 p = amd_buf + amd_len
    uint8 b = v & 0xFF
    unsafe { *(p as uint8) = b }
    amd_len = amd_len + 1
}

fn amd_u16(uint64 v) {
    amd_byte(v & 0xFF)
    amd_byte((v >> 8) & 0xFF)
}

fn amd_u32(uint64 v) {
    amd_byte(v & 0xFF)
    amd_byte((v >> 8) & 0xFF)
    amd_byte((v >> 16) & 0xFF)
    amd_byte((v >> 24) & 0xFF)
}

fn amd_u64(uint64 v) {
    amd_u32(v & 0xFFFFFFFF)
    amd_u32((v >> 32) & 0xFFFFFFFF)
}

fn amd_bytes(uint64 src, uint64 n) {
    uint64 i = 0
    while i < n {
        uint64 sp = src + i
        uint64 b = 0
        unsafe { *(sp as uint8) -> b }
        amd_byte(b)
        i = i + 1
    }
}

fn amd_pad_to(uint64 target) {
    while amd_len < target { amd_byte(0) }
}

fn amd_align_up(uint64 n, uint64 a) -> uint64 {
    uint64 m = a - 1
    return (n + m) & ~m
}

fn amd_align(uint64 a) { amd_pad_to(amd_align_up(amd_len, a)) }

// Write a u32 at a specific offset (for back-patching).
fn amd_patch_u32(uint64 off, uint64 v) {
    uint64 p0 = amd_buf + off
    uint8 b0 = v & 0xFF
    unsafe { *(p0 as uint8) = b0 }
    uint64 p1 = amd_buf + off + 1
    uint8 b1 = (v >> 8) & 0xFF
    unsafe { *(p1 as uint8) = b1 }
    uint64 p2 = amd_buf + off + 2
    uint8 b2 = (v >> 16) & 0xFF
    unsafe { *(p2 as uint8) = b2 }
    uint64 p3 = amd_buf + off + 3
    uint8 b3 = (v >> 24) & 0xFF
    unsafe { *(p3 as uint8) = b3 }
}

// ---------------------------------------------------------------------------
// MsgPack mini-encoder — just enough for the AMD metadata we produce
// ---------------------------------------------------------------------------
//
// The metadata is a small map: top-level has 3 keys (amdhsa.kernels,
// amdhsa.target, amdhsa.version), and each kernel is a map with
// 15-ish keys. All strings are ASCII, short enough for fixstr; two
// values in the kernel map can overflow 32 (kernarg_size, max flat
// workgroup size) so we need the uint16 tag too.
//
// MsgPack reference (packed specification):
//   positive fixint  0x00..0x7F
//   fixmap N         0x80 | (N & 0x0F)        (N < 16)
//   fixarray N       0x90 | (N & 0x0F)        (N < 16)
//   fixstr len       0xA0 | (len & 0x1F)      (len <= 31)
//   false            0xC2
//   true             0xC3
//   uint8            0xCC <u8>
//   uint16           0xCD <u16 BE>
//   uint32           0xCE <u32 BE>
//   str8             0xD9 <u8 len> <bytes>
//   map16            0xDE <u16 BE count>

fn mp_fixmap(uint64 n) {
    uint64 tag = 0x80 | (n & 0x0F)
    amd_byte(tag)
}

fn mp_fixarray(uint64 n) {
    if n < 16 {
        uint64 tag = 0x90 | (n & 0x0F)
        amd_byte(tag)
    } else {
        // array16 tag: 0xDC followed by u16 BE count. Needed once
        // kernels with more than 15 kernargs appeared (M1t-3's
        // lif_stp has 19 kernargs; lif_full will have 22).
        amd_byte(0xDC)
        amd_byte((n >> 8) & 0xFF)
        amd_byte(n & 0xFF)
    }
}

fn mp_map16(uint64 n) {
    amd_byte(0xDE)
    amd_byte((n >> 8) & 0xFF)
    amd_byte(n & 0xFF)
}

fn mp_str_bytes(uint64 ptr, uint64 len) {
    if len <= 31 {
        uint64 tag = 0xA0 | (len & 0x1F)
        amd_byte(tag)
    } else if len <= 255 {
        amd_byte(0xD9)
        amd_byte(len & 0xFF)
    } else {
        write(2, "format_amdgpu: mp_str length > 255 unsupported\n", 47)
        exit(1)
    }
    amd_bytes(ptr, len)
}

// mp_str_lit — convenience for compile-time constant strings.
fn mp_str_lit(uint64 s) { mp_str_bytes(s, str_len(s)) }

fn mp_uint(uint64 v) {
    if v < 0x80 {
        amd_byte(v)
    } else if v <= 0xFF {
        amd_byte(0xCC)
        amd_byte(v)
    } else if v <= 0xFFFF {
        amd_byte(0xCD)
        amd_byte((v >> 8) & 0xFF)
        amd_byte(v & 0xFF)
    } else if v <= 0xFFFFFFFF {
        amd_byte(0xCE)
        amd_byte((v >> 24) & 0xFF)
        amd_byte((v >> 16) & 0xFF)
        amd_byte((v >> 8)  & 0xFF)
        amd_byte(v & 0xFF)
    } else {
        write(2, "format_amdgpu: mp_uint > 2^32 unsupported\n", 42)
        exit(1)
    }
}

fn mp_true()  { amd_byte(0xC3) }
fn mp_false() { amd_byte(0xC2) }

// ---------------------------------------------------------------------------
// AMD kernel metadata (.note body)
// ---------------------------------------------------------------------------
//
// Emits the complete MsgPack blob that goes inside the NT_AMDGPU_METADATA
// note. Returns the byte length written. Shape:
//
//   { "amdhsa.kernels": [ {...} ],
//     "amdhsa.target":  "amdgcn-amd-amdhsa--gfx1100",
//     "amdhsa.version": [1, 2] }
//
// The inner kernel map lists the bare minimum fields ROCm's loader
// inspects for a zero-kernarg / zero-resource kernel. Future
// milestones (M1b onwards) will extend `.args`.

// Args descriptor layout:
//   [arg0_size, arg0_kind, arg1_size, arg1_kind, ...]
// Each entry is 16 bytes (two u64s). Kinds: 0 = global_buffer,
// 1 = by_value. The encoder treats an empty (n_args=0) descriptor
// as "no kernargs" — same as the M1a nop kernel.
static uint64 AMD_ARG_KIND_GLOBAL_BUFFER = 0
static uint64 AMD_ARG_KIND_BY_VALUE      = 1

fn amd_arg_size_at(uint64 desc, uint64 i) -> uint64 {
    uint64 p = desc + i * 16
    uint64 v = 0
    unsafe { *(p as uint64) -> v }
    return v
}

fn amd_arg_kind_at(uint64 desc, uint64 i) -> uint64 {
    uint64 p = desc + i * 16 + 8
    uint64 v = 0
    unsafe { *(p as uint64) -> v }
    return v
}

// Emit the MsgPack body for all kernels currently registered in
// the kernel table. Each kernel contributes one entry in the
// `amdhsa.kernels` fixarray; top-level keys (`amdhsa.target`,
// `amdhsa.version`) are singletons.
fn amd_emit_metadata_body() -> uint64 {
    uint64 start = amd_len

    // Top-level map with 3 entries.
    mp_fixmap(3)

    // "amdhsa.kernels" -> [ {...} × kt_count ]
    mp_str_lit("amdhsa.kernels")
    mp_fixarray(kt_count)

    uint64 ki = 0
    while ki < kt_count {
        uint64 kname_ptr    = kt_get(ki, 0)
        uint64 kname_len    = kt_get(ki, 1)
        uint64 args_desc    = kt_get(ki, 4)
        uint64 n_args       = kt_get(ki, 5)
        uint64 kernarg_sz   = kt_get(ki, 6)
        uint64 sgpr_count   = kt_get(ki, 7)
        uint64 vgpr_count   = kt_get(ki, 8)
        uint64 group_seg_sz = kt_get(ki, 13)

        // 16-entry inner map: needs map16 not fixmap (caps at 15).
        mp_map16(16)

        // .args — per-arg fixmap, shape depends on kind. See
        // amd_emit_metadata_body's original comment for field layout.
        mp_str_lit(".args")
        mp_fixarray(n_args)
        uint64 aai  = 0
        uint64 aoff = 0
        while aai < n_args {
            uint64 sz   = amd_arg_size_at(args_desc, aai)
            uint64 kind = amd_arg_kind_at(args_desc, aai)
            // Each arg sits at its natural alignment within the
            // kernarg segment. The AMDGPU ABI aligns to the arg's
            // own size for primitives (e.g. f64 rounds to 8). Without
            // this the decay kernel's factor gets offset=12 and the
            // kernel reads the wrong 8 bytes.
            if sz > 1 {
                uint64 rem = aoff - (aoff / sz) * sz
                if rem != 0 { aoff = aoff + sz - rem }
            }
            if kind == AMD_ARG_KIND_GLOBAL_BUFFER {
                mp_fixmap(4)
                mp_str_lit(".address_space"); mp_str_lit("global")
                mp_str_lit(".offset");        mp_uint(aoff)
                mp_str_lit(".size");          mp_uint(sz)
                mp_str_lit(".value_kind");    mp_str_lit("global_buffer")
            } else {
                mp_fixmap(3)
                mp_str_lit(".offset");        mp_uint(aoff)
                mp_str_lit(".size");          mp_uint(sz)
                mp_str_lit(".value_kind");    mp_str_lit("by_value")
            }
            aoff = aoff + sz
            aai  = aai + 1
        }
        mp_str_lit(".group_segment_fixed_size");   mp_uint(group_seg_sz)
        mp_str_lit(".kernarg_segment_align");      mp_uint(8)
        mp_str_lit(".kernarg_segment_size");       mp_uint(kernarg_sz)
        mp_str_lit(".max_flat_workgroup_size");    mp_uint(1024)
        mp_str_lit(".name");                       mp_str_bytes(kname_ptr, kname_len)
        mp_str_lit(".private_segment_fixed_size"); mp_uint(0)
        mp_str_lit(".sgpr_count");                 mp_uint(sgpr_count)
        mp_str_lit(".sgpr_spill_count");           mp_uint(0)

        // .symbol = <name>.kd — built inline per kernel.
        uint8[256] ksym_buf
        uint64 ki_sb = 0
        while ki_sb < kname_len {
            uint64 src = kname_ptr + ki_sb
            uint64 b = 0
            unsafe { *(src as uint8) -> b }
            uint64 dst = ksym_buf + ki_sb
            uint8 b8 = b
            unsafe { *(dst as uint8) = b8 }
            ki_sb = ki_sb + 1
        }
        uint64 sp_dot = ksym_buf + kname_len
        uint8 dot = 46; unsafe { *(sp_dot as uint8) = dot }
        uint64 sp_k = ksym_buf + kname_len + 1
        uint8 k8 = 107; unsafe { *(sp_k as uint8) = k8 }
        uint64 sp_d = ksym_buf + kname_len + 2
        uint8 d8 = 100; unsafe { *(sp_d as uint8) = d8 }
        uint64 ksym_len = kname_len + 3
        mp_str_lit(".symbol");                     mp_str_bytes(ksym_buf, ksym_len)

        mp_str_lit(".uniform_work_group_size");    mp_uint(1)
        mp_str_lit(".uses_dynamic_stack");         mp_false()
        mp_str_lit(".vgpr_count");                 mp_uint(vgpr_count)
        mp_str_lit(".vgpr_spill_count");           mp_uint(0)
        mp_str_lit(".wavefront_size");             mp_uint(32)
        mp_str_lit(".workgroup_processor_mode");   mp_uint(1)

        ki = ki + 1
    }

    //   "amdhsa.target" -> "amdgcn-amd-amdhsa--gfx1100"
    mp_str_lit("amdhsa.target")
    mp_str_bytes(amdgpu_target_arch_str_ptr(), amdgpu_target_arch_str_len())

    //   "amdhsa.version" -> [1, 2]
    mp_str_lit("amdhsa.version")
    mp_fixarray(2)
    mp_uint(1)
    mp_uint(2)

    return amd_len - start
}

// ---------------------------------------------------------------------------
// Kernel descriptor (64 bytes) — lives in .rodata, referenced by the
// symbol "<kernel>.kd". Layout from AMDGPU ABI v4 (same offsets as v5).
//
//   0x00 u32  group_segment_fixed_size
//   0x04 u32  private_segment_fixed_size
//   0x08 u32  kernarg_size
//   0x0C u8[4] reserved
//   0x10 i64  kernel_code_entry_byte_offset   (from KD start to .text entry)
//   0x18 u8[20] reserved
//   0x2C u32  compute_pgm_rsrc3
//   0x30 u32  compute_pgm_rsrc1
//   0x34 u32  compute_pgm_rsrc2
//   0x38 u16  kernel_code_properties
//   0x3A u8   kernarg_preload_length
//   0x3B u8   kernarg_preload_offset
//   0x3C u8[4] reserved

fn amd_emit_kernel_descriptor(uint64 kernarg_size, uint64 entry_offset,
                              uint64 rsrc1, uint64 rsrc2, uint64 rsrc3,
                              uint64 properties, uint64 group_segment_size) {
    // 0x00
    amd_u32(group_segment_size)       // group_segment_fixed_size (LDS bytes)
    amd_u32(0)                        // private_segment_fixed_size
    amd_u32(kernarg_size)             // kernarg_size
    amd_u32(0)                        // reserved
    // 0x10
    amd_u64(entry_offset)             // signed offset to entry
    // 0x18
    amd_u64(0)
    amd_u64(0)
    amd_u32(0)                        // reserved block (20 bytes)
    // 0x2C
    amd_u32(rsrc3)                    // compute_pgm_rsrc3
    // 0x30
    amd_u32(rsrc1)                    // compute_pgm_rsrc1
    amd_u32(rsrc2)                    // compute_pgm_rsrc2
    // 0x38
    amd_u16(properties)
    amd_byte(0)                       // kernarg_preload_length
    amd_byte(0)                       // kernarg_preload_offset
    amd_u32(0)                        // reserved tail
}

// ---------------------------------------------------------------------------
// ELF emission
// ---------------------------------------------------------------------------
//
// We lay the file out in a single pass, using fixed offsets that
// mirror the hipcc-produced code object but trimmed for M1a. All
// offsets below are PICKED at layout time; there is no back-patch
// pass. The section / segment sizes follow from string/content
// lengths we compute up front.

static uint64 AMD_ELF_HEADER_SIZE   = 64
static uint64 AMD_PHDR_SIZE         = 56
static uint64 AMD_SHDR_SIZE         = 64
static uint64 AMD_SYMBOL_SIZE       = 24

// ELF constants
static uint64 ELF_ET_DYN            = 3
static uint64 ELF_EM_AMDGPU         = 224
static uint64 ELF_OSABI_AMDGPU_HSA  = 64
static uint64 ELF_AMDHSA_ABI_V4     = 4
// AMDGPU machine flags — values from LLVM EF_AMDGPU_MACH defines.
// Each gfx target needs a distinct e_flags value in the .co's ELF
// header.  Adding more targets here is the first step to making the
// AST-walker recognisers backend-portable (Slice B/C of the strategic
// memo).
static uint64 ELF_EF_AMDGPU_GFX1030 = 0x36   // RDNA2 (RX 6800/6900)
static uint64 ELF_EF_AMDGPU_GFX1031 = 0x37   // RDNA2 (RX 6700)
static uint64 ELF_EF_AMDGPU_GFX1033 = 0x39   // RDNA2 (Steam Deck APU)
static uint64 ELF_EF_AMDGPU_GFX1100 = 0x41   // RDNA3 (RX 7800 XT, current dev box)
static uint64 ELF_EF_AMDGPU_GFX1101 = 0x42   // RDNA3 (RX 7700 XT)
static uint64 ELF_EF_AMDGPU_GFX1200 = 0x4C   // RDNA4 (RX 9070)

// Selected target architecture for amdgpu-native emit.  Default = 0
// keeps the gfx1100 behavior every existing test expects.  Flip via
// `target_arch_set()` (called from --target-arch= CLI handler) before
// any kernel emit.
//
// Encoding: 0=gfx1100, 1=gfx1030, 2=gfx1031, 3=gfx1033, 4=gfx1101, 5=gfx1200.
static uint64 _amdgpu_target_arch = 0

@export
fn amdgpu_target_arch_set(uint64 a) {
    _amdgpu_target_arch = a
}

@export
fn amdgpu_target_arch_eflags() -> uint64 {
    if _amdgpu_target_arch == 1 { return ELF_EF_AMDGPU_GFX1030 }
    if _amdgpu_target_arch == 2 { return ELF_EF_AMDGPU_GFX1031 }
    if _amdgpu_target_arch == 3 { return ELF_EF_AMDGPU_GFX1033 }
    if _amdgpu_target_arch == 4 { return ELF_EF_AMDGPU_GFX1101 }
    if _amdgpu_target_arch == 5 { return ELF_EF_AMDGPU_GFX1200 }
    return ELF_EF_AMDGPU_GFX1100
}

// Returns the literal ASCII bytes of the LLVM target triple suffix
// (e.g., "gfx1100", "gfx1030") to embed in the amdhsa.target msgpack
// string.  Caller emits "amdgcn-amd-amdhsa--<suffix>".
@export
fn amdgpu_target_arch_str_ptr() -> uint64 {
    _amdgpu_target_str_init_once()
    if _amdgpu_target_arch == 1 { return amdgpu_target_str_gfx1030 }
    if _amdgpu_target_arch == 2 { return amdgpu_target_str_gfx1031 }
    if _amdgpu_target_arch == 3 { return amdgpu_target_str_gfx1033 }
    if _amdgpu_target_arch == 4 { return amdgpu_target_str_gfx1101 }
    if _amdgpu_target_arch == 5 { return amdgpu_target_str_gfx1200 }
    return amdgpu_target_str_gfx1100
}

@export
fn amdgpu_target_arch_str_len() -> uint64 {
    return 26
}

// All target strings have the same 26-byte length: "amdgcn-amd-amdhsa--gfxNNNN".
static uint64 amdgpu_target_str_gfx1030 = 0
static uint64 amdgpu_target_str_gfx1031 = 0
static uint64 amdgpu_target_str_gfx1033 = 0
static uint64 amdgpu_target_str_gfx1100 = 0
static uint64 amdgpu_target_str_gfx1101 = 0
static uint64 amdgpu_target_str_gfx1200 = 0
static uint64 _amdgpu_target_str_init   = 0

// Allocate the six target-string buffers lazily.  Called automatically
// the first time amdgpu_target_arch_str_ptr() is invoked.
fn _amdgpu_target_str_init_once() {
    if _amdgpu_target_str_init != 0 { return }
    amdgpu_target_str_gfx1030 = alloc(26)
    amdgpu_target_str_gfx1031 = alloc(26)
    amdgpu_target_str_gfx1033 = alloc(26)
    amdgpu_target_str_gfx1100 = alloc(26)
    amdgpu_target_str_gfx1101 = alloc(26)
    amdgpu_target_str_gfx1200 = alloc(26)
    // Common prefix "amdgcn-amd-amdhsa--gfx" (22 bytes), then 4-digit gfx ID.
    uint64 prefix = "amdgcn-amd-amdhsa--gfx"
    uint64 i = 0
    while i < 22 {
        uint8 c = 0
        unsafe { *((prefix + i) as uint8) -> c }
        unsafe { *((amdgpu_target_str_gfx1030 + i) as uint8) = c }
        unsafe { *((amdgpu_target_str_gfx1031 + i) as uint8) = c }
        unsafe { *((amdgpu_target_str_gfx1033 + i) as uint8) = c }
        unsafe { *((amdgpu_target_str_gfx1100 + i) as uint8) = c }
        unsafe { *((amdgpu_target_str_gfx1101 + i) as uint8) = c }
        unsafe { *((amdgpu_target_str_gfx1200 + i) as uint8) = c }
        i = i + 1
    }
    // Per-target 4-byte IDs: gfx<NNNN>.
    uint8 c0 = 49  // '1'
    unsafe { *((amdgpu_target_str_gfx1030 + 22) as uint8) = c0 }
    unsafe { *((amdgpu_target_str_gfx1030 + 23) as uint8) = c0 - 1 }   // '0'
    unsafe { *((amdgpu_target_str_gfx1030 + 24) as uint8) = c0 + 2 }   // '3'
    unsafe { *((amdgpu_target_str_gfx1030 + 25) as uint8) = c0 - 1 }   // '0'
    unsafe { *((amdgpu_target_str_gfx1031 + 22) as uint8) = c0 }
    unsafe { *((amdgpu_target_str_gfx1031 + 23) as uint8) = c0 - 1 }
    unsafe { *((amdgpu_target_str_gfx1031 + 24) as uint8) = c0 + 2 }
    unsafe { *((amdgpu_target_str_gfx1031 + 25) as uint8) = c0 }       // '1'
    unsafe { *((amdgpu_target_str_gfx1033 + 22) as uint8) = c0 }
    unsafe { *((amdgpu_target_str_gfx1033 + 23) as uint8) = c0 - 1 }
    unsafe { *((amdgpu_target_str_gfx1033 + 24) as uint8) = c0 + 2 }
    unsafe { *((amdgpu_target_str_gfx1033 + 25) as uint8) = c0 + 2 }   // '3'
    unsafe { *((amdgpu_target_str_gfx1100 + 22) as uint8) = c0 }
    unsafe { *((amdgpu_target_str_gfx1100 + 23) as uint8) = c0 }
    unsafe { *((amdgpu_target_str_gfx1100 + 24) as uint8) = c0 - 1 }
    unsafe { *((amdgpu_target_str_gfx1100 + 25) as uint8) = c0 - 1 }
    unsafe { *((amdgpu_target_str_gfx1101 + 22) as uint8) = c0 }
    unsafe { *((amdgpu_target_str_gfx1101 + 23) as uint8) = c0 }
    unsafe { *((amdgpu_target_str_gfx1101 + 24) as uint8) = c0 - 1 }
    unsafe { *((amdgpu_target_str_gfx1101 + 25) as uint8) = c0 }
    unsafe { *((amdgpu_target_str_gfx1200 + 22) as uint8) = c0 }
    unsafe { *((amdgpu_target_str_gfx1200 + 23) as uint8) = c0 + 1 }   // '2'
    unsafe { *((amdgpu_target_str_gfx1200 + 24) as uint8) = c0 - 1 }
    unsafe { *((amdgpu_target_str_gfx1200 + 25) as uint8) = c0 - 1 }
    _amdgpu_target_str_init = 1
}

static uint64 ELF_PT_LOAD           = 1
static uint64 ELF_PT_DYNAMIC        = 2
static uint64 ELF_PT_NOTE           = 4
static uint64 ELF_PT_PHDR           = 6

static uint64 ELF_PF_X              = 1
static uint64 ELF_PF_W              = 2
static uint64 ELF_PF_R              = 4

static uint64 ELF_SHT_NULL          = 0
static uint64 ELF_SHT_PROGBITS      = 1
static uint64 ELF_SHT_SYMTAB        = 2
static uint64 ELF_SHT_STRTAB        = 3
static uint64 ELF_SHT_HASH          = 5
static uint64 ELF_SHT_DYNAMIC       = 6
static uint64 ELF_SHT_NOTE          = 7
static uint64 ELF_SHT_DYNSYM        = 11

// .dynamic DT_* tags
static uint64 DT_NULL               = 0
static uint64 DT_HASH               = 4
static uint64 DT_STRTAB             = 5
static uint64 DT_SYMTAB             = 6
static uint64 DT_STRSZ              = 10
static uint64 DT_SYMENT             = 11

static uint64 ELF_SHF_WRITE         = 1
static uint64 ELF_SHF_ALLOC         = 2
static uint64 ELF_SHF_EXECINSTR     = 4

// Symbol binding + type packed into st_info
static uint64 ELF_STB_LOCAL         = 0
static uint64 ELF_STB_GLOBAL        = 1
static uint64 ELF_STT_NOTYPE        = 0
static uint64 ELF_STT_OBJECT        = 1
static uint64 ELF_STT_FUNC          = 2
static uint64 ELF_STV_DEFAULT       = 0
static uint64 ELF_STV_PROTECTED     = 3

fn amd_st_info(uint64 bind, uint64 typ) -> uint64 {
    return ((bind & 0xF) << 4) | (typ & 0xF)
}

// Emit the NT_AMDGPU_METADATA note: name="AMDGPU\0\0" (8 bytes) +
// MsgPack body. Returns total note bytes written. Pulls kernel
// list from the kernel table.
fn amd_emit_note_section() -> uint64 {
    uint64 start = amd_len
    uint64 hdr_off = amd_len
    amd_u32(7)            // n_namesz = strlen("AMDGPU") + 1 = 7
    amd_u32(0)            // n_descsz — back-patched
    amd_u32(0x20)         // n_type = NT_AMDGPU_METADATA = 32
    // name: "AMDGPU\0" padded to 4 bytes → "AMDGPU\0\0"
    amd_byte(65)  // A
    amd_byte(77)  // M
    amd_byte(68)  // D
    amd_byte(71)  // G
    amd_byte(80)  // P
    amd_byte(85)  // U
    amd_byte(0)
    amd_byte(0)   // padding to 8-byte name area
    // Body
    uint64 body_len = amd_emit_metadata_body()
    amd_patch_u32(hdr_off + 4, body_len)
    amd_align(4)
    return amd_len - start
}

// ---------------------------------------------------------------------------
// gfx1100 instruction encoder (M1c subset)
//
// We only encode what write_sentinel needs: SOPP (s_endpgm,
// s_waitcnt), SMEM (s_load_b64), a single VOPD shape
// (v_dual_mov_b32 + v_dual_mov_b32 with a 32-bit literal), and
// one FLAT/GLOBAL form (global_store_b32 with SADDR). Enough to
// take the kernel from hand-pasted bytes to structured calls;
// broader coverage grows as Stage 1 proper lands.
//
// All encoders write 32-bit words little-endian into a dedicated
// kernel-text buffer (`asm_text_buf`) so the caller can pass the
// full text to emit_amdgpu_code_object without tangling it with
// the surrounding ELF layout.
// ---------------------------------------------------------------------------

static uint64 asm_text_buf = 0
static uint64 asm_text_len = 0
static uint64 asm_text_cap = 0

fn asm_init() {
    if asm_text_buf == 0 {
        // Slice 4.19.4: bumped from 4096 → 16384 to fit the mega-kernel
        // phase 7 attn_decode-coop emit (2× 128-fmac unrolled inner dot
        // products + 3-pass softmax + cooperative output ≈ 5 KB of ISA on
        // top of phases 1/3/5 which already total ~3 KB).
        asm_text_cap = 16384
        asm_text_buf = alloc(asm_text_cap)
    }
    asm_text_len = 0
}

fn asm_byte(uint64 v) {
    if asm_text_len >= asm_text_cap {
        write(2, "format_amdgpu: asm text overflow\n", 33)
        exit(1)
    }
    uint64 p = asm_text_buf + asm_text_len
    uint8 b = v & 0xFF
    unsafe { *(p as uint8) = b }
    asm_text_len = asm_text_len + 1
}

fn asm_u32(uint64 word) {
    asm_byte(word & 0xFF)
    asm_byte((word >> 8)  & 0xFF)
    asm_byte((word >> 16) & 0xFF)
    asm_byte((word >> 24) & 0xFF)
}

// Patch a previously-emitted dword in place. Used to back-fill branch
// offsets that depend on the rest of the kernel body (e.g.,
// s_cbranch_scc1 to .Lend, where the offset is only knowable after
// the full kernel has been emitted).
fn asm_patch_u32(uint64 dword_idx, uint64 word) {
    uint64 p = asm_text_buf + dword_idx * 4
    uint8 b0 =  word        & 0xFF
    uint8 b1 = (word >> 8)  & 0xFF
    uint8 b2 = (word >> 16) & 0xFF
    uint8 b3 = (word >> 24) & 0xFF
    unsafe { *(p as uint8) = b0 }
    uint64 p1 = p + 1; unsafe { *(p1 as uint8) = b1 }
    uint64 p2 = p + 2; unsafe { *(p2 as uint8) = b2 }
    uint64 p3 = p + 3; unsafe { *(p3 as uint8) = b3 }
}

// ─── Slice B target-arch-aware ISA emit ─────────────────────────────
// Many gfx10 ↔ gfx11 instructions share semantics but encode to
// different dwords (ops shifted, NULL register renumbered, SOPP/SMEM
// imm fields rearranged).  Rather than re-derive every field layout,
// we keep the established gfx11 dwords inline and use this pair
// helper to substitute the gfx10 equivalent when targeting RDNA2.
//
// Each call site carries BOTH pre-verified dwords; the runtime just
// picks one. Verified against `llvm-mc -mcpu=gfx{1030,1100}` probes
// on the exact instruction stream emitted by residual_add_f32.

fn _is_gfx10() -> uint64 {
    uint64 a = _amdgpu_target_arch
    if a == 1 { return 1 }   // gfx1030
    if a == 2 { return 1 }   // gfx1031
    if a == 3 { return 1 }   // gfx1033
    return 0                  // 0=gfx1100, 4=gfx1101, 5=gfx1200 use gfx11 encoding
}

// Emit one dword, picking gfx10 vs gfx11 by current target.
fn asm_u32_arch(uint64 gfx11_word, uint64 gfx10_word) {
    if _is_gfx10() != 0 { asm_u32(gfx10_word) } else { asm_u32(gfx11_word) }
}

// integer log2 for power-of-two inputs.  Asserts (returns 0xFF) if the
// input isn't a power of two; emit-time helpers should validate before
// calling.
fn _ilog2_pow2(uint64 n) -> uint64 {
    if n == 0 { return 0xFF }
    if (n & (n - 1)) != 0 { return 0xFF }
    uint64 k = 0
    uint64 m = n
    while m > 1 { m = m >> 1; k = k + 1 }
    return k
}

// One step of the LDS pairwise reduction over a power-of-two block.
// Each step:
//   ds_load_b32 v7, v6 offset:(stride*4)   ; pull from neighbour
//   v_<reduce>_f32 v5, v5, v7              ; reduce_op_dword picks max/add
//   gate lanes < stride, gated ds_store back to LDS[lane*4]
//   barrier
// `saved_exec_sgpr` is the SGPR number used for the s_and_saveexec
// (softmax uses s12; layernorm/rmsnorm use s14).
fn _emit_reduce_step_pow2(uint64 stride, uint64 reduce_op_dword,
                          uint64 saved_exec_sgpr) {
    uint64 byte_off = stride * 4
    // ds_load_b32 v7, v6 offset:byte_off  (DS encoding stable across gfx10/11)
    asm_u32(0xD8D80000 | (byte_off & 0xFFFF))
    asm_u32(0x07000006)
    // s_waitcnt lgkmcnt(0)
    asm_u32_arch(0xBF89FC07, 0xBF8CC07F)
    // v_<max|add>_f32_e32 v5, v5, v7  (VOP2 op stable)
    asm_u32(reduce_op_dword)
    // v_cmp_gt_u32_e32 vcc_lo, stride, v0  (VOPC op shift gfx11 0x4C → gfx10 0xC4)
    if stride <= 64 {
        uint64 inline_byte = 0x80 + stride
        asm_u32_arch(0x7C980000 | inline_byte, 0x7D880000 | inline_byte)
    } else {
        asm_u32_arch(0x7C9800FF, 0x7D8800FF)
        asm_u32(stride)
    }
    // s_and_saveexec_b32 saved_exec, vcc_lo  (SOP1 op 0x20 → 0x3C)
    uint64 sgpr_field = 0x80 | (saved_exec_sgpr & 0x7F)
    asm_u32_arch(0xBE00206A | (sgpr_field << 16),
                 0xBE003C6A | (sgpr_field << 16))
    // ds_store_b32 v6, v5  (DS encoding stable)
    asm_u32(0xD8340000)
    asm_u32(0x00000506)
    // s_mov_b32 exec_lo, saved_exec  (SOP1 op 0x00 → 0x03)
    asm_u32_arch(0xBEFE0000 | (saved_exec_sgpr & 0xFF),
                 0xBEFE0300 | (saved_exec_sgpr & 0xFF))
    // s_waitcnt lgkmcnt(0)
    asm_u32_arch(0xBF89FC07, 0xBF8CC07F)
    // s_barrier  (SOPP op 0x3D → 0x0A)
    asm_u32_arch(0xBFBD0000, 0xBF8A0000)
}

// Emit the full LDS pairwise reduction tree for a power-of-two N.
// Caller is responsible for the initial ds_store + barrier that puts
// every lane's value into LDS[lane*4] before this is called.
//
// reduce_op_dword:
//   0x200A0F05  for v_max_f32_e32 v5, v5, v7  (used by softmax phase A)
//   0x060A0F05  for v_add_f32_e32 v5, v5, v7  (used by softmax phase B,
//                                              layernorm/rmsnorm sum-of-…)
fn _emit_lds_reduce_pow2(uint64 N, uint64 reduce_op_dword,
                         uint64 saved_exec_sgpr) {
    uint64 stride = N / 2
    while stride >= 1 {
        _emit_reduce_step_pow2(stride, reduce_op_dword, saved_exec_sgpr)
        stride = stride / 2
    }
}

// f32 bit pattern for 1/N when N is a power of two.
// 1/N = 2^-log2(N); IEEE-754 exponent field = 127 - log2(N), mantissa = 0.
fn _f32_bits_recip_pow2(uint64 N) -> uint64 {
    uint64 e = _ilog2_pow2(N)
    if e == 0xFF { return 0 }
    return (127 - e) << 23
}

// Smallest power of two ≥ N. For N already a power of two returns N.
fn _round_up_pow2(uint64 N) -> uint64 {
    if N == 0 { return 1 }
    if (N & (N - 1)) == 0 { return N }
    uint64 p = 1
    while p < N { p = p << 1 }
    return p
}

// f32 bit pattern for 1/N for ANY N (used for non-power-of-two
// hidden_dim values like Qwen3-0.6B's 896 or Qwen3-1.5B's 1536).
// Computed by manual division: bias 127, then encode (1 + frac) * 2^e
// where 2^e ≤ 1/N < 2*2^e.  Uses round-to-nearest-even.
fn _f32_bits_recip(uint64 N) -> uint64 {
    if N == 0 { return 0 }
    // Find exponent e such that 2^-(e+1) < 1/N ≤ 2^-e, i.e.
    //   2^e ≤ N < 2^(e+1).  Same as floor(log2(N)).
    uint64 e = 0
    uint64 m = N
    while m > 1 { m = m >> 1; e = e + 1 }
    // Now 2^e ≤ N < 2^(e+1).  Need 1/N as (1 + frac) * 2^-(e+1)
    // when N > 2^e, else exact 2^-e when N == 2^e.
    if (N & (N - 1)) == 0 {
        // power of two, exact
        return (127 - e) << 23
    }
    // 1/N in [2^-(e+1), 2^-e); represent as 1.frac * 2^-(e+1)
    // where 1.frac = 2^(e+1) / N.  Compute (2^(e+1) << 23) / N to get
    // the 24-bit integer 1.frac (top bit = 1, rest = 23-bit mantissa).
    uint64 num = 1
    num = num << (e + 1 + 23)
    uint64 q = num / N
    uint64 rem = num - q * N
    // round-to-nearest-even: if 2*rem > N, round up; if ==, round to even.
    uint64 two_rem = rem * 2
    if two_rem > N {
        q = q + 1
    } else if two_rem == N {
        if (q & 1) != 0 { q = q + 1 }
    }
    // q is now the 24-bit value 1.frac (in 23 fractional bits + leading 1).
    // Strip the leading 1 bit (q's bit 23).  If rounding overflowed, adjust.
    if q == (1 << 24) {
        // rounded up to 2.0 → 1.0 * 2^-(e); shift exponent
        return (127 - e) << 23
    }
    uint64 mantissa = q & 0x7FFFFF
    uint64 exp_field = 127 - (e + 1)
    return (exp_field << 23) | mantissa
}

// Identity-fill preamble: for lanes where v0 (lane id) >= N, overwrite
// v10 with `identity_bits` so the subsequent reduction sees an
// identity element from the padding lanes.  Used when block size is
// Np = round_up_pow2(N) > N to handle non-power-of-two N.  Caller is
// responsible for ensuring the global_load that produced v10 was
// either gated to lane<N or had safe slack in the buffer (otherwise
// padding lanes' loads can fault on the last row).
//
//   v_cmp_lt_u32_e64 sX, v0, sN            (sX.lane = (lane < N))
//   v_mov_b32_e32    v15, identity_bits
//   v_cndmask_b32_e64 v10, v15, v10, sX    (lane<N → v10; lane>=N → v15)
//
// `mask_sgpr` is the SGPR used for the predicate (also used by the
// reduction tree as saved_exec — fine since the cndmask consumes it
// before the tree starts).  `n_kernarg_sgpr` holds the runtime N.
fn _emit_identity_fill_v10(uint64 mask_sgpr, uint64 n_kernarg_sgpr,
                           uint64 identity_bits) {
    // v_cmp_lt_u32_e64 mask_sgpr, v0, n_kernarg_sgpr  (VOP3 op 0x49 → 0xC1)
    asm_u32_arch(0xD4490000 | (mask_sgpr & 0x7F),
                 0xD4C10000 | (mask_sgpr & 0x7F))
    asm_u32(((n_kernarg_sgpr & 0xFF) << 9) | 0x100)
    // v_mov_b32_e32 v15, identity_bits  (literal-escape encoding, stable)
    asm_u32(0x7E1E02FF)
    asm_u32(identity_bits)
    // v_cndmask_b32_e64 v10, v15, v10, mask_sgpr  (VOP3 op stable)
    asm_u32(0xD501000A)
    asm_u32(0x0002150F | ((mask_sgpr & 0xFF) << 18))
}

// Identity-fill on v5 (instead of v10).  Used by layernorm in the
// mid-section to clear padding-lane v5 before Phase B's initial LDS
// store, since v5 = diff² = mean² for padding lanes (where v10 = 0
// makes diff = -mean) would pollute the variance reduction.
//
// v_cmp_lt_u32_e64 mask_sgpr, v0, sN
// v_mov_b32_e32    v15, identity_bits
// v_cndmask_b32_e64 v5, v15, v5, mask_sgpr   (lane<N → v5; lane>=N → v15)
//   src0 = v15 (0x10F), src1 = v5 (0x105), src2 = sX
//   low  = 0x10F | (0x105 << 9) | (sX << 18) = 0x20B0F | (sX << 18)
fn _emit_identity_fill_v5(uint64 mask_sgpr, uint64 n_kernarg_sgpr,
                          uint64 identity_bits) {
    asm_u32_arch(0xD4490000 | (mask_sgpr & 0x7F),
                 0xD4C10000 | (mask_sgpr & 0x7F))
    asm_u32(((n_kernarg_sgpr & 0xFF) << 9) | 0x100)
    asm_u32(0x7E1E02FF)
    asm_u32(identity_bits)
    asm_u32(0xD5010005)
    asm_u32(0x00020B0F | ((mask_sgpr & 0xFF) << 18))
}

// Gated global_load: load v10 from v[2:3] only on lanes where
// v0 < n_kernarg_sgpr.  Padding lanes get v10 = identity_bits (no
// load issued from them, so no risk of OOB faults on the last row).
//
//   v_cmp_lt_u32_e64 sX, v0, sN
//   v_mov_b32_e32    v10, identity_bits   ; default for masked lanes
//   s_and_saveexec_b32 sY, sX
//   global_load_b32 v10, v[2:3], off
//   s_waitcnt vmcnt(0)
//   s_mov_b32 exec_lo, sY                 ; restore exec for full block
//
// `mask_sgpr` and `save_sgpr` should be different so the saveexec'd
// value of exec is preserved for restoration.  They share a register
// in our use because mask_sgpr is dead by the time we restore (post-
// cndmask).  We pass the same sgpr for both.
fn _emit_gated_load_v10(uint64 mask_sgpr, uint64 n_kernarg_sgpr,
                        uint64 identity_bits) {
    // v_cmp_lt_u32_e64 mask_sgpr, v0, n_kernarg_sgpr  (VOP3 op shift)
    asm_u32_arch(0xD4490000 | (mask_sgpr & 0x7F),
                 0xD4C10000 | (mask_sgpr & 0x7F))
    asm_u32(((n_kernarg_sgpr & 0xFF) << 9) | 0x100)
    // v_mov_b32_e32 v10, identity_bits
    asm_u32(0x7E1402FF)
    asm_u32(identity_bits)
    // s_and_saveexec_b32 mask_sgpr, mask_sgpr  (SOP1 op 0x20 → 0x3C)
    asm_u32_arch(0xBE800000 | ((mask_sgpr & 0x7F) << 16) | 0x2000 | (mask_sgpr & 0x7F),
                 0xBE800000 | ((mask_sgpr & 0x7F) << 16) | 0x3C00 | (mask_sgpr & 0x7F))
    // global_load_b32 v10, v[2:3], off  (FLAT op + NULL re-encode)
    asm_u32_arch(0xDC520000, 0xDC308000)
    asm_u32_arch(0x0A7C0002, 0x0A7D0002)
    // s_waitcnt vmcnt(0)
    asm_u32_arch(0xBF8903F7, 0xBF8C3F70)
    // s_mov_b32 exec_lo, mask_sgpr  (SOP1 op 0x00 → 0x03)
    asm_u32_arch(0xBEFE0000 | (mask_sgpr & 0xFF),
                 0xBEFE0300 | (mask_sgpr & 0xFF))
}

// Final-store gating preamble: mask off lanes where v0 >= N so they
// don't write past the row's end.  Skips exec restore — caller must
// follow with s_endpgm.
//
//   v_cmp_lt_u32_e64 sX, v0, sN
//   s_and_saveexec_b32 sX, sX            (exec &= sX; sX := old exec)
fn _emit_store_gate(uint64 mask_sgpr, uint64 n_kernarg_sgpr) {
    // v_cmp_lt_u32_e64 mask_sgpr, v0, n_kernarg_sgpr  (VOP3 op 0x49 → 0xC1)
    asm_u32_arch(0xD4490000 | (mask_sgpr & 0x7F),
                 0xD4C10000 | (mask_sgpr & 0x7F))
    asm_u32(((n_kernarg_sgpr & 0xFF) << 9) | 0x100)
    // s_and_saveexec_b32 mask_sgpr, mask_sgpr  (SOP1 op 0x20 → 0x3C)
    asm_u32_arch(0xBE800000 | ((mask_sgpr & 0x7F) << 16) | 0x2000 | (mask_sgpr & 0x7F),
                 0xBE800000 | ((mask_sgpr & 0x7F) << 16) | 0x3C00 | (mask_sgpr & 0x7F))
}

// Build address pair v[lo:lo+1] = s[base_lo:base_lo+1] + v_off.  Used
// by thread-coarsened kernels to (re)build chunk-0 addresses from
// the saved byte-offset VGPR (typically v4).
fn _emit_vpair_build_from_sbase(uint64 vp_lo, uint64 sgpr_lo, uint64 v_off) {
    uint64 vp_hi = vp_lo + 1
    uint64 sgpr_hi = sgpr_lo + 1
    // v_mov_b32 v_hi, 0   — encoding 0x7E000280 | (vp_hi << 17)
    asm_u32(0x7E000280 | ((vp_hi & 0xFF) << 17))
    // v_add_co_u32 v_lo, vcc_lo, s_lo, v_off
    //   0xD7006A00 | vp_lo,  src0=s_lo, src1=v_off
    asm_u32(0xD7006A00 | (vp_lo & 0xFF))
    asm_u32(((0x100 | (v_off & 0xFF)) << 9) | (sgpr_lo & 0xFF))
    // v_add_co_ci_u32_e64 v_hi, null, s_hi, v_hi, vcc_lo
    //   0xD5207C00 | vp_hi
    asm_u32(0xD5207C00 | (vp_hi & 0xFF))
    asm_u32((0x6A << 18) | ((0x100 | (vp_hi & 0xFF)) << 9) | (sgpr_hi & 0xFF))
}

// Compute v_pos VGPR = chunk_off + v0.  Used by thread-coarsened
// causal attention to compute the global-element index for the mask.
// VOP2 vdst occupies bits 23:17 (= vdst << 17); the existing prologue
// pattern v_add_nc_u32 v1, s12, v0 = 0x4A02000C confirms byte 2 =
// (vdst<<1) (& 0xFF), so we shift the vdst number by 17 bits.
fn _emit_vpos_for_chunk(uint64 v_pos, uint64 chunk_off) {
    if chunk_off == 0 {
        // v_add_nc_u32 v_pos, 0, v0
        asm_u32(0x4A000080 | ((v_pos & 0xFF) << 17))
    } else {
        // v_add_nc_u32 v_pos, lit, v0
        asm_u32(0x4A0000FF | ((v_pos & 0xFF) << 17))
        asm_u32(chunk_off)
    }
}

// Causal mask injection (large-N variant): v10 = (v_pos > s15) ? -inf
// : v10.  Uses v15 as identity scratch and sX as predicate sgpr.
fn _emit_causal_mask_v10(uint64 mask_sgpr, uint64 v_pos) {
    // v_cmp_lt_u32_e64 mask_sgpr, s15, v_pos
    asm_u32(0xD4490000 | (mask_sgpr & 0x7F))
    asm_u32(((0x100 | (v_pos & 0xFF)) << 9) | 0x0F)   // src0 = s15 (0x0F)
    // v_mov_b32 v15, -inf
    asm_u32(0x7E1E02FF)
    asm_u32(0xFF800000)
    // v_cndmask_b32_e64 v10, v10, v15, mask_sgpr
    asm_u32(0xD501000A)
    asm_u32(0x00021F0A | ((mask_sgpr & 0xFF) << 18))
}

// Bump a 64-bit VGPR pair (vp_lo:vp_lo+1) by a 32-bit immediate.
// Used by thread-coarsened kernels to advance the in/out/gamma
// addresses by 4096 (= 1024 lanes × 4 bytes) between chunks.
//
//   s_mov_b32 s14, imm
//   v_add_co_u32   vp_lo,  vcc_lo, s14, vp_lo
//   v_add_co_ci_u32_e64 vp_lo+1, null, 0, vp_lo+1, vcc_lo
fn _emit_vpair_add_imm(uint64 vp_lo, uint64 imm) {
    // s_mov_b32 s14, imm  (literal-escape encoding)
    asm_u32(0xBE8E00FF)
    asm_u32(imm)
    // v_add_co_u32 vp_lo, vcc_lo, s14, vp_lo
    asm_u32(0xD7006A00 | (vp_lo & 0xFF))
    uint64 vp_lo_field = 0x100 | (vp_lo & 0xFF)        // VGPR src encoding
    asm_u32((vp_lo_field << 9) | 0x0E)                  // src0 = s14, src1 = vp_lo
    // v_add_co_ci_u32_e64 vp_lo+1, null, 0, vp_lo+1, vcc_lo
    uint64 vp_hi = vp_lo + 1
    asm_u32(0xD5207C00 | (vp_hi & 0xFF))
    uint64 vp_hi_field = 0x100 | (vp_hi & 0xFF)
    // src0 = 0 inline (0x80), src1 = vp_hi, src2 = vcc_lo (0x6A)
    asm_u32((0x6A << 18) | (vp_hi_field << 9) | 0x80)
}

// ── SOPP format (single 32-bit word) ────────────────────────────────
// [31:23] = 0x17F   (SOPP prefix on gfx11)
// [22:16] = 7-bit opcode
// [15:0]  = simm16
//
// SOPP opcodes we care about:
//   0x30  s_endpgm
//   0x09  s_waitcnt
static uint64 GFX11_SOPP_PREFIX = 0x17F

fn asm_sopp(uint64 op, uint64 simm16) {
    uint64 word = (GFX11_SOPP_PREFIX << 23)
                  | ((op & 0x7F) << 16)
                  | (simm16 & 0xFFFF)
    asm_u32(word)
}

fn asm_s_endpgm() { asm_sopp(0x30, 0) }

// s_clause <count> — scheduling hint that the next (count+1)
// instructions form a group with no intervening memory ops. Clang
// emits this ahead of back-to-back s_load_* pairs to let the
// hardware batch their SMEM accesses. op = 0x05 on gfx11.
fn asm_s_clause(uint64 count) { asm_sopp(0x05, count & 0xFFFF) }

// s_waitcnt lgkmcnt(0) — wait for scalar/LDS memory, ignore vmcnt.
// simm16 encoding for gfx11 combined waitcnt:
//   [3:0]    vmcnt[3:0]
//   [7]      expcnt
//   [11:8]   lgkmcnt
//   [14:12]  vmcnt[6:4]
//   [15]     reserved (set by clang)
// The composed "lgkmcnt=0, others max" value is 0xFC07; clang emits
// exactly this ahead of reads from SMEM-loaded SGPRs.
fn asm_s_waitcnt_lgkmcnt_zero() { asm_sopp(0x09, 0xFC07) }

// s_waitcnt vmcnt(0) — wait for VMEM ops to drain. simm16 0x03F7
// = lgkmcnt max (0xF) << 8 | expcnt max << 7 | vmcnt_lo 0x7 and
// vmcnt_hi=0 (vmcnt total bits scattered across [3:0] and [14:12]
// on gfx11). We care about "vmcnt=0, others ignored", clang emits
// exactly 0x03F7 for that.
fn asm_s_waitcnt_vmcnt_zero() { asm_sopp(0x09, 0x03F7) }

// s_waitcnt vmcnt(N) for N in {1, 2} — partial drain: wait until at
// most N outstanding VMEM ops remain. Lets the compiler interleave
// VALU/SALU computation with later VMEM loads in flight (mirrors
// hipcc's lif_step / delivery_step inner loops).
fn asm_s_waitcnt_vmcnt_1() { asm_sopp(0x09, 0x07F7) }
fn asm_s_waitcnt_vmcnt_2() { asm_sopp(0x09, 0x0BF7) }

// s_delay_alu <simm16> — SOPP op 0x07 (gfx11+). The simm16 encodes
// how far back the current instruction should wait for a VALU
// dependency. simm16 values this helper takes directly:
//   0x01 = instid0(VALU_DEP_1)
//   0x02 = instid0(VALU_DEP_2)
//   0x03 = instid0(VALU_DEP_3)
//   0x04 = instid0(VALU_DEP_4)
// Used to satisfy VGPR RAW hazards between a multi-cycle VALU (e.g.
// v_add_f64) and a consumer (e.g. an atomic that reads the result
// in its data quad). The CAS-loop in the M1p demo relies on this
// to guarantee v[6:7] is settled before the cmpswap reads the quad.
fn asm_s_delay_alu(uint64 simm16) {
    // gfx11-only instruction (SOPP op 0x07).  gfx10 has different
    // VALU→VMEM hazard handling and no s_delay_alu opcode; emit s_nop 0
    // (SOPP op 0x00 = 0xBF800000) on gfx10 as a no-op stand-in.
    if _is_gfx10() != 0 { asm_u32(0xBF800000); return }
    asm_sopp(0x07, simm16 & 0xFFFF)
}

// s_waitcnt_vscnt null, 0 — gfx10/11 split the VMEM counter into
// vmcnt (reads + atomics-with-return) and vscnt (pure stores and
// no-return atomics). This helper drains vscnt to 0. After any
// write-heavy kernel or atomic sequence that may produce stores,
// emit this in addition to vmcnt(0) before s_endpgm to ensure the
// memory system is quiesced before the dispatch completes.
// Verified against llvm-mc: encoding [0x00,0x00,0x7c,0xbc]
// → word 0xBC7C0000 (SOPK-family, op 0x3E, sdst=null=0x7D, simm=0).
fn asm_s_waitcnt_vscnt_zero() { asm_u32(0xBC7C0000) }

// s_cbranch_execz <simm16> — SOPP op 0x25. Branches forward by
// simm16 dwords if EXEC == 0 (no lanes active). Used right after
// s_and_saveexec to skip the guarded body when no lane passed the
// predicate. Caller passes the dword count directly.
fn asm_s_cbranch_execz(uint64 simm16_dwords) { asm_sopp(0x25, simm16_dwords & 0xFFFF) }

// ── Scalar control flow (M1m — building blocks for the CSR kernel
// while loops that M1n will actually wire up). All three are SOPP;
// simm16 is a SIGNED dword offset added to PC+4 — negative values
// encode as the two's-complement 16-bit pattern for backward
// branches.

// s_branch <simm16>          — unconditional scalar branch.
//   Clang reference: s_branch 0x8 → 0xBFA00008  (op 0x20)
fn asm_s_branch(uint64 simm16_dwords) { asm_sopp(0x20, simm16_dwords & 0xFFFF) }

// s_cbranch_scc0 <simm16>    — branch if SCC == 0 (last SALU
// compare was false).  Op 0x21 on gfx11 (clang: 0xBFA10008).
fn asm_s_cbranch_scc0(uint64 simm16_dwords) { asm_sopp(0x21, simm16_dwords & 0xFFFF) }

// s_cbranch_vccz <simm16> — SOPP op 0x23. Branches if VCC == 0
// (all lanes' vcmp was false / equal).
fn asm_s_cbranch_vccz(uint64 simm16_dwords) { asm_sopp(0x23, simm16_dwords & 0xFFFF) }

// s_cbranch_vccnz <simm16> — SOPP op 0x24. Branches if VCC != 0
// (some lane's vcmp was true / mismatch). Used by the CAS retry
// loop: when cmpswap's returned prev differs from the expected pair,
// vcc_lo becomes nonzero and we branch back to the loop head.
fn asm_s_cbranch_vccnz(uint64 simm16_dwords) { asm_sopp(0x24, simm16_dwords & 0xFFFF) }

// s_cbranch_scc1 <simm16>    — branch if SCC == 1 (compare true).
// Op 0x22 on gfx11 (clang: 0xBFA20008).
fn asm_s_cbranch_scc1(uint64 simm16_dwords) { asm_sopp(0x22, simm16_dwords & 0xFFFF) }

// ── Scalar arithmetic / compare (M1m).

// s_add_u32 sdst, ssrc0, imm8  (SOP2 op 0x00).
//   SOP2 word = [31:30]=10 | [29:23]=op | [22:16]=sdst | [15:8]=ssrc1 | [7:0]=ssrc0.
//   For a small literal imm (0..64), ssrc1 encodes as 0x80+imm.
//   Clang reference: s_add_u32 s2, s2, 1 → 0x80028102.
fn asm_s_add_u32_imm(uint64 sdst, uint64 ssrc0_sgpr, uint64 imm) {
    uint64 ssrc1_enc = 0x80 + (imm & 0x3F)               // inline const
    uint64 word = (0x2 << 30)                             // SOP2 prefix
                  | (0x00 << 23)                          // op
                  | ((sdst & 0x7F) << 16)
                  | ((ssrc1_enc & 0xFF) << 8)
                  | (ssrc0_sgpr & 0xFF)
    asm_u32(word)
}

// s_cmp_lt_u32 ssrc0, ssrc1  (SOPC op 0x0A).
//   Sets SCC = (ssrc0 < ssrc1). Format:
//   [31:24] = 0xBF prefix | [23:16] = op | [15:8] = ssrc1 | [7:0] = ssrc0
//   Clang reference: s_cmp_lt_u32 s2, s3 → 0xBF0A0302.
fn asm_s_cmp_lt_u32(uint64 ssrc0, uint64 ssrc1) {
    uint64 word = (0xBF << 24)
                  | (0x0A << 16)
                  | ((ssrc1 & 0xFF) << 8)
                  | (ssrc0 & 0xFF)
    asm_u32(word)
}

// s_cmp_eq_u32 ssrc0, ssrc1  (SOPC op 0x06).
//   Sets SCC = (ssrc0 == ssrc1). For "test register against small
//   constant" patterns (e.g. cell_type == 1), pass ssrc1 = 0x80 + K
//   for inline constant K. Verified: s_cmp_eq_u32 s14, 1 → 0xBF06810E.
fn asm_s_cmp_eq_u32(uint64 ssrc0, uint64 ssrc1) {
    uint64 word = (0xBF << 24)
                  | (0x06 << 16)
                  | ((ssrc1 & 0xFF) << 8)
                  | (ssrc0 & 0xFF)
    asm_u32(word)
}

// s_mov_b32 sdst, 0  (SOP1 op 0x00 with inline-0 src).
//   Format: [31:23]=0x17D | [22:16]=sdst | [15:8]=op | [7:0]=ssrc0
//   Clang reference: s_mov_b32 s2, 0 → 0xBE820080.
fn asm_s_mov_b32_imm0(uint64 sdst) {
    uint64 word = (0x17D << 23)
                  | ((sdst & 0x7F) << 16)
                  | (0x00 << 8)
                  | 0x80                                  // inline constant 0
    asm_u32(word)
}

// Generalised s_mov_b32 sdst, ssrc0 — any SGPR/exec_lo (0x7E)/
// vcc_lo (0x6A) encoded in either slot. Used to save/restore
// EXEC around per-lane divergent loops.
//   s_mov_b32 s4, exec_lo → 0xBE84007E
//   s_mov_b32 exec_lo, s4 → 0xBEFE0004
fn asm_s_mov_b32(uint64 sdst, uint64 ssrc0) {
    uint64 word = (0x17D << 23)
                  | ((sdst & 0x7F) << 16)
                  | (0x00 << 8)
                  | (ssrc0 & 0xFF)
    asm_u32(word)
}

// s_mov_b32 sdst, <inline imm 0..64>  — uses inline-constant src
// encoding (no literal-32 word).
//   Verified: s_mov_b32 s24, 63 → 0xBE9800BF (src = 0x80 + 63 = 0xBF).
//   Slice 5.9 fix: AMDGPU inline-constant range is 0..64 (encoded as
//   0x80..0xC0); the previous `imm & 0x3F` mask wrapped 64 to 0,
//   causing Llama mega-kernel's HIDDEN/32 = 64 loop counter to start
//   at 0 (effectively infinite via 0xFFFFFFFF underflow) and hang
//   the GPU.  Fall back to a 32-bit literal encoding when imm > 64
//   so the helper produces correct ISA across the full Qwen3+Llama
//   parametric range.
fn asm_s_mov_b32_inline_imm(uint64 sdst, uint64 imm) {
    if imm > 64 {
        asm_s_mov_b32_lit32(sdst, imm)
        return
    }
    uint64 ssrc0 = 0x80 + (imm & 0x7F)
    uint64 word = (0x17D << 23)
                  | ((sdst & 0x7F) << 16)
                  | (0x00 << 8)
                  | (ssrc0 & 0xFF)
    asm_u32(word)
}

// s_mov_b32 sdst, <32-bit literal>  — src = 0xFF, then 4-byte lit32.
//   Verified: s_mov_b32 s30, 0x7F4A7C15 → 0xBE9E00FF + lit 0x7F4A7C15.
fn asm_s_mov_b32_lit32(uint64 sdst, uint64 lit32) {
    uint64 word = (0x17D << 23)
                  | ((sdst & 0x7F) << 16)
                  | (0x00 << 8)
                  | 0xFF
    asm_u32(word)
    asm_u32(lit32 & 0xFFFFFFFF)
}

// s_sub_u32 sdst, ssrc0, <inline imm 0..64>   (SOP2 op 0x01)
//   Verified: s_sub_u32 s24, s24, 1 → 0x80988118.
fn asm_s_sub_u32_imm(uint64 sdst, uint64 ssrc0_sgpr, uint64 imm) {
    uint64 ssrc1_enc = 0x80 + (imm & 0x3F)
    uint64 word = (0x2 << 30)
                  | (0x01 << 23)
                  | ((sdst & 0x7F) << 16)
                  | ((ssrc1_enc & 0xFF) << 8)
                  | (ssrc0_sgpr & 0xFF)
    asm_u32(word)
}

// ── VALU divergent-loop primitives (M1n).
//
// v_cmp_lt_u32_e32 vcc_lo, v_src0, v_src1  — VOPC op 0x49.
//   Sets VCC[lane] = (src0 < src1) per active lane. Used to gate
//   each iteration of a while loop where the bound differs per
//   lane.
//   Clang reference: v_cmp_lt_u32_e32 vcc_lo, v0, v1 → 0x7C920300.
fn asm_v_cmp_lt_u32_vv(uint64 vsrc0, uint64 vsrc1) {
    uint64 src0_enc = 0x100 | (vsrc0 & 0xFF)
    uint64 word = (0x3E << 25)
                  | (0x49 << 17)
                  | ((vsrc1 & 0xFF) << 9)
                  | (src0_enc & 0x1FF)
    asm_u32(word)
}

// v_cmp_ne_u64_e32 vcc_lo, v[src0:+1], v[src1:+1]  — VOPC op 0x5D (64-bit).
//   Sets VCC[lane] = (u64(src0) != u64(src1)) per active lane. Both
//   operands are VGPR pairs. Used by the atomic-CAS retry loop: after
//   cmpswap, compare the returned "prev" against the "expected" pair;
//   if any lane saw a mismatch, vcc is nonzero and the loop retries.
//   Verified against llvm-mc: `v_cmp_ne_u64_e32 vcc_lo, v[0:1], v[4:5]`
//   → 0x7CBA0900.
fn asm_v_cmp_ne_u64_vv(uint64 vsrc0_pair, uint64 vsrc1_pair) {
    uint64 src0_enc = 0x100 | (vsrc0_pair & 0xFF)
    uint64 word = (0x3E << 25)
                  | (0x5D << 17)
                  | ((vsrc1_pair & 0xFF) << 9)
                  | (src0_enc & 0x1FF)
    asm_u32(word)
}

// v_cmp_lt_f64_e32 vcc_lo, 0, v[vsrc1_pair:+1]  — VOPC op 0x21.
//   Sets VCC[lane] = (0.0 < v[vsrc1:vsrc1+1]) per active lane. With
//   src0 pinned to inline-zero (0x80), this is the "rel > 0.0" guard
//   used by csr_i_deliver / csr_e_deliver. Verified against llvm-mc:
//   `v_cmp_lt_f64_e32 vcc_lo, 0, v[4:5]` → 0x7C420880.
fn asm_v_cmp_lt_f64_zero_v(uint64 vsrc1_pair) {
    uint64 word = (0x3E << 25)
                  | (0x21 << 17)
                  | ((vsrc1_pair & 0xFF) << 9)
                  | 0x80                       // src0 = inline 0.0
    asm_u32(word)
}

// v_cmp_ge_f64_e32 vcc_lo, v[src0:+1], v[src1:+1]  — VOPC op 0x26.
//   Sets VCC[lane] = (v[src0:+1] >= v[src1:+1]) per active lane. Used
//   by lif_spike to test v_new >= V_thresh for spike detection.
//   Verified: `v_cmp_ge_f64_e32 vcc_lo, v[0:1], v[22:23]` → 0x7C4C2D00.
fn asm_v_cmp_ge_f64_vv(uint64 vsrc0_pair, uint64 vsrc1_pair) {
    uint64 src0_enc = 0x100 | (vsrc0_pair & 0xFF)
    uint64 word = (0x3E << 25)
                  | (0x26 << 17)
                  | ((vsrc1_pair & 0xFF) << 9)
                  | (src0_enc & 0x1FF)
    asm_u32(word)
}

// s_and_b32 exec_lo, exec_lo, vcc_lo  — SOP2 op 0x0B.
//   Reduces EXEC to the intersection of current EXEC and VCC:
//   lanes where vcmp was false drop out of the active set.
//   Hard-wired to the exec_lo & vcc_lo operand shape since that's
//   the only one any of our loop patterns need.
//   Clang reference: → 0x8B7E6A7E.
fn asm_s_and_b32_exec_vcc_lo() {
    // (0x2<<30) SOP2 prefix | (0x16<<23) op (s_and_b32 on gfx11)
    // | (0x7E<<16) sdst=exec_lo | (0x6A<<8) ssrc1=vcc_lo
    // | 0x7E ssrc0=exec_lo
    uint64 word = (0x2 << 30)
                  | (0x16 << 23)
                  | (0x7E << 16)
                  | (0x6A << 8)
                  | 0x7E
    asm_u32(word)
}

// v_cmp_eq_u32_e32 vcc_lo, <inline imm>, v<vgpr>  — VOPC op 0x4A.
//   Sets VCC[lane] = (imm == u32(v[vgpr])) per active lane. src0 is
//   an inline literal (0..63 encoded as 0x80+K; mask is &0x3F). Used
//   for the ref == 0 guard in mt_lif_full.
//   Verified: `v_cmp_eq_u32_e32 vcc_lo, 0, v12` → 0x7C941880.
fn asm_v_cmp_eq_u32_imm_vgpr(uint64 imm, uint64 vgpr) {
    uint64 src0_enc = 0x80 + (imm & 0x3F)
    // VOPC op shift: gfx11 op 0x4A → gfx10 op 0xC2 (= 0x4A | 0x80 high
    // bit, plus VOPC prefix 0x7C → 0x7D in bit 24).
    uint64 op = 0x4A
    if _is_gfx10() != 0 { op = 0xC2 }
    uint64 word = (0x3E << 25)
                  | ((op & 0xFF) << 17)
                  | ((vgpr & 0xFF) << 9)
                  | (src0_enc & 0x1FF)
    asm_u32(word)
}

// s_xor_b32 exec_lo, exec_lo, s<ssrc1>  — SOP2 op s_xor_b32 (gfx11).
//   Flips EXEC by XORing with a saved SGPR. Used to transition from
//   the "then" EXEC mask to the "else" mask (complementary lanes)
//   inside an if/else guarded by s_and_saveexec_b32.
//   Verified via llvm-mc: `s_xor_b32 exec_lo, exec_lo, s46` encodes
//   as bytes [0x7e,0x2e,0x7e,0x8d] → word 0x8D7E2E7E. That puts the
//   gfx11 op field at 0x1A (not 0x18).
fn asm_s_xor_b32_exec_sgpr(uint64 ssrc1) {
    uint64 word = (0x2 << 30)
                  | (0x1A << 23)
                  | (0x7E << 16)
                  | ((ssrc1 & 0xFF) << 8)
                  | 0x7E
    asm_u32(word)
}

// v_add_nc_u32_e32 vdst, vsrc0, vsrc1  — VOP2 op 0x25, no-carry
// 32-bit vector integer add.
//   Clang reference: v_add_nc_u32_e32 v2, v0, v2 → 0x4A040500.
fn asm_v_add_nc_u32_vv(uint64 vdst, uint64 vsrc0, uint64 vsrc1) {
    uint64 src0_enc = 0x100 | (vsrc0 & 0xFF)
    uint64 word = (0x25 << 25)
                  | ((vdst & 0xFF) << 17)
                  | ((vsrc1 & 0xFF) << 9)
                  | (src0_enc & 0x1FF)
    asm_u32(word)
}

// v_add_nc_u32_e32 vdst, imm, vsrc1 — same op but with an inline
// constant (0..64 encode as 0x80+K) in the src0 slot.
//   Clang reference: v_add_nc_u32_e32 v0, 1, v0 → 0x4A000081.
fn asm_v_add_nc_u32_imm(uint64 vdst, uint64 imm, uint64 vsrc1) {
    uint64 src0_enc = 0x80 + (imm & 0x3F)
    uint64 word = (0x25 << 25)
                  | ((vdst & 0xFF) << 17)
                  | ((vsrc1 & 0xFF) << 9)
                  | (src0_enc & 0x1FF)
    asm_u32(word)
}

// s_cbranch_execnz <simm16>  — SOPP op 0x26. Branches if EXEC != 0
// (at least one lane still active). Used to loop back while any
// lane still has work.
fn asm_s_cbranch_execnz(uint64 simm16_dwords) { asm_sopp(0x26, simm16_dwords & 0xFFFF) }

// ── SMEM format (64-bit instruction) ───────────────────────────────
// Word 1 (gfx11):
//   [31:26] = 0x3D   (SMEM prefix)
//   [25:18] = 8-bit opcode
//   [17]     reserved
//   [14]     DLC
//   [13]     GLC
//   [12:7]   sdata_pair (6-bit) — SGPR-pair index (halved): to load
//             into s[2N:2N+1], pass N. asm_s_load_b64(0, 0) loads into
//             s[0:1]; asm_s_load_b64(1, 0) into s[2:3]; etc.
//   [6:0]    sbase_pair (7-bit) — SGPR-pair index, ALSO halved (NOT
//             a raw SGPR index). To read from s[2:3], pass sbase=1;
//             from s[4:5], pass sbase=2. This asymmetry with FLAT/
//             GLOBAL saddr (which is raw) was verified against
//             llvm-mc — an earlier comment here claimed the opposite
//             because the single caller only ever used sbase=0,
//             masking the issue.
// Word 2 (offset):
//   [31:25]  soffset (7-bit SGPR index; 0x7D = SGPR_NULL)
//   [24:0]   25-bit signed immediate offset
//
// For "s[sdata:sdata+1], s[sbase:sbase+1], null" with zero offset:
//   clang emits 0xF8000000 as the offset word. That's soffset bits
//   [31:25] = 0x7C — the gfx11 "no SGPR offset" sentinel, not the
//   SGPR_NULL (0x7D) reg index. Leave as opaque for now; exposing
//   it properly comes when we grow the encoder.
static uint64 GFX11_SMEM_PREFIX = 0x3D

// s_load_b64 s[sdata:sdata+1], s[sbase:sbase+1], null  (op 0x01)
fn asm_s_load_b64(uint64 sdata, uint64 sbase_pair) {
    uint64 word1 = (GFX11_SMEM_PREFIX << 26)
                   | (0x01 << 18)
                   | ((sdata & 0x3F) << 7)
                   | (sbase_pair & 0x7F)
    asm_u32(word1)
    asm_u32(0xF8000000)
}

// s_load_b64 pair s[sdata_pair:+1], s[sbase_pair:+1], <imm_offset>
// (SMEM op 0x01 with a non-zero imm offset). Lets us pull a second
// 8-byte kernarg past the base pointer — e.g. kernarg[16..23].
fn asm_s_load_b64_off(uint64 sdata_pair, uint64 sbase_pair, uint64 imm_offset) {
    uint64 word1 = (GFX11_SMEM_PREFIX << 26)
                   | (0x01 << 18)
                   | ((sdata_pair & 0x3F) << 7)
                   | (sbase_pair & 0x7F)
    asm_u32(word1)
    uint64 word2 = (0x7C << 25) | (imm_offset & 0x1FFFFFF)
    asm_u32(word2)
}

// s_load_b32 s<SGPR>, s[sbase_pair:+1], <imm_offset>  (SMEM op 0x00)
//
// Gotcha: the SMEM sdata field is pair-index-encoded even for b32
// loads (the destination must be an even SGPR for hardware
// alignment reasons), so a load into s2 needs sdata_pair=1 — not 2.
// The 6-bit field lives at [12:7] of word 1. This mirrors how the
// b64 loader already takes "pair index"; asm_s_load_b64(0,0)
// coincidentally works because 0/2==0, but sdata_pair=N here means
// the destination SGPR is 2N.
fn asm_s_load_b32(uint64 sdata_pair, uint64 sbase_pair, uint64 imm_offset) {
    uint64 word1 = (GFX11_SMEM_PREFIX << 26)
                   | (0x00 << 18)
                   | ((sdata_pair & 0x3F) << 7)
                   | (sbase_pair & 0x7F)
    asm_u32(word1)
    uint64 word2 = (0x7C << 25) | (imm_offset & 0x1FFFFFF)
    asm_u32(word2)
}

// ── VOP1: single-source vector op in 32 bits. Layout (gfx11):
//   [31:25] = 0x3F  (VOP1 prefix)
//   [24:17] = vdst  (8-bit VGPR destination)
//   [16:9]  = op    (8-bit opcode)
//   [8:0]   = src0  (9-bit: SGPR=raw, VGPR=0x100|N, inline=0x80..0xC0 for 0..64)
// Verified against llvm-mc: `v_mov_b32 v6, 7` → 0x7E0C0287.
fn asm_v_mov_b32(uint64 vdst_vgpr, uint64 src0) {
    uint64 word = (0x3F << 25)
                  | ((vdst_vgpr & 0xFF) << 17)
                  | (0x01 << 9)
                  | (src0 & 0x1FF)
    asm_u32(word)
}

// v_mov_b32 vdst, <inline imm 0..64>  — the common case.
// inline_u 0→0x80, 1→0x81, …, 64→0xC0. For negatives use 0xC1..0xD0 directly
// via asm_v_mov_b32.
fn asm_v_mov_b32_inline_u(uint64 vdst_vgpr, uint64 inline_u) {
    asm_v_mov_b32(vdst_vgpr, 0x80 + inline_u)
}

// ── VOPD: dual-issue VOP1/VOP2 pair in one 64-bit instruction (gfx11+).
// Full encoding is intricate; we only need the specific form
//   v_dual_mov_b32 v0, 0 :: v_dual_mov_b32 v1, <literal32>
// which clang emits for the sentinel kernel. Words are:
//   0xCA100080   — VOPD + op pair (mov, mov), v_dst_x=v0, v_dst_y=v1,
//                  src_x=inline-zero, src_y=VGPR encoding 0xFF (literal)
//   0x000000FF   — per-slot operand word; 0xFF in the slot-y source
//                  means "literal follows"
//   <literal32>  — the 32-bit immediate for dst_y
fn asm_v_dual_mov_b32_mov_b32_lit(uint64 vdst_x, uint64 vdst_y, uint64 lit32) {
    // Reference encoding depends on vdst_x=0, vdst_y=1; if the
    // caller uses other dsts we'd need to splice them into word 1's
    // [14:9] / [23:17] fields. Today the one caller passes (0,1).
    if vdst_x != 0 {
        write(2, "format_amdgpu: asm_v_dual_mov_b32 only supports vdst_x=0\n", 57)
        exit(1)
    }
    if vdst_y != 1 {
        write(2, "format_amdgpu: asm_v_dual_mov_b32 only supports vdst_y=1\n", 57)
        exit(1)
    }
    asm_u32(0xCA100080)
    asm_u32(0x000000FF)
    asm_u32(lit32)
}

// VOPD sibling of the _lit variant above: src_y comes from an
// already-populated SGPR instead of a 32-bit literal word. Word-1
// is unchanged (same opcode pair + vdst encoding); word-2 holds
// the slot-Y src0 directly — SGPR indices encode in the low 9
// bits. Save 4 bytes and one instruction-cache cycle relative to
// the literal form.
fn asm_v_dual_mov_b32_mov_b32_sgpr(uint64 vdst_x, uint64 vdst_y, uint64 src_y_sgpr) {
    if vdst_x != 0 {
        write(2, "format_amdgpu: asm_v_dual_mov_b32 only supports vdst_x=0\n", 57)
        exit(1)
    }
    if vdst_y != 1 {
        write(2, "format_amdgpu: asm_v_dual_mov_b32 only supports vdst_y=1\n", 57)
        exit(1)
    }
    asm_u32(0xCA100080)
    asm_u32(src_y_sgpr & 0x1FF)
}

// VOPD v_dual_mov with BOTH slots sourced from SGPRs. For splat-f64:
//   v_dual_mov_b32 v0, s_lo :: v_dual_mov_b32 v1, s_hi
// moves an SGPR pair into a VGPR pair in one issue. Still hard-wired
// to the canonical (vdst_x=0, vdst_y=1) layout — VOPD's implicit
// "vdst_y = vdst_x XOR 1" pairing means (0,1) is the natural slot
// for data placed in v[0:1].
// Verified against llvm-mc: `v_dual_mov_b32 v0, s4 :: v_dual_mov_b32 v1, s5`
//   → 0xCA100004 0x00000005.
fn asm_v_dual_mov_b32_sx_sy(uint64 vdst_x, uint64 vdst_y,
                            uint64 src_x_sgpr, uint64 src_y_sgpr) {
    if vdst_x != 0 {
        write(2, "format_amdgpu: asm_v_dual_mov_b32_sx_sy only supports vdst_x=0\n", 63)
        exit(1)
    }
    if vdst_y != 1 {
        write(2, "format_amdgpu: asm_v_dual_mov_b32_sx_sy only supports vdst_y=1\n", 63)
        exit(1)
    }
    // Same word-1 constant skeleton as the lit/sgpr variants, with
    // the slot-x src occupying the low 9 bits.
    uint64 word1 = 0xCA100000 | (src_x_sgpr & 0x1FF)
    asm_u32(word1)
    asm_u32(src_y_sgpr & 0x1FF)
}

// Generalised v_dual_mov_b32 + v_dual_mov_b32 for arbitrary even/odd
// VGPR pairs. Used for f64 splat: v[vd:vd+1] = s[ss:ss+1].
//
// Encoding (verified against llvm-mc on gfx1100):
//   word1 = 0xCA100000 | src_x_sgpr_9bit
//   word2 = (vdst_x_8bit << 24) | ((vdst_y - 1)_8bit << 16) | src_y_8bit
//
// Examples (dword2 layout: [vdst_x][vdst_y-1][reserved=0][src_y_lo8]):
//   v4,s40 :: v5,s41 → 0xCA100028 0x04040029
//   v10,s10 :: v11,s11 → 0xCA10000A 0x0A0A000B
//   v22,s24 :: v23,s25 → 0xCA100018 0x16160019
//
// Constraint: vdst_pair_even must be EVEN (so vdst_y = vdst_pair_even+1
// is odd — VOPD's slot-Y output bank requires odd VGPRs).
fn asm_v_dual_mov_b32_pair_sxsy(uint64 vdst_pair_even,
                                uint64 src_x_sgpr,
                                uint64 src_y_sgpr) {
    uint64 word1 = 0xCA100000 | (src_x_sgpr & 0x1FF)
    asm_u32(word1)
    uint64 word2 = ((vdst_pair_even & 0xFF) << 24)
                   | ((vdst_pair_even & 0xFF) << 16)    // vdst_y - 1 = vdst_x
                   | (src_y_sgpr & 0xFF)
    asm_u32(word2)
}

// VOPD: v_dual_fmac_f32 (X-slot) :: v_dual_fmac_f32 (Y-slot)  [gfx11+].
//
// Encoding (verified against llvm-mc on gfx1100 — see slice 7.6b probes
// in commit history):
//   word1 = 0xC8000000 | (vsrc1_X << 9) | (0x100 | (vsrc0_X & 0xFF))
//   word2 = (vdst_X << 24) | ((vdst_Y - 1) << 16) | (vsrc1_Y << 9)
//         | (0x100 | (vsrc0_Y & 0xFF))
//
// Semantics: dst_X += src0_X * src1_X  AND  dst_Y += src0_Y * src1_Y, in
// the same cycle on the SIMD32 pair (one X-slot lane + one Y-slot lane).
//
// gfx11 VOPD constraints (all asserted at call sites, NOT enforced here):
//   1. vdst_X and vdst_Y MUST have opposite parity (one even, one odd)
//      — assembler error "one dst register must be even and the other odd".
//   2. src0_X bank != src0_Y bank, where bank = vgpr & 0x3 (mod 4).
//   3. src1_X bank != src1_Y bank (same rule).
//   4. All srcs must be VGPRs (no SGPR / literal / inline-const in VOPD).
//   5. Both src0_X and src0_Y are 9-bit fields with the 0x100 marker
//      indicating "VGPR" (same encoding family as VOP2).  Omitting the
//      marker makes the disassembler decode them as SGPRs.
//
// Probed encodings (round-trip):
//   v2,v10,v11 :: v41,v9,v12  → C800170A 02281909
//     word2 = (2<<24) | (40<<16) | (12<<9) | (0x100 | 9)
//           = 0x02000000 | 0x00280000 | 0x00001800 | 0x00000109 = 0x02281909
//   v42,v14,v15 :: v43,v13,v16 → C8001F0E 2A2A210D
//     word2 = (42<<24) | (42<<16) | (16<<9) | (0x100 | 13)
//           = 0x2A000000 | 0x002A0000 | 0x00002000 | 0x0000010D = 0x2A2A210D
//   v2,v10,v11 :: v3,v12,v13  → C800170A 02021B0C
//     word2 = (2<<24) | (2<<16) | (13<<9) | (0x100 | 12)
//           = 0x02000000 | 0x00020000 | 0x00001A00 | 0x0000010C = 0x02021B0C
fn asm_v_dual_fmac_f32(uint64 vdst_x, uint64 vsrc0_x, uint64 vsrc1_x,
                       uint64 vdst_y, uint64 vsrc0_y, uint64 vsrc1_y) {
    uint64 word1 = 0xC8000000
                   | ((vsrc1_x & 0xFF) << 9)
                   | (0x100 | (vsrc0_x & 0xFF))
    uint64 word2 = ((vdst_x & 0xFF) << 24)
                   | (((vdst_y - 1) & 0xFF) << 16)
                   | ((vsrc1_y & 0xFF) << 9)
                   | (0x100 | (vsrc0_y & 0xFF))
    asm_u32(word1)
    asm_u32(word2)
}

// ── VOP2 — two-operand VGPR math in 32 bits. Layout (gfx11):
//   [31]     = 0   (VOP2 marker — zero bit distinguishes from VOP3/VOPC)
//   [30:25]  = op (6 bits)
//   [24:17]  = vdst (8 bits, VGPR)
//   [16:9]   = vsrc1 (8 bits, VGPR)
//   [8:0]    = src0 (9 bits, general — SGPR / VGPR / inline / literal)
//
// Inline-constant src0 encodings used here:
//   128..192  = 0..64  (for 0 <= K <= 64, encoding is 128 + K)
//
// For `v_lshlrev_b32 vdst, K, vsrc`, semantics = vdst = vsrc << K.
// src0 holds the shift amount (inline const), vsrc1 the value.
fn asm_v_lshlrev_b32_imm(uint64 vdst_vgpr, uint64 shift_amount, uint64 src_vgpr) {
    // VOP2 op 0x18 = v_lshlrev_b32 on gfx11. (First draft used 0x30,
    // which would set bit 30 of the word and break the VOP2-family
    // marker convention; confirmed against clang's v_lshlrev_b32
    // output.)
    uint64 src0_enc = 128 + (shift_amount & 0x3F)
    uint64 word = (0x18 << 25)
                  | ((vdst_vgpr & 0xFF) << 17)
                  | ((src_vgpr  & 0xFF) << 9)
                  | (src0_enc & 0x1FF)
    asm_u32(word)
}

// ── VOPC — vector compare producing a lane mask into VCC. Layout
// (gfx11):
//   [31:25] = 0b0111110   (VOPC prefix, 0x3E)
//   [24:17] = 8-bit op
//   [16:9]  = vsrc1 (8 bits, VGPR)
//   [8:0]   = src0 (9 bits)
//
// v_cmp_gt_u32_e32 vcc_lo, src0, vsrc1  ≡  VCC = (src0 > vsrc1).
// Op 0x4C on gfx11. With src0 = SGPR, vsrc1 = VGPR, this gives the
// "sgpr > vgpr" lane mask we need for `if v0 < n` bounds checks —
// clang emits "gt" (not "lt") to put the SGPR on the left.
fn asm_v_cmp_gt_u32_sgpr_vgpr(uint64 sgpr_src0, uint64 vgpr_src1) {
    uint64 word = (0x3E << 25)
                  | (0x4C << 17)
                  | ((vgpr_src1 & 0xFF) << 9)
                  | (sgpr_src0 & 0x1FF)      // SGPRs encode directly as src0
    asm_u32(word)
}

// ── SOP1 — single-source scalar op. Layout (gfx11):
//   [31:23] = 0b101111101 (0x17D prefix — one bit higher than SOPP)
//   [22:16] = 7-bit ssrc0   (here we use 0x6A = VCC_LO)
//   [15:8]  = 8-bit op
//   [7:0]   = sdst (7 bits) + 1 bit reserved
//
// s_and_saveexec_b32 sdst, ssrc0 — op 0x20 on gfx11. Saves current
// EXEC into sdst, sets EXEC = EXEC & ssrc0 (the vcc_lo mask from
// the preceding vcmp), returning original EXEC in sdst for the
// `end-if` restore point.
fn asm_s_and_saveexec_b32_vcc_lo(uint64 sdst_sgpr) {
    // Reference: s_and_saveexec_b32 s2, vcc_lo = 0xBE82206A
    //   [31:23] = 101111101 = 0x17D
    //   [22:16] = 0000010   = s2 (sdst, low 7 bits)
    //   [15:8]  = 00100000  = 0x20 (op = s_and_saveexec_b32)
    //   [7:0]   = 01101010  = 0x6A (ssrc0 = VCC_LO)
    uint64 word = (0x17D << 23)
                  | ((sdst_sgpr & 0x7F) << 16)
                  | (0x20 << 8)
                  | 0x6A                          // VCC_LO
    asm_u32(word)
}

// ── FLAT/GLOBAL (gfx11) — 64-bit instruction.
// Word 1: opcode + flags. For global_store_b32 with SADDR variant
// clang emits 0xDC6A0000 (opcode field encodes the SEG=global + the
// specific b32-store op).
// Word 2 fields:
//   [31:24] = reserved / scratch_offset (we hold at 0)
//   [23:16] = saddr (SGPR pair index for the base pointer)
//   [15:8]  = vdata (VGPR holding the value to store)
//   [7:0]   = vaddr (VGPR holding byte offset from saddr)
//
// For v0/v1/s[0:1] the reference is 0x00000100 — saddr=0, vdata=1,
// vaddr=0.
fn asm_global_store_b32(uint64 v_addr, uint64 v_data, uint64 saddr_pair) {
    asm_u32(0xDC6A0000)
    uint64 word2 = ((saddr_pair & 0x7F) << 16)
                   | ((v_data     & 0xFF) << 8)
                   | (v_addr      & 0xFF)
    asm_u32(word2)
}

// global_load_b64 v[vdst_pair:+1], v_addr, s[saddr_pair:+1]   (op 0x15)
// Loads 8 bytes from (s[saddr]+v_addr) into the VGPR pair
// starting at vdst_pair.
fn asm_global_load_b64(uint64 vdst_pair, uint64 v_addr, uint64 saddr_pair) {
    asm_u32(0xDC560000)
    uint64 word2 = ((saddr_pair & 0x7F) << 16)
                   | ((vdst_pair & 0xFF) << 24)
                   | ((v_addr    & 0xFF) << 0)
    // Reference for v[0:1]/v2/s[2:3]: 0x00020002
    //   [31:24]=vdst=0x00, [23:16]=saddr=0x02, [15:8]=vdata=0x00,
    //   [7:0]=vaddr=0x02. So vdst encoded at [31:24].
    asm_u32(word2)
}

// global_load_b64 ... glc  — bit 14 of word1 forces a bypass of L0
// so the load reads through L2. Needed when reading a location that
// an atomic just wrote on this same wave: a plain load would hit
// stale L0 and the CAS-loop's "assumed" would not match the actual
// post-atomic memory value. Verified via llvm-mc: word1 = 0xDC564000.
fn asm_global_load_b64_glc(uint64 vdst_pair, uint64 v_addr, uint64 saddr_pair) {
    asm_u32(0xDC564000)
    uint64 word2 = ((saddr_pair & 0x7F) << 16)
                   | ((vdst_pair & 0xFF) << 24)
                   | ((v_addr    & 0xFF) << 0)
    asm_u32(word2)
}

// buffer_gl0_inv — invalidate the L0 cache. No operands; emits
// a 64-bit instruction (word1=0xE0AC0000, word2=0). Used after
// an atomic-with-return so that subsequent plain global_loads
// from the same address do not return the pre-atomic value from
// a stale L0 cache line.
fn asm_buffer_gl0_inv() {
    asm_u32(0xE0AC0000)
    asm_u32(0x00000000)
}

// buffer_gl1_inv — invalidate the L1 cache.  Used in cross-WG
// signal-poll barriers (slice 4 mega-kernel) so that a post-atomic
// spin-load on the counter sees the value committed by other WGs'
// atomic_adds rather than a stale L1 line.
fn asm_buffer_gl1_inv() {
    asm_u32(0xE0B00000)
    asm_u32(0x00000000)
}

// global_store_b64 v_addr, v[vdata_pair:+1], s[saddr_pair:+1]  (op 0x1B)
// Stores the VGPR pair starting at vdata_pair to (s[saddr]+v_addr).
// Verified against llvm-mc:
//   v0, v[6:7], s[0:1] → word2 0x00000600   (vdata at [15:8])
//   v0, v[0:1], s[0:1] → word2 0x00000000
//   v2, v[0:1], s[2:3] → word2 0x00020002
// NOTE: the store layout is asymmetric with loads. For loads, vdst
// is at [31:24]; for stores, vdata is at [15:8]. Older callers all
// happened to store v[0:1] (vdata=0), which masked this asymmetry.
fn asm_global_store_b64(uint64 v_addr, uint64 vdata_pair, uint64 saddr_pair) {
    asm_u32(0xDC6E0000)
    uint64 word2 = ((saddr_pair & 0x7F) << 16)
                   | ((vdata_pair & 0xFF) << 8)
                   | (v_addr & 0xFF)
    asm_u32(word2)
}

// global_atomic_cmpswap_b64 v[vdst_pair:+1], v_addr, v[vdata_quad:+3], s[saddr_pair:+1] glc
// 8-byte atomic compare-and-swap on (s[saddr_pair]+v_addr).
// VGPR quad layout per AMD ISA (cross-checked against clang's HIP lowering
// of atomicCAS(addr, cmp, val)):
//   v[vdata_quad:+1]   = NEW value  (what to write if cmp matches)
//   v[vdata_quad+2:+3] = COMPARE value (what memory must currently hold)
// With GLC=1, v[vdst_pair:+1] receives the old memory value.
//
// IMPORTANT (gfx11): when operands for cmp/new are produced by VALU
// instructions (e.g. v_add_f64 to compute new = current + delta), the
// atomic is only reliable when vdst_pair overlaps vdata_quad's low half
// (i.e. vdst_pair == vdata_quad). Non-overlapping layouts seem to work
// for simple hand-written tests where the data_quad is set via inline
// constants (M1o) but silently fail to swap when the data_quad VGPRs
// were written by multi-cycle VALU ops just before the atomic (M1p).
// hipcc always emits the overlapping form.
//
// Verified against llvm-mc:
//   v[0:1], v2, v[4:7], s[0:1] glc → 0xDD0A4000 0x00000402
//   v[8:9], v2, v[4:7], s[2:3] glc → 0xDD0A4000 0x08000402
//   v[0:1], v10,v[4:7], s[0:1] glc → 0xDD0A4000 0x0000040A
fn asm_global_atomic_cmpswap_b64_glc(uint64 vdst_pair, uint64 v_addr,
                                      uint64 vdata_quad, uint64 saddr_pair) {
    asm_u32(0xDD0A4000)
    uint64 word2 = ((vdst_pair  & 0xFF) << 24)
                   | ((saddr_pair & 0x7F) << 16)
                   | ((vdata_quad & 0xFF) << 8)
                   | (v_addr      & 0xFF)
    asm_u32(word2)
}

// global_atomic_add_u64 v[vaddr:+1], v[vdata:+1], off  — GLOBAL op 0x0E,
//   no-return form. Adds u64(vdata_pair) to *((uint64*)&mem[vaddr_pair])
//   atomically. Used for bumping the LTD event counter in mt_csr_e_delayed.
//   Verified: `global_atomic_add_u64 v[0:1], v[2:3], off` → 0xDD0E0000, 0x007C0200.
fn asm_global_atomic_add_u64_offvaddr(uint64 vaddr_pair, uint64 vdata_pair) {
    // word1 fixed: GLOBAL prefix + op 0x0E + vdst=0 (no return).
    asm_u32(0xDD0E0000)
    uint64 word2 = ((vaddr_pair & 0xFF) << 0)
                   | ((vdata_pair & 0xFF) << 8)
                   | (0x7C << 16)                       // saddr = OFF/NULL
    asm_u32(word2 & 0xFFFFFFFF)
}

// ── VOP3 — 64-bit three-source vector op. Layout (gfx11, non-VOP3P):
//   Word 1:
//     [31:26] = 0x35  (VOP3 prefix)
//     [25:16] = 10-bit op
//     [15]    = clamp
//     [14:11] = opsel (or similar)
//     [7:0]   = vdst (8 bits)
//   Word 2:
//     [31:29] = neg[2,1,0]  (source-negation flags, lane-high)
//     [28:21] doesn't matter here
//     (This is a narrow helper, not a general VOP3 encoder.)
//
// v_fma_f64 vdst_pair, -s[0:1], v[0:1], v[0:1]  — op 0x014 on gfx11.
// Used for the decay idiom  v - v * factor  == fma(-factor, v, v).
// Reference bytes: 0xD6140000 0x24020000.
// v_mad_u32_u24 vdst, s_src0, s_src1, v_src2   (VOP3 op 0x0B)
// vdst = src0 * src1 + src2, interpreting src0/src1 as u24. On
// gfx1100 this is the compact way to compute a 32-bit fused
// multiply-add across an SGPR pair and a VGPR — which is exactly
// what the grid-tid formula needs (gid = wg_id_x * bdim + tid).
// Verified against llvm-mc: op=0x0B, word1=0xD60B0001 for
// `v_mad_u32_u24 v1, s3, s2, v0`.
fn asm_v_mad_u32_u24(uint64 vdst_vgpr,
                     uint64 src0_sgpr, uint64 src1_sgpr,
                     uint64 src2_vgpr) {
    uint64 word1 = (0x6B << 25) | (0x00B << 16) | (vdst_vgpr & 0xFF)
    asm_u32(word1)
    uint64 src0_enc = src0_sgpr & 0x1FF                // SGPR raw
    uint64 src1_enc = src1_sgpr & 0x1FF                // SGPR raw
    uint64 src2_enc = 0x100 | (src2_vgpr & 0xFF)       // VGPR 0x100+N
    uint64 word2 = ((src2_enc & 0x1FF) << 18)
                   | ((src1_enc & 0x1FF) << 9)
                   | (src0_enc & 0x1FF)
    asm_u32(word2)
}

// v_add_f64 vdst_pair, s_pair, -v_pair  (VOP3 op 0x127, neg[1]=1)
//
// Used by the relax idiom: `diff = target - v` is lowered as
// `add_f64(target_sgpr_pair, -v_src_pair)`. Encoding verified
// against clang for `v_add_f64 v[4:5], s[0:1], -v[2:3]`
// = 0xD7270004 0x40020400.
fn asm_v_add_f64_s_negv(uint64 vdst_pair, uint64 s_src_pair,
                         uint64 v_src_pair) {
    uint64 word1 = (0x6B << 25) | (0x127 << 16) | (vdst_pair & 0xFF)
    asm_u32(word1)
    uint64 src0_enc = s_src_pair & 0x1FF                // SGPR raw
    uint64 src1_enc = 0x100 | (v_src_pair & 0xFF)       // VGPR 0x100+N
    uint64 neg = 0x2                                     // neg[1] = 1 → -src1
    uint64 word2 = (neg << 29)
                   | ((src1_enc & 0x1FF) << 9)
                   | (src0_enc & 0x1FF)
    asm_u32(word2)
}

// v_add_f64 vdst_pair, v_src0_pair, v_src1_pair  (VOP3 op 0x127, no neg)
//
// The pure VGPR+VGPR form. Used by the f64-atomic-add CAS loop body
// to compute new = current + delta, where both operands are already
// sitting in VGPR pairs (current from a global_load, delta from a
// pair of SGPR-sourced v_mov_b32s).
// Verified against llvm-mc: `v_add_f64 v[4:5], v[0:1], v[2:3]`
// → 0xD7270004 0x00020500.
fn asm_v_add_f64_vv(uint64 vdst_pair, uint64 v_src0_pair, uint64 v_src1_pair) {
    uint64 word1 = (0x6B << 25) | (0x127 << 16) | (vdst_pair & 0xFF)
    asm_u32(word1)
    uint64 src0_enc = 0x100 | (v_src0_pair & 0xFF)
    uint64 src1_enc = 0x100 | (v_src1_pair & 0xFF)
    uint64 word2 = ((src1_enc & 0x1FF) << 9)
                   | (src0_enc & 0x1FF)
    asm_u32(word2)
}

// v_mul_f64 vdst_pair, v_src0_pair, v_src1_pair  (VOP3 op 0x128).
//   Companion to v_add_f64_vv. csr_i_deliver computes effective =
//   w * release, both VGPR pairs, storing into another pair.
//   Verified: v_mul_f64 v[0:1], v[2:3], v[4:5] → 0xD7280000 0x00020902.
fn asm_v_mul_f64_vv(uint64 vdst_pair, uint64 v_src0_pair, uint64 v_src1_pair) {
    uint64 word1 = (0x6B << 25) | (0x128 << 16) | (vdst_pair & 0xFF)
    asm_u32(word1)
    uint64 src0_enc = 0x100 | (v_src0_pair & 0xFF)
    uint64 src1_enc = 0x100 | (v_src1_pair & 0xFF)
    uint64 word2 = ((src1_enc & 0x1FF) << 9)
                   | (src0_enc & 0x1FF)
    asm_u32(word2)
}

// v_sub_f64 vdst_pair, v_src0_pair, v_src1_pair  (= v_add_f64 with neg[1]=1).
//   Implemented as `v_add_f64 vdst, src0, -src1` on gfx11 (no dedicated
//   subtract op). Used by the LIF integrate body for V_rest - V and
//   drive - s_inh * J_I. Verified: v_add_f64 v[2:3], v[2:3], -v[6:7]
//   → 0xD7270002 0x40020D02 (neg bit at word2[30]).
fn asm_v_sub_f64_vv(uint64 vdst_pair, uint64 v_src0_pair, uint64 v_src1_pair) {
    uint64 word1 = (0x6B << 25) | (0x127 << 16) | (vdst_pair & 0xFF)
    asm_u32(word1)
    uint64 src0_enc = 0x100 | (v_src0_pair & 0xFF)
    uint64 src1_enc = 0x100 | (v_src1_pair & 0xFF)
    uint64 neg = 0x2                                // neg[1] = 1 → src1 negated
    uint64 word2 = (neg << 29)
                   | ((src1_enc & 0x1FF) << 9)
                   | (src0_enc & 0x1FF)
    asm_u32(word2)
}

// v_max_f64 vdst, v[src0:+1], v[src1:+1]  — VOP3A op 0x2A.
//   Sets v[vdst:vdst+1] = max(v[src0:src0+1], v[src1:src1+1]) as f64.
//   Same shape as asm_v_mul_f64_vv, different op. Used by the STDP
//   LTD weight clamp in mt_csr_e_delayed.
//   Verified: `v_max_f64 v[0:1], v[2:3], v[4:5]` → 0xD72A0000, 0x00020902.
fn asm_v_max_f64_vv(uint64 vdst_pair, uint64 vsrc0_pair, uint64 vsrc1_pair) {
    uint64 word1 = (0xD7 << 24) | (0x2A << 16) | (vdst_pair & 0xFF)
    uint64 src0_enc = 0x100 | (vsrc0_pair & 0xFF)
    uint64 src1_enc = 0x100 | (vsrc1_pair & 0xFF)
    uint64 word2 = (src1_enc << 9) | (src0_enc & 0x1FF)
    asm_u32(word1)
    asm_u32(word2 & 0xFFFFFFFF)
}

// v_min_f64 vdst, v[src0:+1], v[src1:+1]  — VOP3A op 0x29.
//   Sets v[vdst:vdst+1] = min(v[src0:src0+1], v[src1:src1+1]) as f64.
//   Verified: `v_min_f64 v[0:1], v[2:3], v[4:5]` → 0xD7290000, 0x00020902.
fn asm_v_min_f64_vv(uint64 vdst_pair, uint64 vsrc0_pair, uint64 vsrc1_pair) {
    uint64 word1 = (0xD7 << 24) | (0x29 << 16) | (vdst_pair & 0xFF)
    uint64 src0_enc = 0x100 | (vsrc0_pair & 0xFF)
    uint64 src1_enc = 0x100 | (vsrc1_pair & 0xFF)
    uint64 word2 = (src1_enc << 9) | (src0_enc & 0x1FF)
    asm_u32(word1)
    asm_u32(word2 & 0xFFFFFFFF)
}

// v_fma_f64 vdst_pair, s_pair, v_src1_pair, v_src2_pair  (no neg)
//
// Companion to asm_v_fma_f64_neg_s_v_v — same op (0x014) but with
// neg=0 and src0 from an SGPR pair rather than a negated one.
// Used by relax: `nv = factor * diff + v` lowers as fma(factor_s,
// diff_v, v_v). Verified against clang for
// `v_fma_f64 v[2:3], s[2:3], v[4:5], v[2:3]` = 0xD6140002 0x040A0802.
fn asm_v_fma_f64_s_v_v(uint64 vdst_pair, uint64 s_src0_pair,
                        uint64 v_src1_pair, uint64 v_src2_pair) {
    uint64 word1 = (0x6B << 25) | (0x014 << 16) | (vdst_pair & 0xFF)
    asm_u32(word1)
    uint64 src0_enc = s_src0_pair & 0x1FF               // SGPR raw
    uint64 src1_enc = 0x100 | (v_src1_pair & 0xFF)
    uint64 src2_enc = 0x100 | (v_src2_pair & 0xFF)
    uint64 word2 = ((src2_enc & 0x1FF) << 18)
                   | ((src1_enc & 0x1FF) << 9)
                   | (src0_enc & 0x1FF)
    asm_u32(word2)
}

fn asm_v_fma_f64_neg_s_v_v(uint64 vdst_pair, uint64 neg_sgpr_pair,
                           uint64 v_src1_pair, uint64 v_src2_pair) {
    // Word 1: prefix + op + vdst.  gfx11 VOP3 prefix is 7 bits at
    // [31:25] = 0x6B (= bit 25 set in the 0x35-at-[31:26] framing);
    // op occupies [24:16] (9 bits).
    uint64 word1 = (0x6B << 25)
                   | (0x014 << 16)
                   | (vdst_pair & 0xFF)
    asm_u32(word1)
    // Word 2 layout reverse-engineered from ref 0x24020000:
    //   [31:29] = neg (3 bits) = 001  ->  negate src0 only
    //   [28:24] = reserved / 0
    //   [22:18] = src2[9:0] low / vgpr pair: reference has 0x02 here
    //              → src2 = v[0:1] pair, but encoding uses the low 9
    //              bits packed. The reference src2 VGPR pair starts at
    //              v0 (encoding 0x100), and clang compresses it into
    //              the word as 0x02 at [22:18]? Actually bits [28:18]
    //              = 11 bits = src2 = 0x...
    //   [17:9]  = src1
    //   [8:0]   = src0
    //
    // Rather than fully derive the field layout we splice in the
    // reverse-engineered value directly for the "neg sgpr, vgpr,
    // vgpr" operand shape that the decay idiom needs. Generalising
    // across VOP3 operand shapes lands alongside the next f64
    // lowerable expression.
    uint64 src0_enc = neg_sgpr_pair & 0x1FF               // SGPR pair: encoding = pair_idx * 2
    uint64 src1_enc = 0x100 | (v_src1_pair & 0xFF)        // VGPR = 0x100 + idx
    uint64 src2_enc = 0x100 | (v_src2_pair & 0xFF)
    uint64 neg = 0x1                                       // neg[0]=1 → -src0
    uint64 word2 = (neg << 29)
                   | ((src2_enc & 0x1FF) << 18)
                   | ((src1_enc & 0x1FF) << 9)
                   | (src0_enc & 0x1FF)
    asm_u32(word2)
}

// ---------------------------------------------------------------------------
// Top-level emitter
// ---------------------------------------------------------------------------

// LDS-aware variant: takes an extra group_segment_size parameter
// (bytes of LDS the kernel needs) and threads it through to the
// kernel descriptor's group_segment_fixed_size field. Required for
// any kernel that uses ds_write_*/ds_read_* (LDS GEMM, attention,
// etc.). The default emit_amdgpu_code_object below calls this with
// group_segment_size = 0.
@export
fn emit_amdgpu_code_object_lds(uint64 kname_ptr, uint64 kname_len,
                                uint64 kernel_bytes, uint64 kernel_size,
                                uint64 kernarg_size, uint64 kernarg_align,
                                uint64 sgpr_count, uint64 vgpr_count,
                                uint64 rsrc1, uint64 rsrc2, uint64 rsrc3,
                                uint64 properties,
                                uint64 args_desc, uint64 n_args,
                                uint64 group_segment_size) -> uint64 {
    kt_reset()
    kt_push_lds(kname_ptr, kname_len, kernel_bytes, kernel_size,
                args_desc, n_args, kernarg_size,
                sgpr_count, vgpr_count,
                rsrc1, rsrc2, rsrc3, properties,
                group_segment_size)
    return emit_amdgpu_multi_code_object()
}

// Back-compat single-kernel emit: push one entry and emit. Used by
// emit_amdgpu_nop_blob, emit_amdgpu_sentinel_blob, and any other
// single-shot caller.
@export
fn emit_amdgpu_code_object(uint64 kname_ptr, uint64 kname_len,
                            uint64 kernel_bytes, uint64 kernel_size,
                            uint64 kernarg_size, uint64 kernarg_align,
                            uint64 sgpr_count, uint64 vgpr_count,
                            uint64 rsrc1, uint64 rsrc2, uint64 rsrc3,
                            uint64 properties,
                            uint64 args_desc, uint64 n_args) -> uint64 {
    kt_reset()
    kt_push(kname_ptr, kname_len, kernel_bytes, kernel_size,
            args_desc, n_args, kernarg_size,
            sgpr_count, vgpr_count,
            rsrc1, rsrc2, rsrc3, properties)
    return emit_amdgpu_multi_code_object()
}

// Emit an amdgcn ELF containing every kernel currently in the
// kernel table (populated via kt_push). Returns the final file size
// in bytes; callers retrieve the buffer via amd_buf_ptr() +
// amd_buf_len(). The single-kernel entry point above is just a
// thin wrapper around this.
@export
fn emit_amdgpu_multi_code_object() -> uint64 {
    amd_init()

    if kt_count == 0 {
        write(2, "format_amdgpu: no kernels in table\n", 35)
        exit(1)
    }

    uint64 n_phdrs = 5

    // ELF header
    amd_byte(0x7F); amd_byte(0x45); amd_byte(0x4C); amd_byte(0x46) // \x7fELF
    amd_byte(2)                       // ELFCLASS64
    amd_byte(1)                       // ELFDATA2LSB
    amd_byte(1)                       // EV_CURRENT
    amd_byte(ELF_OSABI_AMDGPU_HSA)
    amd_byte(ELF_AMDHSA_ABI_V4)
    amd_byte(0); amd_byte(0); amd_byte(0); amd_byte(0)
    amd_byte(0); amd_byte(0); amd_byte(0)
    amd_u16(ELF_ET_DYN)               // e_type
    amd_u16(ELF_EM_AMDGPU)            // e_machine
    amd_u32(1)                        // e_version
    amd_u64(0)                        // e_entry (unused for code objects)
    amd_u64(AMD_ELF_HEADER_SIZE)      // e_phoff (right after header)
    uint64 shoff_patch = amd_len
    amd_u64(0)                        // e_shoff — patched later
    amd_u32(amdgpu_target_arch_eflags())  // e_flags (target-arch routed)
    amd_u16(AMD_ELF_HEADER_SIZE)      // e_ehsize
    amd_u16(AMD_PHDR_SIZE)            // e_phentsize
    amd_u16(n_phdrs)                  // e_phnum
    amd_u16(AMD_SHDR_SIZE)            // e_shentsize
    uint64 shnum_patch = amd_len
    amd_u16(0)                        // e_shnum — patched later
    uint64 shstrndx_patch = amd_len
    amd_u16(0)                        // e_shstrndx — patched later

    // PHDR placeholders (we'll emit actual phdrs after we compute
    // the layout). Reserve `n_phdrs * AMD_PHDR_SIZE` zeroed bytes.
    uint64 phdr_off = amd_len
    uint64 phdr_area = n_phdrs * AMD_PHDR_SIZE
    uint64 pi = 0
    while pi < phdr_area { amd_byte(0); pi = pi + 1 }

    // ---- Phase 2: emit the R-segment payload.

    // Pad to 16 bytes for cleanliness.
    amd_align(16)

    uint64 r_seg_start = 0                  // R segment starts at file 0 (covers header+phdrs+everything below)
    uint64 r_vaddr = 0

    // .note — emit all kernels' metadata in one note.
    uint64 note_off = amd_len
    uint64 note_size = amd_emit_note_section()
    amd_align(8)

    // .hash — single-bucket SysV hash covering 1 + 2 * kt_count
    // dynsym entries. With one bucket every name lookup walks the
    // chain in insertion order: bucket[0] points at the highest
    // sym index, then chain[] walks back down to sym 1 (sym 0 is
    // STN_UNDEF and terminates). This is O(N) per lookup — fine at
    // the current scale; a proper gnu-hash variant lands when we
    // start emitting .co files with dozens of kernels.
    uint64 hash_off = amd_len
    uint64 n_syms_total = 1 + kt_count * 2      // NULL + {FUNC, OBJECT} per kernel
    amd_u32(1)                                  // nbuckets
    amd_u32(n_syms_total)                       // nchain
    amd_u32(n_syms_total - 1)                   // buckets[0] = last sym idx
    amd_u32(0)                                  // chain[0] — STN_UNDEF
    uint64 hi = 1
    while hi < n_syms_total {
        if hi == 1 {
            amd_u32(0)                          // chain[1] terminates
        } else {
            amd_u32(hi - 1)                     // chain[i] -> i-1
        }
        hi = hi + 1
    }
    uint64 hash_size = amd_len - hash_off
    amd_align(8)

    // .dynsym — NULL + {FUNC, OBJECT} per kernel. st_value / st_shndx
    // are back-patched once we know the .text and .rodata vaddrs.
    // Elf64_Sym: st_name(u32) st_info(u8) st_other(u8) st_shndx(u16)
    //            st_value(u64) st_size(u64) — 24 bytes.
    uint64 dynsym_off = amd_len
    amd_u32(0); amd_byte(0); amd_byte(0); amd_u16(0)
    amd_u64(0); amd_u64(0)
    uint64 dynstr_running = 1                   // skip leading \0
    uint64 dki = 0
    while dki < kt_count {
        uint64 kname_len_k = kt_get(dki, 1)
        uint64 kernel_sz_k = kt_get(dki, 3)
        // FUNC sym — name at dynstr_running, value/shndx patched.
        amd_u32(dynstr_running)
        amd_byte(amd_st_info(ELF_STB_GLOBAL, ELF_STT_FUNC))
        amd_byte(ELF_STV_PROTECTED)
        amd_u16(0)                              // st_shndx patched
        amd_u64(0)                              // st_value patched
        amd_u64(kernel_sz_k)
        dynstr_running = dynstr_running + kname_len_k + 1
        // OBJECT sym for "<name>.kd" — +3 chars ("." "k" "d").
        amd_u32(dynstr_running)
        amd_byte(amd_st_info(ELF_STB_GLOBAL, ELF_STT_OBJECT))
        amd_byte(ELF_STV_PROTECTED)
        amd_u16(0)                              // st_shndx patched
        amd_u64(0)                              // st_value patched
        amd_u64(64)
        dynstr_running = dynstr_running + kname_len_k + 3 + 1
        dki = dki + 1
    }
    uint64 dynsym_size = amd_len - dynsym_off

    // .dynstr: \0 + for each kernel: kname\0 + kname.kd\0
    uint64 dynstr_off = amd_len
    amd_byte(0)
    uint64 dsi = 0
    while dsi < kt_count {
        uint64 kname_ptr_k = kt_get(dsi, 0)
        uint64 kname_len_k = kt_get(dsi, 1)
        amd_bytes(kname_ptr_k, kname_len_k); amd_byte(0)
        amd_bytes(kname_ptr_k, kname_len_k)
        amd_byte(46); amd_byte(107); amd_byte(100); amd_byte(0)
        dsi = dsi + 1
    }
    uint64 dynstr_size = amd_len - dynstr_off

    // .rodata — one 64-byte kernel descriptor per kernel. The entry
    // byte offset inside each KD is back-patched once we've laid
    // out .text (different per-kernel delta).
    amd_align(64)
    uint64 rodata_off = amd_len
    uint64 rdi = 0
    while rdi < kt_count {
        uint64 kd_off_this = amd_len
        kt_set_u64_arr(kt_kd_off, rdi, kd_off_this)
        uint64 kernarg_sz = kt_get(rdi, 6)
        uint64 k_rsrc1    = kt_get(rdi, 9)
        uint64 k_rsrc2    = kt_get(rdi, 10)
        uint64 k_rsrc3    = kt_get(rdi, 11)
        uint64 k_props    = kt_get(rdi, 12)
        uint64 k_lds      = kt_get(rdi, 13)
        amd_emit_kernel_descriptor(kernarg_sz, 0, k_rsrc1, k_rsrc2, k_rsrc3, k_props, k_lds)
        rdi = rdi + 1
    }
    amd_align(8)

    // .dynamic — minimum tags ROCm's loader follows to locate the
    // symbol table. We don't write a DT_GNU_HASH; DT_HASH alone is
    // enough for the SysV lookup path.
    uint64 dynamic_off = amd_len
    uint64 dyn_count = 6
    amd_u64(DT_HASH);   amd_u64(hash_off)
    amd_u64(DT_STRTAB); amd_u64(dynstr_off)
    amd_u64(DT_SYMTAB); amd_u64(dynsym_off)
    amd_u64(DT_STRSZ);  amd_u64(dynstr_size)
    amd_u64(DT_SYMENT); amd_u64(AMD_SYMBOL_SIZE)
    amd_u64(DT_NULL);   amd_u64(0)
    uint64 dynamic_size = amd_len - dynamic_off

    // End of R-segment payload.
    uint64 r_seg_end = amd_len

    // ---- .text must be page-aligned (0x1000) VIRTUALLY. We keep
    // file_offset ≡ vaddr (mod 0x1000) and give .text its own page.
    // File: pad to next 0x1000 boundary starting from 0x1000.
    // hipcc puts .text at file 0x900 / vaddr 0x1900. We'll do the
    // same modular offset: file 0x?00 / vaddr 0x1?00 where ? is the
    // same low-nibble. Simplest is file-align to 0x100 once we're
    // above 0x800, then vaddr = file_off + 0x1000.
    amd_align(256)
    uint64 text_file_off = amd_len
    uint64 text_vaddr_base = text_file_off + 0x1000

    // Emit each kernel's bytes back-to-back. 256-align kernels 2..N
    // (the ABI wants each kernel entry to start on a cache line);
    // kernel 0 already inherits the section's 256-alignment. We
    // deliberately compute text_size BEFORE any trailing pad so
    // the single-kernel N=1 case matches the pre-M1f byte layout
    // exactly (phdr filesz and .text sh_size cover only real
    // instruction bytes, not file padding).
    uint64 txi = 0
    while txi < kt_count {
        if txi > 0 { amd_align(256) }
        uint64 k_bytes = kt_get(txi, 2)
        uint64 k_bsize = kt_get(txi, 3)
        write(2, "DBG emit_text k_bsize=", 22)
        uint64 dbg_kbs_buf = alloc(32)
        uint64 dbg_kbs_l = fmt_uint(dbg_kbs_buf, k_bsize)
        write(2, dbg_kbs_buf, dbg_kbs_l)
        write(2, "\n", 1)
        uint64 k_vaddr = amd_len - text_file_off + text_vaddr_base
        kt_set_u64_arr(kt_text_vaddr, txi, k_vaddr)
        amd_bytes(k_bytes, k_bsize)
        txi = txi + 1
    }
    uint64 text_size = amd_len - text_file_off
    amd_align(16)

    // Back-patch each KD's entry_byte_offset (i64 at KD+0x10) with
    // its own kernel's text vaddr delta.
    uint64 pki = 0
    while pki < kt_count {
        uint64 kd_off_k = kt_get_u64_arr(kt_kd_off, pki)
        uint64 text_va  = kt_get_u64_arr(kt_text_vaddr, pki)
        uint64 delta    = text_va - kd_off_k
        uint64 patch_at = kd_off_k + 0x10
        uint64 ei = 0
        while ei < 8 {
            uint64 ep = amd_buf + patch_at + ei
            uint8 eb = (delta >> (ei * 8)) & 0xFF
            unsafe { *(ep as uint8) = eb }
            ei = ei + 1
        }
        pki = pki + 1
    }

    // ---- Phase 2b: emit .symtab + .strtab at the tail of the file.
    // ROCm's ELF loader walks the section table looking up string
    // tables for every strtab-linked section; a code object without
    // a non-dynamic .strtab trips its "null sections(STRTAB)" check
    // even though runtime symbol resolution only reads .dynsym. Keep
    // these unallocated (outside any LOAD segment) — they exist
    // purely for the loader's sanity check.
    amd_align(8)
    uint64 strtab_off = amd_len
    amd_byte(0)
    uint64 sti = 0
    while sti < kt_count {
        uint64 knm_ptr = kt_get(sti, 0)
        uint64 knm_len = kt_get(sti, 1)
        amd_bytes(knm_ptr, knm_len); amd_byte(0)
        amd_bytes(knm_ptr, knm_len)
        amd_byte(46); amd_byte(107); amd_byte(100); amd_byte(0)
        sti = sti + 1
    }
    uint64 strtab_size = amd_len - strtab_off

    amd_align(8)
    uint64 symtab_off = amd_len
    amd_u32(0); amd_byte(0); amd_byte(0); amd_u16(0)
    amd_u64(0); amd_u64(0)
    uint64 strtab_running = 1
    uint64 syi = 0
    while syi < kt_count {
        uint64 kn_len_s = kt_get(syi, 1)
        uint64 kn_sz_s  = kt_get(syi, 3)
        uint64 k_vaddr_s = kt_get_u64_arr(kt_text_vaddr, syi)
        uint64 kd_off_s  = kt_get_u64_arr(kt_kd_off, syi)
        // FUNC sym
        amd_u32(strtab_running)
        amd_byte(amd_st_info(ELF_STB_GLOBAL, ELF_STT_FUNC))
        amd_byte(ELF_STV_PROTECTED)
        amd_u16(6)                       // .text section index
        amd_u64(k_vaddr_s)
        amd_u64(kn_sz_s)
        strtab_running = strtab_running + kn_len_s + 1
        // OBJECT sym
        amd_u32(strtab_running)
        amd_byte(amd_st_info(ELF_STB_GLOBAL, ELF_STT_OBJECT))
        amd_byte(ELF_STV_PROTECTED)
        amd_u16(5)                       // .rodata section index
        amd_u64(kd_off_s)
        amd_u64(64)
        strtab_running = strtab_running + kn_len_s + 3 + 1
        syi = syi + 1
    }
    uint64 symtab_size = amd_len - symtab_off

    // ---- Phase 3: section headers.
    // Sections (in this order — index must match):
    //   0: NULL
    //   1: .note
    //   2: .hash
    //   3: .dynsym
    //   4: .dynstr
    //   5: .rodata
    //   6: .text
    //   7: .dynamic
    //   8: .symtab
    //   9: .strtab
    //  10: .shstrtab

    // Build .shstrtab contents. We collect names and their offsets as
    // we write. Each section's sh_name is the offset within .shstrtab.
    amd_align(8)
    uint64 shstrtab_off = amd_len
    amd_byte(0)
    uint64 sh_name_note     = amd_len - shstrtab_off
    uint64 s_note   = ".note";    amd_bytes(s_note,   5);  amd_byte(0)
    uint64 sh_name_hash     = amd_len - shstrtab_off
    uint64 s_hash   = ".hash";    amd_bytes(s_hash,   5);  amd_byte(0)
    uint64 sh_name_dynsym   = amd_len - shstrtab_off
    uint64 s_dynsym = ".dynsym";  amd_bytes(s_dynsym, 7);  amd_byte(0)
    uint64 sh_name_dynstr   = amd_len - shstrtab_off
    uint64 s_dynstr = ".dynstr";  amd_bytes(s_dynstr, 7);  amd_byte(0)
    uint64 sh_name_rodata   = amd_len - shstrtab_off
    uint64 s_rodata = ".rodata";  amd_bytes(s_rodata, 7);  amd_byte(0)
    uint64 sh_name_text     = amd_len - shstrtab_off
    uint64 s_text   = ".text";    amd_bytes(s_text,   5);  amd_byte(0)
    uint64 sh_name_dynamic  = amd_len - shstrtab_off
    uint64 s_dyn    = ".dynamic"; amd_bytes(s_dyn,    8);  amd_byte(0)
    uint64 sh_name_symtab   = amd_len - shstrtab_off
    uint64 s_symtab = ".symtab"; amd_bytes(s_symtab, 7);  amd_byte(0)
    uint64 sh_name_strtab   = amd_len - shstrtab_off
    uint64 s_strtab = ".strtab"; amd_bytes(s_strtab, 7);  amd_byte(0)
    uint64 sh_name_shstr    = amd_len - shstrtab_off
    uint64 s_shstr  = ".shstrtab"; amd_bytes(s_shstr, 9);  amd_byte(0)
    uint64 shstrtab_size = amd_len - shstrtab_off

    // Section header table.
    amd_align(8)
    uint64 shoff = amd_len
    // [0] NULL
    uint64 si = 0
    while si < AMD_SHDR_SIZE { amd_byte(0); si = si + 1 }
    // [1] .note
    amd_u32(sh_name_note)
    amd_u32(ELF_SHT_NOTE)
    amd_u64(ELF_SHF_ALLOC)
    amd_u64(note_off)
    amd_u64(note_off)
    amd_u64(note_size)
    amd_u32(0); amd_u32(0)
    amd_u64(4); amd_u64(0)
    // [2] .hash
    amd_u32(sh_name_hash)
    amd_u32(ELF_SHT_HASH)
    amd_u64(ELF_SHF_ALLOC)
    amd_u64(hash_off)
    amd_u64(hash_off)
    amd_u64(hash_size)
    amd_u32(3)                      // sh_link = .dynsym (index 3)
    amd_u32(0)
    amd_u64(4); amd_u64(4)
    // [3] .dynsym
    amd_u32(sh_name_dynsym)
    amd_u32(ELF_SHT_DYNSYM)
    amd_u64(ELF_SHF_ALLOC)
    amd_u64(dynsym_off)
    amd_u64(dynsym_off)
    amd_u64(dynsym_size)
    amd_u32(4)                      // sh_link = .dynstr (index 4)
    amd_u32(1)                      // sh_info — first non-local sym index
    amd_u64(8)
    amd_u64(AMD_SYMBOL_SIZE)
    // [4] .dynstr
    amd_u32(sh_name_dynstr)
    amd_u32(ELF_SHT_STRTAB)
    amd_u64(ELF_SHF_ALLOC)
    amd_u64(dynstr_off)
    amd_u64(dynstr_off)
    amd_u64(dynstr_size)
    amd_u32(0); amd_u32(0)
    amd_u64(1); amd_u64(0)
    // [5] .rodata — size is 64 per kernel descriptor.
    amd_u32(sh_name_rodata)
    amd_u32(ELF_SHT_PROGBITS)
    amd_u64(ELF_SHF_ALLOC)
    amd_u64(rodata_off)
    amd_u64(rodata_off)
    amd_u64(64 * kt_count)
    amd_u32(0); amd_u32(0)
    amd_u64(64); amd_u64(0)
    // [6] .text — sh_addr at the first kernel's vaddr.
    amd_u32(sh_name_text)
    amd_u32(ELF_SHT_PROGBITS)
    amd_u64(ELF_SHF_ALLOC | ELF_SHF_EXECINSTR)
    amd_u64(text_vaddr_base)
    amd_u64(text_file_off)
    amd_u64(text_size)
    amd_u32(0); amd_u32(0)
    amd_u64(256); amd_u64(0)
    // [7] .dynamic
    amd_u32(sh_name_dynamic)
    amd_u32(ELF_SHT_DYNAMIC)
    amd_u64(ELF_SHF_ALLOC)
    amd_u64(dynamic_off)
    amd_u64(dynamic_off)
    amd_u64(dynamic_size)
    amd_u32(4)                      // sh_link = .dynstr
    amd_u32(0)
    amd_u64(8); amd_u64(16)
    // [8] .symtab — non-allocated, keeps the loader's sanity check happy.
    amd_u32(sh_name_symtab)
    amd_u32(ELF_SHT_SYMTAB)
    amd_u64(0)
    amd_u64(0)
    amd_u64(symtab_off)
    amd_u64(symtab_size)
    amd_u32(9)                      // sh_link = .strtab (index 9)
    amd_u32(1)                      // sh_info — first non-local
    amd_u64(8)
    amd_u64(AMD_SYMBOL_SIZE)
    // [9] .strtab
    amd_u32(sh_name_strtab)
    amd_u32(ELF_SHT_STRTAB)
    amd_u64(0)
    amd_u64(0)
    amd_u64(strtab_off)
    amd_u64(strtab_size)
    amd_u32(0); amd_u32(0)
    amd_u64(1); amd_u64(0)
    // [10] .shstrtab
    amd_u32(sh_name_shstr)
    amd_u32(ELF_SHT_STRTAB)
    amd_u64(0)
    amd_u64(0)
    amd_u64(shstrtab_off)
    amd_u64(shstrtab_size)
    amd_u32(0); amd_u32(0)
    amd_u64(1); amd_u64(0)

    uint64 shnum = 11

    // Patch e_shoff, e_shnum, e_shstrndx.
    uint64 sp0 = amd_buf + shoff_patch
    uint64 wi = 0
    while wi < 8 {
        uint64 bp = amd_buf + shoff_patch + wi
        uint8 bb = (shoff >> (wi * 8)) & 0xFF
        unsafe { *(bp as uint8) = bb }
        wi = wi + 1
    }
    uint64 snp0 = amd_buf + shnum_patch
    uint8 sn0 = shnum & 0xFF
    unsafe { *(snp0 as uint8) = sn0 }
    uint64 snp1 = amd_buf + shnum_patch + 1
    uint8 sn1 = (shnum >> 8) & 0xFF
    unsafe { *(snp1 as uint8) = sn1 }
    uint64 ssp0 = amd_buf + shstrndx_patch
    uint64 shstrndx = 10
    uint8 ss0 = shstrndx & 0xFF
    unsafe { *(ssp0 as uint8) = ss0 }
    uint64 ssp1 = amd_buf + shstrndx_patch + 1
    uint8 ss1 = (shstrndx >> 8) & 0xFF
    unsafe { *(ssp1 as uint8) = ss1 }

    // Patch every .dynsym entry's st_shndx + st_value now that
    // .text / .rodata vaddrs are known. Entry layout: 24 bytes
    // each, st_shndx at +6, st_value at +8. Entry k's FUNC sym is
    // at dynsym_off + (1 + 2k) * 24; its OBJECT sym at +1.
    uint64 patch_k = 0
    while patch_k < kt_count {
        uint64 func_off = dynsym_off + (1 + patch_k * 2) * 24
        uint64 obj_off  = dynsym_off + (1 + patch_k * 2 + 1) * 24
        uint64 tv       = kt_get_u64_arr(kt_text_vaddr, patch_k)
        uint64 kdv      = kt_get_u64_arr(kt_kd_off, patch_k)

        // FUNC — .text shndx = 6, value = text vaddr
        uint64 pfs = amd_buf + func_off + 6
        uint8 fs0 = 6; unsafe { *(pfs as uint8) = fs0 }
        uint64 pfs1 = amd_buf + func_off + 7
        uint8 fs1 = 0; unsafe { *(pfs1 as uint8) = fs1 }
        uint64 fvi = 0
        while fvi < 8 {
            uint64 vp = amd_buf + func_off + 8 + fvi
            uint8 vb = (tv >> (fvi * 8)) & 0xFF
            unsafe { *(vp as uint8) = vb }
            fvi = fvi + 1
        }

        // OBJECT — .rodata shndx = 5, value = KD file offset == vaddr
        uint64 pos = amd_buf + obj_off + 6
        uint8 os0 = 5; unsafe { *(pos as uint8) = os0 }
        uint64 pos1 = amd_buf + obj_off + 7
        uint8 os1 = 0; unsafe { *(pos1 as uint8) = os1 }
        uint64 ovi = 0
        while ovi < 8 {
            uint64 vp = amd_buf + obj_off + 8 + ovi
            uint8 vb = (kdv >> (ovi * 8)) & 0xFF
            unsafe { *(vp as uint8) = vb }
            ovi = ovi + 1
        }
        patch_k = patch_k + 1
    }

    // ---- Phase 4: emit the real phdrs at the reserved location.
    // Segment layout:
    //   PHDR_self : covers the phdrs themselves
    //   LOAD R    : file 0 -> r_seg_end, vaddr 0
    //   LOAD RX   : file text_file_off -> text_end, vaddr text_vaddr
    //   NOTE      : .note area

    uint64 r_filesz  = r_seg_end                // end of R-covered payload
    uint64 r_memsz   = r_filesz
    uint64 rx_filesz = (text_file_off + text_size) - text_file_off
    uint64 rx_memsz  = rx_filesz

    uint64 ph = phdr_off
    // [0] PHDR
    amd_patch_u32(ph,      ELF_PT_PHDR)
    amd_patch_u32(ph +  4, ELF_PF_R)
    uint64 wj = 0
    while wj < 8 {
        uint64 bp = amd_buf + ph + 8 + wj
        uint8 bb = (AMD_ELF_HEADER_SIZE >> (wj * 8)) & 0xFF
        unsafe { *(bp as uint8) = bb }
        wj = wj + 1
    }
    // p_vaddr, p_paddr
    uint64 wk = 0
    while wk < 8 {
        uint64 bp1 = amd_buf + ph + 16 + wk
        uint64 bp2 = amd_buf + ph + 24 + wk
        uint8 bb = (AMD_ELF_HEADER_SIZE >> (wk * 8)) & 0xFF
        unsafe { *(bp1 as uint8) = bb }
        unsafe { *(bp2 as uint8) = bb }
        wk = wk + 1
    }
    // filesz, memsz
    uint64 wl = 0
    while wl < 8 {
        uint64 bp3 = amd_buf + ph + 32 + wl
        uint64 bp4 = amd_buf + ph + 40 + wl
        uint8 bb = (phdr_area >> (wl * 8)) & 0xFF
        unsafe { *(bp3 as uint8) = bb }
        unsafe { *(bp4 as uint8) = bb }
        wl = wl + 1
    }
    amd_patch_u32(ph + 48, 8)         // align

    // [1] LOAD R
    uint64 ph1 = phdr_off + AMD_PHDR_SIZE
    amd_patch_u32(ph1,      ELF_PT_LOAD)
    amd_patch_u32(ph1 +  4, ELF_PF_R)
    // offset=0, vaddr=0, paddr=0
    uint64 wa = 0
    while wa < 24 {
        uint64 bp = amd_buf + ph1 + 8 + wa
        uint8 bb = 0
        unsafe { *(bp as uint8) = bb }
        wa = wa + 1
    }
    uint64 wb = 0
    while wb < 8 {
        uint64 bp3 = amd_buf + ph1 + 32 + wb
        uint64 bp4 = amd_buf + ph1 + 40 + wb
        uint8 bb = (r_filesz >> (wb * 8)) & 0xFF
        unsafe { *(bp3 as uint8) = bb }
        unsafe { *(bp4 as uint8) = bb }
        wb = wb + 1
    }
    amd_patch_u32(ph1 + 48, 0x1000)

    // [2] LOAD RX
    uint64 ph2 = phdr_off + 2 * AMD_PHDR_SIZE
    amd_patch_u32(ph2,      ELF_PT_LOAD)
    amd_patch_u32(ph2 +  4, ELF_PF_R | ELF_PF_X)
    uint64 wc = 0
    while wc < 8 {
        uint64 bp = amd_buf + ph2 + 8 + wc
        uint8 bb = (text_file_off >> (wc * 8)) & 0xFF
        unsafe { *(bp as uint8) = bb }
        wc = wc + 1
    }
    uint64 wd = 0
    while wd < 8 {
        uint64 bp1 = amd_buf + ph2 + 16 + wd
        uint64 bp2 = amd_buf + ph2 + 24 + wd
        uint8 bb = (text_vaddr_base >> (wd * 8)) & 0xFF
        unsafe { *(bp1 as uint8) = bb }
        unsafe { *(bp2 as uint8) = bb }
        wd = wd + 1
    }
    uint64 we = 0
    while we < 8 {
        uint64 bp3 = amd_buf + ph2 + 32 + we
        uint64 bp4 = amd_buf + ph2 + 40 + we
        uint8 bb = (rx_filesz >> (we * 8)) & 0xFF
        unsafe { *(bp3 as uint8) = bb }
        unsafe { *(bp4 as uint8) = bb }
        we = we + 1
    }
    amd_patch_u32(ph2 + 48, 0x1000)

    // [3] NOTE
    uint64 ph3 = phdr_off + 3 * AMD_PHDR_SIZE
    amd_patch_u32(ph3,      ELF_PT_NOTE)
    amd_patch_u32(ph3 +  4, ELF_PF_R)
    uint64 wf = 0
    while wf < 8 {
        uint64 bp1 = amd_buf + ph3 + 8  + wf     // offset
        uint64 bp2 = amd_buf + ph3 + 16 + wf     // vaddr
        uint64 bp3 = amd_buf + ph3 + 24 + wf     // paddr
        uint8 bb = (note_off >> (wf * 8)) & 0xFF
        unsafe { *(bp1 as uint8) = bb }
        unsafe { *(bp2 as uint8) = bb }
        unsafe { *(bp3 as uint8) = bb }
        wf = wf + 1
    }
    uint64 wg = 0
    while wg < 8 {
        uint64 bp1 = amd_buf + ph3 + 32 + wg
        uint64 bp2 = amd_buf + ph3 + 40 + wg
        uint8 bb = (note_size >> (wg * 8)) & 0xFF
        unsafe { *(bp1 as uint8) = bb }
        unsafe { *(bp2 as uint8) = bb }
        wg = wg + 1
    }
    amd_patch_u32(ph3 + 48, 4)

    // [4] PT_DYNAMIC — points at .dynamic so loaders pick up the
    // DT_HASH/DT_SYMTAB/DT_STRTAB tags. Addr space is same as the R
    // segment (vaddr == file offset).
    uint64 ph4 = phdr_off + 4 * AMD_PHDR_SIZE
    amd_patch_u32(ph4,      ELF_PT_DYNAMIC)
    amd_patch_u32(ph4 +  4, ELF_PF_R)
    uint64 wm = 0
    while wm < 8 {
        uint64 bp1 = amd_buf + ph4 + 8  + wm
        uint64 bp2 = amd_buf + ph4 + 16 + wm
        uint64 bp3 = amd_buf + ph4 + 24 + wm
        uint8 bb = (dynamic_off >> (wm * 8)) & 0xFF
        unsafe { *(bp1 as uint8) = bb }
        unsafe { *(bp2 as uint8) = bb }
        unsafe { *(bp3 as uint8) = bb }
        wm = wm + 1
    }
    uint64 wn = 0
    while wn < 8 {
        uint64 bp1 = amd_buf + ph4 + 32 + wn
        uint64 bp2 = amd_buf + ph4 + 40 + wn
        uint8 bb = (dynamic_size >> (wn * 8)) & 0xFF
        unsafe { *(bp1 as uint8) = bb }
        unsafe { *(bp2 as uint8) = bb }
        wn = wn + 1
    }
    amd_patch_u32(ph4 + 48, 8)

    return amd_len
}

// ---------------------------------------------------------------------------
// High-level driver: emit a no-op kernel code object (M1a).
//
// One kernel named "nop_kernel" whose body is a single s_endpgm
// (0xBF810000 in little-endian: 00 00 81 BF). Used to verify the
// code-object format is accepted by hipModuleLoadData before any
// instruction encoder lands in Stage 1 proper.

@export
fn emit_amdgpu_nop_blob(uint64 out_path) -> uint64 {
    uint64 kname = "nop_kernel"
    uint64 klen  = 10

    // s_endpgm — SOPP encoding bf810000, little-endian.
    uint8[4] kcode
    uint64 kp0 = kcode + 0; uint8 b0 = 0x00; unsafe { *(kp0 as uint8) = b0 }
    uint64 kp1 = kcode + 1; uint8 b1 = 0x00; unsafe { *(kp1 as uint8) = b1 }
    uint64 kp2 = kcode + 2; uint8 b2 = 0x81; unsafe { *(kp2 as uint8) = b2 }
    uint64 kp3 = kcode + 3; uint8 b3 = 0xBF; unsafe { *(kp3 as uint8) = b3 }

    // Resource values: copied verbatim from hipcc's decay_step
    // reference object. They encode a wavefront-size-32 kernel with
    // sensible float modes. We don't need any of this to be tight
    // for s_endpgm, and overreporting resources is harmless.
    uint64 rsrc1 = 0xE0AF0000
    uint64 rsrc2 = 0x0000009E
    uint64 rsrc3 = 0x00000020
    uint64 props = 0x0408          // KERNARG_SEGMENT_PTR | WAVEFRONT_SIZE32

    uint64 size = emit_amdgpu_code_object(kname, klen,
                                           kcode, 4,
                                           0,       // kernarg_size
                                           8,       // kernarg_align
                                           0,       // sgpr_count
                                           0,       // vgpr_count
                                           rsrc1, rsrc2, rsrc3, props,
                                           0, 0)    // args_desc, n_args

    uint64 fd = file_open(out_path, 1)
    if fd > 0xFFFFFFFFFFFFF000 {
        write(2, "emit_amdgpu_nop_blob: cannot open output\n", 41)
        return 1
    }
    file_write(fd, amd_buf, size)
    file_close(fd)
    return 0
}

// ---------------------------------------------------------------------------
// M1b: single-kernel blob that writes a 0xDEADBEEF sentinel through a
// global pointer arg. The kernel body is hand-assembled — 5
// instructions — lifted from `clang --target=amdgcn -mcpu=gfx1100 -O3`
// output. An in-tree AMDGPU assembler is the next milestone; for M1b
// we only prove that the code-object wrapper correctly describes the
// kernarg ABI and that the launcher's arg passing wires up, with the
// payload instructions supplied as a pre-assembled blob.
//
// Kernel source (reference):
//   extern "C" __global__ void write_sentinel(unsigned int *out) {
//       *out = 0xDEADBEEFu;
//   }
//
// Encoding (gfx1100, 36 bytes total — each 32-bit instruction is
// stored little-endian; llvm-objdump prints the reassembled word,
// the actual byte stream is the LE decomposition of each word):
//
//   00 00 04 F4   00 00 00 F8     s_load_b64 s[0:1], s[0:1], null
//                                   (words 0xF4040000, 0xF8000000)
//   80 00 10 CA   FF 00 00 00     v_dual_mov_b32 v0, 0 :: v_dual_mov_b32 v1, 0xdeadbeef
//                                   (words 0xCA100080, 0x000000FF)
//   EF BE AD DE                    literal 0xDEADBEEF
//   07 FC 89 BF                    s_waitcnt lgkmcnt(0)          (0xBF89FC07)
//   00 00 6A DC   00 01 00 00     global_store_b32 v0, v1, s[0:1]
//                                   (words 0xDC6A0000, 0x00000100)
//   00 00 B0 BF                    s_endpgm                      (0xBFB00000)
@export
fn emit_amdgpu_sentinel_blob(uint64 out_path) -> uint64 {
    uint64 kname = "write_sentinel"
    uint64 klen  = 14

    // Build the kernel body through the structured encoders. After
    // M1c this replaces M1b's 36-byte hand-pasted blob; callers
    // elsewhere can now generate kernels opcode-by-opcode rather
    // than copy-pasting clang output.
    //
    // Source-level semantics: out[0] = 0xDEADBEEF.
    //
    //   s_load_b64  s[0:1], s[0:1], null         ; kernarg -> device ptr
    //   v_dual_mov_b32 v0, 0                     ; byte offset
    //       :: v_dual_mov_b32 v1, 0xdeadbeef     ; store value
    //   s_waitcnt   lgkmcnt(0)
    //   global_store_b32  v0, v1, s[0:1]
    //   s_endpgm
    asm_init()
    asm_s_load_b64(0, 0)                              // s[0:1] <- [s[0:1]]
    asm_v_dual_mov_b32_mov_b32_lit(0, 1, 0xDEADBEEF)  // v0 = 0, v1 = sentinel
    asm_s_waitcnt_lgkmcnt_zero()
    asm_global_store_b32(0, 1, 0)                     // *s[0:1] = v1
    asm_s_endpgm()

    // Resource values from clang's gfx1100 -O3 output for this kernel.
    // rsrc3 = 0x10 (differs from M1a's 0x20 — hipcc's decay uses 0x20
    // but the LLVM standalone path defaults to 0x10; ROCm accepts
    // either).
    uint64 rsrc1 = 0xE0AF0000
    uint64 rsrc2 = 0x0000009E
    uint64 rsrc3 = 0x00000010
    uint64 props = 0x0408    // KERNARG_SEGMENT_PTR | WAVEFRONT_SIZE32

    // One arg: 8-byte global_buffer.
    uint64[2] args_desc
    uint64 adp0 = args_desc + 0;  unsafe { *(adp0 as uint64) = 8 }
    uint64 adp1 = args_desc + 8;  unsafe { *(adp1 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }

    uint64 size = emit_amdgpu_code_object(kname, klen,
                                           asm_text_buf, asm_text_len,
                                           8,       // kernarg_size (one 8-byte ptr)
                                           8,       // kernarg_align
                                           2,       // sgpr_count
                                           2,       // vgpr_count
                                           rsrc1, rsrc2, rsrc3, props,
                                           args_desc, 1)

    uint64 fd = file_open(out_path, 1)
    if fd > 0xFFFFFFFFFFFFF000 {
        write(2, "emit_amdgpu_sentinel_blob: cannot open output\n", 46)
        return 1
    }
    file_write(fd, amd_buf, size)
    file_close(fd)
    return 0
}

// ---------------------------------------------------------------------------
// M1n per-lane loop demo: hand-crafted kernel that exercises the
// VALU divergent while-loop primitives (v_cmp, s_and_b32 on EXEC,
// s_cbranch_execz, s_branch, EXEC save/restore). Each lane runs a
// different number of iterations based on its tid.
//
// Kernel (one workgroup, multiple threads):
//     gid = tid_x()
//     if gid < n:
//         acc = 0; i = 0
//         while i < gid:
//             acc += i
//             i += 1
//         out[gid] = acc          // = gid*(gid-1)/2 (Gauss)
//
// 18-instruction lowering:
//
//   s_load_b32 s2, s[0:1], 0x8                ; n
//   s_load_b64 s[4:5], s[0:1], null           ; out ptr
//   s_waitcnt lgkmcnt(0)
//   v_cmp_gt_u32 vcc_lo, s2, v0               ; (n > gid)
//   s_and_saveexec_b32 s2, vcc_lo
//   s_cbranch_execz tail                      ; all lanes out
//   v_mov_b32 v1, 0                            ; i = 0
//   v_mov_b32 v2, 0                            ; acc = 0
//   s_mov_b32 s3, exec_lo                      ; save outer EXEC
// loop_head:
//   v_cmp_lt_u32_e32 vcc_lo, v1, v0           ; (i < gid) per lane
//   s_and_b32 exec_lo, exec_lo, vcc_lo         ; drop done lanes
//   s_cbranch_execz loop_exit                  ; if all done, break
//   v_add_nc_u32 v2, v1, v2                   ; acc += i
//   v_add_nc_u32 v1, 1, v1                    ; i += 1
//   s_branch loop_head                         ; back
// loop_exit:
//   s_mov_b32 exec_lo, s3                      ; restore outer EXEC
//   v_lshlrev_b32 v0, 2, v0                    ; v0 = gid*4 (byte off)
//   global_store_b32 v0, v2, s[4:5]
// tail:
//   s_endpgm
@export
fn emit_amdgpu_per_lane_loop_blob(uint64 out_path) -> uint64 {
    uint64 kname = "per_lane_loop"
    uint64 klen  = 13

    asm_init()
    asm_s_load_b32(1, 0, 0x8)                   // s2 = n
    asm_s_load_b64(2, 0)                        // s[4:5] = out
    asm_s_waitcnt_lgkmcnt_zero()
    asm_v_cmp_gt_u32_sgpr_vgpr(2, 0)            // vcc = (s2 > v0)
    asm_s_and_saveexec_b32_vcc_lo(2)            // save + restrict
    // cbranch_execz skip distance: if all lanes out, jump over the
    // guarded body + loop to s_endpgm. Dwords from cbranch to
    // s_endpgm:
    //   v_mov, v_mov, s_mov, v_cmp, s_and, cbranch, v_add, v_add,
    //   s_branch, s_mov, v_lshl, global_store (2), = 14 dwords.
    asm_s_cbranch_execz(14)
    // v_mov_b32 v1, 0 → 0x7E020280
    asm_u32(0x7E020280)
    // v_mov_b32 v2, 0 → 0x7E040280
    asm_u32(0x7E040280)
    asm_s_mov_b32(3, 0x7E)                      // s3 = exec_lo

    // loop_head starts here — capture dword offset (relative to .text start)
    // so we can compute the backward branch.
    uint64 loop_head_off = asm_text_len / 4      // in dwords

    asm_v_cmp_lt_u32_vv(1, 0)                   // vcc = (v1 < v0)
    asm_s_and_b32_exec_vcc_lo()
    // cbranch_execz to loop_exit: 3 dwords ahead (v_add, v_add, s_branch)
    // then loop_exit is the 4th dword.
    asm_s_cbranch_execz(3)
    asm_v_add_nc_u32_vv(2, 1, 2)                // v2 += v1
    asm_v_add_nc_u32_imm(1, 1, 1)               // v1 += 1
    // s_branch backward to loop_head. After s_branch, PC advances to
    // (current dword + 1). Target = loop_head_off. simm16 = target - (current+1).
    uint64 s_branch_at_dword = asm_text_len / 4
    uint64 delta = loop_head_off - (s_branch_at_dword + 1)
    asm_s_branch(delta & 0xFFFF)

    // loop_exit:
    asm_s_mov_b32(0x7E, 3)                      // exec_lo = s3
    // v_lshlrev_b32 v0, 2, v0 → use existing helper
    asm_v_lshlrev_b32_imm(0, 2, 0)
    asm_global_store_b32(0, 2, 4)               // *(s[4:5] + v0) = v2  (saddr raw SGPR=4)

    // tail:
    asm_s_endpgm()

    uint64[4] args_desc
    uint64 a0 = args_desc + 0;   unsafe { *(a0 as uint64) = 8 }
    uint64 a1 = args_desc + 8;   unsafe { *(a1 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a2 = args_desc + 16;  unsafe { *(a2 as uint64) = 4 }
    uint64 a3 = args_desc + 24;  unsafe { *(a3 as uint64) = AMD_ARG_KIND_BY_VALUE }

    uint64 rsrc1 = 0xE0AF0000
    uint64 rsrc2 = 0x0000009E
    uint64 rsrc3 = 0x00000010
    uint64 props = 0x0408

    uint64 size = emit_amdgpu_code_object(kname, klen,
                                           asm_text_buf, asm_text_len,
                                           12,
                                           8,
                                           6,           // sgpr s0..s5
                                           3,           // vgpr v0..v2
                                           rsrc1, rsrc2, rsrc3, props,
                                           args_desc, 2)

    uint64 fd = file_open(out_path, 1)
    if fd > 0xFFFFFFFFFFFFF000 {
        write(2, "emit_amdgpu_per_lane_loop_blob: cannot open output\n", 51)
        return 1
    }
    file_write(fd, amd_buf, size)
    file_close(fd)
    return 0
}

// ---------------------------------------------------------------------------
// M1o atomic-CAS demo: hand-crafted kernel that exercises the
// global_atomic_cmpswap_b64 encoder. Single-kernarg (u64 *out).
// Launched with block_x=1 so only lane 0 is active, no contention.
//
//   *out = atomicCAS((uint64_t*)out, 0, 7)
//   after kernel: *out == 7  (memory held 0, compare matches, swap succeeds)
//
// Assembly (12 dwords, 48 bytes). Note the AMD data-quad ordering:
// v[4:5] holds the NEW value (to be written on match), v[6:7] holds
// the COMPARE value — mirrors HIP's `atomicCAS(addr, cmp, val)` which
// clang lowers with val in the low pair and cmp in the high pair.
//
//   s_load_b64 s[0:1], s[0:1], null                          ; kernarg ptr
//   s_waitcnt lgkmcnt(0)
//   v_mov_b32 v2, 0                                          ; v_addr (byte offset)
//   v_mov_b32 v4, 7                                          ; new_lo = 7
//   v_mov_b32 v5, 0                                          ; new_hi
//   v_mov_b32 v6, 0                                          ; cmp_lo
//   v_mov_b32 v7, 0                                          ; cmp_hi
//   global_atomic_cmpswap_b64 v[0:1], v2, v[4:7], s[0:1] glc ; atomic swap
//   s_waitcnt vmcnt(0)
//   s_waitcnt_vscnt null, 0
//   s_endpgm
@export
fn emit_amdgpu_atomic_demo_blob(uint64 out_path) -> uint64 {
    uint64 kname = "atomic_cas_demo"
    uint64 klen  = 15

    asm_init()
    asm_s_load_b64(0, 0)                                   // s[0:1] <- [s[0:1]]
    asm_s_waitcnt_lgkmcnt_zero()
    asm_v_mov_b32_inline_u(2, 0)                           // v2 = 0  (byte offset)
    asm_v_mov_b32_inline_u(4, 7)                           // v4 = new_lo = 7
    asm_v_mov_b32_inline_u(5, 0)                           // v5 = new_hi
    asm_v_mov_b32_inline_u(6, 0)                           // v6 = cmp_lo
    asm_v_mov_b32_inline_u(7, 0)                           // v7 = cmp_hi
    asm_global_atomic_cmpswap_b64_glc(0, 2, 4, 0)          // v[0:1] = atomicCAS(*s[0:1], v[6:7]=0, v[4:5]=7)
    asm_s_waitcnt_vmcnt_zero()                             // drain return-value path
    asm_s_waitcnt_vscnt_zero()                             // drain the store path (gfx10+)
    asm_s_endpgm()

    uint64 rsrc1 = 0xE0AF0000
    uint64 rsrc2 = 0x0000009E
    uint64 rsrc3 = 0x00000010
    uint64 props = 0x0408

    uint64[2] args_desc
    uint64 adp0 = args_desc + 0;  unsafe { *(adp0 as uint64) = 8 }
    uint64 adp1 = args_desc + 8;  unsafe { *(adp1 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }

    uint64 size = emit_amdgpu_code_object(kname, klen,
                                           asm_text_buf, asm_text_len,
                                           8,       // kernarg_size (one 8-byte ptr)
                                           8,       // kernarg_align
                                           2,       // sgpr_count  (s0, s1)
                                           8,       // vgpr_count  (v0..v7)
                                           rsrc1, rsrc2, rsrc3, props,
                                           args_desc, 1)

    uint64 fd = file_open(out_path, 1)
    if fd > 0xFFFFFFFFFFFFF000 {
        write(2, "emit_amdgpu_atomic_demo_blob: cannot open output\n", 49)
        return 1
    }
    file_write(fd, amd_buf, size)
    file_close(fd)
    return 0
}

// ---------------------------------------------------------------------------
// M1p f64-atomic-add demo: the CAS-loop idiom composed from the M1o
// atomic_cmpswap_b64 encoder + f64 arithmetic. Single-thread kernel
// that atomically adds `delta` to *out (f64). This is the primitive
// the CSR scatter kernels need — every E/I synapse delivery does
// exactly this step (atomic += conductance into the post-synaptic
// neuron's state).
//
// Kernargs (16 bytes, 8-byte aligned):
//   [0..7]   = out ptr  (u64)
//   [8..15]  = delta    (f64)
//
// VGPR map (matches hipcc — vdst MUST overlap data_quad low half
// for gfx11 atomic-with-return reliability when the data comes from
// VALU ops):
//   v[0:1]  = data_quad[0:1] = NEW pre-CAS, PREV post-CAS (= vdst)
//   v[2:3]  = data_quad[2:3] = COMPARE / assumed
//   v[4:5]  = delta, copied from s[2:3]
//   v6      = v_addr byte offset (= 0)
//
// Assembly (~18 dwords):
//   s_load_b64 s[2:3], s[0:1], 0x8       ; delta (load BEFORE overwriting s[0:1])
//   s_load_b64 s[0:1], s[0:1], null      ; out ptr
//   s_waitcnt  lgkmcnt(0)
//   v_mov_b32  v6, 0                     ; v_addr offset
//   global_load_b64 v[2:3], v6, s[0:1]   ; assumed = *out
//   s_waitcnt  vmcnt(0)
//   v_mov_b32  v4, s2                    ; delta_lo
//   v_mov_b32  v5, s3                    ; delta_hi
// loop_head:
//   v_add_f64  v[0:1], v[2:3], v[4:5]    ; new = assumed + delta
//   s_delay_alu instid0(VALU_DEP_1)      ; let v_add_f64 settle
//   global_atomic_cmpswap_b64 v[0:1], v6, v[0:3], s[0:1] glc  ; v[0:1] = prev after CAS
//   s_waitcnt  vmcnt(0); s_waitcnt_vscnt null, 0
//   v_cmp_ne_u64_e32 vcc_lo, v[2:3], v[0:1]   ; vcc=1 if CAS lost race
//   v_mov_b32  v2, v0                    ; assumed := prev
//   v_mov_b32  v3, v1
//   s_cbranch_vccnz loop_head
//   s_endpgm
@export
fn emit_amdgpu_f64_atomic_add_blob(uint64 out_path) -> uint64 {
    uint64 kname = "f64_atomic_add_demo"
    uint64 klen  = 19

    // VGPR layout (mirrors hipcc exactly — vdst must overlap
    // data_quad low half for atomic-with-return per AMD ISA):
    //   v[0:1] = NEW pre-CAS, PREV post-CAS (data_quad[0:1] / vdst)
    //   v[2:3] = CMP / assumed             (data_quad[2:3])
    //   v[4:5] = delta                      (from s[2:3] via v_mov)
    //   v6     = v_addr byte offset (= 0)
    asm_init()
    asm_s_load_b64_off(1, 0, 0x8)                    // s[2:3] <- kernarg[8..15] = delta bits
    asm_s_load_b64(0, 0)                             // s[0:1] <- kernarg[0..7]  = out ptr
    asm_s_waitcnt_lgkmcnt_zero()
    asm_v_mov_b32_inline_u(6, 0)                     // v6 = 0 (v_addr offset)
    asm_global_load_b64(2, 6, 0)                     // v[2:3] = *s[0:1] (expected/cmp)
    asm_s_waitcnt_vmcnt_zero()
    asm_v_mov_b32(4, 2)                              // v4 = s2   (delta_lo)
    asm_v_mov_b32(5, 3)                              // v5 = s3   (delta_hi)

    // loop_head:
    uint64 loop_head_off = asm_text_len / 4

    asm_v_add_f64_vv(0, 2, 4)                        // v[0:1] = v[2:3] + v[4:5]  (new)
    asm_s_delay_alu(0x01)                            // let v_add_f64 settle
    asm_global_atomic_cmpswap_b64_glc(0, 6, 0, 0)    // v[0:1] = CAS(*s[0:1]+v6, cmp=v[2:3], new=v[0:1]); vdst overlaps
    asm_s_waitcnt_vmcnt_zero()
    asm_s_waitcnt_vscnt_zero()
    asm_v_cmp_ne_u64_vv(2, 0)                        // vcc = (v[2:3] != v[0:1] = prev)
    asm_v_mov_b32(2, 0x100 | 0)                      // v2 = v0  (assumed <- prev for next iter)
    asm_v_mov_b32(3, 0x100 | 1)                      // v3 = v1

    // Backward branch to loop_head.
    uint64 cbranch_off = asm_text_len / 4
    uint64 delta = loop_head_off - (cbranch_off + 1)
    asm_s_cbranch_vccnz(delta & 0xFFFF)

    asm_s_endpgm()

    uint64 rsrc1 = 0xE0AF0000
    uint64 rsrc2 = 0x0000009E
    uint64 rsrc3 = 0x00000010
    uint64 props = 0x0408

    // Two kernargs: out ptr (8 B, GLOBAL_BUFFER) + delta (8 B, BY_VALUE).
    uint64[4] args_desc
    uint64 a0 = args_desc + 0;   unsafe { *(a0 as uint64) = 8 }
    uint64 a1 = args_desc + 8;   unsafe { *(a1 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a2 = args_desc + 16;  unsafe { *(a2 as uint64) = 8 }
    uint64 a3 = args_desc + 24;  unsafe { *(a3 as uint64) = AMD_ARG_KIND_BY_VALUE }

    uint64 size = emit_amdgpu_code_object(kname, klen,
                                           asm_text_buf, asm_text_len,
                                           16,      // kernarg_size (ptr + f64)
                                           8,       // kernarg_align
                                           4,       // sgpr_count (s0..s3)
                                           7,       // vgpr_count (v0..v6)
                                           rsrc1, rsrc2, rsrc3, props,
                                           args_desc, 2)

    uint64 fd = file_open(out_path, 1)
    if fd > 0xFFFFFFFFFFFFF000 {
        write(2, "emit_amdgpu_f64_atomic_add_blob: cannot open output\n", 52)
        return 1
    }
    file_write(fd, amd_buf, size)
    file_close(fd)
    return 0
}

// ---------------------------------------------------------------------------
// M1q (post-M1q' hazard fix) full CSR scatter demo: multi-synapse
// while loop + CSR-indirected (tgt, w) loads + f64 atomic-add into
// s_out[tgt]. Uses the clang-matching pattern discovered during the
// M1q' investigation:
//   * Scalar precomputation of rpi_tgt+syn*8 and rpi_w+syn*8 in SGPR
//     pairs (s_lshl_b64 + s_add_u32 + s_addc_u32).
//   * VMEM loads of tgt/w with saddr=<precomputed pair> and a
//     constant-zero v_addr VGPR (v8=0).
//   * 64-bit scatter address computed as a VGPR pair (v[6:7]) via
//     v_lshlrev_b64 + v_add_co_u32 + v_add_co_ci_u32_e64.
//   * Assumed-load and global_atomic_cmpswap use saddr=OFF (0x7C)
//     with a full 64-bit v_addr pair. The mixed saddr+32b-v_addr
//     mode my earlier attempts used failed under two specific
//     conditions that this pattern avoids: (a) VMEM-loaded VGPR
//     used as v_lshlrev source, and (b) chained atomic ops to the
//     same saddr-anchored address.
//
// Kernargs (32 bytes):
//   [0..7]   = rpi_ptr_ptr  (u64* — CSR row pointers)
//   [8..15]  = rpi_tgt_ptr  (u64* — target-neuron column indices)
//   [16..23] = rpi_w_ptr    (f64* — synapse weights)
//   [24..31] = s_out_ptr    (f64* — scatter destination)
@export
fn emit_amdgpu_csr_scatter_demo_blob(uint64 out_path) -> uint64 {
    uint64 kname = "csr_scatter_demo"
    uint64 klen  = 16

    asm_init()

    // --- Prologue: 4 pointer kernargs ---
    asm_s_load_b64(1, 0)                            // s[2:3] = rpi_ptr_ptr
    asm_s_load_b64_off(2, 0, 0x08)                  // s[4:5] = rpi_tgt_ptr
    asm_s_load_b64_off(3, 0, 0x10)                  // s[6:7] = rpi_w_ptr
    asm_s_load_b64_off(4, 0, 0x18)                  // s[8:9] = s_out_ptr
    asm_s_waitcnt_lgkmcnt_zero()

    // --- Second-level SMEM: [start, end] = rpi_ptr[0..1] ---
    asm_s_load_b64_off(5, 1, 0x00)                  // s[10:11] = start
    asm_s_load_b64_off(6, 1, 0x08)                  // s[12:13] = end
    asm_s_waitcnt_lgkmcnt_zero()

    // Constant zero VGPR used as v_addr for saddr-only VMEM loads.
    asm_v_mov_b32_inline_u(8, 0)

    // --- loop_head (SALU-driven while loop over synapses) ---
    uint64 loop_head_off = asm_text_len / 4
    asm_s_cmp_lt_u32(10, 12)                        // scc = (syn < end)
    uint64 scc_patch_off = asm_text_len / 4
    asm_s_cbranch_scc0(0)                           // (placeholder, patched below)

    // Scalar precompute: s[14:15] = syn * 8
    asm_u32(0x848E830A)                             // s_lshl_b64 s[14:15], s[10:11], 3

    // s[16:17] = rpi_tgt_ptr + syn*8  (64-bit add)
    asm_u32(0x80100E04)                             // s_add_u32  s16, s4, s14
    asm_u32(0x82110F05)                             // s_addc_u32 s17, s5, s15

    // s[18:19] = rpi_w_ptr + syn*8
    asm_u32(0x80120E06)                             // s_add_u32  s18, s6, s14
    asm_u32(0x82130F07)                             // s_addc_u32 s19, s7, s15

    // Clang-matching layout: tgt goes into v[0:1], gets shifted in
    // place, then the scatter addr is built into v[6:7]. vmcnt(1) to
    // wait for ONLY the tgt load, like clang does.
    asm_u32(0xDC560000)                             // global_load_b64 v[0:1], v8, s[16:17]
    asm_u32(0x00100008)
    asm_u32(0xDC560000)                             // global_load_b64 v[4:5], v8, s[18:19]
    asm_u32(0x04120008)
    // s_waitcnt vmcnt(1) → word 0xBF8907F7 per clang. 0x07F7 = vmcnt=1
    // with other counters max.
    asm_u32(0xBF8907F7)

    // Shift tgt in place as 64-bit pair (byte offset for scatter).
    asm_u32(0xD73C0000)                             // v_lshlrev_b64 v[0:1], 3, v[0:1]
    asm_u32(0x00020083)

    // Compound s_delay_alu matching clang between v_lshlrev_b64 and
    // v_add_co_u32: VALU_DEP_1 | instskip(NEXT) | instid1(VALU_DEP_1)
    // = simm 0x0091 (SOPP op 0x07).
    asm_u32(0xBF870091)

    // Scatter address v[6:7] = s[8:9] + v[0:1] with carry.
    asm_u32(0xD7006A06)                             // v_add_co_u32 v6, vcc_lo, s8, v0
    asm_u32(0x00020008)
    asm_u32(0xD5207C07)                             // v_add_co_ci_u32_e64 v7, null, s9, v1, vcc_lo
    asm_u32(0x01AA0209)

    // Prime CAS "assumed" — saddr=OFF, v[6:7] is the 64-bit v_addr.
    asm_u32(0xDC560000)                             // global_load_b64 v[2:3], v[6:7], off
    asm_u32(0x027C0006)
    asm_s_waitcnt_vmcnt_zero()

    // --- CAS retry loop for f64 atomic-add ---
    uint64 cas_head_off = asm_text_len / 4
    asm_v_add_f64_vv(0, 2, 4)                       // v[0:1] = assumed + w
    asm_s_delay_alu(0x01)

    asm_u32(0xDD0A4000)                             // global_atomic_cmpswap_b64 v[0:1], v[6:7], v[0:3], off glc
    asm_u32(0x007C0006)
    asm_s_waitcnt_vmcnt_zero()
    asm_s_waitcnt_vscnt_zero()

    asm_v_cmp_ne_u64_vv(2, 0)
    asm_v_mov_b32(2, 0x100 | 0)
    asm_v_mov_b32(3, 0x100 | 1)
    uint64 cas_branch_off = asm_text_len / 4
    uint64 cas_delta = cas_head_off - (cas_branch_off + 1)
    asm_s_cbranch_vccnz(cas_delta & 0xFFFF)

    // Bump syn and loop back.
    asm_s_add_u32_imm(10, 10, 1)
    uint64 outer_branch_off = asm_text_len / 4
    uint64 outer_delta = loop_head_off - (outer_branch_off + 1)
    asm_s_branch(outer_delta & 0xFFFF)

    // loop_exit: back-patch the scc0 cbranch.
    uint64 loop_exit_off = asm_text_len / 4
    uint64 scc_skip = loop_exit_off - (scc_patch_off + 1)
    uint64 patch_byte = asm_text_buf + scc_patch_off * 4
    uint32 new_word = 0xBFA10000 | (scc_skip & 0xFFFF)
    unsafe { *(patch_byte as uint32) = new_word }

    asm_s_endpgm()

    uint64 rsrc1 = 0xE0AF0000
    uint64 rsrc2 = 0x0000009E
    uint64 rsrc3 = 0x00000010
    uint64 props = 0x0408

    // Four GLOBAL_BUFFER pointer kernargs.
    uint64[8] args_desc
    uint64 a0 = args_desc + 0;  unsafe { *(a0 as uint64) = 8 }
    uint64 a1 = args_desc + 8;  unsafe { *(a1 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a2 = args_desc + 16; unsafe { *(a2 as uint64) = 8 }
    uint64 a3 = args_desc + 24; unsafe { *(a3 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a4 = args_desc + 32; unsafe { *(a4 as uint64) = 8 }
    uint64 a5 = args_desc + 40; unsafe { *(a5 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a6 = args_desc + 48; unsafe { *(a6 as uint64) = 8 }
    uint64 a7 = args_desc + 56; unsafe { *(a7 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }

    uint64 size = emit_amdgpu_code_object(kname, klen,
                                           asm_text_buf, asm_text_len,
                                           32,      // kernarg_size (4 × 8 bytes)
                                           8,       // kernarg_align
                                           20,      // sgpr_count (s0..s19)
                                           16,      // vgpr_count (v0..v15)
                                           rsrc1, rsrc2, rsrc3, props,
                                           args_desc, 4)

    uint64 fd = file_open(out_path, 1)
    if fd > 0xFFFFFFFFFFFFF000 {
        write(2, "emit_amdgpu_csr_scatter_demo_blob: cannot open output\n", 54)
        return 1
    }
    file_write(fd, amd_buf, size)
    file_close(fd)
    return 0
}

// ---------------------------------------------------------------------------
// M1r csr_i_deliver: the first full scientific shape — the inhibitory
// CSR delivery kernel. Extends M1q's scatter with:
//   * Two nested guards over scalar state (cell_type == 1, release > 0)
//     implemented with SALU compares + scc/vccz branches so the body
//     is skipped when the guards fail (single-thread scope).
//   * f64 multiply of w * rel to produce the effective conductance
//     before the atomic-add.
// Single-thread semantics mirror the inner body of csr_i_deliver in
// examples/gpu_csr_i.mlr; a future milestone wires this into the AST
// lowerer + multi-thread EXEC-narrowing.
//
// Kernargs (56 bytes):
//   [0..7]   rpi_ptr_ptr    (u64*)
//   [8..15]  rpi_tgt_ptr    (u64*)
//   [16..23] rpi_w_ptr      (f64*)
//   [24..31] cell_type_ptr  (u64*)
//   [32..39] release_ptr    (f64*)
//   [40..47] s_inh_ptr      (f64*, scatter destination)
//   [48..55] n              (u64 by-value; unused in single-thread)
@export
fn emit_amdgpu_csr_i_deliver_blob(uint64 out_path) -> uint64 {
    uint64 kname = "csr_i_deliver"
    uint64 klen  = 13

    asm_init()

    // --- Prologue: 6 pointer kernargs (+ n kernarg skipped) ---
    asm_s_load_b64(1, 0)                            // s[2:3]   = rpi_ptr_ptr
    asm_s_load_b64_off(2, 0, 0x08)                  // s[4:5]   = rpi_tgt_ptr
    asm_s_load_b64_off(3, 0, 0x10)                  // s[6:7]   = rpi_w_ptr
    asm_s_load_b64_off(4, 0, 0x18)                  // s[8:9]   = cell_type_ptr
    asm_s_load_b64_off(5, 0, 0x20)                  // s[10:11] = release_ptr
    asm_s_load_b64_off(6, 0, 0x28)                  // s[12:13] = s_inh_ptr
    asm_s_waitcnt_lgkmcnt_zero()

    // --- Guard 1: ct == 1 ---
    asm_s_load_b64_off(7, 4, 0x00)                  // s[14:15] = *cell_type_ptr
    asm_s_waitcnt_lgkmcnt_zero()
    asm_s_cmp_eq_u32(14, 0x81)                      // scc = (s14 == 1)
    uint64 ct_patch_off = asm_text_len / 4
    asm_s_cbranch_scc0(0)                           // placeholder → loop_exit

    // --- Guard 2: rel > 0.0 ---
    asm_s_load_b64_off(8, 5, 0x00)                  // s[16:17] = rel bits
    asm_s_waitcnt_lgkmcnt_zero()
    asm_v_mov_b32(4, 16)                            // v4 = s16 (rel_lo)
    asm_v_mov_b32(5, 17)                            // v5 = s17 (rel_hi)
    asm_s_delay_alu(0x02)
    asm_v_cmp_lt_f64_zero_v(4)                      // vcc = (0.0 < rel)
    uint64 rel_patch_off = asm_text_len / 4
    asm_sopp(0x23, 0)                               // s_cbranch_vccz placeholder → loop_exit

    // --- Load start, end via SMEM (sbase=1 = s[2:3] = rpi_ptr_ptr) ---
    asm_s_load_b64_off(9, 1, 0x00)                  // s[18:19] = start
    asm_s_load_b64_off(10, 1, 0x08)                 // s[20:21] = end
    asm_s_waitcnt_lgkmcnt_zero()

    // v8 = 0 constant for saddr-only VMEM loads.
    asm_v_mov_b32_inline_u(8, 0)

    // --- Outer loop: for syn in [start, end) ---
    uint64 loop_head_off = asm_text_len / 4
    asm_s_cmp_lt_u32(18, 20)                        // scc = (syn < end)
    uint64 loop_patch_off = asm_text_len / 4
    asm_s_cbranch_scc0(0)                           // placeholder → loop_exit

    // Scalar precompute of rpi_tgt+syn*8 and rpi_w+syn*8.
    asm_u32(0x84968312)                             // s_lshl_b64 s[22:23], s[18:19], 3
    asm_u32(0x80181604)                             // s_add_u32  s24, s4, s22
    asm_u32(0x82191705)                             // s_addc_u32 s25, s5, s23
    asm_u32(0x801A1606)                             // s_add_u32  s26, s6, s22
    asm_u32(0x821B1707)                             // s_addc_u32 s27, s7, s23

    // VMEM: v[0:1] = rpi_tgt[syn], v[6:7] = rpi_w[syn]
    asm_u32(0xDC560000)                             // global_load_b64 v[0:1], v8, s[24:25]
    asm_u32(0x00180008)
    asm_u32(0xDC560000)                             // global_load_b64 v[6:7], v8, s[26:27]
    asm_u32(0x061A0008)
    asm_u32(0xBF8907F7)                             // s_waitcnt vmcnt(1) — wait for tgt only

    // Shift tgt*8 in place (clang-matching layout).
    asm_u32(0xD73C0000)                             // v_lshlrev_b64 v[0:1], 3, v[0:1]
    asm_u32(0x00020083)
    asm_u32(0xBF870091)                             // s_delay_alu VALU_DEP_1 | instskip(NEXT) | instid1(VALU_DEP_1)

    // Scatter addr v[10:11] = s_inh + tgt*8.
    asm_u32(0xD7006A0A)                             // v_add_co_u32 v10, vcc_lo, s12, v0
    asm_u32(0x0002000C)
    asm_u32(0xD5207C0B)                             // v_add_co_ci_u32_e64 v11, null, s13, v1, vcc_lo
    asm_u32(0x01AA020D)

    // Wait for w load, then compute effective = w * rel.
    asm_s_waitcnt_vmcnt_zero()
    asm_v_mul_f64_vv(12, 6, 4)                      // v[12:13] = w * rel
    asm_s_delay_alu(0x01)

    // Prime CAS assumed = *s_inh[tgt] via saddr=OFF load.
    asm_u32(0xDC560000)                             // global_load_b64 v[2:3], v[10:11], off
    asm_u32(0x027C000A)
    asm_s_waitcnt_vmcnt_zero()

    // --- CAS retry loop for the atomic add ---
    uint64 cas_head_off = asm_text_len / 4
    asm_v_add_f64_vv(0, 2, 12)                      // v[0:1] = assumed + effective
    asm_s_delay_alu(0x01)
    asm_u32(0xDD0A4000)                             // global_atomic_cmpswap_b64 v[0:1], v[10:11], v[0:3], off glc
    asm_u32(0x007C000A)
    asm_s_waitcnt_vmcnt_zero()
    asm_s_waitcnt_vscnt_zero()
    asm_v_cmp_ne_u64_vv(2, 0)
    asm_v_mov_b32(2, 0x100 | 0)
    asm_v_mov_b32(3, 0x100 | 1)
    uint64 cas_branch_off = asm_text_len / 4
    uint64 cas_delta = cas_head_off - (cas_branch_off + 1)
    asm_s_cbranch_vccnz(cas_delta & 0xFFFF)

    // Bump syn and branch back.
    asm_s_add_u32_imm(18, 18, 1)
    uint64 outer_branch_off = asm_text_len / 4
    uint64 outer_delta = loop_head_off - (outer_branch_off + 1)
    asm_s_branch(outer_delta & 0xFFFF)

    // --- loop_exit: patch the three forward-skip placeholders ---
    uint64 loop_exit_off = asm_text_len / 4

    uint64 ct_skip = loop_exit_off - (ct_patch_off + 1)
    uint64 pb0 = asm_text_buf + ct_patch_off * 4
    uint32 w_ct = 0xBFA10000 | (ct_skip & 0xFFFF)
    unsafe { *(pb0 as uint32) = w_ct }

    uint64 rel_skip = loop_exit_off - (rel_patch_off + 1)
    uint64 pb1 = asm_text_buf + rel_patch_off * 4
    uint32 w_rel = 0xBFA30000 | (rel_skip & 0xFFFF)
    unsafe { *(pb1 as uint32) = w_rel }

    uint64 loop_skip = loop_exit_off - (loop_patch_off + 1)
    uint64 pb2 = asm_text_buf + loop_patch_off * 4
    uint32 w_loop = 0xBFA10000 | (loop_skip & 0xFFFF)
    unsafe { *(pb2 as uint32) = w_loop }

    asm_s_endpgm()

    // rsrc values matching clang for this kernel shape (7 kernargs,
    // ~14 VGPRs): rsrc1 bit 0 set (VGPR granules = 1 → allows up to
    // ~36 VGPRs wave32) and rsrc3 = 0x30 (gfx11 forward-progress bits).
    uint64 rsrc1 = 0xE0AF0001
    uint64 rsrc2 = 0x0000009E
    uint64 rsrc3 = 0x00000030
    uint64 props = 0x0408

    // 7 kernargs: 6 GLOBAL_BUFFER + 1 BY_VALUE.
    uint64[14] args_desc
    uint64 a0 = args_desc + 0;   unsafe { *(a0 as uint64) = 8 }
    uint64 a1 = args_desc + 8;   unsafe { *(a1 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a2 = args_desc + 16;  unsafe { *(a2 as uint64) = 8 }
    uint64 a3 = args_desc + 24;  unsafe { *(a3 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a4 = args_desc + 32;  unsafe { *(a4 as uint64) = 8 }
    uint64 a5 = args_desc + 40;  unsafe { *(a5 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a6 = args_desc + 48;  unsafe { *(a6 as uint64) = 8 }
    uint64 a7 = args_desc + 56;  unsafe { *(a7 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a8 = args_desc + 64;  unsafe { *(a8 as uint64) = 8 }
    uint64 a9 = args_desc + 72;  unsafe { *(a9 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a10 = args_desc + 80; unsafe { *(a10 as uint64) = 8 }
    uint64 a11 = args_desc + 88; unsafe { *(a11 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a12 = args_desc + 96; unsafe { *(a12 as uint64) = 8 }
    uint64 a13 = args_desc + 104;unsafe { *(a13 as uint64) = AMD_ARG_KIND_BY_VALUE }

    uint64 size = emit_amdgpu_code_object(kname, klen,
                                           asm_text_buf, asm_text_len,
                                           56,      // kernarg_size (7 × 8 bytes)
                                           8,       // kernarg_align
                                           28,      // sgpr_count (s0..s27)
                                           16,      // vgpr_count (v0..v15)
                                           rsrc1, rsrc2, rsrc3, props,
                                           args_desc, 7)

    uint64 fd = file_open(out_path, 1)
    if fd > 0xFFFFFFFFFFFFF000 {
        write(2, "emit_amdgpu_csr_i_deliver_blob: cannot open output\n", 51)
        return 1
    }
    file_write(fd, amd_buf, size)
    file_close(fd)
    return 0
}

// ---------------------------------------------------------------------------
// M1s csr_e_deliver: the full excitatory CSR delivery kernel, adding
// STDP LTD on top of M1r's csr_i_deliver shape.
//
// Semantics (single-thread, src = 0):
//   for each synapse syn in [rpe_ptr[0], rpe_ptr[1]):
//     tgt  = rpe_tgt[syn]
//     w    = rpe_w[syn]
//     atomicAdd(&s_exc[tgt], w * release)
//     if rpe_is_ee[syn] != 0:
//       w_new = clamp(w + A_minus * x_post[tgt], 0.0, w_max)
//       rpe_w[syn] = w_new                     (non-atomic — one
//                                               thread per source)
//       atomicAdd_u64(ltd_events, 1)
//
// Kernargs (11 args, 88 bytes):
//   [0..7]   rpe_ptr_ptr    (u64*)
//   [8..15]  rpe_tgt_ptr    (u64*)
//   [16..23] rpe_w_ptr      (f64*)
//   [24..31] rpe_is_ee_ptr  (u64*)
//   [32..39] x_post_ptr     (f64*)
//   [40..47] release_ptr    (f64*)
//   [48..55] s_exc_ptr      (f64*)
//   [56..63] ltd_events_ptr (u64*)
//   [64..71] n              (u64 by-value, unused single-thread)
//   [72..79] A_minus        (f64 by-value)
//   [80..87] w_max          (f64 by-value)
@export
fn emit_amdgpu_csr_e_deliver_blob(uint64 out_path) -> uint64 {
    uint64 kname = "csr_e_deliver"
    uint64 klen  = 13

    asm_init()

    // --- Prologue: 8 pointer kernargs + 2 f64 by-value (skip n) ---
    asm_s_load_b64(1, 0)                            // s[2:3]   = rpe_ptr_ptr
    asm_s_load_b64_off(2, 0, 0x08)                  // s[4:5]   = rpe_tgt_ptr
    asm_s_load_b64_off(3, 0, 0x10)                  // s[6:7]   = rpe_w_ptr
    asm_s_load_b64_off(4, 0, 0x18)                  // s[8:9]   = rpe_is_ee_ptr
    asm_s_load_b64_off(5, 0, 0x20)                  // s[10:11] = x_post_ptr
    asm_s_load_b64_off(6, 0, 0x28)                  // s[12:13] = release_ptr (transient)
    asm_s_load_b64_off(7, 0, 0x30)                  // s[14:15] = s_exc_ptr
    asm_s_load_b64_off(8, 0, 0x38)                  // s[16:17] = ltd_events_ptr
    asm_s_load_b64_off(9, 0, 0x48)                  // s[18:19] = A_minus bits (skip n at 0x40)
    asm_s_load_b64_off(10, 0, 0x50)                 // s[20:21] = w_max bits
    asm_s_waitcnt_lgkmcnt_zero()

    // --- Guard: rel > 0.0 ---
    asm_s_load_b64_off(11, 6, 0x00)                 // s[22:23] = *release_ptr (sbase=6 = s[12:13])
    asm_s_waitcnt_lgkmcnt_zero()
    asm_v_mov_b32(4, 22)                            // v4 = rel_lo
    asm_v_mov_b32(5, 23)                            // v5 = rel_hi
    asm_s_delay_alu(0x02)
    asm_v_cmp_lt_f64_zero_v(4)                      // vcc = (0.0 < rel)
    uint64 rel_patch_off = asm_text_len / 4
    asm_sopp(0x23, 0)                               // s_cbranch_vccz placeholder → loop_exit

    // --- Load start/end via rpe_ptr_ptr (sbase=1 = s[2:3]) ---
    asm_s_load_b64_off(12, 1, 0x00)                 // s[24:25] = start
    asm_s_load_b64_off(13, 1, 0x08)                 // s[26:27] = end
    asm_s_waitcnt_lgkmcnt_zero()

    // Move A_minus and w_max into VGPR pairs (v[16:17], v[18:19]).
    asm_v_mov_b32(16, 18)                           // v16 = s18
    asm_v_mov_b32(17, 19)                           // v17 = s19
    asm_v_mov_b32(18, 20)                           // v18 = s20
    asm_v_mov_b32(19, 21)                           // v19 = s21

    // Constants in VGPRs: v8 = 0 (v_addr zero), v[26:27] = (1, 0) for
    // ltd_events atomic increment.
    asm_v_mov_b32_inline_u(8, 0)
    asm_v_mov_b32_inline_u(26, 1)
    asm_v_mov_b32_inline_u(27, 0)
    asm_s_delay_alu(0x04)                           // settle v_mov burst

    // --- Outer loop: syn = start .. end ---
    uint64 loop_head_off = asm_text_len / 4
    asm_s_cmp_lt_u32(24, 26)                        // scc = (syn < end)
    uint64 loop_patch_off = asm_text_len / 4
    asm_s_cbranch_scc0(0)                           // placeholder → loop_exit

    // Scalar per-iter address compute.
    asm_u32(0x849C8318)                             // s_lshl_b64 s[28:29], s[24:25], 3
    asm_u32(0x801E1C04)                             // s_add_u32  s30, s4, s28  (rpe_tgt+syn*8 lo)
    asm_u32(0x821F1D05)                             // s_addc_u32 s31, s5, s29
    asm_u32(0x80201C06)                             // s_add_u32  s32, s6, s28  (rpe_w+syn*8 lo)
    asm_u32(0x82211D07)                             // s_addc_u32 s33, s7, s29
    asm_u32(0x80221C08)                             // s_add_u32  s34, s8, s28  (rpe_is_ee+syn*8 lo)
    asm_u32(0x82231D09)                             // s_addc_u32 s35, s9, s29

    // VMEM: load tgt into v[0:1], w into v[6:7].
    asm_u32(0xDC560000)                             // global_load_b64 v[0:1], v8, s[30:31]
    asm_u32(0x001E0008)
    asm_u32(0xDC560000)                             // global_load_b64 v[6:7], v8, s[32:33]
    asm_u32(0x06200008)
    asm_u32(0xBF8907F7)                             // s_waitcnt vmcnt(1) — wait for tgt

    // Shift tgt*8 in place, delay for settlement.
    asm_u32(0xD73C0000)                             // v_lshlrev_b64 v[0:1], 3, v[0:1]
    asm_u32(0x00020083)
    asm_u32(0xBF870091)                             // s_delay_alu compound

    // Scatter addr v[10:11] = s_exc + tgt*8.
    asm_u32(0xD7006A0A)                             // v_add_co_u32 v10, vcc_lo, s14, v0
    asm_u32(0x0002000E)
    asm_u32(0xD5207C0B)                             // v_add_co_ci_u32_e64 v11, null, s15, v1, vcc_lo
    asm_u32(0x01AA020F)

    // x_post addr v[22:23] = x_post + tgt*8.
    asm_u32(0xD7006A16)                             // v_add_co_u32 v22, vcc_lo, s10, v0
    asm_u32(0x0002000A)
    asm_u32(0xD5207C17)                             // v_add_co_ci_u32_e64 v23, null, s11, v1, vcc_lo
    asm_u32(0x01AA020B)

    asm_s_waitcnt_vmcnt_zero()                      // wait for w

    // effective = w * rel → v[12:13]
    asm_v_mul_f64_vv(12, 6, 4)
    asm_s_delay_alu(0x01)

    // Prime CAS assumed = *s_exc[tgt].
    asm_u32(0xDC560000)                             // global_load_b64 v[2:3], v[10:11], off
    asm_u32(0x027C000A)
    asm_s_waitcnt_vmcnt_zero()

    // CAS retry loop.
    uint64 cas_head_off = asm_text_len / 4
    asm_v_add_f64_vv(0, 2, 12)                      // new = assumed + effective
    asm_s_delay_alu(0x01)
    asm_u32(0xDD0A4000)                             // global_atomic_cmpswap_b64 v[0:1], v[10:11], v[0:3], off glc
    asm_u32(0x007C000A)
    asm_s_waitcnt_vmcnt_zero()
    asm_s_waitcnt_vscnt_zero()
    asm_v_cmp_ne_u64_vv(2, 0)
    asm_v_mov_b32(2, 0x100 | 0)
    asm_v_mov_b32(3, 0x100 | 1)
    uint64 cas_branch_off = asm_text_len / 4
    uint64 cas_delta = cas_head_off - (cas_branch_off + 1)
    asm_s_cbranch_vccnz(cas_delta & 0xFFFF)

    // --- STDP guard: is_ee[syn] != 0 (SMEM) ---
    asm_u32(0xF4040911)                             // s_load_b64 s[36:37], s[34:35], null
    asm_u32(0xF8000000)
    asm_s_waitcnt_lgkmcnt_zero()
    asm_u32(0xBF108024)                             // s_cmp_eq_u64 s[36:37], 0
    uint64 stdp_patch_off = asm_text_len / 4
    asm_s_cbranch_scc1(0)                           // scc=1 (is_ee==0) → skip

    // Load x_post[tgt] via precomputed v[22:23] (saddr=OFF).
    asm_u32(0xDC560000)                             // global_load_b64 v[14:15], v[22:23], off
    asm_u32(0x0E7C0016)
    asm_s_waitcnt_vmcnt_zero()

    // w_new = fma(A_minus, x_post, w) → v[20:21]
    asm_u32(0xD6140014)                             // v_fma_f64 v[20:21], v[16:17], v[14:15], v[6:7]
    asm_u32(0x041A1D10)
    asm_s_delay_alu(0x01)

    // Clamp: w_new = max(w_new, 0.0)
    asm_u32(0xD72A0014)                             // v_max_f64 v[20:21], v[20:21], 0
    asm_u32(0x00010114)
    asm_s_delay_alu(0x01)

    // Clamp: w_new = min(w_new, w_max)
    asm_u32(0xD7290014)                             // v_min_f64 v[20:21], v[20:21], v[18:19]
    asm_u32(0x00022514)
    asm_s_delay_alu(0x01)

    // Non-atomic store w_new → rpe_w[syn]  (saddr-mode via s[32:33])
    asm_u32(0xDC6E0000)                             // global_store_b64 v8, v[20:21], s[32:33]
    asm_u32(0x00201408)
    asm_s_waitcnt_vscnt_zero()

    // Atomic ++ ltd_events
    asm_u32(0xDD0E0000)                             // global_atomic_add_u64 v0, v[26:27], s[16:17]
    asm_u32(0x00101A00)
    asm_s_waitcnt_vmcnt_zero()
    asm_s_waitcnt_vscnt_zero()

    // --- skip_stdp: patch the stdp forward branch to here ---
    uint64 skip_stdp_off = asm_text_len / 4
    uint64 stdp_skip = skip_stdp_off - (stdp_patch_off + 1)
    uint64 pb_s = asm_text_buf + stdp_patch_off * 4
    uint32 w_stdp = 0xBFA20000 | (stdp_skip & 0xFFFF)   // s_cbranch_scc1
    unsafe { *(pb_s as uint32) = w_stdp }

    // syn++ and branch back to loop_head.
    asm_s_add_u32_imm(24, 24, 1)
    uint64 outer_branch_off = asm_text_len / 4
    uint64 outer_delta = loop_head_off - (outer_branch_off + 1)
    asm_s_branch(outer_delta & 0xFFFF)

    // --- loop_exit: patch the rel-guard + outer-loop placeholders ---
    uint64 loop_exit_off = asm_text_len / 4

    uint64 rel_skip = loop_exit_off - (rel_patch_off + 1)
    uint64 pb_r = asm_text_buf + rel_patch_off * 4
    uint32 w_rel = 0xBFA30000 | (rel_skip & 0xFFFF)
    unsafe { *(pb_r as uint32) = w_rel }

    uint64 loop_skip = loop_exit_off - (loop_patch_off + 1)
    uint64 pb_l = asm_text_buf + loop_patch_off * 4
    uint32 w_loop = 0xBFA10000 | (loop_skip & 0xFFFF)
    unsafe { *(pb_l as uint32) = w_loop }

    asm_s_endpgm()

    // VGPR granules = 3 (gfx11 wave32 granule = 8 → up to 32 VGPRs).
    // Kernel uses v0..v27 = 28 VGPRs, so granules=3 gives headroom.
    uint64 rsrc1 = 0xE0AF0003
    uint64 rsrc2 = 0x0000009E
    uint64 rsrc3 = 0x00000030
    uint64 props = 0x0408

    // 11 kernargs: 8 GLOBAL_BUFFER + 3 BY_VALUE (n, A_minus, w_max).
    uint64[22] args_desc
    uint64 i = 0
    while i < 8 {
        uint64 ap = args_desc + i * 16;      unsafe { *(ap as uint64) = 8 }
        uint64 ak = args_desc + i * 16 + 8;  unsafe { *(ak as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
        i = i + 1
    }
    // by-value args
    uint64 a16 = args_desc + 128; unsafe { *(a16 as uint64) = 8 }
    uint64 a17 = args_desc + 136; unsafe { *(a17 as uint64) = AMD_ARG_KIND_BY_VALUE }   // n
    uint64 a18 = args_desc + 144; unsafe { *(a18 as uint64) = 8 }
    uint64 a19 = args_desc + 152; unsafe { *(a19 as uint64) = AMD_ARG_KIND_BY_VALUE }   // A_minus
    uint64 a20 = args_desc + 160; unsafe { *(a20 as uint64) = 8 }
    uint64 a21 = args_desc + 168; unsafe { *(a21 as uint64) = AMD_ARG_KIND_BY_VALUE }   // w_max

    uint64 size = emit_amdgpu_code_object(kname, klen,
                                           asm_text_buf, asm_text_len,
                                           88,      // kernarg_size (11 × 8)
                                           8,       // kernarg_align
                                           40,      // sgpr_count (s0..s37 + pad)
                                           28,      // vgpr_count (v0..v27)
                                           rsrc1, rsrc2, rsrc3, props,
                                           args_desc, 11)

    uint64 fd = file_open(out_path, 1)
    if fd > 0xFFFFFFFFFFFFF000 {
        write(2, "emit_amdgpu_csr_e_deliver_blob: cannot open output\n", 51)
        return 1
    }
    file_write(fd, amd_buf, size)
    file_close(fd)
    return 0
}

// ---------------------------------------------------------------------------
// M1t (first sub-milestone) lif_integrate: the core LIF neuron
// update — refractory decrement OR membrane integration. Single-
// thread, one neuron. Full lif_full (spike detection + STP + ring
// buffer writes) stays deferred; this demo proves the f64 math chain
// and the nested conditional path.
//
// Semantics (for neuron i=0, single-thread):
//   if ref[0] > 0:
//       ref[0] -= 1
//       V[0]  = V_reset
//   else:
//       drive  = RI[0] + s_exc[0] * J_E - s_inh[0] * J_I
//       dv     = dt_over_tau * (V_rest - V[0] + drive)
//       V[0]  += dv
//
// Kernargs (80 bytes, 10 × 8):
//   [0..7]   V_ptr          (f64*)
//   [8..15]  ref_ptr        (u64*)
//   [16..23] RI_ptr         (f64*)
//   [24..31] s_exc_ptr      (f64*)
//   [32..39] s_inh_ptr      (f64*)
//   [40..47] dt_over_tau    (f64 by-value, precomputed = dt / tau_m)
//   [48..55] V_rest         (f64 by-value)
//   [56..63] J_E            (f64 by-value)
//   [64..71] J_I            (f64 by-value)
//   [72..79] V_reset        (f64 by-value)
@export
fn emit_amdgpu_lif_integrate_blob(uint64 out_path) -> uint64 {
    uint64 kname = "lif_integrate"
    uint64 klen  = 13

    asm_init()

    // --- Prologue: 5 pointers + 5 f64 by-value kernargs ---
    asm_s_load_b64(1, 0)                            // s[2:3]   = V_ptr
    asm_s_load_b64_off(2, 0, 0x08)                  // s[4:5]   = ref_ptr
    asm_s_load_b64_off(3, 0, 0x10)                  // s[6:7]   = RI_ptr
    asm_s_load_b64_off(4, 0, 0x18)                  // s[8:9]   = s_exc_ptr
    asm_s_load_b64_off(5, 0, 0x20)                  // s[10:11] = s_inh_ptr
    asm_s_load_b64_off(6, 0, 0x28)                  // s[12:13] = dt_over_tau bits
    asm_s_load_b64_off(7, 0, 0x30)                  // s[14:15] = V_rest bits
    asm_s_load_b64_off(8, 0, 0x38)                  // s[16:17] = J_E bits
    asm_s_load_b64_off(9, 0, 0x40)                  // s[18:19] = J_I bits
    asm_s_load_b64_off(10, 0, 0x48)                 // s[20:21] = V_reset bits
    asm_s_waitcnt_lgkmcnt_zero()

    // --- Load ref[0] via SMEM (deref ref_ptr = s[4:5]) ---
    asm_s_load_b64_off(11, 2, 0x00)                 // s[22:23] = ref[0] (sbase=2 = s[4:5])
    asm_s_waitcnt_lgkmcnt_zero()

    // Guard: if ref[0] == 0 → integrate (scc=1 → fall through)
    //                   > 0 → refractory (scc=0 → branch).
    asm_s_cmp_eq_u32(22, 0x80)                      // scc = (s22 == 0)
    uint64 integrate_else_off = asm_text_len / 4
    asm_s_cbranch_scc0(0)                           // placeholder → refractory_body

    // --- Integrate path ---
    asm_v_mov_b32_inline_u(8, 0)                    // v8 = 0 (v_addr for saddr loads)

    // VMEM loads:
    //   v[0:1] = V[0]        (saddr = s[2:3], raw SGPR 2)
    //   v[2:3] = RI[0]       (saddr = s[6:7], raw SGPR 6)
    //   v[4:5] = s_exc[0]    (saddr = s[8:9], raw SGPR 8)
    //   v[6:7] = s_inh[0]    (saddr = s[10:11], raw SGPR 10)
    asm_u32(0xDC560000)                             // global_load_b64 v[0:1], v8, s[2:3]
    asm_u32(0x00020008)
    asm_u32(0xDC560000)                             // global_load_b64 v[2:3], v8, s[6:7]
    asm_u32(0x02060008)
    asm_u32(0xDC560000)                             // global_load_b64 v[4:5], v8, s[8:9]
    asm_u32(0x04080008)
    asm_u32(0xDC560000)                             // global_load_b64 v[6:7], v8, s[10:11]
    asm_u32(0x060A0008)
    asm_s_waitcnt_vmcnt_zero()

    // Move f64 kernargs into VGPR pairs.
    asm_v_mov_b32(10, 12)                           // v10 = s12 (dt_over_tau lo)
    asm_v_mov_b32(11, 13)                           // v11 = s13
    asm_v_mov_b32(12, 14)                           // v12 = s14 (V_rest lo)
    asm_v_mov_b32(13, 15)                           // v13 = s15
    asm_v_mov_b32(14, 16)                           // v14 = s16 (J_E lo)
    asm_v_mov_b32(15, 17)                           // v15 = s17
    asm_v_mov_b32(16, 18)                           // v16 = s18 (J_I lo)
    asm_v_mov_b32(17, 19)                           // v17 = s19
    asm_s_delay_alu(0x04)                           // settle 4 VALU back

    // Arithmetic chain (re-using VGPRs per notes above):
    //   v[4:5] = s_exc * J_E
    //   v[6:7] = s_inh * J_I
    //   v[2:3] = RI + s_exc*J_E
    //   v[2:3] = v[2:3] - s_inh*J_I        (= drive)
    //   v[4:5] = V_rest - V
    //   v[2:3] = v[4:5] + v[2:3]           (= V_rest - V + drive)
    //   v[4:5] = dt_over_tau * v[2:3]      (= dv)
    //   v[0:1] = V + dv                    (= v_new)
    asm_v_mul_f64_vv(4, 4, 14)                      // v[4:5] = s_exc * J_E
    asm_v_mul_f64_vv(6, 6, 16)                      // v[6:7] = s_inh * J_I
    asm_s_delay_alu(0x02)
    asm_v_add_f64_vv(2, 2, 4)                       // v[2:3] = RI + s_exc*J_E
    asm_s_delay_alu(0x01)
    asm_v_sub_f64_vv(2, 2, 6)                       // v[2:3] = v[2:3] - s_inh*J_I (drive)
    asm_v_sub_f64_vv(4, 12, 0)                      // v[4:5] = V_rest - V
    asm_s_delay_alu(0x02)
    asm_v_add_f64_vv(2, 4, 2)                       // v[2:3] = V_rest - V + drive
    asm_s_delay_alu(0x01)
    asm_v_mul_f64_vv(4, 10, 2)                      // v[4:5] = dt_over_tau * v[2:3] (dv)
    asm_s_delay_alu(0x01)
    asm_v_add_f64_vv(0, 0, 4)                       // v[0:1] = V + dv (v_new)
    asm_s_delay_alu(0x01)

    // Store v[0:1] = v_new to V[0].
    asm_u32(0xDC6E0000)                             // global_store_b64 v8, v[0:1], s[2:3]
    asm_u32(0x00020008)
    asm_s_waitcnt_vscnt_zero()

    // Branch to end.
    uint64 skip_refr_off = asm_text_len / 4
    asm_s_branch(0)                                 // placeholder → end

    // --- Refractory path: patch above scc0 to land here ---
    uint64 refr_off = asm_text_len / 4
    uint64 ie_skip = refr_off - (integrate_else_off + 1)
    uint64 pb_ie = asm_text_buf + integrate_else_off * 4
    uint32 w_ie = 0xBFA10000 | (ie_skip & 0xFFFF)
    unsafe { *(pb_ie as uint32) = w_ie }

    // refractory body:
    //   s22 = s22 - 1       (ref_new)
    //   *ref[0] = s[22:23]
    //   *V[0]   = V_reset (s[20:21])
    asm_u32(0x80968116)                             // s_sub_u32 s22, s22, 1
    asm_v_mov_b32_inline_u(8, 0)                    // v8 = 0
    asm_v_mov_b32(18, 22)                           // v18 = s22 (ref_new lo)
    asm_v_mov_b32(19, 23)                           // v19 = s23
    asm_s_delay_alu(0x02)
    asm_u32(0xDC6E0000)                             // global_store_b64 v8, v[18:19], s[4:5]
    asm_u32(0x00041208)                             // saddr=4, vdata=18, v_addr=8
    asm_s_waitcnt_vscnt_zero()

    // *V[0] = V_reset.
    asm_v_mov_b32(18, 20)                           // v18 = s20 (V_reset lo)
    asm_v_mov_b32(19, 21)                           // v19 = s21
    asm_s_delay_alu(0x02)
    asm_u32(0xDC6E0000)                             // global_store_b64 v8, v[18:19], s[2:3]
    asm_u32(0x00021208)                             // saddr=2, vdata=18, v_addr=8
    asm_s_waitcnt_vscnt_zero()

    // --- end: patch the integrate skip-to-end ---
    uint64 end_off = asm_text_len / 4
    uint64 end_skip = end_off - (skip_refr_off + 1)
    uint64 pb_se = asm_text_buf + skip_refr_off * 4
    uint32 w_se = 0xBFA00000 | (end_skip & 0xFFFF)  // SOPP op 0x20 = s_branch
    unsafe { *(pb_se as uint32) = w_se }

    asm_s_endpgm()

    uint64 rsrc1 = 0xE0AF0003                       // VGPR granules=3 (32 VGPRs)
    uint64 rsrc2 = 0x0000009E
    uint64 rsrc3 = 0x00000030
    uint64 props = 0x0408

    // 10 kernargs: 5 GLOBAL_BUFFER + 5 BY_VALUE.
    uint64[20] args_desc
    uint64 ai = 0
    while ai < 5 {
        uint64 p0 = args_desc + ai * 16;      unsafe { *(p0 as uint64) = 8 }
        uint64 p1 = args_desc + ai * 16 + 8;  unsafe { *(p1 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
        ai = ai + 1
    }
    while ai < 10 {
        uint64 p0 = args_desc + ai * 16;      unsafe { *(p0 as uint64) = 8 }
        uint64 p1 = args_desc + ai * 16 + 8;  unsafe { *(p1 as uint64) = AMD_ARG_KIND_BY_VALUE }
        ai = ai + 1
    }

    uint64 size = emit_amdgpu_code_object(kname, klen,
                                           asm_text_buf, asm_text_len,
                                           80,      // kernarg_size (10 × 8)
                                           8,       // kernarg_align
                                           24,      // sgpr_count (s0..s23)
                                           24,      // vgpr_count (v0..v23)
                                           rsrc1, rsrc2, rsrc3, props,
                                           args_desc, 10)

    uint64 fd = file_open(out_path, 1)
    if fd > 0xFFFFFFFFFFFFF000 {
        write(2, "emit_amdgpu_lif_integrate_blob: cannot open output\n", 51)
        return 1
    }
    file_write(fd, amd_buf, size)
    file_close(fd)
    return 0
}

// ---------------------------------------------------------------------------
// M1t-2 lif_spike: LIF integrate + spike detection. Extends M1t-1
// with a threshold compare: if v_new >= V_thresh the neuron fires —
// V resets, ref becomes ref_steps, spike counter increments.
// Otherwise V just absorbs v_new.
//
// Kernargs (13 args, 104 bytes):
//   [0..7]   V_ptr        (f64*)
//   [8..15]  ref_ptr      (u64*)
//   [16..23] RI_ptr       (f64*)
//   [24..31] s_exc_ptr    (f64*)
//   [32..39] s_inh_ptr    (f64*)
//   [40..47] spike_ptr    (u64*)    — NEW
//   [48..55] dt_over_tau  (f64)
//   [56..63] V_rest       (f64)
//   [64..71] J_E          (f64)
//   [72..79] J_I          (f64)
//   [80..87] V_reset      (f64)
//   [88..95] V_thresh     (f64)     — NEW
//   [96..103] ref_steps   (u64)     — NEW
@export
fn emit_amdgpu_lif_spike_blob(uint64 out_path) -> uint64 {
    uint64 kname = "lif_spike"
    uint64 klen  = 9

    asm_init()

    // --- Prologue: 6 pointers + 7 by-value kernargs ---
    asm_s_load_b64(1, 0)                            // s[2:3]   V_ptr
    asm_s_load_b64_off(2, 0, 0x08)                  // s[4:5]   ref_ptr
    asm_s_load_b64_off(3, 0, 0x10)                  // s[6:7]   RI_ptr
    asm_s_load_b64_off(4, 0, 0x18)                  // s[8:9]   s_exc_ptr
    asm_s_load_b64_off(5, 0, 0x20)                  // s[10:11] s_inh_ptr
    asm_s_load_b64_off(6, 0, 0x28)                  // s[12:13] spike_ptr
    asm_s_load_b64_off(7, 0, 0x30)                  // s[14:15] dt_over_tau
    asm_s_load_b64_off(8, 0, 0x38)                  // s[16:17] V_rest
    asm_s_load_b64_off(9, 0, 0x40)                  // s[18:19] J_E
    asm_s_load_b64_off(10, 0, 0x48)                 // s[20:21] J_I
    asm_s_load_b64_off(11, 0, 0x50)                 // s[22:23] V_reset
    asm_s_load_b64_off(12, 0, 0x58)                 // s[24:25] V_thresh
    asm_s_load_b64_off(13, 0, 0x60)                 // s[26:27] ref_steps
    asm_s_waitcnt_lgkmcnt_zero()

    // Load ref[0] (SMEM deref of s[4:5]).
    asm_s_load_b64_off(14, 2, 0x00)                 // s[28:29] = ref[0]
    // Load spike[0] (SMEM deref of s[12:13]).
    asm_s_load_b64_off(15, 6, 0x00)                 // s[30:31] = spike[0] (sbase=6 = s[12:13])
    asm_s_waitcnt_lgkmcnt_zero()

    // Guard: ref[0] == 0 → integrate; > 0 → refractory.
    asm_s_cmp_eq_u32(28, 0x80)
    uint64 integrate_else_off = asm_text_len / 4
    asm_s_cbranch_scc0(0)                           // placeholder → refractory

    // ---- Integrate path ----
    asm_v_mov_b32_inline_u(8, 0)                    // v8 = 0

    // VMEM loads via saddr-only (raw SGPR index for saddr).
    asm_u32(0xDC560000)                             // global_load_b64 v[0:1], v8, s[2:3]
    asm_u32(0x00020008)
    asm_u32(0xDC560000)                             // global_load_b64 v[2:3], v8, s[6:7]
    asm_u32(0x02060008)
    asm_u32(0xDC560000)                             // global_load_b64 v[4:5], v8, s[8:9]
    asm_u32(0x04080008)
    asm_u32(0xDC560000)                             // global_load_b64 v[6:7], v8, s[10:11]
    asm_u32(0x060A0008)
    asm_s_waitcnt_vmcnt_zero()

    // Move f64 kernarg SGPRs to VGPR pairs for arithmetic.
    asm_v_mov_b32(10, 14)                           // v10 = s14 (dt_over_tau lo)
    asm_v_mov_b32(11, 15)
    asm_v_mov_b32(12, 16)                           // v12 = s16 (V_rest lo)
    asm_v_mov_b32(13, 17)
    asm_v_mov_b32(14, 18)                           // v14 = s18 (J_E lo)
    asm_v_mov_b32(15, 19)
    asm_v_mov_b32(16, 20)                           // v16 = s20 (J_I lo)
    asm_v_mov_b32(17, 21)
    asm_v_mov_b32(20, 24)                           // v20 = s24 (V_thresh lo)
    asm_v_mov_b32(21, 25)
    asm_s_delay_alu(0x04)

    // Arithmetic chain (same as M1t-1): v_new → v[0:1].
    asm_v_mul_f64_vv(4, 4, 14)                      // v[4:5] = s_exc * J_E
    asm_v_mul_f64_vv(6, 6, 16)                      // v[6:7] = s_inh * J_I
    asm_s_delay_alu(0x02)
    asm_v_add_f64_vv(2, 2, 4)                       // v[2:3] = RI + s_exc*J_E
    asm_s_delay_alu(0x01)
    asm_v_sub_f64_vv(2, 2, 6)                       // v[2:3] = drive
    asm_v_sub_f64_vv(4, 12, 0)                      // v[4:5] = V_rest - V
    asm_s_delay_alu(0x02)
    asm_v_add_f64_vv(2, 4, 2)                       // v[2:3] = V_rest - V + drive
    asm_s_delay_alu(0x01)
    asm_v_mul_f64_vv(4, 10, 2)                      // v[4:5] = dv
    asm_s_delay_alu(0x01)
    asm_v_add_f64_vv(0, 0, 4)                       // v[0:1] = v_new
    asm_s_delay_alu(0x01)

    // Spike detect: vcc = (v_new >= V_thresh).
    asm_v_cmp_ge_f64_vv(0, 20)
    uint64 spike_patch_off = asm_text_len / 4
    asm_s_cbranch_vccnz(0)                          // placeholder → spike body

    // No-spike: V[0] = v_new.
    asm_u32(0xDC6E0000)                             // global_store_b64 v8, v[0:1], s[2:3]
    asm_u32(0x00020008)
    asm_s_waitcnt_vscnt_zero()
    uint64 after_no_spike_off = asm_text_len / 4
    asm_s_branch(0)                                 // placeholder → end

    // ---- Spike body ----
    uint64 spike_off = asm_text_len / 4
    // Patch spike cbranch forward.
    uint64 sp_skip = spike_off - (spike_patch_off + 1)
    uint64 pb_sp = asm_text_buf + spike_patch_off * 4
    uint32 w_sp = 0xBFA40000 | (sp_skip & 0xFFFF)   // SOPP op 0x24 = s_cbranch_vccnz
    unsafe { *(pb_sp as uint32) = w_sp }

    // V = V_reset (move s[22:23] to v[18:19], store via s[2:3]).
    asm_v_mov_b32(18, 22)                           // v18 = s22 (V_reset lo)
    asm_v_mov_b32(19, 23)
    asm_s_delay_alu(0x02)
    asm_u32(0xDC6E0000)                             // global_store_b64 v8, v[18:19], s[2:3]
    asm_u32(0x00021208)
    asm_s_waitcnt_vscnt_zero()

    // ref = ref_steps (move s[26:27] to v[18:19], store via s[4:5]).
    asm_v_mov_b32(18, 26)                           // v18 = s26 (ref_steps lo)
    asm_v_mov_b32(19, 27)
    asm_s_delay_alu(0x02)
    asm_u32(0xDC6E0000)                             // global_store_b64 v8, v[18:19], s[4:5]
    asm_u32(0x00041208)
    asm_s_waitcnt_vscnt_zero()

    // spike[0] += 1 (scalar: s[30:31] + 1 with carry, then store via s[12:13]).
    asm_u32(0x801E811E)                             // s_add_u32 s30, s30, 1 (inline 1 = 0x81)
    asm_u32(0x821F801F)                             // s_addc_u32 s31, s31, 0
    asm_v_mov_b32(18, 30)                           // v18 = s30 (new spike lo)
    asm_v_mov_b32(19, 31)
    asm_s_delay_alu(0x02)
    asm_u32(0xDC6E0000)                             // global_store_b64 v8, v[18:19], s[12:13]
    asm_u32(0x000C1208)                             // saddr=12, vdata=18, v_addr=8
    asm_s_waitcnt_vscnt_zero()

    // Branch to end.
    uint64 after_spike_off = asm_text_len / 4
    asm_s_branch(0)                                 // placeholder → end

    // ---- Refractory body ----
    uint64 refr_off = asm_text_len / 4
    uint64 ie_skip = refr_off - (integrate_else_off + 1)
    uint64 pb_ie = asm_text_buf + integrate_else_off * 4
    uint32 w_ie = 0xBFA10000 | (ie_skip & 0xFFFF)
    unsafe { *(pb_ie as uint32) = w_ie }

    asm_u32(0x809C811C)                             // s_sub_u32 s28, s28, 1
    asm_v_mov_b32_inline_u(8, 0)
    asm_v_mov_b32(18, 28)                           // v18 = s28 (ref_new lo)
    asm_v_mov_b32(19, 29)
    asm_s_delay_alu(0x02)
    asm_u32(0xDC6E0000)                             // global_store_b64 v8, v[18:19], s[4:5]
    asm_u32(0x00041208)
    asm_s_waitcnt_vscnt_zero()

    // V = V_reset.
    asm_v_mov_b32(18, 22)                           // v18 = s22 (V_reset lo)
    asm_v_mov_b32(19, 23)
    asm_s_delay_alu(0x02)
    asm_u32(0xDC6E0000)                             // global_store_b64 v8, v[18:19], s[2:3]
    asm_u32(0x00021208)
    asm_s_waitcnt_vscnt_zero()

    // ---- end: patch the two forward branches ----
    uint64 end_off = asm_text_len / 4

    uint64 ns_skip = end_off - (after_no_spike_off + 1)
    uint64 pb_ns = asm_text_buf + after_no_spike_off * 4
    uint32 w_ns = 0xBFA00000 | (ns_skip & 0xFFFF)   // s_branch
    unsafe { *(pb_ns as uint32) = w_ns }

    uint64 as_skip = end_off - (after_spike_off + 1)
    uint64 pb_as = asm_text_buf + after_spike_off * 4
    uint32 w_as = 0xBFA00000 | (as_skip & 0xFFFF)
    unsafe { *(pb_as as uint32) = w_as }

    asm_s_endpgm()

    uint64 rsrc1 = 0xE0AF0003
    uint64 rsrc2 = 0x0000009E
    uint64 rsrc3 = 0x00000030
    uint64 props = 0x0408

    // 13 kernargs: 6 GLOBAL_BUFFER + 7 BY_VALUE.
    uint64[26] args_desc
    uint64 ai = 0
    while ai < 6 {
        uint64 p0 = args_desc + ai * 16;      unsafe { *(p0 as uint64) = 8 }
        uint64 p1 = args_desc + ai * 16 + 8;  unsafe { *(p1 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
        ai = ai + 1
    }
    while ai < 13 {
        uint64 p0 = args_desc + ai * 16;      unsafe { *(p0 as uint64) = 8 }
        uint64 p1 = args_desc + ai * 16 + 8;  unsafe { *(p1 as uint64) = AMD_ARG_KIND_BY_VALUE }
        ai = ai + 1
    }

    uint64 size = emit_amdgpu_code_object(kname, klen,
                                           asm_text_buf, asm_text_len,
                                           104,     // kernarg_size (13 × 8)
                                           8,       // kernarg_align
                                           32,      // sgpr_count (s0..s31)
                                           24,      // vgpr_count (v0..v23)
                                           rsrc1, rsrc2, rsrc3, props,
                                           args_desc, 13)

    uint64 fd = file_open(out_path, 1)
    if fd > 0xFFFFFFFFFFFFF000 {
        write(2, "emit_amdgpu_lif_spike_blob: cannot open output\n", 47)
        return 1
    }
    file_write(fd, amd_buf, size)
    file_close(fd)
    return 0
}

// ---------------------------------------------------------------------------
// M1t-3 lif_stp: lif_spike + post-spike trace bumps (x_pre += 1.0,
// x_post += 1.0) + STP update:
//     rel       = u_stp * x_stp
//     release  := rel
//     x_stp    := x_stp - rel
//     u_stp    := u_stp + U_baseline * (1.0 - u_stp)
//
// Kernargs (19 args, 152 bytes). Appends x_pre_ptr, x_post_ptr,
// u_stp_ptr, x_stp_ptr, release_ptr, U_baseline to M1t-2's layout.
@export
fn emit_amdgpu_lif_stp_blob(uint64 out_path) -> uint64 {
    uint64 kname = "lif_stp"
    uint64 klen  = 7

    asm_init()

    // --- Prologue: load all 19 kernargs ---
    asm_s_load_b64(1, 0)                            // s[2:3]   V_ptr
    asm_s_load_b64_off(2, 0, 0x08)                  // s[4:5]   ref_ptr
    asm_s_load_b64_off(3, 0, 0x10)                  // s[6:7]   RI_ptr
    asm_s_load_b64_off(4, 0, 0x18)                  // s[8:9]   s_exc_ptr
    asm_s_load_b64_off(5, 0, 0x20)                  // s[10:11] s_inh_ptr
    asm_s_load_b64_off(6, 0, 0x28)                  // s[12:13] spike_ptr
    asm_s_load_b64_off(7, 0, 0x30)                  // s[14:15] x_pre_ptr
    asm_s_load_b64_off(8, 0, 0x38)                  // s[16:17] x_post_ptr
    asm_s_load_b64_off(9, 0, 0x40)                  // s[18:19] u_stp_ptr
    asm_s_load_b64_off(10, 0, 0x48)                 // s[20:21] x_stp_ptr
    asm_s_load_b64_off(11, 0, 0x50)                 // s[22:23] release_ptr
    asm_s_load_b64_off(12, 0, 0x58)                 // s[24:25] dt_over_tau
    asm_s_load_b64_off(13, 0, 0x60)                 // s[26:27] V_rest
    asm_s_load_b64_off(14, 0, 0x68)                 // s[28:29] J_E
    asm_s_load_b64_off(15, 0, 0x70)                 // s[30:31] J_I
    asm_s_load_b64_off(16, 0, 0x78)                 // s[32:33] V_reset
    asm_s_load_b64_off(17, 0, 0x80)                 // s[34:35] V_thresh
    asm_s_load_b64_off(18, 0, 0x88)                 // s[36:37] ref_steps
    asm_s_load_b64_off(19, 0, 0x90)                 // s[38:39] U_baseline
    asm_s_waitcnt_lgkmcnt_zero()

    // Load ref[0] (deref ref_ptr, sbase=2).
    asm_s_load_b64_off(20, 2, 0x00)                 // s[40:41] = ref[0]
    // Load spike[0] (deref spike_ptr, sbase=6).
    asm_s_load_b64_off(21, 6, 0x00)                 // s[42:43] = spike[0]
    asm_s_waitcnt_lgkmcnt_zero()

    // Guard: ref[0] == 0 → integrate; > 0 → refractory.
    asm_s_cmp_eq_u32(40, 0x80)
    uint64 integrate_else_off = asm_text_len / 4
    asm_s_cbranch_scc0(0)                           // placeholder → refractory

    // ---- Integrate path ----
    asm_v_mov_b32_inline_u(8, 0)                    // v8 = 0

    // VMEM loads
    asm_u32(0xDC560000)                             // global_load_b64 v[0:1], v8, s[2:3]
    asm_u32(0x00020008)
    asm_u32(0xDC560000)                             // global_load_b64 v[2:3], v8, s[6:7]
    asm_u32(0x02060008)
    asm_u32(0xDC560000)                             // global_load_b64 v[4:5], v8, s[8:9]
    asm_u32(0x04080008)
    asm_u32(0xDC560000)                             // global_load_b64 v[6:7], v8, s[10:11]
    asm_u32(0x060A0008)
    asm_s_waitcnt_vmcnt_zero()

    // Move f64 kernargs to VGPR pairs.
    asm_v_mov_b32(10, 24)                           // v10 = s24 (dt_over_tau lo)
    asm_v_mov_b32(11, 25)
    asm_v_mov_b32(12, 26)                           // v12 = s26 (V_rest lo)
    asm_v_mov_b32(13, 27)
    asm_v_mov_b32(14, 28)                           // v14 = s28 (J_E lo)
    asm_v_mov_b32(15, 29)
    asm_v_mov_b32(16, 30)                           // v16 = s30 (J_I lo)
    asm_v_mov_b32(17, 31)
    asm_v_mov_b32(20, 34)                           // v20 = s34 (V_thresh lo)
    asm_v_mov_b32(21, 35)
    asm_v_mov_b32(30, 38)                           // v30 = s38 (U_baseline lo)
    asm_v_mov_b32(31, 39)
    asm_s_delay_alu(0x04)

    // v_new arithmetic chain (same pattern as M1t-1/2).
    asm_v_mul_f64_vv(4, 4, 14)                      // v[4:5] = s_exc * J_E
    asm_v_mul_f64_vv(6, 6, 16)                      // v[6:7] = s_inh * J_I
    asm_s_delay_alu(0x02)
    asm_v_add_f64_vv(2, 2, 4)                       // v[2:3] = RI + s_exc*J_E
    asm_s_delay_alu(0x01)
    asm_v_sub_f64_vv(2, 2, 6)                       // v[2:3] = drive
    asm_v_sub_f64_vv(4, 12, 0)                      // v[4:5] = V_rest - V
    asm_s_delay_alu(0x02)
    asm_v_add_f64_vv(2, 4, 2)                       // v[2:3] = V_rest - V + drive
    asm_s_delay_alu(0x01)
    asm_v_mul_f64_vv(4, 10, 2)                      // v[4:5] = dv
    asm_s_delay_alu(0x01)
    asm_v_add_f64_vv(0, 0, 4)                       // v[0:1] = v_new
    asm_s_delay_alu(0x01)

    // Spike detect.
    asm_v_cmp_ge_f64_vv(0, 20)
    uint64 spike_patch_off = asm_text_len / 4
    asm_s_cbranch_vccnz(0)                          // placeholder → spike body

    // --- No-spike: store v_new to V[0] ---
    asm_u32(0xDC6E0000)                             // global_store_b64 v8, v[0:1], s[2:3]
    asm_u32(0x00020008)
    asm_s_waitcnt_vscnt_zero()
    uint64 after_no_spike_off = asm_text_len / 4
    asm_s_branch(0)                                 // → end

    // ---- Spike body ----
    uint64 spike_off = asm_text_len / 4
    uint64 sp_skip = spike_off - (spike_patch_off + 1)
    uint64 pb_sp = asm_text_buf + spike_patch_off * 4
    uint32 w_sp = 0xBFA40000 | (sp_skip & 0xFFFF)
    unsafe { *(pb_sp as uint32) = w_sp }

    // V = V_reset (s[32:33] → v[18:19], store via s[2:3]).
    asm_v_mov_b32(18, 32)
    asm_v_mov_b32(19, 33)
    asm_s_delay_alu(0x02)
    asm_u32(0xDC6E0000)                             // global_store_b64 v8, v[18:19], s[2:3]
    asm_u32(0x00021208)
    asm_s_waitcnt_vscnt_zero()

    // ref = ref_steps (s[36:37] → v[18:19], store via s[4:5]).
    asm_v_mov_b32(18, 36)
    asm_v_mov_b32(19, 37)
    asm_s_delay_alu(0x02)
    asm_u32(0xDC6E0000)                             // global_store_b64 v8, v[18:19], s[4:5]
    asm_u32(0x00041208)
    asm_s_waitcnt_vscnt_zero()

    // spike[0] += 1.
    asm_u32(0x802A812A)                             // s_add_u32 s42, s42, 1
    asm_u32(0x822B802B)                             // s_addc_u32 s43, s43, 0
    asm_v_mov_b32(18, 42)
    asm_v_mov_b32(19, 43)
    asm_s_delay_alu(0x02)
    asm_u32(0xDC6E0000)                             // global_store_b64 v8, v[18:19], s[12:13]
    asm_u32(0x000C1208)
    asm_s_waitcnt_vscnt_zero()

    // x_pre[0] += 1.0.
    asm_u32(0xDC560000)                             // global_load_b64 v[22:23], v8, s[14:15]
    asm_u32(0x160E0008)
    asm_s_waitcnt_vmcnt_zero()
    asm_u32(0xD7270016)                             // v_add_f64 v[22:23], v[22:23], 1.0 (src1=0xF2)
    asm_u32(0x0001E516)
    asm_s_delay_alu(0x01)
    asm_u32(0xDC6E0000)                             // global_store_b64 v8, v[22:23], s[14:15]
    asm_u32(0x000E1608)
    asm_s_waitcnt_vscnt_zero()

    // x_post[0] += 1.0.
    asm_u32(0xDC560000)                             // global_load_b64 v[22:23], v8, s[16:17]
    asm_u32(0x16100008)
    asm_s_waitcnt_vmcnt_zero()
    asm_u32(0xD7270016)                             // v_add_f64 v[22:23], v[22:23], 1.0
    asm_u32(0x0001E516)
    asm_s_delay_alu(0x01)
    asm_u32(0xDC6E0000)                             // global_store_b64 v8, v[22:23], s[16:17]
    asm_u32(0x00101608)
    asm_s_waitcnt_vscnt_zero()

    // STP: load u_stp[0] → v[24:25], x_stp[0] → v[26:27].
    asm_u32(0xDC560000)                             // global_load_b64 v[24:25], v8, s[18:19]
    asm_u32(0x18120008)
    asm_u32(0xDC560000)                             // global_load_b64 v[26:27], v8, s[20:21]
    asm_u32(0x1A140008)
    asm_s_waitcnt_vmcnt_zero()

    // rel = u * x → v[28:29].
    asm_v_mul_f64_vv(28, 24, 26)
    asm_s_delay_alu(0x01)

    // release[0] = rel (store v[28:29] to s[22:23]).
    asm_u32(0xDC6E0000)                             // global_store_b64 v8, v[28:29], s[22:23]
    asm_u32(0x00161C08)
    asm_s_waitcnt_vscnt_zero()

    // x_new = x - rel.
    asm_v_sub_f64_vv(26, 26, 28)                    // v[26:27] = v[26:27] - v[28:29]
    asm_s_delay_alu(0x01)
    asm_u32(0xDC6E0000)                             // global_store_b64 v8, v[26:27], s[20:21]
    asm_u32(0x00141A08)
    asm_s_waitcnt_vscnt_zero()

    // u_new = u + U_baseline * (1 - u)
    //   tmp = 1.0 - u
    //   prod = U_baseline * tmp
    //   u_new = u + prod
    asm_u32(0xD727001C)                             // v_add_f64 v[28:29], 1.0, -v[24:25]
    asm_u32(0x400230F2)
    asm_s_delay_alu(0x01)
    asm_v_mul_f64_vv(28, 30, 28)                    // v[28:29] = U_baseline * tmp
    asm_s_delay_alu(0x01)
    asm_v_add_f64_vv(24, 24, 28)                    // v[24:25] = u + prod
    asm_s_delay_alu(0x01)
    asm_u32(0xDC6E0000)                             // global_store_b64 v8, v[24:25], s[18:19]
    asm_u32(0x00121808)
    asm_s_waitcnt_vscnt_zero()

    uint64 after_spike_off = asm_text_len / 4
    asm_s_branch(0)                                 // → end

    // ---- Refractory body ----
    uint64 refr_off = asm_text_len / 4
    uint64 ie_skip = refr_off - (integrate_else_off + 1)
    uint64 pb_ie = asm_text_buf + integrate_else_off * 4
    uint32 w_ie = 0xBFA10000 | (ie_skip & 0xFFFF)
    unsafe { *(pb_ie as uint32) = w_ie }

    asm_u32(0x80A88128)                             // s_sub_u32 s40, s40, 1 (ref--)
    asm_v_mov_b32_inline_u(8, 0)
    asm_v_mov_b32(18, 40)
    asm_v_mov_b32(19, 41)
    asm_s_delay_alu(0x02)
    asm_u32(0xDC6E0000)                             // global_store_b64 v8, v[18:19], s[4:5]
    asm_u32(0x00041208)
    asm_s_waitcnt_vscnt_zero()

    asm_v_mov_b32(18, 32)                           // V_reset lo
    asm_v_mov_b32(19, 33)
    asm_s_delay_alu(0x02)
    asm_u32(0xDC6E0000)                             // global_store_b64 v8, v[18:19], s[2:3]
    asm_u32(0x00021208)
    asm_s_waitcnt_vscnt_zero()

    // ---- end: patch forward branches ----
    uint64 end_off = asm_text_len / 4

    uint64 ns_skip = end_off - (after_no_spike_off + 1)
    uint64 pb_ns = asm_text_buf + after_no_spike_off * 4
    uint32 w_ns = 0xBFA00000 | (ns_skip & 0xFFFF)
    unsafe { *(pb_ns as uint32) = w_ns }

    uint64 as_skip = end_off - (after_spike_off + 1)
    uint64 pb_as = asm_text_buf + after_spike_off * 4
    uint32 w_as = 0xBFA00000 | (as_skip & 0xFFFF)
    unsafe { *(pb_as as uint32) = w_as }

    asm_s_endpgm()

    uint64 rsrc1 = 0xE0AF0004                       // granules=4 → 40 VGPRs
    uint64 rsrc2 = 0x0000009E
    uint64 rsrc3 = 0x00000030
    uint64 props = 0x0408

    // 19 kernargs: 11 GLOBAL_BUFFER + 8 BY_VALUE.
    uint64[38] args_desc
    uint64 ai = 0
    while ai < 11 {
        uint64 p0 = args_desc + ai * 16;      unsafe { *(p0 as uint64) = 8 }
        uint64 p1 = args_desc + ai * 16 + 8;  unsafe { *(p1 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
        ai = ai + 1
    }
    while ai < 19 {
        uint64 p0 = args_desc + ai * 16;      unsafe { *(p0 as uint64) = 8 }
        uint64 p1 = args_desc + ai * 16 + 8;  unsafe { *(p1 as uint64) = AMD_ARG_KIND_BY_VALUE }
        ai = ai + 1
    }

    uint64 size = emit_amdgpu_code_object(kname, klen,
                                           asm_text_buf, asm_text_len,
                                           152,     // kernarg_size
                                           8,       // kernarg_align
                                           48,      // sgpr_count
                                           32,      // vgpr_count
                                           rsrc1, rsrc2, rsrc3, props,
                                           args_desc, 19)

    uint64 fd = file_open(out_path, 1)
    if fd > 0xFFFFFFFFFFFFF000 {
        write(2, "emit_amdgpu_lif_stp_blob: cannot open output\n", 45)
        return 1
    }
    file_write(fd, amd_buf, size)
    file_close(fd)
    return 0
}

// ---------------------------------------------------------------------------
// M1t-4 lif_full (Stage-1 exit kernel): lif_stp + ring-buffer scatter
// for E-cells. After the STP update, if cell_type[i] == 0, the release
// value is stored into buf_delay[w_base + i] — the pending-delivery
// entry for the next-timestep synaptic fan-out. This is the kernel
// the 200k-neuron simulation actually dispatches each step.
//
// Kernargs (22 args, 176 bytes). Appends cell_type_ptr, buf_delay_ptr,
// w_base to M1t-3's layout.
@export
fn emit_amdgpu_lif_full_blob(uint64 out_path) -> uint64 {
    uint64 kname = "lif_full"
    uint64 klen  = 8

    asm_init()

    // --- Prologue: load all 22 kernargs ---
    // 11 pointer kernargs from lif_stp + 2 new pointers + 8 + 1 new by-val.
    asm_s_load_b64(1, 0)                            // s[2:3]   V_ptr
    asm_s_load_b64_off(2, 0, 0x08)                  // s[4:5]   ref_ptr
    asm_s_load_b64_off(3, 0, 0x10)                  // s[6:7]   RI_ptr
    asm_s_load_b64_off(4, 0, 0x18)                  // s[8:9]   s_exc_ptr
    asm_s_load_b64_off(5, 0, 0x20)                  // s[10:11] s_inh_ptr
    asm_s_load_b64_off(6, 0, 0x28)                  // s[12:13] spike_ptr
    asm_s_load_b64_off(7, 0, 0x30)                  // s[14:15] x_pre_ptr
    asm_s_load_b64_off(8, 0, 0x38)                  // s[16:17] x_post_ptr
    asm_s_load_b64_off(9, 0, 0x40)                  // s[18:19] u_stp_ptr
    asm_s_load_b64_off(10, 0, 0x48)                 // s[20:21] x_stp_ptr
    asm_s_load_b64_off(11, 0, 0x50)                 // s[22:23] release_ptr
    asm_s_load_b64_off(12, 0, 0x58)                 // s[24:25] dt_over_tau
    asm_s_load_b64_off(13, 0, 0x60)                 // s[26:27] V_rest
    asm_s_load_b64_off(14, 0, 0x68)                 // s[28:29] J_E
    asm_s_load_b64_off(15, 0, 0x70)                 // s[30:31] J_I
    asm_s_load_b64_off(16, 0, 0x78)                 // s[32:33] V_reset
    asm_s_load_b64_off(17, 0, 0x80)                 // s[34:35] V_thresh
    asm_s_load_b64_off(18, 0, 0x88)                 // s[36:37] ref_steps
    asm_s_load_b64_off(19, 0, 0x90)                 // s[38:39] U_baseline
    asm_s_load_b64_off(22, 0, 0x98)                 // s[44:45] cell_type_ptr (NEW)
    asm_s_load_b64_off(23, 0, 0xA0)                 // s[46:47] buf_delay_ptr (NEW)
    asm_s_load_b64_off(24, 0, 0xA8)                 // s[48:49] w_base (NEW)
    asm_s_waitcnt_lgkmcnt_zero()

    // Load ref[0] and spike[0] into scratch (sbase pair-halved).
    asm_s_load_b64_off(20, 2, 0x00)                 // s[40:41] = ref[0]
    asm_s_load_b64_off(21, 6, 0x00)                 // s[42:43] = spike[0]
    asm_s_waitcnt_lgkmcnt_zero()

    // Guard: ref == 0 → integrate; > 0 → refractory.
    asm_s_cmp_eq_u32(40, 0x80)
    uint64 integrate_else_off = asm_text_len / 4
    asm_s_cbranch_scc0(0)

    // ---- Integrate path ----
    asm_v_mov_b32_inline_u(8, 0)

    // VMEM loads of V, RI, s_exc, s_inh.
    asm_u32(0xDC560000); asm_u32(0x00020008)        // V → v[0:1]
    asm_u32(0xDC560000); asm_u32(0x02060008)        // RI → v[2:3]
    asm_u32(0xDC560000); asm_u32(0x04080008)        // s_exc → v[4:5]
    asm_u32(0xDC560000); asm_u32(0x060A0008)        // s_inh → v[6:7]
    asm_s_waitcnt_vmcnt_zero()

    // Move f64 kernargs to VGPR pairs.
    asm_v_mov_b32(10, 24); asm_v_mov_b32(11, 25)    // v[10:11] = dt_over_tau
    asm_v_mov_b32(12, 26); asm_v_mov_b32(13, 27)    // v[12:13] = V_rest
    asm_v_mov_b32(14, 28); asm_v_mov_b32(15, 29)    // v[14:15] = J_E
    asm_v_mov_b32(16, 30); asm_v_mov_b32(17, 31)    // v[16:17] = J_I
    asm_v_mov_b32(20, 34); asm_v_mov_b32(21, 35)    // v[20:21] = V_thresh
    asm_v_mov_b32(30, 38); asm_v_mov_b32(31, 39)    // v[30:31] = U_baseline
    asm_s_delay_alu(0x04)

    // v_new arithmetic chain.
    asm_v_mul_f64_vv(4, 4, 14)                      // s_exc * J_E
    asm_v_mul_f64_vv(6, 6, 16)                      // s_inh * J_I
    asm_s_delay_alu(0x02)
    asm_v_add_f64_vv(2, 2, 4)                       // RI + s_exc*J_E
    asm_s_delay_alu(0x01)
    asm_v_sub_f64_vv(2, 2, 6)                       // drive
    asm_v_sub_f64_vv(4, 12, 0)                      // V_rest - V
    asm_s_delay_alu(0x02)
    asm_v_add_f64_vv(2, 4, 2)                       // V_rest - V + drive
    asm_s_delay_alu(0x01)
    asm_v_mul_f64_vv(4, 10, 2)                      // dv
    asm_s_delay_alu(0x01)
    asm_v_add_f64_vv(0, 0, 4)                       // v_new
    asm_s_delay_alu(0x01)

    // Spike detect.
    asm_v_cmp_ge_f64_vv(0, 20)
    uint64 spike_patch_off = asm_text_len / 4
    asm_s_cbranch_vccnz(0)

    // No-spike: store v_new to V.
    asm_u32(0xDC6E0000); asm_u32(0x00020008)
    asm_s_waitcnt_vscnt_zero()
    uint64 after_no_spike_off = asm_text_len / 4
    asm_s_branch(0)

    // ---- Spike body ----
    uint64 spike_off = asm_text_len / 4
    uint64 sp_skip = spike_off - (spike_patch_off + 1)
    uint64 pb_sp = asm_text_buf + spike_patch_off * 4
    uint32 w_sp = 0xBFA40000 | (sp_skip & 0xFFFF)
    unsafe { *(pb_sp as uint32) = w_sp }

    // V = V_reset.
    asm_v_mov_b32(18, 32); asm_v_mov_b32(19, 33)
    asm_s_delay_alu(0x02)
    asm_u32(0xDC6E0000); asm_u32(0x00021208)
    asm_s_waitcnt_vscnt_zero()

    // ref = ref_steps.
    asm_v_mov_b32(18, 36); asm_v_mov_b32(19, 37)
    asm_s_delay_alu(0x02)
    asm_u32(0xDC6E0000); asm_u32(0x00041208)
    asm_s_waitcnt_vscnt_zero()

    // spike++.
    asm_u32(0x802A812A)                             // s_add_u32 s42, s42, 1
    asm_u32(0x822B802B)                             // s_addc_u32 s43, s43, 0
    asm_v_mov_b32(18, 42); asm_v_mov_b32(19, 43)
    asm_s_delay_alu(0x02)
    asm_u32(0xDC6E0000); asm_u32(0x000C1208)
    asm_s_waitcnt_vscnt_zero()

    // x_pre += 1.0.
    asm_u32(0xDC560000); asm_u32(0x160E0008)        // load x_pre → v[22:23]
    asm_s_waitcnt_vmcnt_zero()
    asm_u32(0xD7270016); asm_u32(0x0001E516)        // v_add_f64 v[22:23], v[22:23], 1.0
    asm_s_delay_alu(0x01)
    asm_u32(0xDC6E0000); asm_u32(0x000E1608)
    asm_s_waitcnt_vscnt_zero()

    // x_post += 1.0.
    asm_u32(0xDC560000); asm_u32(0x16100008)
    asm_s_waitcnt_vmcnt_zero()
    asm_u32(0xD7270016); asm_u32(0x0001E516)
    asm_s_delay_alu(0x01)
    asm_u32(0xDC6E0000); asm_u32(0x00101608)
    asm_s_waitcnt_vscnt_zero()

    // STP: load u, x; rel = u*x; store release; x_new = x - rel; u_new = u + U*(1-u).
    asm_u32(0xDC560000); asm_u32(0x18120008)        // u → v[24:25]
    asm_u32(0xDC560000); asm_u32(0x1A140008)        // x → v[26:27]
    asm_s_waitcnt_vmcnt_zero()

    asm_v_mul_f64_vv(28, 24, 26)                    // v[28:29] = rel = u*x
    asm_s_delay_alu(0x01)
    asm_u32(0xDC6E0000); asm_u32(0x00161C08)        // release[0] = rel
    asm_s_waitcnt_vscnt_zero()

    asm_v_sub_f64_vv(26, 26, 28)                    // x_new = x - rel
    asm_s_delay_alu(0x01)
    asm_u32(0xDC6E0000); asm_u32(0x00141A08)        // x_stp[0] = x_new
    asm_s_waitcnt_vscnt_zero()

    // u_new = u + U_baseline * (1 - u)
    asm_u32(0xD727001C); asm_u32(0x400230F2)        // v[28:29] = 1.0 - u
    asm_s_delay_alu(0x01)
    asm_v_mul_f64_vv(28, 30, 28)                    // U_base * (1-u)
    asm_s_delay_alu(0x01)
    asm_v_add_f64_vv(24, 24, 28)                    // u_new
    asm_s_delay_alu(0x01)
    asm_u32(0xDC6E0000); asm_u32(0x00121808)        // u_stp[0] = u_new
    asm_s_waitcnt_vscnt_zero()

    // --- Ring buffer: if cell_type[0] == 0, write rel to buf_delay[w_base+0] ---
    // Reload rel into v[28:29] (it was overwritten by u_new intermediate).
    asm_u32(0xDC560000); asm_u32(0x1C160008)        // global_load_b64 v[28:29], v8, s[22:23]  (re-read release[0])
    asm_s_waitcnt_vmcnt_zero()

    // SMEM load cell_type[0] (sbase=22 → s[44:45]).
    asm_u32(0xF4040C96); asm_u32(0xF8000000)        // s_load_b64 s[50:51], s[44:45], null
    asm_s_waitcnt_lgkmcnt_zero()

    asm_u32(0xBF068032)                             // s_cmp_eq_u32 s50, 0
    uint64 ring_patch_off = asm_text_len / 4
    asm_s_cbranch_scc0(0)                           // skip ring if ct != 0

    // scatter addr: buf_delay + w_base*8.
    asm_u32(0x84B48330)                             // s_lshl_b64 s[52:53], s[48:49], 3
    asm_u32(0x8036342E)                             // s_add_u32  s54, s46, s52
    asm_u32(0x8237352F)                             // s_addc_u32 s55, s47, s53

    // Store v[28:29] (rel) at s[54:55].
    asm_u32(0xDC6E0000); asm_u32(0x00361C08)        // global_store_b64 v8, v[28:29], s[54:55]
    asm_s_waitcnt_vscnt_zero()

    // skip_ring patch.
    uint64 skip_ring_off = asm_text_len / 4
    uint64 ring_skip = skip_ring_off - (ring_patch_off + 1)
    uint64 pb_ring = asm_text_buf + ring_patch_off * 4
    uint32 w_ring = 0xBFA10000 | (ring_skip & 0xFFFF)
    unsafe { *(pb_ring as uint32) = w_ring }

    uint64 after_spike_off = asm_text_len / 4
    asm_s_branch(0)

    // ---- Refractory body ----
    uint64 refr_off = asm_text_len / 4
    uint64 ie_skip = refr_off - (integrate_else_off + 1)
    uint64 pb_ie = asm_text_buf + integrate_else_off * 4
    uint32 w_ie = 0xBFA10000 | (ie_skip & 0xFFFF)
    unsafe { *(pb_ie as uint32) = w_ie }

    asm_u32(0x80A88128)                             // s_sub_u32 s40, s40, 1
    asm_v_mov_b32_inline_u(8, 0)
    asm_v_mov_b32(18, 40); asm_v_mov_b32(19, 41)
    asm_s_delay_alu(0x02)
    asm_u32(0xDC6E0000); asm_u32(0x00041208)
    asm_s_waitcnt_vscnt_zero()

    asm_v_mov_b32(18, 32); asm_v_mov_b32(19, 33)
    asm_s_delay_alu(0x02)
    asm_u32(0xDC6E0000); asm_u32(0x00021208)
    asm_s_waitcnt_vscnt_zero()

    // ---- end: patch forward branches ----
    uint64 end_off = asm_text_len / 4

    uint64 ns_skip = end_off - (after_no_spike_off + 1)
    uint64 pb_ns = asm_text_buf + after_no_spike_off * 4
    uint32 w_ns = 0xBFA00000 | (ns_skip & 0xFFFF)
    unsafe { *(pb_ns as uint32) = w_ns }

    uint64 as_skip = end_off - (after_spike_off + 1)
    uint64 pb_as = asm_text_buf + after_spike_off * 4
    uint32 w_as = 0xBFA00000 | (as_skip & 0xFFFF)
    unsafe { *(pb_as as uint32) = w_as }

    asm_s_endpgm()

    uint64 rsrc1 = 0xE0AF0004
    uint64 rsrc2 = 0x0000009E
    uint64 rsrc3 = 0x00000030
    uint64 props = 0x0408

    // 22 kernargs: 13 GLOBAL_BUFFER + 9 BY_VALUE.
    uint64[44] args_desc
    uint64 ai = 0
    while ai < 13 {
        uint64 p0 = args_desc + ai * 16;      unsafe { *(p0 as uint64) = 8 }
        uint64 p1 = args_desc + ai * 16 + 8;  unsafe { *(p1 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
        ai = ai + 1
    }
    while ai < 22 {
        uint64 p0 = args_desc + ai * 16;      unsafe { *(p0 as uint64) = 8 }
        uint64 p1 = args_desc + ai * 16 + 8;  unsafe { *(p1 as uint64) = AMD_ARG_KIND_BY_VALUE }
        ai = ai + 1
    }

    uint64 size = emit_amdgpu_code_object(kname, klen,
                                           asm_text_buf, asm_text_len,
                                           176,     // kernarg_size (22 × 8)
                                           8,       // kernarg_align
                                           56,      // sgpr_count
                                           32,      // vgpr_count
                                           rsrc1, rsrc2, rsrc3, props,
                                           args_desc, 22)

    uint64 fd = file_open(out_path, 1)
    if fd > 0xFFFFFFFFFFFFF000 {
        write(2, "emit_amdgpu_lif_full_blob: cannot open output\n", 46)
        return 1
    }
    file_write(fd, amd_buf, size)
    file_close(fd)
    return 0
}

// ---------------------------------------------------------------------------
// M1u-1 mt_lif_integrate: multi-thread LIF integrate. Each lane
// processes neuron i = tid. The integrate math (v_new = v + dt_over_tau
// * (V_rest - v + drive)) is the same as M1t-1, but now operating on
// VGPR pairs whose values were VMEM-loaded from arrays indexed by tid*8.
// No refractory branch, no spike detect — this is just the arithmetic-
// at-scale smoke test before the full mt_lif_full port.
//
// Launch convention: block_x = N, grid_x = 1. Hardware sets EXEC so
// that only lanes 0..N-1 run, so we skip the explicit tid<n guard.
//
// Kernargs (8 args, 64 bytes):
//   [0..7]   V_ptr
//   [8..15]  RI_ptr
//   [16..23] s_exc_ptr
//   [24..31] s_inh_ptr
//   [32..39] dt_over_tau (f64)
//   [40..47] V_rest      (f64)
//   [48..55] J_E         (f64)
//   [56..63] J_I         (f64)
@export
fn emit_amdgpu_mt_lif_integrate_blob(uint64 out_path) -> uint64 {
    uint64 kname = "mt_lif_integrate"
    uint64 klen  = 16

    asm_init()

    // Kernarg loads.
    asm_s_load_b64(1, 0)                            // s[2:3]   V_ptr
    asm_s_load_b64_off(2, 0, 0x08)                  // s[4:5]   RI_ptr
    asm_s_load_b64_off(3, 0, 0x10)                  // s[6:7]   s_exc_ptr
    asm_s_load_b64_off(4, 0, 0x18)                  // s[8:9]   s_inh_ptr
    asm_s_load_b64_off(5, 0, 0x20)                  // s[10:11] dt_over_tau
    asm_s_load_b64_off(6, 0, 0x28)                  // s[12:13] V_rest
    asm_s_load_b64_off(7, 0, 0x30)                  // s[14:15] J_E
    asm_s_load_b64_off(8, 0, 0x38)                  // s[16:17] J_I
    asm_s_waitcnt_lgkmcnt_zero()

    // Per-lane byte offset: v2 = tid * 8 (v0 already holds tid_x).
    asm_v_lshlrev_b32_imm(2, 3, 0)                  // v2 = v0 << 3
    asm_s_delay_alu(0x01)

    // VMEM loads per-lane (saddr = s[X:X+1], v_addr = v2).
    // Encodings: [word1=0xDC560000, word2=(vdst<<24) | (saddr<<16) | v_addr]
    asm_u32(0xDC560000); asm_u32(0x04020002)        // V    → v[4:5]   (saddr=2)
    asm_u32(0xDC560000); asm_u32(0x06040002)        // RI   → v[6:7]   (saddr=4)
    asm_u32(0xDC560000); asm_u32(0x08060002)        // s_exc→ v[8:9]   (saddr=6)
    asm_u32(0xDC560000); asm_u32(0x0A080002)        // s_inh→ v[10:11] (saddr=8)
    asm_s_waitcnt_vmcnt_zero()

    // Move f64 kernargs SGPR→VGPR pairs.
    asm_v_mov_b32(12, 10); asm_v_mov_b32(13, 11)    // v[12:13] dt_over_tau
    asm_v_mov_b32(14, 12); asm_v_mov_b32(15, 13)    // v[14:15] V_rest
    asm_v_mov_b32(16, 14); asm_v_mov_b32(17, 15)    // v[16:17] J_E
    asm_v_mov_b32(18, 16); asm_v_mov_b32(19, 17)    // v[18:19] J_I
    asm_s_delay_alu(0x04)

    // Arithmetic chain (same as M1t-1 but with shifted VGPR layout):
    //   v[8:9]  = s_exc * J_E
    //   v[10:11]= s_inh * J_I
    //   v[6:7]  = RI + s_exc*J_E
    //   v[6:7] -= s_inh*J_I           (= drive)
    //   v[8:9]  = V_rest - V
    //   v[6:7]  = v[8:9] + v[6:7]      (= V_rest - V + drive)
    //   v[8:9]  = dt_over_tau * v[6:7] (= dv)
    //   v[4:5]  += dv                  (= v_new)
    asm_v_mul_f64_vv(8, 8, 16)                      // s_exc * J_E
    asm_v_mul_f64_vv(10, 10, 18)                    // s_inh * J_I
    asm_s_delay_alu(0x02)
    asm_v_add_f64_vv(6, 6, 8)                       // RI + s_exc*J_E
    asm_s_delay_alu(0x01)
    asm_v_sub_f64_vv(6, 6, 10)                      // drive
    asm_v_sub_f64_vv(8, 14, 4)                      // V_rest - V
    asm_s_delay_alu(0x02)
    asm_v_add_f64_vv(6, 8, 6)                       // V_rest - V + drive
    asm_s_delay_alu(0x01)
    asm_v_mul_f64_vv(8, 12, 6)                      // dv = dt_over_tau * (...)
    asm_s_delay_alu(0x01)
    asm_v_add_f64_vv(4, 4, 8)                       // v_new = V + dv
    asm_s_delay_alu(0x01)

    // Store v_new to V[tid]  (saddr=s[2:3], v_addr=v2, vdata=v4).
    asm_u32(0xDC6E0000); asm_u32(0x00020402)        // global_store_b64 v2, v[4:5], s[2:3]
    asm_s_waitcnt_vscnt_zero()

    asm_s_endpgm()

    uint64 rsrc1 = 0xE0AF0002                       // VGPR granules=2 → 24 VGPRs (we use v0..v19)
    uint64 rsrc2 = 0x0000009E
    uint64 rsrc3 = 0x00000030
    uint64 props = 0x0408

    // 8 kernargs: 4 GLOBAL_BUFFER + 4 BY_VALUE.
    uint64[16] args_desc
    uint64 ai = 0
    while ai < 4 {
        uint64 p0 = args_desc + ai * 16;      unsafe { *(p0 as uint64) = 8 }
        uint64 p1 = args_desc + ai * 16 + 8;  unsafe { *(p1 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
        ai = ai + 1
    }
    while ai < 8 {
        uint64 p0 = args_desc + ai * 16;      unsafe { *(p0 as uint64) = 8 }
        uint64 p1 = args_desc + ai * 16 + 8;  unsafe { *(p1 as uint64) = AMD_ARG_KIND_BY_VALUE }
        ai = ai + 1
    }

    uint64 size = emit_amdgpu_code_object(kname, klen,
                                           asm_text_buf, asm_text_len,
                                           64,      // kernarg_size
                                           8,       // kernarg_align
                                           20,      // sgpr_count
                                           20,      // vgpr_count
                                           rsrc1, rsrc2, rsrc3, props,
                                           args_desc, 8)

    uint64 fd = file_open(out_path, 1)
    if fd > 0xFFFFFFFFFFFFF000 {
        write(2, "emit_amdgpu_mt_lif_integrate_blob: cannot open output\n", 54)
        return 1
    }
    file_write(fd, amd_buf, size)
    file_close(fd)
    return 0
}

// ---------------------------------------------------------------------------
// M1u-2 mt_lif_full: multi-thread LIF + spike + traces + STP + ring-
// buffer scatter. Each lane processes neuron i = tid. Branches from
// single-thread lif_full (ref==0, V>=Vth, ct==0) become per-lane
// EXEC-mask branches: v_cmp → s_and_saveexec → body → s_xor exec,sN
// → else-body → s_mov exec,sN.
//
// Launch convention: block_x = N, grid_x = 1. Kernargs identical to
// lif_full (22 entries, 176 bytes), but pointer args now reference
// N-entry arrays instead of single slots. Ring buffer `buf_delay`
// is 2D: delay_slots × N, indexed buf_delay[w_base*N + tid].
//
// THIS IS THE SCAFFOLD STAGE. Prologue + state loads + S→V broadcasts
// only; the arithmetic, EXEC-mask branches, and stores land in
// subsequent commits.
@export
fn emit_amdgpu_mt_lif_full_blob(uint64 out_path) -> uint64 {
    uint64 kname = "mt_lif_full"
    uint64 klen  = 11

    asm_init()

    // --- Prologue: load all 22 kernargs (same layout as ST lif_full) ---
    asm_s_load_b64(1, 0)                            // s[2:3]   V_ptr
    asm_s_load_b64_off(2, 0, 0x08)                  // s[4:5]   ref_ptr
    asm_s_load_b64_off(3, 0, 0x10)                  // s[6:7]   RI_ptr
    asm_s_load_b64_off(4, 0, 0x18)                  // s[8:9]   s_exc_ptr
    asm_s_load_b64_off(5, 0, 0x20)                  // s[10:11] s_inh_ptr
    asm_s_load_b64_off(6, 0, 0x28)                  // s[12:13] spike_ptr
    asm_s_load_b64_off(7, 0, 0x30)                  // s[14:15] x_pre_ptr
    asm_s_load_b64_off(8, 0, 0x38)                  // s[16:17] x_post_ptr
    asm_s_load_b64_off(9, 0, 0x40)                  // s[18:19] u_stp_ptr
    asm_s_load_b64_off(10, 0, 0x48)                 // s[20:21] x_stp_ptr
    asm_s_load_b64_off(11, 0, 0x50)                 // s[22:23] release_ptr
    asm_s_load_b64_off(12, 0, 0x58)                 // s[24:25] dt_over_tau
    asm_s_load_b64_off(13, 0, 0x60)                 // s[26:27] V_rest
    asm_s_load_b64_off(14, 0, 0x68)                 // s[28:29] J_E
    asm_s_load_b64_off(15, 0, 0x70)                 // s[30:31] J_I
    asm_s_load_b64_off(16, 0, 0x78)                 // s[32:33] V_reset
    asm_s_load_b64_off(17, 0, 0x80)                 // s[34:35] V_thresh
    asm_s_load_b64_off(18, 0, 0x88)                 // s[36:37] ref_steps
    asm_s_load_b64_off(19, 0, 0x90)                 // s[38:39] U_baseline
    asm_s_load_b64_off(20, 0, 0x98)                 // s[40:41] cell_type_ptr
    asm_s_load_b64_off(21, 0, 0xA0)                 // s[42:43] buf_delay_ptr
    asm_s_load_b64_off(22, 0, 0xA8)                 // s[44:45] w_base
    asm_s_waitcnt_lgkmcnt_zero()

    // Per-lane byte offset: v2 = tid * 8.
    asm_v_lshlrev_b32_imm(2, 3, 0)
    asm_s_delay_alu(0x01)

    // --- Per-lane VMEM loads (saddr = raw SGPR index of pair low half) ---
    // Encoding: [word1=0xDC560000, word2=(vdst<<24) | (saddr<<16) | v_addr]
    asm_u32(0xDC560000); asm_u32(0x04020002)        // V        → v[4:5]   saddr=s2
    asm_u32(0xDC560000); asm_u32(0x0C040002)        // ref      → v[12:13] saddr=s4
    asm_u32(0xDC560000); asm_u32(0x06060002)        // RI       → v[6:7]   saddr=s6
    asm_u32(0xDC560000); asm_u32(0x08080002)        // s_exc    → v[8:9]   saddr=s8
    asm_u32(0xDC560000); asm_u32(0x0A0A0002)        // s_inh    → v[10:11] saddr=s10
    asm_u32(0xDC560000); asm_u32(0x0E0C0002)        // spike    → v[14:15] saddr=s12
    asm_u32(0xDC560000); asm_u32(0x100E0002)        // x_pre    → v[16:17] saddr=s14
    asm_u32(0xDC560000); asm_u32(0x12100002)        // x_post   → v[18:19] saddr=s16
    asm_u32(0xDC560000); asm_u32(0x14120002)        // u_stp    → v[20:21] saddr=s18
    asm_u32(0xDC560000); asm_u32(0x16140002)        // x_stp    → v[22:23] saddr=s20
    asm_u32(0xDC560000); asm_u32(0x18280002)        // cell_type→ v[24:25] saddr=s40
    asm_s_waitcnt_vmcnt_zero()

    // SGPR→VGPR broadcast of all f64 by-value constants.
    asm_v_mov_b32(44, 24); asm_v_mov_b32(45, 25)    // v[44:45] dt_over_tau
    asm_v_mov_b32(32, 26); asm_v_mov_b32(33, 27)    // v[32:33] V_rest
    asm_v_mov_b32(34, 28); asm_v_mov_b32(35, 29)    // v[34:35] J_E
    asm_v_mov_b32(36, 30); asm_v_mov_b32(37, 31)    // v[36:37] J_I
    asm_v_mov_b32(38, 32); asm_v_mov_b32(39, 33)    // v[38:39] V_reset
    asm_v_mov_b32(40, 34); asm_v_mov_b32(41, 35)    // v[40:41] V_thresh
    asm_v_mov_b32(42, 38); asm_v_mov_b32(43, 39)    // v[42:43] U_baseline
    asm_s_delay_alu(0x04)

    // --- Outer branch: if ref == 0 { integrate + spike } else { refractory } ---
    asm_v_cmp_eq_u32_imm_vgpr(0, 12)                // vcc_lo = (v12 == 0)
    asm_s_and_saveexec_b32_vcc_lo(46)               // s46 = outer EXEC, EXEC &= (ref==0)

    // --- Integrate arithmetic: v_new = V + dt_over_tau * (V_rest - V + drive) ---
    // drive    = RI + s_exc*J_E - s_inh*J_I
    // Uses v[26:27], v[28:29], v[30:31] as reusable f64 scratch.
    asm_v_mul_f64_vv(28, 8, 34)                     // v[28:29] = s_exc * J_E
    asm_v_mul_f64_vv(30, 10, 36)                    // v[30:31] = s_inh * J_I
    asm_s_delay_alu(0x02)
    asm_v_add_f64_vv(26, 6, 28)                     // v[26:27] = RI + s_exc*J_E
    asm_s_delay_alu(0x01)
    asm_v_sub_f64_vv(26, 26, 30)                    // v[26:27] = drive
    asm_v_sub_f64_vv(28, 32, 4)                     // v[28:29] = V_rest - V
    asm_s_delay_alu(0x02)
    asm_v_add_f64_vv(26, 28, 26)                    // v[26:27] = V_rest - V + drive
    asm_s_delay_alu(0x01)
    asm_v_mul_f64_vv(28, 44, 26)                    // v[28:29] = dv = dt_over_tau * (...)
    asm_s_delay_alu(0x01)
    asm_v_add_f64_vv(26, 4, 28)                     // v[26:27] = v_new (live for spike branch in Task 4)
    asm_s_delay_alu(0x01)

    // --- Spike branch (per-lane EXEC-mask predication) ---
    // if v_new >= V_thresh { spike_body } else { V = v_new }
    asm_v_cmp_ge_f64_vv(26, 40)                     // vcc_lo = (v_new >= V_thresh) per lane
    asm_s_and_saveexec_b32_vcc_lo(47)               // s47 = outer EXEC, EXEC &= vcc_lo

    // ---- spike-body (EXEC = spiking lanes) ----
    // Store V = V_reset to V_ptr[tid].
    asm_u32(0xDC6E0000); asm_u32(0x00022602)        // global_store_b64 v2, v[38:39], s[2:3]
    asm_s_waitcnt_vscnt_zero()

    // Store ref = ref_steps (low 32 bits) to ref_ptr[tid]. ref_steps
    // arrives via s[36:37]; v[46] gets the low word, v[47] gets 0.
    asm_v_mov_b32(46, 36)
    asm_v_mov_b32_inline_u(47, 0)
    asm_s_delay_alu(0x02)
    asm_u32(0xDC6E0000); asm_u32(0x00042E02)        // global_store_b64 v2, v[46:47], s[4:5]
    asm_s_waitcnt_vscnt_zero()

    // spike++ — increment low 32 bits of v[14:15].
    // v_add_nc_u32_e64 v14, v14, 1  (verified via llvm-mc gfx1100):
    //   encoding bytes [0x0e,0x00,0x25,0xd5,0x0e,0x03,0x01,0x00]
    //   → word1=0xD525000E, word2=0x0001030E (src0=v14, src1=inline 1).
    asm_u32(0xD525000E); asm_u32(0x0001030E)
    asm_s_delay_alu(0x01)
    asm_u32(0xDC6E0000); asm_u32(0x000C0E02)        // global_store_b64 v2, v[14:15], s[12:13]
    asm_s_waitcnt_vscnt_zero()

    // x_pre += 1.0 (VOP3 v_add_f64). Verified via llvm-mc:
    //   v_add_f64 v[16:17], v[16:17], 1.0 → 0xD7270010, 0x0001E510.
    asm_u32(0xD7270010); asm_u32(0x0001E510)
    asm_s_delay_alu(0x01)
    asm_u32(0xDC6E0000); asm_u32(0x000E1002)        // global_store_b64 v2, v[16:17], s[14:15]
    asm_s_waitcnt_vscnt_zero()

    // x_post += 1.0 (same shape, vdst=18). Verified via llvm-mc:
    //   v_add_f64 v[18:19], v[18:19], 1.0 → 0xD7270012, 0x0001E512.
    asm_u32(0xD7270012); asm_u32(0x0001E512)
    asm_s_delay_alu(0x01)
    asm_u32(0xDC6E0000); asm_u32(0x00101202)        // global_store_b64 v2, v[18:19], s[16:17]
    asm_s_waitcnt_vscnt_zero()

    // --- STP update ---
    // rel = u * x → v[28:29] (scratch).
    asm_v_mul_f64_vv(28, 20, 22)                    // v[28:29] = u * x = rel
    asm_s_delay_alu(0x01)
    asm_u32(0xDC6E0000); asm_u32(0x00161C02)        // store rel to release_ptr[tid] via s[22:23]
    asm_s_waitcnt_vscnt_zero()

    // x_new = x - rel (overwrites v[22:23] in place).
    asm_v_sub_f64_vv(22, 22, 28)
    asm_s_delay_alu(0x01)
    asm_u32(0xDC6E0000); asm_u32(0x00141602)        // store x_new to x_stp_ptr[tid] via s[20:21]
    asm_s_waitcnt_vscnt_zero()

    // u_new = u + U_baseline * (1 - u).
    //   Step 1: v[30:31] = 1.0 + (-u) via v_add_f64 with src0=inline 1.0, src1=-v[20:21].
    //   Verified via llvm-mc: v_add_f64 v[30:31], 1.0, -v[20:21] → 0xD727001E, 0x400228F2.
    asm_u32(0xD727001E); asm_u32(0x400228F2)
    asm_s_delay_alu(0x01)
    asm_v_mul_f64_vv(30, 42, 30)                    // v[30:31] = U_base * (1 - u)
    asm_s_delay_alu(0x01)
    asm_v_add_f64_vv(20, 20, 30)                    // v[20:21] = u_new = u + U_base*(1-u)
    asm_s_delay_alu(0x01)
    asm_u32(0xDC6E0000); asm_u32(0x00121402)        // store u_new to u_stp_ptr[tid] via s[18:19]
    asm_s_waitcnt_vscnt_zero()

    // --- Nested ring-buffer scatter: if cell_type[tid] == 0, write rel to buf_delay[w_base*N + tid] ---
    // Compute scalar base = s[42:43] + (w_base << 7)   (N*8 = 128 = 1<<7 for N=16).
    // All three verified via llvm-mc:
    //   s_lshl_b64 s[52:53], s[44:45], 7 → 0x84B4872C
    //   s_add_u32  s54, s42, s52          → 0x8036342A
    //   s_addc_u32 s55, s43, s53          → 0x8237352B
    // Ring-base pointer arithmetic (scalar, executed once per wave):
    //   s[52:53] = w_base << 7  (N*8 = 128 for N=16)
    //   s[54:55] = buf_delay_ptr + s[52:53]  (full 64-bit base ptr)
    asm_u32(0x84B4872C)                             // s_lshl_b64 s[52:53], s[44:45], 7
    asm_u32(0x8036342A)                             // s_add_u32  s54, s42, s52
    asm_u32(0x8237352B)                             // s_addc_u32 s55, s43, s53

    // Reload rel from release_ptr[tid] into v[28:29] (it was overwritten by u-chain).
    asm_u32(0xDC560000); asm_u32(0x1C160002)        // global_load_b64 v[28:29], v2, s[22:23]
    asm_s_waitcnt_vmcnt_zero()

    // Predicate on cell_type == 0.
    asm_v_cmp_eq_u32_imm_vgpr(0, 24)                // vcc_lo = (v24 == 0)
    asm_s_and_saveexec_b32_vcc_lo(48)               // s48 = spike-EXEC, EXEC &= (ct==0)

    // Scatter: buf_delay_base (s[54:55]) + tid*8 (v2) ← v[28:29] (rel).
    asm_u32(0xDC6E0000); asm_u32(0x00361C02)        // global_store_b64 v2, v[28:29], s[54:55]
    asm_s_waitcnt_vscnt_zero()

    // Restore EXEC to spike-path (drop ct-predicate).
    asm_s_mov_b32(0x7E, 48)

    // ---- no-spike body (complementary lanes within outer EXEC) ----
    asm_s_xor_b32_exec_sgpr(47)                     // EXEC = old_EXEC ^ s47 = non-spiking lanes

    // Store v_new to V_ptr[tid] for lanes that did NOT spike.
    asm_u32(0xDC6E0000); asm_u32(0x00021A02)        // global_store_b64 v2, v[26:27], s[2:3]
    asm_s_waitcnt_vscnt_zero()

    // Restore outer EXEC.
    asm_s_mov_b32(0x7E, 47)

    // ---- refractory-path lanes ----
    asm_s_xor_b32_exec_sgpr(46)                     // EXEC = outer ^ (ref==0) = refractory lanes

    // Decrement ref per-lane: v12 -= 1 (v_sub_nc_u32_e64 v12, v12, 1).
    // llvm-mc verified: word1 = 0xD526000C, word2 = 0x0001030C.
    asm_u32(0xD526000C); asm_u32(0x0001030C)
    asm_s_delay_alu(0x01)
    asm_u32(0xDC6E0000); asm_u32(0x00040C02)        // global_store_b64 v2, v[12:13], s[4:5]
    asm_s_waitcnt_vscnt_zero()

    // V = V_reset (same encoding as the spike-path reset).
    asm_u32(0xDC6E0000); asm_u32(0x00022602)        // global_store_b64 v2, v[38:39], s[2:3]
    asm_s_waitcnt_vscnt_zero()

    // Restore kernel-initial EXEC mask.
    asm_s_mov_b32(0x7E, 46)

    asm_s_endpgm()

    uint64 rsrc1 = 0xE0AF0005                       // VGPR granule=5: (5+1)*8 = 48 VGPRs
    uint64 rsrc2 = 0x0000009E
    uint64 rsrc3 = 0x00000030
    uint64 props = 0x0408

    // 22 kernargs: 13 GLOBAL_BUFFER + 9 BY_VALUE.
    uint64[44] args_desc
    uint64 ai = 0
    while ai < 13 {
        uint64 p0 = args_desc + ai * 16;      unsafe { *(p0 as uint64) = 8 }
        uint64 p1 = args_desc + ai * 16 + 8;  unsafe { *(p1 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
        ai = ai + 1
    }
    while ai < 22 {
        uint64 p0 = args_desc + ai * 16;      unsafe { *(p0 as uint64) = 8 }
        uint64 p1 = args_desc + ai * 16 + 8;  unsafe { *(p1 as uint64) = AMD_ARG_KIND_BY_VALUE }
        ai = ai + 1
    }

    uint64 size = emit_amdgpu_code_object(kname, klen,
                                           asm_text_buf, asm_text_len,
                                           176,     // kernarg_size
                                           8,       // kernarg_align
                                           56,      // sgpr_count
                                           48,      // vgpr_count (granule 5)
                                           rsrc1, rsrc2, rsrc3, props,
                                           args_desc, 22)

    uint64 fd = file_open(out_path, 1)
    if fd > 0xFFFFFFFFFFFFF000 {
        write(2, "emit_amdgpu_mt_lif_full_blob: cannot open output\n", 49)
        return 1
    }
    file_write(fd, amd_buf, size)
    file_close(fd)
    return 0
}

// ---------------------------------------------------------------------------
// B3 mt_csr_i_deliver: multi-thread inhibitory CSR delivery. Per-synapse
// dispatch — each lane handles one edge. Branches from the single-thread
// s_cmp + inner row loop become: coalesced VMEM loads of per-edge state
// + predicate-gated EXEC mask + f64 CAS-retry atomic add.
//
// Launch convention: block_x = total_edges, grid_x = 1.
//
// Kernargs (9 entries, 72 bytes):
//   [0x00] rpi_tgt_ptr        (u64*)
//   [0x08] rpi_w_ptr          (f64*)
//   [0x10] edge_to_src_ptr    (u64*)  — built host-side
//   [0x18] cell_type_ptr      (u64*)
//   [0x20] release_ptr        (f64*)
//   [0x28] s_inh_ptr          (f64*)
//   [0x30] n_pre              (u64 by-value, reserved)
//   [0x38] total_edges        (u64 by-value, reserved)
//   [0x40] _reserved          (u64)
//
// THIS IS THE SCAFFOLD STAGE. Predicates + atomic scatter land in the
// next commit.
@export
fn emit_amdgpu_mt_csr_i_deliver_blob(uint64 out_path) -> uint64 {
    uint64 kname = "mt_csr_i_deliver"
    uint64 klen  = 16

    asm_init()

    // --- Prologue: 9 kernarg SMEM loads ---
    asm_s_load_b64(1, 0)                            // s[2:3]   rpi_tgt_ptr
    asm_s_load_b64_off(2, 0, 0x08)                  // s[4:5]   rpi_w_ptr
    asm_s_load_b64_off(3, 0, 0x10)                  // s[6:7]   edge_to_src_ptr
    asm_s_load_b64_off(4, 0, 0x18)                  // s[8:9]   cell_type_ptr
    asm_s_load_b64_off(5, 0, 0x20)                  // s[10:11] release_ptr
    asm_s_load_b64_off(6, 0, 0x28)                  // s[12:13] s_inh_ptr
    asm_s_load_b64_off(7, 0, 0x30)                  // s[14:15] n_pre (unused)
    asm_s_load_b64_off(8, 0, 0x38)                  // s[16:17] total_edges (unused)
    asm_s_load_b64_off(9, 0, 0x40)                  // s[18:19] _reserved
    asm_s_waitcnt_lgkmcnt_zero()

    // Per-lane byte offset: v2 = tid * 8.
    asm_v_lshlrev_b32_imm(2, 3, 0)
    asm_s_delay_alu(0x01)

    // --- Per-lane VMEM loads (saddr = raw SGPR index of pair low half) ---
    // Encoding: [word1=0xDC560000, word2=(vdst<<24) | (saddr<<16) | v_addr]
    // Outputs: v[4:5]=rpi_tgt, v[6:7]=rpi_w, v[8:9]=edge_to_src
    asm_u32(0xDC560000); asm_u32(0x04020002)        // rpi_tgt      → v[4:5]   saddr=s2
    asm_u32(0xDC560000); asm_u32(0x06040002)        // rpi_w        → v[6:7]   saddr=s4
    asm_u32(0xDC560000); asm_u32(0x08060002)        // edge_to_src  → v[8:9]   saddr=s6
    asm_s_waitcnt_vmcnt_zero()

    // --- Compute per-lane src*8 offset → v[10:11] (src is in v[8:9]) ---
    // Plan had 0x00021183 for word2; llvm-mc says 0x00021083. Using
    // llvm-mc's value (src1=v[8:9] encodes as 0x108 → bits 17:9 of word2).
    asm_u32(0xD73C000A); asm_u32(0x00021083)        // v_lshlrev_b64 v[10:11], 3, v[8:9]
    asm_s_delay_alu(0x01)

    // --- cell_type address: v[12:13] = s[8:9] + v[10:11] ---
    // Plan had 0x0002140A for this word2; llvm-mc says 0x00021408 (src0=s8=0x08).
    // Plan duplicated the s10 constant here; corrected to s8.
    asm_u32(0xD7006A0C); asm_u32(0x00021408)        // v_add_co_u32 v12, vcc_lo, s8, v10
    // Plan had 0x01AA160B for word2; llvm-mc says 0x01AA1609 (src0=s9=0x09, not 0x0B).
    asm_u32(0xD5207C0D); asm_u32(0x01AA1609)        // v_add_co_ci_u32_e64 v13, null, s9, v11, vcc_lo
    asm_s_delay_alu(0x01)

    // --- Load cell_type[src] → v[16:17] via saddr=OFF + 64-bit v_addr ---
    asm_u32(0xDC560000); asm_u32(0x107C000C)        // global_load_b64 v[16:17], v[12:13], off
    asm_s_waitcnt_vmcnt_zero()

    // --- Outer predicate: cell_type[src] == 1 ---
    asm_v_cmp_eq_u32_imm_vgpr(1, 16)                // vcc_lo = (v16 == 1)
    asm_s_and_saveexec_b32_vcc_lo(46)               // s46 = outer EXEC, EXEC &= ct==1

    // --- Recompute release address (v[12:13] is scratch) ---
    asm_u32(0xD7006A0C); asm_u32(0x0002140A)        // v_add_co_u32 v12, vcc_lo, s10, v10
    asm_u32(0xD5207C0D); asm_u32(0x01AA160B)        // v_add_co_ci_u32_e64 v13, null, s11, v11, vcc_lo
    asm_s_delay_alu(0x01)
    asm_u32(0xDC560000); asm_u32(0x127C000C)        // global_load_b64 v[18:19], v[12:13], off
    asm_s_waitcnt_vmcnt_zero()

    // --- Inner predicate: release[src] > 0.0 ---
    asm_v_cmp_lt_f64_zero_v(18)                     // vcc_lo = (0.0 < v[18:19])
    asm_s_and_saveexec_b32_vcc_lo(47)               // s47 = post-ct EXEC, EXEC &= rel>0

    // --- Scatter address: v[20:21] = s[12:13] + tgt*8 (tgt in v[4:5]) ---
    asm_u32(0xD73C0014); asm_u32(0x00020883)        // v_lshlrev_b64 v[20:21], 3, v[4:5]
    asm_s_delay_alu(0x01)
    asm_u32(0xD7006A14); asm_u32(0x0002280C)        // v_add_co_u32 v20, vcc_lo, s12, v20
    asm_u32(0xD5207C15); asm_u32(0x01AA2A0D)        // v_add_co_ci_u32_e64 v21, null, s13, v21, vcc_lo
    asm_s_delay_alu(0x01)

    // --- effective = w * rel → v[22:23] (v[6:7]=w, v[18:19]=rel) ---
    asm_v_mul_f64_vv(22, 6, 18)
    asm_s_delay_alu(0x01)

    // --- Prime CAS assumed = *s_inh[tgt] via saddr=OFF load ---
    asm_u32(0xDC560000); asm_u32(0x027C0014)        // global_load_b64 v[2:3], v[20:21], off
    asm_s_waitcnt_vmcnt_zero()

    // --- CAS retry loop for atomic f64 add ---
    uint64 cas_head_off = asm_text_len / 4
    asm_v_add_f64_vv(0, 2, 22)                      // v[0:1] = assumed + effective
    asm_s_delay_alu(0x01)
    asm_u32(0xDD0A4000); asm_u32(0x007C0014)        // global_atomic_cmpswap_b64 v[0:1], v[20:21], v[0:3], off glc
    asm_s_waitcnt_vmcnt_zero()
    asm_s_waitcnt_vscnt_zero()
    asm_v_cmp_ne_u64_vv(2, 0)
    asm_v_mov_b32(2, 0x100 | 0)                     // v2 = returned_prev_lo (copy of v0)
    asm_v_mov_b32(3, 0x100 | 1)                     // v3 = returned_prev_hi (copy of v1)
    // Narrow EXEC to lanes that still need to retry. Without this, lanes
    // that already succeeded keep re-participating in the loop body,
    // which for atomic-add is not idempotent — successful lanes keep
    // adding `effective` on top of other lanes' writes, so no lane ever
    // sees a stable "assumed" value and the loop never terminates.
    asm_s_and_b32_exec_vcc_lo()                     // exec_lo &= vcc_lo
    uint64 cas_branch_off = asm_text_len / 4
    uint64 cas_delta = cas_head_off - (cas_branch_off + 1)
    asm_s_cbranch_execnz(cas_delta & 0xFFFF)

    // --- Restore EXEC masks ---
    asm_s_mov_b32(0x7E, 47)                         // exec_lo = s47 (drop rel>0)
    asm_s_mov_b32(0x7E, 46)                         // exec_lo = s46 (drop ct==1)

    asm_s_endpgm()

    uint64 rsrc1 = 0xE0AF0002                       // VGPR granule=2 → 24 VGPRs
    uint64 rsrc2 = 0x0000009E
    uint64 rsrc3 = 0x00000030
    uint64 props = 0x0408

    // 9 kernargs: 6 GLOBAL_BUFFER + 3 BY_VALUE.
    uint64[18] args_desc
    uint64 ai = 0
    while ai < 6 {
        uint64 p0 = args_desc + ai * 16;      unsafe { *(p0 as uint64) = 8 }
        uint64 p1 = args_desc + ai * 16 + 8;  unsafe { *(p1 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
        ai = ai + 1
    }
    while ai < 9 {
        uint64 p0 = args_desc + ai * 16;      unsafe { *(p0 as uint64) = 8 }
        uint64 p1 = args_desc + ai * 16 + 8;  unsafe { *(p1 as uint64) = AMD_ARG_KIND_BY_VALUE }
        ai = ai + 1
    }

    uint64 size = emit_amdgpu_code_object(kname, klen,
                                           asm_text_buf, asm_text_len,
                                           72,      // kernarg_size (9 × 8)
                                           8,       // kernarg_align
                                           48,      // sgpr_count (s2..s19 kernargs, s46/s47 EXEC saves)
                                           24,      // vgpr_count
                                           rsrc1, rsrc2, rsrc3, props,
                                           args_desc, 9)

    uint64 fd = file_open(out_path, 1)
    if fd > 0xFFFFFFFFFFFFF000 {
        write(2, "emit_amdgpu_mt_csr_i_deliver_blob: cannot open output\n", 54)
        return 1
    }
    file_write(fd, amd_buf, size)
    file_close(fd)
    return 0
}

// ---------------------------------------------------------------------------
// B3 mt_csr_e_delayed: multi-thread excitatory CSR delivery with
// delay-line read, STDP LTD, and fused buf_delay clear.
//
// Launch convention: block_x = total_edges, grid_x = 1.
//
// Kernargs (14 entries, 112 bytes):
//   [0x00] rpe_tgt_ptr         (u64*)
//   [0x08] rpe_w_ptr           (f64*)
//   [0x10] rpe_is_ee_ptr       (u64*)
//   [0x18] edge_to_src_e_ptr   (u64*)
//   [0x20] is_first_edge_e_ptr (u64*)
//   [0x28] buf_delay_ptr       (f64*)
//   [0x30] row_base            (u64 by-value)
//   [0x38] x_post_ptr          (f64*)
//   [0x40] s_exc_ptr           (f64*)
//   [0x48] ltd_events_ptr      (u64*)
//   [0x50] n_pre               (u64 by-value)
//   [0x58] A_minus             (f64 by-value)
//   [0x60] w_max               (f64 by-value)
//   [0x68] _reserved           (u64)
//
// THIS IS THE SCAFFOLD STAGE. Outer predicate + atomic scatter land
// in the next commit; STDP LTD + first-edge clear land after that.
@export
fn emit_amdgpu_mt_csr_e_delayed_blob(uint64 out_path) -> uint64 {
    uint64 kname = "mt_csr_e_delayed"
    uint64 klen  = 16

    asm_init()

    // --- Prologue: 14 kernarg SMEM loads ---
    asm_s_load_b64(1, 0)                            // s[2:3]   rpe_tgt_ptr
    asm_s_load_b64_off(2, 0, 0x08)                  // s[4:5]   rpe_w_ptr
    asm_s_load_b64_off(3, 0, 0x10)                  // s[6:7]   rpe_is_ee_ptr
    asm_s_load_b64_off(4, 0, 0x18)                  // s[8:9]   edge_to_src_e_ptr
    asm_s_load_b64_off(5, 0, 0x20)                  // s[10:11] is_first_edge_e_ptr
    asm_s_load_b64_off(6, 0, 0x28)                  // s[12:13] buf_delay_ptr
    asm_s_load_b64_off(7, 0, 0x30)                  // s[14:15] row_base
    asm_s_load_b64_off(8, 0, 0x38)                  // s[16:17] x_post_ptr
    asm_s_load_b64_off(9, 0, 0x40)                  // s[18:19] s_exc_ptr
    asm_s_load_b64_off(10, 0, 0x48)                 // s[20:21] ltd_events_ptr
    asm_s_load_b64_off(11, 0, 0x50)                 // s[22:23] n_pre (unused)
    asm_s_load_b64_off(12, 0, 0x58)                 // s[24:25] A_minus
    asm_s_load_b64_off(13, 0, 0x60)                 // s[26:27] w_max
    asm_s_load_b64_off(14, 0, 0x68)                 // s[28:29] _reserved
    asm_s_waitcnt_lgkmcnt_zero()

    // Per-lane byte offset v2 = tid*8.
    asm_v_lshlrev_b32_imm(2, 3, 0)
    asm_s_delay_alu(0x01)

    // --- Per-lane VMEM loads (saddr = raw SGPR index of pair low half) ---
    // Encoding: [word1=0xDC560000, word2=(vdst<<24) | (saddr<<16) | v_addr]
    // Outputs: v[4:5]=rpe_tgt, v[6:7]=rpe_w, v[12:13]=rpe_is_ee, v[8:9]=edge_to_src, v[14:15]=is_first
    asm_u32(0xDC560000); asm_u32(0x04020002)        // rpe_tgt         → v[4:5]   saddr=s2
    asm_u32(0xDC560000); asm_u32(0x06040002)        // rpe_w           → v[6:7]   saddr=s4
    asm_u32(0xDC560000); asm_u32(0x0C060002)        // rpe_is_ee       → v[12:13] saddr=s6
    asm_u32(0xDC560000); asm_u32(0x08080002)        // edge_to_src_e   → v[8:9]   saddr=s8
    asm_u32(0xDC560000); asm_u32(0x0E0A0002)        // is_first_edge_e → v[14:15] saddr=s10
    asm_s_waitcnt_vmcnt_zero()

    // --- SGPR→VGPR broadcast of f64 by-value constants ---
    asm_v_mov_b32(30, 24); asm_v_mov_b32(31, 25)    // v[30:31] A_minus
    asm_v_mov_b32(32, 26); asm_v_mov_b32(33, 27)    // v[32:33] w_max
    asm_s_delay_alu(0x02)

    // --- Gather: rel = buf_delay[row_base + src] ---
    // Scalar precompute: s[30:31] = buf_delay_ptr + row_base * 8
    asm_u32(0x849E830E)                             // s_lshl_b64 s[30:31], s[14:15], 3
    asm_u32(0x801E1E0C)                             // s_add_u32  s30, s12, s30
    asm_u32(0x821F1F0D)                             // s_addc_u32 s31, s13, s31
    asm_s_waitcnt_lgkmcnt_zero()

    // Per-lane offset: v[16:17] = src * 8 (v[8:9] holds src, shift by 3)
    asm_u32(0xD73C0010); asm_u32(0x00021083)        // v_lshlrev_b64 v[16:17], 3, v[8:9]
    asm_s_delay_alu(0x01)

    // Build per-lane vaddr: v[18:19] = s[30:31] + v[16:17]
    asm_u32(0xD7006A12); asm_u32(0x0002201E)        // v_add_co_u32 v18, vcc_lo, s30, v16
    asm_u32(0xD5207C13); asm_u32(0x01AA221F)        // v_add_co_ci_u32_e64 v19, null, s31, v17, vcc_lo
    asm_s_delay_alu(0x01)

    // Load rel → v[20:21]
    asm_u32(0xDC560000); asm_u32(0x147C0012)        // global_load_b64 v[20:21], v[18:19], off
    asm_s_waitcnt_vmcnt_zero()

    // --- Outer predicate: rel > 0.0 ---
    asm_v_cmp_lt_f64_zero_v(20)                     // vcc_lo = (0.0 < v[20:21])
    asm_s_and_saveexec_b32_vcc_lo(46)               // s46 = initial EXEC, EXEC &= rel>0

    // --- Scatter address: v[24:25] = s_exc_ptr + tgt*8 (tgt in v[4:5]) ---
    asm_u32(0xD73C0016); asm_u32(0x00020883)        // v_lshlrev_b64 v[22:23], 3, v[4:5]
    asm_s_delay_alu(0x01)
    asm_u32(0xD7006A18); asm_u32(0x00022C12)        // v_add_co_u32 v24, vcc_lo, s18, v22
    asm_u32(0xD5207C19); asm_u32(0x01AA2E13)        // v_add_co_ci_u32_e64 v25, null, s19, v23, vcc_lo
    asm_s_delay_alu(0x01)

    // --- effective = w * rel → v[26:27] (v[6:7]=w, v[20:21]=rel) ---
    asm_v_mul_f64_vv(26, 6, 20)
    asm_s_delay_alu(0x01)

    // Save v2 (per-lane tid*8 byte offset) to v44 BEFORE the prime CAS
    // load — that load clobbers v[2:3] with s_exc[tgt]'s current value.
    // The CAS retry later re-clobbers v2 each iteration. Post-CAS, v2
    // is restored from v44 so STDP LTD + first-edge-clear VMEM stores
    // address their lane's rpe_w / buf_delay slot correctly.
    asm_v_mov_b32(44, 0x100 | 2)                    // v44 = v2 (tid*8)
    asm_s_delay_alu(0x01)

    // --- Prime CAS assumed = *s_exc[tgt] ---
    asm_u32(0xDC560000); asm_u32(0x027C0018)        // global_load_b64 v[2:3], v[24:25], off
    asm_s_waitcnt_vmcnt_zero()

    // Save the rel>0 EXEC mask to s49; the CAS loop narrows EXEC as
    // lanes succeed, leaving EXEC=0 at loop exit. Subsequent STDP LTD
    // and first-edge-clear blocks need EXEC = rel>0 mask to run.
    asm_s_mov_b32(49, 0x7E)                         // s49 = exec_lo

    // --- CAS retry loop for atomic f64 add ---
    uint64 cas_head_e_off = asm_text_len / 4
    asm_v_add_f64_vv(0, 2, 26)                      // v[0:1] = assumed + effective
    asm_s_delay_alu(0x01)
    asm_u32(0xDD0A4000); asm_u32(0x007C0018)        // global_atomic_cmpswap_b64 v[0:1], v[24:25], v[0:3], off glc
    asm_s_waitcnt_vmcnt_zero()
    asm_s_waitcnt_vscnt_zero()
    asm_v_cmp_ne_u64_vv(2, 0)
    asm_v_mov_b32(2, 0x100 | 0)
    asm_v_mov_b32(3, 0x100 | 1)
    // Narrow EXEC to retrying lanes (see mt_csr_i_deliver for rationale).
    asm_s_and_b32_exec_vcc_lo()
    uint64 cas_branch_e_off = asm_text_len / 4
    uint64 cas_delta_e = cas_head_e_off - (cas_branch_e_off + 1)
    asm_s_cbranch_execnz(cas_delta_e & 0xFFFF)

    // Restore EXEC FIRST (CAS narrowed it to 0), so the v2 restore below
    // actually runs on the rel>0 lanes. If we moved v2 before this,
    // the VALU would execute on zero lanes and do nothing.
    asm_s_mov_b32(0x7E, 49)                         // exec_lo = s49

    // Restore v2 (tid*8 byte offset) from v44 for the STDP + first-edge
    // VMEM stores — the CAS retry clobbered v2 via v_mov v2, v0.
    asm_v_mov_b32(2, 0x100 | 44)                    // v2 = v44
    asm_s_delay_alu(0x01)

    // Precompute rpe_w store addr v[46:47] = s[4:5] + v44 (= rpe_w_ptr + tid*8).
    // Use v44 directly (instead of v2 via restore) so no VALU-VGPR
    // restore hazard can bite. v44 was saved from v2 pre-CAS under
    // rel>0 EXEC and the CAS loop doesn't touch v44.
    asm_u32(0xD7006A2E); asm_u32(0x00025804)        // v_add_co_u32 v46, vcc_lo, s4, v44
    asm_u32(0xD5207C2F); asm_u32(0x01AA2E05)        // v_add_co_ci_u32_e64 v47, null, s5, v23, vcc_lo
    asm_s_delay_alu(0x01)

    // --- Nested: if rpe_is_ee[edge] == 1 { STDP LTD } ---
    asm_v_cmp_eq_u32_imm_vgpr(1, 12)                // vcc_lo = (is_ee == 1)
    asm_s_and_saveexec_b32_vcc_lo(47)               // s47 = outer mask, EXEC &= (is_ee == 1)

    // --- Load x_post[tgt] via saddr=OFF + 64-bit v_addr ---
    // Build x_post addr: v[28:29] = s[16:17] + v[22:23] (v[22:23]=tgt*8 from Task-5 scatter calc)
    asm_u32(0xD7006A1C); asm_u32(0x00022C10)        // v_add_co_u32 v28, vcc_lo, s16, v22
    asm_u32(0xD5207C1D); asm_u32(0x01AA2E11)        // v_add_co_ci_u32_e64 v29, null, s17, v23, vcc_lo
    asm_s_delay_alu(0x01)
    asm_u32(0xDC560000); asm_u32(0x227C001C)        // global_load_b64 v[34:35], v[28:29], off
    asm_s_waitcnt_vmcnt_zero()

    // --- w_new = clamp(w + A_minus * x_post[tgt], 0.0, w_max) ---
    // v[36:37] = A_minus * x_post[tgt]  (A_minus in v[30:31], x_post in v[34:35])
    asm_v_mul_f64_vv(36, 30, 34)
    asm_s_delay_alu(0x01)
    // v[36:37] = w + A_minus*x_post   (v[6:7] = w)
    asm_v_add_f64_vv(36, 6, 36)
    asm_s_delay_alu(0x01)
    // Build zero pair in v[38:39] for the max clamp.
    asm_v_mov_b32_inline_u(38, 0)
    asm_v_mov_b32_inline_u(39, 0)
    asm_s_delay_alu(0x02)
    // v[36:37] = max(v[36:37], 0.0)
    asm_v_max_f64_vv(36, 36, 38)
    asm_s_delay_alu(0x01)
    // v[36:37] = min(v[36:37], w_max)   (w_max in v[32:33])
    asm_v_min_f64_vv(36, 36, 32)
    asm_s_delay_alu(0x01)

    // --- Store w_new back to rpe_w[edge] via saddr=s[4:5], v_addr=v2 ---
    // Encoding: 0xDC6E0000, (vdst_ignored<<24 | saddr<<16 | vdata<<8 | vaddr) = 0x00042402
    // v[46:47] was precomputed before the is_ee saveexec so the addr
    // pair is fresh for ALL rel>0 lanes, not just is_ee ones. Store
    // uses saddr=OFF + full 64-bit v_addr to avoid the gfx11 H1 hazard.
    asm_u32(0xDC6E0000); asm_u32(0x007C242E)        // global_store_b64 v[46:47], v[36:37], off
    asm_s_waitcnt_vscnt_zero()

    // --- atomic_add_u64(ltd_events, 1) ---
    // All lanes target the same address (ltd_events_ptr), build per-lane copies.
    // Addr pair v[40:41] = s[20:21].
    asm_v_mov_b32(40, 20)
    asm_v_mov_b32(41, 21)
    asm_s_delay_alu(0x02)
    // Data pair v[42:43] = 1_u64.
    asm_v_mov_b32_inline_u(42, 1)
    asm_v_mov_b32_inline_u(43, 0)
    asm_s_delay_alu(0x02)
    asm_global_atomic_add_u64_offvaddr(40, 42)
    asm_s_waitcnt_vscnt_zero()

    // --- Restore is_ee mask ---
    asm_s_mov_b32(0x7E, 47)

    // --- Nested: if is_first_edge[edge] == 1 { buf_delay[row_base+src] = 0 } ---
    asm_v_cmp_eq_u32_imm_vgpr(1, 14)                // vcc_lo = (v14 == 1)
    asm_s_and_saveexec_b32_vcc_lo(48)               // s48 = outer mask, EXEC &= is_first==1

    // v[18:19] still holds buf_delay addr from Task 5 outer gather; v[38:39] holds 0.0.
    // global_store_b64 v[18:19] vaddr pair, v[38:39] data pair, saddr=OFF.
    // Encoding: 0xDC6E0000, (saddr=0x7C<<16 | vdata=0x26<<8 | vaddr=0x12) = 0x007C2612
    asm_u32(0xDC6E0000); asm_u32(0x007C2612)
    asm_s_waitcnt_vscnt_zero()

    asm_s_mov_b32(0x7E, 48)

    // --- Restore outer EXEC ---
    asm_s_mov_b32(0x7E, 46)

    asm_s_endpgm()

    uint64 rsrc1 = 0xE0AF0005                       // VGPR granule=5 → 48 VGPRs
    uint64 rsrc2 = 0x0000009E
    uint64 rsrc3 = 0x00000030
    uint64 props = 0x0408

    uint64[28] args_desc
    uint64 ai = 0
    // 10 pointer args: rpe_tgt, rpe_w, rpe_is_ee, edge_to_src_e, is_first_edge_e
    while ai < 6 {
        uint64 p0 = args_desc + ai * 16;     unsafe { *(p0 as uint64) = 8 }
        uint64 p1 = args_desc + ai * 16 + 8; unsafe { *(p1 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
        ai = ai + 1
    }
    // row_base (by-value) at index 6
    uint64 rb_p0 = args_desc + ai * 16;     unsafe { *(rb_p0 as uint64) = 8 }
    uint64 rb_p1 = args_desc + ai * 16 + 8; unsafe { *(rb_p1 as uint64) = AMD_ARG_KIND_BY_VALUE }
    ai = ai + 1
    // x_post_ptr, s_exc_ptr, ltd_events_ptr at indices 7, 8, 9
    while ai < 10 {
        uint64 p0 = args_desc + ai * 16;     unsafe { *(p0 as uint64) = 8 }
        uint64 p1 = args_desc + ai * 16 + 8; unsafe { *(p1 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
        ai = ai + 1
    }
    // n_pre, A_minus, w_max, _reserved (4 by-values) at indices 10-13
    while ai < 14 {
        uint64 p0 = args_desc + ai * 16;     unsafe { *(p0 as uint64) = 8 }
        uint64 p1 = args_desc + ai * 16 + 8; unsafe { *(p1 as uint64) = AMD_ARG_KIND_BY_VALUE }
        ai = ai + 1
    }

    uint64 size = emit_amdgpu_code_object(kname, klen,
                                           asm_text_buf, asm_text_len,
                                           112,     // kernarg_size (14 × 8)
                                           8,       // kernarg_align
                                           50,      // sgpr_count (s0..s29 kernargs, s[30:31] scratch, s46/47/48 EXEC saves)
                                           48,      // vgpr_count (granule 5)
                                           rsrc1, rsrc2, rsrc3, props,
                                           args_desc, 14)

    uint64 fd = file_open(out_path, 1)
    if fd > 0xFFFFFFFFFFFFF000 {
        write(2, "emit_amdgpu_mt_csr_e_delayed_blob: cannot open output\n", 54)
        return 1
    }
    file_write(fd, amd_buf, size)
    file_close(fd)
    return 0
}

// ---------------------------------------------------------------------------
// B4 decay_step: per-lane exponential decay. buf[tid] -= buf[tid] * factor.
// Semantics matches examples/gpu_stage13_full.mlr:39-49.
//
// Launch: block_x = N, grid_x = 1. Guard via tid < n.
//
// Kernargs (4 entries, 32 bytes):
//   [0x00] buf_ptr    (f64*)
//   [0x08] n          (u64 by-value)
//   [0x10] factor     (f64 by-value)
//   [0x18] _reserved  (u64)
@export
fn emit_amdgpu_decay_step_blob(uint64 out_path) -> uint64 {
    uint64 kname = "decay_step"
    uint64 klen  = 10

    asm_init()

    // --- Prologue: 4 kernarg SMEM loads ---
    asm_s_load_b64(1, 0)                            // s[2:3]   buf_ptr
    asm_s_load_b64_off(2, 0, 0x08)                  // s[4:5]   n
    asm_s_load_b64_off(3, 0, 0x10)                  // s[6:7]   factor
    asm_s_load_b64_off(4, 0, 0x18)                  // s[8:9]   _reserved
    asm_s_waitcnt_lgkmcnt_zero()

    // tid < n guard. `asm_v_cmp_gt_u32_sgpr_vgpr(s, v)` sets vcc = (s > v).
    // Passing (s=4, v=0) gives vcc = (s4 > v0) = (n > tid) = (tid < n).
    asm_v_cmp_gt_u32_sgpr_vgpr(4, 0)                // vcc_lo = (s4 > v0)
    asm_s_and_saveexec_b32_vcc_lo(46)               // s46 = outer EXEC, EXEC &= (tid < n)

    // Per-lane byte offset: v2 = tid * 8.
    asm_v_lshlrev_b32_imm(2, 3, 0)
    asm_s_delay_alu(0x01)

    // Load buf[tid] → v[4:5] (saddr=s2 low-half index for s[2:3]=buf_ptr, v_addr=v2).
    asm_u32(0xDC560000); asm_u32(0x04020002)        // global_load_b64 v[4:5], v2, s[2:3]
    asm_s_waitcnt_vmcnt_zero()

    // SGPR→VGPR broadcast of factor (s[6:7] → v[6:7]).
    asm_v_mov_b32(6, 6); asm_v_mov_b32(7, 7)        // v[6:7] = factor
    asm_s_delay_alu(0x02)

    // v[8:9] = buf * factor
    asm_v_mul_f64_vv(8, 4, 6)
    asm_s_delay_alu(0x01)
    // v[4:5] = buf - buf*factor
    asm_v_sub_f64_vv(4, 4, 8)
    asm_s_delay_alu(0x01)

    // Store v[4:5] back to buf[tid].
    asm_u32(0xDC6E0000); asm_u32(0x00020402)        // global_store_b64 v2, v[4:5], s[2:3]
    asm_s_waitcnt_vscnt_zero()

    // Restore outer EXEC (drop tid<n mask).
    asm_s_mov_b32(0x7E, 46)

    asm_s_endpgm()

    uint64 rsrc1 = 0xE0AF0001                       // VGPR granule=1 → 16 VGPRs
    uint64 rsrc2 = 0x0000009E
    uint64 rsrc3 = 0x00000030
    uint64 props = 0x0408

    // 4 kernargs: 1 GLOBAL_BUFFER + 3 BY_VALUE.
    uint64[8] args_desc
    uint64 p_a0_size = args_desc + 0;   unsafe { *(p_a0_size as uint64) = 8 }
    uint64 p_a0_kind = args_desc + 8;   unsafe { *(p_a0_kind as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 p_a1_size = args_desc + 16;  unsafe { *(p_a1_size as uint64) = 8 }
    uint64 p_a1_kind = args_desc + 24;  unsafe { *(p_a1_kind as uint64) = AMD_ARG_KIND_BY_VALUE }
    uint64 p_a2_size = args_desc + 32;  unsafe { *(p_a2_size as uint64) = 8 }
    uint64 p_a2_kind = args_desc + 40;  unsafe { *(p_a2_kind as uint64) = AMD_ARG_KIND_BY_VALUE }
    uint64 p_a3_size = args_desc + 48;  unsafe { *(p_a3_size as uint64) = 8 }
    uint64 p_a3_kind = args_desc + 56;  unsafe { *(p_a3_kind as uint64) = AMD_ARG_KIND_BY_VALUE }

    uint64 size = emit_amdgpu_code_object(kname, klen,
                                           asm_text_buf, asm_text_len,
                                           32,      // kernarg_size (4 × 8)
                                           8,       // kernarg_align
                                           48,      // sgpr_count (kernargs + EXEC save at s46)
                                           16,      // vgpr_count
                                           rsrc1, rsrc2, rsrc3, props,
                                           args_desc, 4)

    uint64 fd = file_open(out_path, 1)
    if fd > 0xFFFFFFFFFFFFF000 {
        write(2, "emit_amdgpu_decay_step_blob: cannot open output\n", 48)
        return 1
    }
    file_write(fd, amd_buf, size)
    file_close(fd)
    return 0
}

// ---------------------------------------------------------------------------
// B4 relax_step: per-lane relaxation toward a target.
//   buf[tid] = buf[tid] + (target - buf[tid]) * factor
// Semantics matches examples/gpu_stage13_full.mlr:52-62.
//
// Launch: block_x = N, grid_x = 1. Guard via tid < n.
//
// Kernargs (5 entries, 40 bytes):
//   [0x00] buf_ptr   (f64*)
//   [0x08] n         (u64 by-value)
//   [0x10] target    (f64 by-value)
//   [0x18] factor    (f64 by-value)
//   [0x20] _reserved (u64)
@export
fn emit_amdgpu_relax_step_blob(uint64 out_path) -> uint64 {
    uint64 kname = "relax_step"
    uint64 klen  = 10

    asm_init()

    // --- Prologue: 5 kernarg SMEM loads ---
    asm_s_load_b64(1, 0)                            // s[2:3]   buf_ptr
    asm_s_load_b64_off(2, 0, 0x08)                  // s[4:5]   n
    asm_s_load_b64_off(3, 0, 0x10)                  // s[6:7]   target
    asm_s_load_b64_off(4, 0, 0x18)                  // s[8:9]   factor
    asm_s_load_b64_off(5, 0, 0x20)                  // s[10:11] _reserved
    asm_s_waitcnt_lgkmcnt_zero()

    // tid < n guard.
    asm_v_cmp_gt_u32_sgpr_vgpr(4, 0)                // vcc_lo = (s4 > v0)
    asm_s_and_saveexec_b32_vcc_lo(46)               // s46 = outer EXEC, EXEC &= (tid < n)

    // v2 = tid * 8.
    asm_v_lshlrev_b32_imm(2, 3, 0)
    asm_s_delay_alu(0x01)

    // Load buf[tid] → v[4:5].
    asm_u32(0xDC560000); asm_u32(0x04020002)        // global_load_b64 v[4:5], v2, s[2:3]
    asm_s_waitcnt_vmcnt_zero()

    // Broadcast target → v[6:7], factor → v[8:9].
    asm_v_mov_b32(6, 6); asm_v_mov_b32(7, 7)        // v[6:7] = target
    asm_v_mov_b32(8, 8); asm_v_mov_b32(9, 9)        // v[8:9] = factor
    asm_s_delay_alu(0x04)

    // v[10:11] = target - buf
    asm_v_sub_f64_vv(10, 6, 4)
    asm_s_delay_alu(0x01)
    // v[10:11] = (target - buf) * factor
    asm_v_mul_f64_vv(10, 10, 8)
    asm_s_delay_alu(0x01)
    // v[4:5] = buf + (target - buf) * factor
    asm_v_add_f64_vv(4, 4, 10)
    asm_s_delay_alu(0x01)

    // Store v[4:5] back to buf[tid].
    asm_u32(0xDC6E0000); asm_u32(0x00020402)        // global_store_b64 v2, v[4:5], s[2:3]
    asm_s_waitcnt_vscnt_zero()

    asm_s_mov_b32(0x7E, 46)
    asm_s_endpgm()

    uint64 rsrc1 = 0xE0AF0001                       // granule 1 → 16 VGPRs
    uint64 rsrc2 = 0x0000009E
    uint64 rsrc3 = 0x00000030
    uint64 props = 0x0408

    // 5 kernargs: 1 GLOBAL_BUFFER + 4 BY_VALUE.
    uint64[10] args_desc
    uint64 p0s = args_desc + 0;   unsafe { *(p0s as uint64) = 8 }
    uint64 p0k = args_desc + 8;   unsafe { *(p0k as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 p1s = args_desc + 16;  unsafe { *(p1s as uint64) = 8 }
    uint64 p1k = args_desc + 24;  unsafe { *(p1k as uint64) = AMD_ARG_KIND_BY_VALUE }
    uint64 p2s = args_desc + 32;  unsafe { *(p2s as uint64) = 8 }
    uint64 p2k = args_desc + 40;  unsafe { *(p2k as uint64) = AMD_ARG_KIND_BY_VALUE }
    uint64 p3s = args_desc + 48;  unsafe { *(p3s as uint64) = 8 }
    uint64 p3k = args_desc + 56;  unsafe { *(p3k as uint64) = AMD_ARG_KIND_BY_VALUE }
    uint64 p4s = args_desc + 64;  unsafe { *(p4s as uint64) = 8 }
    uint64 p4k = args_desc + 72;  unsafe { *(p4k as uint64) = AMD_ARG_KIND_BY_VALUE }

    uint64 size = emit_amdgpu_code_object(kname, klen,
                                           asm_text_buf, asm_text_len,
                                           40,      // kernarg_size (5 × 8)
                                           8,       // kernarg_align
                                           48,      // sgpr_count
                                           16,      // vgpr_count
                                           rsrc1, rsrc2, rsrc3, props,
                                           args_desc, 5)

    uint64 fd = file_open(out_path, 1)
    if fd > 0xFFFFFFFFFFFFF000 {
        write(2, "emit_amdgpu_relax_step_blob: cannot open output\n", 48)
        return 1
    }
    file_write(fd, amd_buf, size)
    file_close(fd)
    return 0
}

// ---------------------------------------------------------------------------
// B4 fill_step: per-lane constant fill. buf[tid] = value.
// Semantics matches examples/gpu_stage13_full.mlr:65-72.
//
// Launch: block_x = N, grid_x = 1. Guard via tid < n.
//
// Kernargs (3 entries, 24 bytes):
//   [0x00] buf_ptr  (f64*)
//   [0x08] n        (u64 by-value)
//   [0x10] value    (f64 by-value)
@export
fn emit_amdgpu_fill_step_blob(uint64 out_path) -> uint64 {
    uint64 kname = "fill_step"
    uint64 klen  = 9

    asm_init()

    asm_s_load_b64(1, 0)                            // s[2:3] buf_ptr
    asm_s_load_b64_off(2, 0, 0x08)                  // s[4:5] n
    asm_s_load_b64_off(3, 0, 0x10)                  // s[6:7] value
    asm_s_waitcnt_lgkmcnt_zero()

    // tid < n guard.
    asm_v_cmp_gt_u32_sgpr_vgpr(4, 0)                // vcc_lo = (s4 > v0)
    asm_s_and_saveexec_b32_vcc_lo(46)

    // v2 = tid * 8.
    asm_v_lshlrev_b32_imm(2, 3, 0)
    asm_s_delay_alu(0x01)

    // Broadcast value → v[4:5].
    asm_v_mov_b32(4, 6); asm_v_mov_b32(5, 7)
    asm_s_delay_alu(0x02)

    // Store.
    asm_u32(0xDC6E0000); asm_u32(0x00020402)        // global_store_b64 v2, v[4:5], s[2:3]
    asm_s_waitcnt_vscnt_zero()

    asm_s_mov_b32(0x7E, 46)
    asm_s_endpgm()

    uint64 rsrc1 = 0xE0AF0000                       // granule 0 → 8 VGPRs
    uint64 rsrc2 = 0x0000009E
    uint64 rsrc3 = 0x00000030
    uint64 props = 0x0408

    uint64[6] args_desc
    uint64 p0s = args_desc + 0;   unsafe { *(p0s as uint64) = 8 }
    uint64 p0k = args_desc + 8;   unsafe { *(p0k as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 p1s = args_desc + 16;  unsafe { *(p1s as uint64) = 8 }
    uint64 p1k = args_desc + 24;  unsafe { *(p1k as uint64) = AMD_ARG_KIND_BY_VALUE }
    uint64 p2s = args_desc + 32;  unsafe { *(p2s as uint64) = 8 }
    uint64 p2k = args_desc + 40;  unsafe { *(p2k as uint64) = AMD_ARG_KIND_BY_VALUE }

    uint64 size = emit_amdgpu_code_object(kname, klen,
                                           asm_text_buf, asm_text_len,
                                           24,      // kernarg_size (3 × 8)
                                           8,       // kernarg_align
                                           48,      // sgpr_count
                                           8,       // vgpr_count
                                           rsrc1, rsrc2, rsrc3, props,
                                           args_desc, 3)

    uint64 fd = file_open(out_path, 1)
    if fd > 0xFFFFFFFFFFFFF000 {
        write(2, "emit_amdgpu_fill_step_blob: cannot open output\n", 47)
        return 1
    }
    file_write(fd, amd_buf, size)
    file_close(fd)
    return 0
}

// ---------------------------------------------------------------------------
// M1m loop-demo: hand-crafted kernel that exercises the SALU while-
// loop primitives (s_add_u32, s_cmp_lt_u32, s_cbranch_scc0,
// s_branch backward) before any AST-lowerer shape wires them in.
//
// Kernel (one thread, writes to out[0]):
//     acc = 0
//     i = 0
//     while i < count:   // count comes from kernarg
//         acc += i
//         i += 1
//     out[0] = acc       // = count*(count-1)/2
//
// Instruction sequence (15 instructions, SALU scalar loop — single
// thread, no VALU predication needed):
//
//   s_load_b32 s2, s[0:1], 0x8         ; s2 = count
//   s_load_b64 s[4:5], s[0:1], null    ; s[4:5] = out ptr
//   s_mov_b32 s6, 0                    ; s6 = i
//   s_mov_b32 s7, 0                    ; s7 = acc
//   s_waitcnt lgkmcnt(0)
// loop_top:
//   s_cmp_lt_u32 s6, s2                ; SCC = (i < count)
//   s_cbranch_scc0 loop_end            ; exit if !lt
//   s_add_u32 s7, s7, s6               ; acc += i    (2-reg form)
//   s_add_u32 s6, s6, 1                ; i += 1
//   s_branch loop_top                  ; back to compare
// loop_end:
//   v_mov_b32 v0, 0                    ; byte offset
//   v_mov_b32 v1, s7                   ; acc → VGPR for store
//   global_store_b32 v0, v1, s[4:5]
//   s_endpgm
@export
fn emit_amdgpu_loop_demo_blob(uint64 out_path) -> uint64 {
    uint64 kname = "loop_demo"
    uint64 klen  = 9

    asm_init()
    asm_s_load_b32(1, 0, 0x8)                      // s2 = count (sdata_pair=1 → s2)
    asm_s_load_b64(2, 0)                           // s[4:5] = out ptr
    asm_s_mov_b32_imm0(6)                          // s6 = 0 (i)
    asm_s_mov_b32_imm0(7)                          // s7 = 0 (acc)
    asm_s_waitcnt_lgkmcnt_zero()

    // loop_top @ offset 5 dwords from text start:
    uint64 loop_top_dword = 5
    asm_s_cmp_lt_u32(6, 2)                         // SCC = (s6 < s2)
    // s_cbranch_scc0 to loop_end: 3 instructions ahead
    //   (s_cbranch itself) + s_add + s_add + s_branch = 4 dwords after
    //   the cbranch → simm16 = 3 (skips 3 dwords to land on
    //   v_mov_b32 at loop_end).
    asm_s_cbranch_scc0(3)
    // s_add_u32 s7, s7, s6 — need a 2-sgpr SOP2 form. Existing
    // asm_s_add_u32_imm only handles imm src1. Emit manually:
    //   SOP2 s_add_u32: [31:23]=0x100, [22:16]=sdst, [15:8]=ssrc1, [7:0]=ssrc0
    uint64 add_word = (0x2 << 30) | (0x00 << 23) | ((7 & 0x7F) << 16) | ((6 & 0xFF) << 8) | (7 & 0xFF)
    asm_u32(add_word)
    asm_s_add_u32_imm(6, 6, 1)                     // s6 += 1
    // s_branch back to loop_top. Current dword offset = 5 + 4 = 9
    // (after cmp, cbranch, add, add). s_branch itself is at dword 9.
    // Target = loop_top_dword = 5. simm16 = target - (current+1) = 5-10 = -5.
    // Encode as two's-complement 16-bit: 0xFFFB.
    asm_s_branch(0xFFFB)

    // loop_end @ dword 10:
    // v_mov_b32 v0, 0  (VOP1 op 0x01, prefix 0x3F at [31:25], vdst at
    // [16:9], src0 at [8:0])
    //   Reference llvm-mc: v_mov_b32 v0, 0 → encoding 7E000280
    //   0x7E000280 = (0x3F<<25) | (0x01<<17) | (0<<9) | 0x80
    asm_u32(0x7E000280)
    // v_mov_b32 v1, s7 (VOP1 op 0x01, vdst=1, src0=SGPR 7 = 0x007)
    //   llvm-mc: 7E020207
    uint64 v_mov_word = (0x3F << 25) | (0x01 << 17) | ((1 & 0xFF) << 9) | (7 & 0x1FF)
    asm_u32(v_mov_word)
    asm_global_store_b32(0, 1, 4)                  // *(s[4:5]) = v1  (saddr=4, raw SGPR index)
    asm_s_endpgm()

    uint64[2] args_desc
    uint64 adp0 = args_desc + 0;  unsafe { *(adp0 as uint64) = 8 }
    uint64 adp1 = args_desc + 8;  unsafe { *(adp1 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    // Second arg would be u32 count but for simplicity we reuse the
    // pointer-only desc: the caller still passes 8 bytes for the ptr.
    // For M1m demo we only need one declared arg and count comes
    // from the next 4 bytes of the kernarg segment — declare it
    // inline-by-hand instead. Use a larger args_desc.
    uint64[4] args_desc2
    uint64 a0 = args_desc2 + 0;   unsafe { *(a0 as uint64) = 8 }
    uint64 a1 = args_desc2 + 8;   unsafe { *(a1 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a2 = args_desc2 + 16;  unsafe { *(a2 as uint64) = 4 }
    uint64 a3 = args_desc2 + 24;  unsafe { *(a3 as uint64) = AMD_ARG_KIND_BY_VALUE }

    uint64 rsrc1 = 0xE0AF0000
    uint64 rsrc2 = 0x0000009E
    uint64 rsrc3 = 0x00000010
    uint64 props = 0x0408

    uint64 size = emit_amdgpu_code_object(kname, klen,
                                           asm_text_buf, asm_text_len,
                                           12,      // kernarg_size (ptr + u32)
                                           8,
                                           8,       // sgpr_count (s0..s7 used)
                                           2,       // vgpr_count
                                           rsrc1, rsrc2, rsrc3, props,
                                           args_desc2, 2)

    uint64 fd = file_open(out_path, 1)
    if fd > 0xFFFFFFFFFFFFF000 {
        write(2, "emit_amdgpu_loop_demo_blob: cannot open output\n", 47)
        return 1
    }
    file_write(fd, amd_buf, size)
    file_close(fd)
    return 0
}

// ---------------------------------------------------------------------------
// LLM Phase A milestone 1 — GEMV f32, native-emit replacement of the
// clang-built /tmp/gemv_f32.co reference. Bytes hand-extracted from
// llvm-mc -mcpu=gfx1100 disassembly of the hand-written reference at
// the comment block below; the dwords appear in the same order.
//
// Each lane computes one row of c[M] = A[M×K] · b[K]. Dispatch is
// (block=256, grid=ceil(M/256)). KD enables USER_SGPR_KERNARG_PTR=2
// and WORKGROUP_ID_X=1 with USER_SGPR_COUNT=15 (rsrc2=0x9E), so the
// GPU pre-loads s[0:1] = kernarg_ptr and wg_id_x = s15.
//
// Kernarg layout (40 bytes, 8-byte aligned):
//   [0..7]   a_ptr (u64)
//   [8..15]  b_ptr (u64)
//   [16..23] c_ptr (u64)
//   [24..31] m     (u64; only low 32 used by the kernel)
//   [32..39] k_dim (u64; only low 32 used by the kernel)
//
// Reference assembly (gfx1100, 47 dwords / 188 bytes):
//
//   s_load_b256       s[4:11], s[0:1], 0x0           ; a/b/c/m
//   s_load_b64        s[12:13], s[0:1], 0x20         ; k_dim
//   s_waitcnt         lgkmcnt(0)
//   s_mov_b32         s14, 0x100                     ; blockDim.x = 256
//   v_mad_u64_u32     v[1:2], null, s15, s14, v[0:1] ; row = wgid*256 + lane
//   s_mov_b32         s2, exec_lo                    ; (saveexec for cmpx)
//   v_cmpx_lt_u64     s[10:11], v[1:2]               ; exec &= row<m
//   s_cbranch_execz   .Lend
//   v_mul_lo_u32      v3, v1, s12                    ; row*k_dim (low 32)
//   v_mov_b32         v4, 0
//   v_lshlrev_b64     v[3:4], 2, v[3:4]              ; *4
//   v_add_co_u32      v3, vcc_lo, s4, v3             ; +a_ptr.lo
//   v_add_co_ci_u32   v4, null, s5, v4, vcc_lo       ; +a_ptr.hi
//   v_mov_b32         v5, 0                          ; sum
//   s_mov_b32         s14, 0                         ; k = 0
//   s_cmp_ge_u32      s14, s12
//   s_cbranch_scc1    .Lstore                        ; k_dim==0 fastpath
//   v_mov_b32         v6, 0                          ; b byte offset
// .Lloop:
//   global_load_b32   v7, v[3:4], off                ; A[row,k]
//   global_load_b32   v8, v6, s[6:7]                 ; b[k]
//   s_waitcnt         vmcnt(0)
//   v_fmac_f32_e32    v5, v7, v8
//   v_add_co_u32      v3, vcc_lo, v3, 4
//   v_add_co_ci_u32   v4, null, 0, v4, vcc_lo
//   v_add_nc_u32_e64  v6, v6, 4
//   s_add_u32         s14, s14, 1
//   s_cmp_lt_u32      s14, s12
//   s_cbranch_scc1    .Lloop
// .Lstore:
//   v_lshlrev_b32     v3, 2, v1                      ; row*4
//   global_store_b32  v3, v5, s[8:9]
//   s_waitcnt_vscnt   null, 0
// .Lend:
//   s_endpgm
@export
// Emit gemv_f32 ISA into asm_text_buf and fill the 5-arg args_desc.
// Shared by emit_amdgpu_gemv_f32_blob (file write) and the
// amdgpu_lower_llm_gemv_f32 routing path (kt_push for module emit).


// ─── Cooperative-row gemv ────────────────────────────────────────────
// Same kernarg layout as gemv_f32 but with a different threading
// strategy: ONE workgroup = ONE wave (32 threads) = ONE row.  All
// 32 lanes cooperatively read K stride-32 elements of A[row,*] and b,
// accumulate per-lane partial products, then LDS-reduce 32→1 and
// lane 0 stores c[row].
//
// Memory pattern: per VMEM instruction, the 32 lanes hit 32 *adjacent*
// f32 indices (one cache line, fully coalesced).  That fixes the
// large-N regression where the row-per-LANE gemv_f32 misses L1 on
// nearly every load (32 different row addresses per wave).
//
// REQUIRES: K is a multiple of 32.  All Qwen3 K values qualify
// (head_dim 128, hidden 1024, intermediate 3072).
fn _emit_gemv_coop_f32_body(uint64 args_desc) {
    asm_init()

    asm_u32_arch(0xF40C0100, 0xF40C0100); asm_u32_arch(0xF8000000, 0xFA000000) // s_load_b256/dwordx8
    asm_u32_arch(0xF4040300, 0xF4040300); asm_u32_arch(0xF8000020, 0xFA000020) // s_load_b64/dwordx2
    asm_u32_arch(0xBF89FC07, 0xBF8CC07F) // s_waitcnt

    asm_u32     (0xBF090A0F)             // s_cmp_ge_u32 s15, s10
    uint64 cbranch_end_idx = asm_text_len / 4
    asm_u32_arch(0xBFA20000, 0xBF850000) // s_cbranch_scc1 .Lend (patched)

    // s[16:17] = a_row_base = a_ptr + row*K*4
    asm_u32_arch(0x96100C0F, 0x93100C0F) // s_mul_i32  s16, s15, s12
    asm_u32_arch(0x84108210, 0x8F108210) // s_lshl_b32 s16, s16, 2
    asm_u32     (0x80101004)             // s_add_u32  s16, s4, s16  (SOP2 stable)
    asm_u32     (0x82118005)             // s_addc_u32 s17, s5, 0    (SOP2 stable)

    // Per-lane init.
    asm_u32_arch(0x300C0082, 0x340C0082) // v_lshlrev_b32 v6, 2, v0
    asm_v_mov_b32(7, 0x100 | 6)
    asm_v_mov_b32(5, 0x80)
    asm_u32_arch(0xBE920080, 0xBE920380) // s_mov_b32 s18, 0  (SOP1 reg-imm op shift)
    asm_u32_arch(0x8513880C, 0x9013880C) // s_lshr_b32 s19, s12, 8  (SOP2 op 0x0A → 0x20)

    // K-loop unrolled 8×.
    uint64 loop_idx = asm_text_len / 4
    asm_u32_arch(0xDC520000, 0xDC308000); asm_u32(0x08100007) // load v8, v7, s[16:17]
    asm_u32_arch(0xDC520000, 0xDC308000); asm_u32(0x09060007) // load v9, v7, s[6:7]
    asm_u32_arch(0xDC520080, 0xDC308080); asm_u32(0x0A100007) // load v10 offset:128
    asm_u32_arch(0xDC520080, 0xDC308080); asm_u32(0x0B060007) // load v11 offset:128
    asm_u32_arch(0xDC520100, 0xDC308100); asm_u32(0x0C100007) // load v12 offset:256
    asm_u32_arch(0xDC520100, 0xDC308100); asm_u32(0x0D060007) // load v13 offset:256
    asm_u32_arch(0xDC520180, 0xDC308180); asm_u32(0x0E100007) // load v14 offset:384
    asm_u32_arch(0xDC520180, 0xDC308180); asm_u32(0x0F060007) // load v15 offset:384
    asm_u32_arch(0xDC520200, 0xDC308200); asm_u32(0x10100007) // load v16 offset:512
    asm_u32_arch(0xDC520200, 0xDC308200); asm_u32(0x11060007) // load v17 offset:512
    asm_u32_arch(0xDC520280, 0xDC308280); asm_u32(0x12100007) // load v18 offset:640
    asm_u32_arch(0xDC520280, 0xDC308280); asm_u32(0x13060007) // load v19 offset:640
    asm_u32_arch(0xDC520300, 0xDC308300); asm_u32(0x14100007) // load v20 offset:768
    asm_u32_arch(0xDC520300, 0xDC308300); asm_u32(0x15060007) // load v21 offset:768
    asm_u32_arch(0xDC520380, 0xDC308380); asm_u32(0x16100007) // load v22 offset:896
    asm_u32_arch(0xDC520380, 0xDC308380); asm_u32(0x17060007) // load v23 offset:896
    asm_u32_arch(0xBF8903F7, 0xBF8C3F70) // s_waitcnt vmcnt(0)
    asm_u32     (0x560A1308); asm_u32(0x560A170A); asm_u32(0x560A1B0C); asm_u32(0x560A1F0E)
    asm_u32     (0x560A2310); asm_u32(0x560A2712); asm_u32(0x560A2B14); asm_u32(0x560A2F16)
    asm_u32     (0x4A0E0EFF); asm_u32(0x00000400) // v_add_nc_u32 v7, 0x400, v7 (VOP2 stable + literal)
    asm_u32     (0x80128112)             // s_add_u32 s18, s18, 1
    asm_u32     (0xBF0A1312)             // s_cmp_lt_u32 s18, s19
    uint64 loop_branch_idx = asm_text_len / 4
    uint64 back_simm = loop_idx - (loop_branch_idx + 1)
    uint64 sccbr_top = 0xBFA20000
    if _is_gfx10() != 0 { sccbr_top = 0xBF850000 }
    asm_u32(sccbr_top | (back_simm & 0xFFFF))

    asm_u32     (0xD8340000); asm_u32(0x00000506) // ds_store_b32 v6, v5
    asm_u32_arch(0xBF89FC07, 0xBF8CC07F)
    asm_u32_arch(0xBFBD0000, 0xBF8A0000) // s_barrier
    _emit_lds_reduce_pow2(32, 0x060A0F05, 14)

    asm_v_cmp_eq_u32_imm_vgpr(0, 0)
    asm_u32_arch(0xBE82206A, 0xBE823C6A) // s_and_saveexec_b32 s2, vcc_lo (SOP1 op shift)
    asm_v_mov_b32(3, 15)
    asm_u32_arch(0x30060682, 0x34060682) // v_lshlrev_b32 v3, 2, v3
    asm_u32_arch(0xDC6A0000, 0xDC708000); asm_u32(0x00080503) // global_store_b32
    asm_u32_arch(0xBC7C0000, 0xBBFD0000) // s_waitcnt_vscnt null, 0
    asm_u32_arch(0xBEFE0002, 0xBEFE0302) // s_mov_b32 exec_lo, s2

    asm_u32_arch(0xBFB00000, 0xBF810000) // s_endpgm

    uint64 total_dwords = asm_text_len / 4
    uint64 fwd_simm = total_dwords - cbranch_end_idx - 2
    asm_patch_u32(cbranch_end_idx, sccbr_top | (fwd_simm & 0xFFFF))

    uint64 a0 = args_desc + 0;   unsafe { *(a0 as uint64) = 8 }
    uint64 a1 = args_desc + 8;   unsafe { *(a1 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a2 = args_desc + 16;  unsafe { *(a2 as uint64) = 8 }
    uint64 a3 = args_desc + 24;  unsafe { *(a3 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a4 = args_desc + 32;  unsafe { *(a4 as uint64) = 8 }
    uint64 a5 = args_desc + 40;  unsafe { *(a5 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a6 = args_desc + 48;  unsafe { *(a6 as uint64) = 8 }
    uint64 a7 = args_desc + 56;  unsafe { *(a7 as uint64) = AMD_ARG_KIND_BY_VALUE }
    uint64 a8 = args_desc + 64;  unsafe { *(a8 as uint64) = 8 }
    uint64 a9 = args_desc + 72;  unsafe { *(a9 as uint64) = AMD_ARG_KIND_BY_VALUE }
}

// Batched-gemv: same as _emit_gemv_coop_f32_body but per-WG also reads
// a wg_id_y batch index from s16 (rsrc2 = 0x19E enables both X and Y
// workgroup IDs).  Shifts b_ptr by wg_id_y * K * 4 and c_ptr by
// wg_id_y * N * 4 so each (wg_x, wg_y) WG produces out[wg_y, wg_x].
// Caller dispatches grid = (N, batch_size, 1).
//
// At wg_id_y = 0 the math collapses to the base kernel — Phase 1.3
// uses this kernel for both batch=1 and batch>1, single binary.
fn _emit_gemv_coop_f32_batched_body(uint64 args_desc) {
    asm_init()

    asm_u32_arch(0xF40C0100, 0xF40C0100); asm_u32_arch(0xF8000000, 0xFA000000) // s_load_b256/dwordx8
    asm_u32_arch(0xF4040300, 0xF4040300); asm_u32_arch(0xF8000020, 0xFA000020) // s_load_b64/dwordx2
    asm_u32_arch(0xBF89FC07, 0xBF8CC07F) // s_waitcnt

    // batch-shift b_ptr += wg_y * K * 4
    asm_u32_arch(0x960E0C10, 0x930E0C10) // s_mul_i32  s14, s16, s12
    asm_u32_arch(0x840E820E, 0x8F0E820E) // s_lshl_b32 s14, s14, 2
    asm_u32     (0x80060E06)             // s_add_u32  s6, s6, s14
    asm_u32     (0x82078007)             // s_addc_u32 s7, s7, 0
    // batch-shift c_ptr += wg_y * N * 4
    asm_u32_arch(0x960E0A10, 0x930E0A10) // s_mul_i32  s14, s16, s10
    asm_u32_arch(0x840E820E, 0x8F0E820E) // s_lshl_b32 s14, s14, 2
    asm_u32     (0x80080E08)             // s_add_u32  s8, s8, s14
    asm_u32     (0x82098009)             // s_addc_u32 s9, s9, 0

    asm_u32     (0xBF090A0F)             // s_cmp_ge_u32 s15, s10
    uint64 cbranch_end_idx = asm_text_len / 4
    asm_u32_arch(0xBFA20000, 0xBF850000) // s_cbranch_scc1 .Lend (patched)

    // a_row_base = a_ptr + row*K*4
    asm_u32_arch(0x96100C0F, 0x93100C0F) // s_mul_i32  s16, s15, s12
    asm_u32_arch(0x84108210, 0x8F108210) // s_lshl_b32 s16, s16, 2
    asm_u32     (0x80101004)             // s_add_u32  s16, s4, s16
    asm_u32     (0x82118005)             // s_addc_u32 s17, s5, 0

    // Per-lane init.
    asm_u32_arch(0x300C0082, 0x340C0082) // v_lshlrev_b32 v6, 2, v0
    asm_v_mov_b32(7, 0x100 | 6)
    asm_v_mov_b32(5, 0x80)
    asm_u32_arch(0xBE920080, 0xBE920380) // s_mov_b32 s18, 0
    asm_u32_arch(0x8513880C, 0x9013880C) // s_lshr_b32 s19, s12, 8

    // K-loop unrolled 8×.
    uint64 loop_idx = asm_text_len / 4
    asm_u32_arch(0xDC520000, 0xDC308000); asm_u32(0x08100007)
    asm_u32_arch(0xDC520000, 0xDC308000); asm_u32(0x09060007)
    asm_u32_arch(0xDC520080, 0xDC308080); asm_u32(0x0A100007)
    asm_u32_arch(0xDC520080, 0xDC308080); asm_u32(0x0B060007)
    asm_u32_arch(0xDC520100, 0xDC308100); asm_u32(0x0C100007)
    asm_u32_arch(0xDC520100, 0xDC308100); asm_u32(0x0D060007)
    asm_u32_arch(0xDC520180, 0xDC308180); asm_u32(0x0E100007)
    asm_u32_arch(0xDC520180, 0xDC308180); asm_u32(0x0F060007)
    asm_u32_arch(0xDC520200, 0xDC308200); asm_u32(0x10100007)
    asm_u32_arch(0xDC520200, 0xDC308200); asm_u32(0x11060007)
    asm_u32_arch(0xDC520280, 0xDC308280); asm_u32(0x12100007)
    asm_u32_arch(0xDC520280, 0xDC308280); asm_u32(0x13060007)
    asm_u32_arch(0xDC520300, 0xDC308300); asm_u32(0x14100007)
    asm_u32_arch(0xDC520300, 0xDC308300); asm_u32(0x15060007)
    asm_u32_arch(0xDC520380, 0xDC308380); asm_u32(0x16100007)
    asm_u32_arch(0xDC520380, 0xDC308380); asm_u32(0x17060007)
    asm_u32_arch(0xBF8903F7, 0xBF8C3F70)
    asm_u32     (0x560A1308); asm_u32(0x560A170A); asm_u32(0x560A1B0C); asm_u32(0x560A1F0E)
    asm_u32     (0x560A2310); asm_u32(0x560A2712); asm_u32(0x560A2B14); asm_u32(0x560A2F16)
    asm_u32     (0x4A0E0EFF); asm_u32(0x00000400)
    asm_u32     (0x80128112)
    asm_u32     (0xBF0A1312)
    uint64 loop_branch_idx = asm_text_len / 4
    uint64 back_simm = loop_idx - (loop_branch_idx + 1)
    uint64 sccbr_top = 0xBFA20000
    if _is_gfx10() != 0 { sccbr_top = 0xBF850000 }
    asm_u32(sccbr_top | (back_simm & 0xFFFF))

    asm_u32     (0xD8340000); asm_u32(0x00000506)
    asm_u32_arch(0xBF89FC07, 0xBF8CC07F)
    asm_u32_arch(0xBFBD0000, 0xBF8A0000)
    _emit_lds_reduce_pow2(32, 0x060A0F05, 14)
    asm_v_cmp_eq_u32_imm_vgpr(0, 0)
    asm_u32_arch(0xBE82206A, 0xBE823C6A) // s_and_saveexec_b32 s2, vcc_lo
    asm_v_mov_b32(3, 15)
    asm_u32_arch(0x30060682, 0x34060682) // v_lshlrev_b32 v3, 2, v3
    asm_u32_arch(0xDC6A0000, 0xDC708000); asm_u32(0x00080503)
    asm_u32_arch(0xBC7C0000, 0xBBFD0000)
    asm_u32_arch(0xBEFE0002, 0xBEFE0302) // s_mov_b32 exec_lo, s2

    asm_u32_arch(0xBFB00000, 0xBF810000)

    uint64 total_dwords = asm_text_len / 4
    uint64 fwd_simm = total_dwords - cbranch_end_idx - 2
    asm_patch_u32(cbranch_end_idx, sccbr_top | (fwd_simm & 0xFFFF))

    uint64 a0 = args_desc + 0;   unsafe { *(a0 as uint64) = 8 }
    uint64 a1 = args_desc + 8;   unsafe { *(a1 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a2 = args_desc + 16;  unsafe { *(a2 as uint64) = 8 }
    uint64 a3 = args_desc + 24;  unsafe { *(a3 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a4 = args_desc + 32;  unsafe { *(a4 as uint64) = 8 }
    uint64 a5 = args_desc + 40;  unsafe { *(a5 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a6 = args_desc + 48;  unsafe { *(a6 as uint64) = 8 }
    uint64 a7 = args_desc + 56;  unsafe { *(a7 as uint64) = AMD_ARG_KIND_BY_VALUE }
    uint64 a8 = args_desc + 64;  unsafe { *(a8 as uint64) = 8 }
    uint64 a9 = args_desc + 72;  unsafe { *(a9 as uint64) = AMD_ARG_KIND_BY_VALUE }
}

@export
fn emit_amdgpu_gemv_coop_f32_batched_blob(uint64 out_path) -> uint64 {
    uint64[10] args_desc
    _emit_gemv_coop_f32_batched_body(args_desc)
    // rsrc2 = 0x19E enables BOTH workgroup_id_x (s15) AND
    // workgroup_id_y (s16).  Other fields identical to the
    // single-stream variant.
    uint64 size = emit_amdgpu_code_object_lds("gemv_coop_f32_batched", 21,
                                               asm_text_buf, asm_text_len,
                                               40, 8, 18, 32,
                                               0xE0AF0003, 0x0000019E, 0x00000010, 0x0408,
                                               args_desc, 5,
                                               128)
    uint64 fd = file_open(out_path, 1)
    if fd > 0xFFFFFFFFFFFFF000 {
        write(2, "emit_amdgpu_gemv_coop_f32_batched_blob: cannot open output\n", 60)
        return 1
    }
    file_write(fd, amd_buf, size)
    file_close(fd)
    return 0
}

fn emit_amdgpu_gemv_coop_f32_blob(uint64 out_path) -> uint64 {
    uint64[10] args_desc
    _emit_gemv_coop_f32_body(args_desc)

    // KD: num_user_sgprs=18, num_vgprs=32 with unroll 8× (v0..v23 used).
    // rsrc1=0xE0AF0003 sets VGPR granules=3 → 32 vgprs allocated.
    uint64 size = emit_amdgpu_code_object_lds("gemv_coop_f32", 13,
                                               asm_text_buf, asm_text_len,
                                               40, 8, 18, 32,
                                               0xE0AF0003, 0x0000009E, 0x00000010, 0x0408,
                                               args_desc, 5,
                                               128)
    uint64 fd = file_open(out_path, 1)
    if fd > 0xFFFFFFFFFFFFF000 {
        write(2, "emit_amdgpu_gemv_coop_f32_blob: cannot open output\n", 51)
        return 1
    }
    file_write(fd, amd_buf, size)
    file_close(fd)
    return 0
}

// ─── bf16-direct cooperative gemv ────────────────────────────────────
// Same shape and reduction strategy as gemv_coop_f32 but reads the
// weight matrix as bf16 (2 bytes/elem) directly from device memory,
// converts to f32 in-register via bit shifts, and accumulates.
//
// Memory bandwidth (vs gemv_coop_f32): A 4 → 2 bytes/elem.  For
// memory-bound shapes (lm_head, qkv, gate_up) net per-element bytes
// drop from 8 (f32) to 6 (bf16+f32 b) — ~25 % bandwidth saved.
// Also skips the dequant launch entirely (caller passes bf16 ptr).
//
// Kernarg layout: 5 args, identical to gemv_coop_f32 — drop-in.
// Block (32, 1, 1).  Grid (M, 1, 1).  LDS 128 B.
//
// REQUIRES: K is a multiple of 64 (4× unroll over 64-element strides).
// All Qwen3 K values qualify: 1024, 2048, 3072.
fn _emit_gemv_coop_bf16_f32_body(uint64 args_desc) {
    asm_init()

    asm_u32_arch(0xF40C0100, 0xF40C0100); asm_u32_arch(0xF8000000, 0xFA000000) // s_load_b256/dwordx8
    asm_u32_arch(0xF4040300, 0xF4040300); asm_u32_arch(0xF8000020, 0xFA000020) // s_load_b64/dwordx2
    asm_u32_arch(0xBF89FC07, 0xBF8CC07F)

    asm_u32     (0xBF090A0F)             // s_cmp_ge_u32 s15, s10
    uint64 cbranch_end_idx = asm_text_len / 4
    asm_u32_arch(0xBFA20000, 0xBF850000) // s_cbranch_scc1 .Lend

    asm_u32_arch(0x96100C0F, 0x93100C0F) // s_mul_i32 s16, s15, s12
    asm_u32_arch(0x84108110, 0x8F108110) // s_lshl_b32 s16, s16, 1 (×2 bf16)
    asm_u32     (0x80101004)             // s_add_u32 s16, s4, s16
    asm_u32     (0x82118005)             // s_addc_u32 s17, s5, 0

    asm_u32_arch(0x300C0082, 0x340C0082) // v_lshlrev_b32 v6, 2, v0
    asm_u32_arch(0x300E0081, 0x340E0081) // v_lshlrev_b32 v7, 1, v0
    asm_u32_arch(0x30100082, 0x34100082) // v_lshlrev_b32 v8, 2, v0
    asm_v_mov_b32(5, 0x80)
    asm_u32_arch(0xBE920080, 0xBE920380) // s_mov_b32 s18, 0
    asm_u32_arch(0x8513880C, 0x9013880C) // s_lshr_b32 s19, s12, 8

    uint64 loop_idx = asm_text_len / 4

    // 8 u16 A loads at offsets 0..448 step 64 bytes.
    asm_u32_arch(0xDC4A0000, 0xDC288000); asm_u32(0x09100007)
    asm_u32_arch(0xDC4A0040, 0xDC288040); asm_u32(0x0A100007)
    asm_u32_arch(0xDC4A0080, 0xDC288080); asm_u32(0x0B100007)
    asm_u32_arch(0xDC4A00C0, 0xDC2880C0); asm_u32(0x0C100007)
    asm_u32_arch(0xDC4A0100, 0xDC288100); asm_u32(0x0D100007)
    asm_u32_arch(0xDC4A0140, 0xDC288140); asm_u32(0x0E100007)
    asm_u32_arch(0xDC4A0180, 0xDC288180); asm_u32(0x0F100007)
    asm_u32_arch(0xDC4A01C0, 0xDC2881C0); asm_u32(0x10100007)

    // 8 b32 B loads at offsets 0..896 step 128 bytes.
    asm_u32_arch(0xDC520000, 0xDC308000); asm_u32(0x11060008)
    asm_u32_arch(0xDC520080, 0xDC308080); asm_u32(0x12060008)
    asm_u32_arch(0xDC520100, 0xDC308100); asm_u32(0x13060008)
    asm_u32_arch(0xDC520180, 0xDC308180); asm_u32(0x14060008)
    asm_u32_arch(0xDC520200, 0xDC308200); asm_u32(0x15060008)
    asm_u32_arch(0xDC520280, 0xDC308280); asm_u32(0x16060008)
    asm_u32_arch(0xDC520300, 0xDC308300); asm_u32(0x17060008)
    asm_u32_arch(0xDC520380, 0xDC308380); asm_u32(0x18060008)
    asm_u32_arch(0xBF8903F7, 0xBF8C3F70)

    // bf16 → f32 in-place via lshl 16.
    asm_u32_arch(0x30121290, 0x34121290)
    asm_u32_arch(0x30141490, 0x34141490)
    asm_u32_arch(0x30161690, 0x34161690)
    asm_u32_arch(0x30181890, 0x34181890)
    asm_u32_arch(0x301A1A90, 0x341A1A90)
    asm_u32_arch(0x301C1C90, 0x341C1C90)
    asm_u32_arch(0x301E1E90, 0x341E1E90)
    asm_u32_arch(0x30202090, 0x34202090)

    asm_u32     (0x560A2309); asm_u32(0x560A250A); asm_u32(0x560A270B); asm_u32(0x560A290C)
    asm_u32     (0x560A2B0D); asm_u32(0x560A2D0E); asm_u32(0x560A2F0F); asm_u32(0x560A3110)

    asm_u32     (0x4A0E0EFF); asm_u32(0x00000200) // v_add_nc_u32 v7, 0x200, v7
    asm_u32     (0x4A1010FF); asm_u32(0x00000400) // v_add_nc_u32 v8, 0x400, v8

    asm_u32     (0x80128112)
    asm_u32     (0xBF0A1312)
    uint64 loop_branch_idx = asm_text_len / 4
    uint64 back_simm = loop_idx - (loop_branch_idx + 1)
    uint64 sccbr_top = 0xBFA20000
    if _is_gfx10() != 0 { sccbr_top = 0xBF850000 }
    asm_u32(sccbr_top | (back_simm & 0xFFFF))

    asm_u32     (0xD8340000); asm_u32(0x00000506)
    asm_u32_arch(0xBF89FC07, 0xBF8CC07F)
    asm_u32_arch(0xBFBD0000, 0xBF8A0000)
    _emit_lds_reduce_pow2(32, 0x060A0F05, 14)

    asm_v_cmp_eq_u32_imm_vgpr(0, 0)
    asm_u32_arch(0xBE82206A, 0xBE823C6A)
    asm_v_mov_b32(3, 15)
    asm_u32_arch(0x30060682, 0x34060682)
    asm_u32_arch(0xDC6A0000, 0xDC708000); asm_u32(0x00080503)
    asm_u32_arch(0xBC7C0000, 0xBBFD0000)
    asm_u32_arch(0xBEFE0002, 0xBEFE0302)

    asm_u32_arch(0xBFB00000, 0xBF810000)

    uint64 total_dwords = asm_text_len / 4
    uint64 fwd_simm = total_dwords - cbranch_end_idx - 2
    asm_patch_u32(cbranch_end_idx, sccbr_top | (fwd_simm & 0xFFFF))

    uint64 a0 = args_desc + 0;   unsafe { *(a0 as uint64) = 8 }
    uint64 a1 = args_desc + 8;   unsafe { *(a1 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a2 = args_desc + 16;  unsafe { *(a2 as uint64) = 8 }
    uint64 a3 = args_desc + 24;  unsafe { *(a3 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a4 = args_desc + 32;  unsafe { *(a4 as uint64) = 8 }
    uint64 a5 = args_desc + 40;  unsafe { *(a5 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a6 = args_desc + 48;  unsafe { *(a6 as uint64) = 8 }
    uint64 a7 = args_desc + 56;  unsafe { *(a7 as uint64) = AMD_ARG_KIND_BY_VALUE }
    uint64 a8 = args_desc + 64;  unsafe { *(a8 as uint64) = 8 }
    uint64 a9 = args_desc + 72;  unsafe { *(a9 as uint64) = AMD_ARG_KIND_BY_VALUE }
}

fn emit_amdgpu_gemv_coop_bf16_f32_blob(uint64 out_path) -> uint64 {
    uint64[10] args_desc
    _emit_gemv_coop_bf16_f32_body(args_desc)

    // num_user_sgprs=18, num_vgprs=32 (v0..v24 used; granularity 8 → 32).
    // rsrc1=0xE0AF0003 sets VGPR granules=3 → 32 vgprs allocated per
    // wave.  0xE0AF0001 (16 vgprs) was the silent-corruption root for
    // earlier 4× attempts that wrote v16+.
    uint64 size = emit_amdgpu_code_object_lds("gemv_coop_bf16_f32", 18,
                                               asm_text_buf, asm_text_len,
                                               40, 8, 18, 32,
                                               0xE0AF0003, 0x0000009E, 0x00000010, 0x0408,
                                               args_desc, 5,
                                               128)
    uint64 fd = file_open(out_path, 1)
    if fd > 0xFFFFFFFFFFFFF000 {
        write(2, "emit_amdgpu_gemv_coop_bf16_f32_blob: cannot open output\n", 56)
        return 1
    }
    file_write(fd, amd_buf, size)
    file_close(fd)
    return 0
}

// ─── bf16-direct gemv mimicking CPU AVX2 reduction tree ───────────────
// Phase 1 of the Llama-3B bit-exactness project (2026-05-14).
//
// Standalone gfx1100 validator kernel: per-row dot product of bf16
// weight against f32 activation, BIT-IDENTICAL to the CPU
// `mm_worker_bf16_f32_avx2_naive` reference (std/matmul.mlr:313).  The
// production `gemv_coop_bf16_f32` uses a 32-thread XOR-butterfly reduce
// with offsets [16,8,4,2,1].  CPU AVX2 uses an 8-lane vhaddps tree with
// effective XOR offsets [4,1,2].  The two diverge at the 9th token in
// Llama-3B greedy decode because bf16 round-off is sensitive to the
// summation order.  This kernel mirrors CPU's exact tree.
//
// Layout per WG (only one wave32 active, 8 lanes contribute):
//   Lane j (0..7) accumulates s_j = sum over (k=j, j+8, j+16, ...)
//                                  of x[k]_f32 * bf16_widen(w[n*K + k])
//   via v_fmac_f32_e32 (single-rounded fused multiply-add).
//   Cross-lane reduce: XOR offsets [4, 1, 2] in that order,
//   matching   vextractf128+vaddps, vhaddps, vhaddps  on AVX2.
//
// Block (32,1,1), grid (N,1,1), kernarg layout (W,X,Y,N,K) — same as
// gemv_coop_bf16_f32 so the launcher can be a near-clone of the
// existing template.
//
// REQUIRES: K is a multiple of 8 (mirrors the AVX2 8-wide accumulator).
fn _emit_gemv_coop_bf16_f32_cputree_body(uint64 args_desc) {
    asm_init()

    // ── Stash WG_ID_X (s15) before any kernarg load touches s4..s15 ──
    // s_mov_b32 s2, s15  → 0xBE82000F
    asm_u32(0xBE82000F)

    // ── Load kernargs: W=s[4:5], X=s[6:7], Y=s[8:9], N=s[10:11], K=s[12:13]
    // (kernarg base ptr lives in s[0:1] under rsrc2=0x9E + user_sgpr_count=18).
    asm_u32(0xF40C0100); asm_u32(0xF8000000)  // s_load_b256 s[4:11], s[0:1], null
    asm_u32(0xF4040300); asm_u32(0xF8000020)  // s_load_b64  s[12:13], s[0:1], 0x20
    asm_s_waitcnt_lgkmcnt_zero()

    // ── Early exit: if wg_id_x (in s2) >= N (s10) skip body ────────────
    // s_cmp_ge_u32 s2, s10
    asm_u32(0xBF090A02)
    uint64 cbranch_end_idx = asm_text_len / 4
    asm_u32(0xBFA20000)                       // s_cbranch_scc1 .Lend (patched)

    // ── W += n * K * 2  (bf16 byte offset for row n) ───────────────────
    // s_mul_i32 s14, s2, s12   ; s14 = n * K
    //   SOP2 op 0x18: word = (2<<30)|(0x18<<23)|(s14<<16)|(s12<<8)|s2
    //                       = 0x96000000|(14<<16)|(12<<8)|2 = 0x960E0C02
    asm_u32(0x960E0C02)
    // s_lshl_b32 s14, s14, 1   ; ×2 bytes
    //   SOP2 op 0x08: word = (2<<30)|(0x08<<23)|(14<<16)|(0x81<<8)|14
    //                      = 0x84000000|(14<<16)|0x8100|14 = 0x840E810E
    asm_u32(0x840E810E)
    // s_add_u32 s4, s4, s14
    asm_u32(0x80040E04)
    // s_addc_u32 s5, s5, 0
    asm_u32(0x82058005)

    // ── Y += n * 4 (output byte offset for row n) ──────────────────────
    // s_lshl_b32 s14, s2, 2
    asm_u32(0x840E8202)
    // s_add_u32 s8, s8, s14
    asm_u32(0x80080E08)
    // s_addc_u32 s9, s9, 0
    asm_u32(0x82098009)

    // ── Per-lane init (FULL EXEC so inactive lanes' v2 stays 0) ────────
    // v2 = acc = 0.0  — initialise in ALL lanes; the FMA loop only fires
    // on lanes 0..7 under narrowed EXEC, so lanes 8..31 keep v2=0 and the
    // post-loop XOR-bpermute reduce can run with full EXEC without
    // polluting the dot-product with whatever lanes 8..31 leaked.
    asm_v_mov_b32_inline_u(2, 0)
    // v3 = lane*2  (bf16 byte offset)
    asm_v_lshlrev_b32_imm(3, 1, 0)
    // v4 = lane*4  (f32 byte offset)
    asm_v_lshlrev_b32_imm(4, 2, 0)

    // ── Narrow EXEC to lanes 0..7 ──────────────────────────────────────
    asm_s_mov_b32_lit32(0x7E, 0x000000FF)     // s_mov_b32 exec_lo, 0xFF

    // ── Per-lane weight ptr v[5:6] = W + lane*2 ────────────────────────
    asm_v_mov_b32_inline_u(6, 0)
    asm_v_add_co_u32_vcc_sv(5, 4, 3)                 // v5 = s4 + v3, vcc=carry
    asm_v_add_co_ci_u32_null_sv_vcc(6, 5, 6)         // v6 = s5 + v6 + carry

    // ── Per-lane x ptr v[7:8] = X + lane*4 ─────────────────────────────
    asm_v_mov_b32_inline_u(8, 0)
    asm_v_add_co_u32_vcc_sv(7, 6, 4)                 // v7 = s6 + v4
    asm_v_add_co_ci_u32_null_sv_vcc(8, 7, 8)         // v8 = s7 + v8 + carry

    // ── K-loop counter: s14 = K / 8 ────────────────────────────────────
    // s_lshr_b32 s14, s12, 3
    //   SOP2 op 0x0A (verified against existing emit at line 6039):
    //   word = (2<<30)|(0x0A<<23)|(14<<16)|(0x83<<8)|s12
    //        = 0x85000000|(14<<16)|0x8300|12 = 0x850E830C
    asm_u32(0x850E830C)

    // ── Inner K-loop ───────────────────────────────────────────────────
    // Each iter: load u16 w, load b32 x, widen, fmac, advance ptrs by
    // (lanes*2)=16 bytes for w and (lanes*4)=32 bytes for x.
    uint64 loop_idx = asm_text_len / 4

    // global_load_u16 v9, v[5:6], off
    //   word1 = 0xDC4A0000, word2 = (vdst=9<<24)|(saddr=0x7C<<16)|vaddr=5
    //   With saddr=null (0x7C) we use the VGPR pair as the full address.
    //   Reference asm_s_load convention: for FLAT/GLOBAL with NULL saddr,
    //   saddr field = 0x7C.  Verified in the existing emit at offset 0x1644
    //   `global_load_u16 v9, v7, s[16:17]` = 0xDC4A0000 0x09100007  →
    //   saddr=0x10 (s16/2=8 actually; we want pure VGPR addr).
    //   For pure-VGPR addressing we set saddr=0x7C (NULL).
    asm_u32(0xDC4A0000); asm_u32(0x097C0005)

    // global_load_b32 v10, v[7:8], off
    asm_u32(0xDC520000); asm_u32(0x0A7C0007)

    asm_s_waitcnt_vmcnt_zero()

    // v_lshlrev_b32 v9, 16, v9        ; bf16 → f32 widen
    asm_v_lshlrev_b32_imm(9, 16, 9)

    // v_fmac_f32_e32 v2, v9, v10      ; acc += w_widen * x  (single-rounded FMA)
    asm_v_fmac_f32_e32_vv(2, 9, 10)

    // v_add_co_u32 v5, vcc, 16, v5    ; w_ptr += 16 bytes
    //   Use inline-imm src0 via v_add_nc_u32 (no carry-out) — but we need
    //   carry for the 64-bit addr.  Use VOP3 v_add_co_u32 with src0=lit16.
    //   Easiest: emit "v_add_nc_u32 v5, 16, v5" (VOP2 op 0x25) and skip
    //   the carry — but that risks page-cross on huge K.  For K up to ~64K
    //   the low 32 bits won't overflow because we start at a 64-bit ptr
    //   aligned and only add K*2 bytes per iter total.  Llama K=3072 →
    //   384 iters × 16B = 6144 bytes total; tiny.  Use VOP2 v_add_nc_u32.
    //   asm_u32(0x4A0A0A90) = v_add_nc_u32_e32 v5, 16, v5
    //   VOP2 op 0x25 → 0x4A<<24 prefix... let me just emit with literal.
    //   v_add_nc_u32_e32 vdst, lit32, vsrc1: word = (0x25<<25)|(vdst<<17)|(vsrc1<<9)|0xFF, then lit32.
    asm_u32(0x4A0A0AFF); asm_u32(16)          // v_add_nc_u32 v5, 0x10, v5
    asm_u32(0x4A0E0EFF); asm_u32(32)          // v_add_nc_u32 v7, 0x20, v7

    // s_sub_u32 s14, s14, 1
    asm_s_sub_u32_imm(14, 14, 1)
    // s_cmp_lg_u32 s14, 0  (loop while != 0)
    //   SOPC op 0x07 (ne_u32): word = 0xBF000000|(0x07<<16)|(0x80<<8)|s14
    asm_u32(0xBF07800E)
    uint64 loop_branch_idx = asm_text_len / 4
    uint64 back_simm = (loop_idx - (loop_branch_idx + 1)) & 0xFFFF
    asm_s_cbranch_scc1(back_simm)

    // ── Restore EXEC to full wave32 for cross-lane reduce ──────────────
    // Lanes 8..31 never ran the FMA loop (they were masked out by the
    // narrow-exec gate) so their v2 still holds the 0 we initialised
    // before the gate — they contribute zeros into the XOR-bpermute and
    // do not pollute the lane-0 final sum.
    asm_s_mov_b32_lit32(0x7E, 0xFFFFFFFF)

    // ── CPU-tree reduce: XOR offsets [4, 1, 2] in that order ───────────
    // Per level: v_xor_b32 v11, off, v0; v_lshlrev_b32 v11, 2, v11;
    //            ds_bpermute_b32 v12, v11, v2; s_waitcnt lgkmcnt(0);
    //            v_add_f32_e32 v2, v2, v12
    //
    // VOP2 v_add_f32_e32 v2, v2, v12 encoding:
    //   op 0x03: word = (3<<25)|(2<<17)|(12<<9)|(0x100|2) = 0x06041902
    uint64 add_word = 0x06000000 | (2 << 17) | (12 << 9) | (0x100 | 2)

    // Step 1: offset 4
    _emit_v_xor_b32_e32_imm_v0(11, 4)
    asm_v_lshlrev_b32_imm(11, 2, 11)
    asm_ds_bpermute_b32(12, 11, 2)
    asm_s_waitcnt_lgkmcnt_zero()
    asm_u32(add_word)

    // Step 2: offset 1
    _emit_v_xor_b32_e32_imm_v0(11, 1)
    asm_v_lshlrev_b32_imm(11, 2, 11)
    asm_ds_bpermute_b32(12, 11, 2)
    asm_s_waitcnt_lgkmcnt_zero()
    asm_u32(add_word)

    // Step 3: offset 2
    _emit_v_xor_b32_e32_imm_v0(11, 2)
    asm_v_lshlrev_b32_imm(11, 2, 11)
    asm_ds_bpermute_b32(12, 11, 2)
    asm_s_waitcnt_lgkmcnt_zero()
    asm_u32(add_word)

    // ── Lane-0 gated store of v2 to Y[n] ───────────────────────────────
    asm_v_cmp_eq_u32_imm_vgpr(0, 0)             // vcc_lo = (v0 == 0)
    asm_s_and_saveexec_b32_vcc_lo(16)           // s16 = old exec; exec &= vcc_lo
    asm_v_mov_b32_inline_u(1, 0)                // v1 = 0  (vaddr offset)
    asm_global_store_b32(1, 2, 8)               // Y[n] = v2 ; s[8:9] holds Y (saddr is raw SGPR idx)
    // s_or_b32 exec_lo, exec_lo, s16  → restore exec
    //   SOP2 op 0x0B (s_or_b32): sdst=0x7E exec_lo, ssrc0=0x7E exec_lo, ssrc1=s16
    //   word = (2<<30)|(0x0B<<23)|(0x7E<<16)|(0x10<<8)|0x7E = 0x8C7E107E
    asm_u32(0x8C7E107E)

    asm_s_endpgm()

    // ── Patch the early-exit branch ────────────────────────────────────
    // Target = the s_endpgm dword (penultimate emit) so the wave cleanly
    // terminates instead of running off the end.  Pattern mirrors
    // _emit_gemv_coop_bf16_f32_body (offset = total - cbranch_idx - 2).
    uint64 total_dwords = asm_text_len / 4
    uint64 fwd_simm = (total_dwords - cbranch_end_idx - 2) & 0xFFFF
    asm_patch_u32(cbranch_end_idx, 0xBFA20000 | fwd_simm)

    // ── Args descriptor: 5 args, all 8 bytes (matches gemv_coop_bf16_f32). ─
    uint64 a0 = args_desc + 0;   unsafe { *(a0 as uint64) = 8 }
    uint64 a1 = args_desc + 8;   unsafe { *(a1 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a2 = args_desc + 16;  unsafe { *(a2 as uint64) = 8 }
    uint64 a3 = args_desc + 24;  unsafe { *(a3 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a4 = args_desc + 32;  unsafe { *(a4 as uint64) = 8 }
    uint64 a5 = args_desc + 40;  unsafe { *(a5 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a6 = args_desc + 48;  unsafe { *(a6 as uint64) = 8 }
    uint64 a7 = args_desc + 56;  unsafe { *(a7 as uint64) = AMD_ARG_KIND_BY_VALUE }
    uint64 a8 = args_desc + 64;  unsafe { *(a8 as uint64) = 8 }
    uint64 a9 = args_desc + 72;  unsafe { *(a9 as uint64) = AMD_ARG_KIND_BY_VALUE }
}

fn emit_amdgpu_gemv_coop_bf16_f32_cputree_blob(uint64 out_path) -> uint64 {
    uint64[10] args_desc
    _emit_gemv_coop_bf16_f32_cputree_body(args_desc)

    // Mirror gemv_coop_bf16_f32's KD: rsrc1=0xE0AF0003 (32 VGPRs),
    // rsrc2=0x9E (enables wg_id_x at s15 + the standard preset SGPRs),
    // kernarg_size=40, sgpr_count=18, vgpr_count=32, group_segment=0
    // (this kernel does NOT use LDS; pass 0 to be safe).
    uint64 size = emit_amdgpu_code_object_lds("gemv_coop_bf16_f32_cputree", 26,
                                               asm_text_buf, asm_text_len,
                                               40, 8, 18, 32,
                                               0xE0AF0003, 0x0000009E, 0x00000010, 0x0408,
                                               args_desc, 5,
                                               0)
    uint64 fd = file_open(out_path, 1)
    if fd > 0xFFFFFFFFFFFFF000 {
        write(2, "emit_amdgpu_gemv_coop_bf16_f32_cputree_blob: cannot open output\n", 64)
        return 1
    }
    file_write(fd, amd_buf, size)
    file_close(fd)
    return 0
}

// ─── Phase F3a: fp32 weight × fp32 act cooperative gemv with CPU-vhaddps tree ──
//
// Mirrors _emit_gemv_coop_bf16_f32_cputree_body with three differences:
//   1. Weights are full f32 (4 bytes/elem) — global_load_b32 instead of
//      global_load_u16, and the per-row W byte offset is n * K * 4.
//   2. NO bf16 widen step (no v_lshlrev_b32 v9, 16, v9).
//   3. Inner-loop w_ptr advance is +32 bytes (8 lanes × 4B f32), not +16.
// Everything else (8-lane exec narrow, single v_fmac_f32, exec restore,
// 3-level [4,1,2] XOR-bpermute reduce, lane-0 store) is identical.
fn _emit_gemv_coop_f32_f32_cputree_body(uint64 args_desc) {
    asm_init()

    // ── Stash WG_ID_X (s15) before any kernarg load touches s4..s15 ──
    // s_mov_b32 s2, s15  → 0xBE82000F
    asm_u32(0xBE82000F)

    // ── Load kernargs: W=s[4:5], X=s[6:7], Y=s[8:9], N=s[10:11], K=s[12:13]
    asm_u32(0xF40C0100); asm_u32(0xF8000000)  // s_load_b256 s[4:11], s[0:1], null
    asm_u32(0xF4040300); asm_u32(0xF8000020)  // s_load_b64  s[12:13], s[0:1], 0x20
    asm_s_waitcnt_lgkmcnt_zero()

    // ── Early exit: if wg_id_x (in s2) >= N (s10) skip body ────────────
    // s_cmp_ge_u32 s2, s10
    asm_u32(0xBF090A02)
    uint64 cbranch_end_idx = asm_text_len / 4
    asm_u32(0xBFA20000)                       // s_cbranch_scc1 .Lend (patched)

    // ── W += n * K * 4  (f32 byte offset for row n) ────────────────────
    // s_mul_i32 s14, s2, s12   ; s14 = n * K
    asm_u32(0x960E0C02)
    // s_lshl_b32 s14, s14, 2   ; ×4 bytes (f32) — was ×2 (bf16)
    //   SOP2 op 0x08: word = (2<<30)|(0x08<<23)|(14<<16)|(0x82<<8)|14
    //                      = 0x84000000|(14<<16)|0x8200|14 = 0x840E820E
    asm_u32(0x840E820E)
    // s_add_u32 s4, s4, s14
    asm_u32(0x80040E04)
    // s_addc_u32 s5, s5, 0
    asm_u32(0x82058005)

    // ── Y += n * 4 (output byte offset for row n) ──────────────────────
    // s_lshl_b32 s14, s2, 2
    asm_u32(0x840E8202)
    // s_add_u32 s8, s8, s14
    asm_u32(0x80080E08)
    // s_addc_u32 s9, s9, 0
    asm_u32(0x82098009)

    // ── Per-lane init (FULL EXEC so inactive lanes' v2 stays 0) ────────
    asm_v_mov_b32_inline_u(2, 0)
    // v3 = lane*4  (f32 weight byte offset) — was lane*2 for bf16
    asm_v_lshlrev_b32_imm(3, 2, 0)
    // v4 = lane*4  (f32 act byte offset) — unchanged
    asm_v_lshlrev_b32_imm(4, 2, 0)

    // ── Narrow EXEC to lanes 0..7 ──────────────────────────────────────
    asm_s_mov_b32_lit32(0x7E, 0x000000FF)     // s_mov_b32 exec_lo, 0xFF

    // ── Per-lane weight ptr v[5:6] = W + lane*4 ────────────────────────
    asm_v_mov_b32_inline_u(6, 0)
    asm_v_add_co_u32_vcc_sv(5, 4, 3)                 // v5 = s4 + v3
    asm_v_add_co_ci_u32_null_sv_vcc(6, 5, 6)         // v6 = s5 + v6 + carry

    // ── Per-lane x ptr v[7:8] = X + lane*4 ─────────────────────────────
    asm_v_mov_b32_inline_u(8, 0)
    asm_v_add_co_u32_vcc_sv(7, 6, 4)                 // v7 = s6 + v4
    asm_v_add_co_ci_u32_null_sv_vcc(8, 7, 8)         // v8 = s7 + v8 + carry

    // ── K-loop counter: s14 = K / 8 ────────────────────────────────────
    // s_lshr_b32 s14, s12, 3
    asm_u32(0x850E830C)

    // ── Inner K-loop ───────────────────────────────────────────────────
    // Each iter: load b32 w (f32), load b32 x (f32), fmac, advance ptrs
    // by (lanes*4)=32 bytes for w and (lanes*4)=32 bytes for x.
    uint64 loop_idx = asm_text_len / 4

    // global_load_b32 v9, v[5:6], off  ; f32 weight (was global_load_u16)
    //   word1 = 0xDC520000 (op 0x14 = LOAD_B32), word2 = (vdst=9<<24)|(saddr=0x7C<<16)|vaddr=5
    asm_u32(0xDC520000); asm_u32(0x097C0005)

    // global_load_b32 v10, v[7:8], off  ; f32 x (unchanged)
    asm_u32(0xDC520000); asm_u32(0x0A7C0007)

    asm_s_waitcnt_vmcnt_zero()

    // NOTE: bf16-widen step removed (no v_lshlrev_b32 v9, 16, v9).

    // v_fmac_f32_e32 v2, v9, v10      ; acc += w * x
    asm_v_fmac_f32_e32_vv(2, 9, 10)

    // v_add_nc_u32 v5, 32, v5   ; w_ptr += 32 (8 lanes × 4B f32) — was 16
    asm_u32(0x4A0A0AFF); asm_u32(32)
    // v_add_nc_u32 v7, 32, v7   ; x_ptr += 32 — unchanged
    asm_u32(0x4A0E0EFF); asm_u32(32)

    // s_sub_u32 s14, s14, 1
    asm_s_sub_u32_imm(14, 14, 1)
    // s_cmp_lg_u32 s14, 0  (loop while != 0)
    asm_u32(0xBF07800E)
    uint64 loop_branch_idx = asm_text_len / 4
    uint64 back_simm = (loop_idx - (loop_branch_idx + 1)) & 0xFFFF
    asm_s_cbranch_scc1(back_simm)

    // ── Restore EXEC to full wave32 for cross-lane reduce ──────────────
    asm_s_mov_b32_lit32(0x7E, 0xFFFFFFFF)

    // ── CPU-tree reduce: XOR offsets [4, 1, 2] in that order ───────────
    // VOP2 v_add_f32_e32 v2, v2, v12 encoding:
    uint64 add_word = 0x06000000 | (2 << 17) | (12 << 9) | (0x100 | 2)

    // Step 1: offset 4
    _emit_v_xor_b32_e32_imm_v0(11, 4)
    asm_v_lshlrev_b32_imm(11, 2, 11)
    asm_ds_bpermute_b32(12, 11, 2)
    asm_s_waitcnt_lgkmcnt_zero()
    asm_u32(add_word)

    // Step 2: offset 1
    _emit_v_xor_b32_e32_imm_v0(11, 1)
    asm_v_lshlrev_b32_imm(11, 2, 11)
    asm_ds_bpermute_b32(12, 11, 2)
    asm_s_waitcnt_lgkmcnt_zero()
    asm_u32(add_word)

    // Step 3: offset 2
    _emit_v_xor_b32_e32_imm_v0(11, 2)
    asm_v_lshlrev_b32_imm(11, 2, 11)
    asm_ds_bpermute_b32(12, 11, 2)
    asm_s_waitcnt_lgkmcnt_zero()
    asm_u32(add_word)

    // ── Lane-0 gated store of v2 to Y[n] ───────────────────────────────
    asm_v_cmp_eq_u32_imm_vgpr(0, 0)             // vcc_lo = (v0 == 0)
    asm_s_and_saveexec_b32_vcc_lo(16)           // s16 = old exec; exec &= vcc_lo
    asm_v_mov_b32_inline_u(1, 0)                // v1 = 0  (vaddr offset)
    asm_global_store_b32(1, 2, 8)               // Y[n] = v2
    // s_or_b32 exec_lo, exec_lo, s16
    asm_u32(0x8C7E107E)

    asm_s_endpgm()

    // ── Patch the early-exit branch ────────────────────────────────────
    uint64 total_dwords = asm_text_len / 4
    uint64 fwd_simm = (total_dwords - cbranch_end_idx - 2) & 0xFFFF
    asm_patch_u32(cbranch_end_idx, 0xBFA20000 | fwd_simm)

    // ── Args descriptor: 5 args, all 8 bytes ──────────────────────────
    uint64 a0 = args_desc + 0;   unsafe { *(a0 as uint64) = 8 }
    uint64 a1 = args_desc + 8;   unsafe { *(a1 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a2 = args_desc + 16;  unsafe { *(a2 as uint64) = 8 }
    uint64 a3 = args_desc + 24;  unsafe { *(a3 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a4 = args_desc + 32;  unsafe { *(a4 as uint64) = 8 }
    uint64 a5 = args_desc + 40;  unsafe { *(a5 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a6 = args_desc + 48;  unsafe { *(a6 as uint64) = 8 }
    uint64 a7 = args_desc + 56;  unsafe { *(a7 as uint64) = AMD_ARG_KIND_BY_VALUE }
    uint64 a8 = args_desc + 64;  unsafe { *(a8 as uint64) = 8 }
    uint64 a9 = args_desc + 72;  unsafe { *(a9 as uint64) = AMD_ARG_KIND_BY_VALUE }
}

fn emit_amdgpu_gemv_coop_f32_f32_cputree_blob(uint64 out_path) -> uint64 {
    uint64[10] args_desc
    _emit_gemv_coop_f32_f32_cputree_body(args_desc)

    // Same KD as bf16 cputree (32 VGPRs, 18 SGPRs, rsrc2=0x9E, no LDS).
    uint64 size = emit_amdgpu_code_object_lds("gemv_coop_f32_f32_cputree", 25,
                                               asm_text_buf, asm_text_len,
                                               40, 8, 18, 32,
                                               0xE0AF0003, 0x0000009E, 0x00000010, 0x0408,
                                               args_desc, 5,
                                               0)
    uint64 fd = file_open(out_path, 1)
    if fd > 0xFFFFFFFFFFFFF000 {
        write(2, "emit_amdgpu_gemv_coop_f32_f32_cputree_blob: cannot open output\n", 63)
        return 1
    }
    file_write(fd, amd_buf, size)
    file_close(fd)
    return 0
}

// ─── bf16-direct cooperative gemv, batched (M streams) ───────────────
// Same shape as gemv_coop_bf16_f32 but reads wg_id_y from s16 (rsrc2 =
// 0x019E) and shifts b_ptr by wg_y*K*4 / c_ptr by wg_y*N*4 so each
// (wg_x, wg_y) WG produces out[wg_y, wg_x].  A (bf16 weight) is shared
// across the batch — no wg_y shift on a_ptr.  Caller dispatches grid
// = (N, batch_size, 1).
//
// At wg_id_y = 0 collapses to the single-stream bf16 kernel — drop-in
// replacement for memory-bound shapes (lm_head batched, qkv-batched,
// gate_up-batched) when MLRIFT_GPU_MATMUL_BF16=1.
//
// REQUIRES: K is a multiple of 256 (8× unroll over 256-element strides
// at 32 lanes — 8 strides × 32 lanes = 256 elems / iter).
fn _emit_gemv_coop_bf16_f32_batched_body(uint64 args_desc) {
    asm_init()

    // Prologue: kernarg load.
    asm_u32_arch(0xF40C0100, 0xF40C0100); asm_u32_arch(0xF8000000, 0xFA000000)
    asm_u32_arch(0xF4040300, 0xF4040300); asm_u32_arch(0xF8000020, 0xFA000020)
    asm_u32_arch(0xBF89FC07, 0xBF8CC07F)

    // batch-shift b_ptr += wg_y * K * 4
    asm_u32_arch(0x960E0C10, 0x930E0C10) // s_mul_i32 s14, s16, s12
    asm_u32_arch(0x840E820E, 0x8F0E820E) // s_lshl_b32 s14, s14, 2
    asm_u32     (0x80060E06)
    asm_u32     (0x82078007)
    // batch-shift c_ptr += wg_y * N * 4
    asm_u32_arch(0x960E0A10, 0x930E0A10) // s_mul_i32 s14, s16, s10
    asm_u32_arch(0x840E820E, 0x8F0E820E) // s_lshl_b32 s14, s14, 2
    asm_u32     (0x80080E08)
    asm_u32     (0x82098009)

    asm_u32     (0xBF090A0F)             // s_cmp_ge_u32 s15, s10
    uint64 cbranch_end_idx = asm_text_len / 4
    asm_u32_arch(0xBFA20000, 0xBF850000) // s_cbranch_scc1 .Lend

    asm_u32_arch(0x96100C0F, 0x93100C0F) // s_mul_i32 s16, s15, s12
    asm_u32_arch(0x84108110, 0x8F108110) // s_lshl_b32 s16, s16, 1
    asm_u32     (0x80101004)             // s_add_u32 s16, s4, s16
    asm_u32     (0x82118005)             // s_addc_u32 s17, s5, 0

    asm_u32_arch(0x300C0082, 0x340C0082) // v_lshlrev_b32 v6, 2, v0
    asm_u32_arch(0x300E0081, 0x340E0081) // v_lshlrev_b32 v7, 1, v0
    asm_u32_arch(0x30100082, 0x34100082) // v_lshlrev_b32 v8, 2, v0
    asm_v_mov_b32(5, 0x80)
    asm_u32_arch(0xBE920080, 0xBE920380) // s_mov_b32 s18, 0
    asm_u32_arch(0x8513880C, 0x9013880C) // s_lshr_b32 s19, s12, 8

    uint64 loop_idx = asm_text_len / 4

    asm_u32_arch(0xDC4A0000, 0xDC288000); asm_u32(0x09100007)
    asm_u32_arch(0xDC4A0040, 0xDC288040); asm_u32(0x0A100007)
    asm_u32_arch(0xDC4A0080, 0xDC288080); asm_u32(0x0B100007)
    asm_u32_arch(0xDC4A00C0, 0xDC2880C0); asm_u32(0x0C100007)
    asm_u32_arch(0xDC4A0100, 0xDC288100); asm_u32(0x0D100007)
    asm_u32_arch(0xDC4A0140, 0xDC288140); asm_u32(0x0E100007)
    asm_u32_arch(0xDC4A0180, 0xDC288180); asm_u32(0x0F100007)
    asm_u32_arch(0xDC4A01C0, 0xDC2881C0); asm_u32(0x10100007)

    asm_u32_arch(0xDC520000, 0xDC308000); asm_u32(0x11060008)
    asm_u32_arch(0xDC520080, 0xDC308080); asm_u32(0x12060008)
    asm_u32_arch(0xDC520100, 0xDC308100); asm_u32(0x13060008)
    asm_u32_arch(0xDC520180, 0xDC308180); asm_u32(0x14060008)
    asm_u32_arch(0xDC520200, 0xDC308200); asm_u32(0x15060008)
    asm_u32_arch(0xDC520280, 0xDC308280); asm_u32(0x16060008)
    asm_u32_arch(0xDC520300, 0xDC308300); asm_u32(0x17060008)
    asm_u32_arch(0xDC520380, 0xDC308380); asm_u32(0x18060008)
    asm_u32_arch(0xBF8903F7, 0xBF8C3F70)

    asm_u32_arch(0x30121290, 0x34121290)
    asm_u32_arch(0x30141490, 0x34141490)
    asm_u32_arch(0x30161690, 0x34161690)
    asm_u32_arch(0x30181890, 0x34181890)
    asm_u32_arch(0x301A1A90, 0x341A1A90)
    asm_u32_arch(0x301C1C90, 0x341C1C90)
    asm_u32_arch(0x301E1E90, 0x341E1E90)
    asm_u32_arch(0x30202090, 0x34202090)

    asm_u32     (0x560A2309); asm_u32(0x560A250A); asm_u32(0x560A270B); asm_u32(0x560A290C)
    asm_u32     (0x560A2B0D); asm_u32(0x560A2D0E); asm_u32(0x560A2F0F); asm_u32(0x560A3110)

    asm_u32     (0x4A0E0EFF); asm_u32(0x00000200)
    asm_u32     (0x4A1010FF); asm_u32(0x00000400)

    asm_u32     (0x80128112)
    asm_u32     (0xBF0A1312)
    uint64 loop_branch_idx = asm_text_len / 4
    uint64 back_simm = loop_idx - (loop_branch_idx + 1)
    uint64 sccbr_top = 0xBFA20000
    if _is_gfx10() != 0 { sccbr_top = 0xBF850000 }
    asm_u32(sccbr_top | (back_simm & 0xFFFF))

    asm_u32     (0xD8340000); asm_u32(0x00000506)
    asm_u32_arch(0xBF89FC07, 0xBF8CC07F)
    asm_u32_arch(0xBFBD0000, 0xBF8A0000)
    _emit_lds_reduce_pow2(32, 0x060A0F05, 14)
    asm_v_cmp_eq_u32_imm_vgpr(0, 0)
    asm_u32_arch(0xBE82206A, 0xBE823C6A)
    asm_v_mov_b32(3, 15)
    asm_u32_arch(0x30060682, 0x34060682)
    asm_u32_arch(0xDC6A0000, 0xDC708000); asm_u32(0x00080503)
    asm_u32_arch(0xBC7C0000, 0xBBFD0000)
    asm_u32_arch(0xBEFE0002, 0xBEFE0302)

    asm_u32_arch(0xBFB00000, 0xBF810000)

    uint64 total_dwords = asm_text_len / 4
    uint64 fwd_simm = total_dwords - cbranch_end_idx - 2
    asm_patch_u32(cbranch_end_idx, sccbr_top | (fwd_simm & 0xFFFF))

    uint64 a0 = args_desc + 0;   unsafe { *(a0 as uint64) = 8 }
    uint64 a1 = args_desc + 8;   unsafe { *(a1 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a2 = args_desc + 16;  unsafe { *(a2 as uint64) = 8 }
    uint64 a3 = args_desc + 24;  unsafe { *(a3 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a4 = args_desc + 32;  unsafe { *(a4 as uint64) = 8 }
    uint64 a5 = args_desc + 40;  unsafe { *(a5 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a6 = args_desc + 48;  unsafe { *(a6 as uint64) = 8 }
    uint64 a7 = args_desc + 56;  unsafe { *(a7 as uint64) = AMD_ARG_KIND_BY_VALUE }
    uint64 a8 = args_desc + 64;  unsafe { *(a8 as uint64) = 8 }
    uint64 a9 = args_desc + 72;  unsafe { *(a9 as uint64) = AMD_ARG_KIND_BY_VALUE }
}

@export
fn emit_amdgpu_gemv_coop_bf16_f32_batched_blob(uint64 out_path) -> uint64 {
    uint64[10] args_desc
    _emit_gemv_coop_bf16_f32_batched_body(args_desc)
    // rsrc2 = 0x019E enables BOTH workgroup_id_x (s15) AND
    // workgroup_id_y (s16).  num_user_sgprs=18, num_vgprs=32 (matches
    // single-stream bf16 variant — same VGPR usage v0..v24).
    uint64 size = emit_amdgpu_code_object_lds("gemv_coop_bf16_f32_batched", 26,
                                               asm_text_buf, asm_text_len,
                                               40, 8, 18, 32,
                                               0xE0AF0003, 0x0000019E, 0x00000010, 0x0408,
                                               args_desc, 5,
                                               128)
    uint64 fd = file_open(out_path, 1)
    if fd > 0xFFFFFFFFFFFFF000 {
        write(2, "emit_amdgpu_gemv_coop_bf16_f32_batched_blob: cannot open output\n", 64)
        return 1
    }
    file_write(fd, amd_buf, size)
    file_close(fd)
    return 0
}

// Q4_0 unpack-fmac primitives.  Each takes (dst, src, ...) and emits the
// corresponding GFX11 dword.  Encoding patterns confirmed via llvm-mc
// probes 2026-05-01.
//
//   _emit_v_and_b32_lit15(d, s)        : v_and_b32 v_d, 15, v_s
//   _emit_v_lshrrev_b32_lit(d, lit, s) : v_lshrrev_b32 v_d, lit, v_s
//   _emit_v_sub_nc_u32_lit8_e64(d, s)  : v_sub_nc_u32_e64 v_d, v_s, 8
//   _emit_v_cvt_f32_i32(d, s)          : v_cvt_f32_i32 v_d, v_s
//   _emit_v_mul_f32(d, s0, s1)         : v_mul_f32 v_d, v_s0, v_s1
//   _emit_v_fmac_f32(d, s0, s1)        : v_fmac_f32 v_d (acc) += v_s0 * v_s1
fn _emit_v_and_b32_lit15(uint64 dst, uint64 src) {
    uint32 enc = 0x36000000 | ((dst & 0x7F) << 17) | ((src & 0x7F) << 9) | 0x8F
    asm_u32(enc)
}
fn _emit_v_lshrrev_b32_lit(uint64 dst, uint64 lit, uint64 src) {
    uint32 lit_enc = 0x80 | (lit & 0x3F)
    // VOP2 op 0x19 (gfx11) → 0x16 (gfx10); top byte 0x32 → 0x2C.
    uint32 top = 0x32000000
    if _is_gfx10() != 0 { top = 0x2C000000 }
    uint32 enc = top | ((dst & 0x7F) << 17) | ((src & 0x7F) << 9) | lit_enc
    asm_u32(enc)
}
fn _emit_v_sub_nc_u32_lit8_e64(uint64 dst, uint64 src) {
    asm_u32(0xD5260000 | (dst & 0xFF))
    // word2: (SRC1=0x88 inline 8) << 9 | (SRC0=0x100|src) = 0x11100 | src
    asm_u32(0x00011100 | (src & 0xFF))
}
fn _emit_v_cvt_f32_i32(uint64 dst, uint64 src) {
    // VOP1 op 0x05.  byte3=0x7E, byte2=DST*2, byte1=(0x05<<1)|1 = 0x0B,
    // byte0 = SRC low 8.
    uint32 enc = 0x7E000000 | ((dst & 0x7F) << 17) | 0x0B00 | (src & 0xFF)
    asm_u32(enc)
}
fn _emit_v_mul_f32(uint64 dst, uint64 s0, uint64 s1) {
    // VOP2 op 8 (top byte 0x10).  SRC0 is 9-bit (vgpr → bit 8 set).
    uint32 enc = 0x10000000 | ((dst & 0x7F) << 17) | ((s1 & 0x7F) << 9) | 0x100 | (s0 & 0xFF)
    asm_u32(enc)
}
fn _emit_v_fmac_f32(uint64 dst, uint64 s0, uint64 s1) {
    // 7-bit op 0x2B → top byte 0x56.  SRC0 9-bit (vgpr).
    uint32 enc = 0x56000000 | ((dst & 0x7F) << 17) | ((s1 & 0x7F) << 9) | 0x100 | (s0 & 0xFF)
    asm_u32(enc)
}

// Emit one unpack-fmac sequence for ONE Q4_0 element.
//
// Scratch vgprs are v30/v31 — must stay OUTSIDE v14..v29 (the input
// load range), or fmacs whose in_vgpr aliases scratch see corrupted
// input data.  Earlier bug 2026-05-01: scratch was v22/v23, which
// collided with inputs[8..11] (loaded via global_load_b128 v[22:25])
// → fmacs for j=8,9 used post-cvt/post-mul values instead of input,
// producing output ~1000× too large.
//
//   v30 = nibble extracted from v_pack at byte_offset (0..3) in v_pack[g],
//         position lo (mask first) or hi (shift 4 first then mask).
//   v30 = v30 - 8       (centre)
//   v30 = cvt_f32_i32   (signed convert)
//   v31 = v9 * v30      (multiply by per-block scale)
//   v5 += v31 * v_in    (accumulate into running sum)
//
//   pack_vgpr  : 10..13 — which v_pack vgpr to extract from
//   shift      : 0, 4, 8, 12, 16, 20, 24, or 28
//   in_vgpr    : the input f32 vgpr to fmac with (in v14..v29)
fn _emit_q4_unpack_fmac(uint64 pack_vgpr, uint64 shift, uint64 in_vgpr) {
    if shift == 0 {
        // Shortcut: low nibble of v_pack[0] is just AND.
        _emit_v_and_b32_lit15(30, pack_vgpr)
    } else {
        _emit_v_lshrrev_b32_lit(30, shift, pack_vgpr)
        _emit_v_and_b32_lit15(30, 30)
    }
    _emit_v_sub_nc_u32_lit8_e64(30, 30)
    _emit_v_cvt_f32_i32(30, 30)
    _emit_v_mul_f32(31, 9, 30)
    _emit_v_fmac_f32(5, 31, in_vgpr)
}

// ─── Q4_0-direct cooperative gemv, batched (M streams) ───────────────
// Reads Q4_0-quantized weights directly (18 bytes per 32-element block:
// fp16 scale + 16 bytes packed int4 nibbles) and produces f32 output.
//
//   Block size: 32 elements (= 1 lane's chunk for K=1024)
//   Block bytes: 18 (2 fp16 scale + 16 packed int4 × 32)
//   Row bytes: K/32 * 18 = 18*K/32
//
// Layout per WG (one output row): 32 lanes cooperatively cover K
// dimension, each lane handles K/32/32 blocks per loop iter, looping
// (K / 1024) times.  At K=1024 → 1 iter, each lane = 1 block.
// At K=2048 → 2 iters; K=3072 → 3 iters.
//
// Kernarg layout (5 args, 40 bytes — matches bf16 batched):
//   [0x00] u64 a_ptr   (Q4_0 weight, N rows × K/32 blocks × 18 bytes)
//   [0x08] u64 b_ptr   (f32 input,   batch × K elements)
//   [0x10] u64 c_ptr   (f32 output,  batch × N elements)
//   [0x18] u64 N       (only low 32 used)
//   [0x20] u64 K       (only low 32 used; must be multiple of 1024)
//
// Grid (N, batch_size, 1); block (32, 1, 1).  rsrc2 = 0x019E enables
// both wg_x (s15) and wg_y (s16).
//
// REQUIRES: K is a multiple of 1024 (loop iter count = K/1024).  All
// Qwen3-0.6B inner-layer K values qualify: 1024, 2048, 3072.
fn _emit_gemv_coop_q4_0_f32_batched_body(uint64 args_desc) {
    asm_init()

    // ── Prologue: kernarg load ───────────────────────────────────────
    asm_u32_arch(0xF40C0100, 0xF40C0100); asm_u32_arch(0xF8000000, 0xFA000000)
    asm_u32_arch(0xF4040300, 0xF4040300); asm_u32_arch(0xF8000020, 0xFA000020)
    asm_u32_arch(0xBF89FC07, 0xBF8CC07F)

    // ── wg_y arithmetic ──────────────────────────────────────────────
    asm_u32_arch(0x960E0C10, 0x930E0C10) // s_mul_i32 s14, s16, s12
    asm_u32_arch(0x840E820E, 0x8F0E820E) // s_lshl_b32 s14, s14, 2
    asm_u32     (0x80060E06)
    asm_u32     (0x82078007)
    asm_u32_arch(0x960E0A10, 0x930E0A10) // s_mul_i32 s14, s16, s10
    asm_u32_arch(0x840E820E, 0x8F0E820E)
    asm_u32     (0x80080E08)
    asm_u32     (0x82098009)

    // ── WG-level bounds check ────────────────────────────────────────
    asm_u32     (0xBF090A0F)             // s_cmp_ge_u32 s15, s10
    uint64 cbranch_end_idx = asm_text_len / 4
    asm_u32_arch(0xBFA20000, 0xBF850000) // s_cbranch_scc1 .Lend

    // ── a_row_base = a_ptr + row * (K/32) * 18 ───────────────────────
    asm_u32_arch(0x8513850C, 0x9013850C) // s_lshr_b32 s19, s12, 5
    asm_u32_arch(0x96110F13, 0x93110F13) // s_mul_i32 s17, s19, s15
    asm_u32_arch(0xBE9000FF, 0xBE9003FF); asm_u32(0x00000012) // s_mov_b32 s16, 18
    asm_u32_arch(0x96111011, 0x93111011) // s_mul_i32 s17, s17, s16
    asm_u32     (0x80101104)             // s_add_u32 s16, s4, s17
    asm_u32     (0x82118005)             // s_addc_u32 s17, s5, 0

    // ── Per-lane init ─────────────────────────────────────────────────
    // VGPR layout:
    //   v0       lane id (0..31) — set by hardware
    //   v3       sum accumulator (f32) — clobbered later for store-offset
    //   v5       running sum accumulator (f32)
    //   v6       LDS slot offset (lane * 4)
    //   v7       a_off (per-block byte offset in a-row, init = lane*18)
    //   v8       b_off (per-block byte offset in b-row, init = lane*128)
    //   v9       fp16 scale → f32 (loaded per iter)
    //   v10..v13 packed nibbles (16 bytes = 4 b32 lanes)
    //   v14..v29 input f32 values (32 inputs = 16 b128 lanes... no wait, 8 b128 = 32 f32)
    //            Actually 32 f32 = 8× b128 = 32 vgprs needed!  Too many.
    //            Reduce to: load 32 inputs as 4× b256 if available, or 8× b128.
    //            8× b128 → 32 vgprs (v14..v45).  Doesn't fit in 32-vgpr KD.
    //            Solution: process inputs in 4 groups of 8 (4× b128 each = 16 vgprs).
    //            Per group: load 8 inputs, do 8 unpacks + 8 fmacs, advance.
    //
    // Simpler: process the 32 elements in TWO halves of 16 each.  Each
    // half loads 8 b128 = 8 f32s, but we need 16 f32s per half.  4 b128 = 16 f32.
    // Re-plan:
    //   Per block, we have 32 weights and 32 inputs.
    //   Process in 4 groups of 8 elements each.
    //   Group g (g in 0..3): use weights from v_pack[g], inputs[g*8..g*8+7].
    //   Load 8 inputs as 2× b128 (= 8 f32s in 8 vgprs).
    //   For each of 8 elements: unpack nibble, sub 8, cvt f32, mul scale, fmac.
    //
    // VGPR re-budget:
    //   v9          fp16 scale (after cvt to f32)
    //   v10..v13    4× b32 packed nibbles (16 bytes per block)
    //   v14..v21    8 input f32s (group g) — re-loaded per group
    //   v22..v23    scratch for unpack (byte, nibble, int_diff, f32_w)
    //   v24, v25    weight f32 (post-scale-mul) — re-used per fmac
    //
    // Still fits in v0..v25 (26 vgprs) → KD granules=3 → 32 vgprs allocated.

    asm_u32_arch(0x300C0082, 0x340C0082) // v_lshlrev_b32 v6, 2, v0
    asm_u32_arch(0x300E0084, 0x340E0084) // v_lshlrev_b32 v7, 4, v0  (lane*16)
    asm_u32     (0x4A0E0F00)             // v_add_nc_u32 v7, v0, v7  (VOP2 stable)
    asm_u32     (0x4A0E0F00)             // v_add_nc_u32 v7, v0, v7
    asm_u32_arch(0x30100087, 0x34100087) // v_lshlrev_b32 v8, 7, v0  (lane*128)
    asm_v_mov_b32(5, 0x80)
    asm_u32_arch(0xBE920080, 0xBE920380) // s_mov_b32 s18, 0
    asm_u32_arch(0x85138A0C, 0x90138A0C) // s_lshr_b32 s19, s12, 10  (K/1024)

    // ── .Lloop ────────────────────────────────────────────────────────
    uint64 loop_idx = asm_text_len / 4

    asm_u32_arch(0xDC4A0000, 0xDC288000); asm_u32(0x09100007) // load_u16 v9, scale
    asm_u32_arch(0xDC5E0002, 0xDC388002); asm_u32(0x0A100007) // load_b128/dwordx4 v[10:13] offset:2

    asm_u32_arch(0xBF8903F7, 0xBF8C3F70) // s_waitcnt vmcnt(0)
    asm_u32     (0x7E121709)             // v_cvt_f32_f16_e32 (VOP1 stable)

    // 4. Process 4 groups of 8 elements each.
    //    Group g (g=0..3): nibbles in v_pack[g], inputs at b_off + g*32.
    //    Per group: load 8 inputs, do 8 (unpack + sub + cvt + mul + fmac).
    //
    //    Nibble layout in v_pack[g] (= 4 bytes):
    //      lo nibble byte j = w[g*4 + j]   for j=0..3  (lo half of group)
    //      hi nibble byte j = w[g*4 + j + 16]          (hi half ... wait)
    //
    //    Actually re-check: GGML Q4_0 packs:
    //      byte j (j=0..15) → low = w[j], high = w[j+16]
    //    So bytes 0..3 hold w[0..3] in low nibbles, w[16..19] in high.
    //    bytes 4..7 hold w[4..7] in low, w[20..23] in high.  Etc.
    //    That means each v_pack[g] (4 bytes = bytes g*4..g*4+3) covers:
    //      4 lo-nibbles → w[g*4..g*4+3]
    //      4 hi-nibbles → w[g*4+16..g*4+19]
    //
    //    To process w[0..7], we need v_pack[0]'s 4 lo-nibbles + v_pack[1]'s
    //    4 lo-nibbles.  That's MIXED across vgprs — annoying.
    //
    //    Re-layout: process w[0..15] (lo nibbles of all bytes), then
    //    w[16..31] (hi nibbles).  Inputs grouped by [0..15] then [16..31].
    //
    //    Per half: load 16 inputs, unpack 16 nibbles, fmac.
    //    16 inputs = 4× b128 (16 f32s in 16 vgprs).  v14..v29 (16 vgprs).
    //
    //    Per nibble extraction (lo half from v_pack[byte_idx/4][byte_idx%4]):
    //      byte = (v_pack[g] >> (j*8)) & 0xFF
    //      lo   = byte & 0xF
    //      w_int = lo - 8
    //      w_f32 = (cvt_f32_i32 w_int) * scale
    //      acc  += w_f32 * input[g*4 + j]
    //
    //    With 16 unpacks + 16 muls + 16 fmacs per half, 2 halves total:
    //    32 unpacks + 32 muls + 32 fmacs per loop iter. ~96 VALU ops.
    //
    //    Implementation: unrolled 16 ops per half.

    // ── Half 0: lo nibbles ──
    asm_u32_arch(0xDC5E0000, 0xDC388000); asm_u32(0x0E060008)
    asm_u32_arch(0xDC5E0010, 0xDC388010); asm_u32(0x12060008)
    asm_u32_arch(0xDC5E0020, 0xDC388020); asm_u32(0x16060008)
    asm_u32_arch(0xDC5E0030, 0xDC388030); asm_u32(0x1A060008)
    asm_u32_arch(0xBF8903F7, 0xBF8C3F70)

    // 16 unpack-fmac sequences for w[0..15].  Element j:
    //   v_pack_idx = 10 + j/4   (which of v10..v13 holds the byte)
    //   shift      = (j % 4) * 8   (0, 8, 16, or 24 — lo nibble at no extra +4)
    //   in_vgpr    = 14 + j   (v14..v29)
    uint64 j = 0
    while j < 16 {
        uint64 pack_idx = 10 + (j >> 2)
        uint64 shift_val = (j & 3) * 8
        uint64 in_vgpr = 14 + j
        _emit_q4_unpack_fmac(pack_idx, shift_val, in_vgpr)
        j = j + 1
    }

    // ── Half 1: hi nibbles ──
    asm_u32_arch(0xDC5E0040, 0xDC388040); asm_u32(0x0E060008)
    asm_u32_arch(0xDC5E0050, 0xDC388050); asm_u32(0x12060008)
    asm_u32_arch(0xDC5E0060, 0xDC388060); asm_u32(0x16060008)
    asm_u32_arch(0xDC5E0070, 0xDC388070); asm_u32(0x1A060008)
    asm_u32_arch(0xBF8903F7, 0xBF8C3F70)

    // 16 unpack-fmac sequences for w[16..31].  Element (j+16):
    //   pack_idx = 10 + j/4   (same packs, different nibbles)
    //   shift    = (j % 4) * 8 + 4   (hi nibble = lo nibble shift + 4)
    //   in_vgpr  = 14 + j   (re-loaded inputs hold input[16+j])
    j = 0
    while j < 16 {
        uint64 pack_idx = 10 + (j >> 2)
        uint64 shift_val = (j & 3) * 8 + 4
        uint64 in_vgpr = 14 + j
        _emit_q4_unpack_fmac(pack_idx, shift_val, in_vgpr)
        j = j + 1
    }

    // ── Update offsets, loop ─────────────────────────────────────────
    asm_u32     (0x4A0E0EFF); asm_u32(0x00000240) // v_add_nc_u32 v7, 0x240, v7
    asm_u32     (0x4A1010FF); asm_u32(0x00001000) // v_add_nc_u32 v8, 0x1000, v8
    asm_u32     (0x80128112)
    asm_u32     (0xBF0A1312)
    uint64 loop_branch_idx = asm_text_len / 4
    uint64 back_simm = loop_idx - (loop_branch_idx + 1)
    uint64 sccbr_top = 0xBFA20000
    if _is_gfx10() != 0 { sccbr_top = 0xBF850000 }
    asm_u32(sccbr_top | (back_simm & 0xFFFF))

    // ── Reduce + lane-0 store ────────────────────────────────────────
    asm_u32     (0xD8340000); asm_u32(0x00000506)
    asm_u32_arch(0xBF89FC07, 0xBF8CC07F)
    asm_u32_arch(0xBFBD0000, 0xBF8A0000)
    _emit_lds_reduce_pow2(32, 0x060A0F05, 14)
    asm_v_cmp_eq_u32_imm_vgpr(0, 0)
    asm_u32_arch(0xBE82206A, 0xBE823C6A)
    asm_v_mov_b32(3, 15)
    asm_u32_arch(0x30060682, 0x34060682)
    asm_u32_arch(0xDC6A0000, 0xDC708000); asm_u32(0x00080503)
    asm_u32_arch(0xBC7C0000, 0xBBFD0000)
    asm_u32_arch(0xBEFE0002, 0xBEFE0302)
    asm_u32_arch(0xBFB00000, 0xBF810000)

    // Patch forward branch.
    uint64 total_dwords = asm_text_len / 4
    uint64 fwd_simm = total_dwords - cbranch_end_idx - 2
    asm_patch_u32(cbranch_end_idx, sccbr_top | (fwd_simm & 0xFFFF))

    uint64 a0 = args_desc + 0;   unsafe { *(a0 as uint64) = 8 }
    uint64 a1 = args_desc + 8;   unsafe { *(a1 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a2 = args_desc + 16;  unsafe { *(a2 as uint64) = 8 }
    uint64 a3 = args_desc + 24;  unsafe { *(a3 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a4 = args_desc + 32;  unsafe { *(a4 as uint64) = 8 }
    uint64 a5 = args_desc + 40;  unsafe { *(a5 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a6 = args_desc + 48;  unsafe { *(a6 as uint64) = 8 }
    uint64 a7 = args_desc + 56;  unsafe { *(a7 as uint64) = AMD_ARG_KIND_BY_VALUE }
    uint64 a8 = args_desc + 64;  unsafe { *(a8 as uint64) = 8 }
    uint64 a9 = args_desc + 72;  unsafe { *(a9 as uint64) = AMD_ARG_KIND_BY_VALUE }
}

@export
fn emit_amdgpu_gemv_coop_q4_0_f32_batched_blob(uint64 out_path) -> uint64 {
    uint64[10] args_desc
    _emit_gemv_coop_q4_0_f32_batched_body(args_desc)
    // rsrc2 = 0x019E enables both wg_x (s15) and wg_y (s16).
    // num_user_sgprs=18, num_vgprs=32 (uses v0..v29 in inner loop).
    // Heavier than bf16 — int4 unpacks need scratch + 16 input vgprs.
    uint64 size = emit_amdgpu_code_object_lds("gemv_coop_q4_0_f32_batched", 26,
                                               asm_text_buf, asm_text_len,
                                               40, 8, 18, 32,
                                               0xE0AF0003, 0x0000019E, 0x00000010, 0x0408,
                                               args_desc, 5,
                                               128)
    uint64 fd = file_open(out_path, 1)
    if fd > 0xFFFFFFFFFFFFF000 {
        write(2, "emit_amdgpu_gemv_coop_q4_0_f32_batched_blob: cannot open output\n", 64)
        return 1
    }
    file_write(fd, amd_buf, size)
    file_close(fd)
    return 0
}

// ─── Fused decode-shape attention ────────────────────────────────────
// Single launch per layer: handles all 16 Q heads of Qwen3-0.6B in one
// kernel.  One workgroup per Q head (block_x = 32, grid_x = nh = 16).
//
// Each lane covers `head_dim / 32 = 4` consecutive elements of the
// head (head_dim hardcoded = 128).  Per-pos work:
//   - load 4 K elements (1 b128 load), compute Q · K (4 fmacs, then
//     32-lane LDS reduce → score)
//   - lane 0 writes scaled score to LDS scores[i]
// Then softmax over scores[0..pos_plus_1).  Then accum loop:
//   - load 4 V elements (1 b128 load), broadcast scores[i], 4 fmacs
//   - final write 4 elements of attn_out per lane
//
// Kernarg layout (40 bytes):
//   [0x00] q_ptr            (q_dim f32 = 16 × 128 = 2048 f32 = 8 KB)
//   [0x08] k_cache_ptr      (max_seq × nkv × hd f32; layer base)
//   [0x10] v_cache_ptr      (same shape)
//   [0x18] out_ptr          (q_dim f32; writes attn_out)
//   [0x20] pos_plus_1       (u64; only low 32 used)
//
// HARDCODED for Qwen3-0.6B:
//   nh = 16, nkv = 8, hd = 128
//   kv_h = wg_id_x >> 1
//   K/V slot stride: 8 × 128 × 4 = 4096 bytes
//   Q row stride: 128 × 4 = 512 bytes
//
// LDS: 32 × 4 (lane reduce) + 64 × 4 (max_seq scores) = 384 B,
// allocate 1024 for safety.
//
// MILESTONE 1 BODY: Q-passthrough.  Each WG (head h) loads its
// 128-element Q slice via per-lane b128 (each lane gets 4 f32) and
// writes it through to out[h, :].  Validates Q-base address arithmetic,
// b128 load, b128 store; doesn't yet compute attention.  Next milestone
// adds the score loop on top of this.
// Emit: s18 = wg_id_x / kv_ratio.  For kv_ratio == 2 (Qwen3-0.6B nh=16
// nkv=8) this is just s_lshr_b32 s18, s15, 1.  For kv_ratio == 5
// (Qwen3-14B nh=40 nkv=8) we need magic-number division:
//   s_mul_hi_u32 s18, s15, 0xCCCCCCCD   ; upper-32 of head * (2^34/5)
//   s_lshr_b32   s18, s18, 2             ; final divide
fn _emit_attn_decode_kv_head_divide(uint64 kv_ratio) {
    if kv_ratio == 2 {
        asm_u32_arch(0x8512810F, 0x9012810F)       // s_lshr_b32 s18, s15, 1
    } else if kv_ratio == 5 {
        // s_mul_hi_u32: gfx11 top byte 0x96 → gfx10 top byte 0x9A.
        asm_u32_arch(0x9692FF0F, 0x9A92FF0F); asm_u32(0xCCCCCCCD)
        asm_u32_arch(0x85128212, 0x90128212)       // s_lshr_b32 s18, s18, 2
    } else {
        asm_u32_arch(0xBE92000F, 0xBE92030F)       // s_mov_b32 s18, s15
    }
}

fn _emit_attn_decode_f32_body_kvr(uint64 args_desc, uint64 kv_ratio) {
    asm_init()

    // Kernarg load.
    asm_u32_arch(0xF40C0100, 0xF40C0100); asm_u32_arch(0xF8000000, 0xFA000000)
    asm_u32_arch(0xF4040300, 0xF4040300); asm_u32_arch(0xF8000020, 0xFA000020)
    asm_u32_arch(0xBF89FC07, 0xBF8CC07F)

    // Kernarg layout (loaded by s_load_b256 → s4..s11, b64 → s12,s13):
    //   q_ptr  (offset 0x00..0x07)  → s[4:5]
    //   kc_ptr (offset 0x08..0x0F)  → s[6:7]
    //   vc_ptr (offset 0x10..0x17)  → s[8:9]
    //   out_ptr(offset 0x18..0x1F)  → s[10:11]
    //   pos_plus_1 (offset 0x20..)  → s[12:13]

    // s14 = head*512
    asm_u32_arch(0x840E890F, 0x8F0E890F)           // s_lshl_b32 s14, s15, 9
    // s[16:17] = q_ptr + head*512
    asm_u32     (0x80100E04)                       // s_add_u32 (SOP2 stable)
    asm_u32     (0x82118005)
    // s[24:25] = out_ptr + head*512
    asm_u32     (0x80180E0A)
    asm_u32     (0x8219800B)
    _emit_attn_decode_kv_head_divide(kv_ratio)
    // s19 = kv_h * 512
    asm_u32_arch(0x84138912, 0x8F138912)
    // s[20:21] = kc_ptr + kv_h*512
    asm_u32     (0x80141306)
    asm_u32     (0x82158007)

    // MILESTONE 2 PHASE 2e: Iterate pos = 0..pos_plus_1; for each pos
    // compute (1/√128) * Q · K[pos] and store to out[head*128 + pos].
    // Q is loaded once outside the loop; per-pos K-slot base advances
    // by 4096 bytes (= nkv * hd * f32 = 8*128*4) each iteration.
    //
    // VGPR layout (v5 must be free for the LDS-reduce helper):
    //   v[12:15] = Q loaded quad
    //   v[16:19] = K loaded quad (per-pos)
    //   v5       = partial dot → reduced total → scaled score
    //   v6       = lane*4  (LDS slot)
    //   v7       = LDS-reduce scratch / 1/√128 literal holder
    //   v8       = lane*16 (Q load offset; also pos=0 store offset = 0)
    //   v9       = pos*4   (per-pos store byte offset for lane 0)
    //   v10      = scratch broadcast for v_mov_b32 v_, sN
    //
    // SGPR loop state:
    //   s12      = pos_plus_1 (kernarg)
    //   s28:29   = current K-slot base (advanced per iter)
    //   s30      = pos counter
    //   s31      = K-slot stride (= 4096)
    asm_u32_arch(0x30100084, 0x34100084) // v_lshlrev_b32 v8, 4, v0
    asm_u32_arch(0x300C0082, 0x340C0082) // v_lshlrev_b32 v6, 2, v0
    asm_s_delay_alu(0x01)

    asm_u32_arch(0xDC5E0000, 0xDC388000); asm_u32(0x0C100008) // global_load_b128 v[12:15], v8, s[16:17]
    asm_u32_arch(0xBF8903F7, 0xBF8C3F70)

    asm_u32_arch(0xBE9C0014, 0xBE9C0314) // s_mov_b32 s28, s20
    asm_u32_arch(0xBE9D0015, 0xBE9D0315) // s_mov_b32 s29, s21
    asm_u32_arch(0xBE9E0080, 0xBE9E0380) // s_mov_b32 s30, 0
    asm_u32_arch(0xBE9F00FF, 0xBE9F03FF); asm_u32(0x00001000) // s_mov_b32 s31, 0x1000

    // 1/√128 literal (loaded once into v7; reduce helper clobbers v7 each
    // iter, so reload at top of body before scale).  Actually simpler:
    // load inside the loop right before v_mul_f32 v5, v5, v7.

    // .Lloop:
    uint64 score_loop_idx = asm_text_len / 4

    asm_u32_arch(0xDC5E0000, 0xDC388000); asm_u32(0x101C0008) // global_load_b128 v[16:19]
    asm_u32_arch(0xBF8903F7, 0xBF8C3F70)

    asm_u32     (0x100A210C)             // v_mul_f32 v5, v12, v16 (VOP2 stable)
    asm_u32     (0x560A230D); asm_u32(0x560A250E); asm_u32(0x560A270F)

    asm_u32     (0xD8340000); asm_u32(0x00000506) // ds_store
    asm_u32_arch(0xBF89FC07, 0xBF8CC07F)
    asm_u32_arch(0xBFBD0000, 0xBF8A0000) // s_barrier
    _emit_lds_reduce_pow2(32, 0x060A0F05, 2)

    asm_v_mov_b32_lit32(7, 0x3DB504F3)
    asm_u32     (0x100A0F05)             // v_mul_f32 v5, v5, v7

    asm_v_mov_b32(10, 30)
    asm_u32_arch(0x30121482, 0x34121482) // v_lshlrev_b32 v9, 2, v10
    asm_s_delay_alu(0x01)

    asm_v_cmp_eq_u32_imm_vgpr(0, 0)
    asm_u32_arch(0xBE82206A, 0xBE823C6A) // s_and_saveexec_b32 s2, vcc_lo
    asm_u32_arch(0xDC6A0000, 0xDC708000); asm_u32(0x00180509) // global_store_b32
    asm_u32     (0xD8340080); asm_u32(0x00000509) // ds_store_b32 offset:128
    asm_u32_arch(0xBC7C0000, 0xBBFD0000)
    asm_u32_arch(0xBEFE0002, 0xBEFE0302) // s_mov_b32 exec_lo, s2

    asm_u32     (0x801E811E)             // s_add_u32 s30, s30, 1
    asm_u32     (0x801C1F1C)             // s_add_u32 s28, s28, s31
    asm_u32     (0x821D801D)             // s_addc_u32 s29, s29, 0
    asm_u32     (0xBF0A0C1E)             // s_cmp_lt_u32 s30, s12
    uint64 score_branch_idx = asm_text_len / 4
    uint64 score_back_simm = score_loop_idx - (score_branch_idx + 1)
    uint64 sccbr_top = 0xBFA20000
    if _is_gfx10() != 0 { sccbr_top = 0xBF850000 }
    asm_u32(sccbr_top | (score_back_simm & 0xFFFF))

    // ---------------------------------------------------------------
    // MILESTONE 3: Softmax over scores[0..pos_plus_1) in LDS @ off 128.
    // ---------------------------------------------------------------
    // Each lane handles one position (assumes pos_plus_1 ≤ 32).  Lanes
    // outside that range get the identity element for each reduce
    // (-inf for max, 0 for sum) so they don't pollute the result.
    //
    // VGPR usage in this section:
    //   v0   lane id
    //   v5   reduce accumulator (helper-mandated)
    //   v6   lane*4 LDS slot (unchanged)
    //   v7   reduce scratch / literal holder
    //   v11  per-lane post-exp value (saved across the sum-reduce)
    asm_u32_arch(0xBF89FC07, 0xBF8CC07F)
    asm_u32_arch(0xBFBD0000, 0xBF8A0000) // s_barrier

    asm_u32_arch(0x7C98000C, 0x7D88000C) // v_cmp_gt_u32 vcc_lo, s12, v0

    asm_u32     (0xD8D80080); asm_u32(0x05000006) // ds_load_b32 v5, v6 offset:128
    asm_u32_arch(0xBF89FC07, 0xBF8CC07F)

    asm_v_mov_b32_lit32(7, 0xFF800000)
    asm_u32     (0x020A0B07)             // v_cndmask_b32 v5, v7, v5, vcc_lo (VOP2 stable)

    asm_u32     (0x7E160305)             // v_mov_b32 v11, v5

    asm_u32     (0xD8340000); asm_u32(0x00000506) // ds_store_b32
    asm_u32_arch(0xBF89FC07, 0xBF8CC07F)
    asm_u32_arch(0xBFBD0000, 0xBF8A0000)
    _emit_lds_reduce_pow2(32, 0x200A0F05, 2)

    // The reduce helper leaves the final result only in lane 0's v5 (and
    // partial-tree leftovers in lanes 1..15). LDS[0] holds the final max
    // (lane 0's last writeback). Broadcast LDS[0] → v5 in every lane so
    // the centring step below sees the same max in all lanes — otherwise
    // padding lanes (-inf score + their stale max-of-pair) compute
    // (-inf) - (-inf) = NaN which poisons the sum reduce.
    asm_v_mov_b32(7, 0x80)
    asm_s_delay_alu(0x01)
    asm_u32     (0xD8D80000); asm_u32(0x05000007) // ds_load_b32 v5, v7
    asm_u32_arch(0xBF89FC07, 0xBF8CC07F)

    asm_u32     (0x08160B0B)             // v_sub_f32 v11, v11, v5
    asm_v_mov_b32_lit32(7, 0x3FB8AA3B)
    asm_u32     (0x10160F0B)             // v_mul_f32 v11, v11, v7
    asm_u32     (0x7E164B0B)             // v_exp_f32 v11, v11

    asm_u32_arch(0x7C98000C, 0x7D88000C)
    asm_u32     (0x02161680)             // v_cndmask_b32 v11, 0, v11, vcc_lo

    asm_u32     (0x7E0A030B)
    asm_u32     (0xD8340000); asm_u32(0x00000506)
    asm_u32_arch(0xBF89FC07, 0xBF8CC07F)
    asm_u32_arch(0xBFBD0000, 0xBF8A0000)
    _emit_lds_reduce_pow2(32, 0x060A0F05, 2)

    asm_v_mov_b32(7, 0x80)
    asm_s_delay_alu(0x01)
    asm_u32     (0xD8D80000); asm_u32(0x05000007)
    asm_u32_arch(0xBF89FC07, 0xBF8CC07F)

    asm_u32     (0x7E0A5505)             // v_rcp_f32 v5 (VOP1 stable)
    asm_u32     (0x100A0B0B)             // v_mul_f32 v5, v11, v5

    asm_u32_arch(0x7C98000C, 0x7D88000C)
    asm_u32_arch(0xBE82206A, 0xBE823C6A)
    asm_u32     (0xD8340080); asm_u32(0x00000506)
    asm_u32_arch(0xBEFE0002, 0xBEFE0302)
    asm_u32_arch(0xBF89FC07, 0xBF8CC07F)
    asm_u32_arch(0xBFBD0000, 0xBF8A0000)

    // ---------------------------------------------------------------
    // MILESTONE 4: Accum loop  acc[lane*4..+3] = Σᵢ w[i] · V[i, kvh, lane*4..+3]
    // ---------------------------------------------------------------
    // Each lane owns 4 elements of the head's output row.  Per-pos:
    //   1. broadcast w[pos] from LDS scores[pos] → v22 (scalar across all lanes).
    //   2. b128-load V[pos, kvh, lane*4..+3] → v[16:19].
    //   3. v_fmac_f32 v[acc], v[V], v22 (4 fmacs).
    //
    // VGPR layout for accum:
    //   v[24:27] = per-lane accum (init 0)
    //   v[16:19] = V loaded quad
    //   v22      = current weight (scalar across lanes via v_mov_b32 vN, sN)
    //
    // SGPR loop state (re-init):
    //   s28:29   = current V-slot base   (vc_ptr + kvh*512, advancing)
    //   s30      = pos counter
    //   s31      = K-slot stride 4096 (still set from score loop)
    //   s27      = LDS scores byte offset (= pos*4 + 128, but we use LDS-load
    //              with imm offset and increment-via-add separately).
    //              We just use s30*4 computed each iter.

    // Init accum to 0.  Inline 0 = 0x80, op v_mov_b32 = 0x01.
    asm_v_mov_b32(24, 0x80)                        // v24 = 0
    asm_v_mov_b32(25, 0x80)                        // v25 = 0
    asm_v_mov_b32(26, 0x80)                        // v26 = 0
    asm_v_mov_b32(27, 0x80)                        // v27 = 0

    asm_u32     (0x801C1308)             // s_add_u32 s28, s8, s19
    asm_u32     (0x821D8009)             // s_addc_u32 s29, s9, 0
    asm_u32_arch(0xBE9E0080, 0xBE9E0380) // s_mov_b32 s30, 0

    uint64 accum_loop_idx = asm_text_len / 4

    asm_v_mov_b32(10, 30)
    asm_u32_arch(0x30121482, 0x34121482) // v_lshlrev_b32 v9, 2, v10
    asm_s_delay_alu(0x01)
    asm_u32     (0xD8D80080); asm_u32(0x16000009) // ds_load_b32 v22 offset:128
    asm_u32_arch(0xDC5E0000, 0xDC388000); asm_u32(0x101C0008) // global_load_b128 v[16:19]
    asm_u32_arch(0xBF89FC07, 0xBF8CC07F)
    asm_u32_arch(0xBF8903F7, 0xBF8C3F70)

    asm_u32     (0x56302D10); asm_u32(0x56322D11); asm_u32(0x56342D12); asm_u32(0x56362D13)

    asm_u32     (0x801E811E)
    asm_u32     (0x801C1F1C)
    asm_u32     (0x821D801D)
    asm_u32     (0xBF0A0C1E)
    uint64 accum_branch_idx = asm_text_len / 4
    uint64 accum_back_simm = accum_loop_idx - (accum_branch_idx + 1)
    asm_u32(sccbr_top | (accum_back_simm & 0xFFFF))

    asm_s_delay_alu(0x01)
    asm_u32_arch(0xDC760000, 0xDC788000); asm_u32(0x00181808) // global_store_b128
    asm_u32_arch(0xBC7C0000, 0xBBFD0000)

    asm_u32_arch(0xBFB00000, 0xBF810000)

    // args_desc fill — 5 args, all 8 bytes.
    uint64 a0 = args_desc + 0;   unsafe { *(a0 as uint64) = 8 }
    uint64 a1 = args_desc + 8;   unsafe { *(a1 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a2 = args_desc + 16;  unsafe { *(a2 as uint64) = 8 }
    uint64 a3 = args_desc + 24;  unsafe { *(a3 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a4 = args_desc + 32;  unsafe { *(a4 as uint64) = 8 }
    uint64 a5 = args_desc + 40;  unsafe { *(a5 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a6 = args_desc + 48;  unsafe { *(a6 as uint64) = 8 }
    uint64 a7 = args_desc + 56;  unsafe { *(a7 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a8 = args_desc + 64;  unsafe { *(a8 as uint64) = 8 }
    uint64 a9 = args_desc + 72;  unsafe { *(a9 as uint64) = AMD_ARG_KIND_BY_VALUE }
}

// Batched variant: grid (nh, batch).  wg_id_x = head, wg_id_y = batch_idx.
// Hardcoded Qwen3-0.6B strides:
//   Q/out per-batch stride = q_dim * 4 = 2048 * 4 = 8192 bytes  = 1 << 13
//   KV per-batch stride    = max_seq * nkv * hd * 4 = 64*8*128*4 = 262144 = 1 << 18
// Both happen to be powers of 2, so a single s_lshl_b32 by 13 / 18 gives the
// per-batch byte offset without a multiply.  Caller passes the layer's
// batch-slab base for kc/vc (= base + layer * batch_stride from slice 1.1).
fn _emit_attn_decode_f32_batched_body(uint64 args_desc) {
    asm_init()
    asm_u32_arch(0xF40C0100, 0xF40C0100); asm_u32_arch(0xF8000000, 0xFA000000)
    asm_u32_arch(0xF4040300, 0xF4040300); asm_u32_arch(0xF8000020, 0xFA000020)
    asm_u32_arch(0xBF89FC07, 0xBF8CC07F)

    asm_u32_arch(0x840E890F, 0x8F0E890F) // s_lshl_b32 s14, s15, 9
    asm_u32_arch(0x84168D10, 0x8F168D10) // s_lshl_b32 s22, s16, 13
    asm_u32_arch(0x84179210, 0x8F179210) // s_lshl_b32 s23, s16, 18 (pre-clobber)
    asm_u32     (0x800E160E)
    asm_u32     (0x80100E04)
    asm_u32     (0x82118005)
    asm_u32     (0x80180E0A)
    asm_u32     (0x8219800B)

    asm_u32_arch(0x8512810F, 0x9012810F) // s_lshr_b32 s18, s15, 1
    asm_u32_arch(0x84138912, 0x8F138912) // s_lshl_b32 s19, s18, 9
    asm_u32     (0x80131713)
    asm_u32     (0x80141306)
    asm_u32     (0x82158007)

    asm_u32_arch(0x30100084, 0x34100084)
    asm_u32_arch(0x300C0082, 0x340C0082)
    asm_s_delay_alu(0x01)
    asm_u32_arch(0xDC5E0000, 0xDC388000); asm_u32(0x0C100008)
    asm_u32_arch(0xBF8903F7, 0xBF8C3F70)

    asm_u32_arch(0xBE9C0014, 0xBE9C0314)
    asm_u32_arch(0xBE9D0015, 0xBE9D0315)
    asm_u32_arch(0xBE9E0080, 0xBE9E0380)
    asm_u32_arch(0xBE9F00FF, 0xBE9F03FF); asm_u32(0x00001000)

    uint64 sccbr_top = 0xBFA20000
    if _is_gfx10() != 0 { sccbr_top = 0xBF850000 }

    uint64 score_loop_idx = asm_text_len / 4
    asm_u32_arch(0xDC5E0000, 0xDC388000); asm_u32(0x101C0008)
    asm_u32_arch(0xBF8903F7, 0xBF8C3F70)
    asm_u32     (0x100A210C); asm_u32(0x560A230D); asm_u32(0x560A250E); asm_u32(0x560A270F)
    asm_u32     (0xD8340000); asm_u32(0x00000506)
    asm_u32_arch(0xBF89FC07, 0xBF8CC07F); asm_u32_arch(0xBFBD0000, 0xBF8A0000)
    _emit_lds_reduce_pow2(32, 0x060A0F05, 2)
    asm_v_mov_b32_lit32(7, 0x3DB504F3)
    asm_u32     (0x100A0F05)
    asm_v_mov_b32(10, 30)
    asm_u32_arch(0x30121482, 0x34121482)
    asm_s_delay_alu(0x01)
    asm_v_cmp_eq_u32_imm_vgpr(0, 0)
    asm_u32_arch(0xBE82206A, 0xBE823C6A)
    asm_u32_arch(0xDC6A0000, 0xDC708000); asm_u32(0x00180509)
    asm_u32     (0xD8340080); asm_u32(0x00000509)
    asm_u32_arch(0xBC7C0000, 0xBBFD0000)
    asm_u32_arch(0xBEFE0002, 0xBEFE0302)
    asm_u32     (0x801E811E); asm_u32(0x801C1F1C); asm_u32(0x821D801D); asm_u32(0xBF0A0C1E)
    uint64 score_branch_idx = asm_text_len / 4
    uint64 score_back_simm = score_loop_idx - (score_branch_idx + 1)
    asm_u32(sccbr_top | (score_back_simm & 0xFFFF))

    asm_u32_arch(0xBF89FC07, 0xBF8CC07F); asm_u32_arch(0xBFBD0000, 0xBF8A0000)
    asm_u32_arch(0x7C98000C, 0x7D88000C)
    asm_u32     (0xD8D80080); asm_u32(0x05000006)
    asm_u32_arch(0xBF89FC07, 0xBF8CC07F)
    asm_v_mov_b32_lit32(7, 0xFF800000)
    asm_u32     (0x020A0B07)
    asm_u32     (0x7E160305)
    asm_u32     (0xD8340000); asm_u32(0x00000506)
    asm_u32_arch(0xBF89FC07, 0xBF8CC07F); asm_u32_arch(0xBFBD0000, 0xBF8A0000)
    _emit_lds_reduce_pow2(32, 0x200A0F05, 2)
    asm_v_mov_b32(7, 0x80)
    asm_s_delay_alu(0x01)
    asm_u32     (0xD8D80000); asm_u32(0x05000007)
    asm_u32_arch(0xBF89FC07, 0xBF8CC07F)
    asm_u32     (0x08160B0B)
    asm_v_mov_b32_lit32(7, 0x3FB8AA3B)
    asm_u32     (0x10160F0B)
    asm_u32     (0x7E164B0B)
    asm_u32_arch(0x7C98000C, 0x7D88000C)
    asm_u32     (0x02161680)
    asm_u32     (0x7E0A030B)
    asm_u32     (0xD8340000); asm_u32(0x00000506)
    asm_u32_arch(0xBF89FC07, 0xBF8CC07F); asm_u32_arch(0xBFBD0000, 0xBF8A0000)
    _emit_lds_reduce_pow2(32, 0x060A0F05, 2)
    asm_v_mov_b32(7, 0x80)
    asm_s_delay_alu(0x01)
    asm_u32     (0xD8D80000); asm_u32(0x05000007)
    asm_u32_arch(0xBF89FC07, 0xBF8CC07F)
    asm_u32     (0x7E0A5505)
    asm_u32     (0x100A0B0B)
    asm_u32_arch(0x7C98000C, 0x7D88000C)
    asm_u32_arch(0xBE82206A, 0xBE823C6A)
    asm_u32     (0xD8340080); asm_u32(0x00000506)
    asm_u32_arch(0xBEFE0002, 0xBEFE0302)
    asm_u32_arch(0xBF89FC07, 0xBF8CC07F); asm_u32_arch(0xBFBD0000, 0xBF8A0000)

    asm_v_mov_b32(24, 0x80); asm_v_mov_b32(25, 0x80); asm_v_mov_b32(26, 0x80); asm_v_mov_b32(27, 0x80)
    asm_u32     (0x801C1308); asm_u32(0x821D8009); asm_u32_arch(0xBE9E0080, 0xBE9E0380)
    uint64 accum_loop_idx = asm_text_len / 4
    asm_v_mov_b32(10, 30)
    asm_u32_arch(0x30121482, 0x34121482)
    asm_s_delay_alu(0x01)
    asm_u32     (0xD8D80080); asm_u32(0x16000009)
    asm_u32_arch(0xDC5E0000, 0xDC388000); asm_u32(0x101C0008)
    asm_u32_arch(0xBF89FC07, 0xBF8CC07F); asm_u32_arch(0xBF8903F7, 0xBF8C3F70)
    asm_u32     (0x56302D10); asm_u32(0x56322D11); asm_u32(0x56342D12); asm_u32(0x56362D13)
    asm_u32     (0x801E811E); asm_u32(0x801C1F1C); asm_u32(0x821D801D); asm_u32(0xBF0A0C1E)
    uint64 accum_branch_idx = asm_text_len / 4
    uint64 accum_back_simm = accum_loop_idx - (accum_branch_idx + 1)
    asm_u32(sccbr_top | (accum_back_simm & 0xFFFF))

    asm_s_delay_alu(0x01)
    asm_u32_arch(0xDC760000, 0xDC788000); asm_u32(0x00181808)
    asm_u32_arch(0xBC7C0000, 0xBBFD0000)
    asm_u32_arch(0xBFB00000, 0xBF810000)

    uint64 a0 = args_desc + 0;   unsafe { *(a0 as uint64) = 8 }
    uint64 a1 = args_desc + 8;   unsafe { *(a1 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a2 = args_desc + 16;  unsafe { *(a2 as uint64) = 8 }
    uint64 a3 = args_desc + 24;  unsafe { *(a3 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a4 = args_desc + 32;  unsafe { *(a4 as uint64) = 8 }
    uint64 a5 = args_desc + 40;  unsafe { *(a5 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a6 = args_desc + 48;  unsafe { *(a6 as uint64) = 8 }
    uint64 a7 = args_desc + 56;  unsafe { *(a7 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a8 = args_desc + 64;  unsafe { *(a8 as uint64) = 8 }
    uint64 a9 = args_desc + 72;  unsafe { *(a9 as uint64) = AMD_ARG_KIND_BY_VALUE }
}

@export
fn emit_amdgpu_attn_decode_f32_batched_blob(uint64 out_path) -> uint64 {
    uint64[10] args_desc
    _emit_attn_decode_f32_batched_body(args_desc)
    // rsrc2 = 0x019E enables both wg_id_x (s15) and wg_id_y (s16).
    uint64 size = emit_amdgpu_code_object_lds("attn_decode_f32_batched", 23,
                                               asm_text_buf, asm_text_len,
                                               40, 8, 18, 32,
                                               0xE0AF0003, 0x0000019E, 0x00000010, 0x0408,
                                               args_desc, 5,
                                               1024)
    uint64 fd = file_open(out_path, 1)
    if fd > 0xFFFFFFFFFFFFF000 {
        write(2, "emit_amdgpu_attn_decode_f32_batched_blob: cannot open output\n", 62)
        return 1
    }
    file_write(fd, amd_buf, size)
    file_close(fd)
    return 0
}

// Multi-Q attention for speculative decoding (spec_K = 4 hardcoded).
// Same structure as attn_decode_f32_batched but with causal-mask-
// within-K-window: for batch_idx m (0..K-1) at logical position pos+m,
// effective valid history = pos + m + 1 (the m-th query attends to the
// verified history 0..pos-1 PLUS the speculative K-vectors at pos..pos+m,
// which were written into the K-cache before this kernel runs).
//
// Caller passes pos_plus_1 = pos + K (= total K-cache positions).
// Per-WG effective bound = pos_plus_1 - K + 1 + m  (= pos + m + 1).
// At K=1 m=0 this collapses to the single-stream batched kernel.
//
// The mask is applied by computing the bound into s23 and using it in
// the softmax active-lane cmp (replacing the original `lane < s12`).
fn _emit_attn_decode_f32_speck4_body(uint64 args_desc) {
    asm_init()
    asm_u32(0xF40C0100); asm_u32(0xF8000000)       // s_load_b256 s[4:11], s[0:1], 0x0
    asm_u32(0xF4040300); asm_u32(0xF8000020)       // s_load_b64  s[12:13], s[0:1], 0x20
    asm_u32(0xBF89FC07)                            // s_waitcnt   lgkmcnt(0)

    // Save wg_y (= speculative row index m) into s3 BEFORE we clobber
    // s16 with the q_ptr+offset address below.  The causal-mask bound
    // computed later (s23 = pos_plus_1 - K + 1 + m) needs m, not the
    // overwritten address — without this stash, s23 was being computed
    // as `(pos_plus_1-3) + (q_ptr_lo + head*512 + wg_y*8192)`, which
    // wrapped to a huge value that masked off lane 0 in the softmax
    // and zeroed row 0's output.
    asm_u32_arch(0xBE830010, 0xBE830310) // s_mov_b32 s3, s16

    asm_u32_arch(0x840E890F, 0x8F0E890F)
    asm_u32_arch(0x84168D10, 0x8F168D10)
    asm_u32     (0x800E160E)
    asm_u32     (0x80100E04)
    asm_u32     (0x82118005)
    asm_u32     (0x80180E0A)
    asm_u32     (0x8219800B)

    asm_u32_arch(0x8512810F, 0x9012810F)
    asm_u32_arch(0x84138912, 0x8F138912)
    asm_u32     (0x80141306)
    asm_u32     (0x82158007)

    asm_u32     (0x8097FF0C); asm_u32(0x00000003) // s_sub_u32 s23, s12, 3 (literal escape, stable)
    asm_u32     (0x80170317)

    asm_u32_arch(0x30100084, 0x34100084)
    asm_u32_arch(0x300C0082, 0x340C0082)
    asm_s_delay_alu(0x01)
    asm_u32_arch(0xDC5E0000, 0xDC388000); asm_u32(0x0C100008)
    asm_u32_arch(0xBF8903F7, 0xBF8C3F70)

    asm_u32_arch(0xBE9C0014, 0xBE9C0314)
    asm_u32_arch(0xBE9D0015, 0xBE9D0315)
    asm_u32_arch(0xBE9E0080, 0xBE9E0380)
    asm_u32_arch(0xBE9F00FF, 0xBE9F03FF); asm_u32(0x00001000)

    uint64 sccbr_top = 0xBFA20000
    if _is_gfx10() != 0 { sccbr_top = 0xBF850000 }

    uint64 score_loop_idx = asm_text_len / 4
    asm_u32_arch(0xDC5E0000, 0xDC388000); asm_u32(0x101C0008)
    asm_u32_arch(0xBF8903F7, 0xBF8C3F70)
    asm_u32     (0x100A210C); asm_u32(0x560A230D); asm_u32(0x560A250E); asm_u32(0x560A270F)
    asm_u32     (0xD8340000); asm_u32(0x00000506)
    asm_u32_arch(0xBF89FC07, 0xBF8CC07F); asm_u32_arch(0xBFBD0000, 0xBF8A0000)
    _emit_lds_reduce_pow2(32, 0x060A0F05, 2)
    asm_v_mov_b32_lit32(7, 0x3DB504F3)
    asm_u32     (0x100A0F05)
    asm_v_mov_b32(10, 30)
    asm_u32_arch(0x30121482, 0x34121482)
    asm_s_delay_alu(0x01)
    asm_v_cmp_eq_u32_imm_vgpr(0, 0)
    asm_u32_arch(0xBE82206A, 0xBE823C6A)
    asm_u32_arch(0xDC6A0000, 0xDC708000); asm_u32(0x00180509)
    asm_u32     (0xD8340080); asm_u32(0x00000509)
    asm_u32_arch(0xBC7C0000, 0xBBFD0000)
    asm_u32_arch(0xBEFE0002, 0xBEFE0302)
    asm_u32     (0x801E811E); asm_u32(0x801C1F1C); asm_u32(0x821D801D); asm_u32(0xBF0A0C1E)
    uint64 score_branch_idx = asm_text_len / 4
    uint64 score_back_simm = score_loop_idx - (score_branch_idx + 1)
    asm_u32(sccbr_top | (score_back_simm & 0xFFFF))

    asm_u32_arch(0xBF89FC07, 0xBF8CC07F); asm_u32_arch(0xBFBD0000, 0xBF8A0000)
    asm_u32_arch(0x7C980017, 0x7D880017) // v_cmp_gt_u32 vcc_lo, s23, v0
    asm_u32     (0xD8D80080); asm_u32(0x05000006)
    asm_u32_arch(0xBF89FC07, 0xBF8CC07F)
    asm_v_mov_b32_lit32(7, 0xFF800000)
    asm_u32     (0x020A0B07)
    asm_u32     (0x7E160305)
    asm_u32     (0xD8340000); asm_u32(0x00000506)
    asm_u32_arch(0xBF89FC07, 0xBF8CC07F); asm_u32_arch(0xBFBD0000, 0xBF8A0000)
    _emit_lds_reduce_pow2(32, 0x200A0F05, 2)
    asm_v_mov_b32(7, 0x80)
    asm_s_delay_alu(0x01)
    asm_u32     (0xD8D80000); asm_u32(0x05000007)
    asm_u32_arch(0xBF89FC07, 0xBF8CC07F)
    asm_u32     (0x08160B0B)
    asm_v_mov_b32_lit32(7, 0x3FB8AA3B)
    asm_u32     (0x10160F0B)
    asm_u32     (0x7E164B0B)
    asm_u32_arch(0x7C980017, 0x7D880017)
    asm_u32     (0x02161680)
    asm_u32     (0x7E0A030B)
    asm_u32     (0xD8340000); asm_u32(0x00000506)
    asm_u32_arch(0xBF89FC07, 0xBF8CC07F); asm_u32_arch(0xBFBD0000, 0xBF8A0000)
    _emit_lds_reduce_pow2(32, 0x060A0F05, 2)
    asm_v_mov_b32(7, 0x80)
    asm_s_delay_alu(0x01)
    asm_u32     (0xD8D80000); asm_u32(0x05000007)
    asm_u32_arch(0xBF89FC07, 0xBF8CC07F)
    asm_u32     (0x7E0A5505)
    asm_u32     (0x100A0B0B)
    asm_u32_arch(0x7C980017, 0x7D880017)
    asm_u32     (0x020A0A80)
    asm_u32     (0xD8340080); asm_u32(0x00000506)
    asm_u32_arch(0xBF89FC07, 0xBF8CC07F); asm_u32_arch(0xBFBD0000, 0xBF8A0000)

    asm_v_mov_b32(24, 0x80); asm_v_mov_b32(25, 0x80); asm_v_mov_b32(26, 0x80); asm_v_mov_b32(27, 0x80)
    asm_u32     (0x801C1308); asm_u32(0x821D8009); asm_u32_arch(0xBE9E0080, 0xBE9E0380)
    uint64 accum_loop_idx = asm_text_len / 4
    asm_v_mov_b32(10, 30)
    asm_u32_arch(0x30121482, 0x34121482)
    asm_s_delay_alu(0x01)
    asm_u32     (0xD8D80080); asm_u32(0x16000009)
    asm_u32_arch(0xDC5E0000, 0xDC388000); asm_u32(0x101C0008)
    asm_u32_arch(0xBF89FC07, 0xBF8CC07F); asm_u32_arch(0xBF8903F7, 0xBF8C3F70)
    asm_u32     (0x56302D10); asm_u32(0x56322D11); asm_u32(0x56342D12); asm_u32(0x56362D13)
    asm_u32     (0x801E811E); asm_u32(0x801C1F1C); asm_u32(0x821D801D); asm_u32(0xBF0A0C1E)
    uint64 accum_branch_idx = asm_text_len / 4
    uint64 accum_back_simm = accum_loop_idx - (accum_branch_idx + 1)
    asm_u32(sccbr_top | (accum_back_simm & 0xFFFF))

    asm_s_delay_alu(0x01)
    asm_u32_arch(0xDC760000, 0xDC788000); asm_u32(0x00181808)
    asm_u32_arch(0xBC7C0000, 0xBBFD0000)
    asm_u32_arch(0xBFB00000, 0xBF810000)

    uint64 a0 = args_desc + 0;   unsafe { *(a0 as uint64) = 8 }
    uint64 a1 = args_desc + 8;   unsafe { *(a1 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a2 = args_desc + 16;  unsafe { *(a2 as uint64) = 8 }
    uint64 a3 = args_desc + 24;  unsafe { *(a3 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a4 = args_desc + 32;  unsafe { *(a4 as uint64) = 8 }
    uint64 a5 = args_desc + 40;  unsafe { *(a5 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a6 = args_desc + 48;  unsafe { *(a6 as uint64) = 8 }
    uint64 a7 = args_desc + 56;  unsafe { *(a7 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a8 = args_desc + 64;  unsafe { *(a8 as uint64) = 8 }
    uint64 a9 = args_desc + 72;  unsafe { *(a9 as uint64) = AMD_ARG_KIND_BY_VALUE }
}

@export
fn emit_amdgpu_attn_decode_f32_speck4_blob(uint64 out_path) -> uint64 {
    uint64[10] args_desc
    _emit_attn_decode_f32_speck4_body(args_desc)
    uint64 size = emit_amdgpu_code_object_lds("attn_decode_f32_speck4", 22,
                                               asm_text_buf, asm_text_len,
                                               40, 8, 18, 32,
                                               0xE0AF0003, 0x0000019E, 0x00000010, 0x0408,
                                               args_desc, 5, 1024)
    uint64 fd = file_open(out_path, 1)
    if fd > 0xFFFFFFFFFFFFF000 { write(2, "speck4 blob fail\n", 17); return 1 }
    file_write(fd, amd_buf, size); file_close(fd); return 0
}

// Backward-compat wrapper: 0.6B's kv_ratio = nh/nkv = 16/8 = 2.
fn _emit_attn_decode_f32_body(uint64 args_desc) {
    _emit_attn_decode_f32_body_kvr(args_desc, 2)
}

fn emit_amdgpu_attn_decode_f32_blob(uint64 out_path) -> uint64 {
    uint64[10] args_desc
    _emit_attn_decode_f32_body(args_desc)

    // KD: num_user_sgprs=18, num_vgprs=32 (will use v0..v24 in full
    // body), rsrc1=0xE0AF0003 (32-vgpr allocation), rsrc2=0x9E
    // (USER_SGPR_COUNT=15, wg_id_x at s15).  LDS = 1024 B.
    uint64 size = emit_amdgpu_code_object_lds("attn_decode_f32", 15,
                                               asm_text_buf, asm_text_len,
                                               40, 8, 18, 32,
                                               0xE0AF0003, 0x0000009E, 0x00000010, 0x0408,
                                               args_desc, 5,
                                               1024)
    uint64 fd = file_open(out_path, 1)
    if fd > 0xFFFFFFFFFFFFF000 {
        write(2, "emit_amdgpu_attn_decode_f32_blob: cannot open output\n", 53)
        return 1
    }
    file_write(fd, amd_buf, size)
    file_close(fd)
    return 0
}

// Qwen3-14B variant: kv_ratio = nh/nkv = 40/8 = 5.  Same body otherwise;
// caller must dispatch with grid_x = 40 (one WG per Q head).
@export
fn emit_amdgpu_attn_decode_f32_14b_blob(uint64 out_path) -> uint64 {
    uint64[10] args_desc
    _emit_attn_decode_f32_body_kvr(args_desc, 5)
    uint64 size = emit_amdgpu_code_object_lds("attn_decode_f32_14b", 19,
                                               asm_text_buf, asm_text_len,
                                               40, 8, 18, 32,
                                               0xE0AF0003, 0x0000009E, 0x00000010, 0x0408,
                                               args_desc, 5,
                                               1024)
    uint64 fd = file_open(out_path, 1)
    if fd > 0xFFFFFFFFFFFFF000 {
        write(2, "emit_amdgpu_attn_decode_f32_14b_blob: cannot open output\n", 58)
        return 1
    }
    file_write(fd, amd_buf, size)
    file_close(fd)
    return 0
}

// Per-head RoPE for Qwen3 decode: head_dim = 128 hardcoded, half = 64.
// Each WG handles one head's 128-element slice; block = 64 lanes,
// one lane per (i, i+half) pair.  In-place rotation:
//   x[..i..]      = x[..i..] * cos[i]      - x[..i+half..] * sin[i]
//   x[..i+half..] = x[..i..] * sin[i]      + x[..i+half..] * cos[i]
//
// Kernarg layout (32 bytes, 4 args):
//   [0x00] x_ptr   → s[4:5]
//   [0x08] cos_ptr → s[6:7]   (half = 64 f32s)
//   [0x10] sin_ptr → s[8:9]   (half = 64 f32s)
//   [0x18] n_heads → s[10:11] (used only as the s_cmp_ge_u32 bound)
//
// VGPR layout: v0 = lane id; v1 = lane*4; v2 = x1; v3 = x2; v4 = c;
// v5 = s; v8 = x1*c; v6 = y1; v9 = y2.
// Per-head RoPE for Qwen3 decode (shared cos/sin tables across heads,
// in-place rotation).  Differs from the existing _emit_rope_f32_body
// which assumes per-row cos/sin tables of length M*64.
fn _emit_rope_qwen3_f32_body(uint64 args_desc) {
    asm_init()

    asm_u32_arch(0xF40C0100, 0xF40C0100); asm_u32_arch(0xF8000000, 0xFA000000) // s_load_b256/dwordx8
    asm_u32_arch(0xBF89FC07, 0xBF8CC07F) // s_waitcnt lgkmcnt(0)

    asm_u32     (0xBF090A0F)             // s_cmp_ge_u32 s15, s10
    uint64 cbranch_idx = asm_text_len / 4
    asm_u32_arch(0xBFA20000, 0xBF850000) // s_cbranch_scc1 (patched)

    asm_u32_arch(0x840C890F, 0x8F0C890F) // s_lshl_b32 s12, s15, 9
    asm_u32     (0x80100C04)             // s_add_u32  s16, s4, s12 (SOP2 stable)
    asm_u32     (0x82118005)             // s_addc_u32 s17, s5, 0   (SOP2 stable)

    asm_u32_arch(0x30020082, 0x34020082) // v_lshlrev_b32 v1, 2, v0
    asm_s_delay_alu(0x01)                // gfx11: s_delay_alu; gfx10: s_nop 0

    // global_load_b32 with sbase: same NULL-bit re-encode as off-form.
    asm_u32_arch(0xDC520000, 0xDC308000); asm_u32(0x02100001) // load v2 from s[16:17]
    asm_u32_arch(0xDC520100, 0xDC308100); asm_u32(0x03100001) // load v3, offset:256
    asm_u32_arch(0xDC520000, 0xDC308000); asm_u32(0x04060001) // load v4 from s[6:7]
    asm_u32_arch(0xDC520000, 0xDC308000); asm_u32(0x05080001) // load v5 from s[8:9]
    asm_u32_arch(0xBF8903F7, 0xBF8C3F70) // s_waitcnt vmcnt(0)

    asm_u32     (0x10100902)             // v_mul_f32 v8, v2, v4   (VOP2 stable)
    asm_u32     (0x100C0B03)             // v_mul_f32 v6, v3, v5
    asm_u32     (0x080C0D08)             // v_sub_f32 v6, v8, v6   (VOP2 op stable)
    asm_u32     (0x10120B02)             // v_mul_f32 v9, v2, v5
    asm_u32     (0x56120903)             // v_fmac_f32 v9, v3, v4  (VOP2 stable)
    asm_s_delay_alu(0x01)

    asm_u32_arch(0xDC6A0000, 0xDC708000); asm_u32(0x00100601) // store v6 to s[16:17]
    asm_u32_arch(0xDC6A0100, 0xDC708100); asm_u32(0x00100901) // store v9, offset:256
    asm_u32_arch(0xBC7C0000, 0xBBFD0000) // s_waitcnt_vscnt null, 0

    asm_u32_arch(0xBFB00000, 0xBF810000) // s_endpgm

    uint64 total_dwords = asm_text_len / 4
    uint64 simm16 = total_dwords - cbranch_idx - 2
    uint64 sccbr_top = 0xBFA20000
    if _is_gfx10() != 0 { sccbr_top = 0xBF850000 }
    asm_patch_u32(cbranch_idx, sccbr_top | (simm16 & 0xFFFF))

    uint64 a0 = args_desc + 0;   unsafe { *(a0 as uint64) = 8 }
    uint64 a1 = args_desc + 8;   unsafe { *(a1 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a2 = args_desc + 16;  unsafe { *(a2 as uint64) = 8 }
    uint64 a3 = args_desc + 24;  unsafe { *(a3 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a4 = args_desc + 32;  unsafe { *(a4 as uint64) = 8 }
    uint64 a5 = args_desc + 40;  unsafe { *(a5 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a6 = args_desc + 48;  unsafe { *(a6 as uint64) = 8 }
    uint64 a7 = args_desc + 56;  unsafe { *(a7 as uint64) = AMD_ARG_KIND_BY_VALUE }
}

@export
fn emit_amdgpu_rope_qwen3_f32_blob(uint64 out_path) -> uint64 {
    uint64[8] args_desc
    _emit_rope_qwen3_f32_body(args_desc)
    uint64 size = emit_amdgpu_code_object_lds("rope_qwen3_f32", 14,
                                               asm_text_buf, asm_text_len,
                                               32, 8, 18, 16,
                                               0xE0AF0001, 0x0000009E, 0x00000010, 0x0408,
                                               args_desc, 4,
                                               0)
    uint64 fd = file_open(out_path, 1)
    if fd > 0xFFFFFFFFFFFFF000 {
        write(2, "emit_amdgpu_rope_qwen3_f32_blob: cannot open output\n", 53)
        return 1
    }
    file_write(fd, amd_buf, size)
    file_close(fd)
    return 0
}

// Qwen3-0.6B QKV-split helper: copy K (1024 f32) + V (1024 f32) out of
// the fused d_qkv buffer into the per-step KV cache slots.  Hardcoded
// shape: q_dim = 2048 → q_byte_offset = 8192; kv_dim = 1024.  Block =
// 128 lanes, grid = 8 (8 * 128 = 1024 elements per slot).  Used to
// keep the qkv matmul → split → qknorm → rope → attn chain entirely
// on-device, dropping the CPU memcpy that previously required sync 1.
//
// Kernarg layout (24 bytes, 3 args):
//   [0x00] uint64 src_qkv → s[4:5]
//   [0x08] uint64 dst_k   → s[6:7]
//   [0x10] uint64 dst_v   → s[8:9]
// q_dim_bytes parameter: 0x2000 (= q_dim=2048 × 4) for Qwen3-0.6B,
// 0x5000 (= q_dim=5120 × 4) for Qwen3-14B.  kv_dim×4 = 0x1000 in both
// (kv_dim=1024 unchanged across these models).  Block=128, grid=8
// (= kv_dim/128) — same for both since kv_dim is unchanged.
fn _emit_qkv_split_f32_body_qd(uint64 args_desc, uint64 q_dim_bytes) {
    asm_init()

    asm_u32_arch(0xF40C0100, 0xF40C0100); asm_u32_arch(0xF8000000, 0xFA000000)
    asm_u32_arch(0xBF89FC07, 0xBF8CC07F)

    asm_u32_arch(0x840E890F, 0x8F0E890F)           // s_lshl_b32 s14, s15, 9
    asm_u32_arch(0xBE8C00FF, 0xBE8C03FF); asm_u32(q_dim_bytes & 0xFFFFFFFF) // s_mov_b32 s12, lit
    asm_u32     (0x800C0E0C)
    asm_u32     (0x80100C04)
    asm_u32     (0x82118005)
    asm_u32_arch(0xBE8D00FF, 0xBE8D03FF); asm_u32(0x00001000) // s_mov_b32 s13, 0x1000
    asm_u32     (0x800C0D0C)
    asm_u32     (0x80120C04)
    asm_u32     (0x82138005)

    asm_u32     (0x80140E06)
    asm_u32     (0x82158007)
    asm_u32     (0x80160E08)
    asm_u32     (0x82178009)

    asm_u32_arch(0x30020082, 0x34020082)           // v_lshlrev_b32 v1, 2, v0
    asm_s_delay_alu(0x01)

    asm_u32_arch(0xDC520000, 0xDC308000); asm_u32(0x02100001) // global_load_b32 v2, K
    asm_u32_arch(0xDC520000, 0xDC308000); asm_u32(0x03120001) // global_load_b32 v3, V
    asm_u32_arch(0xBF8903F7, 0xBF8C3F70)

    asm_u32_arch(0xDC6A0000, 0xDC708000); asm_u32(0x00140201) // global_store_b32 dst_K
    asm_u32_arch(0xDC6A0000, 0xDC708000); asm_u32(0x00160301) // global_store_b32 dst_V
    asm_u32_arch(0xBC7C0000, 0xBBFD0000)

    asm_u32_arch(0xBFB00000, 0xBF810000)

    uint64 a0 = args_desc + 0;   unsafe { *(a0 as uint64) = 8 }
    uint64 a1 = args_desc + 8;   unsafe { *(a1 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a2 = args_desc + 16;  unsafe { *(a2 as uint64) = 8 }
    uint64 a3 = args_desc + 24;  unsafe { *(a3 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a4 = args_desc + 32;  unsafe { *(a4 as uint64) = 8 }
    uint64 a5 = args_desc + 40;  unsafe { *(a5 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
}

