        return 1
    }

    ast_init(65536)
    codegen_init(1048576, v2_src, v2_tokens)
    parser_init(v2_tokens, v2_tcount)
    uint64 v2_root = parse_module()
    if v2_root == 0 {
        write(2, "emit_amdgpu_llama_3b_megakernel_v2_f32_swexp_blob: parse_module returned null -- syntax error in .mlr\n", 102)
        return 1
    }

    uint64 fn_node = 0
    uint32 wc = ast_child(v2_root)
    while wc != 0 {
        uint32 k = ast_kind(wc)
        if k == 2 {
            if ast_fn_is_kernel(wc) != 0 {
                uint32 name_tok = ast_data1(wc)
                if tok_matches(name_tok, "llama_3b_layer_megakernel", 25) != 0 {
                    fn_node = wc
                    wc = 0
                } else {
                    uint32 nxt = ast_next(wc)
                    wc = nxt
                }
            } else {
                uint32 nxt = ast_next(wc)
                wc = nxt
            }
        } else {
            uint32 nxt = ast_next(wc)
            wc = nxt
        }
    }
    if fn_node == 0 {
        write(2, "emit_amdgpu_llama_3b_megakernel_v2_f32_swexp_blob: @kernel fn llama_3b_layer_megakernel not found in .mlr\n", 106)
        return 1
