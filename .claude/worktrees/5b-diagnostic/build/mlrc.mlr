        // x0 = path
        emit_a64_mov(0, path_r)
        // x1 = argv
        emit_a64_mov(1, argv_r)
        // x2 = envp
        uint64 envp_off_a = static_lookup_by_name("cli_envp", 8)
        if envp_off_a != 0xFFFFFFFF {
            emit_a64_static_load(envp_off_a)
            emit_a64_mov(2, 0)
            emit_a64_mov(0, path_r)       // restore x0
        } else {
            emit_a64_mov_imm(2, 0)
        }
        // syscall execve
        uint64 execve_nr_a = ir_a64_syscall_nr(59)
        emit_a64_syscall_nr(execve_nr_a)
        emit_a64_svc()
        // Save errno
        uint64 errno_off_a = static_lookup_by_name("exec_errno", 10)
        if errno_off_a != 0xFFFFFFFF {
            emit_a64_static_store(errno_off_a)
        }
        if dst_r != 0xFFFFFFFF && dst_r != 0 {
            emit_a64_mov(dst_r, 0)
        }
        if dst_r == 0xFFFFFFFF {
            ir_a64_emit_store_spill(0, dest_v)
        }
        return
