    if op == 70 {
        // IR_ALLOC: allocate memory with size header
        // src1 = size vreg (if != 0), or imm = constant size (if src1 == 0)
        uint64 size_reg = 0
        if s1_v != 0 {
            size_reg = ir_resolve_src(s1_v, 0)
        } else {
