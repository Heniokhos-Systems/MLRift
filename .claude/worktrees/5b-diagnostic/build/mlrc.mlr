    while codegen_output_len() < header4 + text_aligned4 { emit_byte(0) }
    uint64 data_file_off4 = codegen_output_len()
    emit_static_data()
    uint64 data_raw_size4 = codegen_output_len() - data_file_off4
    uint64 data_aligned4 = (data_raw_size4 + 0x1FF) & ~0x1FF
    if data_aligned4 == 0 { data_aligned4 = 0x200 }
    while codegen_output_len() < data_file_off4 + data_aligned4 { emit_byte(0) }
    uint64 text_va_size4 = (text_size4 + 0xFFF) & ~0xFFF
    uint64 data_rva4 = 0x1000 + text_va_size4
    uint64 data_va_size4 = (data_raw_size4 + 0xFFF) & ~0xFFF
    if data_va_size4 == 0 { data_va_size4 = 0x1000 }
