                exit(0)
            } else if str_starts_with(arg, "--emit-amdgpu-qkv-split-f32-14b=", 32) != 0 {
                uint64 qs14_path = arg + 32
                uint64 qs14_rc = emit_amdgpu_qkv_split_f32_14b_blob(qs14_path)
                if qs14_rc != 0 {
                    write(2, "mlrc: --emit-amdgpu-qkv-split-f32-14b failed\n", 45)
                    exit(1)
                }
                write(1, "mlrc: wrote ", 12)
                uint64 qs14l = str_len(qs14_path)
                write(1, qs14_path, qs14l)
                write(1, " (amdgpu qkv-split-f32-14b code object, q_dim=5120)\n", 53)
                exit(0)
            } else if str_starts_with(arg, "--emit-amdgpu-qkv-split-f32-batched-14b=", 40) != 0 {
                uint64 qsb14_path = arg + 40
                uint64 qsb14_rc = emit_amdgpu_qkv_split_f32_batched_14b_blob(qsb14_path)
                if qsb14_rc != 0 {
                    write(2, "mlrc: --emit-amdgpu-qkv-split-f32-batched-14b failed\n", 53)
                    exit(1)
                }
                write(1, "mlrc: wrote ", 12)
                uint64 qsb14l = str_len(qsb14_path)
                write(1, qsb14_path, qsb14l)
                write(1, " (amdgpu qkv-split-f32-batched-14b code object)\n", 49)
                exit(0)
            } else if str_starts_with(arg, "--emit-amdgpu-attn-decode-f32=", 30) != 0 {
                // Fused decode-shape attention kernel (Qwen3-0.6B
                // hardcoded shape: nh=16, nkv=8, hd=128).  Single
                // launch per layer, all 16 heads in parallel.  Body
                // currently a stub (s_endpgm) for KD scaffolding —
                // real compute lands incrementally.
                uint64 ad_path = arg + 30
                uint64 ad_rc = emit_amdgpu_attn_decode_f32_blob(ad_path)
                if ad_rc != 0 {
                    write(2, "mlrc: --emit-amdgpu-attn-decode-f32 failed\n", 43)
                    exit(1)
                }
                write(1, "mlrc: wrote ", 12)
                uint64 adl = str_len(ad_path)
                write(1, ad_path, adl)
                write(1, " (amdgpu attn-decode-f32 code object)\n", 38)
                exit(0)
            // --emit-amdgpu-gemm-f32= deleted — Phase 3c-3 owns AST path.
            } else if str_starts_with(arg, "--emit-amdgpu-gemm-f32-lds=", 27) != 0 {
                // LLM Phase A milestone 3 native-emit (task #70).
                // 16x16 LDS-tiled GEMM, 2 KiB LDS per workgroup.
                uint64 gl_path = arg + 27
                uint64 gl_rc = emit_amdgpu_gemm_f32_lds_blob(gl_path)
                if gl_rc != 0 {
                    write(2, "mlrc: --emit-amdgpu-gemm-f32-lds failed\n", 40)
                    exit(1)
                }
                write(1, "mlrc: wrote ", 12)
                uint64 gll = str_len(gl_path)
                write(1, gl_path, gll)
                write(1, " (amdgpu gemm-f32-lds code object)\n", 35)
                exit(0)
            // --emit-amdgpu-layernorm-f32= deleted — Phase 3b-3 owns AST path.
            // --emit-amdgpu-rmsnorm-f32= (non-parametric N=256) deleted —
            // Phase 3b owns the AST-walker path; for production sizes use
            // --emit-amdgpu-rmsnorm-f32-N=<N>:<path>.
            // --emit-amdgpu-rope-f32= (non-parametric D=128) deleted —
            // Phase 3c-1 owns the AST-walker path; for production D values
            // use --emit-amdgpu-rope-f32-D=<D>:<path>.
            } else if str_starts_with(arg, "--emit-amdgpu-rope-f32-D=", 25) != 0 {
                // Format: --emit-amdgpu-rope-f32-D=<D>:<path>
                uint64 rpd_arg = arg + 25
                uint64 rpd_D = 0
                uint64 rpd_i = 0
                while 1 == 1 {
                    uint64 rpd_p = rpd_arg + rpd_i
                    uint64 rpd_c = 0
                    unsafe { *(rpd_p as uint8) -> rpd_c }
                    if rpd_c == 0 || rpd_c == 58 { break }
                    if rpd_c < 48 || rpd_c > 57 {
                        write(2, "mlrc: --emit-amdgpu-rope-f32-D: expected <D>:<path>\n", 53)
                        exit(1)
                    }
                    rpd_D = rpd_D * 10 + (rpd_c - 48)
                    rpd_i = rpd_i + 1
                }
                uint64 rpd_path = rpd_arg + rpd_i + 1
                uint64 rpd_rc = emit_amdgpu_rope_f32_D_blob(rpd_path, rpd_D)
                if rpd_rc != 0 {
                    write(2, "mlrc: --emit-amdgpu-rope-f32-D failed\n", 39)
                    exit(1)
                }
                write(1, "mlrc: wrote ", 12)
                uint64 rpdl = str_len(rpd_path)
                write(1, rpd_path, rpdl)
                write(1, " (amdgpu rope-f32 code object, D-parametric)\n", 46)
                exit(0)
            } else if str_starts_with(arg, "--emit-amdgpu-kv-broadcast-f32=", 31) != 0 {
                uint64 kvb_path = arg + 31
                uint64 kvb_rc = emit_amdgpu_kv_broadcast_f32_blob(kvb_path)
                if kvb_rc != 0 {
                    write(2, "mlrc: --emit-amdgpu-kv-broadcast-f32 failed\n", 45)
                    exit(1)
                }
                write(1, "mlrc: wrote ", 12)
                uint64 kvbl = str_len(kvb_path)
                write(1, kvb_path, kvbl)
                write(1, " (amdgpu kv-broadcast-f32 code object)\n", 40)
                exit(0)
            } else if str_starts_with(arg, "--emit-amdgpu-head-extract-f32=", 31) != 0 {
                uint64 he_path = arg + 31
                uint64 he_rc = emit_amdgpu_head_extract_f32_blob(he_path)
                if he_rc != 0 {
                    write(2, "mlrc: --emit-amdgpu-head-extract-f32 failed\n", 45)
                    exit(1)
                }
                write(1, "mlrc: wrote ", 12)
                uint64 hel = str_len(he_path)
                write(1, he_path, hel)
                write(1, " (amdgpu head-extract-f32 code object)\n", 40)
                exit(0)
            } else if str_starts_with(arg, "--emit-amdgpu-head-insert-f32=", 30) != 0 {
                uint64 hi_path = arg + 30
                uint64 hi_rc = emit_amdgpu_head_insert_f32_blob(hi_path)
                if hi_rc != 0 {
                    write(2, "mlrc: --emit-amdgpu-head-insert-f32 failed\n", 44)
                    exit(1)
                }
                write(1, "mlrc: wrote ", 12)
                uint64 hil = str_len(hi_path)
                write(1, hi_path, hil)
                write(1, " (amdgpu head-insert-f32 code object)\n", 39)
                exit(0)
            } else if str_starts_with(arg, "--emit-amdgpu-transpose-f32=", 28) != 0 {
                uint64 tr_path = arg + 28
                uint64 tr_rc = emit_amdgpu_transpose_f32_blob(tr_path)
                if tr_rc != 0 {
                    write(2, "mlrc: --emit-amdgpu-transpose-f32 failed\n", 42)
                    exit(1)
                }
                write(1, "mlrc: wrote ", 12)
                uint64 trl = str_len(tr_path)
                write(1, tr_path, trl)
                write(1, " (amdgpu transpose-f32 code object)\n", 37)
                exit(0)
            } else if str_starts_with(arg, "--emit-amdgpu-embedding-lookup-f32=", 35) != 0 {
                uint64 emb_path = arg + 35
                uint64 emb_rc = emit_amdgpu_embedding_lookup_f32_blob(emb_path)
                if emb_rc != 0 {
                    write(2, "mlrc: --emit-amdgpu-embedding-lookup-f32 failed\n", 49)
                    exit(1)
                }
                write(1, "mlrc: wrote ", 12)
                uint64 embl = str_len(emb_path)
                write(1, emb_path, embl)
                write(1, " (amdgpu embedding-lookup-f32 code object)\n", 44)
                exit(0)
            } else if str_starts_with(arg, "--emit-amdgpu-argmax-logits-f32=", 32) != 0 {
                uint64 am_path = arg + 32
                uint64 am_rc = emit_amdgpu_argmax_logits_f32_blob(am_path)
                if am_rc != 0 {
                    write(2, "mlrc: --emit-amdgpu-argmax-logits-f32 failed\n", 46)
                    exit(1)
                }
                write(1, "mlrc: wrote ", 12)
                uint64 aml = str_len(am_path)
                write(1, am_path, aml)
                write(1, " (amdgpu argmax-logits-f32 code object)\n", 41)
                exit(0)
            // --emit-amdgpu-softmax-causal-f32= (non-parametric N=256)
            // deleted — Phase 3b-4 owns the AST-walker path.  For
            // production sizes use --emit-amdgpu-softmax-causal-f32-N=.
            // --emit-amdgpu-softmax-f32= deleted — Phase 3b-2 owns AST path.
            } else if str_starts_with(arg, "--emit-amdgpu-softmax-causal-f32-N=", 35) != 0 {
                // Format: --emit-amdgpu-softmax-causal-f32-N=<N>:<path>
                uint64 scn_arg = arg + 35
                uint64 scn_N = 0
                uint64 scn_i = 0
                while 1 == 1 {
                    uint64 scn_p = scn_arg + scn_i
                    uint64 scn_c = 0
                    unsafe { *(scn_p as uint8) -> scn_c }
                    if scn_c == 0 || scn_c == 58 { break }
