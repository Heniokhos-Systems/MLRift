// ─────────────────────────────────────────────────────────────────────
// Slice 6.3 — Llama-3.2-1B SPECK4 (M_EFF=4) layer mega-kernel v2.
//
// Mirror of emit_amdgpu_qwen3_megakernel_speck4_blob_v2 above, but for
// the Llama-3.2-1B body in examples/llm/llama_layer_megakernel_speck4.mlr.
// Emits a v2 .co by:
//   1. Parsing examples/llm/llama_layer_megakernel_speck4.mlr
//   2. Locating the @kernel fn llama_layer_megakernel_speck4 node in the AST
//   3. Calling recognize_megakernel_swiglu_dense_gqa_speck4 — the SAME
//      speck4 recognizer as Qwen3.  Name-dispatch installs the Llama arch
//      globals (HIDDEN=2048, HEAD_DIM=64, N_HEADS=32, N_KV_HEADS=8,
//      FF=8192, USE_QKNORM=0, ROPE_PAIR_LAYOUT=1) before any phase
//      emitter runs.
//   4. Wrapping the emitted ISA bytes into a complete .co via the standard
//      multi_code_object path.
//
// Returns 0 on success, 1 on error.
// MUST be called just before exit; clobbers global parser/AST/codegen state.
@export
fn emit_amdgpu_llama_megakernel_speck4_blob_v2(uint64 out_path) -> uint64 {
    uint64 kname = "llama_layer_megakernel_speck4"
    uint64 klen  = 29

    // ── Step 1: parse examples/llm/llama_layer_megakernel_speck4.mlr ───
    uint64 mlr_path = "examples/llm/llama_layer_megakernel_speck4.mlr"
    uint64 mlr_fd = file_open(mlr_path, 0)
    if mlr_fd > 0xFFFFFFFFFFFFF000 {
        write(2, "emit_amdgpu_llama_megakernel_speck4_blob_v2: cannot open examples/llm/llama_layer_megakernel_speck4.mlr\n", 104)
        return 1
    }
    uint64 mlr_sz = file_size(mlr_fd)
    if mlr_sz == 0 {
        write(2, "emit_amdgpu_llama_megakernel_speck4_blob_v2: empty .mlr file\n", 61)
        file_close(mlr_fd)
        return 1
    }
    uint64 v2_src = alloc(mlr_sz + 1)
    file_read(mlr_fd, v2_src, mlr_sz)
    file_close(mlr_fd)
    uint64 v2_nul_p = v2_src + mlr_sz
    uint8 v2_nul = 0
    unsafe { *(v2_nul_p as uint8) = v2_nul }

    // Lex the source
    uint64 v2_max_tok = 65536
    uint64 v2_tokens = alloc(v2_max_tok * 16)
    lexer_init(v2_src, mlr_sz, v2_tokens, v2_max_tok)
    uint64 v2_tcount = lexer_run()
    if v2_tcount == 0 {
        write(2, "emit_amdgpu_llama_megakernel_speck4_blob_v2: lexer produced 0 tokens -- syntax error in .mlr\n", 93)
        return 1
    }

    // Parse into a fresh AST arena
    ast_init(65536)
    codegen_init(1048576, v2_src, v2_tokens)
    parser_init(v2_tokens, v2_tcount)
    uint64 v2_root = parse_module()
    if v2_root == 0 {
        write(2, "emit_amdgpu_llama_megakernel_speck4_blob_v2: parse_module returned null -- syntax error in .mlr\n", 96)
        return 1
    }

    // ── Step 2: find the @kernel fn llama_layer_megakernel_speck4 node ──
    uint64 fn_node = 0
    uint32 wc = ast_child(v2_root)
    while wc != 0 {
        uint32 k = ast_kind(wc)
        if k == 2 {
            if ast_fn_is_kernel(wc) != 0 {
                uint32 name_tok = ast_data1(wc)
                if tok_matches(name_tok, "llama_layer_megakernel_speck4", 29) != 0 {
                    fn_node = wc
                    wc = 0   // break
                } else {
                    uint32 nxt = ast_next(wc)
                    wc = nxt
                }
            } else {
                uint32 nxt = ast_next(wc)
                wc = nxt
            }
        } else {
            uint32 nxt = ast_next(wc)
            wc = nxt
        }
    }
    if fn_node == 0 {
        write(2, "emit_amdgpu_llama_megakernel_speck4_blob_v2: @kernel fn llama_layer_megakernel_speck4 not found in .mlr\n", 104)
        return 1
    }

    // ── Step 3: run the speck4 recognizer (name-dispatch swaps in Llama arch) ──
    kt_reset()
    uint64 rec_rc = recognize_megakernel_swiglu_dense_gqa_speck4(fn_node, v2_src, kname, klen)
    if rec_rc != 0 {
        write(2, "emit_amdgpu_llama_megakernel_speck4_blob_v2: recognizer shape mismatch\n", 71)
        return 1
    }

    // ── Step 4: wrap into .co and write ────────────────────────────────
    uint64 size = emit_amdgpu_multi_code_object()

    uint64 fd = file_open(out_path, 1)
    if fd > 0xFFFFFFFFFFFFF000 {
        write(2, "emit_amdgpu_llama_megakernel_speck4_blob_v2: cannot open output\n", 64)
        return 1
    }
    file_write(fd, amd_buf, size)
    file_close(fd)
    return 0
}
// Mega-kernel AST-walker lift — multi-phase recognizer + sub-recognizers.
//
// Slice 4.19.0: scaffold.  Implements the structural recognizer skeleton
// and emits a stub kernel (9 × s_nop phases + 8 working cross-WG barriers
// + max_phase early-exit checks).
//
// Slice 4.19.1: phase 1 (input rmsnorm, WG-0 gated).  Adds
// recognize_phase_rmsnorm_wg_gated and _emit_rmsnorm_wg_gated_inline
// (slice 4.19.6 renamed from _emit_phase1_rmsnorm_inline and parameterized
// by kernarg byte offsets so phase 11 can reuse it); replaces the phase-1
// s_nop stub with the real inline rmsnorm ISA when the source has the
// rmsnorm_wg0_marker call in its phase-1 block.
//
// Top-level: recognize_megakernel_swiglu_dense_gqa(fn_node, source, kname_ptr, nl)
// walks the function body parameter list and body shape, then delegates to
// mega_emit_stub_kernel which produces a real .co that loads, launches, and
// completes without GPU hang at max_phase=0.
//
// Spec: docs/superpowers/specs/2026-05-07-megakernel-ast-walker-lift-design.md

// ── Named constants ───────────────────────────────────────────────────────
// MEGA_KERNARG_COUNT: number of kernel arguments in qwen3_layer_megakernel.
//   24 = (in_residual, out_residual, qkv_w, o_w, gate_up_w, down_w,
//         in_norm_g, post_norm_g, q_norm_g, k_norm_g, rope_cos, rope_sin,
//         kc_layer, vc_layer, pos, barrier_counter, gu_scratch,
//         b_x_norm_g, b_qkv_g, b_attn_q_g, b_mid_g, b_mid_norm_g,
//         b_attn_out_g, max_phase)
static uint64 MEGA_KERNARG_COUNT = 24

// MEGA_WG_PERSIST: number of persistent workgroups in the v2 kernel.
//   Matches the HIP source #define WG_PERSIST 512.
static uint64 MEGA_WG_PERSIST = 512

// ── speck4 mega-kernel constants ──────────────────────────────────────────
// Slice 4.20.0: scaffold for the M_EFF=4 multi-query mega-kernel
// (qwen3_layer_megakernel_speck4).  Identical 24-arg kernarg layout as the
// base; per-stream slabs are 4× larger (M_EFF=4 streams).
//
// MEGA_KERNARG_COUNT_SPECK4 — same 24 args as base.
static uint64 MEGA_KERNARG_COUNT_SPECK4 = 24

// MEGA_M_EFF — number of speculative-decode streams per layer pass.
static uint64 MEGA_M_EFF = 4

// MEGA_LDS_SPECK4 — phase 7 needs attn_w_lds[M_EFF*128]=512 floats=2048B
// plus wave_tmp[1]=4B at offset 0 (same layout as base for clean reuse with
// _emit_rmsnorm_wg_gated_inline's broadcast slot).  Round up to 2080
// (multiple of 32) for safety.
//   layout: offset 0..3   = wave_tmp[0]            (4 B)
//           offset 4..31  = padding                (28 B; alignment headroom)
//           offset 32..2079 = attn_w_lds[512]      (2048 B)
// The base mega-kernel uses LDS=516; speck4 explicitly overrides to 2080.
static uint64 MEGA_LDS_SPECK4 = 2080

// AST_KIND_BLOCK: ast_kind() value for a Block node (used in recognizer).
static uint64 AST_KIND_BLOCK = 15

// ── Slice 5.0 — arch globals (Phase A: Llama-3.2-1B mega-kernel port) ─────
// Default values match Qwen3-0.6B literals so emitter byte output is
// unchanged at this slice (no emitter currently reads these globals).
// Subsequent slices (5.1-5.6) progressively replace Qwen3 hard-coded
// literals in the 6 base emitters with reads from these globals.
//
// Set by mega_set_arch_qwen3_06b() / mega_set_arch_llama_1b() via the
// megakernel_dispatch_arch() name-dispatch helper called from the top of
// recognize_megakernel_swiglu_dense_gqa{,_speck4}.
static uint64 MEGA_HIDDEN              = 1024     // Qwen3 default; setter overrides
static uint64 MEGA_HEAD_DIM            =  128
static uint64 MEGA_N_HEADS             =   16
static uint64 MEGA_N_KV_HEADS          =    8
static uint64 MEGA_FF                  = 3072
static uint64 MEGA_USE_QKNORM          =    1     // Qwen3=1, Llama=0
static uint64 MEGA_ROPE_PAIR_LAYOUT    =    0     // 0 = NEOX split-half (Qwen3),
                                                  // 1 = NORM consecutive-pair (Llama)
static uint64 MEGA_RMSNORM_EPS_BITS    = 0x3727C5AC  // phase 1/11 RMSNorm eps.
                                                     // Both Qwen3 and Llama use 1e-5
                                                     // here. The phase-5 qknorm eps
                                                     // (1e-6) is hardcoded in slice
                                                     // 5.3 under the MEGA_USE_QKNORM
                                                     // branch.
// Slice 8.0 (2026-05-13) — precomputed f32 bit pattern for 1.0f / MEGA_HIDDEN.
// _arch_inv_n_f32_bits() below only handles power-of-2 inputs.  Llama-3.2-3B
// has HIDDEN=3072 (not power of 2 — 3 × 2^10), so the rmsnorm-scale literal
// must be precomputed per-arch by the setter instead of derived at emit time.
//   1/1024 = 0x3A800000  (Qwen3-0.6B)
//   1/2048 = 0x3A000000  (Llama-3.2-1B)
//   1/3072 = 0x39AAAAAB  (Llama-3.2-3B)
//   1/4096 = 0x39800000  (Mistral-7B)
static uint64 MEGA_INV_HIDDEN_BITS      = 0x3A800000  // Qwen3 default (1/1024)

// Slice 8.2-B Phase 2.6 (2026-05-14) — precomputed f32 bit pattern for N
// (== MEGA_HIDDEN itself), used by the cputree rmsnorm helper to compute
// mean_sq = ssq / N via correctly-rounded IEEE f32 div (matching CPU
// vdivss).  Required when N is not a power of 2 (Llama-3B N=3072 → 1/N
// is not exactly representable, so multiplying by MEGA_INV_HIDDEN_BITS
// drifts by 1 ULP vs CPU).
//   1024 → 0x44800000   (Qwen3)
//   2048 → 0x45000000   (Llama-1B)
//   3072 → 0x45400000   (Llama-3B)
//   4096 → 0x45800000   (Mistral)
static uint64 MEGA_HIDDEN_F32_BITS      = 0x44800000  // Qwen3 default (1024.0f)

// Slice 8.3 F3b (2026-05-14) — selects weight load dtype in the Llama-3B
// cputree gemv phases (3 / 9 / 13).  Default 0 = bf16 (`global_load_u16` +
// lshl-16 widen, stride k_pad*2 bytes).  Set to 1 by
// `emit_amdgpu_llama_3b_megakernel_v2_f32_blob` to emit f32 weight loads
// (`global_load_b32`, no widen, stride k_pad*4 bytes) — used by the fp32
// branch of the Llama-3B driver that uploads dequantized fp32 weights.
// The flag is reset to 0 after emit so subsequent bf16 emits stay byte-
// identical.  All other archs (Qwen3 / Llama-1B / Mistral) ignore this
// flag — only the Llama-3B-gated phase-3/9/13 sites consult it.
static uint64 MEGA_WEIGHT_DTYPE          = 0          // 0=bf16, 1=f32

// Slice 8.3 path-B (2026-05-14) — phase-7 softmax `v_exp_f32` selector.
// Default 0 = hardware `v_exp_f32_e32 v22, v20` (single VOP1 op; ≈1 ULP).
// Set to 1 by `emit_amdgpu_llama_3b_megakernel_v2_swexp_blob` (and the
// combined fp32+swexp variant) to emit the CPU-matching minimax exp
// polynomial as ~22 ISA ops inline.  The flag is reset to 0 after each
// such emit so subsequent default emits stay byte-identical.  All other
// archs (Qwen3 / Llama-1B / Mistral) IGNORE this flag — the phase-7 emit
// site additionally gates on `MEGA_HIDDEN == 3072` so a stray write to
// this global cannot perturb the proven 20/20 sister-arch byte patterns.
//
// The polynomial mirrors `exp_f32_fast` in std/qwen3.mlr (lines 991-1054)
// bit-for-bit: 5-term Horner schedule with constants
//   c5=0x3AAEC3CD, c4=0x3C1D6AF5, c3=0x3D635847, c2=0x3E75FDF0, c1=0x3F317218,
// argument-reduction via floor(|r|+0.5) using v_cvt_i32_f32 (truncation of
// non-negative = floor) and explicit sign tracking via the input's sign
// bit, and 2^n via manual exponent bit-injection (`(127±n_abs)<<23`).
static uint64 MEGA_SOFTWARE_EXP         = 0          // 0=hw v_exp_f32, 1=poly

// ── Slice 5.0 — arch setters + name-dispatch + bit-math helpers ───────────

fn mega_set_arch_qwen3_06b() {
    MEGA_HIDDEN          = 1024
    MEGA_HEAD_DIM        =  128
    MEGA_N_HEADS         =   16
    MEGA_N_KV_HEADS      =    8
    MEGA_FF              = 3072
    MEGA_USE_QKNORM      =    1
    MEGA_ROPE_PAIR_LAYOUT=    0
    MEGA_M_EFF           =    4   // slice 4.21.1: default speck4; dispatch
                                  // bumps to 8/16 for _speck8 / _speck16
    MEGA_RMSNORM_EPS_BITS= 0x3727C5AC   // 1e-5f (phase 1/11; phase-5 qknorm
                                        // hardcodes 0x358637BD = 1e-6 in slice 5.3)
    MEGA_INV_HIDDEN_BITS = 0x3A800000   // 1/1024 (slice 8.0)
    MEGA_HIDDEN_F32_BITS = 0x44800000   // 1024.0f (slice 8.2-B phase 2.6)
}

fn mega_set_arch_llama_1b() {
    MEGA_HIDDEN          = 2048
    MEGA_HEAD_DIM        =   64
    MEGA_N_HEADS         =   32
    MEGA_N_KV_HEADS      =    8
    MEGA_FF              = 8192
    MEGA_USE_QKNORM      =    0
    MEGA_ROPE_PAIR_LAYOUT=    1
    MEGA_M_EFF           =    4   // slice 4.21.1: Llama-speck4 default;
                                  // mks8/16 for Llama is future work.
    MEGA_RMSNORM_EPS_BITS= 0x3727C5AC   // 1e-5f (Llama)
    MEGA_INV_HIDDEN_BITS = 0x3A000000   // 1/2048 (slice 8.0)
    MEGA_HIDDEN_F32_BITS = 0x45000000   // 2048.0f (slice 8.2-B phase 2.6)
}

// Slice 8.0 (2026-05-13) — Llama-3.2-3B-Instruct.
// Same body shape as Llama-1B (GQA, RMSNorm, RoPE consecutive pairs, no
// qknorm, SwiGLU FFN); arch knobs:
//   hidden=3072 (NOT power of 2 — first such arch; requires precomputed
//     MEGA_INV_HIDDEN_BITS since _arch_inv_n_f32_bits only handles pow2),
//   head_dim=128 (matches Mistral/Qwen3 path),
//   n_heads=24 (NEW — outer_cap for phase 7 = 24·4 = 96 > 64 → lit32 form,
//     already patched in slice 7.2b for Mistral N_HEADS=32),
//   n_kv_heads=8 (GQA 3:1),
//   ff=8192 (same as Llama-1B; phase 15 silu-mul WG count
//     = (8192+31)/32 = 256, fits the slice 7.2d arch-derived form exactly),
//   rope theta=500000 (Llama-3.x; CPU-side tables), 28 layers (driver).
// Tied lm_head (uses embed.ptr) — same as Llama-1B.
fn mega_set_arch_llama_3b() {
    MEGA_HIDDEN          = 3072
    MEGA_HEAD_DIM        =  128
    MEGA_N_HEADS         =   24
    MEGA_N_KV_HEADS      =    8
    MEGA_FF              = 8192
    MEGA_USE_QKNORM      =    0
    MEGA_ROPE_PAIR_LAYOUT=    1
    MEGA_M_EFF           =    4   // speck4 wired but llama_3b_speck4 .co
                                  // is future work; M=1 base path first.
    MEGA_RMSNORM_EPS_BITS= 0x3727C5AC   // 1e-5f (Llama-3.x)
    MEGA_INV_HIDDEN_BITS = 0x39AAAAAB   // 1/3072 (slice 8.0) — non-pow2 HIDDEN
    MEGA_HIDDEN_F32_BITS = 0x45400000   // 3072.0f (slice 8.2-B phase 2.6)
}

// Slice 7.0 (2026-05-13) — Mistral-7B-Instruct-v0.3.
// Same body shape as Llama-1B (GQA, RMSNorm, RoPE consecutive pairs, no
// qknorm, SwiGLU FFN); arch knobs differ in size:
//   hidden=4096 (vs 2048), head_dim=128 (vs 64; matches Qwen3 path),
//   n_heads=32, n_kv_heads=8 (GQA 4:1, same as Llama-1B),
//   ff=14336 (vs 8192), rope theta=10000 (CPU-side tables; not in this
//   setter), 32 layers (loop bound in driver, not here).
// Untied lm_head (separate output.weight tensor) — handled in driver.
fn mega_set_arch_mistral_7b() {
    MEGA_HIDDEN          = 4096
    MEGA_HEAD_DIM        =  128
    MEGA_N_HEADS         =   32
    MEGA_N_KV_HEADS      =    8
    MEGA_FF              = 14336
    MEGA_USE_QKNORM      =    0
    MEGA_ROPE_PAIR_LAYOUT=    1
    MEGA_M_EFF           =    4   // speck4 wired but mistral_speck4 .co
                                  // is future work; M=1 base path first.
    MEGA_RMSNORM_EPS_BITS= 0x3727C5AC   // 1e-5f (Mistral)
    MEGA_INV_HIDDEN_BITS = 0x39800000   // 1/4096 (slice 8.0)
    MEGA_HIDDEN_F32_BITS = 0x45800000   // 4096.0f (slice 8.2-B phase 2.6)
}

// Slice 8.3 F3b (2026-05-14) — set the weight-dtype gate for the Llama-3B
// cputree gemv phases.  Default 0 (bf16); the f32 emit blob flips this to
// 1 before running the multi-phase body and resets it to 0 after, so the
// bf16 emit path stays byte-identical.
fn mega_set_weight_dtype(uint64 dtype) {
    MEGA_WEIGHT_DTYPE = dtype
}

// Slice 8.3 path-B (2026-05-14) — set the software-exp gate for the Llama-3B
// phase-7 softmax.  Default 0 (hardware v_exp_f32); the swexp emit blobs
// flip this to 1 before running the multi-phase body and reset it to 0
// after, so the default bf16 emit path stays byte-identical to the pre-B
// baseline.
fn mega_set_software_exp(uint64 enable) {
    MEGA_SOFTWARE_EXP = enable
}

// Returns the 32-bit f32 bit pattern of 1.0f/n for n a power of 2 in
// [1, 2^30].  Used by phase 1/11 (n=HIDDEN) and phase 5 qknorm (n=HEAD_DIM).
//
// 1/n = 1.0f * 2^(-log2(n)) → IEEE-754 exponent = 127 - log2(n).
//   bits = (127 - log2(n)) << 23
//   E.g. n=1024 (log2=10) → (117 << 23) = 0x3A800000.  ✓ matches phase 1.
//        n=2048 (log2=11) → (116 << 23) = 0x3A000000.
//        n= 128 (log2= 7) → (120 << 23) = 0x3C000000.  ✓ matches phase 5 qknorm.
//        n=  64 (log2= 6) → (121 << 23) = 0x3C800000.
fn _arch_inv_n_f32_bits(uint64 n) -> uint64 {
    uint64 log2_n = 0
    uint64 v = n
    while v > 1 { v = v >> 1; log2_n = log2_n + 1 }
    uint64 exp = 127 - log2_n
    return (exp & 0xFF) << 23
}

// log2(n) for n a power of 2 in [1, 2^30].
fn _arch_log2_pow2(uint64 n) -> uint64 {
    uint64 r = 0
    uint64 v = n
    while v > 1 { v = v >> 1; r = r + 1 }
    return r
}

// SOPC s_cmp_ge_u32 sX, lit_N: emits inline-imm form for v <= 64,
// else lit32 form.  Used by phase 5 outer-cap / Q boundary / K boundary
// gates whose thresholds depend on (N_HEADS, N_KV_HEADS).
//
// inline-imm: word = 0xBF09<inline_field><sgpr> where inline_field=0x80+v
//   (bits[15:8] = ssrc1 = 0x80+v, bits[7:0] = ssrc0 = sgpr).
// lit32:      word = 0xBF09FF<sgpr>; literal follows in next dword.
fn _emit_s_cmp_ge_u32_lit(uint64 sgpr, uint64 v) {
    if v <= 64 {
        uint64 inline_imm = 0x80 + v
        asm_u32(0xBF090000 | (inline_imm << 8) | (sgpr & 0xFF))
    } else {
        asm_u32(0xBF09FF00 | (sgpr & 0xFF))
        asm_u32(v)
    }
}

// SOPC s_cmp_lt_u32 sX, lit_N: same shape but op=0x0A.
fn _emit_s_cmp_lt_u32_lit(uint64 sgpr, uint64 v) {
    if v <= 64 {
        uint64 inline_imm = 0x80 + v
        asm_u32(0xBF0A0000 | (inline_imm << 8) | (sgpr & 0xFF))
    } else {
        asm_u32(0xBF0AFF00 | (sgpr & 0xFF))
        asm_u32(v)
    }
}

// SOP2 sdst = ssrc * factor.  Emits inline s_lshl_b32 if factor is a
// non-zero power of 2 with shift in [0, 31]; otherwise emits the lit32
// s_mul_i32 form.  Used by phase 5 speck4 per-m row-stride math, where
// QKV row stride differs across archs (Qwen3 16384=pow2, Llama 12288=
// 3*4096 not pow2).
//
// Power-of-2 path: s_lshl_b32 sdst, ssrc, shift  (SOP2 op 8).
//   word = (2<<30)|(8<<23)|(sdst<<16)|((0x80+shift)<<8)|ssrc
// Lit32 path:      s_mul_i32 sdst, ssrc, lit32   (SOP2 op 0x2C in gfx11).
//   Verified via llvm-mc: `s_mul_i32 s19, s16, 12288` → `9613FF10 00003000`.
//   word = (2<<30)|(0x2C<<23)|(sdst<<16)|(0xFF<<8)|ssrc
//        = 0x96000000 | (sdst<<16) | (0xFF<<8) | ssrc
fn _emit_s_mul_u32_pow2_or_lit(uint64 sdst, uint64 ssrc, uint64 factor) {
    uint64 f = factor
    uint64 shift = 0
    uint64 is_pow2 = 1
    if factor == 0 { is_pow2 = 0 }
    while f > 1 {
        if (f & 1) != 0 { is_pow2 = 0 }
        f = f >> 1
        shift = shift + 1
    }
    if is_pow2 != 0 && shift <= 31 {
        // s_lshl_b32 sdst, ssrc, inline shift  (SOP2 op 8)
        uint64 inline_imm = 0x80 + shift
        asm_u32(0x84000000 | ((sdst & 0xFF) << 16) | (inline_imm << 8) | (ssrc & 0xFF))
    } else {
        // s_mul_i32 sdst, ssrc, lit32  (SOP2 op 0x2C in gfx11; ssrc1=0xFF)
        asm_u32(0x96000000 | ((sdst & 0xFF) << 16) | (0xFF << 8) | (ssrc & 0xFF))
        asm_u32(factor)
    }
}

// Slice 8.1: emit `sdst = ssrc / gqa_ratio` for the current arch.  Phase 7's
// `kv_head = q_head / (N_HEADS / N_KV_HEADS)` formerly used s_lshr_b32 with
// log2(gqa_ratio), which is correct only for pow-2 ratios (Qwen3 2:1, Llama
// 4:1, Mistral 4:1).  Llama-3.2-3B has ratio=3 (24/8), for which the shift
// approximation routes Q heads to the wrong KV head (and OOB for q>=16).
//
// Non-pow-2 case for ratio=3: classic libdivide magic via 32-bit s_mul_hi_u32
// with 0xAAAAAAAB, then s_lshr_b32 by 1.  Identity: 3 * 0xAAAAAAAB = 2^33 + 1,
// so high_u32(q * M) >> 1 == q / 3 for all 32-bit q.
fn _emit_div_kv_head(uint64 sdst, uint64 ssrc) {
    uint64 ratio = MEGA_N_HEADS / MEGA_N_KV_HEADS
    uint64 r = ratio
    uint64 shift = 0
    uint64 is_pow2 = 1
    if ratio == 0 { is_pow2 = 0 }
    while r > 1 {
        if (r & 1) != 0 { is_pow2 = 0 }
        r = r >> 1
        shift = shift + 1
    }
    if is_pow2 != 0 {
        // s_lshr_b32 sdst, ssrc, shift  (SOP2 op 0x0A, inline imm 0x80+shift)
        uint64 inline_imm = 0x80 + shift
        asm_u32(0x85000000 | ((sdst & 0x7F) << 16) | (inline_imm << 8) | (ssrc & 0xFF))
    } else if ratio == 3 {
        // s_mul_hi_u32 sdst, ssrc, 0xAAAAAAAB  (SOP2 op 0x2D, lit32 ssrc1=0xFF)
        // bits 31:24 = 0x96; bits 23:16 = 0x80|sdst (op msb=1); ssrc1=0xFF; ssrc0=ssrc.
        asm_u32(0x96800000 | ((sdst & 0x7F) << 16) | (0xFF << 8) | (ssrc & 0xFF))
        asm_u32(0xAAAAAAAB)
        // s_lshr_b32 sdst, sdst, 1  (inline imm 0x81)
        asm_u32(0x85000000 | ((sdst & 0x7F) << 16) | (0x81 << 8) | (sdst & 0xFF))
    } else {
        write(2, "_emit_div_kv_head: unsupported GQA ratio (only pow2 or 3)\n", 58)
        exit(1)
    }
}

// 1/sqrt(n) f32 bits for n a power of 2 in {64, 128, 256, ...}.
// Slice 6.7e: previous table had 0x3D000000 for n=64 (= 1/32) and
// 0x3C800000 for n=256 (= 1/64) — off-by-one in the exponent.  These
// silently mis-scaled phase-7 attention softmax for any non-Qwen3
// HEAD_DIM; corrected below.
//   n= 64: 1/sqrt(64)  = 1/8  = 0.125        = 0x3E000000
//   n=128: 1/sqrt(128) ≈ 0.0883883          = 0x3DB504F3
//   n=256: 1/sqrt(256) = 1/16 = 0.0625      = 0x3D800000
fn _arch_inv_sqrt_pow2_f32_bits(uint64 n) -> uint64 {
    if n ==  64 { return 0x3E000000 }     // 1/sqrt(64) = 1/8  = 0.125
    if n == 128 { return 0x3DB504F3 }     // 1/sqrt(128)       ≈ 0.0883883
    if n == 256 { return 0x3D800000 }     // 1/sqrt(256) = 1/16 = 0.0625
    write(2, "_arch_inv_sqrt_pow2_f32_bits: unsupported n\n", 44)
    exit(1)
    return 0
}

// Name-dispatcher: examines the kernel name and selects the correct arch
// preset.  Called at the top of recognize_megakernel_swiglu_dense_gqa{,_speck4}
// so the recognizer/emitter pipeline always operates on a consistent set of
// arch globals.  Unknown body names abort hard.
fn megakernel_dispatch_arch(uint64 kname_ptr, uint64 nl) {
    if str_starts_with(kname_ptr, "qwen3_layer_megakernel", 22) != 0 {
        mega_set_arch_qwen3_06b()
        // Slice 4.21.1: per-variant M_EFF override.  Default (slice-4.20.x
        // speck4 path) is MEGA_M_EFF=4 via mega_set_arch_qwen3_06b().
        // For `_speck8` and `_speck16` kernel names, bump after the base
        // preset so phase emitters that read MEGA_M_EFF generate the
        // right per-stream stride / loop count.
        if str_starts_with(kname_ptr, "qwen3_layer_megakernel_speck8", 29) != 0 {
            MEGA_M_EFF = 8
            return
        }
        if str_starts_with(kname_ptr, "qwen3_layer_megakernel_speck16", 30) != 0 {
            MEGA_M_EFF = 16
            return
        }
        // base / speck4 — MEGA_M_EFF stays at 4 from mega_set_arch_qwen3_06b.
        return
    }
    // Slice 8.0: check "llama_3b_layer_megakernel" BEFORE the generic
    // "llama_layer_megakernel" prefix (which the 3B name would also
    // match prefix-wise; "llama_3b..." starts with "llama_" but NOT
    // with "llama_layer_..." so order doesn't actually matter here —
    // keep the more specific check first for clarity).
    if str_starts_with(kname_ptr, "llama_3b_layer_megakernel", 25) != 0 {
        mega_set_arch_llama_3b()
        return
    }
    if str_starts_with(kname_ptr, "llama_layer_megakernel", 22) != 0 {
        mega_set_arch_llama_1b()
        return
    }
    if str_starts_with(kname_ptr, "mistral_layer_megakernel", 24) != 0 {
        mega_set_arch_mistral_7b()
        return
    }
    write(2, "megakernel_dispatch_arch: unknown body name\n", 44)
    exit(1)
}

// ── ISA encoding constants ────────────────────────────────────────────────
// SGPR layout for the stub kernel:
//   s[0:1]  = kernarg ptr pair (COv5 implicit)
//   vcc_lo  = lane-0 mask (v_cmp_eq_u32_e32 result, writes vcc_lo)
//   s3      = saved exec (for s_and_saveexec_b32 / s_or_b32 pattern)
//   s[8:9]  = barrier_counter ptr (arg 15, loaded from kernarg offset 0x78)
//   s[10:11]= max_phase value (arg 23, loaded from kernarg offset 0xB8)
//
// VGPR layout:
//   v0  = tid_local_x (hardware provided)
//   v1  = scratch (vaddr=0 for global ops)
//   v2  = barrier data (atomic addend or spin poll result)
//
// MEGA_WG_PERSIST workgroups in the v2 kernel (=512, matches HIP source).
// Each barrier increments a global counter; spins until (phase+1)*512.
//
// Barrier ISA sequence (30 dwords, gfx1100):
//   threadfence (waitcnt + gl0/gl1 inv)
//   lane-0 mask via v_cmp_eq_u32_e32 vcc_lo + s_and_saveexec_b32 s3, vcc_lo
//   lane-0 path: global_atomic_add_u32 counter += 1 + cache flush
//   restore exec (s_or_b32 exec_lo, exec_lo, s3)
//   spin loop: global_load_b32 glc + compare + branch
//   restore full exec
//
// All instructions are gfx11 (rsrc2=0x9E, target=gfx1100).

// Emit one cross-WG barrier for a given wg_persist grid size.
//
// phase_idx:  0..7.  threshold = (phase_idx+1) * wg_persist.
// wg_persist: number of persistent workgroups (must satisfy
//             (phase_idx+1)*wg_persist <= 0xFFFF — checked below).
// Register conventions: s[8:9]=counter_ptr, vcc_lo=lane-0 mask, s3=saved-exec,
// v0=lane id (hardware), v1=vaddr(0), v2=data/spin.
fn mega_emit_barrier_isa(uint64 phase_idx, uint64 wg_persist) {
    // 16-bit cap: the spin-poll comparison uses s_movk_i32 which only
    // accepts a 16-bit immediate field.  (phase_idx+1)*wg_persist must
    // fit in 16 bits for the branch encoding to be correct.  At slice
    // 4.19.x sizes (max phase_idx=7, wg_persist=512) the max threshold
    // is 8*512 = 4096 which is well within 0xFFFF.  If this limit is
    // ever exceeded a wider emit (s_mov_b32 + literal) will be needed.
    uint64 threshold = (phase_idx + 1) * wg_persist
    if threshold > 0xFFFF {
        write(2, "mega_emit_barrier_isa: barrier counter overflow: (phase+1)*wg_persist > 0xFFFF\n", 80)
        exit(1)
    }

    // ── threadfence ──────────────────────────────────────────────────────
    // Flush writer stores and invalidate caches before the atomic.
    // s_waitcnt lgkmcnt(0)   ; wait for any pending scalar/LDS ops
    asm_s_waitcnt_lgkmcnt_zero()
    // s_waitcnt_vscnt null, 0 ; wait for pending vector stores
    asm_s_waitcnt_vscnt_zero()
    // buffer_gl1_inv          ; invalidate L1
    asm_buffer_gl1_inv()
    // buffer_gl0_inv          ; invalidate L0
    asm_buffer_gl0_inv()

    // ── lane-0 mask ───────────────────────────────────────────────────────
    // v_cmp_eq_u32_e32 vcc_lo, 0, v0  → vcc_lo = mask of lanes where tid==0
    // Use the VOPC e32 form (writes to vcc_lo automatically).
    asm_v_cmp_eq_u32_imm_vgpr(0, 0)    // v_cmp_eq_u32_e32 vcc_lo, 0, v0

    // s_and_saveexec_b32 s3, vcc_lo  ; restrict exec to lane 0, save old exec in s3
    asm_s_and_saveexec_b32_vcc_lo(3)   // s3 = old exec; exec = exec & vcc_lo

    // s_cbranch_execz fwd_9  ; skip atomic if lane 0 not active (exec==0)
    // Forward skip = 9 dwords (the lane-0 path below: steps 8..13)
    asm_s_cbranch_execz(9)

    // ── lane-0 atomic path (9 dwords) ────────────────────────────────────
    // v_mov_b32 v1, 0   ; vaddr = 0 (NULL offset for global_atomic with saddr)
    asm_v_mov_b32_inline_u(1, 0)
    // v_mov_b32 v2, 1   ; vdata = 1 (increment amount)
    asm_v_mov_b32_inline_u(2, 1)
    // global_atomic_add_u32 v2, v1, s[8:9]
    // word1=0xDCD60000, word2=(saddr<<16)|(vdata<<8)|vaddr = (8<<16)|(2<<8)|1
    asm_u32(0xDCD60000)
    asm_u32(0x00080201)
    // s_waitcnt_vscnt null, 0  ; drain store queue after atomic
    asm_s_waitcnt_vscnt_zero()
    // buffer_gl1_inv
    asm_buffer_gl1_inv()
    // buffer_gl0_inv
    asm_buffer_gl0_inv()

    // ── restore exec before spin (skip_atomic target) ─────────────────────
    // s_or_b32 exec_lo, exec_lo, s3   ; restore all lanes active
    // SOP2 op 0x0C: (0x2<<30)|(0x0C<<23)|(sdst<<16)|(ssrc1<<8)|ssrc0
    //   sdst=exec_lo=0x7E, ssrc0=exec_lo=0x7E, ssrc1=s3=3
    asm_u32(0x8C7E037E)

    // ── spin loop (9 dwords) ──────────────────────────────────────────────
    // Slice 4.23 (2026-05-13): dropped buffer_gl1_inv from the spin body.
    // The spin load uses GLC=1 (bypasses L0/L1 caches and reads from L2
    // directly), so post-load L1 invalidation is redundant.  buffer_gl0_inv
    // kept for defense-in-depth on the L0 side; producer-side fence at
    // the top of mega_emit_barrier_isa still does both.  Savings:
    // ~50-200 ns per spin probe × 8 barriers × 16 layers = ~1-2 ms/step
    // on Llama-1B M=1 (8 barriers × WG_PERSIST=512 active spin lanes).
    // See project_megakernel_inner_loop_5x_gap.md.
    // Loop: load counter, check if >= threshold, spin until done.
    // v_mov_b32 v1, 0   ; vaddr = 0 for spin load
    asm_v_mov_b32_inline_u(1, 0)
    // global_load_b32 glc v2, v1, s[8:9]
    // word1=0xDC524000 (GLC bit 14 set), word2=(vdst<<24)|(saddr<<16)|vaddr
    //   vdst=v2=2, saddr=s8=8, vaddr=v1=1
    asm_u32(0xDC524000)
    asm_u32(0x02080001)
    // s_waitcnt vmcnt(0)
    asm_s_waitcnt_vmcnt_zero()
    // buffer_gl0_inv  (gl1_inv dropped — GLC load already bypasses L1)
    asm_buffer_gl0_inv()
    // v_cmp_gt_u32_e32 vcc_lo, threshold, v2  ; vcc = (threshold > counter)
    // Means: spin while counter < threshold.  VOPC e32 form: src0=literal.
    // word1 = (0x3E<<25)|(0x4C<<17)|(vsrc1<<9)|0xFF
    //   vsrc1=v2=2, src0=0xFF (literal follows)
    // word2 = threshold value
    asm_u32(0x7C9804FF)        // v_cmp_gt_u32_e32 vcc_lo, <lit>, v2
    asm_u32(threshold & 0xFFFFFFFF)
    // s_cbranch_vccnz spin_back  ; loop if vcc != 0 (counter still < threshold)
    // spin_back is 9 dwords BEFORE this instruction (was 11 pre-4.23):
    //   v_mov(1) + global_load(2) + waitcnt(1) + gl0inv(2) + vcmpgt(2) + this(1) = 9
    //   simm16 = -9 (to branch back to v_mov before spin load)
    asm_s_cbranch_vccnz(0xFFF7)   // simm16 = -9 as u16

    // ── restore full exec after spin ─────────────────────────────────────
    // s_or_b32 exec_lo, exec_lo, s3
    asm_u32(0x8C7E037E)
}

// ── Shared wave-XOR reduce helpers ───────────────────────────────────────
//
// _emit_v_xor_b32_e32_imm_v0 — emit v_xor_b32_e32 vdst, imm, v0.
// VOP2 op 0x1D: word = (0x1D<<25)|(vdst<<17)|(vsrc1=v0=0<<9)|(0x80+imm).
// imm must be in 1..16 (inline integer range: 0x81..0x90).
// Used for the 5-level wave-XOR reduce address computation in phase 1 and
// phase 3 (and future phases with the same reduce pattern).
fn _emit_v_xor_b32_e32_imm_v0(uint64 vdst, uint64 imm) {
    // src0 = 0x80+imm (inline integer), vsrc1 = v0 = 0
    uint64 word = 0x3A000000 | ((vdst & 0xFF) << 17) | (0x80 + (imm & 0x1F))
    asm_u32(word)
}

// _emit_wave_xor_reduce_add_f32_5_levels — emit 5-level wave-XOR reduce.
// On entry: acc_vgpr holds the per-lane partial sum (f32).
// On exit:  acc_vgpr (lane 0) holds the wave-reduced total.
//           addr_vgpr and tmp_vgpr are clobbered.
//
// Pattern per level (offset = 16, 8, 4, 2, 1):
//   v_xor_b32_e32 addr_vgpr, offset, v0   ; XOR lane index
//   v_lshlrev_b32_imm addr_vgpr, 2, addr_vgpr  ; ×4 → byte addr
//   ds_bpermute_b32 tmp_vgpr, addr_vgpr, acc_vgpr ; gather from partner
//   s_waitcnt lgkmcnt(0)
//   v_add_f32_e32 acc_vgpr, acc_vgpr, tmp_vgpr  ; accumulate
fn _emit_wave_xor_reduce_add_f32_5_levels(uint64 acc, uint64 addr, uint64 tmp) {
    // v_add_f32_e32 acc, acc, tmp encoding:
    //   VOP2 op 0x03: (3<<25)|(acc<<17)|(tmp<<9)|(0x100|acc)
    uint64 add_word = 0x06000000 | ((acc & 0xFF) << 17) | ((tmp & 0xFF) << 9) | (0x100 | (acc & 0xFF))
    // offsets: 16, 8, 4, 2, 1
    uint64 off = 16
    while off >= 1 {
        _emit_v_xor_b32_e32_imm_v0(addr, off)
        asm_v_lshlrev_b32_imm(addr, 2, addr)
        asm_ds_bpermute_b32(tmp, addr, acc)
        asm_s_waitcnt_lgkmcnt_zero()
        asm_u32(add_word)
        off = off / 2
    }
}

// _emit_wave_xor_reduce_max_f32_5_levels — sister of the add helper but
// uses v_max_f32_e32 to compute a wave-wide max (used by phase 7 pass 1).
//
// On entry: acc holds the per-lane partial max (f32; lanes that never wrote
//           must hold -inf or any safe identity, e.g. -1e30).
// On exit:  every lane's acc holds the wave-reduced max (xor-bfly is
//           symmetric — no separate broadcast needed).
//           addr_vgpr and tmp_vgpr are clobbered.
//
// Per-level pattern (offset = 16, 8, 4, 2, 1):
//   v_xor_b32_e32 addr, offset, v0
//   v_lshlrev_b32_imm addr, 2, addr     ; ×4 → byte addr
//   ds_bpermute_b32 tmp, addr, acc      ; gather partner's value
//   s_waitcnt lgkmcnt(0)
//   v_max_f32_e32 acc, acc, tmp         ; max-reduce
//
// VOP2 op for v_max_f32 = 0x10 (prefix 0x20000000).  Verified against the
// existing softmax phase-A encoding 0x200A0F05 (= v_max_f32_e32 v5, v5, v7).
fn _emit_wave_xor_reduce_max_f32_5_levels(uint64 acc, uint64 addr, uint64 tmp) {
    // v_max_f32_e32 acc, acc, tmp encoding:
    //   VOP2 op 0x10: (0x10<<25)|(acc<<17)|(tmp<<9)|(0x100|acc)
    uint64 max_word = 0x20000000 | ((acc & 0xFF) << 17) | ((tmp & 0xFF) << 9) | (0x100 | (acc & 0xFF))
    uint64 off = 16
    while off >= 1 {
        _emit_v_xor_b32_e32_imm_v0(addr, off)
        asm_v_lshlrev_b32_imm(addr, 2, addr)
        asm_ds_bpermute_b32(tmp, addr, acc)
        asm_s_waitcnt_lgkmcnt_zero()
        asm_u32(max_word)
        off = off / 2
    }
}

// ── rmsnorm WG-0-gated inline ISA emitter ─────────────────────────────────
//
// _emit_rmsnorm_wg_gated_inline — emits a WG-0-gated rmsnorm ISA body
// INLINE into the ongoing asm buffer (no asm_init, no s_endpgm).
//
// Shared by phase 1 (input rmsnorm) and phase 11 (post-attn rmsnorm) — the
// math is identical (`out[i] = (in[i] / sqrt(mean(in*in)+eps)) * norm[i]`,
// N=HIDDEN=1024, eps=1e-5f) but the three kernarg byte offsets differ.
// Slice 4.19.6 parameterized the loads (was hardcoded to phase-1 offsets).
//
// DEVIATION NOTE (plan Task 1 vs implementation): The original plan called
// for reusing `_emit_rmsnorm_f32_body_N_eps` from format_amdgpu.mlr, but
// that helper is structurally incompatible with inline emission: it calls
// asm_init() (resets the buffer), emits s_endpgm (terminates the kernel),
// uses an LDS-tree reduce instead of the wave-XOR pattern required here,
// and is a multi-arch pair emitter.  This function duplicates the math
// core in single-arch gfx1100 form.
//
// Parameters (kernarg byte offsets within the 192-byte kernarg segment):
//   in_kofs    = byte offset of the input ptr   (phase 1: 0x00 = in_residual,
//                                                 phase 11: 0xA0 = b_mid_g)
//   norm_kofs  = byte offset of the norm-weight ptr
//                                                (phase 1: 0x30 = in_norm_g,
//                                                 phase 11: 0x38 = post_norm_g)
//   out_kofs   = byte offset of the output ptr  (phase 1: 0x88 = b_x_norm_g,
//                                                 phase 11: 0xA8 = b_mid_norm_g)
//   wg_id_sgpr = SGPR # holding wg_id_x for the WG-0 gate.  Phase 1 uses 15
//                (hardware register, untouched at that point).  Phase 11 must
//                use 28 (the saved copy stashed in the prologue) because
//                phase 5's `s_load_b64 s[14:15], ..., 0x58` (rope_sin)
//                clobbers s15 mid-kernel.  Same constraint that forced
//                phase 9 to read s28 instead of s15.
//
// Mega-kernel SGPR context on entry:
//   s[0:1]  = kernarg ptr
//   s[8:9]  = barrier_counter ptr (already loaded by prologue)
//   s[10:11]= max_phase value (already loaded by prologue)
//   s15     = wg_id_x ON KERNEL ENTRY only — phase 5 clobbers it via
//             `s_load_b64 s[14:15], 0x58` (rope_sin). Use the wg_id_sgpr
//             parameter to pick s15 (phase 1, runs before phase 5) vs
//             s28 (post-phase-5 invocations — saved by kernel prologue).
//
// SGPRs touched by this body (regardless of phase):
//   s[2:3]  = input ptr        (loaded from kernarg byte off in_kofs)
//   s[4:5]  = norm-weight ptr  (loaded from kernarg byte off norm_kofs)
//   s[6:7]  = output ptr       (loaded from kernarg byte off out_kofs)
//   s12     = loop counter / saved exec_lo (reused each section)
//   s14     = float literal scratch (1/1024, eps)
//
// VGPR context (all locals, not preserved past the phase):
//   v0  = lane id (hardware, must be preserved)
//   v2  = ssq accumulator → scale broadcast
//   v3:v4 = pointer pair (advances during loops)
//   v5:v6 = second pointer pair (norm-weight / scratch)
//   v7:v8 = third pointer pair (output)
//   v9  = lane * 4 (constant byte offset, computed once)
//   v10, v11 = load temporaries for output loop
//
// LDS layout — 516 bytes total, regions overlap by lifetime:
//   phase 1 / phase 5 / phase 11 use offset 512..515 as `wave_tmp[0]`
//     (rsqrt scale broadcast, live only within the phase, written before
//     the per-phase s_barrier and dead after the phase exits).
//   phase 7 uses offset 4..515 as `attn_w_lds[t]` at byte off `4 + t*4`
//     (softmax weights for t in [0..127], cached between Pass 2 and
//     Pass 3, live only within phase 7).
//   offset 0..3 is unused on this kernel layout.
//   The two regions overlap at byte 512 (wave_tmp[0] vs attn_w_lds[127])
//   but lifetimes are disjoint: phase 1's wave_tmp is dead by the time
//   the per-phase barrier hands off to phase 7.
//
// Hardware: gfx1100 (RDNA3) wave32.  N=HIDDEN=1024, WAVE=32 → 32 iters.
//
// Slice 4.20.1 added `stream_byte_offset`: when non-zero, the helper
// inserts `s_add_u32 s2, s2, stream_byte_offset` (carry into s3) and the
// matching add into s[6:7] right after the kernarg loads, before any
// VGPR pointer setup.  Used by the speck4 m4 wrapper to retarget input
// + output base pointers to stream m's slab (m*HIDDEN*4 bytes).  The
// norm-weight ptr (s[4:5]) is stream-independent and is left untouched.
// Base-mega callsites pass 0 (no offset).
fn _emit_rmsnorm_wg_gated_inline(uint64 in_kofs, uint64 norm_kofs,
                                  uint64 out_kofs, uint64 wg_id_sgpr,
                                  uint64 stream_byte_offset) {
    // Record the dword index of the s_cmp before the skip branch so
    // we can patch the simm16 after measuring the body size.
    uint64 gate_cmp_pos = asm_text_len / 4   // position of s_cmp_lg_u32

    // ── WG-0 gate ─────────────────────────────────────────────────────
    // s_cmp_lg_u32 s<wg_id_sgpr>, 0   (SCC=1 if wg_id != 0)
    // SOPC op 0x07: word = 0xBF | (0x07<<16) | (ssrc1<<8) | ssrc0
    //   ssrc0 = wg_id_sgpr & 0xFF, ssrc1 = inline-0 = 0x80
    uint64 cmp_word = 0xBF078000 | (wg_id_sgpr & 0xFF)
    asm_u32(cmp_word)
    // s_cbranch_scc1 .skip_rmsnorm_body  — placeholder simm16=0 (patched below)
    asm_s_cbranch_scc1(0)

    // ── Load 3 pointer args ────────────────────────────────────────────
    // s_load_b64 s[2:3], s[0:1], in_kofs    (input ptr — phase-specific)
    asm_s_load_b64_off(1, 0, in_kofs)
    // s_load_b64 s[4:5], s[0:1], norm_kofs  (norm-weight ptr — phase-specific)
    asm_s_load_b64_off(2, 0, norm_kofs)
    // s_load_b64 s[6:7], s[0:1], out_kofs   (output ptr — phase-specific)
    asm_s_load_b64_off(3, 0, out_kofs)
    asm_s_waitcnt_lgkmcnt_zero()

    // ── Optional per-stream base-pointer adjust (slice 4.20.1) ────────
    // When stream_byte_offset != 0, retarget s[2:3] (input) and s[6:7]
    // (output) to stream m's slab.  s[4:5] (norm-weight) is unchanged —
    // norm weights are shared across all M_EFF streams.
    //
    // 32-bit-literal SOP2 encoding (ssrc1=0xFF means "literal follows"):
    //   s_add_u32  s2, s2, lit  → 0x8002FF02 ; <lit32>
    //   s_addc_u32 s3, s3, 0    → 0x82038003   (op 4, ssrc1=0x80=inline-0)
    //   s_add_u32  s6, s6, lit  → 0x8006FF06 ; <lit32>
    //   s_addc_u32 s7, s7, 0    → 0x82078007
    if stream_byte_offset != 0 {
        asm_u32(0x8002FF02); asm_u32(stream_byte_offset)   // s2 += lit
        asm_u32(0x82038003)                                 // s3 += carry
        asm_u32(0x8006FF06); asm_u32(stream_byte_offset)   // s6 += lit
        asm_u32(0x82078007)                                 // s7 += carry
    }

    // ── Init ──────────────────────────────────────────────────────────
    // v2 = 0.0f  (ssq accumulator; inline-0 = f32 0.0)
    asm_v_mov_b32_inline_u(2, 0)
    // v9 = lane * 4  (constant byte offset per thread)
    asm_v_lshlrev_b32_imm(9, 2, 0)
    // v4 = 0  (hi-word zero for initial ptr setup)
    asm_v_mov_b32_inline_u(4, 0)
    // v3 = input_lo + v9  (input ptr lo)
    asm_v_add_co_u32_vcc_sv(3, 2, 9)
    // v4 = input_hi + carry  (v4 was 0; reuse as carry target)
    asm_v_add_co_ci_u32_null_sv_vcc(4, 3, 4)
    // s12 = HIDDEN/32   (SSQ loop counter — was hardcoded 32 for Qwen3 N=1024)
    asm_s_mov_b32_inline_imm(12, MEGA_HIDDEN / 32)

    // ── SSQ loop (HIDDEN/32 iters: ssq += input[lane + i*32]^2) ────────
    // Loop runs while s12 > 0.  Per iteration: load, fmac, advance ptr,
    // decrement counter, compare-zero, branch-if-not-zero.
    uint64 loop_ssq_top = asm_text_len / 4   // dword index of loop top

    // global_load_b32 v5, v[3:4], off
    // word1=0xDC520000, word2=(vdst<<24)|(0x7C<<16)|vaddr_lo
    asm_u32(0xDC520000)
    asm_u32(0x057C0003)    // vdst=5, saddr=0x7C(off), vaddr=3
    asm_s_waitcnt_vmcnt_zero()
    // v_fmac_f32_e32 v2, v5, v5   (ssq += v5 * v5)
    asm_v_fmac_f32_e32_vv(2, 5, 5)
    // Advance ptr by 128 bytes (32 floats × 4 bytes):
    // v_add_co_u32 v3, vcc_lo, 128, v3  — VOP3B with literal
    //   word1=0xD7006A03, word2=(src1=v3<<9)|src0=0xFF, word3=128
    asm_u32(0xD7006A03)
    asm_u32(0x000206FF)
    asm_u32(128)
    // v_add_co_ci_u32_e64 v4, null, 0, v4, vcc_lo
    //   word1=0xD5207C04, word2=(vcc_lo<<18)|(v4<<9)|inline-0
    //   = (0x6A<<18)|(0x104<<9)|0x80 = 0x01A80000|0x00020800|0x80 = 0x01AA0880
    asm_u32(0xD5207C04)
    asm_u32(0x01AA0880)
    // s_sub_u32 s12, s12, 1
    asm_s_sub_u32_imm(12, 12, 1)
    // s_cmp_eq_u32 s12, 0
    asm_s_cmp_eq_u32(12, 0x80)
    // s_cbranch_scc0 loop_ssq (branch if s12 != 0)
    uint64 loop_ssq_dwords = (asm_text_len / 4) - loop_ssq_top   // body dwords emitted
    // simm16 = -(loop_ssq_dwords + 1)  (back-branch, including this instruction)
    uint64 back_simm16 = (0 - loop_ssq_dwords - 1) & 0xFFFF
    asm_s_cbranch_scc0(back_simm16)

    // ── Wave XOR reduce (5 levels: offsets 16, 8, 4, 2, 1) ─────────────
    // acc=v2, addr=v6, tmp=v7.  Shared helper extracts the 5-level pattern
    // so phase 3 (and future phases) can reuse it without duplication.
    _emit_wave_xor_reduce_add_f32_5_levels(2, 6, 7)

    // ── Lane-0: compute scale, store to LDS[512] ─────────────────────
    // Save exec; gate to lane 0; compute rsqrt; write LDS.
    // s_mov_b32 s12, exec_lo   (save full exec)
    asm_s_mov_b32(12, 0x7E)
    // v_cmpx_eq_u32_e32 0, v0  (exec = {lanes where v0==0} = lane 0 only)
    asm_u32(0x7D940080)
    // s_mov_b32 s14, MEGA_INV_HIDDEN_BITS  (1/N.0f bits; set per-arch by
    //   the arch setter — Qwen3 1024→0x3A800000, Llama-1B 2048→0x3A000000,
    //   Llama-3B 3072→0x39AAAAAB, Mistral 4096→0x39800000.  Slice 8.0
    //   moved this off _arch_inv_n_f32_bits because that helper only
    //   handles power-of-2 N; Llama-3B HIDDEN=3072 is the first non-pow2.)
    asm_s_mov_b32_lit32(14, MEGA_INV_HIDDEN_BITS)
    // v_mul_f32 v2, s14, v2  (v2 = ssq / N)
    // VOP2: (8<<25)|(2<<17)|(2<<9)|14 = 0x10000000|0x00040000|0x00000400|14 = 0x1004040E
    asm_u32(0x1004040E)
    // s_mov_b32 s14, MEGA_RMSNORM_EPS_BITS  (eps; 1e-5f = 0x3727C5AC for both
    //   Qwen3 phase 1/11 and Llama)
    asm_s_mov_b32_lit32(14, MEGA_RMSNORM_EPS_BITS)
    // v_add_f32 v2, s14, v2  (v2 = ssq/N + eps)
    // VOP2: (3<<25)|(2<<17)|(2<<9)|14 = 0x06000000|0x00040000|0x00000400|14 = 0x0604040E
    asm_u32(0x0604040E)
    // v_rsq_f32 v2, v2  (v2 = rsqrt(ssq/N+eps))
    // VOP1: (0x3F<<25)|(2<<17)|(0x2E<<9)|(0x100|2)
    //   = 0x7E000000|0x00040000|0x00005C00|0x102 = 0x7E045D02
    asm_u32(0x7E045D02)
    // v_mov_b32 v8, 0  (LDS store address = 0, offset:512 encoded in word1)
    asm_v_mov_b32_inline_u(8, 0)
    // ds_store_b32 v8, v2 offset:512
    // word1=0xD8340000|(512&0xFFFF)=0xD8340200, word2=(vdata<<8)|vaddr=(2<<8)|8=0x0208
    asm_u32(0xD8340200)
    asm_u32(0x00000208)
    // s_mov_b32 exec_lo, s12  (restore full exec)
    asm_s_mov_b32(0x7E, 12)

    // ── Barrier + LDS broadcast ───────────────────────────────────────
    asm_s_waitcnt_lgkmcnt_zero()
    asm_s_barrier()
    // v_mov_b32 v8, 0  (LDS load address)
    asm_v_mov_b32_inline_u(8, 0)
    // ds_load_b32 v2, v8 offset:512
    // word1=0xD8D80000|(512)=0xD8D80200, word2=(vdst<<24)|vaddr=(2<<24)|8=0x02000008
    asm_u32(0xD8D80200)
    asm_u32(0x02000008)
    asm_s_waitcnt_lgkmcnt_zero()

    // ── Output loop (32 iters: out[i] = in[i] * scale * norm[i]) ───────
    // Re-setup pointers from saved lane*4 (v9) and loaded SGPRs.
    // input ptr: v3:v4
    asm_v_mov_b32_inline_u(4, 0)
    asm_v_add_co_u32_vcc_sv(3, 2, 9)
    asm_v_add_co_ci_u32_null_sv_vcc(4, 3, 4)
    // norm-weight ptr: v5:v6
    asm_v_mov_b32_inline_u(6, 0)
    asm_v_add_co_u32_vcc_sv(5, 4, 9)
    asm_v_add_co_ci_u32_null_sv_vcc(6, 5, 6)
    // output ptr: v7:v8
    asm_v_mov_b32_inline_u(8, 0)
    asm_v_add_co_u32_vcc_sv(7, 6, 9)
    asm_v_add_co_ci_u32_null_sv_vcc(8, 7, 8)
    // s12 = HIDDEN/32  (output loop counter — was hardcoded 32 for Qwen3 N=1024)
    asm_s_mov_b32_inline_imm(12, MEGA_HIDDEN / 32)

    uint64 loop_out_top = asm_text_len / 4

    // global_load_b32 v10, v[3:4], off  (input[i])
    asm_u32(0xDC520000)
    asm_u32(0x0A7C0003)    // vdst=10=0x0A, saddr=0x7C, vaddr=3
    // global_load_b32 v11, v[5:6], off  (norm-weight[i])
    asm_u32(0xDC520000)
    asm_u32(0x0B7C0005)    // vdst=11=0x0B, saddr=0x7C, vaddr=5
    asm_s_waitcnt_vmcnt_zero()
    // v_mul_f32 v10, v2, v10  (scale * input[i])
    // VOP2: (8<<25)|(10<<17)|(10<<9)|(0x100|2)
    //   src1=v10=10 (8-bit VGPR field), src0=v2=0x102 (VGPR bit)
    //   = 0x10000000|0x00140000|0x00001400|0x102 = 0x10141502
    asm_u32(0x10141502)
    // v_mul_f32 v10, v10, v11  (result * norm-weight[i])
    // VOP2: (8<<25)|(10<<17)|(11<<9)|(0x100|10)
    //   src1=v11=11, src0=v10=0x10A
    //   = 0x10000000|0x00140000|0x00001600|0x10A = 0x1014170A
    asm_u32(0x1014170A)
    // global_store_b32 v[7:8], v10, off
    // word1=0xDC6A0000, word2=(0x7C<<16)|(vdata<<8)|vaddr=(0x7C<<16)|(10<<8)|7=0x007C0A07
    asm_u32(0xDC6A0000)
    asm_u32(0x007C0A07)
    // Advance input ptr by 128 bytes (v3:v4)
    asm_u32(0xD7006A03)
    asm_u32(0x000206FF)
    asm_u32(128)
    asm_u32(0xD5207C04)
    asm_u32(0x01AA0880)
    // Advance norm-weight ptr by 128 bytes (v5:v6)
    asm_u32(0xD7006A05)
    asm_u32(0x00020AFF)
    asm_u32(128)
    // v_add_co_ci_u32_e64 v6, null, 0, v6, vcc_lo
    // word1=0xD5207C06, word2=(0x6A<<18)|(0x106<<9)|0x80=0x01A80000|0x000C0C00|0x80=?
    // 0x106<<9 = 0x20C00 → 0x01A80000|0x0020C00|0x80... wait:
    // (0x6A<<18) = 0x01A80000
    // (0x106<<9) = 0x106*512 = 532*512... no: 0x106 = 262 decimal, *512 = 134144 = 0x20C00
    // word2 = 0x01A80000 | 0x00020C00 | 0x80 = 0x01AA0C80
    asm_u32(0xD5207C06)
    asm_u32(0x01AA0C80)
    // Advance output ptr by 128 bytes (v7:v8)
    asm_u32(0xD7006A07)
    asm_u32(0x00020EFF)
    asm_u32(128)
    // v_add_co_ci_u32_e64 v8, null, 0, v8, vcc_lo
    // word2 = (0x6A<<18)|(0x108<<9)|0x80 = 0x01A80000|0x00021000|0x80 = 0x01AA1080
    asm_u32(0xD5207C08)
    asm_u32(0x01AA1080)
    // s_sub_u32 s12, s12, 1
    asm_s_sub_u32_imm(12, 12, 1)
    // s_cmp_eq_u32 s12, 0
    asm_s_cmp_eq_u32(12, 0x80)
    // s_cbranch_scc0 loop_out
    uint64 loop_out_dwords = (asm_text_len / 4) - loop_out_top
    uint64 back_out_simm16 = (0 - loop_out_dwords - 1) & 0xFFFF
    asm_s_cbranch_scc0(back_out_simm16)

    // ── Patch the WG-0 skip-branch simm16 ─────────────────────────────
    // Target of the gate branch = current position (after all rmsnorm body).
    uint64 body_dwords = (asm_text_len / 4) - (gate_cmp_pos + 2)
    asm_patch_u32(gate_cmp_pos + 1, 0xBFA20000 | (body_dwords & 0xFFFF))
}

// _emit_rmsnorm_cputree_wg_gated_inline — CPU-matching reduction-tree
// variant of _emit_rmsnorm_wg_gated_inline.  Phase 2.5 of the Llama-3B
// bit-exact plan (2026-05-14).
//
// Same outer scaffolding (WG-0 gate, kernarg loads, per-stream byte
// offset, lane-0 LDS scale broadcast, per-element write-back) as
// _emit_rmsnorm_wg_gated_inline.  ONLY the SSQ math changes to match
// CPU `qwen3_dot_avx2(in, in, HIDDEN)` (std/qwen3.mlr:639) exactly:
//   - 8 active lanes (exec_lo = 0xFF), stride-8 K partition
//   - v_mul_f32 then v_add_f32 (TWO roundings; matches CPU vmulps+vaddps),
//     NOT v_fmac_f32 (one rounding) as the base helper uses.
//   - 3-level XOR-bpermute reduce in offset order [4, 1, 2]
//     (matches CPU's vextractf128 + 2× vhaddps reduction tree)
//
// Without these three changes, ssq drifts ~1 ULP vs CPU, which amplifies
// to ~10 ULP in phase-3 b_attn_q_g (rmsnorm amplifies via 1/sqrt(ssq)).
//
// Caller contract: only invoke when MEGA_HIDDEN == 3072 (Llama-3B).  All
// other archs keep the proven 5-level wave32 reduce.
//
// VGPR layout — mirrors base helper EXCEPT adds v8 as v_mul intermediate.
// The base helper uses v8 only as a transient store-addr in lane-0 LDS
// broadcast (set to 0 inline) and re-set to 0 in the output loop.  We use
// the same recycle pattern — v8 carries x*x during the K-loop and is
// trampled (set to 0) before any LDS store.
fn _emit_rmsnorm_cputree_wg_gated_inline(uint64 in_kofs, uint64 norm_kofs,
                                          uint64 out_kofs, uint64 wg_id_sgpr,
                                          uint64 stream_byte_offset) {
    uint64 gate_cmp_pos = asm_text_len / 4

    // ── WG-0 gate ─────────────────────────────────────────────────────
    uint64 cmp_word = 0xBF078000 | (wg_id_sgpr & 0xFF)
    asm_u32(cmp_word)
    asm_s_cbranch_scc1(0)   // patched at end

    // ── Load 3 pointer args ────────────────────────────────────────────
    asm_s_load_b64_off(1, 0, in_kofs)
    asm_s_load_b64_off(2, 0, norm_kofs)
    asm_s_load_b64_off(3, 0, out_kofs)
    asm_s_waitcnt_lgkmcnt_zero()

    // ── Optional per-stream base-pointer adjust ───────────────────────
    if stream_byte_offset != 0 {
        asm_u32(0x8002FF02); asm_u32(stream_byte_offset)
        asm_u32(0x82038003)
        asm_u32(0x8006FF06); asm_u32(stream_byte_offset)
        asm_u32(0x82078007)
    }

    // ── Init ──────────────────────────────────────────────────────────
    // v2 = 0.0f (ssq accumulator) — set with FULL EXEC so lanes 8..31
    // keep v2=0 and contribute identity to the wave-XOR-bpermute reduce.
    asm_v_mov_b32_inline_u(2, 0)
    asm_v_lshlrev_b32_imm(9, 2, 0)        // v9 = lane*4
    asm_v_mov_b32_inline_u(4, 0)
    asm_v_add_co_u32_vcc_sv(3, 2, 9)      // v3 = input_lo + lane*4
    asm_v_add_co_ci_u32_null_sv_vcc(4, 3, 4)

    // ── Narrow EXEC to lanes 0..7 ─────────────────────────────────────
    // Lanes 8..31 keep their v2=0 and skip the K-loop.  Mirrors the
    // exec narrow in _emit_gemv_cputree_bf16_padded_strided_inline:1484.
    asm_s_mov_b32_lit32(0x7E, 0x000000FF)

    // ── SSQ loop (HIDDEN/8 iters: ssq += input[lane + i*8]^2) ─────────
    asm_s_mov_b32_inline_imm(12, MEGA_HIDDEN / 8)

    uint64 loop_ssq_top = asm_text_len / 4

    // global_load_b32 v5, v[3:4], off
    asm_u32(0xDC520000)
    asm_u32(0x057C0003)
    asm_s_waitcnt_vmcnt_zero()
    // v_mul_f32_e32 v8, v5, v5  (single rounding 1: v8 = x*x)
    //   VOP2 op 0x08: (8<<25)|(vdst=8<<17)|(vsrc1=v5=5<<9)|(src0=v5=0x105)
    //   = 0x10000000 | 0x00100000 | 0x00000A00 | 0x105 = 0x10100B05
    asm_u32(0x10100B05)
    // v_add_f32_e32 v2, v2, v8  (single rounding 2: acc += x*x)
    //   VOP2 op 0x03: (3<<25)|(vdst=2<<17)|(vsrc1=v8=8<<9)|(src0=v2=0x102)
    //   = 0x06000000 | 0x00040000 | 0x00001000 | 0x102 = 0x06041102
    asm_u32(0x06041102)
    // Advance ptr by 32 bytes (8 floats × 4 bytes): v[3:4] += 32
    asm_u32(0xD7006A03)
    asm_u32(0x000206FF)
    asm_u32(32)
    asm_u32(0xD5207C04)
    asm_u32(0x01AA0880)
    asm_s_sub_u32_imm(12, 12, 1)
    asm_s_cmp_eq_u32(12, 0x80)
    uint64 loop_ssq_dwords = (asm_text_len / 4) - loop_ssq_top
    uint64 back_simm16 = (0 - loop_ssq_dwords - 1) & 0xFFFF
    asm_s_cbranch_scc0(back_simm16)

    // ── Restore EXEC to full wave32 for cross-lane reduce + write-back ─
    asm_s_mov_b32_lit32(0x7E, 0xFFFFFFFF)

    // ── CPU-tree 3-level reduce, XOR offsets [4, 1, 2] in that order ──
    // Per level: v_xor_b32 v6, off, v0 ; v_lshlrev_b32 v6, 2, v6 ;
    //            ds_bpermute_b32 v7, v6, v2 ; waitcnt lgkm(0) ;
    //            v_add_f32_e32 v2, v2, v7
    // v_add_f32 v2, v2, v7: (3<<25)|(2<<17)|(7<<9)|(0x100|2) = 0x06040F02
    uint64 add_word = 0x06000000 | (2 << 17) | (7 << 9) | (0x100 | 2)

    // Step 1: offset 4
    _emit_v_xor_b32_e32_imm_v0(6, 4)
    asm_v_lshlrev_b32_imm(6, 2, 6)
    asm_ds_bpermute_b32(7, 6, 2)
    asm_s_waitcnt_lgkmcnt_zero()
    asm_u32(add_word)

    // Step 2: offset 1
    _emit_v_xor_b32_e32_imm_v0(6, 1)
    asm_v_lshlrev_b32_imm(6, 2, 6)
    asm_ds_bpermute_b32(7, 6, 2)
    asm_s_waitcnt_lgkmcnt_zero()
    asm_u32(add_word)

    // Step 3: offset 2
    _emit_v_xor_b32_e32_imm_v0(6, 2)
    asm_v_lshlrev_b32_imm(6, 2, 6)
    asm_ds_bpermute_b32(7, 6, 2)
    asm_s_waitcnt_lgkmcnt_zero()
    asm_u32(add_word)

    // ── Lane-0: CPU-matching IEEE-correct scale pipeline ─────────────
    // Phase 2.6 (slice 8.2-B, 2026-05-14).  The base helper uses:
    //   v_mul_f32 v2, s14, v2        ; mean_sq = ssq * (1/N_bits)
    //   v_add_f32 v2, s14, v2        ; mean_sq + eps
    //   v_rsq_f32 v2, v2             ; rsqrt   (RDNA3 approx, ~1 ULP error)
    // CPU does:
    //   mean_sq = ssq / N            ; vdivss  (correctly rounded)
    //   x       = mean_sq + eps      ; vaddss  (correctly rounded)
    //   s       = sqrt_f32(x)        ; vsqrtss (correctly rounded)
    //   rsq     = 1.0f / s           ; vdivss  (correctly rounded)
    // Replace v_mul_f32(s14=1/N) → IEEE div by N, and v_rsq_f32 → sqrt + IEEE div.
    //   When N is a power of 2 (Qwen3/Llama-1B/Mistral) the IEEE div by N is
    //   bit-identical to the precomputed v_mul_f32(s14=1/N_bits) form, so the
    //   sister archs stay 20/20.  Only Llama-3B (N=3072) actually changes
    //   bits.  Similarly, v_sqrt_f32 + IEEE-div(1.0, sqrt) is bit-identical to
    //   CPU's vsqrtss + vdivss, which v_rsq_f32 alone is not.
    // VGPR usage: v2 holds ssq → rsq (final).  Scratch v10..v15 for div sequences.
    asm_s_mov_b32(12, 0x7E)               // s12 = exec_lo (save full exec)
    asm_u32(0x7D940080)                    // v_cmpx_eq_u32_e32 0, v0 (exec={lane 0})
    // v_mov_b32 v10, lit32 = MEGA_HIDDEN_F32_BITS (N as f32 in VGPR for div)
    //   VOP1 v_mov_b32_e32: (0x3F<<25) | (vdst<<17) | (0x01<<9) | src
    //   For lit32 source: src=0xFF, then lit32 dword follows.
    //   = 0x7E000000 | (10<<17) | (1<<9) | 0xFF = 0x7E1402FF
    asm_u32(0x7E1402FF)
    asm_u32(MEGA_HIDDEN_F32_BITS)
    // IEEE-correct mean_sq = v2 (ssq) / v10 (N).  Result → v2.
    // Scratch: v11=ds, v12=ns, v13=r, v14=r2, v15=q0.
    asm_v_div_f32_ieee(2, 2, 10, 11, 12, 13, 14, 15)
    // v_add_f32 v2, s14_eps, v2  (mean_sq + eps; s14 holds eps bits)
    asm_s_mov_b32_lit32(14, MEGA_RMSNORM_EPS_BITS)
    asm_u32(0x0604040E)                    // v_add_f32 v2, s14, v2 (correctly-rounded)
    // v_sqrt_f32 v2, v2  (correctly-rounded f32 sqrt)
    asm_v_sqrt_f32_e32_v(2, 2)
    // IEEE-correct rsq = 1.0 / v2.  Need 1.0 in a VGPR for the helper.
    // v_mov_b32 v10, 0x3F800000   (1.0f)
    asm_u32(0x7E1402FF)
    asm_u32(0x3F800000)
    // rsq = v10 (1.0) / v2 (sqrt).  Result → v2.
    asm_v_div_f32_ieee(2, 10, 2, 11, 12, 13, 14, 15)
    // Store rsq to LDS[512] for cross-lane broadcast.
    asm_v_mov_b32_inline_u(8, 0)           // v8 = 0 (LDS store addr)
    asm_u32(0xD8340200)
    asm_u32(0x00000208)                    // ds_store_b32 v8, v2 offset:512
    asm_s_mov_b32(0x7E, 12)                // restore exec_lo

    // ── Barrier + LDS broadcast ───────────────────────────────────────
    asm_s_waitcnt_lgkmcnt_zero()
    asm_s_barrier()
    asm_v_mov_b32_inline_u(8, 0)
    asm_u32(0xD8D80200)
    asm_u32(0x02000008)                    // ds_load_b32 v2, v8 offset:512
    asm_s_waitcnt_lgkmcnt_zero()

    // ── Output loop (HIDDEN/32 iters: out[i] = in[i] * scale * norm[i]) ─
    // Pointwise elementwise scale — unchanged from base helper.  Uses
    // FULL wave32, processing HIDDEN/32 elements per lane stride-32.
    asm_v_mov_b32_inline_u(4, 0)
    asm_v_add_co_u32_vcc_sv(3, 2, 9)
    asm_v_add_co_ci_u32_null_sv_vcc(4, 3, 4)
    asm_v_mov_b32_inline_u(6, 0)
    asm_v_add_co_u32_vcc_sv(5, 4, 9)
    asm_v_add_co_ci_u32_null_sv_vcc(6, 5, 6)
    asm_v_mov_b32_inline_u(8, 0)
    asm_v_add_co_u32_vcc_sv(7, 6, 9)
    asm_v_add_co_ci_u32_null_sv_vcc(8, 7, 8)
    asm_s_mov_b32_inline_imm(12, MEGA_HIDDEN / 32)

    uint64 loop_out_top = asm_text_len / 4

    asm_u32(0xDC520000)
    asm_u32(0x0A7C0003)
    asm_u32(0xDC520000)
    asm_u32(0x0B7C0005)
    asm_s_waitcnt_vmcnt_zero()
    // ── Phase 2.6: CPU-matching per-element mul order ─────────────────
    // CPU qwen3_scale_vvw_avx2 computes (v * w) * scale (vmulps v,w then
    // vmulps * scale). The base helper computed (scale * v) * w, which
    // can differ by 1 ULP at large magnitudes when intermediates round
    // differently. Match CPU order exactly.
    // v_mul_f32 v10, v10, v11   (v10 = x * w)
    asm_u32(0x1014170A)
    // v_mul_f32 v10, v2, v10    (v10 = (x*w) * scale  ; commutative)
    asm_u32(0x10141502)
    asm_u32(0xDC6A0000)
    asm_u32(0x007C0A07)
    asm_u32(0xD7006A03)
    asm_u32(0x000206FF)
    asm_u32(128)
    asm_u32(0xD5207C04)
    asm_u32(0x01AA0880)
    asm_u32(0xD7006A05)
    asm_u32(0x00020AFF)
    asm_u32(128)
    asm_u32(0xD5207C06)
    asm_u32(0x01AA0C80)
    asm_u32(0xD7006A07)
    asm_u32(0x00020EFF)
    asm_u32(128)
    asm_u32(0xD5207C08)
    asm_u32(0x01AA1080)
    asm_s_sub_u32_imm(12, 12, 1)
    asm_s_cmp_eq_u32(12, 0x80)
    uint64 loop_out_dwords = (asm_text_len / 4) - loop_out_top
    uint64 back_out_simm16 = (0 - loop_out_dwords - 1) & 0xFFFF
    asm_s_cbranch_scc0(back_out_simm16)

    // ── Patch the WG-0 skip-branch simm16 ─────────────────────────────
    uint64 body_dwords = (asm_text_len / 4) - (gate_cmp_pos + 2)
    asm_patch_u32(gate_cmp_pos + 1, 0xBFA20000 | (body_dwords & 0xFFFF))
}

// _emit_rmsnorm_wg_gated_m4_inline — speck4 m4 wrapper around the
// WG-0-gated rmsnorm body.  Emits 4 sequential rmsnorm bodies for streams
// m=0..3.  For each stream m, the input/output base pointers are offset
// by m * HIDDEN * 4 = m * 4096 bytes within the M_EFF*HIDDEN slabs at the
// kernarg-buffer-pointed base addresses.  The norm-weight pointer is
// stream-independent (one shared norm per phase) and is left untouched.
//
// Implementation choice (slice 4.20.1): static unroll, 4× the
// `_emit_rmsnorm_wg_gated_inline` body inline, threading a per-stream
// `stream_byte_offset` through the helper's new 5th parameter (default
// 0 for base-mega callsites).  Each invocation re-emits its own WG-0
// gate + 3 kernarg loads + base-pointer adjust + body — matches v1
// hipcc -O3 unrolled ISA structure (the HIP source's `for m in 0..3`
// loop is constant-trip and fully unrolled), so disasm-diff stays
// readable if the bit-exact gate fails.
//
// Cost: 4× the .text size of one rmsnorm body for this phase.  Each
// stream's kernarg loads (s_load_b64 ×3) hit the L2 KCACHE on streams
// 1..3, so the latency overhead vs runtime-loop is small.
//
// Phase 1 callsite: in_kofs=0x00, norm_kofs=0x30, out_kofs=0x88, wg=15
// Phase 11 callsite: in_kofs=0xA0, norm_kofs=0x38, out_kofs=0xA8, wg=28
fn _emit_rmsnorm_wg_gated_m4_inline(uint64 in_kofs, uint64 norm_kofs,
                                     uint64 out_kofs, uint64 wg_id_sgpr) {
    // Slice 4.21.2: was unrolled-4; now MEGA_M_EFF-driven loop.  At
    // MEGA_M_EFF=4 the emit sequence is byte-identical to the prior
    // unrolled body (4 sequential _emit_rmsnorm_wg_gated_inline calls
    // with strides 0, S, 2S, 3S).  For MEGA_M_EFF=8 / 16 the same
    // emitter produces 8 / 16 sequential calls.
    // Stream byte offset = MEGA_HIDDEN * 4 per stream (4 bytes per f32).
    uint64 stride = MEGA_HIDDEN * 4
    uint64 m = 0
    while m < MEGA_M_EFF {
        _emit_rmsnorm_wg_gated_inline(in_kofs, norm_kofs, out_kofs, wg_id_sgpr, m * stride)
        m = m + 1
    }
}

// ── Marker recognition helpers ────────────────────────────────────────────
//
// _body_has_marker(body_node, name_ptr, name_len) — generic sub-recognizer.
//
// Walks all if-block bodies in body_node looking for a Call to the function
// named by name_ptr/name_len.  Handles both:
//   ExprStmt → Call(name)   (bare call statement)
//   VarDecl  → Call(name)   (e.g. `uint64 _ = marker()`)
//
// Returns 1 if found, 0 if not found.
//
// All phase recognizers (_body_has_*_marker) are one-line wrappers below.
fn _body_has_marker(uint64 body_node, uint64 name_ptr, uint64 name_len) -> uint64 {
    uint32 stmt = ast_child(body_node)
    while stmt != 0 {
        if ast_kind(stmt) == 13 {
            uint32 then_blk = ast_data1(stmt)
            if then_blk != 0 {
                uint32 inner = ast_child(then_blk)
                while inner != 0 {
                    // ExprStmt(kind 16) → Call(kind 35) → callee token
                    if ast_kind(inner) == 16 {
                        uint32 expr = ast_child(inner)
                        if expr != 0 && ast_kind(expr) == 35 {
                            uint32 callee = ast_data1(expr)
                            if tok_matches(callee, name_ptr, name_len) != 0 {
                                return 1
                            }
                        }
                    }
                    // VarDecl(kind 10) → init Call(kind 35) → callee token
                    if ast_kind(inner) == 10 {
                        uint32 init = ast_child(inner)
                        if init != 0 && ast_kind(init) == 35 {
                            uint32 callee = ast_data1(init)
                            if tok_matches(callee, name_ptr, name_len) != 0 {
                                return 1
                            }
                        }
                    }
                    inner = ast_next(inner)
                }
            }
        }
        stmt = ast_next(stmt)
    }
    return 0
}

// Sub-recognizer: phase 1 / phase 11 — rmsnorm gated to WG 0 only.
// Returns 1 if rmsnorm_wg0_marker() call found in any if-block, 0 otherwise.
fn _body_has_rmsnorm_wg0_marker(uint64 body_node) -> uint64 {
    return _body_has_marker(body_node, "rmsnorm_wg0_marker", 18)
}

// Sub-recognizer: phase 3 / phase 13 — gemv_coop_bf16_f32, padded-row stride.
// Shape: if wg_id < 256 { qkv_matmul_marker() }
// Returns 1 if qkv_matmul_marker() call found in any if-block, 0 otherwise.
fn _body_has_qkv_matmul_marker(uint64 body_node) -> uint64 {
    return _body_has_marker(body_node, "qkv_matmul_marker", 17)
}

// Sub-recognizer: phase 5 — QKV split + qknorm + RoPE (3-way head dispatch).
// Shape: if wg_id < 32 { qkv_split_qknorm_rope_marker() }
// Returns 1 if qkv_split_qknorm_rope_marker() call found in any if-block, 0 otherwise.
fn _body_has_qkv_split_qknorm_rope_marker(uint64 body_node) -> uint64 {
    return _body_has_marker(body_node, "qkv_split_qknorm_rope_marker", 28)
}

// Sub-recognizer: phase 7 — attn_decode with cooperative-WG dimension.
// Shape: if wg_id < 64 { attn_decode_coop_marker() }   (64 = N_HEADS*ATTN_COOP)
// Returns 1 if attn_decode_coop_marker() call found in any if-block, 0 otherwise.
fn _body_has_attn_decode_coop_marker(uint64 body_node) -> uint64 {
    return _body_has_marker(body_node, "attn_decode_coop_marker", 23)
}


// Phase 3 / phase 13 inline ISA emitter — gemv_coop_bf16_f32 padded-row stride.
//
// Emits INLINE (no asm_init, no s_endpgm) into the ongoing asm buffer.
// Slice 4.19.7 renamed _emit_phase3_qkv_matmul_inline →
// _emit_gemv_coop_bf16_padded_strided_inline and parameterized the 3
// kernarg byte offsets + wg_id_sgpr so phase 13 (gate_up matmul) can reuse it.
//
// sdata_pair semantics: each pair index N maps to SGPR pair s[2N:2N+1].
//   asm_s_load_b64_off(N, 0, offset) → s[2N:2N+1] = kernarg[offset:offset+7]
// Example: sdata_pair=1 → s[2:3].  Both phase 3 and phase 13 pass (1, 2, 3),
// landing the weight/input/output ptrs in s[2:3]/s[4:5]/s[6:7].
//
// Phase 3 caller passes byte offsets:
//   w_kofs=0x10   → s[2:3] = qkv_w      (arg 2)
//   x_kofs=0x88   → s[4:5] = b_x_norm_g (arg 17)
//   out_kofs=0x90 → s[6:7] = b_qkv_g    (arg 18)
//   wg_id_sgpr=15 (s15 still holds the hardware wg_id_x at phase 3 entry).
//
// Phase 13 caller passes byte offsets:
//   w_kofs=0x20   → s[2:3] = gate_up_w   (arg 4)
//   x_kofs=0xA8   → s[4:5] = b_mid_norm_g (arg 21)
//   out_kofs=0x80 → s[6:7] = gu_scratch  (arg 16)
//   wg_id_sgpr=28 (s15 was clobbered by phase 5's rope_sin load; the prologue
//   stashed the original wg_id_x to s28, same as phase 9 / phase 11 use).
//
// SGPR context on entry (from prologue):
//   s[0:1]  = kernarg ptr pair
//   s[8:9]  = barrier_counter ptr (not used here)
//   s[10:11]= max_phase value (not used here)
//   s15     = wg_id_x ON KERNEL ENTRY (clobbered after phase 5)
//   s28     = saved wg_id_x (set by prologue before phase 5)
//
// Body allocates:
//   s[2:3]  = weight ptr        (kernarg offset = w_kofs)
//   s[4:5]  = input  ptr        (kernarg offset = x_kofs)
//   s[6:7]  = output ptr        (kernarg offset = out_kofs)
//   s12     = r_off loop counter (0..ROWS_PER_WG-1)
//   s13     = row index (wg_id + r_off * wg_active)
//   s14     = k loop bound / row*4 byte offset / scratch
//
// VGPR context (local to the phase, not preserved after):
//   v0  = lane id (hardware — must be preserved across phase; xor only uses it r/o)
//   v1  = vaddr = 0 (for global_store with saddr)
//   v2  = acc (f32 accumulator per lane)
//   v3:v4 = weight row ptr (w_row_u32 + lane*4, then +128 per iter)
//   v5:v6 = x ptr (b_x_norm_g + lane*8, then +256 per iter)
//   v7  = lane * 4 (constant, for weight ptr init each row)
//   v8  = lane * 8 (constant, for x ptr init each row)
//   v9  = packed u32 (2 bf16 weights)
//   v10 = bf16-lo as f32 (lshlrev by 16)
//   v11 = x[kp*2]   (loaded f32)
//   v12 = x[kp*2+1] (loaded f32 from +4 byte offset)
//
// Algorithm (parameterized by n_out / k / k_pad / wg_active):
//   ROWS_PER_WG = ceil(n_out / wg_active)
//                 phase 3:  ceil(4096/256) = 16
//                 phase 13: ceil(6144/256) = 24
//   for r_off = 0..ROWS_PER_WG-1:
//       row = wg_id + r_off * wg_active
//       if row >= n_out: continue (skip via gate branch)
//       acc = 0.0
//       w_row_u32 = w_ptr + row * k_pad * 2     (bytes; k_pad in u16 = 2B each)
//       x_base = x_ptr + 0                      (f32 array, kp indexes directly)
//       for kp = lane; kp < k/2; kp += 32:
//           packed = w_row_u32[kp]               (global_load_b32)
//           x0 = x_base[kp*2]                   (global_load_b32)
//           x1 = x_base[kp*2+1]                 (global_load_b32 offset:+4)
//           w0 = bf16_to_f32(packed & 0xFFFF)   (v_lshlrev_b32 v10, 16, v9)
//           w1 = bf16_to_f32(packed >> 16)      (v_and_b32 0xFFFF0000, v9)
//           acc += w0*x0 + w1*x1                (2× v_fmac_f32)
//       acc = wave_reduce_add_5_levels(acc)      (_emit_wave_xor_reduce_add_f32_5_levels)
//       if lane == 0:
//           out[row] = acc                       (global_store_b32 via s[6:7]+row*4)
// _emit_gemv_coop_bf16_padded_strided_inline — gemv_coop_bf16_f32,
// padded-row stride, emitted INLINE (no asm_init, no s_endpgm).
//
// Shared by phase 3 (QKV matmul) and phase 13 (gate_up matmul).  The math
// core is identical: bf16 weight unpack → fmac into f32 acc → wave-XOR
// reduce → lane-0 store.  The only differences across phases are:
//   1. Output shape (n_out): QKV_DIM=4096 vs 2*FF=6144.
//   2. Kernarg byte offsets for the 3 pointers.
//   3. Which SGPR holds wg_id_x (s15 on kernel entry, but phase 5 clobbers
//      s15 mid-kernel via `s_load_b64 s[14:15], 0x58` for rope_sin; the
//      prologue saves it to s28 for downstream phases).
//
// For phase 3 (N_OUT=4096, K=1024, K_PAD=1152, WG_ACTIVE=256):
//   ROWS_PER_WG = 16.  wg_id range = 0..255.  Max row = 255+15*256 = 4095 < 4096.
//   All 16 rows per WG are in-bounds — no per-row bounds check needed.
//   k/2 / 32 = 512/32 = 16 inner loop iterations.
//
// For phase 13 (N_OUT=6144, K=1024, K_PAD=1152, WG_ACTIVE=256):
//   ROWS_PER_WG = 24.  wg_id range = 0..255.  Max row = 255+23*256 = 6143 < 6144.
//   All 24 rows per WG are in-bounds — no per-row bounds check needed.
//
// SGPR layout (in addition to prologue s[0:1], s[8:9], s[10:11], wg_id_sgpr):
//   s[2:3]  = weight ptr (loaded; advances by w_row_step each outer iter)
//   s[4:5]  = input  ptr (loaded once; never modified)
//   s[6:7]  = output ptr (loaded once; never modified; output ptr computed per row)
//   s12     = outer loop counter (r_off)
//   s13     = row index (init: wg_id_sgpr; +wg_active each outer iter)
//   s14     = output byte offset per row / scratch
//   s17     = saved exec_lo for lane-0 gate (clobbered & restored inside)
//
// VGPR layout:
//   v0  = lane id (hardware, r/o)
//   v1  = vaddr=0 for output store
//   v2  = acc (f32 accumulator)
//   v3:v4 = weight ptr per lane (init: s[2:3]+lane*4; +128 each inner iter)
//   v5:v6 = x ptr per lane     (init: s[4:5]+lane*8; +256 each inner iter)
//   v7  = lane*4  (constant)
//   v8  = lane*8  (constant)
//   v9  = packed u32 (2 bf16 weights); reused as bpermute addr after inner loop
//   v10 = bf16-lo f32 / reduce tmp
//   v11 = x[kp*2]
//   v12 = x[kp*2+1]
//
// Parameters:
//   n_out         = number of output rows (phase 3: 4096; phase 13: 6144)
//   k             = inner K dimension (e.g. HIDDEN = 1024)
//   k_pad         = padded row stride in u16 elements (e.g. HIDDEN_PAD = 1152)
//   wg_active     = number of WGs active in this phase (row-stride divisor).
//                   MEGA_WG_PERSIST=512 is the launch grid; wg_active is the
//                   active-WG count for this phase's per-WG row assignment.
//                   Both phase 3 and phase 13 use wg_active=256.
//   w_sdata_pair  = sdata_pair for weight ptr (loaded via s_load_b64)
//   x_sdata_pair  = sdata_pair for input ptr
//   out_sdata_pair= sdata_pair for output ptr
//   w_kofs        = kernarg byte offset for weight ptr (phase 3: 0x10 = qkv_w;
//                                                       phase 13: 0x20 = gate_up_w)
//   x_kofs        = kernarg byte offset for input ptr  (phase 3: 0x88 = b_x_norm_g;
//                                                       phase 13: 0xA8 = b_mid_norm_g)
//   out_kofs      = kernarg byte offset for output ptr (phase 3: 0x90 = b_qkv_g;
//                                                       phase 13: 0x80 = gu_scratch)
//   wg_id_sgpr    = SGPR # holding wg_id_x.  Phase 3 uses 15 (still untouched
//                   when phase 3 runs).  Phase 13 must use 28 (the saved copy
//                   stashed in the prologue) because phase 5's rope_sin load
//                   has clobbered s15 by then — same constraint that forced
//                   phase 9 / phase 11 to read s28.
fn _emit_gemv_coop_bf16_padded_strided_inline(uint64 n_out, uint64 k, uint64 k_pad,
                                    uint64 wg_active,
                                    uint64 w_sdata_pair, uint64 x_sdata_pair,
                                    uint64 out_sdata_pair,
                                    uint64 w_kofs, uint64 x_kofs, uint64 out_kofs,
                                    uint64 wg_id_sgpr) {
    // ── WG gate (skip if wg_id >= wg_active) ─────────────────────────────
    // s_cmp_ge_u32 s<wg_id_sgpr>, wg_active: SOPC op=0x09, ssrc0=wg_id_sgpr,
    //   ssrc1=lit(0xFF), lit=wg_active
    //   SOPC ops: eq_i32=0, ne_i32=1, gt_i32=2, ge_i32=3, lt_i32=4, le_i32=5,
    //             eq_u32=6, ne_u32=7, gt_u32=8, ge_u32=9, lt_u32=10, le_u32=11
    //   word = 0xBF000000|(9<<16)|(0xFF<<8)|wg_id_sgpr
    uint64 gate_cmp_pos = asm_text_len / 4
    asm_u32(0xBF09FF00 | (wg_id_sgpr & 0xFF))
    asm_u32(wg_active)
    asm_s_cbranch_scc1(0)   // patched at end

    // ── Load base pointers ────────────────────────────────────────────────
    asm_s_load_b64_off(w_sdata_pair,   0, w_kofs)     // weight → s[w_lo:w_hi]
    asm_s_load_b64_off(x_sdata_pair,   0, x_kofs)     // input  → s[x_lo:x_hi]
    asm_s_load_b64_off(out_sdata_pair, 0, out_kofs)   // output → s[out_lo:out_hi]
    asm_s_waitcnt_lgkmcnt_zero()

    // SGPR pair indices (needed early for the slice 6.7d per-WG weight offset).
    uint64 w_lo = w_sdata_pair * 2
    uint64 w_hi = w_lo + 1
    uint64 x_lo = x_sdata_pair * 2
    uint64 x_hi = x_lo + 1
    uint64 out_lo = out_sdata_pair * 2
    uint64 out_hi = out_lo + 1

    // ── Slice 6.7d: per-WG weight base offset (bug #3 fix) ────────────────
    // HIP reference (qwen3_layer_megakernel.hip.cpp phase3_qkv_matmul):
    //     w_row_u32 = qkv_w + row * HIDDEN_PAD;       // row = wg_id + r_off*WG_PERSIST
    // i.e. the weight base for r_off=0 is qkv_w + wg_id * k_pad bf16-elements
    // = qkv_w + wg_id * k_pad * 2 bytes.  Without this, every WG starts at
    // row 0 and the per-outer-iter advance (w_row_step = wg_active*k_pad*2)
    // only walks rows 0, wg_active, 2*wg_active, ... shared across all WGs —
    // so b_qkv_g[r_off*wg_active .. r_off*wg_active + wg_active-1] all
    // collapse to the same dot product (the wg_active-stripe pattern observed
    // on Llama at slice 6.7c).  Qwen3 was never bit-exact-validated under
    // the firing M=1 mega-kernel (slice 5.10 / 6.4 acceptance runs were
    // CPU bf16 fallback per the slice 6.5+ correction); the v1/v2 A/B
    // harness's v1 .co was a clang-offload bundle that the loader never
    // actually decoded, so v1 produced its uninitialised slab and "matched"
    // v2's identically uninitialised slab.
    //
    // Encoding plan:
    //     s14 = s<wg_id_sgpr> * (k_pad * 2)      ; bytes
    //     s[w_lo:w_hi] += s14                    ; 64-bit add (lo + carry)
    // Uses the existing _emit_s_mul_u32_pow2_or_lit helper so the s_mul_i32
    // collapses to s_lshl_b32 when k_pad*2 is a power of two (none of the
    // current archs hit that fast path: Qwen3 k_pad*2 = 2304, Llama 4352).
    _emit_s_mul_u32_pow2_or_lit(14, wg_id_sgpr, k_pad * 2)
    // s_add_u32 w_lo, w_lo, s14   (SOP2 op 0, ssrc1=s14=0x0E)
    asm_u32(0x80000000 | (w_lo << 16) | (14 << 8) | w_lo)
    // s_addc_u32 w_hi, w_hi, 0    (SOP2 op 4, ssrc1=0x80=inline-0)
    asm_u32(0x82000000 | (w_hi << 16) | 0x8000 | w_hi)

    // ── Constant lane offsets ─────────────────────────────────────────────
    asm_v_lshlrev_b32_imm(7, 2, 0)   // v7 = lane*4
    asm_v_lshlrev_b32_imm(8, 3, 0)   // v8 = lane*8
    asm_v_mov_b32_inline_u(1, 0)     // v1 = 0 (vaddr for store)

    // ── Outer loop init ───────────────────────────────────────────────────
    // s13 = row = wg_id (read from wg_id_sgpr param: s15 phase 3, s28 phase 13)
    // s_mov_b32 s13, s<wg_id_sgpr>: SOP1 (0x17D<<23)|(0x0D<<16)|wg_id_sgpr
    //   word = 0xBE8D0000 | wg_id_sgpr
    //   Verified: asm_s_mov_b32(13, 15) = 0xBE8D000F (phase 3 original).
    asm_s_mov_b32(13, wg_id_sgpr)
    // s12 = r_off = 0 (outer loop counter)
    asm_s_mov_b32_inline_imm(12, 0)

    // w_row_step = wg_active * k_pad * 2 bytes (advance qkv_w ptr per r_off iter)
    uint64 w_row_step = wg_active * k_pad * 2
    // k_iters = k / 2 / 32 (inner loop count; for k=1024: 512/32=16)
    uint64 k_iters = k / 2 / 32
    // rows_per_wg = ceil(n_out / wg_active)
    uint64 rows_per_wg = (n_out + wg_active - 1) / wg_active

    uint64 outer_top = asm_text_len / 4

    // ── Per-row body ──────────────────────────────────────────────────────
    // Slice 7.6a (2026-05-17): 8-way multi-accumulator.  acc[0..7] live in
    // v2, v41, v42, v43, v44, v45, v46, v47.  Even-VGPR/odd-VGPR pairing
    // (X-slot even, Y-slot odd) satisfies VOPD's vdst parity constraint so
    // Ramp 2 (slice 7.6b) can pack adjacent FMAs as v_dual_fmac_f32.
    asm_v_mov_b32_inline_u(2,  0)   // acc[0] = 0.0 (X-slot, even — keeps v2 for wave-reduce target)
    asm_v_mov_b32_inline_u(41, 0)   // acc[1] = 0.0 (Y-slot, odd)
    asm_v_mov_b32_inline_u(42, 0)   // acc[2] = 0.0 (X-slot, even)
    asm_v_mov_b32_inline_u(43, 0)   // acc[3] = 0.0 (Y-slot, odd)
    asm_v_mov_b32_inline_u(44, 0)   // acc[4] = 0.0
    asm_v_mov_b32_inline_u(45, 0)   // acc[5] = 0.0
    asm_v_mov_b32_inline_u(46, 0)   // acc[6] = 0.0
    asm_v_mov_b32_inline_u(47, 0)   // acc[7] = 0.0

    // init weight ptr: v3:v4 = s[w_lo:w_hi] + lane*4
    asm_v_mov_b32_inline_u(4, 0)
    asm_v_add_co_u32_vcc_sv(3, w_lo, 7)
    asm_v_add_co_ci_u32_null_sv_vcc(4, w_hi, 4)

    // init x ptr: v5:v6 = s[x_lo:x_hi] + lane*8
    asm_v_mov_b32_inline_u(6, 0)
    asm_v_add_co_u32_vcc_sv(5, x_lo, 8)
    asm_v_add_co_ci_u32_null_sv_vcc(6, x_hi, 6)

    // ── Inner K loop (8× unrolled, 8-way multi-accumulator) ──────────────
    // Slice 7.5 (2026-05-13): extended from 4× to 8× unroll.  Each iter
    // issues 24 loads in a clause (8 weight pairs + 16 x elements) with
    // one waitcnt, 16 FMAs, one ptr-advance per ptr.  Exposes ~24 VMEM ops
    // in flight to mask the ~300-cycle global_load latency more
    // aggressively than the 4× version's 12 in flight.
    //
    // Slice 7.6a (2026-05-17): split the single v2 accumulator into 8
    // independent accumulators (v2/v41/v42/v43/v44/v45/v46/v47) so the 16
    // FMAs in the body form 8 independent dependency chains rather than one
    // serial chain through v2.  This eliminates the v_fmac→v_fmac RAW
    // serialization that the gfx11 issue queue could not hide even with the
    // 8× unroll's wider load window.  Post-inner-loop epilogue sums
    // acc[1..7] back into acc[0]=v2 BEFORE the wave-XOR reduce (which still
    // operates on v2 alone).
    //
    // Slice 7.6b (2026-05-17): the 16 FMAs are now emitted as 8 VOPD pairs
    // (v_dual_fmac_f32 :: v_dual_fmac_f32) — each pair issues the lo*x_even
    // half on slot X and the hi*x_odd half on slot Y in a single 64-bit
    // VOPD instruction, engaging gfx11 dual-issue.  Bank constraints (src0_X
    // bank != src0_Y bank, src1_X bank != src1_Y bank, vdst even/odd
    // parity) are satisfied by pairing within a single weight-pair: src0 is
    // (lo bank 2, hi bank 1), src1 is (x_even bank 3, x_odd bank 0).
    //
    // Precondition: k_iters_outer = k / 16 / 32 must be integer.  Llama-1B
    // (k ∈ {2048, 8192}) → k_iters/8 ∈ {4, 16}.  Qwen3-0.6B (k ∈ {1024,
    // 3072, 2048}) → k_iters/8 ∈ {2, 6, 4}.  Mistral-7B (k ∈ {4096, 14336})
    // → k_iters/8 ∈ {8, 28}.  All integer.
    //
    // VGPR pressure: v9, v13, v17, v21, v25, v29, v33, v37 (weights, stride 4)
    // plus v10/v14/v18/v22/v26/v30/v34/v38 (lo-bf16 unpacks) plus
    // v11/v12, v15/v16, v19/v20, v23/v24, v27/v28, v31/v32, v35/v36, v39/v40
    // (x pairs) plus v2/v41..v47 (8 accumulators).  Peak v47, well within
    // rsrc1=0xE0AF0006 (56-VGPR) budget.
    // global_load_b32 offset max u12 = 0xFFF; max used here = 0x704 (x[15]).
    uint64 k_iters_unrolled = k_iters / 8
    asm_s_mov_b32_inline_imm(14, k_iters_unrolled)
    uint64 inner_top = asm_text_len / 4

    asm_s_clause(23)
    asm_u32(0xDC520000); asm_u32(0x097C0003)    // global_load_b32 v9,  v[3:4], off              (weight 0)
    asm_u32(0xDC520080); asm_u32(0x0D7C0003)    // global_load_b32 v13, v[3:4], off offset:128   (weight 1)
    asm_u32(0xDC520100); asm_u32(0x117C0003)    // global_load_b32 v17, v[3:4], off offset:256   (weight 2)
    asm_u32(0xDC520180); asm_u32(0x157C0003)    // global_load_b32 v21, v[3:4], off offset:384   (weight 3)
    asm_u32(0xDC520200); asm_u32(0x197C0003)    // global_load_b32 v25, v[3:4], off offset:512   (weight 4)
    asm_u32(0xDC520280); asm_u32(0x1D7C0003)    // global_load_b32 v29, v[3:4], off offset:640   (weight 5)
    asm_u32(0xDC520300); asm_u32(0x217C0003)    // global_load_b32 v33, v[3:4], off offset:768   (weight 6)
    asm_u32(0xDC520380); asm_u32(0x257C0003)    // global_load_b32 v37, v[3:4], off offset:896   (weight 7)
    asm_u32(0xDC520000); asm_u32(0x0B7C0005)    // global_load_b32 v11, v[5:6], off              (x[0])
    asm_u32(0xDC520004); asm_u32(0x0C7C0005)    // global_load_b32 v12, v[5:6], off offset:4     (x[1])
    asm_u32(0xDC520100); asm_u32(0x0F7C0005)    // global_load_b32 v15, v[5:6], off offset:256   (x[2])
    asm_u32(0xDC520104); asm_u32(0x107C0005)    // global_load_b32 v16, v[5:6], off offset:260   (x[3])
    asm_u32(0xDC520200); asm_u32(0x137C0005)    // global_load_b32 v19, v[5:6], off offset:512   (x[4])
    asm_u32(0xDC520204); asm_u32(0x147C0005)    // global_load_b32 v20, v[5:6], off offset:516   (x[5])
    asm_u32(0xDC520300); asm_u32(0x177C0005)    // global_load_b32 v23, v[5:6], off offset:768   (x[6])
    asm_u32(0xDC520304); asm_u32(0x187C0005)    // global_load_b32 v24, v[5:6], off offset:772   (x[7])
    asm_u32(0xDC520400); asm_u32(0x1B7C0005)    // global_load_b32 v27, v[5:6], off offset:1024  (x[8])
    asm_u32(0xDC520404); asm_u32(0x1C7C0005)    // global_load_b32 v28, v[5:6], off offset:1028  (x[9])
    asm_u32(0xDC520500); asm_u32(0x1F7C0005)    // global_load_b32 v31, v[5:6], off offset:1280  (x[10])
    asm_u32(0xDC520504); asm_u32(0x207C0005)    // global_load_b32 v32, v[5:6], off offset:1284  (x[11])
    asm_u32(0xDC520600); asm_u32(0x237C0005)    // global_load_b32 v35, v[5:6], off offset:1536  (x[12])
    asm_u32(0xDC520604); asm_u32(0x247C0005)    // global_load_b32 v36, v[5:6], off offset:1540  (x[13])
    asm_u32(0xDC520700); asm_u32(0x277C0005)    // global_load_b32 v39, v[5:6], off offset:1792  (x[14])
    asm_u32(0xDC520704); asm_u32(0x287C0005)    // global_load_b32 v40, v[5:6], off offset:1796  (x[15])
    asm_s_waitcnt_vmcnt_zero()

    asm_v_lshlrev_b32_imm(10, 16, 9)            // v10 = bf16-lo[0] as f32
    asm_u32(0x361212FF); asm_u32(0xFFFF0000)    // v9  = bf16-hi[0] as f32
    asm_v_lshlrev_b32_imm(14, 16, 13)           // v14 = bf16-lo[1] as f32
    asm_u32(0x361A1AFF); asm_u32(0xFFFF0000)    // v13 = bf16-hi[1] as f32
    asm_v_lshlrev_b32_imm(18, 16, 17)           // v18 = bf16-lo[2] as f32
    asm_u32(0x362222FF); asm_u32(0xFFFF0000)    // v17 = bf16-hi[2] as f32
    asm_v_lshlrev_b32_imm(22, 16, 21)           // v22 = bf16-lo[3] as f32
    asm_u32(0x362A2AFF); asm_u32(0xFFFF0000)    // v21 = bf16-hi[3] as f32
    asm_v_lshlrev_b32_imm(26, 16, 25)           // v26 = bf16-lo[4] as f32
    asm_u32(0x363232FF); asm_u32(0xFFFF0000)    // v25 = bf16-hi[4] as f32
    asm_v_lshlrev_b32_imm(30, 16, 29)           // v30 = bf16-lo[5] as f32
    asm_u32(0x363A3AFF); asm_u32(0xFFFF0000)    // v29 = bf16-hi[5] as f32
    asm_v_lshlrev_b32_imm(34, 16, 33)           // v34 = bf16-lo[6] as f32
    asm_u32(0x364242FF); asm_u32(0xFFFF0000)    // v33 = bf16-hi[6] as f32
    asm_v_lshlrev_b32_imm(38, 16, 37)           // v38 = bf16-lo[7] as f32
    asm_u32(0x364A4AFF); asm_u32(0xFFFF0000)    // v37 = bf16-hi[7] as f32

    // 16 FMAs into 8 independent accumulators, packed as 8 VOPD pairs.
    // Slice 7.6b (2026-05-17): adjacent (lo*x_even, hi*x_odd) FMAs that
    // target the X/Y accumulators of one weight-pair are now issued as a
    // single v_dual_fmac_f32 to engage gfx11 dual-issue.  Per-pair bank
    // layout (verified — see asm_v_dual_fmac_f32 docstring):
    //   src0:  X=lo (v10,v14,v18,...) bank 2  |  Y=hi (v9,v13,v17,...) bank 1
    //   src1:  X=x_even (v11,v15,...) bank 3  |  Y=x_odd (v12,v16,...) bank 0
    //   vdst:  X∈{v2,v42,v44,v46} even        |  Y∈{v41,v43,v45,v47} odd
    asm_v_dual_fmac_f32(2,  10, 11,  41, 9,  12)   // acc[0]+=w0_lo*x[0] :: acc[1]+=w0_hi*x[1]
    asm_v_dual_fmac_f32(42, 14, 15,  43, 13, 16)   // acc[2]+=w1_lo*x[2] :: acc[3]+=w1_hi*x[3]
    asm_v_dual_fmac_f32(44, 18, 19,  45, 17, 20)   // acc[4]+=w2_lo*x[4] :: acc[5]+=w2_hi*x[5]
    asm_v_dual_fmac_f32(46, 22, 23,  47, 21, 24)   // acc[6]+=w3_lo*x[6] :: acc[7]+=w3_hi*x[7]
    asm_v_dual_fmac_f32(2,  26, 27,  41, 25, 28)   // acc[0]+=w4_lo*x[8] :: acc[1]+=w4_hi*x[9]
    asm_v_dual_fmac_f32(42, 30, 31,  43, 29, 32)   // acc[2]+=w5_lo*x[10]:: acc[3]+=w5_hi*x[11]
    asm_v_dual_fmac_f32(44, 34, 35,  45, 33, 36)   // acc[4]+=w6_lo*x[12]:: acc[5]+=w6_hi*x[13]
    asm_v_dual_fmac_f32(46, 38, 39,  47, 37, 40)   // acc[6]+=w7_lo*x[14]:: acc[7]+=w7_hi*x[15]

    // advance weight ptr +1024 bytes (8 weights × 128B stride)
    asm_u32(0xD7006A03); asm_u32(0x000206FF); asm_u32(1024)
    asm_u32(0xD5207C04); asm_u32(0x01AA0880)
    // advance x ptr +2048 bytes (16 x × 128B stride)
    asm_u32(0xD7006A05); asm_u32(0x00020AFF); asm_u32(2048)
    asm_u32(0xD5207C06); asm_u32(0x01AA0C80)

    asm_s_sub_u32_imm(14, 14, 1)
    asm_s_cmp_eq_u32(14, 0x80)
    uint64 inner_back = (0 - ((asm_text_len / 4) - inner_top) - 1) & 0xFFFF
    asm_s_cbranch_scc0(inner_back)

    // ── Sum 8 accumulators back into v2 (Ramp 7.6a) ──────────────────────
    // Must run BEFORE the wave-XOR reduce, which uses v2 as acc and v9/v10
    // as scratch (clobbering w0_hi/w0_lo, both dead now).  This is per-lane
    // reduction; the wave-XOR then reduces across lanes as before.
    //   v_add_f32_e32 v2, v2, v41   = 0x06045302  (vsrc1=v41=0x29 → 0x29<<9=0x5200; src0=v2|0x100=0x102)
    asm_u32(0x06045302)                          // v2 += v41
    asm_u32(0x06045502)                          // v2 += v42
    asm_u32(0x06045702)                          // v2 += v43
    asm_u32(0x06045902)                          // v2 += v44
    asm_u32(0x06045B02)                          // v2 += v45
    asm_u32(0x06045D02)                          // v2 += v46
    asm_u32(0x06045F02)                          // v2 += v47

    // ── Wave XOR reduce ───────────────────────────────────────────────────
    // acc=v2, addr=v9 (free after inner loop), tmp=v10
    _emit_wave_xor_reduce_add_f32_5_levels(2, 9, 10)

    // ── Lane-0 store ──────────────────────────────────────────────────────
    // Save exec to s17 (free high SGPR; s15 = wg_id_x MUST NOT be overwritten here —
    // clobbering s15 was the root cause of the phase-5 zero-output bug: all WGs saw
    // s15 = 0xFFFFFFFF = exec_lo instead of the real wg_id, so all 512 WGs took the
    // outer gate skip-branch wg_id >= 32, leaving kc/vc/b_attn_q_g buffers all zeros).
    // GFX11 (RDNA3) does not enforce an SGPR upper limit via RSRC1 bits[9:6] (the HIP
    // compiler emits bits[9:6]=0 for a kernel that uses s0..s67), so s17 is safe.
    // v_cmpx_eq_u32_e32 clobbers BOTH exec AND vcc_lo, so we cannot use vcc_lo as save.
    // Correct pattern: v_cmp_eq_u32_e32 (writes ONLY vcc_lo), then s_and_saveexec_b32 s17.
    // v_cmp_eq_u32_e32 vcc_lo, 0, v0  → vcc_lo = mask of lane 0 (does NOT modify exec)
    asm_v_cmp_eq_u32_imm_vgpr(0, 0)  // vcc_lo = (v0 == 0), exec unchanged
    // s_and_saveexec_b32 s17, vcc_lo  → s17 = old exec; exec = exec & vcc_lo (lane 0 only)
    asm_s_and_saveexec_b32_vcc_lo(17)

    // output byte offset = row * 4
    // s_lshl_b32 s14, s13, 2: SOP2 op=0x08, sdst=s14=0x0E, ssrc1=inline 2=0x82, ssrc0=s13=0x0D
    //   Verified from codebase: s_lshl_b32 s14,s14,2 = 0x840E820E (op bits give 0x84 prefix)
    //   word = (2<<30)|(8<<23)|(0x0E<<16)|(0x82<<8)|0x0D = 0x840E820D
    asm_u32(0x840E820D)

    // s_add_u32 out_lo, out_lo, s14  (b_qkv_g += row*4)
    // SOP2 op 0: word = (2<<30)|(0<<23)|(sdst<<16)|(ssrc1<<8)|ssrc0 = 0x80000000|...
    asm_u32(0x80000000 | (out_lo << 16) | (14 << 8) | out_lo)
    // s_addc_u32 out_hi, out_hi, 0
    // SOP2 op 4: word = (2<<30)|(4<<23)|(sdst<<16)|(0x80<<8)|ssrc0 = 0x82000000|...
    // Verified: s_addc_u32 s7,s7,0 = 0x82078007 (from format_amdgpu.mlr line 6101)
    asm_u32(0x82000000 | (out_hi << 16) | 0x8000 | out_hi)

    // global_store_b32 v1, v2, s[out_lo:out_hi]
    asm_u32(0xDC6A0000)
    asm_u32((out_lo << 16) | (2 << 8) | 1)

    // Restore exec: s_or_b32 exec_lo, exec_lo, s17  (restores from s17 save above)
    // SOP2 op=11 (s_or_b32): sdst=exec_lo=0x7E, ssrc0=exec_lo=0x7E, ssrc1=s17=0x11
    // Verified base encoding: s_or_b32 exec_lo, exec_lo, s3 = 0x8C7E037E (from barrier code)
    //   ssrc1 field is bits[15:8]; s17=0x11 → 0x8C7E117E
    asm_u32(0x8C7E117E)               // s_or_b32 exec_lo, exec_lo, s17

    // ── Restore b_qkv_g ptr (undo the offset added above) ─────────────────
    // We added row*4 to s[out_lo:out_hi]. Remove it: s_sub_u32 / s_subb_u32.
    // s14 currently holds row*4 (computed above by s_lshl_b32 s14,s13,2).
    // s_sub_u32 out_lo, out_lo, s14: SOP2 op 0x01
    //   Verified: s_sub_u32 = op 1 from 0x80968116 = s_sub_u32 s22,s22,1
    //   word = (2<<30)|(1<<23)|(out_lo<<16)|(s14=0x0E<<8)|out_lo
    //        = 0x80800000|(out_lo<<16)|(0x0E<<8)|out_lo
    asm_u32(0x80800000 | (out_lo << 16) | (0x0E << 8) | out_lo)
    // s_subb_u32 out_hi, out_hi, 0: SOP2 op 0x05
    //   Verified: op 5 = s_subb_u32 from 0x82878007 having op=5
    //   word = (2<<30)|(5<<23)|(out_hi<<16)|(0x80<<8)|out_hi
    //        = 0x82800000|(out_hi<<16)|0x8000|out_hi
    asm_u32(0x82800000 | (out_hi << 16) | 0x8000 | out_hi)

    // ── Outer loop advance ────────────────────────────────────────────────
    // Advance weight ptr by w_row_step bytes (next WG_PERSIST-strided row)
    // s14 = w_row_step (literal): s_mov_b32 s14, lit32
    // SOP1 (0x17D<<23)|(0x0E<<16)|0xFF = 0xBE8E00FF, then literal word
    asm_s_mov_b32_lit32(14, w_row_step & 0xFFFFFFFF)
    // s_add_u32 w_lo, w_lo, s14 (op 0): 0x80000000|(w_lo<<16)|(0x0E<<8)|w_lo
    asm_u32(0x80000000 | (w_lo << 16) | (0x0E << 8) | w_lo)
    // s_addc_u32 w_hi, w_hi, 0 (op 4): 0x82000000|(w_hi<<16)|(0x80<<8)|w_hi
    asm_u32(0x82000000 | (w_hi << 16) | 0x8000 | w_hi)

    // Advance row: s13 += wg_active (active WG count for this phase's row stride)
    // s_add_u32 s13, s13, wg_active: ssrc1=0xFF(lit), lit=wg_active
    // word = (0x80000000)|(0x0D<<16)|(0xFF<<8)|0x0D = 0x800DFF0D, lit=wg_active
    asm_u32(0x800DFF0D)
    asm_u32(wg_active)

    // Increment r_off: s_add_u32 s12, s12, 1; check s12 < rows_per_wg
    // s_add_u32 s12, s12, 1: ssrc1=0x81(inline imm 1)
    // SOP2 op 0x00: word = 0x80000000|(0x0C<<16)|(0x81<<8)|0x0C = 0x800C810C
    asm_u32(0x800C810C)
    // s_cmp_lt_u32 s12, rows_per_wg: SCC=1 if s12 < rows_per_wg
    // SOPC op 0x0A (10=lt_u32), ssrc0=s12=0x0C, ssrc1=literal
    // word = 0xBF000000|(0x0A<<16)|(0xFF<<8)|0x0C = 0xBF0AFF0C, lit=rows_per_wg
    asm_u32(0xBF0AFF0C)
    asm_u32(rows_per_wg & 0xFFFFFFFF)
    // s_cbranch_scc1 outer_top
    uint64 outer_back = (outer_top - (asm_text_len / 4) - 1) & 0xFFFF
    asm_s_cbranch_scc1(outer_back)

    // ── Patch the WG gate skip-branch ─────────────────────────────────────
    uint64 body_dwords = (asm_text_len / 4) - (gate_cmp_pos + 3)
    asm_patch_u32(gate_cmp_pos + 2, 0xBFA20000 | (body_dwords & 0xFFFF))
}

// ── Phase 2 cputree inline ISA emitter ────────────────────────────────────
//
// _emit_gemv_cputree_bf16_padded_strided_inline — CPU-matching reduction-tree
// variant of _emit_gemv_coop_bf16_padded_strided_inline.
//
// Same outer scaffolding (WG gate, kernarg loads, per-WG weight base offset,
// outer-row loop, lane-0 store, outer advance, gate patch) as the existing
// helper, but the INNER per-row body matches the CPU's bf16→f32 dot product
// exactly:
//   - 8 active lanes per wave (exec_lo = 0xFF), stride-8 K partition
//   - Single-FMA v_fmac_f32 per K iter (no unroll), bf16-widen via lshl 16
//   - 3-level XOR-bpermute reduce in offset order [4, 1, 2]
//
// This is the inline-mega-kernel port of _emit_gemv_coop_bf16_f32_cputree_body
// (src/format_amdgpu.mlr line 6414).  Phase 2 of the Llama-3B bit-exact plan.
//
// Signature matches _emit_gemv_coop_bf16_padded_strided_inline so the
// caller (mega-kernel phase 3 emit) can swap helpers based on MEGA_HIDDEN.
//
// VGPR usage (kept close to the existing helper for coexistence safety):
//   v0       = lane id (hardware, r/o)
//   v1       = vaddr=0 for global_store_b32 saddr-form (set inside per-row body)
//   v2       = acc (f32 accumulator)
//   v3:v4    = weight ptr per lane (s[w_lo:w_hi] + lane*2; +16 each inner iter)
//   v5:v6    = x ptr per lane     (s[x_lo:x_hi] + lane*4; +32 each inner iter)
//   v7       = lane*4 (constant, x byte offset)
//   v8       = lane*2 (constant, w byte offset)  [reused from existing helper's v8]
//   v9       = scratch bf16 weight load → bf16-widen → bpermute addr scratch
//   v10      = scratch f32 x load → reduce tmp
//   v11      = scratch bpermute addr (reduce)
//   v12      = scratch bpermute tmp  (reduce)
fn _emit_gemv_cputree_bf16_padded_strided_inline(uint64 n_out, uint64 k, uint64 k_pad,
                                    uint64 wg_active,
                                    uint64 w_sdata_pair, uint64 x_sdata_pair,
                                    uint64 out_sdata_pair,
                                    uint64 w_kofs, uint64 x_kofs, uint64 out_kofs,
                                    uint64 wg_id_sgpr) {
    // ── WG gate (skip if wg_id >= wg_active) — identical to base helper ──
    uint64 gate_cmp_pos = asm_text_len / 4
    asm_u32(0xBF09FF00 | (wg_id_sgpr & 0xFF))
    asm_u32(wg_active)
    asm_s_cbranch_scc1(0)   // patched at end

    // ── Load base pointers ────────────────────────────────────────────────
    asm_s_load_b64_off(w_sdata_pair,   0, w_kofs)
    asm_s_load_b64_off(x_sdata_pair,   0, x_kofs)
    asm_s_load_b64_off(out_sdata_pair, 0, out_kofs)
    asm_s_waitcnt_lgkmcnt_zero()

    uint64 w_lo = w_sdata_pair * 2
    uint64 w_hi = w_lo + 1
    uint64 x_lo = x_sdata_pair * 2
    uint64 x_hi = x_lo + 1
    uint64 out_lo = out_sdata_pair * 2
    uint64 out_hi = out_lo + 1

    // ── Slice 6.7d: per-WG weight base offset ─────────────────────────────
    // s14 = wg_id * (k_pad * 2);  s[w_lo:w_hi] += s14
    _emit_s_mul_u32_pow2_or_lit(14, wg_id_sgpr, k_pad * 2)
    asm_u32(0x80000000 | (w_lo << 16) | (14 << 8) | w_lo)
    asm_u32(0x82000000 | (w_hi << 16) | 0x8000 | w_hi)

    // ── Constant lane offsets (cputree: lane*2 for bf16, lane*4 for f32) ──
    asm_v_lshlrev_b32_imm(7, 2, 0)   // v7 = lane*4 (f32 byte offset for x)
    asm_v_lshlrev_b32_imm(8, 1, 0)   // v8 = lane*2 (bf16 byte offset for w)

    // ── Outer-row loop init ───────────────────────────────────────────────
    asm_s_mov_b32(13, wg_id_sgpr)            // s13 = row = wg_id
    asm_s_mov_b32_inline_imm(12, 0)          // s12 = r_off = 0

    uint64 w_row_step = wg_active * k_pad * 2
    uint64 k_iters = k / 8                   // 8 active lanes per wave
    uint64 rows_per_wg = (n_out + wg_active - 1) / wg_active

    uint64 outer_top = asm_text_len / 4

    // ── Per-row body ──────────────────────────────────────────────────────
    // v2 = acc = 0.0 — set with FULL EXEC so lanes 8..31 keep v2=0 and do
    // not pollute the post-loop XOR-bpermute reduce.
    asm_v_mov_b32_inline_u(2, 0)

    // init weight ptr: v3:v4 = s[w_lo:w_hi] + lane*2 (= v8)
    asm_v_mov_b32_inline_u(4, 0)
    asm_v_add_co_u32_vcc_sv(3, w_lo, 8)
    asm_v_add_co_ci_u32_null_sv_vcc(4, w_hi, 4)

    // init x ptr: v5:v6 = s[x_lo:x_hi] + lane*4 (= v7)
    asm_v_mov_b32_inline_u(6, 0)
    asm_v_add_co_u32_vcc_sv(5, x_lo, 7)
    asm_v_add_co_ci_u32_null_sv_vcc(6, x_hi, 6)

    // ── Narrow EXEC to lanes 0..7 ─────────────────────────────────────────
    // s_mov_b32 exec_lo, 0xFF  (lanes 8..31 keep their previous v2=0 and
    // do not run the K-loop FMAs).
    asm_s_mov_b32_lit32(0x7E, 0x000000FF)

    // ── K-loop counter: s14 = k_iters ─────────────────────────────────────
    asm_s_mov_b32_inline_imm(14, k_iters)

    uint64 loop_idx = asm_text_len / 4
    // global_load_u16 v9, v[3:4], off
    asm_u32(0xDC4A0000); asm_u32(0x097C0003)
    // global_load_b32 v10, v[5:6], off
    asm_u32(0xDC520000); asm_u32(0x0A7C0005)
    asm_s_waitcnt_vmcnt_zero()
    // v_lshlrev_b32 v9, 16, v9  — bf16 → f32 widen
    asm_v_lshlrev_b32_imm(9, 16, 9)
    // v_fmac_f32_e32 v2, v9, v10
    asm_v_fmac_f32_e32_vv(2, 9, 10)
    // v_add_nc_u32 v3, 0x10, v3   (w_ptr += 16 bytes)
    asm_u32(0x4A0606FF); asm_u32(16)
    // v_add_nc_u32 v5, 0x20, v5   (x_ptr += 32 bytes)
    asm_u32(0x4A0A0AFF); asm_u32(32)
    asm_s_sub_u32_imm(14, 14, 1)
    // s_cmp_lg_u32 s14, 0
    asm_u32(0xBF07800E)
    uint64 loop_branch_idx = asm_text_len / 4
    uint64 back_simm = (loop_idx - (loop_branch_idx + 1)) & 0xFFFF
    asm_s_cbranch_scc1(back_simm)

    // ── Restore EXEC to full wave32 for cross-lane reduce ─────────────────
    asm_s_mov_b32_lit32(0x7E, 0xFFFFFFFF)

    // ── CPU-tree 3-level reduce, XOR offsets [4, 1, 2] in that order ──────
    // Per level: v_xor_b32 v11, off, v0 ; v_lshlrev_b32 v11, 2, v11 ;
    //            ds_bpermute_b32 v12, v11, v2 ; waitcnt lgkm(0) ;
    //            v_add_f32_e32 v2, v2, v12
    uint64 add_word = 0x06000000 | (2 << 17) | (12 << 9) | (0x100 | 2)

    // Step 1: offset 4
    _emit_v_xor_b32_e32_imm_v0(11, 4)
    asm_v_lshlrev_b32_imm(11, 2, 11)
    asm_ds_bpermute_b32(12, 11, 2)
    asm_s_waitcnt_lgkmcnt_zero()
    asm_u32(add_word)

    // Step 2: offset 1
    _emit_v_xor_b32_e32_imm_v0(11, 1)
    asm_v_lshlrev_b32_imm(11, 2, 11)
    asm_ds_bpermute_b32(12, 11, 2)
    asm_s_waitcnt_lgkmcnt_zero()
    asm_u32(add_word)

    // Step 3: offset 2
    _emit_v_xor_b32_e32_imm_v0(11, 2)
    asm_v_lshlrev_b32_imm(11, 2, 11)
    asm_ds_bpermute_b32(12, 11, 2)
    asm_s_waitcnt_lgkmcnt_zero()
    asm_u32(add_word)

    // ── Lane-0 gated store of v2 to out[row] ──────────────────────────────
    asm_v_cmp_eq_u32_imm_vgpr(0, 0)            // vcc_lo = (v0 == 0)
    asm_s_and_saveexec_b32_vcc_lo(17)          // s17 = old exec; exec &= vcc_lo
    asm_v_mov_b32_inline_u(1, 0)               // v1 = 0 (vaddr for store)

    // output byte offset = row * 4
    // s_lshl_b32 s14, s13, 2
    asm_u32(0x840E820D)
    // s_add_u32 out_lo, out_lo, s14
    asm_u32(0x80000000 | (out_lo << 16) | (14 << 8) | out_lo)
    // s_addc_u32 out_hi, out_hi, 0
    asm_u32(0x82000000 | (out_hi << 16) | 0x8000 | out_hi)

    // global_store_b32 v1, v2, s[out_lo:out_hi]
    asm_u32(0xDC6A0000)
    asm_u32((out_lo << 16) | (2 << 8) | 1)

    // Restore exec: s_or_b32 exec_lo, exec_lo, s17
    asm_u32(0x8C7E117E)

    // ── Restore out ptr (undo the row*4 offset) ───────────────────────────
    // s14 still holds row*4 here.
    asm_u32(0x80800000 | (out_lo << 16) | (0x0E << 8) | out_lo)
    asm_u32(0x82800000 | (out_hi << 16) | 0x8000 | out_hi)

    // ── Outer loop advance ────────────────────────────────────────────────
    // Advance weight ptr by w_row_step bytes
    asm_s_mov_b32_lit32(14, w_row_step & 0xFFFFFFFF)
    asm_u32(0x80000000 | (w_lo << 16) | (0x0E << 8) | w_lo)
    asm_u32(0x82000000 | (w_hi << 16) | 0x8000 | w_hi)

    // Advance row: s13 += wg_active
    asm_u32(0x800DFF0D)
    asm_u32(wg_active)

    // r_off += 1; if r_off < rows_per_wg loop
    asm_u32(0x800C810C)
    asm_u32(0xBF0AFF0C)
    asm_u32(rows_per_wg & 0xFFFFFFFF)
    uint64 outer_back = (outer_top - (asm_text_len / 4) - 1) & 0xFFFF
    asm_s_cbranch_scc1(outer_back)

    // ── Patch the WG gate skip-branch ─────────────────────────────────────
    uint64 body_dwords = (asm_text_len / 4) - (gate_cmp_pos + 3)
    asm_patch_u32(gate_cmp_pos + 2, 0xBFA20000 | (body_dwords & 0xFFFF))
}

// _emit_gemv_cputree_f32_padded_strided_inline — fp32-weight variant of
// _emit_gemv_cputree_bf16_padded_strided_inline.  Slice 8.3 F3b
// (2026-05-14) — used by phase 3 / phase 13 of the Llama-3B mega-kernel
// when MEGA_WEIGHT_DTYPE == 1.
//
// Identical scaffolding to the bf16 cputree helper (WG gate, kernarg loads,
// slice 6.7d per-WG weight base offset, outer-row loop, exec narrow to 8
// lanes, 3-level [4,1,2] XOR-bpermute reduce, lane-0 store, outer advance,
// gate patch).  Only the inner K-loop math differs:
//   - weight load: global_load_b32 (4B) instead of global_load_u16 (2B)
//   - NO bf16-widen step (no v_lshlrev_b32 v9, 16, v9)
//   - per-lane w_ptr stride = lane*4 bytes (matches f32 act stride),
//     mirrored on v8 (was lane*2 for bf16)
//   - inner-loop w_ptr advance = +32 bytes per iter (8 lanes × 4B f32),
//     was +16 for bf16
//   - per-WG weight base offset uses k_pad*4 bytes (was k_pad*2 for bf16)
//   - outer-row weight advance w_row_step = wg_active * k_pad * 4 (was *2)
//
// Inner-loop byte encodings cloned from
// _emit_gemv_coop_f32_f32_cputree_body (src/format_amdgpu.mlr,
// commit 1279bef) — the standalone fp32 cputree gemv validated at
// K=3072 N=5120 (slice 8.3 F3a).
//
// VGPR usage (identical pressure to bf16 cputree; v8 just stores lane*4
// now so both v7 and v8 carry the same value — kept for code symmetry):
//   v0       = lane id (hardware, r/o)
//   v1       = vaddr=0 for global_store_b32 saddr-form
//   v2       = acc (f32 accumulator)
//   v3:v4    = weight ptr per lane (init: s[w_lo:w_hi]+lane*4; +32 each iter)
//   v5:v6    = x ptr per lane     (init: s[x_lo:x_hi]+lane*4; +32 each iter)
//   v7       = lane*4 (f32 byte offset for x)
//   v8       = lane*4 (f32 byte offset for w — was lane*2 for bf16)
//   v9       = scratch f32 weight load → bpermute addr scratch
//   v10      = scratch f32 x load → reduce tmp
//   v11      = scratch bpermute addr (reduce)
//   v12      = scratch bpermute tmp  (reduce)
fn _emit_gemv_cputree_f32_padded_strided_inline(uint64 n_out, uint64 k, uint64 k_pad,
                                    uint64 wg_active,
                                    uint64 w_sdata_pair, uint64 x_sdata_pair,
                                    uint64 out_sdata_pair,
                                    uint64 w_kofs, uint64 x_kofs, uint64 out_kofs,
                                    uint64 wg_id_sgpr) {
    // ── WG gate (skip if wg_id >= wg_active) — identical to bf16 helper ──
    uint64 gate_cmp_pos = asm_text_len / 4
    asm_u32(0xBF09FF00 | (wg_id_sgpr & 0xFF))
    asm_u32(wg_active)
    asm_s_cbranch_scc1(0)   // patched at end

    // ── Load base pointers ────────────────────────────────────────────────
    asm_s_load_b64_off(w_sdata_pair,   0, w_kofs)
    asm_s_load_b64_off(x_sdata_pair,   0, x_kofs)
    asm_s_load_b64_off(out_sdata_pair, 0, out_kofs)
    asm_s_waitcnt_lgkmcnt_zero()

    uint64 w_lo = w_sdata_pair * 2
    uint64 w_hi = w_lo + 1
    uint64 x_lo = x_sdata_pair * 2
    uint64 x_hi = x_lo + 1
    uint64 out_lo = out_sdata_pair * 2
    uint64 out_hi = out_lo + 1

    // ── Slice 6.7d: per-WG weight base offset ─────────────────────────────
    // s14 = wg_id * (k_pad * 4);  s[w_lo:w_hi] += s14   (f32 row stride)
    _emit_s_mul_u32_pow2_or_lit(14, wg_id_sgpr, k_pad * 4)
    asm_u32(0x80000000 | (w_lo << 16) | (14 << 8) | w_lo)
    asm_u32(0x82000000 | (w_hi << 16) | 0x8000 | w_hi)

    // ── Constant lane offsets (f32: both lane*4) ──────────────────────────
    asm_v_lshlrev_b32_imm(7, 2, 0)   // v7 = lane*4 (f32 byte offset for x)
    asm_v_lshlrev_b32_imm(8, 2, 0)   // v8 = lane*4 (f32 byte offset for w)

    // ── Outer-row loop init ───────────────────────────────────────────────
    asm_s_mov_b32(13, wg_id_sgpr)            // s13 = row = wg_id
    asm_s_mov_b32_inline_imm(12, 0)          // s12 = r_off = 0

    uint64 w_row_step = wg_active * k_pad * 4
    uint64 k_iters = k / 8                   // 8 active lanes per wave
    uint64 rows_per_wg = (n_out + wg_active - 1) / wg_active

    uint64 outer_top = asm_text_len / 4

    // ── Per-row body ──────────────────────────────────────────────────────
    // v2 = acc = 0.0 — set with FULL EXEC so lanes 8..31 keep v2=0.
    asm_v_mov_b32_inline_u(2, 0)

    // init weight ptr: v3:v4 = s[w_lo:w_hi] + lane*4 (= v8)
    asm_v_mov_b32_inline_u(4, 0)
    asm_v_add_co_u32_vcc_sv(3, w_lo, 8)
    asm_v_add_co_ci_u32_null_sv_vcc(4, w_hi, 4)

    // init x ptr: v5:v6 = s[x_lo:x_hi] + lane*4 (= v7)
    asm_v_mov_b32_inline_u(6, 0)
    asm_v_add_co_u32_vcc_sv(5, x_lo, 7)
    asm_v_add_co_ci_u32_null_sv_vcc(6, x_hi, 6)

    // ── Narrow EXEC to lanes 0..7 ─────────────────────────────────────────
    asm_s_mov_b32_lit32(0x7E, 0x000000FF)

    // ── K-loop counter: s14 = k_iters ─────────────────────────────────────
    asm_s_mov_b32_inline_imm(14, k_iters)

    uint64 loop_idx = asm_text_len / 4
    // global_load_b32 v9, v[3:4], off   (f32 weight; was global_load_u16)
    asm_u32(0xDC520000); asm_u32(0x097C0003)
    // global_load_b32 v10, v[5:6], off  (f32 x — unchanged)
    asm_u32(0xDC520000); asm_u32(0x0A7C0005)
    asm_s_waitcnt_vmcnt_zero()
    // NOTE: bf16-widen step removed (no v_lshlrev_b32 v9, 16, v9).
    // v_fmac_f32_e32 v2, v9, v10
    asm_v_fmac_f32_e32_vv(2, 9, 10)
    // v_add_nc_u32 v3, 0x20, v3   (w_ptr += 32 bytes; 8 lanes × f32-4B) — was 16
    asm_u32(0x4A0606FF); asm_u32(32)
    // v_add_nc_u32 v5, 0x20, v5   (x_ptr += 32 bytes; unchanged)
    asm_u32(0x4A0A0AFF); asm_u32(32)
    asm_s_sub_u32_imm(14, 14, 1)
    // s_cmp_lg_u32 s14, 0
    asm_u32(0xBF07800E)
    uint64 loop_branch_idx = asm_text_len / 4
    uint64 back_simm = (loop_idx - (loop_branch_idx + 1)) & 0xFFFF
    asm_s_cbranch_scc1(back_simm)

    // ── Restore EXEC to full wave32 for cross-lane reduce ─────────────────
    asm_s_mov_b32_lit32(0x7E, 0xFFFFFFFF)

    // ── CPU-tree 3-level reduce, XOR offsets [4, 1, 2] in that order ──────
    uint64 add_word = 0x06000000 | (2 << 17) | (12 << 9) | (0x100 | 2)

    // Step 1: offset 4
    _emit_v_xor_b32_e32_imm_v0(11, 4)
    asm_v_lshlrev_b32_imm(11, 2, 11)
    asm_ds_bpermute_b32(12, 11, 2)
    asm_s_waitcnt_lgkmcnt_zero()
    asm_u32(add_word)

    // Step 2: offset 1
    _emit_v_xor_b32_e32_imm_v0(11, 1)
    asm_v_lshlrev_b32_imm(11, 2, 11)
    asm_ds_bpermute_b32(12, 11, 2)
    asm_s_waitcnt_lgkmcnt_zero()
    asm_u32(add_word)

    // Step 3: offset 2
    _emit_v_xor_b32_e32_imm_v0(11, 2)
    asm_v_lshlrev_b32_imm(11, 2, 11)
    asm_ds_bpermute_b32(12, 11, 2)
    asm_s_waitcnt_lgkmcnt_zero()
    asm_u32(add_word)

    // ── Lane-0 gated store of v2 to out[row] ──────────────────────────────
    asm_v_cmp_eq_u32_imm_vgpr(0, 0)            // vcc_lo = (v0 == 0)
    asm_s_and_saveexec_b32_vcc_lo(17)          // s17 = old exec; exec &= vcc_lo
    asm_v_mov_b32_inline_u(1, 0)               // v1 = 0 (vaddr for store)

    // output byte offset = row * 4
    // s_lshl_b32 s14, s13, 2
    asm_u32(0x840E820D)
    // s_add_u32 out_lo, out_lo, s14
    asm_u32(0x80000000 | (out_lo << 16) | (14 << 8) | out_lo)
    // s_addc_u32 out_hi, out_hi, 0
    asm_u32(0x82000000 | (out_hi << 16) | 0x8000 | out_hi)

    // global_store_b32 v1, v2, s[out_lo:out_hi]
    asm_u32(0xDC6A0000)
    asm_u32((out_lo << 16) | (2 << 8) | 1)

    // Restore exec: s_or_b32 exec_lo, exec_lo, s17
    asm_u32(0x8C7E117E)

    // ── Restore out ptr (undo the row*4 offset) ───────────────────────────
    asm_u32(0x80800000 | (out_lo << 16) | (0x0E << 8) | out_lo)
    asm_u32(0x82800000 | (out_hi << 16) | 0x8000 | out_hi)

    // ── Outer loop advance ────────────────────────────────────────────────
    // Advance weight ptr by w_row_step bytes (f32: wg_active * k_pad * 4)
    asm_s_mov_b32_lit32(14, w_row_step & 0xFFFFFFFF)
    asm_u32(0x80000000 | (w_lo << 16) | (0x0E << 8) | w_lo)
    asm_u32(0x82000000 | (w_hi << 16) | 0x8000 | w_hi)

    // Advance row: s13 += wg_active
    asm_u32(0x800DFF0D)
    asm_u32(wg_active)

    // r_off += 1; if r_off < rows_per_wg loop
    asm_u32(0x800C810C)
    asm_u32(0xBF0AFF0C)
    asm_u32(rows_per_wg & 0xFFFFFFFF)
    uint64 outer_back = (outer_top - (asm_text_len / 4) - 1) & 0xFFFF
    asm_s_cbranch_scc1(outer_back)

    // ── Patch the WG gate skip-branch ─────────────────────────────────────
    uint64 body_dwords = (asm_text_len / 4) - (gate_cmp_pos + 3)
    asm_patch_u32(gate_cmp_pos + 2, 0xBFA20000 | (body_dwords & 0xFFFF))
}

// ── Phase 3 m4 inline ISA emitter — gemv-coop-bf16-padded-strided × 4 streams
//
// _emit_gemv_coop_bf16_padded_strided_m4_inline — speck4 phase-3 variant.
// Same single bf16 weight read per row as the base emitter, but accumulates
// FOUR independent dot products (one per stream m=0..3) and stores 4 output
// rows.  Maps the HIP source body:
//
//     for r_off in 0..ROWS_PER_WG:
//         row = wg_id + r_off * WG_PERSIST
//         acc0=acc1=acc2=acc3=0
//         for kp in lane..HIDDEN/2 step WAVE:
//             packed = qkv_w[row*HIDDEN_PAD/2 + kp]
//             w0 = bf16_lo, w1 = bf16_hi
//             accm += w0 * b_x_norm_g_4[m*HIDDEN + 2*kp]
//                   + w1 * b_x_norm_g_4[m*HIDDEN + 2*kp + 1]   (m=0..3)
//         wave-XOR-reduce(acc0/1/2/3)
//         if lane==0:
//             b_qkv_g_4[m*QKV_DIM + row] = accm  (m=0..3)
//
// Stream stride layout (HIP source: `b_x_norm_g_4[m*HIDDEN + k]`,
// `b_qkv_g_4[m*QKV_DIM + row]`):
//   x stream stride  = HIDDEN  *4 = 1024*4 =  4096 bytes  (UNPADDED)
//   out stream stride= QKV_DIM *4 = 4096*4 = 16384 bytes
//
// Implementation choice (slice 4.20.2):
//   - PRECOMPUTED per-stream lane vgpr bases v8/v28/v29/v30 = lane*8 +
//     m*4096 (bytes), computed once outside the outer loop.  Stream-0 is
//     v8 (= lane*8) — same as base emitter — so the existing v[5:6] init
//     pattern is unchanged for stream 0.
//   - Per row: 4 vgpr-pair x ptrs (v[5:6], v[16:17], v[18:19], v[20:21])
//     derived by `v_add_co_u32 vN, vcc_lo, s[x_lo], v_lane_off_m`.
//     Each pair advances by +256 bytes per inner-loop iter (32 floats × 8).
//   - Inner loop: 1 weight load → bf16 unpack → 4 × {x lo+hi load + 2
//     fmacs into acc_m} → advance 5 vgpr pairs (1 weight + 4 x).
//   - Lane-0 store block: ONE exec-gate; 4 sequential stores at output
//     offsets row*4 + m*16384 (computed by adding s14=row*4 once, then
//     adding 16384 between stores via SOP2 lit; restore s_out at end).
//
// SGPR layout (mirrors base; no extra sgpr pairs needed):
//   s[0:1]   = kernarg ptr (untouched)
//   s[2:3]   = qkv_w ptr   (loaded; advances by w_row_step per outer iter)
//   s[4:5]   = b_x_norm_g_4 ptr (loaded once, stream-0 base; never modified)
//   s[6:7]   = b_qkv_g_4 ptr (loaded once, stream-0 base; offset+restored
//                              per row by the 4-store block)
//   s12      = outer loop counter (r_off)
//   s13      = row index (init: wg_id_sgpr; +wg_active each outer iter)
//   s14      = row*4 / w_row_step / outer-loop scratch
//   s17      = saved exec_lo for lane-0 gate
//
// VGPR layout (24 used, all within RSRC1 vgpr_count cap):
//   v0       = lane id (hardware, r/o)
//   v1       = vaddr=0 (for global_store_b32 saddr-form)
//   v2       = acc_0 (stream 0 accumulator)
//   v3:v4    = weight ptr per lane (init: s[2:3]+lane*4; +128 each inner)
//   v5:v6    = x ptr stream 0 per lane (init: s[4:5]+lane*8;       +256)
//   v7       = lane*4
//   v8       = lane*8                      (= stream-0 lane offset)
//   v9       = packed u32 (2 bf16 weights) → reused for wave-reduce addr
//   v10      = bf16-lo as f32 → reused for wave-reduce tmp
//   v11      = x[kp*2]   stream 0
//   v12      = x[kp*2+1] stream 0
//   v13      = acc_1 (stream 1 accumulator)
//   v14      = acc_2 (stream 2 accumulator)
//   v15      = acc_3 (stream 3 accumulator)
//   v16:v17  = x ptr stream 1 per lane (+256)
//   v18:v19  = x ptr stream 2 per lane (+256)
//   v20:v21  = x ptr stream 3 per lane (+256)
//   v22      = x[kp*2]   stream 1
//   v23      = x[kp*2+1] stream 1
//   v24      = x[kp*2]   stream 2
//   v25      = x[kp*2+1] stream 2
//   v26      = x[kp*2]   stream 3
//   v27      = x[kp*2+1] stream 3
//   v28      = lane*8 + 4096   (stream-1 lane offset; constant after init)
//   v29      = lane*8 + 8192   (stream-2 lane offset)
//   v30      = lane*8 + 12288  (stream-3 lane offset)
//
// Parameters: same shape as base emitter (n_out, k, k_pad, wg_active,
// 3 sdata_pairs, 3 kernarg byte offsets, wg_id_sgpr).  The 4-stream
// fan-out is implied (per-stream offsets are constants HIDDEN*4 and
// QKV_DIM*4 derived from k and n_out internally — only valid speck4
// callsite is phase 3 with shape (4096, 1024, 1152, 256)).
fn _emit_gemv_coop_bf16_padded_strided_m4_inline(uint64 n_out, uint64 k, uint64 k_pad,
                                    uint64 wg_active,
                                    uint64 w_sdata_pair, uint64 x_sdata_pair,
                                    uint64 out_sdata_pair,
                                    uint64 w_kofs, uint64 x_kofs, uint64 out_kofs,
                                    uint64 wg_id_sgpr) {
    // Per-stream byte strides (derived from HIP source semantics):
    //   x stream stride  = k    * 4 (unpadded HIDDEN!)
    //   out stream stride= n_out* 4
    uint64 x_stream_stride   = k * 4
    uint64 out_stream_stride = n_out * 4

    // ── WG gate (skip if wg_id >= wg_active) ─────────────────────────────
    uint64 gate_cmp_pos = asm_text_len / 4
    asm_u32(0xBF09FF00 | (wg_id_sgpr & 0xFF))
    asm_u32(wg_active)
    asm_s_cbranch_scc1(0)   // patched at end

    // ── Load base pointers ────────────────────────────────────────────────
    asm_s_load_b64_off(w_sdata_pair,   0, w_kofs)     // qkv_w        → s[w_lo:w_hi]
    asm_s_load_b64_off(x_sdata_pair,   0, x_kofs)     // b_x_norm_g_4 → s[x_lo:x_hi] (stream-0)
    asm_s_load_b64_off(out_sdata_pair, 0, out_kofs)   // b_qkv_g_4    → s[out_lo:out_hi] (stream-0)
    asm_s_waitcnt_lgkmcnt_zero()

    // SGPR pair indices (needed early for the slice 6.7d per-WG weight offset).
    uint64 _w_lo_m4 = w_sdata_pair * 2
    uint64 _w_hi_m4 = _w_lo_m4 + 1

    // ── Slice 6.7d: per-WG weight base offset (bug #3 fix; same as base) ──
    // qkv_w row stride = k_pad bf16 = k_pad*2 bytes; per-WG offset = wg_id*k_pad*2.
    _emit_s_mul_u32_pow2_or_lit(14, wg_id_sgpr, k_pad * 2)
    // s_add_u32 w_lo, w_lo, s14
    asm_u32(0x80000000 | (_w_lo_m4 << 16) | (14 << 8) | _w_lo_m4)
    // s_addc_u32 w_hi, w_hi, 0
    asm_u32(0x82000000 | (_w_hi_m4 << 16) | 0x8000 | _w_hi_m4)

    // ── Constant lane offsets ─────────────────────────────────────────────
    asm_v_lshlrev_b32_imm(7, 2, 0)   // v7 = lane*4
    asm_v_lshlrev_b32_imm(8, 3, 0)   // v8 = lane*8 (stream-0 lane offset)
    asm_v_mov_b32_inline_u(1, 0)     // v1 = 0 (vaddr for store)

    // Precompute per-stream lane offsets v28/v29/v30 = lane*8 + m*x_stream_stride
    // (m = 1, 2, 3).  Used per-row to derive 4 separate vgpr-pair x ptrs.
    // VOP3 v_add_co_u32 vdst, vcc_lo, lit, v8  (sgpr-form with src0=0xFF=lit):
    //   word1 = 0xD7006A00 | vdst
    //   word2 = ((0x100|v8) << 9) | 0xFF = 0x10800 | 0xFF wait
    //   v_src1=v8: src1_enc=0x108; (0x108<<9)|0xFF = 0x21000|0xFF = 0x210FF
    //   word3 = literal (m * x_stream_stride)
    // Verified pattern from base emitter ptr-advance (line 877):
    //   0xD7006A03; 0x000206FF; <128>  =  v_add_co_u32 v3, vcc_lo, 128, v3
    // Here we use v8 as the v_src1 (lane*8 base), vdst = v28/v29/v30.
    // src1 = v8: (0x108 << 9) | 0xFF = 0x210FF
    asm_u32(0xD7006A1C); asm_u32(0x000210FF); asm_u32(x_stream_stride)         // v28 = v8 + 4096
    asm_u32(0xD7006A1D); asm_u32(0x000210FF); asm_u32(2 * x_stream_stride)     // v29 = v8 + 8192
    asm_u32(0xD7006A1E); asm_u32(0x000210FF); asm_u32(3 * x_stream_stride)     // v30 = v8 + 12288

    // ── Outer loop init ───────────────────────────────────────────────────
    asm_s_mov_b32(13, wg_id_sgpr)              // s13 = row = wg_id
    asm_s_mov_b32_inline_imm(12, 0)            // s12 = r_off = 0

    uint64 w_lo = w_sdata_pair * 2
    uint64 w_hi = w_lo + 1
    uint64 x_lo = x_sdata_pair * 2
    uint64 x_hi = x_lo + 1
    uint64 out_lo = out_sdata_pair * 2
    uint64 out_hi = out_lo + 1

    uint64 w_row_step = wg_active * k_pad * 2
    uint64 k_iters = k / 2 / 32
    uint64 rows_per_wg = (n_out + wg_active - 1) / wg_active

    uint64 outer_top = asm_text_len / 4

    // ── Per-row body ──────────────────────────────────────────────────────
    // Reset all 4 accumulators.
    asm_v_mov_b32_inline_u(2,  0)     // acc_0 = 0.0
    asm_v_mov_b32_inline_u(13, 0)     // acc_1 = 0.0
    asm_v_mov_b32_inline_u(14, 0)     // acc_2 = 0.0
    asm_v_mov_b32_inline_u(15, 0)     // acc_3 = 0.0

    // init weight ptr: v3:v4 = s[w_lo:w_hi] + lane*4
    asm_v_mov_b32_inline_u(4, 0)
    asm_v_add_co_u32_vcc_sv(3, w_lo, 7)
    asm_v_add_co_ci_u32_null_sv_vcc(4, w_hi, 4)

    // init x stream-0 ptr: v5:v6 = s[x_lo:x_hi] + v8(lane*8)
    asm_v_mov_b32_inline_u(6, 0)
    asm_v_add_co_u32_vcc_sv(5, x_lo, 8)
    asm_v_add_co_ci_u32_null_sv_vcc(6, x_hi, 6)

    // init x stream-1 ptr: v16:v17 = s[x_lo:x_hi] + v28(lane*8 + 4096)
    asm_v_mov_b32_inline_u(17, 0)
    asm_v_add_co_u32_vcc_sv(16, x_lo, 28)
    asm_v_add_co_ci_u32_null_sv_vcc(17, x_hi, 17)

    // init x stream-2 ptr: v18:v19 = s[x_lo:x_hi] + v29(lane*8 + 8192)
    asm_v_mov_b32_inline_u(19, 0)
    asm_v_add_co_u32_vcc_sv(18, x_lo, 29)
    asm_v_add_co_ci_u32_null_sv_vcc(19, x_hi, 19)

    // init x stream-3 ptr: v20:v21 = s[x_lo:x_hi] + v30(lane*8 + 12288)
    asm_v_mov_b32_inline_u(21, 0)
    asm_v_add_co_u32_vcc_sv(20, x_lo, 30)
    asm_v_add_co_ci_u32_null_sv_vcc(21, x_hi, 21)

    // ── Inner K loop ──────────────────────────────────────────────────────
    asm_s_mov_b32_inline_imm(14, k_iters)
    uint64 inner_top = asm_text_len / 4

    // 1 weight load (shared across 4 streams)
    asm_u32(0xDC520000); asm_u32(0x097C0003)    // global_load_b32 v9, v[3:4], off
    // 4 stream x loads (lo + hi pair per stream)
    asm_u32(0xDC520000); asm_u32(0x0B7C0005)    // global_load_b32 v11, v[5:6], off          (stream 0 lo)
    asm_u32(0xDC520004); asm_u32(0x0C7C0005)    // global_load_b32 v12, v[5:6], off offset:4 (stream 0 hi)
    asm_u32(0xDC520000); asm_u32(0x167C0010)    // global_load_b32 v22, v[16:17], off          (stream 1 lo)
    asm_u32(0xDC520004); asm_u32(0x177C0010)    // global_load_b32 v23, v[16:17], off offset:4 (stream 1 hi)
    asm_u32(0xDC520000); asm_u32(0x187C0012)    // global_load_b32 v24, v[18:19], off          (stream 2 lo)
    asm_u32(0xDC520004); asm_u32(0x197C0012)    // global_load_b32 v25, v[18:19], off offset:4 (stream 2 hi)
    asm_u32(0xDC520000); asm_u32(0x1A7C0014)    // global_load_b32 v26, v[20:21], off          (stream 3 lo)
    asm_u32(0xDC520004); asm_u32(0x1B7C0014)    // global_load_b32 v27, v[20:21], off offset:4 (stream 3 hi)
    asm_s_waitcnt_vmcnt_zero()

    // Unpack packed bf16 → 2 f32 in v10 (lo) + v9 (hi).
    asm_v_lshlrev_b32_imm(10, 16, 9)           // v10 = bf16-lo as f32
    asm_u32(0x361212FF); asm_u32(0xFFFF0000)   // v9  = bf16-hi as f32 (v9 &= 0xFFFF0000)

    // 4 fmacs per stream (acc_m += w0 * x_lo + w1 * x_hi)
    asm_v_fmac_f32_e32_vv(2,  10, 11)          // acc_0 += w0 * x0_lo
    asm_v_fmac_f32_e32_vv(2,  9,  12)          // acc_0 += w1 * x0_hi
    asm_v_fmac_f32_e32_vv(13, 10, 22)          // acc_1 += w0 * x1_lo
    asm_v_fmac_f32_e32_vv(13, 9,  23)          // acc_1 += w1 * x1_hi
    asm_v_fmac_f32_e32_vv(14, 10, 24)          // acc_2 += w0 * x2_lo
    asm_v_fmac_f32_e32_vv(14, 9,  25)          // acc_2 += w1 * x2_hi
    asm_v_fmac_f32_e32_vv(15, 10, 26)          // acc_3 += w0 * x3_lo
    asm_v_fmac_f32_e32_vv(15, 9,  27)          // acc_3 += w1 * x3_hi

    // advance weight ptr +128 bytes (32 lanes × 4 = 128)
    asm_u32(0xD7006A03); asm_u32(0x000206FF); asm_u32(128)
    asm_u32(0xD5207C04); asm_u32(0x01AA0880)
    // advance stream-0 x ptr +256 bytes
    asm_u32(0xD7006A05); asm_u32(0x00020AFF); asm_u32(256)
    asm_u32(0xD5207C06); asm_u32(0x01AA0C80)
    // advance stream-1 x ptr +256 bytes (v[16:17])
    //   v_add_co_u32 v16, vcc_lo, 256, v16:  word1=0xD7006A10, src1=v16=0x110, src0=0xFF(lit)
    //   word2 = (0x110<<9)|0xFF = 0x22000|0xFF = 0x220FF
    asm_u32(0xD7006A10); asm_u32(0x000220FF); asm_u32(256)
    //   v_add_co_ci_u32_e64 v17, null, 0, v17, vcc_lo: word1=0xD5207C11
    //   word2 = (0x6A<<18)|((0x100|17)<<9)|0x80 = 0x01A80000|((0x111)<<9)|0x80
    //         = 0x01A80000|(0x22200)|0x80 = 0x01AA2280
    asm_u32(0xD5207C11); asm_u32(0x01AA2280)
    // advance stream-2 x ptr +256 bytes (v[18:19])
    //   v_add_co_u32 v18, vcc_lo, 256, v18: word1=0xD7006A12, src1=v18=0x112
    //   word2 = (0x112<<9)|0xFF = 0x22400|0xFF = 0x224FF
    asm_u32(0xD7006A12); asm_u32(0x000224FF); asm_u32(256)
    //   v_add_co_ci_u32_e64 v19, null, 0, v19, vcc_lo: word1=0xD5207C13
    //   word2 = (0x6A<<18)|((0x100|19)<<9)|0x80 = 0x01A80000|(0x113<<9)|0x80
    //         = 0x01A80000|0x22600|0x80 = 0x01AA2680
    asm_u32(0xD5207C13); asm_u32(0x01AA2680)
    // advance stream-3 x ptr +256 bytes (v[20:21])
    //   v_add_co_u32 v20, vcc_lo, 256, v20: word1=0xD7006A14, src1=v20=0x114
    //   word2 = (0x114<<9)|0xFF = 0x22800|0xFF = 0x228FF
    asm_u32(0xD7006A14); asm_u32(0x000228FF); asm_u32(256)
    //   v_add_co_ci_u32_e64 v21, null, 0, v21, vcc_lo: word1=0xD5207C15
    //   word2 = (0x6A<<18)|((0x100|21)<<9)|0x80 = 0x01A80000|(0x115<<9)|0x80
    //         = 0x01A80000|0x22A00|0x80 = 0x01AA2A80
    asm_u32(0xD5207C15); asm_u32(0x01AA2A80)

    asm_s_sub_u32_imm(14, 14, 1)
    asm_s_cmp_eq_u32(14, 0x80)
    uint64 inner_back = (0 - ((asm_text_len / 4) - inner_top) - 1) & 0xFFFF
    asm_s_cbranch_scc0(inner_back)

    // ── Wave XOR reduce × 4 (acc_0..acc_3) ────────────────────────────────
    // acc=v2/v13/v14/v15, addr=v9, tmp=v10 (both free after inner loop).
    // Each call clobbers v9/v10 but those are dead after the inner loop.
    _emit_wave_xor_reduce_add_f32_5_levels(2,  9, 10)
    _emit_wave_xor_reduce_add_f32_5_levels(13, 9, 10)
    _emit_wave_xor_reduce_add_f32_5_levels(14, 9, 10)
    _emit_wave_xor_reduce_add_f32_5_levels(15, 9, 10)

    // ── Lane-0 store × 4 ──────────────────────────────────────────────────
    // Save exec → s17, gate to lane 0, then 4 stores at offsets
    //   row*4, row*4+16384, row*4+32768, row*4+49152
    // computed by walking s[out_lo:out_hi] +s14 once for row*4, then
    // adding 16384 between successive stream stores.  After the 4 stores,
    // restore s[out_lo:out_hi] by subtracting the total (s14 + 3*16384).
    asm_v_cmp_eq_u32_imm_vgpr(0, 0)  // vcc_lo = (v0 == 0); exec unchanged
    asm_s_and_saveexec_b32_vcc_lo(17)

    // s14 = row * 4: s_lshl_b32 s14, s13, 2 = 0x840E820D
    asm_u32(0x840E820D)

    // s_add_u32 out_lo, out_lo, s14 (b_qkv_g_4 += row*4 — stream 0 base)
    asm_u32(0x80000000 | (out_lo << 16) | (14 << 8) | out_lo)
    // s_addc_u32 out_hi, out_hi, 0
    asm_u32(0x82000000 | (out_hi << 16) | 0x8000 | out_hi)

    // ── Stream 0 store: out[m=0, row] = acc_0 ─────────────────────────────
    // global_store_b32 v1, v2, s[out_lo:out_hi]
    asm_u32(0xDC6A0000)
    asm_u32((out_lo << 16) | (2 << 8) | 1)

    // ── Stream 1 store: out += 16384 bytes; store v13 ─────────────────────
    // s_add_u32 out_lo, out_lo, lit (lit = out_stream_stride = 16384)
    //   SOP2 op 0, ssrc1=0xFF (lit): word = 0x80000000|(out_lo<<16)|(0xFF<<8)|out_lo
    asm_u32(0x80000000 | (out_lo << 16) | (0xFF << 8) | out_lo)
    asm_u32(out_stream_stride)
    // s_addc_u32 out_hi, out_hi, 0
    asm_u32(0x82000000 | (out_hi << 16) | 0x8000 | out_hi)
    // global_store_b32 v1, v13, s[out_lo:out_hi]
    asm_u32(0xDC6A0000)
    asm_u32((out_lo << 16) | (13 << 8) | 1)

    // ── Stream 2 store: out += 16384 bytes; store v14 ─────────────────────
    asm_u32(0x80000000 | (out_lo << 16) | (0xFF << 8) | out_lo)
    asm_u32(out_stream_stride)
    asm_u32(0x82000000 | (out_hi << 16) | 0x8000 | out_hi)
    asm_u32(0xDC6A0000)
    asm_u32((out_lo << 16) | (14 << 8) | 1)

    // ── Stream 3 store: out += 16384 bytes; store v15 ─────────────────────
    asm_u32(0x80000000 | (out_lo << 16) | (0xFF << 8) | out_lo)
    asm_u32(out_stream_stride)
    asm_u32(0x82000000 | (out_hi << 16) | 0x8000 | out_hi)
    asm_u32(0xDC6A0000)
    asm_u32((out_lo << 16) | (15 << 8) | 1)

    // Restore exec: s_or_b32 exec_lo, exec_lo, s17
    asm_u32(0x8C7E117E)

    // ── Restore b_qkv_g_4 ptr ────────────────────────────────────────────
    // We added s14 (=row*4) once + 3 × out_stream_stride (=49152) total.
    // Subtract row*4 first (using s14), then subtract 3 × out_stream_stride
    // as a single literal (= 3 * n_out * 4 = 49152 for phase 3).
    // s_sub_u32 out_lo, out_lo, s14
    asm_u32(0x80800000 | (out_lo << 16) | (0x0E << 8) | out_lo)
    // s_subb_u32 out_hi, out_hi, 0
    asm_u32(0x82800000 | (out_hi << 16) | 0x8000 | out_hi)
    // s_sub_u32 out_lo, out_lo, lit (lit = 3 * out_stream_stride)
    //   SOP2 op 1, ssrc1=0xFF: word = 0x80800000|(out_lo<<16)|(0xFF<<8)|out_lo
    asm_u32(0x80800000 | (out_lo << 16) | (0xFF << 8) | out_lo)
    asm_u32(3 * out_stream_stride)
    // s_subb_u32 out_hi, out_hi, 0
    asm_u32(0x82800000 | (out_hi << 16) | 0x8000 | out_hi)

    // ── Outer loop advance ────────────────────────────────────────────────
    // Advance weight ptr by w_row_step bytes
    asm_s_mov_b32_lit32(14, w_row_step & 0xFFFFFFFF)
    asm_u32(0x80000000 | (w_lo << 16) | (0x0E << 8) | w_lo)
    asm_u32(0x82000000 | (w_hi << 16) | 0x8000 | w_hi)

    // Advance row: s13 += wg_active
    asm_u32(0x800DFF0D)
    asm_u32(wg_active)

    // Increment r_off and check < rows_per_wg
    asm_u32(0x800C810C)
    asm_u32(0xBF0AFF0C)
    asm_u32(rows_per_wg & 0xFFFFFFFF)
    uint64 outer_back = (outer_top - (asm_text_len / 4) - 1) & 0xFFFF
    asm_s_cbranch_scc1(outer_back)

    // ── Patch the WG gate skip-branch ─────────────────────────────────────
    uint64 body_dwords = (asm_text_len / 4) - (gate_cmp_pos + 3)
    asm_patch_u32(gate_cmp_pos + 2, 0xBFA20000 | (body_dwords & 0xFFFF))
}

// ── Phase 9 inline ISA emitter — gemv-residual-fused ──────────────────────
//
// _emit_phase9_gemv_residual_inline — gemv_coop_bf16_f32, padded-row stride,
// with residual-add at the lane-0 row-store.  Body identical to phase 3
// (_emit_gemv_coop_bf16_padded_strided_inline) except the lane-0 store does
//   out[row] = in_residual[row] + acc
// instead of
//   out[row] = acc.
//
// Caller supplies kernarg byte offsets directly (since phase 9's inputs
// are not the canonical 0x10/0x88/0x90 phase-3 set):
//   w_kofs   = byte offset for the bf16 weight ptr      (e.g. o_w        = 0x18)
//   x_kofs   = byte offset for the f32 input  ptr       (e.g. b_attn_out_g = 0xB0)
//   res_kofs = byte offset for the f32 residual ptr     (e.g. in_residual  = 0x00)
//   out_kofs = byte offset for the f32 output   ptr     (e.g. b_mid_g      = 0xA0)
//
// SGPR context on entry (from prologue):
//   s[0:1]   = kernarg ptr pair
//   s[8:9]   = barrier_counter ptr        (must NOT be clobbered)
//   s[10:11] = max_phase value            (must NOT be clobbered)
//   s15      = wg_id_x ONLY VALID IF NO PRIOR PHASE CLOBBERED IT — phase 5
//              clobbers s15 with the high half of rope_sin (s_load_b64
//              s[14:15], 0x58), so by the time phase 9 runs s15 is garbage.
//              Phase 9 reads the SAVED wg_id_x from s28 (stashed in the
//              kernel prologue: `asm_s_mov_b32(28, 15)`), exactly like
//              phase 7 does.
//   s28      = saved wg_id_x (use this for the row index, NOT s15)
//
// Phase 9 SGPR allocation:
//   s[2:3]   = o_w ptr           (kernarg 0x18; advances by w_row_step per r_off)
//   s[4:5]   = b_attn_out_g ptr  (kernarg 0xB0; never modified)
//   s[6:7]   = b_mid_g ptr       (kernarg 0xA0; offset+restored per row)
//   s[18:19] = in_residual ptr   (kernarg 0x00; offset+restored per row)
//              s[18:19] is sdata_pair=9, free across phases.  Avoids s17
//              (used as exec-save in lane-0 gate).
//   s12      = r_off outer counter (0..ROWS_PER_WG-1)
//   s13      = row index (init: s28; +256 each outer iter)
//   s14      = inner k_iters / row*4 byte offset / w_row_step scratch
//   s17      = saved exec_lo for lane-0 gate (clobbered & restored inside)
//
// VGPR usage (mirrors phase 3 exactly except v9 is reused at lane-0 store
// time as the residual-load destination — safe because v9 is dead after
// the wave-XOR reduce):
//   v0   = lane id (hardware, r/o)
//   v1   = vaddr=0   (for global_load_b32 saddr-form and global_store_b32)
//   v2   = acc       (f32 accumulator; final wave-reduced sum)
//   v3:v4 = weight ptr per lane (init: s[w_lo:w_hi]+lane*4; +128 each inner)
//   v5:v6 = x ptr per lane     (init: s[x_lo:x_hi]+lane*8; +256 each inner)
//   v7   = lane*4 (constant)
//   v8   = lane*8 (constant)
//   v9   = packed u32 (2 bf16 weights) → reused as bpermute addr → reused as
//          v_res in the residual-add-then-store block
//   v10  = bf16-lo f32 / reduce tmp
//   v11  = x[kp*2]
//   v12  = x[kp*2+1]
//
// gfx11 hazard note: the residual load lands in v9, then we do
// `v_add_f32 v2, v2, v9` (VALU) followed by `global_store_b32 ..., v2, ...`
// (VMEM consumer of v2).  Per the gfx11 VALU→VMEM/LDS rule we must insert
// `s_delay_alu instid0(VALU_DEP_1)` between them.
//
// Verified: this function differs from _emit_gemv_coop_bf16_padded_strided_inline only
// in (1) the gate uses s28 not s15, (2) the row-init mov is from s28 not
// s15, (3) the lane-0 store block adds the residual-load + v_add_f32
// + delay_alu before the global_store.  All other inner-loop math
// (bf16-unpack, fmac, ptr-advance, wave-XOR reduce) is identical.
fn _emit_phase9_gemv_residual_inline(uint64 n_out, uint64 k, uint64 k_pad,
                                      uint64 wg_active,
                                      uint64 w_kofs, uint64 x_kofs,
                                      uint64 res_kofs, uint64 out_kofs) {
    // ── WG gate (skip if wg_id >= wg_active) ─────────────────────────────
    // s_cmp_ge_u32 s28, wg_active: SOPC op=0x09, ssrc0=s28=0x1C, ssrc1=lit(0xFF)
    //   word = 0xBF000000|(9<<16)|(0xFF<<8)|0x1C = 0xBF09FF1C  (s28 not s15)
    uint64 gate_cmp_pos = asm_text_len / 4
    asm_u32(0xBF09FF1C)
    asm_u32(wg_active)
    asm_s_cbranch_scc1(0)   // patched at end

    // ── Load base pointers ────────────────────────────────────────────────
    // sdata pairs: 1=s[2:3] (w), 2=s[4:5] (x), 3=s[6:7] (out), 9=s[18:19] (res).
    // Pair 9 chosen to avoid s17 collision (used as exec save in lane-0 gate).
    asm_s_load_b64_off(1, 0, w_kofs)     // o_w           → s[2:3]
    asm_s_load_b64_off(2, 0, x_kofs)     // b_attn_out_g  → s[4:5]
    asm_s_load_b64_off(3, 0, out_kofs)   // b_mid_g       → s[6:7]
    asm_s_load_b64_off(9, 0, res_kofs)   // in_residual   → s[18:19]
    asm_s_waitcnt_lgkmcnt_zero()

    // ── Slice 6.7d: per-WG weight base offset (bug #3 fix; same as phase 3) ──
    // o_w row stride = k_pad bf16 = k_pad*2 bytes.  wg_id is the saved s28.
    //     s14 = s28 * (k_pad * 2)
    //     s[2:3] += s14
    _emit_s_mul_u32_pow2_or_lit(14, 28, k_pad * 2)
    // s_add_u32 s2, s2, s14
    asm_u32(0x80000000 | (2 << 16) | (14 << 8) | 2)
    // s_addc_u32 s3, s3, 0
    asm_u32(0x82000000 | (3 << 16) | 0x8000 | 3)

    // ── Constant lane offsets ─────────────────────────────────────────────
    asm_v_lshlrev_b32_imm(7, 2, 0)   // v7 = lane*4
    asm_v_lshlrev_b32_imm(8, 3, 0)   // v8 = lane*8
    asm_v_mov_b32_inline_u(1, 0)     // v1 = 0 (vaddr for load/store)

    // ── Outer loop init ───────────────────────────────────────────────────
    // s13 = row = wg_id (read from saved s28, NOT s15)
    // s_mov_b32 s13, s28: SOP1 (0x17D<<23)|(0x0D<<16)|0x1C = 0xBE8D001C
    asm_s_mov_b32(13, 28)
    // s12 = r_off = 0
    asm_s_mov_b32_inline_imm(12, 0)

    uint64 w_lo = 2
    uint64 w_hi = 3
    uint64 x_lo = 4
    uint64 x_hi = 5
    uint64 out_lo = 6
    uint64 out_hi = 7
    uint64 res_lo = 18
    uint64 res_hi = 19
    uint64 res_pair = 9          // s[18:19] for global_load_b32 saddr field

    // w_row_step = wg_active * k_pad * 2 bytes
    uint64 w_row_step = wg_active * k_pad * 2
    // k_iters = k / 2 / 32 (for k=2048: 1024/32 = 32)
    uint64 k_iters = k / 2 / 32
    // rows_per_wg = ceil(n_out / wg_active) (for 1024/256 = 4)
    uint64 rows_per_wg = (n_out + wg_active - 1) / wg_active

    uint64 outer_top = asm_text_len / 4

    // ── Per-row body ──────────────────────────────────────────────────────
    // Slice 7.6a (2026-05-17): Phase 9 (residual gemv) RETAINS the single-
    // accumulator slice-7.5 pattern.  Mistral down_proj (k=14336, 28 inner
    // iters per row × 16 rows × 256 WGs) wedges the KFD queue at >=4
    // accumulators in this emitter — Phase 3's identical multi-acc body is
    // fine on the same model, and Llama/Qwen3 don't surface it in either
    // phase.  Root cause not pinpointed; ruled out: bank conflicts, VGPR
    // budget (within rsrc1=56), branch range, VALU→LDS s_delay_alu.  Holding
    // phase-3 multi-acc as the slice-7.6a deliverable; phase-9 follow-up
    // tracked separately.
    asm_v_mov_b32_inline_u(2, 0)   // acc = 0.0

    // init weight ptr: v3:v4 = s[w_lo:w_hi] + lane*4
    asm_v_mov_b32_inline_u(4, 0)
    asm_v_add_co_u32_vcc_sv(3, w_lo, 7)
    asm_v_add_co_ci_u32_null_sv_vcc(4, w_hi, 4)

    // init x ptr: v5:v6 = s[x_lo:x_hi] + lane*8
    asm_v_mov_b32_inline_u(6, 0)
    asm_v_add_co_u32_vcc_sv(5, x_lo, 8)
    asm_v_add_co_ci_u32_null_sv_vcc(6, x_hi, 6)

    // ── Inner K loop (8× unrolled, single-accumulator — slice 7.5 baseline) ──
    uint64 k_iters_unrolled = k_iters / 8
    asm_s_mov_b32_inline_imm(14, k_iters_unrolled)
    uint64 inner_top = asm_text_len / 4

    asm_s_clause(23)
    asm_u32(0xDC520000); asm_u32(0x097C0003)    // global_load_b32 v9,  v[3:4], off              (weight 0)
    asm_u32(0xDC520080); asm_u32(0x0D7C0003)    // global_load_b32 v13, v[3:4], off offset:128   (weight 1)
    asm_u32(0xDC520100); asm_u32(0x117C0003)    // global_load_b32 v17, v[3:4], off offset:256   (weight 2)
    asm_u32(0xDC520180); asm_u32(0x157C0003)    // global_load_b32 v21, v[3:4], off offset:384   (weight 3)
    asm_u32(0xDC520200); asm_u32(0x197C0003)    // global_load_b32 v25, v[3:4], off offset:512   (weight 4)
    asm_u32(0xDC520280); asm_u32(0x1D7C0003)    // global_load_b32 v29, v[3:4], off offset:640   (weight 5)
    asm_u32(0xDC520300); asm_u32(0x217C0003)    // global_load_b32 v33, v[3:4], off offset:768   (weight 6)
    asm_u32(0xDC520380); asm_u32(0x257C0003)    // global_load_b32 v37, v[3:4], off offset:896   (weight 7)
    asm_u32(0xDC520000); asm_u32(0x0B7C0005)    // global_load_b32 v11, v[5:6], off              (x[0])
    asm_u32(0xDC520004); asm_u32(0x0C7C0005)    // global_load_b32 v12, v[5:6], off offset:4     (x[1])
    asm_u32(0xDC520100); asm_u32(0x0F7C0005)    // global_load_b32 v15, v[5:6], off offset:256   (x[2])
    asm_u32(0xDC520104); asm_u32(0x107C0005)    // global_load_b32 v16, v[5:6], off offset:260   (x[3])
    asm_u32(0xDC520200); asm_u32(0x137C0005)    // global_load_b32 v19, v[5:6], off offset:512   (x[4])
    asm_u32(0xDC520204); asm_u32(0x147C0005)    // global_load_b32 v20, v[5:6], off offset:516   (x[5])
    asm_u32(0xDC520300); asm_u32(0x177C0005)    // global_load_b32 v23, v[5:6], off offset:768   (x[6])
    asm_u32(0xDC520304); asm_u32(0x187C0005)    // global_load_b32 v24, v[5:6], off offset:772   (x[7])
    asm_u32(0xDC520400); asm_u32(0x1B7C0005)    // global_load_b32 v27, v[5:6], off offset:1024  (x[8])
    asm_u32(0xDC520404); asm_u32(0x1C7C0005)    // global_load_b32 v28, v[5:6], off offset:1028  (x[9])
    asm_u32(0xDC520500); asm_u32(0x1F7C0005)    // global_load_b32 v31, v[5:6], off offset:1280  (x[10])
    asm_u32(0xDC520504); asm_u32(0x207C0005)    // global_load_b32 v32, v[5:6], off offset:1284  (x[11])
    asm_u32(0xDC520600); asm_u32(0x237C0005)    // global_load_b32 v35, v[5:6], off offset:1536  (x[12])
    asm_u32(0xDC520604); asm_u32(0x247C0005)    // global_load_b32 v36, v[5:6], off offset:1540  (x[13])
    asm_u32(0xDC520700); asm_u32(0x277C0005)    // global_load_b32 v39, v[5:6], off offset:1792  (x[14])
    asm_u32(0xDC520704); asm_u32(0x287C0005)    // global_load_b32 v40, v[5:6], off offset:1796  (x[15])
    asm_s_waitcnt_vmcnt_zero()

    asm_v_lshlrev_b32_imm(10, 16, 9)            // v10 = bf16-lo[0] as f32
    asm_u32(0x361212FF); asm_u32(0xFFFF0000)    // v9  = bf16-hi[0] as f32
    asm_v_lshlrev_b32_imm(14, 16, 13)           // v14 = bf16-lo[1] as f32
    asm_u32(0x361A1AFF); asm_u32(0xFFFF0000)    // v13 = bf16-hi[1] as f32
    asm_v_lshlrev_b32_imm(18, 16, 17)           // v18 = bf16-lo[2] as f32
    asm_u32(0x362222FF); asm_u32(0xFFFF0000)    // v17 = bf16-hi[2] as f32
    asm_v_lshlrev_b32_imm(22, 16, 21)           // v22 = bf16-lo[3] as f32
    asm_u32(0x362A2AFF); asm_u32(0xFFFF0000)    // v21 = bf16-hi[3] as f32
    asm_v_lshlrev_b32_imm(26, 16, 25)           // v26 = bf16-lo[4] as f32
    asm_u32(0x363232FF); asm_u32(0xFFFF0000)    // v25 = bf16-hi[4] as f32
    asm_v_lshlrev_b32_imm(30, 16, 29)           // v30 = bf16-lo[5] as f32
    asm_u32(0x363A3AFF); asm_u32(0xFFFF0000)    // v29 = bf16-hi[5] as f32
    asm_v_lshlrev_b32_imm(34, 16, 33)           // v34 = bf16-lo[6] as f32
    asm_u32(0x364242FF); asm_u32(0xFFFF0000)    // v33 = bf16-hi[6] as f32
    asm_v_lshlrev_b32_imm(38, 16, 37)           // v38 = bf16-lo[7] as f32
    asm_u32(0x364A4AFF); asm_u32(0xFFFF0000)    // v37 = bf16-hi[7] as f32

    asm_v_fmac_f32_e32_vv(2, 10, 11)            // acc += w0_lo * x[0]
    asm_v_fmac_f32_e32_vv(2, 9, 12)             // acc += w0_hi * x[1]
    asm_v_fmac_f32_e32_vv(2, 14, 15)            // acc += w1_lo * x[2]
    asm_v_fmac_f32_e32_vv(2, 13, 16)            // acc += w1_hi * x[3]
    asm_v_fmac_f32_e32_vv(2, 18, 19)            // acc += w2_lo * x[4]
    asm_v_fmac_f32_e32_vv(2, 17, 20)            // acc += w2_hi * x[5]
    asm_v_fmac_f32_e32_vv(2, 22, 23)            // acc += w3_lo * x[6]
    asm_v_fmac_f32_e32_vv(2, 21, 24)            // acc += w3_hi * x[7]
    asm_v_fmac_f32_e32_vv(2, 26, 27)            // acc += w4_lo * x[8]
    asm_v_fmac_f32_e32_vv(2, 25, 28)            // acc += w4_hi * x[9]
    asm_v_fmac_f32_e32_vv(2, 30, 31)            // acc += w5_lo * x[10]
    asm_v_fmac_f32_e32_vv(2, 29, 32)            // acc += w5_hi * x[11]
    asm_v_fmac_f32_e32_vv(2, 34, 35)            // acc += w6_lo * x[12]
    asm_v_fmac_f32_e32_vv(2, 33, 36)            // acc += w6_hi * x[13]
    asm_v_fmac_f32_e32_vv(2, 38, 39)            // acc += w7_lo * x[14]
    asm_v_fmac_f32_e32_vv(2, 37, 40)            // acc += w7_hi * x[15]

    // advance weight ptr +1024 bytes (8 weights × 128B stride)
    asm_u32(0xD7006A03); asm_u32(0x000206FF); asm_u32(1024)
    asm_u32(0xD5207C04); asm_u32(0x01AA0880)
    // advance x ptr +2048 bytes (16 x × 128B stride)
    asm_u32(0xD7006A05); asm_u32(0x00020AFF); asm_u32(2048)
    asm_u32(0xD5207C06); asm_u32(0x01AA0C80)

    asm_s_sub_u32_imm(14, 14, 1)
    asm_s_cmp_eq_u32(14, 0x80)
    uint64 inner_back = (0 - ((asm_text_len / 4) - inner_top) - 1) & 0xFFFF
    asm_s_cbranch_scc0(inner_back)

    // ── Wave XOR reduce ───────────────────────────────────────────────────
    // acc=v2, addr=v9 (free after inner loop), tmp=v10
    _emit_wave_xor_reduce_add_f32_5_levels(2, 9, 10)

    // ── Lane-0 residual-add + store ──────────────────────────────────────
    // Same exec-save pattern as phase 3 (s17 = exec save; v_cmp_eq writes
    // ONLY vcc_lo; s_and_saveexec_b32 s17, vcc_lo gates exec to lane 0).
    asm_v_cmp_eq_u32_imm_vgpr(0, 0)         // vcc_lo = (v0 == 0)
    asm_s_and_saveexec_b32_vcc_lo(17)       // s17 = old exec; exec &= vcc_lo

    // s14 = row * 4  (s_lshl_b32 s14, s13, 2)
    //   word = 0x840E820D (verified, from phase 3)
    asm_u32(0x840E820D)

    // out_ptr += s14   (b_mid_g += row*4)
    //   s_add_u32 s6,s6,s14 = 0x80061406  (out_lo=6, ssrc1=s14=0x0E)
    asm_u32(0x80000000 | (out_lo << 16) | (14 << 8) | out_lo)
    //   s_addc_u32 s7,s7,0
    asm_u32(0x82000000 | (out_hi << 16) | 0x8000 | out_hi)

    // res_ptr += s14   (in_residual += row*4)
    //   s_add_u32 s18,s18,s14
    asm_u32(0x80000000 | (res_lo << 16) | (14 << 8) | res_lo)
    //   s_addc_u32 s19,s19,0
    asm_u32(0x82000000 | (res_hi << 16) | 0x8000 | res_hi)

    // global_load_b32 v9, v1, s[res_lo:res_hi]
    //   word1 = 0xDC520000
    //   word2 = (vdst<<24) | (saddr<<16) | vaddr
    //   saddr is the SGPR INDEX of the low reg (= res_lo = 18 for s[18:19]),
    //   NOT the sdata pair index — encoding bug fixed post-bring-up.
    asm_u32(0xDC520000)
    asm_u32((9 << 24) | ((res_lo & 0x7F) << 16) | 1)

    // wait for residual load to retire
    asm_s_waitcnt_vmcnt_zero()

    // v_add_f32_e32 v2, v2, v9  (acc = res + acc; commutative for f32)
    //   VOP2 op 0x03: (3<<25)|(v2<<17)|(v9<<9)|(0x100|v2)
    //                = 0x06000000|0x00040000|0x00001200|0x102 = 0x06041302
    asm_u32(0x06041302)

    // gfx11 VALU→VMEM hazard: let v_add_f32 settle before global_store
    asm_s_delay_alu(0x01)

    // global_store_b32 v1, v2, s[out_lo:out_hi]
    asm_u32(0xDC6A0000)
    asm_u32(((out_lo & 0x7F) << 16) | (2 << 8) | 1)

    // Restore exec: s_or_b32 exec_lo, exec_lo, s17
    asm_u32(0x8C7E117E)

    // ── Restore in_residual + b_mid_g ptrs (undo row*4 added above) ──────
    // s14 still holds row*4 (only the lane-0 gate modified state, but s14
    // was set BEFORE the saveexec — it's a scalar value shared by all lanes,
    // so it survives the exec-mask change unmodified).
    // s_sub_u32 out_lo, out_lo, s14
    asm_u32(0x80800000 | (out_lo << 16) | (0x0E << 8) | out_lo)
    // s_subb_u32 out_hi, out_hi, 0
    asm_u32(0x82800000 | (out_hi << 16) | 0x8000 | out_hi)
    // s_sub_u32 res_lo, res_lo, s14
    asm_u32(0x80800000 | (res_lo << 16) | (0x0E << 8) | res_lo)
    // s_subb_u32 res_hi, res_hi, 0
    asm_u32(0x82800000 | (res_hi << 16) | 0x8000 | res_hi)

    // ── Outer loop advance ────────────────────────────────────────────────
    // Advance weight ptr by w_row_step bytes
    asm_s_mov_b32_lit32(14, w_row_step & 0xFFFFFFFF)
    asm_u32(0x80000000 | (w_lo << 16) | (0x0E << 8) | w_lo)
    asm_u32(0x82000000 | (w_hi << 16) | 0x8000 | w_hi)

    // Advance row: s13 += wg_active
    asm_u32(0x800DFF0D)
    asm_u32(wg_active)

    // r_off++; check r_off < rows_per_wg
    asm_u32(0x800C810C)               // s_add_u32 s12, s12, 1
    asm_u32(0xBF0AFF0C)               // s_cmp_lt_u32 s12, lit
    asm_u32(rows_per_wg & 0xFFFFFFFF)
    uint64 outer_back = (outer_top - (asm_text_len / 4) - 1) & 0xFFFF
    asm_s_cbranch_scc1(outer_back)

    // ── Patch the WG gate skip-branch ─────────────────────────────────────
    uint64 body_dwords = (asm_text_len / 4) - (gate_cmp_pos + 3)
    asm_patch_u32(gate_cmp_pos + 2, 0xBFA20000 | (body_dwords & 0xFFFF))
}

// ── Slice 7.9 (2026-05-17): cross-WG residual-add helper for split phase 9/17 ──
//
// _emit_residual_add_inline — streamed lane-wise f32 add.
//
//   out[i] = in_a[i] + in_b[i]    for i in 0..n_out
//
// Phase 9 split (Mistral only — gated on MEGA_HIDDEN==4096 in mega_emit_stub_kernel):
//   Step A emits the multi-acc gemv to an intermediate buffer (b_attn_q_g),
//   then a cross-WG barrier, then this helper does the residual-add.
//
// Why split:
//   Slice 7.6a's multi-acc + tree-reduce body wedged the KFD queue when used
//   in _emit_phase9_gemv_residual_inline (Mistral: o_proj K=4096 AND
//   down_proj K=14336 both wedged).  Slice-7.7 F4 evidence (multi-acc on
//   o_proj + single-acc on down_proj still wedged at layer 0) ruled out K as
//   the trigger.  The structural shape `dependent-VALU reduce → VMEM
//   residual-load → add → store` in the lane-0 epilogue is what MES chokes
//   on; phase 3 has the same multi-acc body but ends in `wave-XOR → LDS →
//   plain store` (no residual load) and works fine.  Split breaks the bad
//   pattern: gemv ends in plain store (phase-3 shape), residual-add becomes
//   a separate streamed elementwise op.
//
// Layout — each WG handles exactly 32 elements via 32 lanes (one f32/lane):
//   wg_id  = saved-wg_id from s28 (matches phase 9/11/13/15/17 convention)
//   idx    = wg_id * 32 + lane
//   in_a[idx]  loaded from kernarg byte off a_kofs
//   in_b[idx]  loaded from kernarg byte off b_kofs
//   out[idx]   stored at kernarg byte off out_kofs
//   WG gate skips if wg_id >= ceil(n_out / 32).
//   Per-lane gate skips if idx >= n_out (defensive; Mistral n_out=4096 is
//                                        exact multiple of 32, so no skip).
//
// SGPRs / VGPRs (all dead by the time this fires; no live state to preserve
// beyond s[8:9]/s[10:11]/s28 set up in the prologue):
//   s[2:3]  = in_a   ptr
//   s[4:5]  = in_b   ptr
//   s[6:7]  = out    ptr
//   s14     = wg_id<<5 scratch
//   s17     = saved exec for per-lane gate
//   v0      = lane id (HW, r/o)
//   v2      = idx
//   v3      = byte_off = idx*4
//   v8      = in_a[idx]
//   v9      = in_b[idx]
fn _emit_residual_add_inline(uint64 n_out, uint64 a_kofs,
                              uint64 b_kofs, uint64 out_kofs) {
    // ── WG gate: skip if s28 >= ceil(n_out / 32) ────────────────────────
    // s_cmp_ge_u32 s28, lit (SOPC op 0x09, ssrc1=0xFF=lit32 follows)
    uint64 wg_count = (n_out + 31) / 32
    uint64 wg_gate_pos = asm_text_len / 4
    asm_u32(0xBF09FF1C)            // s_cmp_ge_u32 s28, lit
    asm_u32(wg_count & 0xFFFFFFFF)
    asm_s_cbranch_scc1(0)          // patched at end

    // ── Load base ptrs ──────────────────────────────────────────────────
    asm_s_load_b64_off(1, 0, a_kofs)     // in_a   → s[2:3]
    asm_s_load_b64_off(2, 0, b_kofs)     // in_b   → s[4:5]
    asm_s_load_b64_off(3, 0, out_kofs)   // out    → s[6:7]
    asm_s_waitcnt_lgkmcnt_zero()

    // ── Compute idx = wg_id*32 + lane = (s28<<5) + v0 → v2 ──────────────
    // s_lshl_b32 s14, s28, 5: SOP2 op 0x08
    //   word = (2<<30)|(8<<23)|(0x0E<<16)|(0x85<<8)|0x1C = 0x840E851C
    asm_u32(0x840E851C)
    // v_add_nc_u32_e32 v2, s14, v0: VOP2 op 0x25
    //   word = (0x25<<25)|(2<<17)|(0<<9)|0x0E = 0x4A04000E
    asm_u32(0x4A04000E)
    // v_lshlrev_b32_e32 v3, 2, v2: byte_off = idx*4
    asm_v_lshlrev_b32_imm(3, 2, 2)

    // ── Per-lane gate: skip if idx >= n_out ─────────────────────────────
    // v_cmp_gt_u32_e32 vcc_lo, n_out, v2 → vcc_lo = (n_out > idx) = (idx < n_out)
    //   word1 = (0x3E<<25)|(0x4C<<17)|(2<<9)|0xFF = 0x7C9804FF
    asm_u32(0x7C9804FF)
    asm_u32(n_out & 0xFFFFFFFF)
    // s_and_saveexec_b32 s17, vcc_lo
    asm_s_and_saveexec_b32_vcc_lo(17)
    // s_cbranch_execz .lane_done (patched after body)
    uint64 lane_execz_pos = asm_text_len / 4
    asm_s_cbranch_execz(0)

    asm_s_delay_alu(0x01)          // VALU→VMEM hazard (v3 just written)

    // ── Load in_a[idx] and in_b[idx] ────────────────────────────────────
    // global_load_b32 v8, v3, s[2:3]: word2 = (vdst=8<<24)|(saddr=2<<16)|vaddr=3
    asm_u32(0xDC520000)
    asm_u32(0x08020003)
    // global_load_b32 v9, v3, s[4:5]: word2 = (vdst=9<<24)|(saddr=4<<16)|vaddr=3
    asm_u32(0xDC520000)
    asm_u32(0x09040003)
    asm_s_waitcnt_vmcnt_zero()

    // ── Add: v8 = v8 + v9 ───────────────────────────────────────────────
    // v_add_f32_e32 v8, v8, v9 — VOP2 op 0x03
    //   word = (3<<25)|(v8=8<<17)|(v9=9<<9)|(0x100|v8) = 0x06000000|0x00100000|0x00001200|0x108
    //        = 0x06101308
    asm_u32(0x06101308)

    // ── Store out[idx] = v8 ─────────────────────────────────────────────
    asm_s_delay_alu(0x01)          // gfx11 VALU→VMEM hazard
    // global_store_b32 v3, v8, s[6:7]: word2 = (saddr=6<<16)|(vdata=8<<8)|vaddr=3
    asm_u32(0xDC6A0000)
    asm_u32(0x00060803)
    asm_s_waitcnt_vscnt_zero()     // drain store before exec restore

    // ── .lane_done: patch per-lane skip target + restore exec ──────────
    uint64 lane_done = asm_text_len / 4
    uint64 lane_off = lane_done - lane_execz_pos - 1
    asm_patch_u32(lane_execz_pos, 0xBFA50000 | (lane_off & 0xFFFF))
    // s_or_b32 exec_lo, exec_lo, s17 (restore full exec for the WG)
    asm_u32(0x8C7E117E)

    // ── Patch WG gate skip-branch to here ───────────────────────────────
    uint64 body_dwords = (asm_text_len / 4) - (wg_gate_pos + 3)
    asm_patch_u32(wg_gate_pos + 2, 0xBFA20000 | (body_dwords & 0xFFFF))
}

// ── Phase 9 inline ISA emitter — gemv-residual-fused, CPU-matching reduce ──
//
// _emit_phase9_gemv_residual_cputree_inline — CPU-matching reduction-tree
// variant of _emit_phase9_gemv_residual_inline.  Phase 3 of the Llama-3B
// bit-exact plan (slice 8.2-B, 2026-05-14).
//
// Body equivalent to _emit_phase9_gemv_residual_inline except the inner
// per-row dot product matches the CPU's bf16→f32 gemv reduction tree:
//   - 8 active lanes per wave (exec_lo = 0xFF), stride-8 K partition
//   - Single-FMA v_fmac_f32 per K iter, bf16-widen via lshl 16
//   - 3-level XOR-bpermute reduce in offset order [4, 1, 2]
// The lane-0 residual-load + add + store epilogue is preserved verbatim
// from the base helper (same kernarg-offset layout, same s28 wg_id source,
// same s17 exec save, same v9-as-residual-load destination).
//
// Signature matches _emit_phase9_gemv_residual_inline so the caller (mega-
// kernel phase 9 emit) can swap helpers based on MEGA_HIDDEN.
//
// FMA semantics: this is the cputree GEMV (single-rounding FMA), NOT the
// rmsnorm SSQ (two-rounding mul+add).  CPU uses vfmadd231ps (single
// rounding), GPU uses v_fmac_f32_e32 (single rounding) — they match.
//
// VGPR usage (mirrors _emit_gemv_cputree_bf16_padded_strided_inline):
//   v0       = lane id (hardware, r/o)
//   v1       = vaddr=0 for load/store
//   v2       = acc (f32 accumulator)
//   v3:v4    = weight ptr per lane (init: s[2:3]+lane*2; +16 each inner iter)
//   v5:v6    = x ptr per lane     (init: s[4:5]+lane*4; +32 each inner iter)
//   v7       = lane*4 (constant, x byte offset)
//   v8       = lane*2 (constant, w byte offset)
//   v9       = loaded bf16 weight → bf16-widen → bpermute addr → v_res
//   v10      = loaded f32 x → reduce tmp
//   v11      = scratch bpermute addr (reduce)
//   v12      = scratch bpermute tmp  (reduce)
//
// SGPR layout (identical to base phase 9):
//   s[2:3]   = o_w ptr           (kernarg 0x18; advances by w_row_step per r_off)
//   s[4:5]   = b_attn_out_g ptr  (kernarg 0xB0; never modified)
//   s[6:7]   = b_mid_g ptr       (kernarg 0xA0; offset+restored per row)
//   s[18:19] = in_residual ptr   (kernarg 0x00; offset+restored per row)
//   s12      = r_off outer counter
//   s13      = row index (init: s28; +wg_active each outer iter)
//   s14      = inner k_iters / row*4 byte offset / w_row_step scratch
//   s17      = saved exec_lo for lane-0 gate
fn _emit_phase9_gemv_residual_cputree_inline(uint64 n_out, uint64 k, uint64 k_pad,
                                              uint64 wg_active,
                                              uint64 w_kofs, uint64 x_kofs,
                                              uint64 res_kofs, uint64 out_kofs) {
    // ── WG gate (skip if wg_id (s28) >= wg_active) ───────────────────────
    // s_cmp_ge_u32 s28, wg_active: word = 0xBF09FF1C
    uint64 gate_cmp_pos = asm_text_len / 4
    asm_u32(0xBF09FF1C)
    asm_u32(wg_active)
    asm_s_cbranch_scc1(0)   // patched at end

    // ── Load base pointers ────────────────────────────────────────────────
    // sdata pairs: 1=s[2:3] (w), 2=s[4:5] (x), 3=s[6:7] (out), 9=s[18:19] (res).
    asm_s_load_b64_off(1, 0, w_kofs)     // o_w           → s[2:3]
    asm_s_load_b64_off(2, 0, x_kofs)     // b_attn_out_g  → s[4:5]
    asm_s_load_b64_off(3, 0, out_kofs)   // b_mid_g       → s[6:7]
    asm_s_load_b64_off(9, 0, res_kofs)   // in_residual   → s[18:19]
    asm_s_waitcnt_lgkmcnt_zero()

    // ── Slice 6.7d: per-WG weight base offset (bug #3 fix) ───────────────
    // o_w row stride = k_pad bf16 = k_pad*2 bytes.  wg_id is the saved s28.
    //     s14 = s28 * (k_pad * 2)
    //     s[2:3] += s14
    _emit_s_mul_u32_pow2_or_lit(14, 28, k_pad * 2)
    // s_add_u32 s2, s2, s14
    asm_u32(0x80000000 | (2 << 16) | (14 << 8) | 2)
    // s_addc_u32 s3, s3, 0
    asm_u32(0x82000000 | (3 << 16) | 0x8000 | 3)

    // ── Constant lane offsets (cputree: lane*2 for bf16 w, lane*4 for f32 x) ─
    asm_v_lshlrev_b32_imm(7, 2, 0)   // v7 = lane*4 (f32 byte offset for x)
    asm_v_lshlrev_b32_imm(8, 1, 0)   // v8 = lane*2 (bf16 byte offset for w)
    asm_v_mov_b32_inline_u(1, 0)     // v1 = 0 (vaddr for load/store)

    // ── Outer loop init ───────────────────────────────────────────────────
    asm_s_mov_b32(13, 28)                    // s13 = row = saved wg_id_x (s28)
    asm_s_mov_b32_inline_imm(12, 0)          // s12 = r_off = 0

    uint64 w_lo = 2
    uint64 w_hi = 3
    uint64 x_lo = 4
    uint64 x_hi = 5
    uint64 out_lo = 6
    uint64 out_hi = 7
    uint64 res_lo = 18
    uint64 res_hi = 19

    uint64 w_row_step = wg_active * k_pad * 2
    uint64 k_iters = k / 8                   // 8 active lanes per wave
    uint64 rows_per_wg = (n_out + wg_active - 1) / wg_active

    uint64 outer_top = asm_text_len / 4

    // ── Per-row body ──────────────────────────────────────────────────────
    // v2 = acc = 0.0 — set with FULL EXEC so lanes 8..31 keep v2=0 and do
    // not pollute the post-loop XOR-bpermute reduce.
    asm_v_mov_b32_inline_u(2, 0)

    // init weight ptr: v3:v4 = s[w_lo:w_hi] + lane*2 (= v8)
    asm_v_mov_b32_inline_u(4, 0)
    asm_v_add_co_u32_vcc_sv(3, w_lo, 8)
    asm_v_add_co_ci_u32_null_sv_vcc(4, w_hi, 4)

    // init x ptr: v5:v6 = s[x_lo:x_hi] + lane*4 (= v7)
    asm_v_mov_b32_inline_u(6, 0)
    asm_v_add_co_u32_vcc_sv(5, x_lo, 7)
    asm_v_add_co_ci_u32_null_sv_vcc(6, x_hi, 6)

    // ── Narrow EXEC to lanes 0..7 ─────────────────────────────────────────
    asm_s_mov_b32_lit32(0x7E, 0x000000FF)

    // ── K-loop counter: s14 = k_iters ─────────────────────────────────────
    asm_s_mov_b32_inline_imm(14, k_iters)

    uint64 loop_idx = asm_text_len / 4
    // global_load_u16 v9, v[3:4], off
    asm_u32(0xDC4A0000); asm_u32(0x097C0003)
    // global_load_b32 v10, v[5:6], off
    asm_u32(0xDC520000); asm_u32(0x0A7C0005)
    asm_s_waitcnt_vmcnt_zero()
    // v_lshlrev_b32 v9, 16, v9 — bf16 → f32 widen
    asm_v_lshlrev_b32_imm(9, 16, 9)
    // v_fmac_f32_e32 v2, v9, v10  (single-rounding FMA — matches CPU vfmadd231ps)
    asm_v_fmac_f32_e32_vv(2, 9, 10)
    // v_add_nc_u32 v3, 0x10, v3   (w_ptr += 16 bytes; 8 lanes × bf16-2B)
    asm_u32(0x4A0606FF); asm_u32(16)
    // v_add_nc_u32 v5, 0x20, v5   (x_ptr += 32 bytes; 8 lanes × f32-4B)
    asm_u32(0x4A0A0AFF); asm_u32(32)
    asm_s_sub_u32_imm(14, 14, 1)
    // s_cmp_lg_u32 s14, 0
    asm_u32(0xBF07800E)
    uint64 loop_branch_idx = asm_text_len / 4
    uint64 back_simm = (loop_idx - (loop_branch_idx + 1)) & 0xFFFF
    asm_s_cbranch_scc1(back_simm)

    // ── Restore EXEC to full wave32 for cross-lane reduce ─────────────────
    asm_s_mov_b32_lit32(0x7E, 0xFFFFFFFF)

    // ── CPU-tree 3-level reduce, XOR offsets [4, 1, 2] in that order ──────
    uint64 add_word = 0x06000000 | (2 << 17) | (12 << 9) | (0x100 | 2)

    // Step 1: offset 4
    _emit_v_xor_b32_e32_imm_v0(11, 4)
    asm_v_lshlrev_b32_imm(11, 2, 11)
    asm_ds_bpermute_b32(12, 11, 2)
    asm_s_waitcnt_lgkmcnt_zero()
    asm_u32(add_word)

    // Step 2: offset 1
    _emit_v_xor_b32_e32_imm_v0(11, 1)
    asm_v_lshlrev_b32_imm(11, 2, 11)
    asm_ds_bpermute_b32(12, 11, 2)
    asm_s_waitcnt_lgkmcnt_zero()
    asm_u32(add_word)

    // Step 3: offset 2
    _emit_v_xor_b32_e32_imm_v0(11, 2)
    asm_v_lshlrev_b32_imm(11, 2, 11)
    asm_ds_bpermute_b32(12, 11, 2)
    asm_s_waitcnt_lgkmcnt_zero()
    asm_u32(add_word)

    // ── Lane-0 residual-add + store ──────────────────────────────────────
    // Same exec-save pattern as the base phase 9 helper.
    asm_v_cmp_eq_u32_imm_vgpr(0, 0)         // vcc_lo = (v0 == 0)
    asm_s_and_saveexec_b32_vcc_lo(17)       // s17 = old exec; exec &= vcc_lo

    // s14 = row * 4  (s_lshl_b32 s14, s13, 2)
    asm_u32(0x840E820D)

    // out_ptr += s14   (b_mid_g += row*4)
    asm_u32(0x80000000 | (out_lo << 16) | (14 << 8) | out_lo)
    asm_u32(0x82000000 | (out_hi << 16) | 0x8000 | out_hi)

    // res_ptr += s14   (in_residual += row*4)
    asm_u32(0x80000000 | (res_lo << 16) | (14 << 8) | res_lo)
    asm_u32(0x82000000 | (res_hi << 16) | 0x8000 | res_hi)

    // global_load_b32 v9, v1, s[res_lo:res_hi]
    //   vdst=v9, saddr=res_lo=18, vaddr=v1
    asm_u32(0xDC520000)
    asm_u32((9 << 24) | ((res_lo & 0x7F) << 16) | 1)

    // wait for residual load to retire
    asm_s_waitcnt_vmcnt_zero()

    // v_add_f32_e32 v2, v2, v9
    //   VOP2 op 0x03: (3<<25)|(v2<<17)|(v9<<9)|(0x100|v2) = 0x06041302
    asm_u32(0x06041302)

    // gfx11 VALU→VMEM hazard: let v_add_f32 settle before global_store
    asm_s_delay_alu(0x01)

    // global_store_b32 v1, v2, s[out_lo:out_hi]
    asm_u32(0xDC6A0000)
    asm_u32(((out_lo & 0x7F) << 16) | (2 << 8) | 1)

    // Restore exec: s_or_b32 exec_lo, exec_lo, s17
    asm_u32(0x8C7E117E)

    // ── Restore in_residual + b_mid_g ptrs (undo row*4 added above) ──────
    // s14 still holds row*4 (scalar; survived the exec-mask narrow above).
    asm_u32(0x80800000 | (out_lo << 16) | (0x0E << 8) | out_lo)
    asm_u32(0x82800000 | (out_hi << 16) | 0x8000 | out_hi)
    asm_u32(0x80800000 | (res_lo << 16) | (0x0E << 8) | res_lo)
    asm_u32(0x82800000 | (res_hi << 16) | 0x8000 | res_hi)

    // ── Outer loop advance ────────────────────────────────────────────────
    // Advance weight ptr by w_row_step bytes
    asm_s_mov_b32_lit32(14, w_row_step & 0xFFFFFFFF)
    asm_u32(0x80000000 | (w_lo << 16) | (0x0E << 8) | w_lo)
    asm_u32(0x82000000 | (w_hi << 16) | 0x8000 | w_hi)

    // Advance row: s13 += wg_active
    asm_u32(0x800DFF0D)
    asm_u32(wg_active)

    // r_off++; check r_off < rows_per_wg
    asm_u32(0x800C810C)               // s_add_u32 s12, s12, 1
    asm_u32(0xBF0AFF0C)               // s_cmp_lt_u32 s12, lit
    asm_u32(rows_per_wg & 0xFFFFFFFF)
    uint64 outer_back = (outer_top - (asm_text_len / 4) - 1) & 0xFFFF
    asm_s_cbranch_scc1(outer_back)

    // ── Patch the WG gate skip-branch ─────────────────────────────────────
    uint64 body_dwords = (asm_text_len / 4) - (gate_cmp_pos + 3)
    asm_patch_u32(gate_cmp_pos + 2, 0xBFA20000 | (body_dwords & 0xFFFF))
}

// _emit_phase9_gemv_residual_cputree_f32_inline — fp32-weight variant of
// _emit_phase9_gemv_residual_cputree_inline.  Slice 8.3 F3b (2026-05-14) —
// used by Llama-3B mega-kernel phase 9 when MEGA_WEIGHT_DTYPE == 1.
//
// Body identical to the bf16 cputree phase-9 helper EXCEPT the inner K-loop
// loads f32 weights (`global_load_b32`, no widen, +32 byte advance) and the
// per-WG / per-row weight strides are 4× k_pad instead of 2× k_pad.
// Residual-load + add + store epilogue is unchanged (still reads f32
// b_attn_out_g / writes f32 b_mid_g / adds f32 in_residual).
//
// SGPR layout, kernarg byte offsets, s28-saved wg_id pattern, s17 exec
// save, sdata pair 9 (= s[18:19]) for residual, and v9-as-residual-load
// destination are all preserved verbatim from the bf16 cputree variant.
fn _emit_phase9_gemv_residual_cputree_f32_inline(uint64 n_out, uint64 k, uint64 k_pad,
                                                  uint64 wg_active,
                                                  uint64 w_kofs, uint64 x_kofs,
                                                  uint64 res_kofs, uint64 out_kofs) {
    // ── WG gate (skip if wg_id (s28) >= wg_active) ───────────────────────
    uint64 gate_cmp_pos = asm_text_len / 4
    asm_u32(0xBF09FF1C)
    asm_u32(wg_active)
    asm_s_cbranch_scc1(0)   // patched at end

    // ── Load base pointers ────────────────────────────────────────────────
    asm_s_load_b64_off(1, 0, w_kofs)     // o_w           → s[2:3]
    asm_s_load_b64_off(2, 0, x_kofs)     // b_attn_out_g  → s[4:5]
    asm_s_load_b64_off(3, 0, out_kofs)   // b_mid_g       → s[6:7]
    asm_s_load_b64_off(9, 0, res_kofs)   // in_residual   → s[18:19]
    asm_s_waitcnt_lgkmcnt_zero()

    // ── Slice 6.7d: per-WG weight base offset (f32: k_pad*4 bytes) ───────
    //     s14 = s28 * (k_pad * 4)
    //     s[2:3] += s14
    _emit_s_mul_u32_pow2_or_lit(14, 28, k_pad * 4)
    // s_add_u32 s2, s2, s14
    asm_u32(0x80000000 | (2 << 16) | (14 << 8) | 2)
    // s_addc_u32 s3, s3, 0
    asm_u32(0x82000000 | (3 << 16) | 0x8000 | 3)

    // ── Constant lane offsets (f32: both lane*4) ──────────────────────────
    asm_v_lshlrev_b32_imm(7, 2, 0)   // v7 = lane*4 (f32 byte offset for x)
    asm_v_lshlrev_b32_imm(8, 2, 0)   // v8 = lane*4 (f32 byte offset for w)
    asm_v_mov_b32_inline_u(1, 0)     // v1 = 0 (vaddr for load/store)

    // ── Outer loop init ───────────────────────────────────────────────────
    asm_s_mov_b32(13, 28)                    // s13 = row = saved wg_id_x (s28)
    asm_s_mov_b32_inline_imm(12, 0)          // s12 = r_off = 0

    uint64 w_lo = 2
    uint64 w_hi = 3
    uint64 x_lo = 4
    uint64 x_hi = 5
    uint64 out_lo = 6
    uint64 out_hi = 7
    uint64 res_lo = 18
    uint64 res_hi = 19

    uint64 w_row_step = wg_active * k_pad * 4
    uint64 k_iters = k / 8                   // 8 active lanes per wave
    uint64 rows_per_wg = (n_out + wg_active - 1) / wg_active

    uint64 outer_top = asm_text_len / 4

    // ── Per-row body ──────────────────────────────────────────────────────
    asm_v_mov_b32_inline_u(2, 0)

    // init weight ptr: v3:v4 = s[w_lo:w_hi] + lane*4 (= v8)
    asm_v_mov_b32_inline_u(4, 0)
    asm_v_add_co_u32_vcc_sv(3, w_lo, 8)
    asm_v_add_co_ci_u32_null_sv_vcc(4, w_hi, 4)

    // init x ptr: v5:v6 = s[x_lo:x_hi] + lane*4 (= v7)
    asm_v_mov_b32_inline_u(6, 0)
    asm_v_add_co_u32_vcc_sv(5, x_lo, 7)
    asm_v_add_co_ci_u32_null_sv_vcc(6, x_hi, 6)

    // ── Narrow EXEC to lanes 0..7 ─────────────────────────────────────────
    asm_s_mov_b32_lit32(0x7E, 0x000000FF)

    // ── K-loop counter: s14 = k_iters ─────────────────────────────────────
    asm_s_mov_b32_inline_imm(14, k_iters)

    uint64 loop_idx = asm_text_len / 4
    // global_load_b32 v9, v[3:4], off   (f32 weight)
    asm_u32(0xDC520000); asm_u32(0x097C0003)
    // global_load_b32 v10, v[5:6], off  (f32 x)
    asm_u32(0xDC520000); asm_u32(0x0A7C0005)
    asm_s_waitcnt_vmcnt_zero()
    // NOTE: bf16-widen step removed.
    // v_fmac_f32_e32 v2, v9, v10
    asm_v_fmac_f32_e32_vv(2, 9, 10)
    // v_add_nc_u32 v3, 0x20, v3   (w_ptr += 32 bytes; 8 lanes × f32-4B)
    asm_u32(0x4A0606FF); asm_u32(32)
    // v_add_nc_u32 v5, 0x20, v5   (x_ptr += 32 bytes; unchanged)
    asm_u32(0x4A0A0AFF); asm_u32(32)
    asm_s_sub_u32_imm(14, 14, 1)
    // s_cmp_lg_u32 s14, 0
    asm_u32(0xBF07800E)
    uint64 loop_branch_idx = asm_text_len / 4
    uint64 back_simm = (loop_idx - (loop_branch_idx + 1)) & 0xFFFF
    asm_s_cbranch_scc1(back_simm)

    // ── Restore EXEC to full wave32 for cross-lane reduce ─────────────────
    asm_s_mov_b32_lit32(0x7E, 0xFFFFFFFF)

    // ── CPU-tree 3-level reduce, XOR offsets [4, 1, 2] in that order ──────
    uint64 add_word = 0x06000000 | (2 << 17) | (12 << 9) | (0x100 | 2)

    // Step 1: offset 4
    _emit_v_xor_b32_e32_imm_v0(11, 4)
    asm_v_lshlrev_b32_imm(11, 2, 11)
    asm_ds_bpermute_b32(12, 11, 2)
    asm_s_waitcnt_lgkmcnt_zero()
    asm_u32(add_word)

    // Step 2: offset 1
    _emit_v_xor_b32_e32_imm_v0(11, 1)
    asm_v_lshlrev_b32_imm(11, 2, 11)
    asm_ds_bpermute_b32(12, 11, 2)
    asm_s_waitcnt_lgkmcnt_zero()
    asm_u32(add_word)

    // Step 3: offset 2
    _emit_v_xor_b32_e32_imm_v0(11, 2)
    asm_v_lshlrev_b32_imm(11, 2, 11)
    asm_ds_bpermute_b32(12, 11, 2)
    asm_s_waitcnt_lgkmcnt_zero()
    asm_u32(add_word)

    // ── Lane-0 residual-add + store ──────────────────────────────────────
    asm_v_cmp_eq_u32_imm_vgpr(0, 0)         // vcc_lo = (v0 == 0)
    asm_s_and_saveexec_b32_vcc_lo(17)       // s17 = old exec; exec &= vcc_lo

    // s14 = row * 4
    asm_u32(0x840E820D)

    // out_ptr += s14   (b_mid_g += row*4)
    asm_u32(0x80000000 | (out_lo << 16) | (14 << 8) | out_lo)
    asm_u32(0x82000000 | (out_hi << 16) | 0x8000 | out_hi)

    // res_ptr += s14   (in_residual += row*4)
    asm_u32(0x80000000 | (res_lo << 16) | (14 << 8) | res_lo)
    asm_u32(0x82000000 | (res_hi << 16) | 0x8000 | res_hi)

    // global_load_b32 v9, v1, s[res_lo:res_hi]
    asm_u32(0xDC520000)
    asm_u32((9 << 24) | ((res_lo & 0x7F) << 16) | 1)

    // wait for residual load to retire
    asm_s_waitcnt_vmcnt_zero()

    // v_add_f32_e32 v2, v2, v9
    asm_u32(0x06041302)

    // gfx11 VALU→VMEM hazard: let v_add_f32 settle before global_store
    asm_s_delay_alu(0x01)

    // global_store_b32 v1, v2, s[out_lo:out_hi]
    asm_u32(0xDC6A0000)
    asm_u32(((out_lo & 0x7F) << 16) | (2 << 8) | 1)

    // Restore exec: s_or_b32 exec_lo, exec_lo, s17
    asm_u32(0x8C7E117E)

    // ── Restore in_residual + b_mid_g ptrs (undo row*4 added above) ──────
    asm_u32(0x80800000 | (out_lo << 16) | (0x0E << 8) | out_lo)
    asm_u32(0x82800000 | (out_hi << 16) | 0x8000 | out_hi)
    asm_u32(0x80800000 | (res_lo << 16) | (0x0E << 8) | res_lo)
    asm_u32(0x82800000 | (res_hi << 16) | 0x8000 | res_hi)

    // ── Outer loop advance ────────────────────────────────────────────────
    // Advance weight ptr by w_row_step bytes (f32: wg_active * k_pad * 4)
    asm_s_mov_b32_lit32(14, w_row_step & 0xFFFFFFFF)
    asm_u32(0x80000000 | (w_lo << 16) | (0x0E << 8) | w_lo)
    asm_u32(0x82000000 | (w_hi << 16) | 0x8000 | w_hi)

    // Advance row: s13 += wg_active
    asm_u32(0x800DFF0D)
    asm_u32(wg_active)

    // r_off++; check r_off < rows_per_wg
    asm_u32(0x800C810C)               // s_add_u32 s12, s12, 1
    asm_u32(0xBF0AFF0C)               // s_cmp_lt_u32 s12, lit
    asm_u32(rows_per_wg & 0xFFFFFFFF)
    uint64 outer_back = (outer_top - (asm_text_len / 4) - 1) & 0xFFFF
    asm_s_cbranch_scc1(outer_back)

    // ── Patch the WG gate skip-branch ─────────────────────────────────────
    uint64 body_dwords = (asm_text_len / 4) - (gate_cmp_pos + 3)
    asm_patch_u32(gate_cmp_pos + 2, 0xBFA20000 | (body_dwords & 0xFFFF))
}

// ── Phase 9 m4 inline ISA emitter — gemv-residual-fused, 4 streams ────────
//
// _emit_phase9_gemv_residual_m4_inline — speck4 phase-9 variant.  Same single
// bf16 weight read per row as the base emitter (_emit_phase9_gemv_residual_inline),
// but accumulates FOUR independent dot products (one per stream m=0..3) and
// stores 4 output rows, each with its own residual-add.
//
// Maps the HIP source body:
//
//     for r_off in 0..ROWS_PER_WG:
//         row = wg_id + r_off * WG_PERSIST
//         acc0=acc1=acc2=acc3=0
//         for kp in lane..Q_DIM/2 step WAVE:
//             packed = o_w[row*Q_DIM_PAD/2 + kp]
//             w0 = bf16_lo, w1 = bf16_hi
//             accm += w0 * b_attn_out_g_4[m*Q_DIM + 2*kp]
//                   + w1 * b_attn_out_g_4[m*Q_DIM + 2*kp + 1]   (m=0..3)
//         wave-XOR-reduce(acc0/1/2/3)
//         if lane==0:
//             b_mid_g_4[m*HIDDEN + row] =
//                 in_residual_4[m*HIDDEN + row] + accm           (m=0..3)
//
// Stream stride layout (slice 4.20.7: now caller-supplied via 3 explicit
// parameters — phase 9 and phase 17 both reuse this emitter but disagree
// on the x-stream stride):
//   phase 9 (oproj):  x=k*4=8192,    res=n_out*4=4096, out=n_out*4=4096
//   phase 17 (down):  x=2*FF*4=24576 (gu_scratch_4 row stride is 2*FF
//                     even though only first FF elements are read),
//                     res=n_out*4=4096, out=n_out*4=4096
//
// SGPR layout (matches base phase 9 + reuses sdata pair 9 = s[18:19] for res):
//   s[0:1]   = kernarg ptr (untouched)
//   s[2:3]   = o_w ptr     (advances by w_row_step per outer iter)
//   s[4:5]   = b_attn_out_g_4 ptr (loaded once, stream-0 base; never modified)
//   s[6:7]   = b_mid_g_4 ptr      (offset+restored per row by the 4-store block)
//   s[18:19] = in_residual_4 ptr  (offset+restored per row; sdata pair 9)
//   s12      = outer loop counter (r_off)
//   s13      = row index (init: s28=saved wg_id_x; +wg_active each outer iter)
//   s14      = row*4 / w_row_step / outer-loop scratch
//   s17      = saved exec_lo for lane-0 gate
//   s28      = saved wg_id_x (read here, NOT s15 — phase 5 clobbered s15)
//
// VGPR layout (mirrors phase-3 m4 exactly; v9 reused as residual-load dest
// like base phase 9):
//   v0       = lane id (hardware, r/o)
//   v1       = vaddr=0 (for global_store/load saddr-form)
//   v2       = acc_0 (stream 0 accumulator)
//   v3:v4    = weight ptr per lane (init: s[2:3]+lane*4; +128 each inner)
//   v5:v6    = x ptr stream 0 per lane (init: s[4:5]+lane*8;       +256)
//   v7       = lane*4
//   v8       = lane*8                      (= stream-0 lane offset)
//   v9       = packed u32 (2 bf16 weights) → wave-reduce addr → residual load
//   v10      = bf16-lo as f32 → wave-reduce tmp
//   v11      = x[kp*2]   stream 0
//   v12      = x[kp*2+1] stream 0
//   v13      = acc_1 (stream 1 accumulator)
//   v14      = acc_2 (stream 2 accumulator)
//   v15      = acc_3 (stream 3 accumulator)
//   v16:v17  = x ptr stream 1 per lane (+256)
//   v18:v19  = x ptr stream 2 per lane (+256)
//   v20:v21  = x ptr stream 3 per lane (+256)
//   v22:v23  = x lo/hi stream 1
//   v24:v25  = x lo/hi stream 2
//   v26:v27  = x lo/hi stream 3
//   v28      = lane*8 + 8192   (stream-1 lane offset; constant after init)
//   v29      = lane*8 + 16384  (stream-2 lane offset)
//   v30      = lane*8 + 24576  (stream-3 lane offset)
//
// gfx11 hazard note: each residual-add is a VALU op feeding a VMEM store;
// the existing base-phase-9 s_delay_alu pattern is replicated per stream.
fn _emit_phase9_gemv_residual_m4_inline(uint64 n_out, uint64 k, uint64 k_pad,
                                         uint64 wg_active,
                                         uint64 w_kofs, uint64 x_kofs,
                                         uint64 res_kofs, uint64 out_kofs,
                                         uint64 x_stream_stride_bytes,
                                         uint64 res_stream_stride_bytes,
                                         uint64 out_stream_stride_bytes) {
    // Per-stream byte strides (slice 4.20.7: caller-supplied — phase 9 uses
    // k*4 / n_out*4 / n_out*4; phase 17 uses 2*FF*4 (24576) / n_out*4 / n_out*4
    // because gu_scratch_4 rows are 2*FF wide even though down_w only reads
    // the first FF elements per row).
    uint64 x_stream_stride   = x_stream_stride_bytes
    uint64 res_stream_stride = res_stream_stride_bytes
    uint64 out_stream_stride = out_stream_stride_bytes

    // ── WG gate (skip if wg_id >= wg_active) — read from s28, NOT s15 ────
    // s_cmp_ge_u32 s28, wg_active: word = 0xBF09FF1C
    uint64 gate_cmp_pos = asm_text_len / 4
    asm_u32(0xBF09FF1C)
    asm_u32(wg_active)
    asm_s_cbranch_scc1(0)   // patched at end

    // ── Load base pointers ────────────────────────────────────────────────
    // sdata pairs: 1=s[2:3] (w), 2=s[4:5] (x), 3=s[6:7] (out), 9=s[18:19] (res).
    asm_s_load_b64_off(1, 0, w_kofs)     // o_w           → s[2:3]
    asm_s_load_b64_off(2, 0, x_kofs)     // b_attn_out_g_4→ s[4:5] (stream-0)
    asm_s_load_b64_off(3, 0, out_kofs)   // b_mid_g_4     → s[6:7] (stream-0)
    asm_s_load_b64_off(9, 0, res_kofs)   // in_residual_4 → s[18:19] (stream-0)
    asm_s_waitcnt_lgkmcnt_zero()

    // ── Slice 6.7d: per-WG weight base offset (bug #3 fix; speck4 sibling) ──
    // Same shape as the base _emit_phase9_gemv_residual_inline fix: the m4
    // variant shares the same w_kofs / k_pad weight layout and the same
    // saved-wg_id register (s28).  Required so b_qkv_g/b_mid_g_4 contain
    // distinct dot products per row (not the wg-0 broadcast pattern that
    // surfaced as Llama bug #3 on the M=1 path).
    _emit_s_mul_u32_pow2_or_lit(14, 28, k_pad * 2)
    // s_add_u32 s2, s2, s14
    asm_u32(0x80000000 | (2 << 16) | (14 << 8) | 2)
    // s_addc_u32 s3, s3, 0
    asm_u32(0x82000000 | (3 << 16) | 0x8000 | 3)

    // ── Constant lane offsets ─────────────────────────────────────────────
    asm_v_lshlrev_b32_imm(7, 2, 0)   // v7 = lane*4
    asm_v_lshlrev_b32_imm(8, 3, 0)   // v8 = lane*8 (stream-0 lane offset)
    asm_v_mov_b32_inline_u(1, 0)     // v1 = 0 (vaddr for store/load)

    // Precompute per-stream lane offsets v28/v29/v30 = lane*8 + m*x_stream_stride
    // (m = 1, 2, 3).  src1=v8 (lane*8) → (0x108<<9)|0xFF = 0x210FF.
    asm_u32(0xD7006A1C); asm_u32(0x000210FF); asm_u32(x_stream_stride)         // v28 = v8 + 8192
    asm_u32(0xD7006A1D); asm_u32(0x000210FF); asm_u32(2 * x_stream_stride)     // v29 = v8 + 16384
    asm_u32(0xD7006A1E); asm_u32(0x000210FF); asm_u32(3 * x_stream_stride)     // v30 = v8 + 24576

    // ── Outer loop init ───────────────────────────────────────────────────
    asm_s_mov_b32(13, 28)                      // s13 = row = saved wg_id (s28)
    asm_s_mov_b32_inline_imm(12, 0)            // s12 = r_off = 0

    uint64 w_lo = 2
    uint64 w_hi = 3
    uint64 x_lo = 4
    uint64 x_hi = 5
    uint64 out_lo = 6
    uint64 out_hi = 7
    uint64 res_lo = 18
    uint64 res_hi = 19

    uint64 w_row_step = wg_active * k_pad * 2
    uint64 k_iters = k / 2 / 32
    uint64 rows_per_wg = (n_out + wg_active - 1) / wg_active

    uint64 outer_top = asm_text_len / 4

    // ── Per-row body ──────────────────────────────────────────────────────
    // Reset all 4 accumulators.
    asm_v_mov_b32_inline_u(2,  0)     // acc_0 = 0.0
    asm_v_mov_b32_inline_u(13, 0)     // acc_1 = 0.0
    asm_v_mov_b32_inline_u(14, 0)     // acc_2 = 0.0
    asm_v_mov_b32_inline_u(15, 0)     // acc_3 = 0.0

    // init weight ptr: v3:v4 = s[w_lo:w_hi] + lane*4
    asm_v_mov_b32_inline_u(4, 0)
    asm_v_add_co_u32_vcc_sv(3, w_lo, 7)
    asm_v_add_co_ci_u32_null_sv_vcc(4, w_hi, 4)

    // init x stream-0 ptr: v5:v6 = s[x_lo:x_hi] + v8(lane*8)
    asm_v_mov_b32_inline_u(6, 0)
    asm_v_add_co_u32_vcc_sv(5, x_lo, 8)
    asm_v_add_co_ci_u32_null_sv_vcc(6, x_hi, 6)

    // init x stream-1 ptr: v16:v17 = s[x_lo:x_hi] + v28
    asm_v_mov_b32_inline_u(17, 0)
    asm_v_add_co_u32_vcc_sv(16, x_lo, 28)
    asm_v_add_co_ci_u32_null_sv_vcc(17, x_hi, 17)

    // init x stream-2 ptr: v18:v19 = s[x_lo:x_hi] + v29
    asm_v_mov_b32_inline_u(19, 0)
    asm_v_add_co_u32_vcc_sv(18, x_lo, 29)
    asm_v_add_co_ci_u32_null_sv_vcc(19, x_hi, 19)

    // init x stream-3 ptr: v20:v21 = s[x_lo:x_hi] + v30
    asm_v_mov_b32_inline_u(21, 0)
    asm_v_add_co_u32_vcc_sv(20, x_lo, 30)
    asm_v_add_co_ci_u32_null_sv_vcc(21, x_hi, 21)

    // ── Inner K loop ──────────────────────────────────────────────────────
    asm_s_mov_b32_inline_imm(14, k_iters)
    uint64 inner_top = asm_text_len / 4

    // 1 weight load (shared across 4 streams)
    asm_u32(0xDC520000); asm_u32(0x097C0003)    // global_load_b32 v9, v[3:4], off
    // 4 stream x loads (lo + hi pair per stream)
    asm_u32(0xDC520000); asm_u32(0x0B7C0005)    // global_load_b32 v11, v[5:6], off          (stream 0 lo)
    asm_u32(0xDC520004); asm_u32(0x0C7C0005)    // global_load_b32 v12, v[5:6], off offset:4 (stream 0 hi)
    asm_u32(0xDC520000); asm_u32(0x167C0010)    // global_load_b32 v22, v[16:17], off          (stream 1 lo)
    asm_u32(0xDC520004); asm_u32(0x177C0010)    // global_load_b32 v23, v[16:17], off offset:4 (stream 1 hi)
    asm_u32(0xDC520000); asm_u32(0x187C0012)    // global_load_b32 v24, v[18:19], off          (stream 2 lo)
    asm_u32(0xDC520004); asm_u32(0x197C0012)    // global_load_b32 v25, v[18:19], off offset:4 (stream 2 hi)
    asm_u32(0xDC520000); asm_u32(0x1A7C0014)    // global_load_b32 v26, v[20:21], off          (stream 3 lo)
    asm_u32(0xDC520004); asm_u32(0x1B7C0014)    // global_load_b32 v27, v[20:21], off offset:4 (stream 3 hi)
    asm_s_waitcnt_vmcnt_zero()

    // Unpack packed bf16 → 2 f32 in v10 (lo) + v9 (hi).
    asm_v_lshlrev_b32_imm(10, 16, 9)           // v10 = bf16-lo as f32
    asm_u32(0x361212FF); asm_u32(0xFFFF0000)   // v9  = bf16-hi as f32

    // 4 fmacs per stream (acc_m += w0 * x_lo + w1 * x_hi)
    asm_v_fmac_f32_e32_vv(2,  10, 11)          // acc_0 += w0 * x0_lo
    asm_v_fmac_f32_e32_vv(2,  9,  12)          // acc_0 += w1 * x0_hi
    asm_v_fmac_f32_e32_vv(13, 10, 22)          // acc_1 += w0 * x1_lo
    asm_v_fmac_f32_e32_vv(13, 9,  23)          // acc_1 += w1 * x1_hi
    asm_v_fmac_f32_e32_vv(14, 10, 24)          // acc_2 += w0 * x2_lo
    asm_v_fmac_f32_e32_vv(14, 9,  25)          // acc_2 += w1 * x2_hi
    asm_v_fmac_f32_e32_vv(15, 10, 26)          // acc_3 += w0 * x3_lo
    asm_v_fmac_f32_e32_vv(15, 9,  27)          // acc_3 += w1 * x3_hi

    // advance weight ptr +128 bytes (32 lanes × 4 = 128)
    asm_u32(0xD7006A03); asm_u32(0x000206FF); asm_u32(128)
    asm_u32(0xD5207C04); asm_u32(0x01AA0880)
    // advance stream-0 x ptr +256 bytes (v[5:6])
    asm_u32(0xD7006A05); asm_u32(0x00020AFF); asm_u32(256)
    asm_u32(0xD5207C06); asm_u32(0x01AA0C80)
    // advance stream-1 x ptr +256 bytes (v[16:17])
    asm_u32(0xD7006A10); asm_u32(0x000220FF); asm_u32(256)
    asm_u32(0xD5207C11); asm_u32(0x01AA2280)
    // advance stream-2 x ptr +256 bytes (v[18:19])
    asm_u32(0xD7006A12); asm_u32(0x000224FF); asm_u32(256)
    asm_u32(0xD5207C13); asm_u32(0x01AA2680)
    // advance stream-3 x ptr +256 bytes (v[20:21])
    asm_u32(0xD7006A14); asm_u32(0x000228FF); asm_u32(256)
    asm_u32(0xD5207C15); asm_u32(0x01AA2A80)

    asm_s_sub_u32_imm(14, 14, 1)
    asm_s_cmp_eq_u32(14, 0x80)
    uint64 inner_back = (0 - ((asm_text_len / 4) - inner_top) - 1) & 0xFFFF
    asm_s_cbranch_scc0(inner_back)

    // ── Wave XOR reduce × 4 (acc_0..acc_3) ────────────────────────────────
    // acc=v2/v13/v14/v15, addr=v9, tmp=v10 (both free after inner loop).
    _emit_wave_xor_reduce_add_f32_5_levels(2,  9, 10)
    _emit_wave_xor_reduce_add_f32_5_levels(13, 9, 10)
    _emit_wave_xor_reduce_add_f32_5_levels(14, 9, 10)
    _emit_wave_xor_reduce_add_f32_5_levels(15, 9, 10)

    // ── Lane-0 residual-add + store × 4 ───────────────────────────────────
    // Save exec → s17, gate to lane 0, then 4 sequential blocks:
    //   advance out_ptr + res_ptr by row*4 (m=0) or stream_stride (m>0)
    //   global_load_b32 v9, v1, s[res_lo:res_hi]
    //   wait, v_add_f32 acc_m, acc_m, v9
    //   s_delay_alu, global_store_b32 v1, acc_m, s[out_lo:out_hi]
    asm_v_cmp_eq_u32_imm_vgpr(0, 0)         // vcc_lo = (v0 == 0)
    asm_s_and_saveexec_b32_vcc_lo(17)       // s17 = old exec; exec &= vcc_lo

    // s14 = row * 4: s_lshl_b32 s14, s13, 2 = 0x840E820D
    asm_u32(0x840E820D)

    // ── Stream 0: out += row*4, res += row*4 ─────────────────────────────
    // s_add_u32 out_lo, out_lo, s14
    asm_u32(0x80000000 | (out_lo << 16) | (14 << 8) | out_lo)
    // s_addc_u32 out_hi, out_hi, 0
    asm_u32(0x82000000 | (out_hi << 16) | 0x8000 | out_hi)
    // s_add_u32 res_lo, res_lo, s14
    asm_u32(0x80000000 | (res_lo << 16) | (14 << 8) | res_lo)
    // s_addc_u32 res_hi, res_hi, 0
    asm_u32(0x82000000 | (res_hi << 16) | 0x8000 | res_hi)

    // global_load_b32 v9, v1, s[res_lo:res_hi]
    //   word2 = (vdst<<24) | ((res_lo & 0x7F)<<16) | vaddr  (saddr is sgpr index)
    asm_u32(0xDC520000)
    asm_u32((9 << 24) | ((res_lo & 0x7F) << 16) | 1)
    asm_s_waitcnt_vmcnt_zero()
    // v_add_f32_e32 v2, v2, v9 = 0x06041302
    asm_u32(0x06041302)
    asm_s_delay_alu(0x01)
    // global_store_b32 v1, v2, s[out_lo:out_hi]
    asm_u32(0xDC6A0000)
    asm_u32(((out_lo & 0x7F) << 16) | (2 << 8) | 1)

    // ── Stream 1: out += out_stride, res += res_stride; store v13 ────────
    // s_add_u32 out_lo, out_lo, lit (lit = out_stream_stride)
    asm_u32(0x80000000 | (out_lo << 16) | (0xFF << 8) | out_lo)
    asm_u32(out_stream_stride)
    asm_u32(0x82000000 | (out_hi << 16) | 0x8000 | out_hi)
    // s_add_u32 res_lo, res_lo, lit (lit = res_stream_stride)
    asm_u32(0x80000000 | (res_lo << 16) | (0xFF << 8) | res_lo)
    asm_u32(res_stream_stride)
    asm_u32(0x82000000 | (res_hi << 16) | 0x8000 | res_hi)
    // global_load_b32 v9, v1, s[res_lo:res_hi]
    asm_u32(0xDC520000)
    asm_u32((9 << 24) | ((res_lo & 0x7F) << 16) | 1)
    asm_s_waitcnt_vmcnt_zero()
    // v_add_f32_e32 v13, v13, v9 = 0x061A130D
    asm_u32(0x061A130D)
    asm_s_delay_alu(0x01)
    // global_store_b32 v1, v13, s[out_lo:out_hi]
    asm_u32(0xDC6A0000)
    asm_u32(((out_lo & 0x7F) << 16) | (13 << 8) | 1)

    // ── Stream 2: out += out_stride, res += res_stride; store v14 ────────
    asm_u32(0x80000000 | (out_lo << 16) | (0xFF << 8) | out_lo)
    asm_u32(out_stream_stride)
    asm_u32(0x82000000 | (out_hi << 16) | 0x8000 | out_hi)
    asm_u32(0x80000000 | (res_lo << 16) | (0xFF << 8) | res_lo)
    asm_u32(res_stream_stride)
    asm_u32(0x82000000 | (res_hi << 16) | 0x8000 | res_hi)
    asm_u32(0xDC520000)
    asm_u32((9 << 24) | ((res_lo & 0x7F) << 16) | 1)
    asm_s_waitcnt_vmcnt_zero()
    // v_add_f32_e32 v14, v14, v9 = 0x061C130E
    asm_u32(0x061C130E)
    asm_s_delay_alu(0x01)
    asm_u32(0xDC6A0000)
    asm_u32(((out_lo & 0x7F) << 16) | (14 << 8) | 1)

    // ── Stream 3: out += out_stride, res += res_stride; store v15 ────────
    asm_u32(0x80000000 | (out_lo << 16) | (0xFF << 8) | out_lo)
    asm_u32(out_stream_stride)
    asm_u32(0x82000000 | (out_hi << 16) | 0x8000 | out_hi)
    asm_u32(0x80000000 | (res_lo << 16) | (0xFF << 8) | res_lo)
    asm_u32(res_stream_stride)
    asm_u32(0x82000000 | (res_hi << 16) | 0x8000 | res_hi)
    asm_u32(0xDC520000)
    asm_u32((9 << 24) | ((res_lo & 0x7F) << 16) | 1)
    asm_s_waitcnt_vmcnt_zero()
    // v_add_f32_e32 v15, v15, v9 = 0x061E130F
    asm_u32(0x061E130F)
    asm_s_delay_alu(0x01)
    asm_u32(0xDC6A0000)
    asm_u32(((out_lo & 0x7F) << 16) | (15 << 8) | 1)

    // Restore exec: s_or_b32 exec_lo, exec_lo, s17
    asm_u32(0x8C7E117E)

    // ── Restore out_ptr + res_ptr ────────────────────────────────────────
    // Total added: row*4 (s14) + 3 × out_stream_stride to out;
    //              row*4 (s14) + 3 × res_stream_stride to res.
    // s_sub_u32 out_lo, out_lo, s14
    asm_u32(0x80800000 | (out_lo << 16) | (0x0E << 8) | out_lo)
    asm_u32(0x82800000 | (out_hi << 16) | 0x8000 | out_hi)
    // s_sub_u32 out_lo, out_lo, lit (3 * out_stream_stride)
    asm_u32(0x80800000 | (out_lo << 16) | (0xFF << 8) | out_lo)
    asm_u32(3 * out_stream_stride)
    asm_u32(0x82800000 | (out_hi << 16) | 0x8000 | out_hi)
    // s_sub_u32 res_lo, res_lo, s14
    asm_u32(0x80800000 | (res_lo << 16) | (0x0E << 8) | res_lo)
    asm_u32(0x82800000 | (res_hi << 16) | 0x8000 | res_hi)
    // s_sub_u32 res_lo, res_lo, lit (3 * res_stream_stride)
    asm_u32(0x80800000 | (res_lo << 16) | (0xFF << 8) | res_lo)
    asm_u32(3 * res_stream_stride)
    asm_u32(0x82800000 | (res_hi << 16) | 0x8000 | res_hi)

    // ── Outer loop advance ────────────────────────────────────────────────
    // Advance weight ptr by w_row_step bytes
    asm_s_mov_b32_lit32(14, w_row_step & 0xFFFFFFFF)
    asm_u32(0x80000000 | (w_lo << 16) | (0x0E << 8) | w_lo)
    asm_u32(0x82000000 | (w_hi << 16) | 0x8000 | w_hi)

    // Advance row: s13 += wg_active
    asm_u32(0x800DFF0D)
    asm_u32(wg_active)

    // r_off++; check r_off < rows_per_wg
    asm_u32(0x800C810C)
    asm_u32(0xBF0AFF0C)
    asm_u32(rows_per_wg & 0xFFFFFFFF)
    uint64 outer_back = (outer_top - (asm_text_len / 4) - 1) & 0xFFFF
    asm_s_cbranch_scc1(outer_back)

    // ── Patch the WG gate skip-branch ─────────────────────────────────────
    uint64 body_dwords = (asm_text_len / 4) - (gate_cmp_pos + 3)
    asm_patch_u32(gate_cmp_pos + 2, 0xBFA20000 | (body_dwords & 0xFFFF))
}

// ── Phase 15 m4 inline ISA emitter — silu_mul-elem-strided × 4 streams ────
//
// _emit_silu_mul_elem_strided_m4_inline — speck4 phase-15 variant.  The
// base slice-4.19.8 silu_mul body operates over a single [0..FF] slab
// (gu_scratch[idx] = silu(gu_scratch[idx]) * gu_scratch[FF+idx], idx<FF=3072).
// speck4 operates over 4 contiguous [m, 0..2*FF] slabs (gu_scratch_4 layout
// matches phase-13 m4 output: stream-m starts at byte m*N_OUT*4 = m*24576).
//
// Implementation: STATIC UNROLL of the silu-mul body 4 times.  Between
// iterations, bump the gu_scratch base ptr s[2:3] by 24576 bytes (= N_OUT*4
// = 2*FF*4) using a 32-bit-literal s_add_u32 + s_addc_u32 carry pair (same
// pattern as slice 4.20.1 rmsnorm m4 wrapper).  After m=3 finishes, leave
// s[2:3] at gu_scratch_4 + 73728 (phase 17 reloads its own copy from kernarg
// 0x80 — no need to restore).
//
// The WG gate (s28 < 256) and the per-lane gate (idx < FF=3072) are emitted
// ONCE outside the m-loop — both predicates are m-independent.  Inside the
// gate, the 4 silu-mul bodies run back-to-back; each body's loads/silu/store
// pattern is identical to base, just with s[2:3] retargeted to stream m's
// slab via the 3 inter-body s_add_u32 instructions.
//
// SGPR layout (matches base phase 15):
//   s[2:3]  = gu_scratch_4 ptr (advances by +24576 between m's)
//   s14     = log2(e) literal scratch (re-loaded per body — cheap)
//   s17     = saved exec_lo for the per-lane idx<FF gate
//   s28     = saved wg_id_x (read here, NOT s15 — phase 5 clobbered s15)
//
// VGPR layout (matches base phase 15, all reused across 4 m iterations):
//   v0      = lane id (hardware, r/o)
//   v2      = idx = wg_id*32 + lane
//   v3      = byte_off_g = idx*4
//   v4      = byte_off_u = byte_off_g + 12288
//   v8      = g (load) → silu(g)*u (store)
//   v9      = u (load)
//   v10     = silu/exp scratch
//
// Bytes-per-body comparison (verified against base @ slice 4.19.8):
//   16 dwords for the silu-mul body itself (loads + waitcnt + silu + store
//   + waitcnt) + 3 dwords for the inter-body s_add_u32+s_addc_u32 pair
//   (only between m=0→1, 1→2, 2→3 — three of them).  Total ~67 dwords vs
//   ~50 for base.
fn _emit_silu_mul_elem_strided_m4_inline() {
    // ── WG gate: skip if wg_id (s28) >= 256 ───────────────────────────────
    // s_cmp_ge_u32 s28, 256 (literal): SOPC op 0x09, ssrc1=0xFF (lit follows)
    uint64 p15_wg_gate_pos = asm_text_len / 4
    asm_u32(0xBF09FF1C)         // s_cmp_ge_u32 s28, lit
    asm_u32(256)
    asm_s_cbranch_scc1(0)       // patched at .phase15_done

    // ── Load gu_scratch_4 base ptr (stream 0) → s[2:3] ────────────────────
    asm_s_load_b64_off(1, 0, 0x80)
    asm_s_waitcnt_lgkmcnt_zero()

    // ── Compute idx = wg_id*32 + lane = (s28<<5) + v0 → v2 ────────────────
    // s_lshl_b32 s14, s28, 5: SOP2 op 0x08
    //   word = (2<<30)|(8<<23)|(0x0E<<16)|(0x85<<8)|0x1C = 0x840E851C
    asm_u32(0x840E851C)
    // v_add_nc_u32_e32 v2, s14, v0: VOP2 op 0x25
    //   word = (0x25<<25)|(2<<17)|(0<<9)|0x0E = 0x4A04000E
    asm_u32(0x4A04000E)
    // v_lshlrev_b32_e32 v3, 2, v2: byte_off_g = idx*4
    asm_v_lshlrev_b32_imm(3, 2, 2)

    // ── Per-lane gate: skip if idx >= FF (MEGA_FF) ────────────────────────
    // v_cmp_gt_u32_e32 vcc_lo, FF, v2 → vcc_lo = (FF > idx) = (idx < FF)
    //   word1 = (0x3E<<25)|(0x4C<<17)|(2<<9)|0xFF = 0x7C9804FF
    asm_u32(0x7C9804FF)
    asm_u32(MEGA_FF)
    // s_and_saveexec_b32 s17, vcc_lo  (s17 = old exec; exec &= vcc_lo)
    asm_s_and_saveexec_b32_vcc_lo(17)
    // s_cbranch_execz .phase15_lane_done (patched after all 4 bodies)
    uint64 p15_lane_execz_pos = asm_text_len / 4
    asm_s_cbranch_execz(0)

    // ── byte_off_u = byte_off_g + FF*4 → v4 ───────────────────────────────
    // v_add_nc_u32_e32 v4, lit, v3: VOP2 op 0x25, src0=0xFF (lit follows)
    //   word1 = (0x25<<25)|(4<<17)|(3<<9)|0xFF = 0x4A0806FF
    asm_u32(0x4A0806FF)
    asm_u32(MEGA_FF * 4)
    asm_s_delay_alu(0x01)       // VALU→VMEM hazard

    // ── Stream stride between m's: m*N_OUT*4 = m*24576 = m*0x6000 bytes ──
    // Apply via s_add_u32 s2, s2, 24576 (lit32) + s_addc_u32 s3, s3, 0 between
    // each consecutive pair of bodies (3 of them total).  Encoding mirrors
    // slice 4.20.1 rmsnorm m4 wrapper's stream_byte_offset adjust.

    uint64 m = 0
    while m < 4 {
        // ── Load g (= s[2:3][byte_off_g]) and u (= s[2:3][byte_off_u]) ────
        // global_load_b32 v8, v3, s[2:3]: word2 = (8<<24)|(2<<16)|3 = 0x08020003
        asm_u32(0xDC520000)
        asm_u32(0x08020003)
        // global_load_b32 v9, v4, s[2:3]: word2 = (9<<24)|(2<<16)|4 = 0x09020004
        asm_u32(0xDC520000)
        asm_u32(0x09020004)
        asm_s_waitcnt_vmcnt_zero()

        // ── SiLU compose: silu(g) = g / (1 + exp(-g)) ─────────────────────
        // s_mov_b32 s14, log2(e) = 0x3FB8AA3B (literal-32 form).
        // (Re-emitted per iter; cost is 2 dwords each.  Could be hoisted out
        // of the loop, but s14 is also used as a scratch for the s_lshl_b32
        // earlier — re-loading here is the safest pattern.)
        asm_s_mov_b32_lit32(14, 0x3FB8AA3B)
        // v_mul_f32_e64 v10, -v8, s14 → v10 = -g * log2(e)
        asm_u32(0xD508000A)
        asm_u32(0x20001D08)
        // v_exp_f32_e32 v10, v10 → v10 = exp2(-g*log2e) = exp(-g)
        asm_u32(0x7E144B0A)
        // v_add_f32_e32 v10, 1.0, v10 → v10 = 1 + exp(-g)
        asm_u32(0x061414F2)
        // v_rcp_f32_e32 v10, v10 → v10 = 1/(1+exp(-g)) = sigmoid(g)
        asm_u32(0x7E14550A)
        // v_mul_f32_e32 v8, v8, v10 → v8 = g * sigmoid(g) = silu(g)
        asm_u32(0x10101508)
        // v_mul_f32_e32 v8, v8, v9 → v8 = silu(g) * u
        asm_u32(0x10101308)

        // ── Store back to s[2:3][byte_off_g] ──────────────────────────────
        asm_s_delay_alu(0x01)       // VALU→VMEM hazard
        // global_store_b32 v3, v8, s[2:3]: word2 = (2<<16)|(8<<8)|3 = 0x00020803
        asm_u32(0xDC6A0000)
        asm_u32(0x00020803)
        asm_s_waitcnt_vscnt_zero()  // drain store before next body's loads

        // ── Bump s[2:3] by 2*FF*4 (N_OUT*4) for next iter (m=0,1,2 only) ─
        // s_add_u32  s2, s2, 2*FF*4 → 0x8002FF02 ; <lit32>
        // s_addc_u32 s3, s3, 0      → 0x82038003 (op 4, ssrc1=0x80=inline-0)
        if m < 3 {
            asm_u32(0x8002FF02); asm_u32(2 * MEGA_FF * 4)
            asm_u32(0x82038003)
        }

        m = m + 1
    }

    // ── .phase15_lane_done: patch the per-lane skip target + restore exec ─
    uint64 p15_lane_done = asm_text_len / 4
    uint64 p15_lane_off = p15_lane_done - p15_lane_execz_pos - 1
    asm_patch_u32(p15_lane_execz_pos, 0xBFA50000 | (p15_lane_off & 0xFFFF))
    // s_or_b32 exec_lo, exec_lo, s17 (restore full exec for the WG)
    asm_u32(0x8C7E117E)

    // ── Patch WG gate skip-branch to here (.phase15_done) ────────────────
    // p15_wg_gate_pos points at s_cmp (2 dwords); s_cbranch_scc1 is at +2.
    uint64 p15_wg_body_dwords = (asm_text_len / 4) - (p15_wg_gate_pos + 3)
    asm_patch_u32(p15_wg_gate_pos + 2, 0xBFA20000 | (p15_wg_body_dwords & 0xFFFF))
}

// ── Phase 5 inline ISA emitter ────────────────────────────────────────────
//
// _emit_phase5_qkv_split_qknorm_rope_inline — emits the 3-way head-per-WG
// QKV-split + qknorm + RoPE ISA INLINE (no asm_init, no s_endpgm).
//
// Shape: 32 WGs active (wg_id 0..31).
//   wg_id <  16           → Q head: rmsnorm-128 + NEOX RoPE → b_attn_q_g
//   16 ≤ wg_id < 24       → K head: rmsnorm-128 + NEOX RoPE → kc_layer[pos*KV_DIM]
//   24 ≤ wg_id < 32       → V head: passthrough copy         → vc_layer[pos*KV_DIM]
//
// Constants: N_HEADS=16, N_KV_HEADS=8, HEAD_DIM=128, half=64, WAVE=32.
//   eps=1e-6 = 0x358637BD,  1/128 = 0x3C000000.
//   Q_DIM=2048 (bytes: 8192),  KV_DIM=1024 (bytes: 4096).
//
// SGPR context on entry (from prologue):
//   s[0:1]  = kernarg ptr pair
//   s[8:9]  = barrier_counter ptr  (must NOT be clobbered — barrier follows)
//   s[10:11]= max_phase value
//   s15     = wg_id_x
//
// Phase 5 SGPR usage (reused across branches; branches are mutually exclusive):
//   s[2:3]  = src base ptr  (b_qkv_g ± head offset, or slice for K/V)
//   s[4:5]  = norm base ptr (q_norm_g / k_norm_g; unused for V)
//   s[6:7]  = dst base ptr  (b_attn_q_g, kc_layer+pos_off, vc_layer+pos_off)
//   s12     = pos (low 32 bits) then reused as SSQ loop counter
//   s13     = head local index (wg_id, kv_head, v_head)
//   s14     = pointer arithmetic scratch
//   s[12:13]= rope_cos base (after pos committed to dst ptr setup)
//   s[14:15]= rope_sin base (s15 is free inside a branch after 3-way dispatch)
//
// VGPR usage (19 VGPRs, v0..v18; well within rsrc1=6 = 56 VGPR budget):
//   v0  = lane id (hardware, r/o)
//   v1  = vaddr=0  (for global_store/ds_store)
//   v2  = ssq accumulator → rsqrt scale (broadcast via LDS[512])
//   v3:v4  = src ptr     (base + lane*4; advances +128/iter in SSQ; reset for RoPE)
//   v5:v6  = norm ptr    (base + lane*4; reset per RoPE iter)
//   v7:v8  = dst lo ptr  (base + lane*4; reset per RoPE iter)
//   v9:v10 = rope_cos ptr (base + lane*4; advances +128/iter)
//   v11:v12= rope_sin ptr (base + lane*4; advances +128/iter)
//   v13    = x1 (load → x1*scale*norm1)
//   v14    = x2 (load → x2*scale*norm2)
//   v15    = wave-XOR addr tmp; reused as cos value
//   v16    = wave-XOR reduce tmp; reused as sin value
//   v17    = rotation scratch (x1*cos or x1*sin intermediate)
//   v18    = rotation scratch (x2*sin or x2*cos intermediate)
//
// LDS layout (shared with phases 1..3, per-WG — no contention):
//   offset 512 = wave_tmp[0]: scale broadcast slot.
//
// Slice 4.19.3 note: eps=1e-6 (NOT 1e-5 used in phase 1/11 for HIDDEN=1024).
//   Different N means different 1/N literal (0x3C000000 vs 0x3A800000).
fn _emit_phase5_qkv_split_qknorm_rope_inline() {
    // ── Slice 5.3 — shape locals derived from MEGA_* arch globals ────────
    // All previously hard-coded Qwen3 literals (head dim, N_HEADS,
    // N_KV_HEADS, qknorm bits, RoPE pair layout) are now expressed as
    // functions of these locals.  At Qwen3 settings every value below
    // resolves to its old hard-coded constant — byte-exact regression.
    uint64 q_dim_bytes        = MEGA_N_HEADS    * MEGA_HEAD_DIM * 4
    uint64 kv_dim_bytes       = MEGA_N_KV_HEADS * MEGA_HEAD_DIM * 4
    uint64 head_off_shift     = _arch_log2_pow2(MEGA_HEAD_DIM * 4)
    uint64 kv_off_shift       = _arch_log2_pow2(kv_dim_bytes)
    uint64 ssq_iter_count     = MEGA_HEAD_DIM / 32
    uint64 rope_iter_count    = MEGA_HEAD_DIM / 64
    uint64 vcopy_iter_count   = MEGA_HEAD_DIM / 32
    uint64 inv_head_dim_bits  = _arch_inv_n_f32_bits(MEGA_HEAD_DIM)
    uint64 outer_cap          = MEGA_N_HEADS + 2 * MEGA_N_KV_HEADS
    uint64 k_boundary         = MEGA_N_HEADS + MEGA_N_KV_HEADS
    uint64 v_src_base_off     = (MEGA_N_HEADS + MEGA_N_KV_HEADS) * MEGA_HEAD_DIM * 4
    // RoPE pair-layout dependent fields (NEOX split-half by default; flipped
    // to NORM consecutive-pair under MEGA_ROPE_PAIR_LAYOUT == 1 — Llama).
    uint64 pair2_load_off     = 256        // NEOX: x2 lives at +HEAD_DIM/2*4 bytes
    uint64 pair2_store_off    = 256
    uint64 ptr_advance_bytes  = 128        // NEOX: src/norm/dst advance per iter
    // Per-lane byte stride into src/norm/dst for the rope pair loop.
    // NEOX (Qwen3, split-half): each thread t handles pair (q[t], q[t+HD/2]),
    //   so the per-lane offset between adjacent threads is 4 bytes (one f32).
    // NORM-pair (Llama, consecutive-pair): each thread t handles pair
    //   (q[2t], q[2t+1]), so the per-lane offset is 8 bytes (one f32 pair).
    uint64 lane_byte_shift    = 2          // NEOX default: lane_id * 4
    if MEGA_ROPE_PAIR_LAYOUT == 1 {
        pair2_load_off    = 4
        pair2_store_off   = 4
        ptr_advance_bytes = 256
        lane_byte_shift   = 3              // NORM-pair: lane_id * 8
    }

    // ── Outer skip-branch: skip if wg_id >= outer_cap (=N_HEADS+2*N_KV_HEADS) ─
    // SOPC s_cmp_ge_u32 s15, outer_cap.  At Qwen3 outer_cap=32 → 0xBF09A00F.
    uint64 outer_gate_pos = asm_text_len / 4
    _emit_s_cmp_ge_u32_lit(15, outer_cap)
    asm_s_cbranch_scc1(0)   // forward to .phase5_done (patched at end)

    // ── Load pos (low 32 bits) from kernarg offset 0x70 (arg 14, u64 by-value) ──
    // s_load_b32 s12, s[0:1], 0x70  (sdata_pair=6 → s12)
    asm_s_load_b32(6, 0, 0x70)
    asm_s_waitcnt_lgkmcnt_zero()

    // ── v1 = 0 (vaddr placeholder for stores and ds ops) ─────────────────
    asm_v_mov_b32_inline_u(1, 0)

    // ── 3-way head dispatch ───────────────────────────────────────────────
    // Q check: s_cmp_lt_u32 s15, MEGA_N_HEADS (SCC=1 if wg_id < N_HEADS).
    // At Qwen3 N_HEADS=16 → 0xBF0A900F.
    _emit_s_cmp_lt_u32_lit(15, MEGA_N_HEADS)
    uint64 q_gate_pos = asm_text_len / 4
    asm_s_cbranch_scc0(0)   // to .not_q if wg_id >= 16 (patched)

    // ════════════════════════════════════════════════════════════════════
    // Q BODY (wg_id < 16)
    //   head = wg_id  (= s15)
    //   src = b_qkv_g + head*128*4  = b_qkv_g + head*512 bytes
    //   dst = b_attn_q_g + head*128*4
    // ════════════════════════════════════════════════════════════════════

    // Load b_qkv_g → s[2:3]   (kernarg 0x90 = arg 18)
    asm_s_load_b64_off(1, 0, 0x90)
    // Load q_norm_g → s[4:5]  (kernarg 0x40 = arg 8) — qknorm only.
    if MEGA_USE_QKNORM != 0 {
        asm_s_load_b64_off(2, 0, 0x40)
    }
    // Load b_attn_q_g → s[6:7] (kernarg 0x98 = arg 19)
    asm_s_load_b64_off(3, 0, 0x98)
    asm_s_waitcnt_lgkmcnt_zero()

    // head_byte_offset = head * HEAD_DIM*4 = s15 << head_off_shift.
    // s_lshl_b32 s13, s15, head_off_shift; SOP2 op 0x08, sdst=s13, ssrc0=s15.
    // At Qwen3 head_off_shift=9 → 0x840D890F.
    asm_u32(0x840D000F | ((0x80 + head_off_shift) << 8))
    // s_add_u32 s2, s2, s13  (src_lo += head*512)
    //   SOP2 op 0: word = 0x80000000|(0x02<<16)|(0x0D<<8)|0x02 = 0x80020D02
    asm_u32(0x80020D02)
    // s_addc_u32 s3, s3, 0   (src_hi += carry)
    //   SOP2 op 4: word = 0x82000000|(0x03<<16)|(0x80<<8)|0x03 = 0x82038003
    asm_u32(0x82038003)
    // s_add_u32 s6, s6, s13  (dst_lo += head*512)
    asm_u32(0x80060D06)
    // s_addc_u32 s7, s7, 0   (dst_hi += carry)
    asm_u32(0x82078007)

    // ── Q: inline rmsnorm-HEAD_DIM (qknorm only) ─────────────────────────
    // Computes scale = rsqrt(ssq/HEAD_DIM + 1e-6) over all lanes and
    // broadcasts the lane-0 result via LDS[512] into v2.  When MEGA_USE_QKNORM
    // is 0 (Llama) this entire block is skipped — v2 retains its previous
    // value (the v_mov_b32_inline_u(1, 0) earlier set up v1; v2 is unused
    // by the rotation math without qknorm).
    if MEGA_USE_QKNORM != 0 {
        // v2 = 0.0 (ssq accumulator)
        asm_v_mov_b32_inline_u(2, 0)
        // v9 = lane*4 (byte offset per lane)
        asm_v_lshlrev_b32_imm(9, 2, 0)
        // v3:v4 = s[2:3] + lane*4  (src ptr, lo+hi)
        asm_v_mov_b32_inline_u(4, 0)
        asm_v_add_co_u32_vcc_sv(3, 2, 9)
        asm_v_add_co_ci_u32_null_sv_vcc(4, 3, 4)
        // SSQ loop: HEAD_DIM/32 iterations (lane..HEAD_DIM step 32 = WAVE).
        // At Qwen3 HEAD_DIM=128 → 4.
        asm_s_mov_b32_inline_imm(12, ssq_iter_count)
        uint64 q_ssq_top = asm_text_len / 4
        // global_load_b32 v13, v[3:4], off
        asm_u32(0xDC520000); asm_u32(0x0D7C0003)
        asm_s_waitcnt_vmcnt_zero()
        // v_fmac_f32_e32 v2, v13, v13  (ssq += v13*v13)
        asm_v_fmac_f32_e32_vv(2, 13, 13)
        // advance src ptr +128 bytes
        asm_u32(0xD7006A03); asm_u32(0x000206FF); asm_u32(128)
        asm_u32(0xD5207C04); asm_u32(0x01AA0880)
        asm_s_sub_u32_imm(12, 12, 1)
        asm_s_cmp_eq_u32(12, 0x80)
        uint64 q_ssq_back = (0 - ((asm_text_len / 4) - q_ssq_top) - 1) & 0xFFFF
        asm_s_cbranch_scc0(q_ssq_back)
        // Wave XOR reduce: acc=v2, addr=v15, tmp=v16
        _emit_wave_xor_reduce_add_f32_5_levels(2, 15, 16)
        // Lane-0: scale = rsqrt(ssq/HEAD_DIM + 1e-6), store to LDS[512]
        asm_s_mov_b32(12, 0x7E)                          // save exec in s12
        asm_u32(0x7D940080)                               // v_cmpx_eq_u32_e32 0, v0 (exec=lane-0)
        asm_s_mov_b32_lit32(14, inv_head_dim_bits)        // s14 = 1/HEAD_DIM (Qwen3=1/128=0x3C000000)
        // v_mul_f32 v2, s14, v2
        asm_u32(0x1004040E)
        asm_s_mov_b32_lit32(14, 0x358637BD)               // s14 = 1e-6f (eps; qknorm hardcoded)
        // v_add_f32 v2, s14, v2
        asm_u32(0x0604040E)
        // v_rsq_f32 v2, v2
        asm_u32(0x7E045D02)
        // ds_store_b32 v1, v2 offset:512
        asm_u32(0xD8340200); asm_u32(0x00000201)
        asm_s_mov_b32(0x7E, 12)                           // restore exec
        asm_s_waitcnt_lgkmcnt_zero()
        asm_s_barrier()
        // ds_load_b32 v2, v1 offset:512
        asm_u32(0xD8D80200); asm_u32(0x02000001)
        asm_s_waitcnt_lgkmcnt_zero()
        // v2 = scale (broadcast to all lanes)
    }

    // ── Q: load rope_cos→s[12:13], rope_sin→s[14:15] ─────────────────────
    // s_load_b64 s[12:13], s[0:1], 0x50  (rope_cos, arg 10; sdata_pair=6)
    asm_s_load_b64_off(6, 0, 0x50)
    // s_load_b64 s[14:15], s[0:1], 0x58  (rope_sin, arg 11; sdata_pair=7)
    asm_s_load_b64_off(7, 0, 0x58)
    asm_s_waitcnt_lgkmcnt_zero()

    // ── Q: RoPE pair-rotation loop (HEAD_DIM/64 iters: lane..HEAD_DIM/2 step 32) ──
    // Slice 6.7: ensure v9 holds the correct per-lane byte stride for this
    // arch's rope pair layout BEFORE Q-rope src/dst ptr setup.
    //   - QKNORM=1 path (Qwen3): the qknorm block above just emitted
    //     v9 = lane*4 (NEOX, lane_byte_shift=2) — already correct, so we
    //     do NOT re-emit here (preserves Qwen3 byte-exactness).
    //   - QKNORM=0 path (Llama): no qknorm block fired, so v9 carries a
    //     stale value from phase 1.  Emit v9 = lane << lane_byte_shift
    //     (NORM-pair → lane*8).  This is the slice 6.7 fix.
    if MEGA_USE_QKNORM == 0 {
        asm_v_lshlrev_b32_imm(9, lane_byte_shift, 0)
    }
    // Reset src ptr: v3:v4 = s[2:3] + v9
    asm_v_mov_b32_inline_u(4, 0)
    asm_v_add_co_u32_vcc_sv(3, 2, 9)
    asm_v_add_co_ci_u32_null_sv_vcc(4, 3, 4)
    // Setup norm ptr: v5:v6 = s[4:5] + v9 — qknorm only.
    if MEGA_USE_QKNORM != 0 {
        asm_v_mov_b32_inline_u(6, 0)
        asm_v_add_co_u32_vcc_sv(5, 4, 9)
        asm_v_add_co_ci_u32_null_sv_vcc(6, 5, 6)
    }
    // Setup dst ptr: v7:v8 = s[6:7] + v9
    asm_v_mov_b32_inline_u(8, 0)
    asm_v_add_co_u32_vcc_sv(7, 6, 9)
    asm_v_add_co_ci_u32_null_sv_vcc(8, 7, 8)
    // Setup rope_cos ptr: v9:v10 = s[12:13] + lane*4  (v9 becomes ptr lo)
    // Re-compute lane*4 into v17 first (v9 will be overwritten)
    asm_v_lshlrev_b32_imm(17, 2, 0)                  // v17 = lane*4
    asm_v_mov_b32_inline_u(10, 0)
    asm_v_add_co_u32_vcc_sv(9, 12, 17)               // v9 = s12 + lane*4
    asm_v_add_co_ci_u32_null_sv_vcc(10, 13, 10)      // v10 = s13 + carry
    // Setup rope_sin ptr: v11:v12 = s[14:15] + lane*4
    asm_v_mov_b32_inline_u(12, 0)
    asm_v_add_co_u32_vcc_sv(11, 14, 17)              // v11 = s14 + lane*4
    asm_v_add_co_ci_u32_null_sv_vcc(12, 15, 12)      // v12 = s15 + carry
    // RoPE loop counter = HEAD_DIM/64 = HEAD_DIM/(2*WAVE).
    // At Qwen3 HEAD_DIM=128 → 2.  At Llama HEAD_DIM=64 → 1.
    asm_s_mov_b32_inline_imm(12, rope_iter_count)
    uint64 q_rope_top = asm_text_len / 4
    // Load x1 = src[i], x2 = src[<pair2_load_off>] (NEOX +256 / NORM +4)
    asm_u32(0xDC520000); asm_u32(0x0D7C0003)          // v13 = src[i]
    asm_u32(0xDC520000 | (pair2_load_off & 0xFFFF)); asm_u32(0x0E7C0003)  // v14 = src[i+pair2]
    // Load norm1 = q_norm[i], norm2 = q_norm[i+pair2] — qknorm only.
    if MEGA_USE_QKNORM != 0 {
        asm_u32(0xDC520000); asm_u32(0x0F7C0005)      // v15 = norm[i]
        asm_u32(0xDC520000 | (pair2_load_off & 0xFFFF)); asm_u32(0x107C0005)  // v16 = norm[i+pair2]
    }
    asm_s_waitcnt_vmcnt_zero()
    // x1', x2' = x * scale * norm — qknorm only (Llama feeds raw v13/v14).
    if MEGA_USE_QKNORM != 0 {
        // v_mul_f32 v13, v2, v13  (scale*x1)
        asm_u32(0x101A1B02)
        // v_mul_f32 v13, v15, v13 (norm1 * (scale*x1))
        asm_u32(0x101A1F0D)
        // v_mul_f32 v14, v2, v14  (scale*x2)
        asm_u32(0x101C1D02)
        // v_mul_f32 v14, v16, v14 (norm2 * (scale*x2))
        asm_u32(0x101C210E)
    }
    // Load cos = rope_cos[i] into v15; sin = rope_sin[i] into v16
    asm_u32(0xDC520000); asm_u32(0x0F7C0009)          // v15 = cos[i]
    asm_u32(0xDC520000); asm_u32(0x107C000B)          // v16 = sin[i]
    asm_s_waitcnt_vmcnt_zero()
    // Rotation: out_lo = x1*cos - x2*sin; out_hi = x1*sin + x2*cos
    // v17 = x1 * cos: v_mul_f32 v17, v13, v15; src0=v13=0x10D, vsrc1=v15=15
    // word=(8<<25)|(17<<17)|(15<<9)|(0x10D)=0x10000000|0x00220000|0x00001E00|0x10D=0x10221F0D
    asm_u32(0x10221F0D)
    // v18 = x2 * sin: v_mul_f32 v18, v14, v16; src0=v14=0x10E, vsrc1=v16=16
    // word=(8<<25)|(18<<17)|(16<<9)|(0x10E)=0x10000000|0x00240000|0x00002000|0x10E=0x1024210E
    asm_u32(0x1024210E)
    // out_lo = v17 - v18: v_sub_f32 v17, v17, v18; VOP2 op 4; src0=v17=0x111, vsrc1=v18=18
    // word=(4<<25)|(17<<17)|(18<<9)|(0x111)=0x08000000|0x00220000|0x00002400|0x111=0x08222511
    asm_u32(0x08222511)
    // global_store_b32 v[7:8], v17, off  (store out_lo at dst[i]; per-lane v7:v8 ptr)
    // word1=0xDC6A0000, word2=(0x7C<<16)|(17<<8)|7=0x007C1107
    asm_u32(0xDC6A0000); asm_u32(0x007C1107)
    // out_hi = x1*sin + x2*cos: v17 = x1*sin; v_fmac(v17, x2, cos)
    // v17 = x1 * sin: v_mul_f32 v17, v13, v16; src0=v13=0x10D, vsrc1=v16=16
    // word=(8<<25)|(17<<17)|(16<<9)|(0x10D)=0x10000000|0x00220000|0x00002000|0x10D=0x1022210D
    asm_u32(0x1022210D)
    // v_fmac_f32_e32 v17, v14, v15  (v17 += x2*cos): vdst=17, src0=v14=0x10E, vsrc1=v15=15
    // VOP2 op 0x2B: word=(0x2B<<25)|(17<<17)|(15<<9)|(0x10E)=0x56000000|0x00220000|0x00001E00|0x10E=0x56221F0E
    asm_u32(0x56221F0E)
    // global_store_b32 v[7:8], v17, off offset:pair2_store_off (NEOX 256 / NORM 4)
    // word1=0xDC6A0000|pair2_store_off, word2=(0x7C<<16)|(17<<8)|7=0x007C1107
    asm_u32(0xDC6A0000 | (pair2_store_off & 0xFFFF)); asm_u32(0x007C1107)
    // Advance src/dst (and qknorm-only norm) ptrs by ptr_advance_bytes
    // (NEOX 128 / NORM 256); cos/sin always advance 128.
    asm_u32(0xD7006A03); asm_u32(0x000206FF); asm_u32(ptr_advance_bytes)   // src ptr lo
    asm_u32(0xD5207C04); asm_u32(0x01AA0880)                                // src ptr hi
    if MEGA_USE_QKNORM != 0 {
        asm_u32(0xD7006A05); asm_u32(0x00020AFF); asm_u32(ptr_advance_bytes)   // norm ptr lo
        asm_u32(0xD5207C06); asm_u32(0x01AA0C80)                                // norm ptr hi
    }
    asm_u32(0xD7006A07); asm_u32(0x00020EFF); asm_u32(ptr_advance_bytes)   // dst ptr lo
    asm_u32(0xD5207C08); asm_u32(0x01AA1080)                                // dst ptr hi
    asm_u32(0xD7006A09); asm_u32(0x000212FF); asm_u32(128)                  // cos ptr lo: v9
    asm_u32(0xD5207C0A); asm_u32(0x01AA1480)                   // cos ptr hi: v10
    asm_u32(0xD7006A0B); asm_u32(0x000216FF); asm_u32(128)    // sin ptr lo: v11
    asm_u32(0xD5207C0C); asm_u32(0x01AA1880)                   // sin ptr hi: v12
    asm_s_sub_u32_imm(12, 12, 1)
    asm_s_cmp_eq_u32(12, 0x80)
    uint64 q_rope_back = (0 - ((asm_text_len / 4) - q_rope_top) - 1) & 0xFFFF
    asm_s_cbranch_scc0(q_rope_back)

    // Q done: s_branch to .phase5_done (SOPP op 0x20; prefix 0x17F → 0xBFA00000 | simm16)
    // Emit placeholder (simm16=0), patch at end.
    uint64 q_done_pos = asm_text_len / 4
    asm_u32(0xBFA00000)   // s_branch simm16=0 placeholder (patched at phase5_done)

    // ── .not_q target: K/V check ─────────────────────────────────────────
    uint64 not_q_target = asm_text_len / 4
    // Patch q_gate branch to here: scc0 (branch when SCC=0 = wg_id >= 16 = NOT Q head)
    asm_patch_u32(q_gate_pos, 0xBFA10000 | ((not_q_target - q_gate_pos - 1) & 0xFFFF))

    // K check: s_cmp_lt_u32 s15, k_boundary (= N_HEADS + N_KV_HEADS).
    // SCC=1 if wg_id < k_boundary → K head.  At Qwen3 k_boundary=24 → 0xBF0A980F.
    _emit_s_cmp_lt_u32_lit(15, k_boundary)
    uint64 k_gate_pos = asm_text_len / 4
    asm_s_cbranch_scc0(0)   // to .not_k if wg_id >= 24 (patched)

    // ════════════════════════════════════════════════════════════════════
    // K BODY (16 ≤ wg_id < 24)
    //   kv_head = wg_id - 16  (= s15 - 16)
    //   src  = b_qkv_g + Q_DIM*4 + kv_head*512  = b_qkv_g + 8192 + kv_head*512
    //   norm = k_norm_g
    //   dst  = kc_layer + pos*KV_DIM*4 + kv_head*512
    //        = kc_layer + pos*4096 + kv_head*512
    // ════════════════════════════════════════════════════════════════════

    // Load b_qkv_g → s[2:3]    (kernarg 0x90)
    asm_s_load_b64_off(1, 0, 0x90)
    // Load k_norm_g → s[4:5]   (kernarg 0x48 = arg 9) — qknorm only.
    if MEGA_USE_QKNORM != 0 {
        asm_s_load_b64_off(2, 0, 0x48)
    }
    // Load kc_layer → s[6:7]   (kernarg 0x60 = arg 12)
    asm_s_load_b64_off(3, 0, 0x60)
    asm_s_waitcnt_lgkmcnt_zero()

    // kv_head = s15 - N_HEADS; s_sub_u32 s13, s15, MEGA_N_HEADS
    // SOP2 op 1 (s_sub): word = (2<<30)|(1<<23)|(0x0D<<16)|(0xFF<<8)|0x0F = 0x808DFF0F, lit=N_HEADS
    // Slice 5.9: literal hard-coded as 16 (Qwen3 N_HEADS) was wrong for
    // Llama (N_HEADS=32) — kv_head was off by 16, K rotation read+wrote
    // garbage offsets, mega_barrier never reconciled.
    asm_u32(0x808DFF0F); asm_u32(MEGA_N_HEADS & 0xFFFFFFFF)

    // src offset = Q_DIM*4 + kv_head*HEAD_DIM*4 = q_dim_bytes + kv_head*(1<<head_off_shift)
    // s14 = kv_head * HEAD_DIM*4 = s13 << head_off_shift.
    // s_lshl_b32 s14, s13, head_off_shift; sdst=14, ssrc0=13.
    // At Qwen3 → 0x840E890D.
    asm_u32(0x840E000D | ((0x80 + head_off_shift) << 8))
    // s14 += q_dim_bytes (= N_HEADS*HEAD_DIM*4); s_add_u32 s14, s14, lit32.
    // Word = 0x80000000|(0x0E<<16)|(0xFF<<8)|0x0E = 0x800EFF0E, lit=q_dim_bytes.
    // At Qwen3 q_dim_bytes=8192.
    asm_u32(0x800EFF0E); asm_u32(q_dim_bytes)
    // s_add_u32 s2, s2, s14 (src_lo += offset)
    asm_u32(0x80020E02)
    // s_addc_u32 s3, s3, 0
    asm_u32(0x82038003)

    // dst offset = pos*KV_DIM*4 + kv_head*HEAD_DIM*4
    // pos*KV_DIM*4 = s12 << kv_off_shift (pos is low 32 bits in s12).
    // s_lshl_b32 s14, s12, kv_off_shift; sdst=14, ssrc0=12.
    // At Qwen3 KV_DIM=1024 → KV_DIM*4=4096 → kv_off_shift=12 → 0x840E8C0C.
    asm_u32(0x840E000C | ((0x80 + kv_off_shift) << 8))
    // dst_lo = kc_layer_lo + pos*4096 + kv_head*512
    // s_add_u32 s6, s6, s14
    asm_u32(0x80060E06)
    // s_addc_u32 s7, s7, 0
    asm_u32(0x82078007)
    // add kv_head*HEAD_DIM*4: s_lshl_b32 s13, s13, head_off_shift.
    // sdst=13, ssrc0=13.  At Qwen3 → 0x840D890D.
    asm_u32(0x840D000D | ((0x80 + head_off_shift) << 8))
    // s_add_u32 s6, s6, s13
    asm_u32(0x80060D06)
    // s_addc_u32 s7, s7, 0
    asm_u32(0x82078007)

    // ── K: inline rmsnorm-HEAD_DIM (qknorm only; identical to Q body) ────
    if MEGA_USE_QKNORM != 0 {
        asm_v_mov_b32_inline_u(2, 0)
        asm_v_lshlrev_b32_imm(9, 2, 0)
        asm_v_mov_b32_inline_u(4, 0)
        asm_v_add_co_u32_vcc_sv(3, 2, 9)
        asm_v_add_co_ci_u32_null_sv_vcc(4, 3, 4)
        asm_s_mov_b32_inline_imm(12, ssq_iter_count)
        uint64 k_ssq_top = asm_text_len / 4
        asm_u32(0xDC520000); asm_u32(0x0D7C0003)
        asm_s_waitcnt_vmcnt_zero()
        asm_v_fmac_f32_e32_vv(2, 13, 13)
        asm_u32(0xD7006A03); asm_u32(0x000206FF); asm_u32(128)
        asm_u32(0xD5207C04); asm_u32(0x01AA0880)
        asm_s_sub_u32_imm(12, 12, 1)
        asm_s_cmp_eq_u32(12, 0x80)
        uint64 k_ssq_back = (0 - ((asm_text_len / 4) - k_ssq_top) - 1) & 0xFFFF
        asm_s_cbranch_scc0(k_ssq_back)
        _emit_wave_xor_reduce_add_f32_5_levels(2, 15, 16)
        asm_s_mov_b32(12, 0x7E)
        asm_u32(0x7D940080)
        asm_s_mov_b32_lit32(14, inv_head_dim_bits)        // s14 = 1/HEAD_DIM
        asm_u32(0x1004040E)
        asm_s_mov_b32_lit32(14, 0x358637BD)
        asm_u32(0x0604040E)
        asm_u32(0x7E045D02)
        asm_u32(0xD8340200); asm_u32(0x00000201)
        asm_s_mov_b32(0x7E, 12)
        asm_s_waitcnt_lgkmcnt_zero()
        asm_s_barrier()
        asm_u32(0xD8D80200); asm_u32(0x02000001)
        asm_s_waitcnt_lgkmcnt_zero()
    }

    // ── K: load rope_cos→s[12:13], rope_sin→s[14:15] ─────────────────────
    asm_s_load_b64_off(6, 0, 0x50)
    asm_s_load_b64_off(7, 0, 0x58)
    asm_s_waitcnt_lgkmcnt_zero()

    // ── K: RoPE pair-rotation loop (identical structure to Q) ────────────
    // Slice 6.7: same v9 lane-stride fix as Q-rope above.  Qwen3 (QKNORM=1)
    // gets v9=lane*4 from the K-qknorm block; Llama (QKNORM=0) must set
    // v9 = lane << lane_byte_shift explicitly (NORM-pair → lane*8).
    if MEGA_USE_QKNORM == 0 {
        asm_v_lshlrev_b32_imm(9, lane_byte_shift, 0)
    }
    asm_v_mov_b32_inline_u(4, 0)
    asm_v_add_co_u32_vcc_sv(3, 2, 9)
    asm_v_add_co_ci_u32_null_sv_vcc(4, 3, 4)
    if MEGA_USE_QKNORM != 0 {
        asm_v_mov_b32_inline_u(6, 0)
        asm_v_add_co_u32_vcc_sv(5, 4, 9)
        asm_v_add_co_ci_u32_null_sv_vcc(6, 5, 6)
    }
    asm_v_mov_b32_inline_u(8, 0)
    asm_v_add_co_u32_vcc_sv(7, 6, 9)
    asm_v_add_co_ci_u32_null_sv_vcc(8, 7, 8)
    asm_v_lshlrev_b32_imm(17, 2, 0)
    asm_v_mov_b32_inline_u(10, 0)
    asm_v_add_co_u32_vcc_sv(9, 12, 17)
    asm_v_add_co_ci_u32_null_sv_vcc(10, 13, 10)
    asm_v_mov_b32_inline_u(12, 0)
    asm_v_add_co_u32_vcc_sv(11, 14, 17)
    asm_v_add_co_ci_u32_null_sv_vcc(12, 15, 12)
    asm_s_mov_b32_inline_imm(12, rope_iter_count)
    uint64 k_rope_top = asm_text_len / 4
    asm_u32(0xDC520000); asm_u32(0x0D7C0003)                            // v13 = src[i]
    asm_u32(0xDC520000 | (pair2_load_off & 0xFFFF)); asm_u32(0x0E7C0003) // v14 = src[i+pair2]
    if MEGA_USE_QKNORM != 0 {
        asm_u32(0xDC520000); asm_u32(0x0F7C0005)                            // v15 = norm[i]
        asm_u32(0xDC520000 | (pair2_load_off & 0xFFFF)); asm_u32(0x107C0005) // v16 = norm[i+pair2]
    }
    asm_s_waitcnt_vmcnt_zero()
    if MEGA_USE_QKNORM != 0 {
        asm_u32(0x101A1B02)
        asm_u32(0x101A1F0D)
        asm_u32(0x101C1D02)
        asm_u32(0x101C210E)
    }
    asm_u32(0xDC520000); asm_u32(0x0F7C0009)
    asm_u32(0xDC520000); asm_u32(0x107C000B)
    asm_s_waitcnt_vmcnt_zero()
    asm_u32(0x10221F0D)
    asm_u32(0x1024210E)
    asm_u32(0x08222511)
    // global_store_b32 v[7:8], v17, off  (K out_lo; per-lane v7:v8 ptr)
    asm_u32(0xDC6A0000); asm_u32(0x007C1107)
    asm_u32(0x1022210D)
    asm_u32(0x56221F0E)
    // global_store_b32 v[7:8], v17, off offset:pair2_store_off  (K out_hi)
    asm_u32(0xDC6A0000 | (pair2_store_off & 0xFFFF)); asm_u32(0x007C1107)
    asm_u32(0xD7006A03); asm_u32(0x000206FF); asm_u32(ptr_advance_bytes)   // src ptr lo
    asm_u32(0xD5207C04); asm_u32(0x01AA0880)
    if MEGA_USE_QKNORM != 0 {
        asm_u32(0xD7006A05); asm_u32(0x00020AFF); asm_u32(ptr_advance_bytes)   // norm ptr lo
        asm_u32(0xD5207C06); asm_u32(0x01AA0C80)
    }
    asm_u32(0xD7006A07); asm_u32(0x00020EFF); asm_u32(ptr_advance_bytes)   // dst ptr lo
    asm_u32(0xD5207C08); asm_u32(0x01AA1080)
    asm_u32(0xD7006A09); asm_u32(0x000212FF); asm_u32(128)                 // cos ptr lo (always 128)
    asm_u32(0xD5207C0A); asm_u32(0x01AA1480)
    asm_u32(0xD7006A0B); asm_u32(0x000216FF); asm_u32(128)                 // sin ptr lo (always 128)
    asm_u32(0xD5207C0C); asm_u32(0x01AA1880)
    asm_s_sub_u32_imm(12, 12, 1)
    asm_s_cmp_eq_u32(12, 0x80)
    uint64 k_rope_back = (0 - ((asm_text_len / 4) - k_rope_top) - 1) & 0xFFFF
    asm_s_cbranch_scc0(k_rope_back)

    // K done: s_branch to .phase5_done (placeholder, patched at end)
    uint64 k_done_pos = asm_text_len / 4
    asm_u32(0xBFA00000)   // s_branch simm16=0 placeholder (patched at end)

    // ── .not_k target: V body ─────────────────────────────────────────────
    uint64 not_k_target = asm_text_len / 4
    // Patch K gate branch to here: scc0 (branch when SCC=0 = wg_id >= 24 = NOT K head)
    asm_patch_u32(k_gate_pos, 0xBFA10000 | ((not_k_target - k_gate_pos - 1) & 0xFFFF))

    // ════════════════════════════════════════════════════════════════════
    // V BODY (24 ≤ wg_id < 32)
    //   v_head = wg_id - 24  (= s15 - 24)
    //   src = b_qkv_g + (Q_DIM+KV_DIM)*4 + v_head*512
    //       = b_qkv_g + 12288 + v_head*512
    //   dst = vc_layer + pos*4096 + v_head*512
    // ════════════════════════════════════════════════════════════════════

    // Load b_qkv_g → s[2:3]    (kernarg 0x90)
    asm_s_load_b64_off(1, 0, 0x90)
    // Load vc_layer → s[6:7]   (kernarg 0x68 = arg 13)
    asm_s_load_b64_off(3, 0, 0x68)
    asm_s_waitcnt_lgkmcnt_zero()

    // v_head = s15 - (N_HEADS+N_KV_HEADS) = s15 - k_boundary
    // s_sub_u32 s13, s15, k_boundary  (lit32)
    // Slice 5.9: literal hard-coded as 24 (Qwen3 N_HEADS+N_KV_HEADS = 16+8)
    // was wrong for Llama (32+8 = 40); v_head was off by 16 → V rotation
    // wrote KV cache at the wrong offsets and the cross-WG barrier
    // never reconciled.
    asm_u32(0x808DFF0F); asm_u32(k_boundary & 0xFFFFFFFF)

    // src offset = v_src_base_off + v_head*HEAD_DIM*4
    // s14 = v_head * HEAD_DIM*4 = s13 << head_off_shift; sdst=14, ssrc0=13.
    // At Qwen3 → 0x840E890D.
    asm_u32(0x840E000D | ((0x80 + head_off_shift) << 8))
    // s14 += v_src_base_off (= (N_HEADS+N_KV_HEADS)*HEAD_DIM*4).  At Qwen3 = 12288.
    asm_u32(0x800EFF0E); asm_u32(v_src_base_off)
    // s_add_u32 s2, s2, s14
    asm_u32(0x80020E02)
    // s_addc_u32 s3, s3, 0
    asm_u32(0x82038003)

    // dst offset = pos*KV_DIM*4 + v_head*HEAD_DIM*4
    // s14 = pos*KV_DIM*4 = s12 << kv_off_shift; sdst=14, ssrc0=12.
    // At Qwen3 → 0x840E8C0C.
    asm_u32(0x840E000C | ((0x80 + kv_off_shift) << 8))
    // s_add_u32 s6, s6, s14
    asm_u32(0x80060E06)
    // s_addc_u32 s7, s7, 0
    asm_u32(0x82078007)
    // add v_head*HEAD_DIM*4: s_lshl_b32 s13, s13, head_off_shift.
    // sdst=13, ssrc0=13.  At Qwen3 → 0x840D890D.
    asm_u32(0x840D000D | ((0x80 + head_off_shift) << 8))
    // s_add_u32 s6, s6, s13
    asm_u32(0x80060D06)
    // s_addc_u32 s7, s7, 0
    asm_u32(0x82078007)

    // ── V: passthrough copy (lane..HEAD_DIM step 32, HEAD_DIM/32 iters) ──
    asm_v_lshlrev_b32_imm(9, 2, 0)               // v9 = lane*4
    asm_v_mov_b32_inline_u(4, 0)
    asm_v_add_co_u32_vcc_sv(3, 2, 9)             // v3:v4 = src ptr
    asm_v_add_co_ci_u32_null_sv_vcc(4, 3, 4)
    asm_v_mov_b32_inline_u(8, 0)
    asm_v_add_co_u32_vcc_sv(7, 6, 9)             // v7:v8 = dst ptr
    asm_v_add_co_ci_u32_null_sv_vcc(8, 7, 8)
    asm_s_mov_b32_inline_imm(12, vcopy_iter_count)   // = HEAD_DIM/32 (Qwen3=4)
    uint64 v_copy_top = asm_text_len / 4
    // global_load_b32 v13, v[3:4], off
    asm_u32(0xDC520000); asm_u32(0x0D7C0003)
    asm_s_waitcnt_vmcnt_zero()
    // global_store_b32 v[7:8], v13, off  (V copy; per-lane v7:v8 ptr)
    // word2=(0x7C<<16)|(13<<8)|7=0x007C0D07
    asm_u32(0xDC6A0000); asm_u32(0x007C0D07)
    // advance src ptr +128 bytes
    asm_u32(0xD7006A03); asm_u32(0x000206FF); asm_u32(128)
    asm_u32(0xD5207C04); asm_u32(0x01AA0880)
    // advance dst ptr +128 bytes
    asm_u32(0xD7006A07); asm_u32(0x00020EFF); asm_u32(128)
    asm_u32(0xD5207C08); asm_u32(0x01AA1080)
    asm_s_sub_u32_imm(12, 12, 1)
    asm_s_cmp_eq_u32(12, 0x80)
    uint64 v_copy_back = (0 - ((asm_text_len / 4) - v_copy_top) - 1) & 0xFFFF
    asm_s_cbranch_scc0(v_copy_back)
    // V fall-through to .phase5_done

    // ── .phase5_done: patch all forward branches ──────────────────────────
    uint64 phase5_done = asm_text_len / 4

    // Patch outer skip-branch (wg_id >= 32 → here)
    asm_patch_u32(outer_gate_pos + 1,
        0xBFA20000 | ((phase5_done - outer_gate_pos - 2) & 0xFFFF))

    // Patch Q done s_branch → .phase5_done
    asm_patch_u32(q_done_pos,
        0xBFA00000 | ((phase5_done - q_done_pos - 1) & 0xFFFF))

    // Patch K done s_branch → .phase5_done
    asm_patch_u32(k_done_pos,
        0xBFA00000 | ((phase5_done - k_done_pos - 1) & 0xFFFF))
}

// ── Phase 5 NEW SHAPE inline ISA emitter (speck4, 128 WGs flat (m, head)) ─
//
// _emit_phase5_qkv_split_qknorm_rope_speck4_inline — speck4-flavored
// phase 5: 128 WGs flat-dispatched over (m, head_kind, head_idx).
//
// Shape (Qwen3-0.6B speck4, M_EFF=4):
//   N_Q_TASKS  = M_EFF * N_HEADS    = 4*16 = 64    (wg 0..63)
//   N_K_TASKS  = M_EFF * N_KV_HEADS = 4*8  = 32    (wg 64..95)
//   N_V_TASKS  = M_EFF * N_KV_HEADS = 4*8  = 32    (wg 96..127)
//   N_TASKS    = 128                                (gate: wg_id < 128)
//
//   Q-path:  m = wg_id / 16,        head = wg_id & 15           (lshr 4 / and 15)
//   K-path:  t = wg_id - 64,  m = t / 8,  head = t & 7         (lshr 3 / and 7)
//   V-path:  t = wg_id - 96,  m = t / 8,  head = t & 7         (lshr 3 / and 7)
//
//   Q src = b_qkv_g_4 + m*QKV_DIM*4 + head*HEAD_DIM*4  = b_qkv + (m<<14) + (head<<9)
//   Q dst = b_attn_q_g_4 + m*Q_DIM*4 + head*HEAD_DIM*4 = b_attn_q + (m<<13) + (head<<9)
//   K src = b_qkv_g_4 + m*QKV_DIM*4 + Q_DIM*4 + head*HEAD_DIM*4   (Q_DIM*4=8192)
//   K dst = kc_layer + (pos_base + m)*KV_DIM*4 + head*HEAD_DIM*4  (u64 add + lshl 12)
//   V src = b_qkv_g_4 + m*QKV_DIM*4 + (Q_DIM+KV_DIM)*4 + head*HEAD_DIM*4 ((Q+KV)*4=12288)
//   V dst = vc_layer + (pos_base + m)*KV_DIM*4 + head*HEAD_DIM*4
//
//   rope_cos / rope_sin: per-m, offset = m * half * 4 = m*256 = m << 8
//
// SGPR context on entry (from prologue):
//   s[0:1]   = kernarg ptr pair
//   s[8:9]   = barrier_counter ptr  (must NOT be clobbered)
//   s[10:11] = max_phase value
//   s15      = wg_id_x (still untouched at phase 5 entry)
//   s28      = saved wg_id_x (set in prologue; not used here, but K/V store
//              positions clobber s14/s15 via rope_sin load, so downstream
//              phases 7/9/11 read s28 for their wg_id).
//
// Phase 5 SGPR usage (mirrors base — per-path mutually exclusive):
//   s[2:3]  = src base ptr (after offsets applied)
//   s[4:5]  = norm base ptr (q_norm / k_norm; unused for V)
//   s[6:7]  = dst base ptr (after offsets applied)
//   s12     = pos_base lo (loaded from kernarg 0x70) → reused as ssq/rope counter
//   s13     = m * (1<<8) for rope offset add; reused as ssq/rope counter
//   s14     = scratch for offsets / rope_cos hi; reused
//   s15     = wg_id_x → reused
//   s16     = m (per-path)
//   s17     = head (per-path)
//   s18     = pos_base hi (ld kernarg 0x74)
//   s19     = scratch
//   s[12:13]= rope_cos base (after pos committed to dst ptr setup)
//   s[14:15]= rope_sin base (s15 is free inside a branch after 3-way dispatch)
fn _emit_phase5_qkv_split_qknorm_rope_speck4_inline() {
    // ── Slice 6.1 — shape locals derived from MEGA_* arch globals ────────
    // Mirrors slice 5.3's lift on the M=1 base emitter.  All previously
    // hard-coded Qwen3 literals (head dim, N_HEADS, N_KV_HEADS, qknorm
    // bits, RoPE pair layout) are now expressed as functions of these
    // locals.  At Qwen3 settings every value below resolves to its old
    // hard-coded constant — byte-exact regression.
    uint64 q_dim_bytes        = MEGA_N_HEADS    * MEGA_HEAD_DIM * 4
    uint64 kv_dim_bytes       = MEGA_N_KV_HEADS * MEGA_HEAD_DIM * 4
    uint64 qkv_dim_bytes      = q_dim_bytes + 2 * kv_dim_bytes
    uint64 head_off_shift     = _arch_log2_pow2(MEGA_HEAD_DIM * 4)
    uint64 kv_off_shift       = _arch_log2_pow2(kv_dim_bytes)
    uint64 ssq_iter_count     = MEGA_HEAD_DIM / 32
    uint64 rope_iter_count    = MEGA_HEAD_DIM / 64
    uint64 vcopy_iter_count   = MEGA_HEAD_DIM / 32
    uint64 inv_head_dim_bits  = _arch_inv_n_f32_bits(MEGA_HEAD_DIM)
    uint64 outer_cap_speck4   = MEGA_M_EFF * (MEGA_N_HEADS + 2 * MEGA_N_KV_HEADS)
    uint64 q_cap_speck4       = MEGA_M_EFF * MEGA_N_HEADS
    uint64 k_cap_speck4       = MEGA_M_EFF * (MEGA_N_HEADS + MEGA_N_KV_HEADS)
    uint64 v_src_base_off     = q_dim_bytes + kv_dim_bytes
    uint64 n_heads_log2       = _arch_log2_pow2(MEGA_N_HEADS)
    uint64 n_kv_heads_log2    = _arch_log2_pow2(MEGA_N_KV_HEADS)
    uint64 head_mask_q        = MEGA_N_HEADS    - 1
    uint64 head_mask_kv       = MEGA_N_KV_HEADS - 1
    // RoPE pair-layout dependent fields (NEOX split-half by default; flipped
    // to NORM consecutive-pair under MEGA_ROPE_PAIR_LAYOUT == 1 — Llama).
    uint64 pair2_load_off     = 256        // NEOX: x2 lives at +HEAD_DIM/2*4 bytes
    uint64 pair2_store_off    = 256
    uint64 ptr_advance_bytes  = 128        // NEOX: src/norm/dst advance per iter
    // Per-lane byte stride into src/norm/dst for the rope pair loop.
    // NEOX (Qwen3, split-half): per-lane offset is 4 bytes (one f32).
    // NORM-pair (Llama, consecutive-pair): per-lane offset is 8 bytes.
    uint64 lane_byte_shift    = 2          // NEOX default: lane_id * 4
    if MEGA_ROPE_PAIR_LAYOUT == 1 {
        pair2_load_off    = 4
        pair2_store_off   = 4
        ptr_advance_bytes = 256
        lane_byte_shift   = 3              // NORM-pair: lane_id * 8
    }

    // ── Outer gate: skip if wg_id >= outer_cap_speck4 ────────────────────
    // SOPC s_cmp_ge_u32 s15, outer_cap_speck4.  Helper picks lit32 form
    // when v > 64 (Qwen3=128, Llama=192 both lit32).
    uint64 outer_gate_pos = asm_text_len / 4
    _emit_s_cmp_ge_u32_lit(15, outer_cap_speck4)
    // Capture position of s_cbranch_scc1 so the patch math doesn't depend
    // on whether the cmp emitted 1 or 2 dwords.
    uint64 outer_branch_pos = asm_text_len / 4
    asm_s_cbranch_scc1(0)   // forward to .phase5_done (patched at end)

    // ── Load pos_base (full 64 bits) → s[20:21] ──────────────────────────
    // We need both halves for u64 (pos_base + m). sdata_pair=10 → s[20:21].
    asm_s_load_b64_off(10, 0, 0x70)
    asm_s_waitcnt_lgkmcnt_zero()

    // ── v1 = 0 (vaddr placeholder for stores and ds ops) ─────────────────
    asm_v_mov_b32_inline_u(1, 0)

    // ── 3-way (Q | K | V) dispatch ───────────────────────────────────────
    // Q check: s_cmp_lt_u32 s15, q_cap_speck4 (= M_EFF * N_HEADS).
    // At Qwen3 q_cap_speck4=64 → 0xBF0AC00F (inline 64).
    _emit_s_cmp_lt_u32_lit(15, q_cap_speck4)
    uint64 q_gate_pos = asm_text_len / 4
    asm_s_cbranch_scc0(0)   // to .not_q if wg_id >= q_cap_speck4 (patched)

    // ════════════════════════════════════════════════════════════════════
    // Q BODY (wg_id < 64)
    //   m    = wg_id >> 4   (s_lshr_b32 s16, s15, 4)
    //   head = wg_id & 15   (s_and_b32  s17, s15, 15)
    //   src  = b_qkv_g_4 + (m << 14) + (head << 9)
    //   dst  = b_attn_q_g_4 + (m << 13) + (head << 9)
    //   norm = q_norm_g
    //   rope = rope_cos_4 + (m << 8), rope_sin_4 + (m << 8)
    // ════════════════════════════════════════════════════════════════════

    // m    = s15 >> n_heads_log2: s_lshr_b32 s16, s15, n_heads_log2
    //   SOP2 op 0x0A (gfx11), sdst=16, ssrc0=15.
    //   At Qwen3 n_heads_log2=4 → 0x8510840F.
    asm_u32(0x85100000 | ((0x80 + n_heads_log2) << 8) | 0x0F)
    // head = s15 & head_mask_q: s_and_b32 s17, s15, head_mask_q
    //   SOP2 op 0x16 (gfx11), sdst=17, ssrc0=15.
    //   At Qwen3 head_mask_q=15 → 0x8B118F0F.
    asm_u32(0x8B110000 | ((0x80 + head_mask_q) << 8) | 0x0F)

    // Load b_qkv_g_4 → s[2:3]   (kernarg 0x90)
    asm_s_load_b64_off(1, 0, 0x90)
    // Load q_norm_g → s[4:5]    (kernarg 0x40) — qknorm only.
    if MEGA_USE_QKNORM != 0 {
        asm_s_load_b64_off(2, 0, 0x40)
    }
    // Load b_attn_q_g_4 → s[6:7] (kernarg 0x98)
    asm_s_load_b64_off(3, 0, 0x98)
    asm_s_waitcnt_lgkmcnt_zero()

    // src offset: m*qkv_dim_bytes + head*HEAD_DIM*4
    // s14 = head << head_off_shift: s_lshl_b32 s14, s17, head_off_shift
    // At Qwen3 head_off_shift=9 → 0x840E8911.
    asm_u32(0x840E0011 | ((0x80 + head_off_shift) << 8))
    // s19 = m * qkv_dim_bytes (Qwen3 16384 pow2 → s_lshl 14 = 0x84138E10;
    // Llama 12288 not pow2 → s_mul_i32 s19, s16, 12288 = 9613FF10 lit=12288).
    _emit_s_mul_u32_pow2_or_lit(19, 16, qkv_dim_bytes)
    // s14 = s14 + s19: s_add_u32 s14, s14, s19
    asm_u32(0x800E130E)
    // s_add_u32  s2, s2, s14
    asm_u32(0x80020E02)
    // s_addc_u32 s3, s3, 0
    asm_u32(0x82038003)

    // dst offset: m*q_dim_bytes + head*HEAD_DIM*4
    // s19 = m * q_dim_bytes (Qwen3 8192 pow2 → s_lshl 13 = 0x84138D10).
    _emit_s_mul_u32_pow2_or_lit(19, 16, q_dim_bytes)
    // s14 = (head << head_off_shift) freshly recomputed (was overwritten above)
    asm_u32(0x840E0011 | ((0x80 + head_off_shift) << 8))
    // s14 = s14 + s19
    asm_u32(0x800E130E)
    // s_add_u32  s6, s6, s14
    asm_u32(0x80060E06)
    // s_addc_u32 s7, s7, 0
    asm_u32(0x82078007)

    // ── Q: inline rmsnorm-HEAD_DIM (qknorm only; identical to base Q body) ─
    if MEGA_USE_QKNORM != 0 {
        asm_v_mov_b32_inline_u(2, 0)
        asm_v_lshlrev_b32_imm(9, 2, 0)
        asm_v_mov_b32_inline_u(4, 0)
        asm_v_add_co_u32_vcc_sv(3, 2, 9)
        asm_v_add_co_ci_u32_null_sv_vcc(4, 3, 4)
        asm_s_mov_b32_inline_imm(12, ssq_iter_count)
        uint64 q_ssq_top = asm_text_len / 4
        asm_u32(0xDC520000); asm_u32(0x0D7C0003)
        asm_s_waitcnt_vmcnt_zero()
        asm_v_fmac_f32_e32_vv(2, 13, 13)
        asm_u32(0xD7006A03); asm_u32(0x000206FF); asm_u32(128)
        asm_u32(0xD5207C04); asm_u32(0x01AA0880)
        asm_s_sub_u32_imm(12, 12, 1)
        asm_s_cmp_eq_u32(12, 0x80)
        uint64 q_ssq_back = (0 - ((asm_text_len / 4) - q_ssq_top) - 1) & 0xFFFF
        asm_s_cbranch_scc0(q_ssq_back)
        _emit_wave_xor_reduce_add_f32_5_levels(2, 15, 16)
        asm_s_mov_b32(12, 0x7E)
        asm_u32(0x7D940080)
        asm_s_mov_b32_lit32(14, inv_head_dim_bits)        // s14 = 1/HEAD_DIM
        asm_u32(0x1004040E)
        asm_s_mov_b32_lit32(14, 0x358637BD)
        asm_u32(0x0604040E)
        asm_u32(0x7E045D02)
        asm_u32(0xD8340200); asm_u32(0x00000201)
        asm_s_mov_b32(0x7E, 12)
        asm_s_waitcnt_lgkmcnt_zero()
        asm_s_barrier()
        asm_u32(0xD8D80200); asm_u32(0x02000001)
        asm_s_waitcnt_lgkmcnt_zero()
    }

    // ── Q: load rope_cos→s[12:13], rope_sin→s[14:15], add m*256 ─────────
    // (Note: _emit_wave_xor_reduce_add_f32_5_levels uses s15 internally?
    //  Check — it doesn't; it uses VGPRs and exec only.  s16 (m) is preserved.)
    // s_load_b64 s[12:13] = rope_cos (0x50)
    asm_s_load_b64_off(6, 0, 0x50)
    // s_load_b64 s[14:15] = rope_sin (0x58)
    asm_s_load_b64_off(7, 0, 0x58)
    asm_s_waitcnt_lgkmcnt_zero()

    // Per-stream cos/sin stride = (HEAD_DIM/2) f32s = HEAD_DIM*2 bytes.
    //   Qwen3 HEAD_DIM=128 → 256 bytes/stream → shift 8 (matches old hard-coded form).
    //   Llama HEAD_DIM= 64 → 128 bytes/stream → shift 7. The previous hard-coded
    //   shift=8 made stream m=2,3 read past the rope_cos_4 buffer end, where the
    //   GPU returned zeros, so the rotation collapsed to zero and K[pos+2,3] became
    //   all-zeros — silently dropping spec-decode K writes for those streams.
    uint64 cos_off_shift = _arch_log2_pow2(MEGA_HEAD_DIM * 2)
    // m_off = m << cos_off_shift: s_lshl_b32 s19, s16, cos_off_shift
    asm_u32(0x84130010 | ((0x80 + cos_off_shift) << 8))
    // s_add_u32  s12, s12, s19  (rope_cos lo += m_off)
    asm_u32(0x800C130C)
    // s_addc_u32 s13, s13, 0
    asm_u32(0x820D800D)
    // s_add_u32  s14, s14, s19  (rope_sin lo += m_off)
    asm_u32(0x800E130E)
    // s_addc_u32 s15, s15, 0
    asm_u32(0x820F800F)

    // ── Q: RoPE pair-rotation loop (HEAD_DIM/64 iters: lane..HEAD_DIM/2 step 32) ─
    // Slice 6.7 fix mirrored from base M=1 emitter: under QKNORM=0 (Llama) the
    // qknorm block above never fired, so v9 carries a stale value from phase 1.
    // Re-emit v9 = lane << lane_byte_shift (NORM-pair → lane*8) before Q ptr setup.
    // Under QKNORM=1 (Qwen3) the qknorm block already wrote v9 = lane*4 — leave
    // alone to preserve byte-exact regression.
    if MEGA_USE_QKNORM == 0 {
        asm_v_lshlrev_b32_imm(9, lane_byte_shift, 0)
    }
    asm_v_mov_b32_inline_u(4, 0)
    asm_v_add_co_u32_vcc_sv(3, 2, 9)
    asm_v_add_co_ci_u32_null_sv_vcc(4, 3, 4)
    if MEGA_USE_QKNORM != 0 {
        asm_v_mov_b32_inline_u(6, 0)
        asm_v_add_co_u32_vcc_sv(5, 4, 9)
        asm_v_add_co_ci_u32_null_sv_vcc(6, 5, 6)
    }
    asm_v_mov_b32_inline_u(8, 0)
    asm_v_add_co_u32_vcc_sv(7, 6, 9)
    asm_v_add_co_ci_u32_null_sv_vcc(8, 7, 8)
    asm_v_lshlrev_b32_imm(17, 2, 0)
    asm_v_mov_b32_inline_u(10, 0)
    asm_v_add_co_u32_vcc_sv(9, 12, 17)
    asm_v_add_co_ci_u32_null_sv_vcc(10, 13, 10)
    asm_v_mov_b32_inline_u(12, 0)
    asm_v_add_co_u32_vcc_sv(11, 14, 17)
    asm_v_add_co_ci_u32_null_sv_vcc(12, 15, 12)
    asm_s_mov_b32_inline_imm(12, rope_iter_count)
    uint64 q_rope_top = asm_text_len / 4
    asm_u32(0xDC520000); asm_u32(0x0D7C0003)                                     // v13 = src[i]
    asm_u32(0xDC520000 | (pair2_load_off & 0xFFFF)); asm_u32(0x0E7C0003)        // v14 = src[i+pair2]
    if MEGA_USE_QKNORM != 0 {
        asm_u32(0xDC520000); asm_u32(0x0F7C0005)                                     // v15 = norm[i]
        asm_u32(0xDC520000 | (pair2_load_off & 0xFFFF)); asm_u32(0x107C0005)        // v16 = norm[i+pair2]
    }
    asm_s_waitcnt_vmcnt_zero()
    if MEGA_USE_QKNORM != 0 {
        asm_u32(0x101A1B02)
        asm_u32(0x101A1F0D)
        asm_u32(0x101C1D02)
        asm_u32(0x101C210E)
    }
    asm_u32(0xDC520000); asm_u32(0x0F7C0009)
    asm_u32(0xDC520000); asm_u32(0x107C000B)
    asm_s_waitcnt_vmcnt_zero()
    asm_u32(0x10221F0D)
    asm_u32(0x1024210E)
    asm_u32(0x08222511)
    asm_u32(0xDC6A0000); asm_u32(0x007C1107)
    asm_u32(0x1022210D)
    asm_u32(0x56221F0E)
    asm_u32(0xDC6A0000 | (pair2_store_off & 0xFFFF)); asm_u32(0x007C1107)
    asm_u32(0xD7006A03); asm_u32(0x000206FF); asm_u32(ptr_advance_bytes)         // src ptr lo
    asm_u32(0xD5207C04); asm_u32(0x01AA0880)
    if MEGA_USE_QKNORM != 0 {
        asm_u32(0xD7006A05); asm_u32(0x00020AFF); asm_u32(ptr_advance_bytes)         // norm ptr lo
        asm_u32(0xD5207C06); asm_u32(0x01AA0C80)
    }
    asm_u32(0xD7006A07); asm_u32(0x00020EFF); asm_u32(ptr_advance_bytes)         // dst ptr lo
    asm_u32(0xD5207C08); asm_u32(0x01AA1080)
    asm_u32(0xD7006A09); asm_u32(0x000212FF); asm_u32(128)                       // cos ptr lo (always 128)
    asm_u32(0xD5207C0A); asm_u32(0x01AA1480)
    asm_u32(0xD7006A0B); asm_u32(0x000216FF); asm_u32(128)                       // sin ptr lo (always 128)
    asm_u32(0xD5207C0C); asm_u32(0x01AA1880)
    asm_s_sub_u32_imm(12, 12, 1)
    asm_s_cmp_eq_u32(12, 0x80)
    uint64 q_rope_back = (0 - ((asm_text_len / 4) - q_rope_top) - 1) & 0xFFFF
    asm_s_cbranch_scc0(q_rope_back)

    // Q done: s_branch to .phase5_done (patched)
    uint64 q_done_pos = asm_text_len / 4
    asm_u32(0xBFA00000)

    // ── .not_q target: K vs V check ──────────────────────────────────────
    uint64 not_q_target = asm_text_len / 4
    asm_patch_u32(q_gate_pos, 0xBFA10000 | ((not_q_target - q_gate_pos - 1) & 0xFFFF))

    // K check: s_cmp_lt_u32 s15, k_cap_speck4 (= M_EFF * (N_HEADS+N_KV_HEADS)).
    // At Qwen3 k_cap_speck4=96 → 0xBF0AFF0F lit=96.
    _emit_s_cmp_lt_u32_lit(15, k_cap_speck4)
    uint64 k_gate_pos = asm_text_len / 4
    asm_s_cbranch_scc0(0)   // to .v_path if wg_id >= k_cap_speck4 (patched)

    // ════════════════════════════════════════════════════════════════════
    // K BODY (64 ≤ wg_id < 96)
    //   t    = wg_id - 64
    //   m    = t >> 3
    //   head = t & 7
    //   src  = b_qkv_g_4 + (m << 14) + 8192 + (head << 9)
    //   dst  = kc_layer + (pos_base + m)*KV_DIM*4 + (head << 9)
    //        = kc_layer + ((pos_base + m) << 12) + (head << 9)
    //   norm = k_norm_g
    // ════════════════════════════════════════════════════════════════════

    // t = s15 - q_cap_speck4 → s19; s_sub_u32 s19, s15, lit32
    //   word = 0x80000000|(1<<23)|(0x13<<16)|(0xFF<<8)|0x0F = 0x8093FF0F
    //   At Qwen3 q_cap_speck4=64.
    asm_u32(0x8093FF0F); asm_u32(q_cap_speck4)
    // m = s19 >> n_kv_heads_log2: s_lshr_b32 s16, s19, n_kv_heads_log2
    //   At Qwen3 n_kv_heads_log2=3 → 0x85108313.
    asm_u32(0x85100013 | ((0x80 + n_kv_heads_log2) << 8))
    // head = s19 & head_mask_kv: s_and_b32 s17, s19, head_mask_kv
    //   At Qwen3 head_mask_kv=7 → 0x8B118713.
    asm_u32(0x8B110013 | ((0x80 + head_mask_kv) << 8))

    // Load b_qkv_g_4 → s[2:3]    (kernarg 0x90)
    asm_s_load_b64_off(1, 0, 0x90)
    // Load k_norm_g → s[4:5]     (kernarg 0x48) — qknorm only.
    if MEGA_USE_QKNORM != 0 {
        asm_s_load_b64_off(2, 0, 0x48)
    }
    // Load kc_layer → s[6:7]     (kernarg 0x60)
    asm_s_load_b64_off(3, 0, 0x60)
    asm_s_waitcnt_lgkmcnt_zero()

    // src offset = m*qkv_dim_bytes + q_dim_bytes + head*HEAD_DIM*4
    // s14 = head << head_off_shift
    asm_u32(0x840E0011 | ((0x80 + head_off_shift) << 8))
    // s19 = m * qkv_dim_bytes
    _emit_s_mul_u32_pow2_or_lit(19, 16, qkv_dim_bytes)
    // s14 = s14 + s19
    asm_u32(0x800E130E)
    // s14 += q_dim_bytes (Qwen3 8192)
    asm_u32(0x800EFF0E); asm_u32(q_dim_bytes)
    // s_add_u32  s2, s2, s14
    asm_u32(0x80020E02)
    // s_addc_u32 s3, s3, 0
    asm_u32(0x82038003)

    // dst offset = (pos_base + m)*KV_DIM*4 + head*HEAD_DIM*4
    // s12 = pos_lo + m: s_add_u32 s12, s20, s16
    asm_u32(0x800C1014)
    // s13 = pos_hi + 0 + carry: s_addc_u32 s13, s21, 0
    asm_u32(0x820D8015)
    // s[12:13] <<= kv_off_shift: s_lshl_b64 s[12:13], s[12:13], kv_off_shift
    //   SOP2 op 0x09 (gfx11 s_lshl_b64).
    //   At Qwen3 kv_off_shift=12 → 0x848C8C0C.
    asm_u32(0x84000000 | (9 << 23) | (12 << 16) | ((0x80 + kv_off_shift) << 8) | 12)
    // s_add_u32  s6, s6, s12
    asm_u32(0x80060C06)
    // s_addc_u32 s7, s7, s13
    asm_u32(0x82070D07)
    // add (head << head_off_shift): s14 = head << head_off_shift
    asm_u32(0x840E0011 | ((0x80 + head_off_shift) << 8))
    // s_add_u32  s6, s6, s14
    asm_u32(0x80060E06)
    // s_addc_u32 s7, s7, 0
    asm_u32(0x82078007)

    // ── K: inline rmsnorm-HEAD_DIM (qknorm only; identical to Q body) ─────
    if MEGA_USE_QKNORM != 0 {
        asm_v_mov_b32_inline_u(2, 0)
        asm_v_lshlrev_b32_imm(9, 2, 0)
        asm_v_mov_b32_inline_u(4, 0)
        asm_v_add_co_u32_vcc_sv(3, 2, 9)
        asm_v_add_co_ci_u32_null_sv_vcc(4, 3, 4)
        asm_s_mov_b32_inline_imm(12, ssq_iter_count)
        uint64 k_ssq_top = asm_text_len / 4
        asm_u32(0xDC520000); asm_u32(0x0D7C0003)
        asm_s_waitcnt_vmcnt_zero()
        asm_v_fmac_f32_e32_vv(2, 13, 13)
        asm_u32(0xD7006A03); asm_u32(0x000206FF); asm_u32(128)
        asm_u32(0xD5207C04); asm_u32(0x01AA0880)
        asm_s_sub_u32_imm(12, 12, 1)
        asm_s_cmp_eq_u32(12, 0x80)
        uint64 k_ssq_back = (0 - ((asm_text_len / 4) - k_ssq_top) - 1) & 0xFFFF
        asm_s_cbranch_scc0(k_ssq_back)
        _emit_wave_xor_reduce_add_f32_5_levels(2, 15, 16)
        asm_s_mov_b32(12, 0x7E)
        asm_u32(0x7D940080)
        asm_s_mov_b32_lit32(14, inv_head_dim_bits)        // s14 = 1/HEAD_DIM
        asm_u32(0x1004040E)
        asm_s_mov_b32_lit32(14, 0x358637BD)
        asm_u32(0x0604040E)
        asm_u32(0x7E045D02)
        asm_u32(0xD8340200); asm_u32(0x00000201)
        asm_s_mov_b32(0x7E, 12)
        asm_s_waitcnt_lgkmcnt_zero()
        asm_s_barrier()
        asm_u32(0xD8D80200); asm_u32(0x02000001)
        asm_s_waitcnt_lgkmcnt_zero()
    }

    // ── K: load rope_cos→s[12:13], rope_sin→s[14:15], add m*cos_stride ───
    asm_s_load_b64_off(6, 0, 0x50)
    asm_s_load_b64_off(7, 0, 0x58)
    asm_s_waitcnt_lgkmcnt_zero()
    // Per-stream cos/sin stride = HEAD_DIM*2 bytes (Qwen3=256→shift 8;
    // Llama=128→shift 7).  Old hard-coded shift=8 was the latent
    // K[pos+2,3]=zero bug for HEAD_DIM=64 — same root cause as the Q-body
    // m_off fix above.
    uint64 cos_off_shift_k = _arch_log2_pow2(MEGA_HEAD_DIM * 2)
    // m_off = m << cos_off_shift_k (s16 still holds m)
    asm_u32(0x84130010 | ((0x80 + cos_off_shift_k) << 8))
    asm_u32(0x800C130C)
    asm_u32(0x820D800D)
    asm_u32(0x800E130E)
    asm_u32(0x820F800F)

    // ── K: RoPE pair-rotation loop (identical structure to Q) ────────────
    // Slice 6.7 fix mirrored from base M=1 emitter: under QKNORM=0 (Llama) the
    // qknorm block above never fired, so v9 carries a stale value from phase 1.
    if MEGA_USE_QKNORM == 0 {
        asm_v_lshlrev_b32_imm(9, lane_byte_shift, 0)
    }
    asm_v_mov_b32_inline_u(4, 0)
    asm_v_add_co_u32_vcc_sv(3, 2, 9)
    asm_v_add_co_ci_u32_null_sv_vcc(4, 3, 4)
    if MEGA_USE_QKNORM != 0 {
        asm_v_mov_b32_inline_u(6, 0)
        asm_v_add_co_u32_vcc_sv(5, 4, 9)
        asm_v_add_co_ci_u32_null_sv_vcc(6, 5, 6)
    }
    asm_v_mov_b32_inline_u(8, 0)
    asm_v_add_co_u32_vcc_sv(7, 6, 9)
    asm_v_add_co_ci_u32_null_sv_vcc(8, 7, 8)
    asm_v_lshlrev_b32_imm(17, 2, 0)
    asm_v_mov_b32_inline_u(10, 0)
    asm_v_add_co_u32_vcc_sv(9, 12, 17)
    asm_v_add_co_ci_u32_null_sv_vcc(10, 13, 10)
    asm_v_mov_b32_inline_u(12, 0)
    asm_v_add_co_u32_vcc_sv(11, 14, 17)
    asm_v_add_co_ci_u32_null_sv_vcc(12, 15, 12)
    asm_s_mov_b32_inline_imm(12, rope_iter_count)
    uint64 k_rope_top = asm_text_len / 4
    asm_u32(0xDC520000); asm_u32(0x0D7C0003)                                     // v13 = src[i]
    asm_u32(0xDC520000 | (pair2_load_off & 0xFFFF)); asm_u32(0x0E7C0003)        // v14 = src[i+pair2]
    if MEGA_USE_QKNORM != 0 {
        asm_u32(0xDC520000); asm_u32(0x0F7C0005)                                     // v15 = norm[i]
        asm_u32(0xDC520000 | (pair2_load_off & 0xFFFF)); asm_u32(0x107C0005)        // v16 = norm[i+pair2]
    }
    asm_s_waitcnt_vmcnt_zero()
    if MEGA_USE_QKNORM != 0 {
        asm_u32(0x101A1B02)
        asm_u32(0x101A1F0D)
        asm_u32(0x101C1D02)
        asm_u32(0x101C210E)
    }
    asm_u32(0xDC520000); asm_u32(0x0F7C0009)
    asm_u32(0xDC520000); asm_u32(0x107C000B)
    asm_s_waitcnt_vmcnt_zero()
    asm_u32(0x10221F0D)
    asm_u32(0x1024210E)
    asm_u32(0x08222511)
    asm_u32(0xDC6A0000); asm_u32(0x007C1107)
    asm_u32(0x1022210D)
    asm_u32(0x56221F0E)
    asm_u32(0xDC6A0000 | (pair2_store_off & 0xFFFF)); asm_u32(0x007C1107)
    asm_u32(0xD7006A03); asm_u32(0x000206FF); asm_u32(ptr_advance_bytes)         // src ptr lo
    asm_u32(0xD5207C04); asm_u32(0x01AA0880)
    if MEGA_USE_QKNORM != 0 {
        asm_u32(0xD7006A05); asm_u32(0x00020AFF); asm_u32(ptr_advance_bytes)         // norm ptr lo
        asm_u32(0xD5207C06); asm_u32(0x01AA0C80)
    }
    asm_u32(0xD7006A07); asm_u32(0x00020EFF); asm_u32(ptr_advance_bytes)         // dst ptr lo
    asm_u32(0xD5207C08); asm_u32(0x01AA1080)
    asm_u32(0xD7006A09); asm_u32(0x000212FF); asm_u32(128)                       // cos ptr lo (always 128)
    asm_u32(0xD5207C0A); asm_u32(0x01AA1480)
    asm_u32(0xD7006A0B); asm_u32(0x000216FF); asm_u32(128)                       // sin ptr lo (always 128)
    asm_u32(0xD5207C0C); asm_u32(0x01AA1880)
    asm_s_sub_u32_imm(12, 12, 1)
    asm_s_cmp_eq_u32(12, 0x80)
    uint64 k_rope_back = (0 - ((asm_text_len / 4) - k_rope_top) - 1) & 0xFFFF
    asm_s_cbranch_scc0(k_rope_back)

    // K done: s_branch to .phase5_done (patched)
    uint64 k_done_pos = asm_text_len / 4
    asm_u32(0xBFA00000)

    // ── .v_path: V body (96 ≤ wg_id < 128) ───────────────────────────────
    uint64 v_path_target = asm_text_len / 4
    asm_patch_u32(k_gate_pos, 0xBFA10000 | ((v_path_target - k_gate_pos - 1) & 0xFFFF))

    // ════════════════════════════════════════════════════════════════════
    // V BODY (96 ≤ wg_id < 128)
    //   t    = wg_id - 96
    //   m    = t >> 3
    //   head = t & 7
    //   src  = b_qkv_g_4 + (m << 14) + 12288 + (head << 9)
    //   dst  = vc_layer + ((pos_base + m) << 12) + (head << 9)
    //   passthrough copy: 128 elements / WAVE=32 → 4 iters @ +128B/iter
    // ════════════════════════════════════════════════════════════════════

    // t = s15 - k_cap_speck4 → s19; s_sub_u32 s19, s15, lit32
    //   At Qwen3 k_cap_speck4=96.
    asm_u32(0x8093FF0F); asm_u32(k_cap_speck4)
    // m = s19 >> n_kv_heads_log2 → s16
    asm_u32(0x85100013 | ((0x80 + n_kv_heads_log2) << 8))
    // head = s19 & head_mask_kv → s17
    asm_u32(0x8B110013 | ((0x80 + head_mask_kv) << 8))

    // Load b_qkv_g_4 → s[2:3] (kernarg 0x90)
    asm_s_load_b64_off(1, 0, 0x90)
    // Load vc_layer → s[6:7]   (kernarg 0x68)
    asm_s_load_b64_off(3, 0, 0x68)
    asm_s_waitcnt_lgkmcnt_zero()

    // src offset = m*qkv_dim_bytes + v_src_base_off + head*HEAD_DIM*4
    // s14 = head << head_off_shift
    asm_u32(0x840E0011 | ((0x80 + head_off_shift) << 8))
    // s19 = m * qkv_dim_bytes
    _emit_s_mul_u32_pow2_or_lit(19, 16, qkv_dim_bytes)
    asm_u32(0x800E130E)                          // s14 = s14 + s19
    asm_u32(0x800EFF0E); asm_u32(v_src_base_off) // s14 += v_src_base_off (Qwen3 12288)
    asm_u32(0x80020E02)                          // s2 += s14
    asm_u32(0x82038003)                          // s3 += carry

    // dst offset = ((pos_base + m) << kv_off_shift) + (head << head_off_shift)
    asm_u32(0x800C1014)                          // s12 = s20 + s16 (pos_lo + m)
    asm_u32(0x820D8015)                          // s13 = s21 + 0  + carry
    // s[12:13] <<= kv_off_shift: s_lshl_b64 s[12:13], s[12:13], kv_off_shift
    asm_u32(0x84000000 | (9 << 23) | (12 << 16) | ((0x80 + kv_off_shift) << 8) | 12)
    asm_u32(0x80060C06)                          // s6 += s12
    asm_u32(0x82070D07)                          // s7 += s13
    asm_u32(0x840E0011 | ((0x80 + head_off_shift) << 8))   // s14 = head << head_off_shift
    asm_u32(0x80060E06)                          // s6 += s14
    asm_u32(0x82078007)                          // s7 += carry

    // ── V: passthrough copy (HEAD_DIM/32 iters) ───────────────────────────
    asm_v_lshlrev_b32_imm(9, 2, 0)               // v9 = lane*4
    asm_v_mov_b32_inline_u(4, 0)
    asm_v_add_co_u32_vcc_sv(3, 2, 9)             // v3:v4 = src ptr
    asm_v_add_co_ci_u32_null_sv_vcc(4, 3, 4)
    asm_v_mov_b32_inline_u(8, 0)
    asm_v_add_co_u32_vcc_sv(7, 6, 9)             // v7:v8 = dst ptr
    asm_v_add_co_ci_u32_null_sv_vcc(8, 7, 8)
    asm_s_mov_b32_inline_imm(12, vcopy_iter_count)   // = HEAD_DIM/32 (Qwen3=4)
    uint64 v_copy_top = asm_text_len / 4
    asm_u32(0xDC520000); asm_u32(0x0D7C0003)     // global_load v13
    asm_s_waitcnt_vmcnt_zero()
    asm_u32(0xDC6A0000); asm_u32(0x007C0D07)     // global_store v13 → dst
    asm_u32(0xD7006A03); asm_u32(0x000206FF); asm_u32(128)   // src lo += 128
    asm_u32(0xD5207C04); asm_u32(0x01AA0880)                  // src hi
    asm_u32(0xD7006A07); asm_u32(0x00020EFF); asm_u32(128)   // dst lo += 128
    asm_u32(0xD5207C08); asm_u32(0x01AA1080)                  // dst hi
    asm_s_sub_u32_imm(12, 12, 1)
    asm_s_cmp_eq_u32(12, 0x80)
    uint64 v_copy_back = (0 - ((asm_text_len / 4) - v_copy_top) - 1) & 0xFFFF
    asm_s_cbranch_scc0(v_copy_back)
    // V fall-through to .phase5_done

    // ── .phase5_done: patch all forward branches ──────────────────────────
    uint64 phase5_done = asm_text_len / 4

    // Patch outer skip-branch (wg_id >= outer_cap_speck4 → here).
    // outer_branch_pos points at the s_cbranch_scc1 placeholder (captured
    // immediately after the cmp, regardless of whether the cmp emitted
    // 1 or 2 dwords).  Branch targets phase5_done.
    asm_patch_u32(outer_branch_pos,
        0xBFA20000 | ((phase5_done - outer_branch_pos - 1) & 0xFFFF))

    // Patch Q done s_branch → .phase5_done
    asm_patch_u32(q_done_pos,
        0xBFA00000 | ((phase5_done - q_done_pos - 1) & 0xFFFF))

    // Patch K done s_branch → .phase5_done
    asm_patch_u32(k_done_pos,
        0xBFA00000 | ((phase5_done - k_done_pos - 1) & 0xFFFF))
}

// ── Slice 8.3 path-B (2026-05-14) — software-exp polynomial helper ────────
//
// _emit_phase7_software_exp_poly_v22_from_v20 emits the CPU `exp_f32_fast`
// minimax polynomial inline as ~22 ISA dwords, replacing the single
// `v_exp_f32_e32 v22, v20` (0x7E2C4B14) when MEGA_SOFTWARE_EXP=1 AND
// MEGA_HIDDEN=3072 (Llama-3B only).
//
// Input  v20 = r = (dot * scale_attn - m) * log2(e)         (CPU's `r = x * log2_e`)
// Output v22 = exp(exp_arg) = 2^r
// Scratch v25, v26, v27, v28, v29   (all dead between v_exp and the LDS write
//   at line 5237 in base phase 7; v25 is overwritten by the immediately-
//   following v_lshlrev_b32 anyway).  Phase 7 already reserves up through
//   v25; v26..v29 are above the high-water mark and well within rsrc1=
//   0xE0AF0006 (56 VGPRs).
//
// CPU reference: std/qwen3.mlr lines 991-1054.
//   Saturation: x ∈ [-87, +88] (input domain).  Translated to post-log2e
//     domain: r_min = -87*log2e = 0xC2FB0768, r_max = +88*log2e = 0x42FDEA11
//     (numpy f32 mul of the saturated x by the same log2e bits).
//   Argument reduction: r_abs = |r|; n_abs = floor(r_abs + 0.5); n_f =
//     n_abs * sign(r);  f = r - n_f ∈ [-0.5, 0.5].
//   Horner poly: p = ((((c5*f + c4)*f + c3)*f + c2)*f + c1)*f + 1.0
//     c5=0x3AAEC3CD (0.00133335)
//     c4=0x3C1D6AF5 (0.00960802)
//     c3=0x3D635847 (0.05550411)
//     c2=0x3E75FDF0 (0.24022651)
//     c1=0x3F317218 (0.69314718)
//   2^n via bit-injection: biased = clamp(127 + n_signed, 0, 254); twoN_bits
//     = biased << 23; twoN = reinterpret_f32(twoN_bits).
//   Result: w = twoN * p.
//
// Sign handling: rather than the CPU's explicit `neg` flag branch, we extract
// the sign bit of r and XOR it into n_abs_f to produce n_f.  Result is bit-
// identical to CPU for all finite inputs (verified: for r=±0 / negative-zero
// edge case, both methods yield n_f=±0 with matching sign).
//
// Caller contract: emit ONLY when (MEGA_HIDDEN == 3072 && MEGA_SOFTWARE_EXP
// == 1).  All other archs / configurations must keep the 1-dword 0x7E2C4B14.
fn _emit_phase7_software_exp_poly_v22_from_v20() {
    // ── Step 1: saturate v20 to CPU's post-log2e range ──────────────────
    // v_max_f32_e32 v20, lit32(r_min), v20  (VOP2 op 0x10)
    //   word = (0x10<<25)|(20<<17)|(20<<9)|0xFF + lit
    asm_u32(0x202828FF)
    asm_u32(0xC2FB0768)        // r_min = -87 * log2e (f32)
    // v_min_f32_e32 v20, lit32(r_max), v20  (VOP2 op 0x0F)
    asm_u32(0x1E2828FF)
    asm_u32(0x42FDEA11)        // r_max = +88 * log2e (f32)

    // ── Step 2: extract sign / abs of r ─────────────────────────────────
    // v25 = r & 0x80000000  (sign bit, in [0, 0x80000000])
    //   v_and_b32_e64 v25, lit32, v20  (VOP3 op 0x1B; 3 dwords)
    asm_u32(0xD51B0019)
    asm_u32(0x000228FF)
    asm_u32(0x80000000)
    // v26 = r & 0x7FFFFFFF  (= |r| for all finite r; -0 → +0)
    //   v_and_b32_e64 v26, lit32, v20  (3 dwords)
    asm_u32(0xD51B001A)
    asm_u32(0x000228FF)
    asm_u32(0x7FFFFFFF)

    // ── Step 3: n_abs = floor(|r| + 0.5)  via add+truncate ──────────────
    // v27 = |r| + 0.5   (v_add_f32_e32 v27, 0.5, v26 — inline-0.5 form 0xF0)
    //   word = (3<<25)|(27<<17)|(26<<9)|0xF0 = 0x063634F0  (verified llvm-mc)
    asm_u32(0x063634F0)
    // v27 (i32) = trunc(v27)  (v_cvt_i32_f32_e32 v27, v27) — for non-neg = floor
    asm_u32(0x7E36111B)
    // v28 (f32) = float(v27)  (v_cvt_f32_i32_e32 v28, v27)
    asm_u32(0x7E380B1B)

    // ── Step 4: apply sign → n_f = sign(r) * n_abs_f  via XOR ───────────
    // v28 = v25 ^ v28  (XOR the sign bit into n_abs_f's sign field)
    //   v_xor_b32_e32 v28, v25, v28  (VOP2 op 0x1D)
    asm_u32(0x3A383919)

    // ── Step 5: f = r - n_f → v20  (v20 was r; now becomes f ∈ [-0.5, 0.5])
    // v_subrev_f32_e32 v20, v28, v20  (VOP2 op 0x05)
    //   word = (5<<25)|(20<<17)|(28<<9)|(0x100|20) = 0x0A28391C ? — verified above as 0x0A28291C
    //   Actually the encoding has v_src1 in the high bits since e32 layout
    //   is: src1<<9 | src0_enc. For v_subrev: dst = src1 - src0 (reverse).
    //   We want v20 = v20 - v28 → result = src1 - src0 with src1=v20, src0=v28.
    //   word = (5<<25)|(20<<17)|(20<<9)|(0x100|28) = 0x0A28291C  ✓
    asm_u32(0x0A28291C)

    // ── Step 6: 5-term Horner polynomial p = (((((c5*f)+c4)*f+c3)*f+c2)*f+c1)*f + 1 ──
    // CRITICAL: emit as SEPARATE v_mul_f32 + v_add_f32 (NOT v_fma_f32) so that
    // each Horner stage has TWO independent f32 roundings — matching CPU's
    // x86 MULSS + ADDSS sequence.  MLRift's FFMA peephole (src/ir.mlr) is
    // gated to fk==1 (f64 only), so CPU `c5*f + c4` compiles to mulss+addss
    // = 2 roundings.  A fused v_fma_f32 here would yield 1 rounding instead
    // and diverge in the low bit.
    //
    // v29 = c5 literal  (v_mov_b32_e32 v29, lit32)
    //   word = (0x3F<<25)|(29<<17)|(0x02<<9)|0xFF = 0x7E3A02FF
    asm_u32(0x7E3A02FF)
    asm_u32(0x3AAEC3CD)            // c5
    // Encodings (verified llvm-mc gfx1100):
    //   v_mul_f32_e32 v29, v29, v20  : 0x103A291D
    //   v_add_f32_e32 v29, lit, v29  : 0x063A3AFF + lit
    // v29 = v29 * f   then   v29 += c4
    asm_u32(0x103A291D); asm_u32(0x063A3AFF); asm_u32(0x3C1D6AF5)   // c4
    // v29 = v29 * f   then   v29 += c3
    asm_u32(0x103A291D); asm_u32(0x063A3AFF); asm_u32(0x3D635847)   // c3
    // v29 = v29 * f   then   v29 += c2
    asm_u32(0x103A291D); asm_u32(0x063A3AFF); asm_u32(0x3E75FDF0)   // c2
    // v29 = v29 * f   then   v29 += c1
    asm_u32(0x103A291D); asm_u32(0x063A3AFF); asm_u32(0x3F317218)   // c1
    // v29 = v29 * f   then   v29 += 1.0  (use inline 1.0 encoding 0xF2 in lit slot? — no, use lit32 to preserve identical 2-rounding semantics)
    asm_u32(0x103A291D); asm_u32(0x063A3AFF); asm_u32(0x3F800000)   // 1.0

    // ── Step 7: 2^n via biased-exponent bit injection ───────────────────
    // v27 currently holds n_abs as i32 (non-neg).  Apply sign: if r<0 then
    // n_signed = -n_abs else n_signed = +n_abs.  v25 holds 0x80000000 (neg)
    // or 0 (pos).  We need to negate v27 when v25 != 0.  Branchless:
    //   mask = arithmetic-shift-right of v25 by 31 → 0xFFFFFFFF if neg, 0 if pos
    //   n_signed = (v27 ^ mask) - mask
    // Even simpler path: extract the sign bit's integer value (0 or 1) and
    // do `n_signed = v27 - 2*sign*v27 + sign*0 = ...`  Cleanest: re-derive
    // from n_f (v28) which already has the correct sign and integer value:
    //   v27 = v_cvt_i32_f32(v28)   ← rounds toward zero; v28 is integer-valued
    // This re-uses the conversion path and is cleaner.  v_cvt_i32_f32 of an
    // integer-valued float is exact (no rounding error).
    asm_u32(0x7E36111C)        // v_cvt_i32_f32_e32 v27, v28

    // biased = v27 + 127   (v_add_nc_u32_e32 v27, 0x7F, v27)
    //   word = (0x25<<25)|(27<<17)|(27<<9)|0xFF = 0x4A3636FF; lit = 0x7F
    asm_u32(0x4A3636FF)
    asm_u32(0x0000007F)

    // biased = max(biased, 0)   (v_max_i32_e32 v27, 0, v27)
    //   word = (0x12<<25)|(27<<17)|(27<<9)|0x80 = 0x24363680  ✓ (probe matched)
    asm_u32(0x24363680)
    // biased = min(biased, 254)   (v_min_i32_e32 v27, 0xFE, v27)
    asm_u32(0x223636FF)
    asm_u32(0x000000FE)

    // twoN_bits = biased << 23   (v_lshlrev_b32_e32 v27, 23, v27)
    //   word = (0x18<<25)|(27<<17)|(27<<9)|(0x80|23) = 0x30363697  ✓
    asm_u32(0x30363697)

    // ── Step 8: result v22 = twoN * p   (reinterpret v27 as f32 directly) ──
    // v_mul_f32_e32 v22, v27, v29  (VOP2 op 0x08)
    //   word = (8<<25)|(22<<17)|(29<<9)|(0x100|27) = 0x102C3B1B  ✓
    asm_u32(0x102C3B1B)
}

// ── Phase 7 inline ISA emitter (attn_decode-coop) ─────────────────────────
//
// _emit_phase7_attn_decode_coop_inline — emits the cooperative-WG attn_decode
// 3-pass softmax-attention ISA INLINE (no asm_init, no s_endpgm).
//
// HIP-equivalent: `phase7_attn_decode` (HIP source removed in slice 4.19.11;
// see git pre-4.19.11 for the original C++ reference).
//
// Shape (Qwen3-0.6B): N_HEADS=16, N_KV_HEADS=8, HEAD_DIM=128, KV_DIM=1024,
//   ATTN_COOP=4 → 64 active WGs (q_head = wg_id/4, coop_idx = wg_id%4),
//   kv_head = q_head>>1, OUT_PER_WG = HEAD_DIM/ATTN_COOP = 32, WAVE=32.
//
// Bit-exactness note (CRITICAL): hipcc's compiled v1 .co uses heavily
// optimized ISA (s_clause, v_dual_*, v_div_scale_f32 / v_div_fixup_f32 IEEE
// divide for inv_sum, prefetch hints).  This emitter reproduces the
// HIP-source semantics structurally but does NOT match hipcc byte-for-byte.
// It uses a plain v_rcp_f32 for inv_sum (≈24-bit ULP, vs hipcc's ~0.5 ULP
// IEEE-correct divide via div_scale + Newton-Raphson + div_fixup).  The
// resulting b_attn_out_g floats may diverge from v1 in low bits → expect
// the slice 4.19.4 A/B gate to fail bit-exact and report BLOCKED rather
// than PASS.  This is a known limitation; full bit-exactness would require
// hand-emitting the IEEE-correct divide expansion and matching hipcc's
// instruction order verbatim.
//
// Mega-kernel SGPR context on entry (from prologue + prior phases):
//   s[0:1]   = kernarg ptr pair
//   s[8:9]   = barrier_counter ptr — MUST NOT BE CLOBBERED
//   s[10:11] = max_phase value
//   s15      = wg_id_x — MUST NOT BE CLOBBERED (used for outer gate, then
//              copied to s_q_head/s_coop_idx; never written via saveexec)
//
// Phase 7 SGPR usage:
//   s[2:3]   = b_attn_q_g + q_head*HEAD_DIM*4 (loaded + offset)
//   s[4:5]   = kc_layer + kv_head*HEAD_DIM*4
//   s[6:7]   = vc_layer + kv_head*HEAD_DIM*4
//   s[12:13] = b_attn_out_g + q_head*HEAD_DIM*4
//   s14      = pos (low 32 bits, from kernarg 0x70)
//   s16      = q_head = wg_id >> 2
//   s17      = saved-exec for lane-active gate (NOT s15!)
//   s18      = coop_idx = wg_id & 3
//   s19      = kv_head = q_head >> 1
//   s20      = q_byte_off = q_head * 512  (HEAD_DIM*4)
//   s21      = kv_byte_off = kv_head * 512
//   s22      = dim_byte_off = coop_idx * 128  (OUT_PER_WG*4)
//   s24      = t_base scalar loop counter (advances 0, 32, 64, ...)
//   s25      = t scalar (Pass 3, advances 0, 1, 2, ..., pos)
//   s26      = lds byte offset scratch (Pass 3: 4 + t*4)
//   s27      = scratch
//
// VGPR usage (within the 56-VGPR rsrc1=0xE0AF0006 budget):
//   v0       = lane id (hardware, r/o)
//   v1       = vaddr=0 placeholder for global_store
//   v2       = m (Pass 1 max accumulator → broadcast across wave)
//   v3       = q ptr lo
//   v4       = q ptr hi
//   v5       = k ptr lo (per-lane: kc_layer + lane_t*KV_DIM*4)
//   v6       = k ptr hi
//   v7       = v ptr lo (Pass 3: vc_layer + dim_byte_off + lane*4)
//   v8       = v ptr hi
//   v9       = lane*4 byte offset (constant)
//   v10      = wave-XOR reduce addr scratch
//   v11      = wave-XOR reduce tmp scratch
//   v12:v15  = Q quad (loaded per inner chunk via b128)
//   v16:v19  = K (or V) quad
//   v20      = dot accumulator / pass 3 V scratch
//   v21      = lane_t (= t_base + lane), Pass 3: out ptr lo
//   v22      = w (post-exp) / Pass 3: out ptr hi
//   v23      = ssum / inv_sum
//   v24      = acc (Pass 3 output accumulator)
//   v25      = LDS broadcast addr (Pass 3 per-iter)
//
// LDS layout: attn_w_lds[t] at byte offset 4 + t*4, for t in [0..127].
// Total LDS usage = 516 bytes (matches mega_emit_stub_kernel KD).
// Phases 1/5 use offset 512..515 as wave_tmp[0] for their rsqrt scale
// broadcast; lifetime is disjoint from phase 7's attn_w_lds reads/writes
// (a per-phase s_barrier separates them), so the byte-512 overlap with
// attn_w_lds[127] is harmless. See top-of-file LDS-layout block.
//
// Constants:
//   scale_attn = 1/sqrt(128) = 0x3DB504F3
//   log2_e     = 1.4426950408 = 0x3FB8AA3B (used for v_exp_f32 = exp2 input)
//   neg_inf_init = -1e30 = 0xF149F2CA  (HIP source: float m = -1e30f)
fn _emit_phase7_attn_decode_coop_inline() {
    // ── Arch-derived shape locals (slice 5.4 + slice 5.10) ──────────────
    // Slice 5.10: ATTN_COOP_arch = HEAD_DIM / WAVE invariant, so
    //   OUT_PER_WG = HEAD_DIM / ATTN_COOP = WAVE = 32 for every model.
    //   Qwen3 HEAD_DIM=128/WAVE=32 → ATTN_COOP=4 (unchanged; byte-exact)
    //   Llama HEAD_DIM= 64/WAVE=32 → ATTN_COOP=2 (was 4; lanes 16-31 ran past
    //                                            their coop's slot → deadlock)
    uint64 attn_coop          = MEGA_HEAD_DIM / 32   // = WAVE invariant; Qwen3=4, Llama=2
    uint64 q_to_coop_shift    = _arch_log2_pow2(attn_coop)  // log2(ATTN_COOP)
    uint64 coop_idx_mask      = attn_coop - 1               // ATTN_COOP - 1
    uint64 head_off_shift     = _arch_log2_pow2(MEGA_HEAD_DIM * 4)            // log2(HEAD_DIM*4)
    // Slice 8.1: q_to_kv_shift removed; _emit_div_kv_head handles both pow-2
    // (s_lshr) and non-pow-2 (Llama-3B ratio=3, libdivide) GQA cases.
    uint64 out_per_wg         = MEGA_HEAD_DIM / attn_coop   // = WAVE = 32 always (slice 5.10)
    uint64 out_per_wg_bytes_shift = _arch_log2_pow2(out_per_wg * 4)           // log2(OUT_PER_WG*4) = log2(128) = 7 always
    uint64 kv_off_shift       = _arch_log2_pow2(MEGA_N_KV_HEADS * MEGA_HEAD_DIM * 4)  // log2(KV_DIM*4)
    uint64 kv_dim_bytes_p7    = MEGA_N_KV_HEADS * MEGA_HEAD_DIM * 4                  // bytes per KV slot (slice 5.9)
    uint64 outer_cap          = MEGA_N_HEADS * attn_coop  // (Qwen3 16*4=64; Llama 32*2=64)
    uint64 chunk_count        = MEGA_HEAD_DIM / 4   // inner-dot chunk count
    uint64 inv_sqrt_head_bits = _arch_inv_sqrt_pow2_f32_bits(MEGA_HEAD_DIM)

    // ── Outer gate: skip if wg_id >= 64 ─────────────────────────────────
    // Use s28 (saved wg_id_x) NOT s15 — phase 5 clobbers s15 with the high
    // half of the rope_sin pointer (s_load_b64 s[14:15], 0x58), so by the
    // time phase 7 runs s15 is garbage.  s28 was set in the kernel prologue
    // from the original wg_id_x.
    // s_cmp_ge_u32 s28, outer_cap: SOPC op=0x09 (Qwen3 outer_cap=64 → 0xBF09C01C)
    // Slice 7.2: _emit_s_cmp_ge_u32_lit emits 1 dword for v<=64 (inline imm) but
    // 2 dwords for v>64 (lit32 form: 0xBF09FF1C + lit32).  Mistral outer_cap=128
    // takes the lit32 path; the s_cbranch_scc1 lives at outer_gate_pos + 2, not
    // outer_gate_pos + 1, so capture its position AFTER the cmp emit.
    _emit_s_cmp_ge_u32_lit(28, outer_cap)
    uint64 outer_gate_pos = asm_text_len / 4
    asm_s_cbranch_scc1(0)        // patched at .phase7_done

    // ── Compute q_head, coop_idx, kv_head from saved wg_id (s28) ────────
    // s16 = wg_id >> log2(ATTN_COOP)  (q_head)  ← uses s28 not s15
    // s_lshr_b32 s16, s28, q_to_coop_shift: SOP2 op 0x0A, sdst=s16=0x10, ssrc0=s28=0x1C
    //   ssrc1 = inline-imm (0x80 + shift); Qwen3 shift=2 → 0x82 (= 0x8510821C)
    //                                       Llama shift=1 → 0x81 (= 0x8510811C)
    uint64 q_to_coop_inline = 0x80 + q_to_coop_shift
    asm_u32(0x8510001C | (q_to_coop_inline << 8))
    // s18 = wg_id & (ATTN_COOP-1)  (coop_idx)  ← uses s28 not s15
    // s_and_b32 s18, s28, coop_idx_mask: SOP2 op 0x16, sdst=s18=0x12, ssrc0=s28=0x1C
    //   ssrc1 = inline-imm (0x80 + mask); Qwen3 mask=3 → 0x83 (= 0x8B12831C)
    //                                       Llama mask=1 → 0x81 (= 0x8B12811C)
    uint64 coop_idx_inline = 0x80 + coop_idx_mask
    asm_u32(0x8B12001C | (coop_idx_inline << 8))
    // s19 = q_head / gqa_ratio = kv_head.  Slice 8.1: for non-pow-2 GQA
    // (Llama-3B 24/8=3), _emit_div_kv_head emits libdivide magic; pow-2
    // archs (Qwen3, Llama-1B, Mistral) still get the same s_lshr_b32 byte.
    _emit_div_kv_head(19, 16)

    // ── Load kernarg pointers ───────────────────────────────────────────
    // s_load_b64 s[2:3], s[0:1], 0x98   (b_attn_q_g, arg 19)
    asm_s_load_b64_off(1, 0, 0x98)
    // s_load_b64 s[4:5], s[0:1], 0x60   (kc_layer, arg 12)
    asm_s_load_b64_off(2, 0, 0x60)
    // s_load_b64 s[6:7], s[0:1], 0x68   (vc_layer, arg 13)
    asm_s_load_b64_off(3, 0, 0x68)
    // s_load_b32 s14, s[0:1], 0x70      (pos low 32, arg 14 by-value u64)
    asm_s_load_b32(7, 0, 0x70)
    // s_load_b64 s[12:13], s[0:1], 0xB0 (b_attn_out_g, arg 22)
    asm_s_load_b64_off(6, 0, 0xB0)
    asm_s_waitcnt_lgkmcnt_zero()

    // ── Compute byte offsets and add to base pointers ───────────────────
    // s20 = q_head * HEAD_DIM*4 = s16 << head_off_shift (Qwen3 shift=9 → 0x84148910)
    asm_u32(0x84140010 | ((0x80 + head_off_shift) << 8))
    // s21 = kv_head * HEAD_DIM*4 = s19 << head_off_shift (Qwen3 → 0x84158913)
    asm_u32(0x84150013 | ((0x80 + head_off_shift) << 8))
    // s22 = coop_idx * OUT_PER_WG*4 = s18 << out_per_wg_bytes_shift
    //   slice 5.10: OUT_PER_WG = WAVE = 32 always, so OUT_PER_WG*4 = 128, shift = 7
    //   Qwen3: coop_idx ∈ [0..3], dim_byte_off ∈ {0,128,256,384} (covers HEAD_DIM*4=512)
    //   Llama: coop_idx ∈ [0..1], dim_byte_off ∈ {0,128}         (covers HEAD_DIM*4=256)
    //   Encoding: 0x84160012 | ((0x80 + 7) << 8) = 0x84168712 (unchanged for Qwen3)
    asm_u32(0x84160012 | ((0x80 + out_per_wg_bytes_shift) << 8))

    // s2 = s2 + s20  (b_attn_q_g += q_head*512); s3 += carry
    // SOP2 op 0 (s_add_u32): word = 0x80000000|(0x02<<16)|(0x14<<8)|0x02 = 0x80021402
    asm_u32(0x80021402)
    // s_addc_u32 s3, s3, 0
    asm_u32(0x82038003)
    // s4 = s4 + s21
    asm_u32(0x80041504)
    asm_u32(0x82058005)
    // s6 = s6 + s21
    asm_u32(0x80061506)
    asm_u32(0x82078007)
    // s12 = s12 + s20  (b_attn_out_g += q_head*512)
    asm_u32(0x800C140C)
    asm_u32(0x820D800D)

    // ── Init v2 = -1e30f (= 0xF149F2CA) ──────────────────────────────────
    asm_v_mov_b32_lit32(2, 0xF149F2CA)
    // ── v9 = lane*4 (constant byte offset) ──────────────────────────────
    asm_v_lshlrev_b32_imm(9, 2, 0)
    // ── v1 = 0 (vaddr=0 for global_store with saddr) ────────────────────
    asm_v_mov_b32_inline_u(1, 0)

    // ════════════════════════════════════════════════════════════════════
    // PASS 1 — max
    // For t_base = 0..pos step 32:
    //   per-lane lane_t = t_base + lane
    //   if lane_t > pos: skip (exec mask)
    //   k_byte_off_lo = lane_t * 4096 = lane_t << 12
    //   k_addr = s[4:5] + k_byte_off
    //   q_addr = s[2:3]  (constant)
    //   dot = sum_{i=0..127} q[i] * k[i]  (32 b128-quad loads, 128 fmacs)
    //   dot *= scale_attn
    //   m = max(m, dot)
    // wave-XOR-max reduce
    // ════════════════════════════════════════════════════════════════════

    // s24 = 0  (t_base counter)
    asm_s_mov_b32_inline_imm(24, 0)
    uint64 pass1_top = asm_text_len / 4

    // s_cmp_lt_u32 s14, s24  (SCC=1 if pos < t_base → exit)
    // SOPC op 0x0A: word = 0xBF000000|(0x0A<<16)|(0x18<<8)|0x0E = 0xBF0A180E
    asm_u32(0xBF0A180E)
    uint64 pass1_exit_pos = asm_text_len / 4
    asm_s_cbranch_scc1(0)        // patched at .pass1_end

    // ── per-lane lane_t = t_base + lane ─────────────────────────────────
    // v_add_nc_u32_e32 v21, s24, v0: VOP2 op 0x25
    //   word = (0x25<<25)|(21<<17)|(0<<9)|0x18 = 0x4A000000|0x002A0000|0x18 = 0x4A2A0018
    //   (verified via llvm-mc gfx1100)
    asm_u32(0x4A2A0018)

    // v_cmp_le_u32_e64 vcc_lo, v21, s14: VOP3 op 0x4B (NOT 0x4D — that's gt_i32)
    //   word1 = 0xD44B006A, word2 = ((s14)<<9)|(0x100|21) = (0x0E<<9)|0x115 = 0x1C00|0x115 = 0x1D15
    //   (verified via llvm-mc gfx1100)
    asm_u32(0xD44B006A)
    asm_u32(0x00001D15)

    // s_and_saveexec_b32 s17, vcc_lo  → s17 saves old exec; exec = exec & vcc_lo
    asm_s_and_saveexec_b32_vcc_lo(17)
    // s_cbranch_execz .pass1_skip  (forward; if no lane active, skip body)
    uint64 pass1_execz_pos = asm_text_len / 4
    asm_s_cbranch_execz(0)        // patched after the body

    // ── k_byte_off (lo) = v21 << kv_off_shift → v10 (Qwen3 shift=12) ─────
    asm_v_lshlrev_b32_imm(10, kv_off_shift, 21)

    // v[5:6] = s[4:5] + (v10, 0)
    asm_v_add_co_u32_vcc_sv(5, 4, 10)
    asm_v_mov_b32_inline_u(6, 0)
    asm_v_add_co_ci_u32_null_sv_vcc(6, 5, 6)

    // q ptr (constant for all lanes): v[3:4] = s[2:3] + 0
    // v_mov_b32 v3, s2; v_mov_b32 v4, s3
    asm_v_mov_b32(3, 2)
    asm_v_mov_b32(4, 3)

    // s_delay_alu (let VALU writes settle before VMEM)
    asm_s_delay_alu(0x01)

    // ── v20 = 0 (dot accumulator) ────────────────────────────────────────
    asm_v_mov_b32_inline_u(20, 0)

    // ── Inner dot: chunk_count chunks × 4 fmacs = HEAD_DIM-elem dot ──────
    uint64 chunk = 0
    while chunk < chunk_count {
        uint64 off = chunk * 16
        // global_load_b128 v[12:15], v[3:4], off  offset:(off)
        // word1 = 0xDC5E0000 | (off & 0xFFFF), word2 = (vdst<<24)|(0x7C<<16)|vaddr_lo
        //   vdst=12=0x0C, vaddr_lo=v3=3
        asm_u32(0xDC5E0000 | (off & 0xFFFF))
        asm_u32(0x0C7C0003)
        // global_load_b128 v[16:19], v[5:6], off  offset:(off)
        asm_u32(0xDC5E0000 | (off & 0xFFFF))
        asm_u32(0x107C0005)
        asm_s_waitcnt_vmcnt_zero()
        // 4 fmacs: v20 += q[i]*k[i] for i in chunk*4..chunk*4+3
        asm_v_fmac_f32_e32_vv(20, 12, 16)
        asm_v_fmac_f32_e32_vv(20, 13, 17)
        asm_v_fmac_f32_e32_vv(20, 14, 18)
        asm_v_fmac_f32_e32_vv(20, 15, 19)
        chunk = chunk + 1
    }

    // ── v20 *= scale_attn (= 1/sqrt(HEAD_DIM); Qwen3 0x3DB504F3) ─────────
    // v_mul_f32_e32 v20, lit, v20  — VOP2 op 0x08, src0=0xFF (lit32 follows)
    //   word = (8<<25)|(20<<17)|(20<<9)|0xFF = 0x10000000|0x00280000|0x00002800|0xFF = 0x102828FF
    //   (verified via llvm-mc gfx1100)
    asm_u32(0x102828FF)
    asm_u32(inv_sqrt_head_bits)

    // ── m = max(m, dot)  → v_max_f32_e32 v2, v2, v20 ─────────────────────
    // VOP2 op 0x10: word = 0x20000000|(2<<17)|(20<<9)|(0x100|2) = 0x20042902
    //   (2<<17)=0x00040000, (20<<9)=0x00002800, src0=0x102 → 0x20042902
    asm_u32(0x20042902)

    // ── .pass1_skip: restore exec ────────────────────────────────────────
    uint64 pass1_skip_target = asm_text_len / 4
    // Patch s_cbranch_execz to here
    uint64 execz_off = pass1_skip_target - pass1_execz_pos - 1
    asm_patch_u32(pass1_execz_pos, 0xBFA50000 | (execz_off & 0xFFFF))

    // s_or_b32 exec_lo, exec_lo, s17  (restore full exec)
    // word = 0x8C7E000 | (0x11<<8) | 0x7E = 0x8C7E117E
    asm_u32(0x8C7E117E)

    // s_add_u32 s24, s24, 32  (t_base += 32)
    // SOP2 op 0: word = 0x80000000|(0x18<<16)|(0xA0<<8)|0x18 = 0x8018A018
    asm_u32(0x8018A018)
    // s_branch back to pass1_top
    uint64 pass1_back_simm = (pass1_top - (asm_text_len / 4) - 1) & 0xFFFF
    asm_u32(0xBFA00000 | pass1_back_simm)

    // ── .pass1_end ───────────────────────────────────────────────────────
    uint64 pass1_end = asm_text_len / 4
    asm_patch_u32(pass1_exit_pos, 0xBFA20000 | ((pass1_end - pass1_exit_pos - 1) & 0xFFFF))

    // ── Wave-XOR-max reduce: acc=v2, addr=v10, tmp=v11 ───────────────────
    _emit_wave_xor_reduce_max_f32_5_levels(2, 10, 11)

    // ════════════════════════════════════════════════════════════════════
    // PASS 2 — sum + LDS cache
    // For t_base = 0..pos step 32 (same loop shape as pass 1):
    //   recompute dot (same i-order, same fmac sequence)
    //   exp_arg = fma(scale, dot, -m)        ← ONE fma to match HIP `dot*scale - m`
    //   exp_arg *= log2_e (= 0x3FB8AA3B)
    //   w = v_exp_f32(exp_arg)
    //   ssum += w
    //   attn_w_lds[lane_t] = w   (LDS byte offset = 4 + lane_t*4)
    // wave-XOR-add reduce
    // inv_sum = v_rcp_f32(ssum)
    // s_barrier (cross-wave LDS visibility)
    // ════════════════════════════════════════════════════════════════════

    // v23 = 0 (ssum)
    asm_v_mov_b32_inline_u(23, 0)
    // s24 = 0 (reset t_base)
    asm_s_mov_b32_inline_imm(24, 0)

    uint64 pass2_top = asm_text_len / 4

    // s_cmp_lt_u32 s14, s24  (SCC=1 if pos < t_base → exit)
    asm_u32(0xBF0A180E)
    uint64 pass2_exit_pos = asm_text_len / 4
    asm_s_cbranch_scc1(0)        // patched at .pass2_end

    // v21 = s24 + v0  (lane_t) — VOP2 op 0x25 (verified via llvm-mc gfx1100)
    asm_u32(0x4A2A0018)

    // v_cmp_le_u32_e64 vcc_lo, v21, s14 — VOP3 op 0x4B
    asm_u32(0xD44B006A)
    asm_u32(0x00001D15)

    asm_s_and_saveexec_b32_vcc_lo(17)
    uint64 pass2_execz_pos = asm_text_len / 4
    asm_s_cbranch_execz(0)

    // k offset, k ptr (same as pass 1; Qwen3 kv_off_shift=12)
    asm_v_lshlrev_b32_imm(10, kv_off_shift, 21)
    asm_v_add_co_u32_vcc_sv(5, 4, 10)
    asm_v_mov_b32_inline_u(6, 0)
    asm_v_add_co_ci_u32_null_sv_vcc(6, 5, 6)
    asm_v_mov_b32(3, 2)
    asm_v_mov_b32(4, 3)
    asm_s_delay_alu(0x01)

    asm_v_mov_b32_inline_u(20, 0)

    chunk = 0
    while chunk < chunk_count {
        uint64 off = chunk * 16
        asm_u32(0xDC5E0000 | (off & 0xFFFF))
        asm_u32(0x0C7C0003)
        asm_u32(0xDC5E0000 | (off & 0xFFFF))
        asm_u32(0x107C0005)
        asm_s_waitcnt_vmcnt_zero()
        asm_v_fmac_f32_e32_vv(20, 12, 16)
        asm_v_fmac_f32_e32_vv(20, 13, 17)
        asm_v_fmac_f32_e32_vv(20, 14, 18)
        asm_v_fmac_f32_e32_vv(20, 15, 19)
        chunk = chunk + 1
    }

    // ── exp_arg = fma(scale, dot, -m) ───────────────────────────────────
    // v_fma_f32 v20, scale_lit, v20, -v2 (VOP3 op 0x113 with src2_neg modifier)
    //   word1 = 0xD6130000 | vdst = 0xD6130014
    //   word2: src2_neg in bit 23+|29... no, modifier bits in word1: NEG[2:0] in
    //     word1 bits[63:61] in VOP3 — actually VOP3 modifiers go in word1 bits[15:11] (abs)
    //     and word2 bits[31:29] (neg). For src2_neg, word2 |= (1<<31).
    //   word2 = (src2<<18)|(src1<<9)|src0 with appropriate encodings:
    //     src0 = 0xFF (literal, scale_attn follows)
    //     src1 = 0x100|20 = 0x114 (v20)
    //     src2 = 0x100|2 = 0x102 (v2)
    //   neg src2 → word2 bit 31 = 1
    //   word2 = (1<<31)|((0x102)<<18)|(0x114<<9)|0xFF = 0x80000000|0x40800000|0x00022800|0xFF
    //         = 0x80000000 | 0x40800000 | 0x000228FF
    //         = 0xC08228FF
    // Wait — the V_FMA_F32 modifier bits: in VOP3-A, NEG[2:0] are bits [63:61]
    // (which is word2 bits [31:29]). So src2_neg sets bit 31 of word2.
    // src1_neg would set bit 30, src0_neg bit 29.
    asm_u32(0xD6130014)
    asm_u32(0x80000000 | (0x102 << 18) | (0x114 << 9) | 0xFF)
    asm_u32(inv_sqrt_head_bits)

    // ── exp_arg *= log2_e (= 0x3FB8AA3B) ────────────────────────────────
    // v_mul_f32_e32 v20, lit, v20  (verified via llvm-mc gfx1100: 0x102828FF + lit)
    asm_u32(0x102828FF)
    asm_u32(0x3FB8AA3B)

    // ── w = exp(exp_arg) → v22 ───────────────────────────────────────────
    // Default (MEGA_SOFTWARE_EXP=0): single hardware op v_exp_f32 (≈1 ULP).
    //   v_exp_f32_e32 v22, v20  (VOP1 op 0x25)
    //   word = (0x3F<<25)|(22<<17)|(0x25<<9)|(0x100|20) = 0x7E2C4B14
    // Slice 8.3 path-B: when MEGA_HIDDEN=3072 (Llama-3B only) AND
    // MEGA_SOFTWARE_EXP=1, emit the ~22-dword CPU-matching minimax poly
    // instead.  All other archs / configurations stay on the hardware op.
    if MEGA_HIDDEN == 3072 && MEGA_SOFTWARE_EXP == 1 {
        _emit_phase7_software_exp_poly_v22_from_v20()
    } else {
        asm_u32(0x7E2C4B14)
    }

    // ── ssum += w  (v23 += v22) ──────────────────────────────────────────
    // v_add_f32_e32 v23, v23, v22  (VOP2 op 0x03)
    //   word = (3<<25)|(23<<17)|(22<<9)|(0x100|23) = 0x06000000|0x002E0000|0x00002C00|0x117 = 0x062E2D17
    asm_u32(0x062E2D17)

    // ── LDS write: attn_w_lds[lane_t] = w (offset = 4 + lane_t*4) ────────
    // v_lshlrev_b32 v25, 2, v21 → lane_t * 4 (lds slot offset relative to attn_w_lds[0])
    asm_v_lshlrev_b32_imm(25, 2, 21)
    // ds_store_b32 v25, v22 offset:4
    //   word1 = 0xD8340000 | 4 = 0xD8340004
    //   word2 = (vdata<<8)|vaddr = (22<<8)|25 = 0x1619
    asm_u32(0xD8340004)
    asm_u32(0x00001619)

    // ── .pass2_skip: restore exec ────────────────────────────────────────
    uint64 pass2_skip_target = asm_text_len / 4
    asm_patch_u32(pass2_execz_pos, 0xBFA50000 | ((pass2_skip_target - pass2_execz_pos - 1) & 0xFFFF))
    asm_u32(0x8C7E117E)        // s_or_b32 exec_lo, exec_lo, s17
    asm_u32(0x8018A018)        // s_add_u32 s24, s24, 32
    uint64 pass2_back_simm = (pass2_top - (asm_text_len / 4) - 1) & 0xFFFF
    asm_u32(0xBFA00000 | pass2_back_simm)

    // ── .pass2_end ───────────────────────────────────────────────────────
    uint64 pass2_end = asm_text_len / 4
    asm_patch_u32(pass2_exit_pos, 0xBFA20000 | ((pass2_end - pass2_exit_pos - 1) & 0xFFFF))

    // ── Wave-XOR-add reduce: acc=v23, addr=v10, tmp=v11 ──────────────────
    _emit_wave_xor_reduce_add_f32_5_levels(23, 10, 11)

    // ── inv_sum = 1.0 / ssum ─────────────────────────────────────────────
    // Phase 2.7 (slice 8.2-B, 2026-05-14): gate Llama-3B onto the
    // IEEE-correct divide pipeline (matches CPU `1.0f / sum_exp` = vdivss).
    // Other archs keep the proven v_rcp_f32 byte (≈24-bit ULP) so their
    // 20/20 bit-exact A/B status is preserved.
    //
    // Scratch VGPR plan (all dead at this point — pass 2 finished writing
    // w to LDS and ssum is reduced into v23 only; pass 3 overwrites
    // v7..v8, v10..v13, v21..v26 with fresh state before any read):
    //   v_q = v23 (overwrite),  v_n = v3 (1.0f),  v_d = v4 (ssum copy)
    //   scratch: v_ds=v5, v_ns=v6, v_r=v10, v_r2=v11, v_q0=v12
    if MEGA_HIDDEN == 3072 {
        // v3 = 1.0f literal
        asm_v_mov_b32_lit32(3, 0x3F800000)
        // v4 = v23 (denominator copy — helper needs distinct v_q vs v_d)
        asm_v_mov_b32(4, 0x100 | 23)
        // IEEE-correct quotient → v23 = v3 / v4
        asm_v_div_f32_ieee(23, 3, 4, 5, 6, 10, 11, 12)
    } else {
        // v_rcp_f32_e32 v23, v23  (VOP1 op 0x2A) — baseline path
        asm_u32(0x7E2E5517)
    }

    // ── s_barrier: ensure pass-2 LDS writes from all lanes are visible ──
    asm_s_waitcnt_lgkmcnt_zero()
    asm_s_barrier()

    // ════════════════════════════════════════════════════════════════════
    // PASS 3 — cooperative output
    //   i = coop_idx*32 + lane         (per-lane output dim within head)
    //   acc = 0
    //   for t = 0..pos:
    //     w = lds[t] * inv_sum
    //     v_val = vc_layer[t][kv_head][i]
    //     acc += w * v_val
    //   b_attn_out_g[q_head*HEAD_DIM + i] = acc
    //
    // OUT_PER_WG = 32 = WAVE → all lanes active (no extra exec gate).
    // ════════════════════════════════════════════════════════════════════

    // ── Compute v[7:8] = vc_layer + kv_head*512 + coop_idx*128 + lane*4 ──
    // Build scalar base: s26 = s6 + s22 (vc_layer + dim_byte_off)
    // s_add_u32 s26, s6, s22: word = 0x80000000|(0x1A<<16)|(0x16<<8)|0x06 = 0x801A1606
    asm_u32(0x801A1606)
    // s_addc_u32 s27, s7, 0: word = 0x82000000|(0x1B<<16)|(0x80<<8)|0x07 = 0x821B8007
    asm_u32(0x821B8007)
    // v[7:8] = s[26:27] + lane*4 (v9)
    asm_v_add_co_u32_vcc_sv(7, 26, 9)
    asm_v_mov_b32_inline_u(8, 0)
    asm_v_add_co_ci_u32_null_sv_vcc(8, 27, 8)

    // ── Compute v[21:26] = b_attn_out_g + dim_byte_off + lane*4 ─────────
    // out ptr LO in v21, HI in v26 (v22 is reused below for w/inv_sum result;
    // a v_mov_b32 v22, ... in the pass-3 loop would otherwise clobber the
    // ptr-hi half, corrupting global_store_b32 v[21:?] — encode-fault-free
    // but stores to a wild address).  Pair v[21:?] is an EXPRESSION-level
    // pair: global_store_b32 with vaddr=v21 reads v21 and v22 as the pair.
    // Solution: keep ptr-hi in v26 and copy v26→v22 right before the store.
    // s26 = s12 + s22; s27 = s13 + 0
    asm_u32(0x801A160C)        // s_add_u32 s26, s12, s22
    asm_u32(0x821B800D)        // s_addc_u32 s27, s13, 0
    asm_v_add_co_u32_vcc_sv(21, 26, 9)
    asm_v_mov_b32_inline_u(26, 0)
    // hi = s27 + v26 + carry  → v26
    asm_v_add_co_ci_u32_null_sv_vcc(26, 27, 26)

    // ── v24 = 0 (acc) ────────────────────────────────────────────────────
    asm_v_mov_b32_inline_u(24, 0)
    // s25 = 0 (t counter)
    asm_s_mov_b32_inline_imm(25, 0)

    uint64 pass3_top = asm_text_len / 4

    // s_cmp_lt_u32 s14, s25  (SCC=1 if pos < t → exit)
    // word = 0xBF000000|(0x0A<<16)|(0x19<<8)|0x0E = 0xBF0A190E
    asm_u32(0xBF0A190E)
    uint64 pass3_exit_pos = asm_text_len / 4
    asm_s_cbranch_scc1(0)

    // ── Load LDS[t]*4 + 4 broadcast, ds_load with offset:4 ──────────────
    // s26/s27 are free to reuse here — at lines above they held the
    // out-ptr (b_attn_out_g + dim_byte_off), already transferred into
    // v[21:?] + v26 for the pass-3 inner loop.
    // s26 = s25 << 2  (LDS byte offset relative to base, before +4)
    // s_lshl_b32 s26, s25, 2: word = (2<<30)|(8<<23)|(0x1A<<16)|(0x82<<8)|0x19 = 0x841A8219
    asm_u32(0x841A8219)
    // v25 = s26 (broadcast scalar to vector)
    asm_v_mov_b32(25, 26)
    // ds_load_b32 v22, v25 offset:4
    //   word1 = 0xD8D80004, word2 = (vdst<<24)|(0x00<<16)|vaddr = (22<<24)|25 = 0x16000019
    asm_u32(0xD8D80004)
    asm_u32(0x16000019)
    asm_s_waitcnt_lgkmcnt_zero()

    // ── w *= inv_sum   (v22 = v22 * v23) ─────────────────────────────────
    // v_mul_f32_e32 v22, v22, v23: VOP2 op 0x08
    //   word = (8<<25)|(22<<17)|(23<<9)|(0x100|22) = 0x10000000|0x002C0000|0x00002E00|0x116 = 0x102C2F16
    asm_u32(0x102C2F16)

    // ── Load V[t][lane] ──────────────────────────────────────────────────
    // global_load_b32 v20, v[7:8], off
    //   word1 = 0xDC520000, word2 = (vdst<<24)|(0x7C<<16)|vaddr = (20<<24)|(0x7C<<16)|7 = 0x147C0007
    asm_u32(0xDC520000)
    asm_u32(0x147C0007)
    asm_s_waitcnt_vmcnt_zero()

    // ── acc += w * v_val  (v_fmac_f32 v24, v22, v20) ────────────────────
    asm_v_fmac_f32_e32_vv(24, 22, 20)

    // ── Advance v[7:8] by KV_DIM*4 bytes ─────────────────────────────────
    // Slice 5.9: was hard-coded 4096 (Qwen3 KV_DIM=1024); Llama
    // KV_DIM=512 → KV_DIM*4=2048.  Use parametric kv_dim_bytes_p7.
    // v_add_co_u32 v7, vcc_lo, lit, v7  (VOP3B op 0x100, src0=lit32, src1=v7)
    asm_u32(0xD7006A07)
    asm_u32(0x00020EFF)
    asm_u32(kv_dim_bytes_p7 & 0xFFFFFFFF)
    // v_add_co_ci_u32_e64 v8, null, 0, v8, vcc_lo
    asm_u32(0xD5207C08)
    asm_u32(0x01AA1080)

    // ── s_add_u32 s25, s25, 1 ────────────────────────────────────────────
    asm_u32(0x80198119)

    // s_branch back to pass3_top
    uint64 pass3_back_simm = (pass3_top - (asm_text_len / 4) - 1) & 0xFFFF
    asm_u32(0xBFA00000 | pass3_back_simm)

    // ── .pass3_end ───────────────────────────────────────────────────────
    uint64 pass3_end = asm_text_len / 4
    asm_patch_u32(pass3_exit_pos, 0xBFA20000 | ((pass3_end - pass3_exit_pos - 1) & 0xFFFF))

    // ── Store acc to out_ptr per-lane ────────────────────────────────────
    asm_u32(0x7E2C031A)
    asm_s_delay_alu(0x01)
    // global_store_b32 v[21:22], v24, off
    asm_u32(0xDC6A0000)
    asm_u32(0x007C1815)

    // ── .phase7_done: patch outer skip-branch ────────────────────────────
    // Slice 7.2: outer_gate_pos points at the s_cbranch_scc1 itself (set
    // AFTER the s_cmp_ge_u32 emit), so the patch indexes outer_gate_pos
    // directly and the offset is target - (pos+1).  Previously the patch
    // used outer_gate_pos+1 / -2 which only worked when the cmp took the
    // inline-imm path (outer_cap <= 64).  Mistral outer_cap=128 forces the
    // lit32 path (2 dwords) and corrupted the lit32 instead of the branch.
    uint64 phase7_done = asm_text_len / 4
    asm_patch_u32(outer_gate_pos,
        0xBFA20000 | ((phase7_done - outer_gate_pos - 1) & 0xFFFF))
}

// _emit_phase7_attn_decode_coop_speck4_inline — speck4-flavored phase 7:
// 64 active WGs (same per-(q_head, coop_idx) decomposition as base), but each
// WG processes 4 query streams via an INTERNAL m-loop with a per-m softmax
// (separate max, ssum, inv_sum) and a per-m attn_w_lds slab.
//
// Shape (Qwen3-0.6B speck4, M_EFF=4): identical per-WG layout to base —
//   q_head   = wg_id >> 2  (using saved s28; phase 5 clobbers s15)
//   coop_idx = wg_id &  3
//   kv_head  = q_head >> 1
// The new dimension is m in [0..3], iterated in a runtime s_branch loop
// (NOT static unroll — unrolled body would push .text past 80 KB).
//
// Per-m address arithmetic:
//   q_ptr   = b_attn_q_g_4   + m*Q_DIM*4       + q_head*HEAD_DIM*4
//                              =  m << 13      + (q_head << 9)
//   out_ptr = b_attn_out_g_4 + m*Q_DIM*4       + q_head*HEAD_DIM*4
//                              =  m << 13      + (q_head << 9)
//   k_ptr (per-t in pass 1/2) = kc_layer + kv_head*HEAD_DIM*4 + lane_t*KV_DIM*4
//                              (kc_layer indexes by absolute t in [0..pos_m],
//                              so the base s4 is unchanged across m; only the
//                              lane_t bound changes from pos to pos_m).
//   v_ptr (per-t in pass 3)   = vc_layer + kv_head*HEAD_DIM*4 + coop_idx*OUT_PER_WG*4 + lane*4
//                              (also indexes by absolute t — base s6 unchanged).
//   t-loop bound = pos_m = pos_base + m  (compared as u32 lane_t <= pos_m_lo;
//                              pos_base is < 2^32 in this codepath).
//
// LDS layout (per-WG, MEGA_LDS_SPECK4 = 2080 bytes):
//   bytes  0..  3 = wave_tmp[0]                   (unused by phase 7)
//   bytes  4..31  = padding
//   bytes 32..2079 = attn_w_lds[M_EFF=4][128]     per-m slab at byte 32+m*512.
// Pass-2 ds_store / pass-3 ds_load both use offset:32 (baked in) plus a
// per-iter sgpr s30 = m << 9 (= m*512) added into the v25 vaddr.
//
// SGPR allocation (mostly identical to base; new entries marked NEW):
//   s2:s3   = b_attn_q_g_4   + q_head*512  (bumped by 8192 at end of each m iter — NEW)
//   s4:s5   = kc_layer       + kv_head*512 (constant across m)
//   s6:s7   = vc_layer       + kv_head*512 (constant across m)
//   s12:s13 = b_attn_out_g_4 + q_head*512  (bumped by 8192 at end of each m iter — NEW)
//   s14     = pos_base low 32                                              NEW (was: pos)
//   s16     = q_head
//   s17     = saved-exec scratch
//   s18     = coop_idx
//   s19     = kv_head
//   s20     = q_head*512
//   s21     = kv_head*512
//   s22     = coop_idx*128
//   s23     = m loop counter [0..4)                                        NEW
//   s24     = t_base / pass-3 t counter (reused per m iter)
//   s25     = pass-3 t counter (reused per m iter)
//   s26,s27 = scratch
//   s28     = saved wg_id_x (read-only, set in prologue)
//   s29     = pos_m_lo = s14 + s23 (recomputed each m iter)                NEW
//   s30     = w_lds_off_m = s23 << 9 = m*512 (recomputed each m iter)      NEW
//
// Bit-exactness: same caveat as base — uses plain v_rcp_f32 (≈24-bit ULP)
// for inv_sum rather than hipcc's IEEE-correct div_scale + Newton-Raphson +
// div_fixup pipeline. b_attn_out_g_4 may diverge from a hipcc-compiled v1
// reference in low ULPs. The slice-4.20.4 A/B harness compares speck4 v2
// emit against speck4 v1 emit; both sides use the same MLRift codegen, so
// rcp differences cancel.
fn _emit_phase7_attn_decode_coop_speck4_inline() {
    // ── Arch-derived shape locals (slice 6.2; mirror of base slice 5.4 + 5.10) ──
    // Slice 5.10: ATTN_COOP_arch = HEAD_DIM / WAVE invariant, so
    //   OUT_PER_WG = HEAD_DIM / ATTN_COOP = WAVE = 32 for every model.
    //   Qwen3 HEAD_DIM=128/WAVE=32 → ATTN_COOP=4 (unchanged; byte-exact)
    //   Llama HEAD_DIM= 64/WAVE=32 → ATTN_COOP=2
    uint64 attn_coop              = MEGA_HEAD_DIM / 32   // = WAVE invariant
    uint64 q_to_coop_shift        = _arch_log2_pow2(attn_coop)
    uint64 coop_idx_mask          = attn_coop - 1
    uint64 head_off_shift         = _arch_log2_pow2(MEGA_HEAD_DIM * 4)
    // Slice 8.1: q_to_kv_shift removed (see _emit_div_kv_head).
    uint64 out_per_wg             = MEGA_HEAD_DIM / attn_coop   // = WAVE = 32 always
    uint64 out_per_wg_bytes_shift = _arch_log2_pow2(out_per_wg * 4)
    uint64 kv_off_shift           = _arch_log2_pow2(MEGA_N_KV_HEADS * MEGA_HEAD_DIM * 4)
    uint64 outer_cap_speck4_p7    = MEGA_N_HEADS * attn_coop  // (Qwen3 16*4=64; Llama 32*2=64)
    uint64 chunk_count            = MEGA_HEAD_DIM / 4
    uint64 inv_sqrt_head_bits     = _arch_inv_sqrt_pow2_f32_bits(MEGA_HEAD_DIM)
    uint64 q_dim_bytes_p7         = MEGA_N_HEADS * MEGA_HEAD_DIM * 4   // per-m q/out stride
    uint64 kv_dim_bytes_p7        = MEGA_N_KV_HEADS * MEGA_HEAD_DIM * 4

    // ── Outer gate: skip if wg_id >= outer_cap_speck4_p7 ─────────────────
    // Use s28 (saved wg_id_x) — speck4 phase 5 clobbers s15 via the
    // rope_sin s_load_b64 s[14:15], 0x58 just like base phase 5.
    // s_cmp_ge_u32 s28, 64: SOPC op=0x09, ssrc1=inline 64=0xC0
    //   word = 0xBF000000|(9<<16)|(0xC0<<8)|0x1C = 0xBF09C01C
    uint64 outer_gate_pos = asm_text_len / 4
    _emit_s_cmp_ge_u32_lit(28, outer_cap_speck4_p7)
    asm_s_cbranch_scc1(0)        // patched at .phase7_done

    // ── Compute q_head, coop_idx, kv_head from saved wg_id (s28) ────────
    // s16 = wg_id >> q_to_coop_shift  (q_head)
    //   Qwen3 shift=2 → 0x8510821C ; Llama shift=1 → 0x8510811C
    uint64 q_to_coop_inline = 0x80 + q_to_coop_shift
    asm_u32(0x8510001C | (q_to_coop_inline << 8))
    // s18 = wg_id & coop_idx_mask  (coop_idx)
    //   Qwen3 mask=3 → 0x8B12831C ; Llama mask=1 → 0x8B12811C
    uint64 coop_idx_inline = 0x80 + coop_idx_mask
    asm_u32(0x8B12001C | (coop_idx_inline << 8))
    // s19 = q_head / gqa_ratio  (kv_head).  Slice 8.1: pow-2 ratios keep the
    // s_lshr_b32 byte; ratio=3 (Llama-3B) uses libdivide magic.
    _emit_div_kv_head(19, 16)

    // ── Load kernarg pointers ───────────────────────────────────────────
    // s_load_b64 s[2:3], s[0:1], 0x98   (b_attn_q_g_4, arg 19)
    asm_s_load_b64_off(1, 0, 0x98)
    // s_load_b64 s[4:5], s[0:1], 0x60   (kc_layer, arg 12)
    asm_s_load_b64_off(2, 0, 0x60)
    // s_load_b64 s[6:7], s[0:1], 0x68   (vc_layer, arg 13)
    asm_s_load_b64_off(3, 0, 0x68)
    // s_load_b32 s14, s[0:1], 0x70      (pos_base low 32, arg 14 by-value u64)
    asm_s_load_b32(7, 0, 0x70)
    // s_load_b64 s[12:13], s[0:1], 0xB0 (b_attn_out_g_4, arg 22)
    asm_s_load_b64_off(6, 0, 0xB0)
    asm_s_waitcnt_lgkmcnt_zero()

    // ── Compute byte offsets and add to base pointers (CONSTANT across m) ──
    // s20 = q_head * HEAD_DIM*4 = s16 << head_off_shift (Qwen3 shift=9 → 0x84148910)
    asm_u32(0x84140010 | ((0x80 + head_off_shift) << 8))
    // s21 = kv_head * HEAD_DIM*4 = s19 << head_off_shift (Qwen3 → 0x84158913)
    asm_u32(0x84150013 | ((0x80 + head_off_shift) << 8))
    // s22 = coop_idx * OUT_PER_WG*4 = s18 << out_per_wg_bytes_shift
    //   slice 5.10: OUT_PER_WG = WAVE = 32 always, so shift = 7 → 0x84168712 (unchanged)
    asm_u32(0x84160012 | ((0x80 + out_per_wg_bytes_shift) << 8))

    // s2 = s2 + s20  (b_attn_q_g_4 += q_head*512); s3 += carry
    asm_u32(0x80021402)
    asm_u32(0x82038003)
    // s4 = s4 + s21  (kc_layer += kv_head*512)
    asm_u32(0x80041504)
    asm_u32(0x82058005)
    // s6 = s6 + s21  (vc_layer += kv_head*512)
    asm_u32(0x80061506)
    asm_u32(0x82078007)
    // s12 = s12 + s20  (b_attn_out_g_4 += q_head*512)
    asm_u32(0x800C140C)
    asm_u32(0x820D800D)

    // ── Constants outside m-loop: v9 = lane*4, v1 = 0 ────────────────────
    asm_v_lshlrev_b32_imm(9, 2, 0)
    asm_v_mov_b32_inline_u(1, 0)

    // ── Initialize m loop counter: s23 = 0 ───────────────────────────────
    asm_s_mov_b32_inline_imm(23, 0)

    // ════════════════════════════════════════════════════════════════════
    // .L_m_loop:  for m in [0, 4)
    //   - reset v2 (max) = -1e30, v23 (ssum) = 0
    //   - compute s29 = pos_m_lo = s14 + s23
    //   - compute s30 = w_lds_off_m = s23 << 9   (= m*512; ds_*_b32 offset:32 baked in)
    //   - run 3-pass softmax body using s29 for t-bound and s30 for LDS
    //   - bump s2 += 8192, s12 += 8192   (per-m q_ptr / out_ptr)
    //   - s23 += 1; if s23 < 4, branch back to .L_m_loop
    // ════════════════════════════════════════════════════════════════════
    uint64 m_loop_top = asm_text_len / 4

    // ── Reset v2 = -1e30f (= 0xF149F2CA) for this m's max accumulator ───
    asm_v_mov_b32_lit32(2, 0xF149F2CA)
    // ── Reset v23 = 0 for this m's ssum accumulator ─────────────────────
    asm_v_mov_b32_inline_u(23, 0)

    // ── s29 = s14 + s23  (pos_m_lo = pos_base_lo + m) ───────────────────
    // s_add_u32 s29, s14, s23: SOP2 op 0
    //   word = 0x80000000|(0x1D<<16)|(0x17<<8)|0x0E = 0x801D170E
    asm_u32(0x801D170E)

    // ── s30 = s23 << 9  (= m*512; per-m attn_w_lds slab base) ───────────
    // s_lshl_b32 s30, s23, 9: SOP2 op 8
    //   word = (2<<30)|(8<<23)|(0x1E<<16)|(0x89<<8)|0x17 = 0x841E8917
    asm_u32(0x841E8917)

    // ════════════════════════════════════════════════════════════════════
    // PASS 1 — max
    // For t_base = 0..pos_m step 32:
    //   per-lane lane_t = t_base + lane
    //   if lane_t > pos_m: skip (exec mask)
    //   k_byte_off_lo = lane_t * 4096 = lane_t << 12
    //   k_addr = s[4:5] + k_byte_off
    //   q_addr = s[2:3]
    //   dot = sum_{i=0..127} q[i] * k[i]   (32 b128 quads, 128 fmacs)
    //   dot *= scale_attn
    //   m = max(m, dot)
    // wave-XOR-max reduce
    // ════════════════════════════════════════════════════════════════════

    // s24 = 0  (t_base counter)
    asm_s_mov_b32_inline_imm(24, 0)
    uint64 pass1_top = asm_text_len / 4

    // s_cmp_lt_u32 s29, s24  (SCC=1 if pos_m < t_base → exit)
    //   word = 0xBF000000|(0x0A<<16)|(0x18<<8)|0x1D = 0xBF0A181D
    asm_u32(0xBF0A181D)
    uint64 pass1_exit_pos = asm_text_len / 4
    asm_s_cbranch_scc1(0)

    // v_add_nc_u32_e32 v21, s24, v0  (lane_t = t_base + lane)
    asm_u32(0x4A2A0018)

    // v_cmp_le_u32_e64 vcc_lo, v21, s29  (per-lane gate against pos_m)
    //   word1 = 0xD44B006A
    //   word2 = (s29<<9)|(0x100|21) = (0x1D<<9)|0x115 = 0x3A00|0x115 = 0x3B15
    asm_u32(0xD44B006A)
    asm_u32(0x00003B15)

    asm_s_and_saveexec_b32_vcc_lo(17)
    uint64 pass1_execz_pos = asm_text_len / 4
    asm_s_cbranch_execz(0)

    // ── k_byte_off (lo) = v21 << kv_off_shift → v10 (Qwen3 shift=12) ─────
    asm_v_lshlrev_b32_imm(10, kv_off_shift, 21)

    // v[5:6] = s[4:5] + (v10, 0)
    asm_v_add_co_u32_vcc_sv(5, 4, 10)
    asm_v_mov_b32_inline_u(6, 0)
    asm_v_add_co_ci_u32_null_sv_vcc(6, 5, 6)

    // q ptr (constant for all lanes): v[3:4] = s[2:3]
    asm_v_mov_b32(3, 2)
    asm_v_mov_b32(4, 3)
    asm_s_delay_alu(0x01)

    // ── v20 = 0 (dot accumulator) ────────────────────────────────────────
    asm_v_mov_b32_inline_u(20, 0)

    // ── Inner dot: chunk_count chunks × 4 fmacs = HEAD_DIM-elem dot ──────
    uint64 chunk = 0
    while chunk < chunk_count {
        uint64 off = chunk * 16
        // global_load_b128 v[12:15], v[3:4], off
        asm_u32(0xDC5E0000 | (off & 0xFFFF))
        asm_u32(0x0C7C0003)
        // global_load_b128 v[16:19], v[5:6], off
        asm_u32(0xDC5E0000 | (off & 0xFFFF))
        asm_u32(0x107C0005)
        asm_s_waitcnt_vmcnt_zero()
        asm_v_fmac_f32_e32_vv(20, 12, 16)
        asm_v_fmac_f32_e32_vv(20, 13, 17)
        asm_v_fmac_f32_e32_vv(20, 14, 18)
        asm_v_fmac_f32_e32_vv(20, 15, 19)
        chunk = chunk + 1
    }

    // v20 *= scale_attn = 1/sqrt(HEAD_DIM)  (Qwen3 = 0x3DB504F3)
    asm_u32(0x102828FF)
    asm_u32(inv_sqrt_head_bits)

    // m = max(m, dot)  → v_max_f32_e32 v2, v2, v20
    asm_u32(0x20042902)

    // ── .pass1_skip ─────────────────────────────────────────────────────
    uint64 pass1_skip_target = asm_text_len / 4
    uint64 execz_off1 = pass1_skip_target - pass1_execz_pos - 1
    asm_patch_u32(pass1_execz_pos, 0xBFA50000 | (execz_off1 & 0xFFFF))

    // s_or_b32 exec_lo, exec_lo, s17
    asm_u32(0x8C7E117E)
    // s_add_u32 s24, s24, 32
    asm_u32(0x8018A018)
    // s_branch back to pass1_top
    uint64 pass1_back_simm = (pass1_top - (asm_text_len / 4) - 1) & 0xFFFF
    asm_u32(0xBFA00000 | pass1_back_simm)

    // .pass1_end
    uint64 pass1_end = asm_text_len / 4
    asm_patch_u32(pass1_exit_pos, 0xBFA20000 | ((pass1_end - pass1_exit_pos - 1) & 0xFFFF))

    // Wave-XOR-max reduce: acc=v2, addr=v10, tmp=v11
    _emit_wave_xor_reduce_max_f32_5_levels(2, 10, 11)

    // ════════════════════════════════════════════════════════════════════
    // PASS 2 — sum + LDS cache (per-m slab at attn_w_lds[m] = bytes 32+m*512..)
    // ════════════════════════════════════════════════════════════════════

    // s24 = 0 (reset t_base)
    asm_s_mov_b32_inline_imm(24, 0)

    uint64 pass2_top = asm_text_len / 4

    // s_cmp_lt_u32 s29, s24  (vs pos_m)
    asm_u32(0xBF0A181D)
    uint64 pass2_exit_pos = asm_text_len / 4
    asm_s_cbranch_scc1(0)

    // v21 = s24 + v0  (lane_t)
    asm_u32(0x4A2A0018)

    // v_cmp_le_u32_e64 vcc_lo, v21, s29
    asm_u32(0xD44B006A)
    asm_u32(0x00003B15)

    asm_s_and_saveexec_b32_vcc_lo(17)
    uint64 pass2_execz_pos = asm_text_len / 4
    asm_s_cbranch_execz(0)

    // k offset, k ptr (same as pass 1)
    asm_v_lshlrev_b32_imm(10, kv_off_shift, 21)
    asm_v_add_co_u32_vcc_sv(5, 4, 10)
    asm_v_mov_b32_inline_u(6, 0)
    asm_v_add_co_ci_u32_null_sv_vcc(6, 5, 6)
    asm_v_mov_b32(3, 2)
    asm_v_mov_b32(4, 3)
    asm_s_delay_alu(0x01)

    asm_v_mov_b32_inline_u(20, 0)

    chunk = 0
    while chunk < chunk_count {
        uint64 off = chunk * 16
        asm_u32(0xDC5E0000 | (off & 0xFFFF))
        asm_u32(0x0C7C0003)
        asm_u32(0xDC5E0000 | (off & 0xFFFF))
        asm_u32(0x107C0005)
        asm_s_waitcnt_vmcnt_zero()
        asm_v_fmac_f32_e32_vv(20, 12, 16)
        asm_v_fmac_f32_e32_vv(20, 13, 17)
        asm_v_fmac_f32_e32_vv(20, 14, 18)
        asm_v_fmac_f32_e32_vv(20, 15, 19)
        chunk = chunk + 1
    }

    // exp_arg = fma(scale, dot, -m)  with scale = 1/sqrt(HEAD_DIM)
    asm_u32(0xD6130014)
    asm_u32(0x80000000 | (0x102 << 18) | (0x114 << 9) | 0xFF)
    asm_u32(inv_sqrt_head_bits)

    // exp_arg *= log2_e
    asm_u32(0x102828FF)
    asm_u32(0x3FB8AA3B)

    // w = exp(exp_arg) → v22
    asm_u32(0x7E2C4B14)

    // ssum += w (v23 += v22)
    asm_u32(0x062E2D17)

    // ── LDS write: attn_w_lds[m][lane_t] = w ─────────────────────────────
    // v25 = v21 << 2  (lane_t * 4)
    asm_v_lshlrev_b32_imm(25, 2, 21)
    // v25 = v25 + s30  (add per-m slab base m*512 via VOP2 v_add_nc_u32_e32)
    //   v_add_nc_u32_e32 v25, s30, v25: VOP2 op 0x25
    //   word = (0x25<<25)|(25<<17)|(25<<9)|0x1E = 0x4A000000|0x00320000|0x00003200|0x1E = 0x4A32321E
    asm_u32(0x4A32321E)
    // ds_store_b32 v25, v22 offset:32  (attn_w_lds base byte = 32; per-m slab via v25)
    //   word1 = 0xD8340020 (op 0x0D, offset16 = 32)
    //   word2 = (vdata<<8)|vaddr = (22<<8)|25 = 0x1619
    asm_u32(0xD8340020)
    asm_u32(0x00001619)

    // .pass2_skip
    uint64 pass2_skip_target = asm_text_len / 4
    asm_patch_u32(pass2_execz_pos, 0xBFA50000 | ((pass2_skip_target - pass2_execz_pos - 1) & 0xFFFF))
    asm_u32(0x8C7E117E)        // s_or_b32 exec_lo, exec_lo, s17
    asm_u32(0x8018A018)        // s_add_u32 s24, s24, 32
    uint64 pass2_back_simm = (pass2_top - (asm_text_len / 4) - 1) & 0xFFFF
    asm_u32(0xBFA00000 | pass2_back_simm)

    // .pass2_end
    uint64 pass2_end = asm_text_len / 4
    asm_patch_u32(pass2_exit_pos, 0xBFA20000 | ((pass2_end - pass2_exit_pos - 1) & 0xFFFF))

    // Wave-XOR-add reduce: acc=v23, addr=v10, tmp=v11
    _emit_wave_xor_reduce_add_f32_5_levels(23, 10, 11)

    // inv_sum = 1.0 / ssum
    asm_u32(0x7E2E5517)

    // s_barrier (cross-wave LDS visibility within this WG; same wave-set,
    // but the 4 coop WGs each independently barrier their own LDS — base
    // pattern unchanged, since LDS is per-WG).
    asm_s_waitcnt_lgkmcnt_zero()
    asm_s_barrier()

    // ════════════════════════════════════════════════════════════════════
    // PASS 3 — cooperative output (per-m output stream, m*Q_DIM*4 stride)
    // ════════════════════════════════════════════════════════════════════

    // ── Compute v[7:8] = vc_layer + kv_head*512 + coop_idx*128 + lane*4 ──
    // s26 = s6 + s22; s27 = s7 + 0
    asm_u32(0x801A1606)
    asm_u32(0x821B8007)
    // v[7:8] = s[26:27] + lane*4 (v9)
    asm_v_add_co_u32_vcc_sv(7, 26, 9)
    asm_v_mov_b32_inline_u(8, 0)
    asm_v_add_co_ci_u32_null_sv_vcc(8, 27, 8)

    // ── Compute v[21:?] + v26 = b_attn_out_g_4 + q_head*512 + coop_idx*128 + lane*4 ──
    //    (s12 was already bumped to b_attn_out_g_4 + q_head*512 + m*8192 at end of
    //     prev m iter, OR is at m=0 base on first iter; either way it's the
    //     correct per-m base.)
    asm_u32(0x801A160C)        // s_add_u32 s26, s12, s22
    asm_u32(0x821B800D)        // s_addc_u32 s27, s13, 0
    asm_v_add_co_u32_vcc_sv(21, 26, 9)
    asm_v_mov_b32_inline_u(26, 0)
    asm_v_add_co_ci_u32_null_sv_vcc(26, 27, 26)

    // v24 = 0 (acc)
    asm_v_mov_b32_inline_u(24, 0)
    // s25 = 0 (t counter)
    asm_s_mov_b32_inline_imm(25, 0)

    uint64 pass3_top = asm_text_len / 4

    // s_cmp_lt_u32 s29, s25  (SCC=1 if pos_m < t → exit)
    //   word = 0xBF000000|(0x0A<<16)|(0x19<<8)|0x1D = 0xBF0A191D
    asm_u32(0xBF0A191D)
    uint64 pass3_exit_pos = asm_text_len / 4
    asm_s_cbranch_scc1(0)

    // ── LDS read addr: s26 = (s25 << 2) + s30, then v25 = s26 ────────────
    // s_lshl_b32 s26, s25, 2: word = 0x841A8219
    asm_u32(0x841A8219)
    // s_add_u32 s26, s26, s30
    //   word = 0x80000000|(0x1A<<16)|(0x1E<<8)|0x1A = 0x801A1E1A
    asm_u32(0x801A1E1A)
    // v25 = s26 (broadcast scalar to vector)
    asm_v_mov_b32(25, 26)
    // ds_load_b32 v22, v25 offset:32  (attn_w_lds[m][t] = byte 32 + m*512 + t*4)
    //   word1 = 0xD8D80020 (op 0x36; offset16=32)
    //   word2 = (vdst<<24)|vaddr = (22<<24)|25 = 0x16000019
    asm_u32(0xD8D80020)
    asm_u32(0x16000019)
    asm_s_waitcnt_lgkmcnt_zero()

    // w *= inv_sum   (v22 = v22 * v23)
    asm_u32(0x102C2F16)

    // Load V[t][lane] via global_load_b32 v20, v[7:8]
    asm_u32(0xDC520000)
    asm_u32(0x147C0007)
    asm_s_waitcnt_vmcnt_zero()

    // acc += w * v_val (v_fmac_f32 v24, v22, v20)
    asm_v_fmac_f32_e32_vv(24, 22, 20)

    // Advance v[7:8] by KV_DIM*4 bytes (Qwen3=4096; Llama=2048)
    asm_u32(0xD7006A07)
    asm_u32(0x00020EFF)
    asm_u32(kv_dim_bytes_p7 & 0xFFFFFFFF)
    asm_u32(0xD5207C08)
    asm_u32(0x01AA1080)

    // s_add_u32 s25, s25, 1
    asm_u32(0x80198119)
    // s_branch back to pass3_top
    uint64 pass3_back_simm = (pass3_top - (asm_text_len / 4) - 1) & 0xFFFF
    asm_u32(0xBFA00000 | pass3_back_simm)

    // .pass3_end
    uint64 pass3_end = asm_text_len / 4
    asm_patch_u32(pass3_exit_pos, 0xBFA20000 | ((pass3_end - pass3_exit_pos - 1) & 0xFFFF))

    // Copy out-ptr-hi (v26) → v22 to form the v[21:22] pair for store.
    asm_u32(0x7E2C031A)
    asm_s_delay_alu(0x01)
    // global_store_b32 v[21:22], v24, off
    asm_u32(0xDC6A0000)
    asm_u32(0x007C1815)

    // ── Bump s2 (q ptr) and s12 (out ptr) by m_stride = Q_DIM*4 ─────────
    // Q_DIM*4 is NOT an inline constant (Qwen3=8192, Llama=8192 — coincidentally
    // identical: 16*128*4 == 32*64*4 == 8192). Use the literal-source encoding:
    // s_add_u32 sdst, ssrc0, lit32 with ssrc1 = 0xFF.
    // s_add_u32 s2, s2, q_dim_bytes_p7:
    //   word = 0x80000000|(0x02<<16)|(0xFF<<8)|0x02 = 0x8002FF02 ; lit = q_dim_bytes_p7
    asm_u32(0x8002FF02)
    asm_u32(q_dim_bytes_p7 & 0xFFFFFFFF)
    // s_addc_u32 s3, s3, 0
    asm_u32(0x82038003)
    // s_add_u32 s12, s12, q_dim_bytes_p7:
    //   word = 0x80000000|(0x0C<<16)|(0xFF<<8)|0x0C = 0x800CFF0C
    asm_u32(0x800CFF0C)
    asm_u32(q_dim_bytes_p7 & 0xFFFFFFFF)
    // s_addc_u32 s13, s13, 0
    asm_u32(0x820D800D)

    // ── m += 1; if m < 4, branch back to .L_m_loop ───────────────────────
    // s_add_u32 s23, s23, 1: SOP2 op 0; ssrc1=inline 1 = 0x81
    //   word = 0x80000000|(0x17<<16)|(0x81<<8)|0x17 = 0x80178117
    asm_u32(0x80178117)
    // s_cmp_lt_u32 s23, 4: SOPC op 0x0A; ssrc1=inline 4 = 0x84
    //   word = 0xBF000000|(0x0A<<16)|(0x84<<8)|0x17 = 0xBF0A8417
    asm_u32(0xBF0A8417)
    // s_cbranch_scc1 .L_m_loop  (back-edge)
    uint64 m_back_simm = (m_loop_top - (asm_text_len / 4) - 1) & 0xFFFF
    asm_u32(0xBFA20000 | m_back_simm)

    // ── .phase7_done: patch outer skip-branch ────────────────────────────
    uint64 phase7_done = asm_text_len / 4
    asm_patch_u32(outer_gate_pos + 1,
        0xBFA20000 | ((phase7_done - outer_gate_pos - 2) & 0xFFFF))
}

// Emit the mega-kernel body into the kernel table.
//
// Real inline ISA emitters are gated by per-phase markers in body_node:
//   slice 4.19.1 — phase 1 (rmsnorm, WG-0).
//   slice 4.19.2 — phase 3 (QKV matmul, WG<256).
//   slice 4.19.3 — phase 5 (QKV split + qknorm + RoPE, WG<32, 3-way dispatch).
//   slice 4.19.4 — phase 7 (attn_decode-coop, WG<64).
//   slice 4.19.5 — phase 9 (o_proj matmul + residual-add, WG<256).
//   slice 4.19.6 — phase 11 (post-attn rmsnorm, WG-0; reuses the phase-1
//                  WG-0-gated rmsnorm body with parameterized kernarg offsets).
//   slice 4.19.7 — phase 13 (gate_up matmul, WG<256; reuses the phase-3
//                  gemv-coop-bf16-padded-strided body with new kernarg triple).
//   slice 4.19.8 — phase 15 (silu_mul elem-strided, WG<256; NEW shape — SiLU(g)*u
//                  in-place over gu_scratch[0..FF]).
//   slice 4.19.9 — phase 17 (down_w matmul + final residual-add, WG<256; reuses
//                  the phase-9 gemv-residual-fused body with new kernarg quad).
//                  LAST phase — no trailing mega_barrier.
// All real-emit phases now landed; mega-kernel v2 is full forward.
//
// max_phase early-exit simm16 values: every phase boundary 0..7 is patched
// dynamically (body sizes vary across recognizer outcomes).
//
// KD parameters match the v1 reference: MEGA_KERNARG_COUNT args, 192-byte
// kernarg segment, rsrc2=0x9E (wg_id_x in s15), MEGA_WG_PERSIST=512.
// LDS=516 (wave_tmp[1]=4B + attn_w_lds[128]=512B = 516B).

fn mega_emit_stub_kernel(uint64 kname_ptr, uint64 nl, uint64 body_node) -> uint64 {
    asm_init()

    // ── Prologue ──────────────────────────────────────────────────────────
    asm_s_load_b64_off(4, 0, 0x78)   // s[8:9]  = barrier_counter ptr (arg 15)
    asm_s_load_b64_off(5, 0, 0xB8)   // s[10:11]= max_phase value     (arg 23)
    asm_s_waitcnt_lgkmcnt_zero()
    // Save wg_id_x (s15) → s28 BEFORE any phase that could clobber s15.
    // Phase 5's `s_load_b64 s[14:15], ..., 0x58` (rope_sin) overwrites s15
    // mid-kernel, so phase 7's outer-gate test against s15 would compare a
    // pointer-high half to 64 and skip the entire phase 7 body for every WG
    // (zero output).  s28 is unused by phases 1, 3, 5 (verified by disasm),
    // so it serves as a safe save slot for the original wg_id_x.
    asm_s_mov_b32(28, 15)            // s28 = wg_id_x (preserved across phases)

    // ── Phase 1: input rmsnorm (WG-0 gated) ──────────────────────────────
    // Kernarg layout: in=in_residual(arg 0, 0x00), norm=in_norm_g(arg 6, 0x30),
    //                 out=b_x_norm_g(arg 17, 0x88).  wg_id_x is still in s15
    //                 (no prior phase has clobbered it yet).
    if _body_has_rmsnorm_wg0_marker(body_node) != 0 {
        // Slice 8.4 (2026-05-15): cputree dispatch removed for Llama-3B.
        // The slice 8.2-B work tried to match MLRift CPU's reduction
        // tree; reframe on 2026-05-14 proved CPU is the wrong reference
        // (GPU already matches PyTorch).  Cputree variant added ~7×
        // per-layer overhead with zero token impact — strict regression.
        _emit_rmsnorm_wg_gated_inline(0x00, 0x30, 0x88, 15, 0)
    } else {
        asm_u32(0xBF800000)   // s_nop 0 (phase 1 stub)
    }
    mega_emit_barrier_isa(0, MEGA_WG_PERSIST)

    // max_phase < 1 check — simm16 patched after measuring phase 3 + remaining stubs.
    // Placeholder: emit s_cmp + s_cbranch_scc1 with simm16=0; patch below.
    asm_s_cmp_lt_u32(10, 0x81)
    uint64 mp1_cbranch_pos = asm_text_len / 4
    asm_s_cbranch_scc1(0)

    // ── Phase 3: QKV matmul (WG < 256) ────────────────────────────────────
    if _body_has_qkv_matmul_marker(body_node) != 0 {
        // w=qkv_w(0x10, pair 1=s[2:3]), x=b_x_norm_g(0x88, pair 2=s[4:5]),
        // out=b_qkv_g(0x90, pair 3=s[6:7]).  wg_id_x=s15 (phase 5 hasn't run yet).
        // wg_active=256: 256 of the 512 MEGA_WG_PERSIST WGs participate.
        // Slice 4.19.7 generalized this emitter (was _emit_phase3_qkv_matmul_inline)
        // so phase 13 can reuse it with a different kernarg byte-offset triple.
        // Slice 5.2: shape args derived from arch globals.
        //   qkv_dim    = N_HEADS*HEAD_DIM + 2*N_KV_HEADS*HEAD_DIM
        //              = 16*128 + 2*8*128 = 4096 (Qwen3); 32*64+2*8*64=3072 (Llama)
        //   hidden_pad = HIDDEN + 128 = 1152 (Qwen3); 2176 (Llama)
        uint64 hidden_pad = MEGA_HIDDEN + 128
        uint64 qkv_dim    = MEGA_N_HEADS*MEGA_HEAD_DIM + 2*MEGA_N_KV_HEADS*MEGA_HEAD_DIM
        // Slice 8.4 (2026-05-15): cputree/fp32 dispatch removed — slice 8.2-B + 8.3
        // were built on the inverted "GPU vs CPU" premise the 2026-05-14 reframe
        // collapsed.  All archs now share the proven unrolled bf16-coop emit.
        _emit_gemv_coop_bf16_padded_strided_inline(qkv_dim, MEGA_HIDDEN, hidden_pad, 256,
                                                   1, 2, 3,
                                                   0x10, 0x88, 0x90, 15)
    } else {
        asm_u32(0xBF800000)   // s_nop 0 (phase 3 stub)
    }
    mega_emit_barrier_isa(1, MEGA_WG_PERSIST)

    // max_phase < 2 check — phase 5 body size varies; patch after emitting phase 5.
    asm_s_cmp_lt_u32(10, 0x82)
    uint64 mp2_cbranch_pos = asm_text_len / 4
    asm_s_cbranch_scc1(0)   // patched below after measuring phase 5 + remaining stubs

    // ── Phase 5: QKV split + qknorm + RoPE (3-way head dispatch, WG < 32) ──
    if _body_has_qkv_split_qknorm_rope_marker(body_node) != 0 {
        _emit_phase5_qkv_split_qknorm_rope_inline()
    } else {
        asm_u32(0xBF800000)   // s_nop 0 (phase 5 stub)
    }
    mega_emit_barrier_isa(2, MEGA_WG_PERSIST)
    asm_s_cmp_lt_u32(10, 0x83)
    uint64 mp3_cbranch_pos = asm_text_len / 4
    asm_s_cbranch_scc1(0)   // patched below

    // ── Phase 7: attn_decode-coop (WG < 64) ───────────────────────────────
    if _body_has_attn_decode_coop_marker(body_node) != 0 {
        _emit_phase7_attn_decode_coop_inline()
    } else {
        asm_u32(0xBF800000)   // s_nop 0 (phase 7 stub)
    }
    mega_emit_barrier_isa(3, MEGA_WG_PERSIST)
    asm_s_cmp_lt_u32(10, 0x84)
    uint64 mp4_cbranch_pos = asm_text_len / 4
    asm_s_cbranch_scc1(0)   // patched below

    // ── Phase 9: o_proj matmul + residual-add (WG < 256) ──────────────────
    // Kernarg layout: w=o_w(arg 3, 0x18), x=b_attn_out_g(arg 22, 0xB0),
    //                 res=in_residual(arg 0, 0x00), out=b_mid_g(arg 20, 0xA0).
    // Shapes: n_out=1024 (HIDDEN), k=2048 (Q_DIM), k_pad=2176 (Q_DIM_PAD),
    //         wg_active=256.
    // Marker recognized inline (no `_body_has_oproj_residual_marker` wrapper)
    // because adding one would overflow the bootstrap's 1024-fn cap. Phases
    // 11-17 will each have a similar marker; once the cap is bumped (or the
    // bootstrap rebuilt), a future polish pass can restore the wrapper for
    // symmetry with phases 1/3/5/7.
    //
    // Slice 7.9 (2026-05-17): Mistral path (MEGA_HIDDEN==4096) splits this
    // phase into (multi-acc gemv → cross-WG barrier → residual-add).  The
    // monolithic emitter wedged the KFD queue when multi-acc was applied to
    // its lane-0 residual-load+add+store epilogue (slice 7.7 F1/F4 evidence);
    // the split lets the gemv body match phase 3's proven shape (multi-acc
    // → plain store).  Other archs (Llama-1B/3B, Qwen3) keep the monolithic
    // path with single-acc bodies — they have not been re-validated against
    // the split, and the constraint is to keep their byte-identical baseline.
    //
    // Mistral split uses b_attn_q_g (kernarg 0x98) as the intermediate buffer
    // (dead after phase 7; size q_dim*4 = 4096*4 = HIDDEN*4 = MEGA_HIDDEN*4
    // bytes — exact match for the gemv output size).
    //
    // Barrier renumbering for Mistral path:
    //   barrier 4 = "phase-9 gemv done"  (NEW for split)
    //   barrier 5 = "phase-9 residual-add done"  (shifted from 4 → 5)
    //   barrier 6 = phase 11 done  (shifted from 5)
    //   barrier 7 = phase 13 done  (shifted from 6)
    //   barrier 8 = phase 15 done  (shifted from 7)
    //   barrier 9 = "phase-17 gemv done"  (NEW for split)
    //   phase-17 residual-add has no trailing barrier (last phase).
    // Max threshold under split = 10 * 512 = 5120 ≤ 0xFFFF.
    uint64 is_mistral_split = 0
    if MEGA_HIDDEN == 4096 { is_mistral_split = 1 }

    if _body_has_marker(body_node, "oproj_residual_marker", 21) != 0 {
        // Slice 5.5: shape args derived from arch globals.
        //   q_dim     = N_HEADS*HEAD_DIM = 16*128 = 2048 (Qwen3); 32*64 = 2048 (Llama)
        //   q_dim_pad = q_dim + 128      = 2176 (Qwen3); 2176 (Llama)
        uint64 q_dim     = MEGA_N_HEADS * MEGA_HEAD_DIM
        uint64 q_dim_pad = q_dim + 128
        if is_mistral_split != 0 {
            // Mistral phase-9 split: gemv → barrier → residual-add.
            // Gemv writes to b_attn_q_g (kernarg 0x98, dead since phase 7).
            // Same emitter as phase 3 — multi-acc + tree-reduce + plain store.
            //   w=o_w(0x18), x=b_attn_out_g(0xB0), out=b_attn_q_g(0x98).
            _emit_gemv_coop_bf16_padded_strided_inline(MEGA_HIDDEN, q_dim, q_dim_pad, 256,
                                                       1, 2, 3,
                                                       0x18, 0xB0, 0x98, 28)
            // Barrier 4: gemv stores complete + visible to all WGs.
            mega_emit_barrier_isa(4, MEGA_WG_PERSIST)
            // Residual-add: out[i] = b_attn_q_g[i] + in_residual[i] → b_mid_g[i].
            //   a=b_attn_q_g(0x98), b=in_residual(0x00), out=b_mid_g(0xA0).
            _emit_residual_add_inline(MEGA_HIDDEN, 0x98, 0x00, 0xA0)
        } else {
            // Slice 8.4 (2026-05-15): cputree dispatch collapsed — see phase-3 note.
            _emit_phase9_gemv_residual_inline(MEGA_HIDDEN, q_dim, q_dim_pad, 256,
                                                0x18, 0xB0, 0x00, 0xA0)
        }
    } else {
        asm_u32(0xBF800000)   // s_nop 0 (phase 9 stub)
        if is_mistral_split != 0 {
            // Keep barrier count parity with the active-marker Mistral path
            // so subsequent barrier indices line up.  Without this the stub
            // path would have a different barrier index sequence and shift
            // every downstream barrier's threshold, which the marker-active
            // path's runtime would deadlock on.  In practice this stub path
            // is unreachable for production drivers (markers are always
            // present in mistral_layer_megakernel.mlr), but keep it correct
            // for completeness.
            mega_emit_barrier_isa(4, MEGA_WG_PERSIST)
        }
    }
    // "phase-9 done" barrier (idx 4 normal, idx 5 for Mistral split — the
    // Mistral path already emitted barrier 4 between gemv and residual-add).
    uint64 b_phase9_done = 4
    if is_mistral_split != 0 { b_phase9_done = 5 }
    mega_emit_barrier_isa(b_phase9_done, MEGA_WG_PERSIST)
    asm_s_cmp_lt_u32(10, 0x85)
    uint64 mp5_cbranch_pos = asm_text_len / 4
    asm_s_cbranch_scc1(0)

    // ── Phase 11: post_norm rmsnorm (WG-0 gated, N=1024) ──────────────────
    // Kernarg layout: in=b_mid_g(arg 20, 0xA0), norm=post_norm_g(arg 7, 0x38),
    //                 out=b_mid_norm_g(arg 21, 0xA8).  Reuses the WG-0-gated
    //                 rmsnorm body shared with phase 1 (slice 4.19.6
    //                 parameterized the kernarg byte offsets + wg_id_x SGPR).
    // wg_id_x lives in s28 here — phase 5's rope_sin load clobbered s15
    // mid-kernel; the prologue saves the original s15→s28 for downstream
    // phases (same constraint that forced phase 9 to read s28).
    // Marker recognized inline (no `_body_has_post_norm_marker` wrapper) —
    // same fn-table-cap discipline as oproj_residual_marker at slice 4.19.5.
    if _body_has_marker(body_node, "post_norm_marker", 16) != 0 {
        // Slice 8.4 (2026-05-15): cputree dispatch collapsed — see phase-1 note.
        _emit_rmsnorm_wg_gated_inline(0xA0, 0x38, 0xA8, 28, 0)
    } else {
        asm_u32(0xBF800000)   // s_nop 0 (phase 11 stub)
    }
    // Slice 7.9: barrier idx 5 normal, idx 6 for Mistral split (renumbered).
    uint64 b_phase11_done = 5
    if is_mistral_split != 0 { b_phase11_done = 6 }
    mega_emit_barrier_isa(b_phase11_done, MEGA_WG_PERSIST)
    asm_s_cmp_lt_u32(10, 0x86)
    uint64 mp6_cbranch_pos = asm_text_len / 4
    asm_s_cbranch_scc1(0)

    // ── Phase 13: gate_up matmul (WG < 256) ───────────────────────────────
    // Kernarg layout: w=gate_up_w(arg 4, 0x20), x=b_mid_norm_g(arg 21, 0xA8),
    //                 out=gu_scratch(arg 16, 0x80).  Reuses the
    //                 gemv-coop-bf16-padded-strided body shared with phase 3
    //                 (slice 4.19.7 generalized the emitter).
    // Shapes: n_out=6144 (= 2*FF), k=1024 (HIDDEN), k_pad=1152 (HIDDEN_PAD),
    //         wg_active=256.  ROWS_PER_WG = ceil(6144/256) = 24.
    // wg_id_x lives in s28 here — phase 5's rope_sin load clobbered s15
    // mid-kernel; the prologue saves the original s15→s28 for downstream
    // phases (same constraint that forced phases 9 / 11 to read s28).
    // Marker recognized inline (no `_body_has_gate_up_matmul_marker` wrapper)
    // — same fn-table-cap discipline as oproj_residual_marker / post_norm_marker.
    if _body_has_marker(body_node, "gate_up_matmul_marker", 21) != 0 {
        // Slice 5.2: 2*FF and HIDDEN/HIDDEN_PAD derived from arch globals.
        //   2*MEGA_FF = 6144 (Qwen3); 16384 (Llama)
        //   hidden_pad = HIDDEN + 128 = 1152 (Qwen3); 2176 (Llama)
        uint64 hidden_pad = MEGA_HIDDEN + 128
        // Slice 8.4 (2026-05-15): cputree dispatch collapsed — see phase-3 note.
        _emit_gemv_coop_bf16_padded_strided_inline(2 * MEGA_FF, MEGA_HIDDEN, hidden_pad, 256,
                                                    1, 2, 3,
                                                    0x20, 0xA8, 0x80, 28)
    } else {
        asm_u32(0xBF800000)   // s_nop 0 (phase 13 stub)
    }
    // Slice 7.9: barrier idx 6 normal, idx 7 for Mistral split (renumbered).
    uint64 b_phase13_done = 6
    if is_mistral_split != 0 { b_phase13_done = 7 }
    mega_emit_barrier_isa(b_phase13_done, MEGA_WG_PERSIST)
    asm_s_cmp_lt_u32(10, 0x87)
    uint64 mp7_cbranch_pos = asm_text_len / 4
    asm_s_cbranch_scc1(0)

    // ── Phase 15: SiLU(gate) * up, in-place over gu_scratch[0..FF] ────────
    // FF=3072, wg_active=256, WAVE=32 → 8192 lane-slots, ELEMS_PER_WG=1.
    // wg_id_x lives in s28 (phase 5 already clobbered s15; prologue stashed
    // the original wg_id_x to s28 for downstream phases — same constraint
    // that forced phases 9 / 11 / 13 to read s28).
    // Math (per element idx):
    //   g = gu_scratch[idx]; u = gu_scratch[FF+idx]
    //   gu_scratch[idx] = (g/(1+exp(-g))) * u  =  silu(g) * u
    // SGPRs: s[2:3] = gu_scratch ptr (loaded from kernarg byte 0x80),
    //        s14 = log2(e) literal scratch / shift result,
    //        s17 = saved exec_lo for the per-lane idx<FF gate.
    // VGPRs: v0 = lane id (r/o); v2 = idx; v3 = byte_off_g = idx*4;
    //        v4 = byte_off_u = byte_off_g + FF*4; v8 = g; v9 = u;
    //        v10 = silu/exp scratch.
    // gfx11 hazards: every VALU result feeding VMEM gets s_delay_alu instid0(VALU_DEP_1).
    // SiLU compose mirrors standalone silu_mul_3a (format_amdgpu.mlr ~13839):
    //   log2(e) → v_mul_f32_e64 NEG-src0 → v_exp_f32 → v_add_f32 1.0 →
    //   v_rcp_f32 → v_mul_f32 g (silu) → v_mul_f32 u.
    // Marker recognized inline; body inlined here (no wrapper fn) per fn-
    // table-cap discipline (slice 4.19.5/6/7 convention; adding a wrapper
    // here would push the bootstrap over the 1024-fn cap).
    if _body_has_marker(body_node, "silu_mul_elem_strided_marker", 28) != 0 {
        // ── WG gate: skip if wg_id (s28) >= ceil(MEGA_FF/32) ──────────────
        // Slice 7.2d: was hardcoded 256 (matched Llama FF=8192 / 32 = 256
        // exactly, Qwen3 FF=3072 / 32 = 96 fit under cap). Mistral FF=14336
        // needs 448 WGs — with 256 only the first 8192 of 14336 elements
        // got silu_mul'd, leaving gate values in gu_scratch[8192..14335]
        // which propagated through phase 17 (down) and corrupted out_resid.
        // s_cmp_ge_u32 s28, lit (SOPC op 0x09, ssrc1=0xFF=lit32 follows)
        uint64 p15_wg_count = (MEGA_FF + 31) / 32
        uint64 p15_wg_gate_pos = asm_text_len / 4
        asm_u32(0xBF09FF1C)         // s_cmp_ge_u32 s28, lit
        asm_u32(p15_wg_count & 0xFFFFFFFF)
        asm_s_cbranch_scc1(0)       // patched at .phase15_done

        // ── Load gu_scratch base ptr → s[2:3] ─────────────────────────────
        asm_s_load_b64_off(1, 0, 0x80)
        asm_s_waitcnt_lgkmcnt_zero()

        // ── Compute idx = wg_id*32 + lane = (s28<<5) + v0 → v2 ────────────
        // s_lshl_b32 s14, s28, 5: SOP2 op 0x08
        //   word = (2<<30)|(8<<23)|(0x0E<<16)|(0x85<<8)|0x1C = 0x840E851C
        asm_u32(0x840E851C)
        // v_add_nc_u32_e32 v2, s14, v0: VOP2 op 0x25
        //   word = (0x25<<25)|(2<<17)|(0<<9)|0x0E = 0x4A04000E
        asm_u32(0x4A04000E)
        // v_lshlrev_b32_e32 v3, 2, v2: byte_off_g = idx*4
        asm_v_lshlrev_b32_imm(3, 2, 2)

        // ── Per-lane gate: skip if idx >= MEGA_FF ────────────────────────
        // v_cmp_gt_u32_e32 vcc_lo, MEGA_FF, v2 → vcc_lo = (MEGA_FF > idx) = (idx < MEGA_FF)
        //   word1 = (0x3E<<25)|(0x4C<<17)|(2<<9)|0xFF = 0x7C9804FF
        asm_u32(0x7C9804FF)
        asm_u32(MEGA_FF)
        // s_and_saveexec_b32 s17, vcc_lo  (s17 = old exec; exec &= vcc_lo)
        asm_s_and_saveexec_b32_vcc_lo(17)
        // s_cbranch_execz .phase15_lane_done (patched after body)
        uint64 p15_lane_execz_pos = asm_text_len / 4
        asm_s_cbranch_execz(0)

        // ── byte_off_u = byte_off_g + FF*4 → v4 ───────────────────────────
        // v_add_nc_u32_e32 v4, lit, v3: VOP2 op 0x25, src0=0xFF (lit follows)
        //   word1 = (0x25<<25)|(4<<17)|(3<<9)|0xFF = 0x4A0806FF
        asm_u32(0x4A0806FF)
        asm_u32(MEGA_FF * 4)
        asm_s_delay_alu(0x01)       // VALU→VMEM hazard

        // ── Load g (= gu_scratch[byte_off_g]) and u (= gu_scratch[byte_off_u]) ─
        // global_load_b32 v8, v3, s[2:3]: word2 = (8<<24)|(2<<16)|3 = 0x08020003
        asm_u32(0xDC520000)
        asm_u32(0x08020003)
        // global_load_b32 v9, v4, s[2:3]: word2 = (9<<24)|(2<<16)|4 = 0x09020004
        asm_u32(0xDC520000)
        asm_u32(0x09020004)
        asm_s_waitcnt_vmcnt_zero()

        // ── SiLU compose: silu(g) = g / (1 + exp(-g)) ────────────────────
        // s_mov_b32 s14, log2(e) = 0x3FB8AA3B (literal-32 form)
        asm_s_mov_b32_lit32(14, 0x3FB8AA3B)
        // v_mul_f32_e64 v10, -v8, s14 → v10 = -g * log2(e)
        //   word1 = 0xD508_000A
        //   word2 = NEG_src0 (bit 29) | (s14<<9) | (0x100|8) = 0x2000_1D08
        asm_u32(0xD508000A)
        asm_u32(0x20001D08)
        // v_exp_f32_e32 v10, v10 → v10 = exp2(-g*log2e) = exp(-g)
        //   VOP1 op 0x4B: word = 0x7E14_4B0A
        asm_u32(0x7E144B0A)
        // v_add_f32_e32 v10, 1.0, v10 → v10 = 1 + exp(-g)
        //   VOP2 op 0x03, src0 = 0xF2 (inline +1.0 f32): word = 0x06141 4F2
        asm_u32(0x061414F2)
        // v_rcp_f32_e32 v10, v10 → v10 = 1/(1+exp(-g)) = sigmoid(g)
        //   VOP1 op 0x55: word = 0x7E14_550A
        asm_u32(0x7E14550A)
        // v_mul_f32_e32 v8, v8, v10 → v8 = g * sigmoid(g) = silu(g)
        //   VOP2 op 0x08, src0 = (0x100|v8) = 0x108: word = 0x1010_1508
        asm_u32(0x10101508)
        // v_mul_f32_e32 v8, v8, v9 → v8 = silu(g) * u
        //   word = 0x1010_1308
        asm_u32(0x10101308)

        // ── Store back to gu_scratch[byte_off_g] ─────────────────────────
        asm_s_delay_alu(0x01)       // VALU→VMEM hazard
        // global_store_b32 v3, v8, s[2:3]: word2 = (2<<16)|(8<<8)|3 = 0x00020803
        asm_u32(0xDC6A0000)
        asm_u32(0x00020803)
        asm_s_waitcnt_vscnt_zero()  // drain store before exec restore

        // ── .phase15_lane_done: patch the per-lane skip target + restore exec ─
        uint64 p15_lane_done = asm_text_len / 4
        uint64 p15_lane_off = p15_lane_done - p15_lane_execz_pos - 1
        asm_patch_u32(p15_lane_execz_pos, 0xBFA50000 | (p15_lane_off & 0xFFFF))
        // s_or_b32 exec_lo, exec_lo, s17 (restore full exec for the WG)
        asm_u32(0x8C7E117E)

        // ── Patch WG gate skip-branch to here (.phase15_done) ────────────
        // p15_wg_gate_pos points at s_cmp (2 dwords); s_cbranch_scc1 is at +2.
        uint64 p15_wg_body_dwords = (asm_text_len / 4) - (p15_wg_gate_pos + 3)
        asm_patch_u32(p15_wg_gate_pos + 2, 0xBFA20000 | (p15_wg_body_dwords & 0xFFFF))
    } else {
        asm_u32(0xBF800000)   // s_nop 0 (phase 15 stub)
    }
    // Slice 7.9: barrier idx 7 normal, idx 8 for Mistral split (renumbered).
    uint64 b_phase15_done = 7
    if is_mistral_split != 0 { b_phase15_done = 8 }
    mega_emit_barrier_isa(b_phase15_done, MEGA_WG_PERSIST)

    // ── Phase 17: down_w matmul + final residual-add (WG < 256) ───────────
    // Kernarg layout: w=down_w(arg 5, 0x28), x=gu_scratch(arg 16, 0x80),
    //                 res=b_mid_g(arg 20, 0xA0), out=out_residual(arg 1, 0x08).
    // Reuses the gemv-residual-fused body shared with phase 9 (slice 4.19.5
    // emitter — _emit_phase9_gemv_residual_inline).
    // Shapes: n_out=1024 (HIDDEN), k=3072 (FF), k_pad=3200 (FF_PAD),
    //         wg_active=256.  ROWS_PER_WG = ceil(1024/256) = 4.
    // wg_id_x lives in s28 here — phase 5's rope_sin load clobbered s15
    // mid-kernel; the prologue saves the original s15→s28 for downstream
    // phases.  The shared emitter hardcodes s28 internally (phase-17 uses
    // the same saved register as phase 9 / 11 / 13 / 15).
    // Marker recognized inline (no `_body_has_down_residual_marker` wrapper)
    // — same fn-table-cap discipline as oproj_residual_marker /
    // post_norm_marker / gate_up_matmul_marker / silu_mul_elem_strided_marker.
    // Phase 17 is the LAST phase: no trailing mega_emit_barrier_isa(8, ...)
    // because no later phase reads phase 17's output.  Control falls through
    // to s_endpgm directly.
    //
    // Slice 7.9 (2026-05-17): Mistral path splits this phase identically to
    // phase 9 — gemv (multi-acc + plain store, writes to b_attn_q_g 0x98)
    // → cross-WG barrier (idx 9) → residual-add (b_attn_q_g + b_mid_g →
    // out_residual).  Phase-17 residual-add has no trailing barrier (last
    // phase; control falls through to s_endpgm).  b_attn_q_g is still dead
    // here (phase 7 was last to read it; phase 9 gemv reused it and the
    // phase-9 residual-add was its last read).
    if _body_has_marker(body_node, "down_residual_marker", 20) != 0 {
        // Slice 5.5: shape args derived from arch globals.
        //   ff_pad = MEGA_FF + 128 = 3200 (Qwen3); 8320 (Llama)
        uint64 ff_pad = MEGA_FF + 128
        if is_mistral_split != 0 {
            // Gemv-only: writes to b_attn_q_g (kernarg 0x98), reusing phase-3
            // shape.  w=down_w(0x28), x=gu_scratch(0x80), out=b_attn_q_g(0x98).
            _emit_gemv_coop_bf16_padded_strided_inline(MEGA_HIDDEN, MEGA_FF, ff_pad, 256,
                                                       1, 2, 3,
                                                       0x28, 0x80, 0x98, 28)
            // Barrier 9: gemv stores complete + visible to all WGs.
            mega_emit_barrier_isa(9, MEGA_WG_PERSIST)
            // Residual-add: out[i] = b_attn_q_g[i] + b_mid_g[i] → out_residual[i].
            //   a=b_attn_q_g(0x98), b=b_mid_g(0xA0), out=out_residual(0x08).
            _emit_residual_add_inline(MEGA_HIDDEN, 0x98, 0xA0, 0x08)
        } else {
            _emit_phase9_gemv_residual_inline(MEGA_HIDDEN, MEGA_FF, ff_pad, 256,
                                                0x28, 0x80, 0xA0, 0x08)
        }
    } else {
        asm_u32(0xBF800000)   // s_nop 0 (phase 17 stub)
    }

    // .Lend:
    asm_s_endpgm()

    // ── Patch all max_phase branches to .Lend ─────────────────────────────
    uint64 endpgm_pos = (asm_text_len / 4) - 1   // s_endpgm is the last dword

    // max_phase < 1 (after barrier 0)
    uint64 mp1_simm16 = (endpgm_pos - mp1_cbranch_pos - 1) & 0xFFFF
    asm_patch_u32(mp1_cbranch_pos, 0xBFA20000 | mp1_simm16)

    // max_phase < 2 (after barrier 1 + phase 5)
    uint64 mp2_simm16 = (endpgm_pos - mp2_cbranch_pos - 1) & 0xFFFF
    asm_patch_u32(mp2_cbranch_pos, 0xBFA20000 | mp2_simm16)

    // max_phase < 3 (after barrier 2)
    uint64 mp3_simm16 = (endpgm_pos - mp3_cbranch_pos - 1) & 0xFFFF
    asm_patch_u32(mp3_cbranch_pos, 0xBFA20000 | mp3_simm16)

    // max_phase < 4 (after barrier 3)
    uint64 mp4_simm16 = (endpgm_pos - mp4_cbranch_pos - 1) & 0xFFFF
    asm_patch_u32(mp4_cbranch_pos, 0xBFA20000 | mp4_simm16)

    // max_phase < 5 (after barrier 4)
    uint64 mp5_simm16 = (endpgm_pos - mp5_cbranch_pos - 1) & 0xFFFF
    asm_patch_u32(mp5_cbranch_pos, 0xBFA20000 | mp5_simm16)

    // max_phase < 6 (after barrier 5)
    uint64 mp6_simm16 = (endpgm_pos - mp6_cbranch_pos - 1) & 0xFFFF
    asm_patch_u32(mp6_cbranch_pos, 0xBFA20000 | mp6_simm16)

    // max_phase < 7 (after barrier 6)
    uint64 mp7_simm16 = (endpgm_pos - mp7_cbranch_pos - 1) & 0xFFFF
    asm_patch_u32(mp7_cbranch_pos, 0xBFA20000 | mp7_simm16)

    // ── Snapshot ISA and register in kernel table ──────────────────────────
    uint64 k_text_size = asm_text_len
    uint64 k_text_buf  = alloc(k_text_size)
    uint64 ci = 0
    while ci < k_text_size {
        uint64 sp = asm_text_buf + ci
        uint64 b = 0
        unsafe { *(sp as uint8) -> b }
        uint64 dp = k_text_buf + ci
        uint8 b8 = b
        unsafe { *(dp as uint8) = b8 }
        ci = ci + 1
    }

    // MEGA_KERNARG_COUNT-arg descriptor: args 14 (pos) and 23 (max_phase) are
    // by-value; all others are global_buffer pointers.
    uint64 args_desc = alloc(MEGA_KERNARG_COUNT * 16)
    uint64 ai = 0
    while ai < MEGA_KERNARG_COUNT {
        uint64 sz_p   = args_desc + ai * 16
        uint64 kind_p = args_desc + ai * 16 + 8
        unsafe { *(sz_p as uint64) = 8 }
        if ai == 14 {
            unsafe { *(kind_p as uint64) = AMD_ARG_KIND_BY_VALUE }
        } else if ai == 23 {
            unsafe { *(kind_p as uint64) = AMD_ARG_KIND_BY_VALUE }
        } else {
            unsafe { *(kind_p as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
        }
        ai = ai + 1
    }

    // KD: rsrc1 = 0xE0AF0006 (56 VGPRs = (6+1)*8, matches v1 HIP-compiled kernel)
    // Phase 1 uses v0..v11 (12 VGPRs); future phases will use more.
    // Using 56 VGPRs here to match the v1 reference and leave room for all phases.
    // rsrc2 = 0x9E (USER_SGPR_COUNT=15, wg_id_x in s15)
    // rsrc3 = 0x10 (standard)
    // props = 0x0408 (wave32, kernarg_ptr)
    // LDS = 516 (matches v1: wave_tmp[1]=4B + attn_w_lds[128]=512B = 516B)
    uint64 rsrc1 = 0xE0AF0006
    uint64 rsrc2 = 0x0000009E
    uint64 rsrc3 = 0x00000010
    uint64 props = 0x0408

    kt_push_lds(kname_ptr, nl, k_text_buf, k_text_size,
                args_desc, MEGA_KERNARG_COUNT, 192,
                16, 3,
                rsrc1, rsrc2, rsrc3, props,
                516)
    return 0
}

// Top-level AST-walking recognizer for the qwen3_layer_megakernel @kernel.
//
// Slice 4.19.0: validates the 24-parameter signature and body block
// shape, then delegates to mega_emit_stub_kernel to produce the stub .co.
// Later slices replace mega_emit_stub_kernel with real phase emitters.
//
// Returns 0 on match (kernel emitted), 1 on shape mismatch (caller
// should fall through to other recognizers).
fn recognize_megakernel_swiglu_dense_gqa(uint64 fn_node, uint64 source,
                                          uint64 kname_ptr, uint64 nl) -> uint64 {
    // Slice 5.0: select arch preset by kernel name before any shape/body
    // checks so subsequent slices (5.1+) can read globals during emit.
    megakernel_dispatch_arch(kname_ptr, nl)

    // ── shape: exactly MEGA_KERNARG_COUNT params ──────────────────────────
    uint64 n_params = 0
    uint64 wp = ast_child(fn_node)
    while wp != 0 {
        n_params = n_params + 1
        wp = ast_next(wp)
    }
    if n_params != MEGA_KERNARG_COUNT { return 1 }

    // ── shape: body is a non-empty Block ─────────────────────────────────
    uint32 body = ast_data3(fn_node)
    if body == 0 { return 1 }
    if ast_kind(body) != AST_KIND_BLOCK { return 1 }

    return mega_emit_stub_kernel(kname_ptr, nl, body)
}

// ──────────────────────────────────────────────────────────────────────────
// Slice 4.20.0 — speck4 mega-kernel scaffold
// ──────────────────────────────────────────────────────────────────────────
//
// mega_emit_stub_kernel_speck4 emits a structurally-valid stub .co for the
// M_EFF=4 multi-query mega-kernel.  All 9 phases are `s_nop 0` placeholders;
// the 8 cross-WG barriers and max_phase early-exit guards are real (cloned
// from mega_emit_stub_kernel).  Slice 4.20.1+ replaces the per-phase stubs
// with real m-loop wrappers / m4 variants / new emitters.
//
// Differences vs mega_emit_stub_kernel:
//   - LDS=2080 (vs base 516) — phase 7 needs attn_w_lds[M_EFF*128]=2048B.
//   - All 9 marker checks use *_speck4_marker names (inlined via
//     _body_has_marker; no per-marker wrappers, slice 4.19.5 fn-table-cap
//     discipline carried forward).
//   - All 9 phases are s_nop stubs at slice 4.20.0; real emit added in
//     subsequent slices (4.20.1..4.20.7).
fn mega_emit_stub_kernel_speck4(uint64 kname_ptr, uint64 nl, uint64 body_node) -> uint64 {
    asm_init()

    // ── Prologue ──────────────────────────────────────────────────────────
    asm_s_load_b64_off(4, 0, 0x78)   // s[8:9]  = barrier_counter ptr (arg 15)
    asm_s_load_b64_off(5, 0, 0xB8)   // s[10:11]= max_phase value     (arg 23)
    asm_s_waitcnt_lgkmcnt_zero()
    // Save wg_id_x (s15) → s28 BEFORE any phase that could clobber s15.
    // Same hazard as base: phase 5's `s_load_b64 s[14:15], ..., 0x58` for
    // rope_sin will overwrite s15 once the real emitter ships at slice 4.20.3.
    // s28 is unused by phases 1, 3, 5; safe save slot for the original wg_id_x.
    asm_s_mov_b32(28, 15)            // s28 = wg_id_x (preserved across phases)

    // ── Phase 1: input rmsnorm × M_EFF (WG-0 gated) ──────────────────────
    // Slice 4.20.1: m4 wrapper around _emit_rmsnorm_wg_gated_inline (4
    // streams, per-m base = base_kofs + m*HIDDEN*4 bytes).  Kernarg layout
    // identical to base mega: in=in_residual_4(arg 0, 0x00),
    // norm=in_norm_g(arg 6, 0x30), out=b_x_norm_g_4(arg 17, 0x88).
    // wg_id_x is in s15 here (no prior phase has clobbered it yet).
    if _body_has_marker(body_node, "rmsnorm_wg0_speck4_marker", 25) != 0 {
        _emit_rmsnorm_wg_gated_m4_inline(0x00, 0x30, 0x88, 15)
    } else {
        asm_u32(0xBF800000)   // s_nop 0 (phase 1 stub)
    }
    mega_emit_barrier_isa(0, MEGA_WG_PERSIST)

    asm_s_cmp_lt_u32(10, 0x81)
    uint64 mp1_cbranch_pos = asm_text_len / 4
    asm_s_cbranch_scc1(0)

    // ── Phase 3: QKV matmul × M_EFF (WG < 256) ────────────────────────────
    // Slice 4.20.2: m4 gemv variant (4 accumulators / 4 output stores per
    // weight-row read).  Shape (n_out=4096, k=1024, k_pad=1152, wg_active=256).
    // Kernarg layout: w=qkv_w(0x10, sgpr pair 1), x=b_x_norm_g_4(0x88, pair 2),
    // out=b_qkv_g_4(0x90, pair 3).  wg_id_x is in s15 here (no prior phase
    // has clobbered s15 yet — phase 1 only touches s2/s4/s6 sgpr pairs).
    if _body_has_marker(body_node, "qkv_matmul_speck4_marker", 24) != 0 {
        // Slice 5.2: shape args derived from arch globals (matches base mega).
        uint64 hidden_pad = MEGA_HIDDEN + 128
        uint64 qkv_dim    = MEGA_N_HEADS*MEGA_HEAD_DIM + 2*MEGA_N_KV_HEADS*MEGA_HEAD_DIM
        _emit_gemv_coop_bf16_padded_strided_m4_inline(qkv_dim, MEGA_HIDDEN, hidden_pad, 256,
                                                       1, 2, 3,
                                                       0x10, 0x88, 0x90, 15)
    } else {
        asm_u32(0xBF800000)   // s_nop 0 (phase 3 stub)
    }
    mega_emit_barrier_isa(1, MEGA_WG_PERSIST)

    asm_s_cmp_lt_u32(10, 0x82)
    uint64 mp2_cbranch_pos = asm_text_len / 4
    asm_s_cbranch_scc1(0)

    // ── Phase 5: QKV split + qknorm + RoPE (WG < 128, flat (m, head)) ────
    // Slice 4.20.0: stub.  Slice 4.20.3 emits the speck4 phase-5 NEW shape
    // (128 WGs = M_EFF*32, decompose wg_id → (m, head) via div/mod).
    if _body_has_marker(body_node, "qkv_split_qknorm_rope_speck4_marker", 35) != 0 {
        _emit_phase5_qkv_split_qknorm_rope_speck4_inline()
    } else {
        asm_u32(0xBF800000)   // s_nop 0 (phase 5 stub)
    }
    mega_emit_barrier_isa(2, MEGA_WG_PERSIST)
    asm_s_cmp_lt_u32(10, 0x83)
    uint64 mp3_cbranch_pos = asm_text_len / 4
    asm_s_cbranch_scc1(0)

    // ── Phase 7: attn_decode-coop with internal m-loop (WG < 64) ─────────
    // Slice 4.20.4: emits the new phase-7 speck4 emitter (3-pass body
    // wrapped in a runtime s_branch loop over m in [0..4); attn_w_lds slab
    // at byte 32+m*512; per-m softmax with separate max/ssum/inv_sum;
    // q_ptr / out_ptr bumped by Q_DIM*4=8192 between iters).
    if _body_has_marker(body_node, "attn_decode_coop_speck4_marker", 30) != 0 {
        _emit_phase7_attn_decode_coop_speck4_inline()
    } else {
        asm_u32(0xBF800000)   // s_nop 0 (phase 7 stub)
    }
    mega_emit_barrier_isa(3, MEGA_WG_PERSIST)
    asm_s_cmp_lt_u32(10, 0x84)
    uint64 mp4_cbranch_pos = asm_text_len / 4
    asm_s_cbranch_scc1(0)

    // ── Phase 9: o_proj matmul + residual-add × M_EFF (WG < 256) ─────────
    // Slice 4.20.5: m4 gemv-residual variant.  Shape (n_out=1024 HIDDEN,
    // k=2048 Q_DIM, k_pad=2176, wg_active=256).  Kernarg layout:
    // w=o_w(0x18, sgpr pair 1), x=b_attn_out_g_4(0xB0, pair 2),
    // res=in_residual_4(0x00, pair 9), out=b_mid_g_4(0xA0, pair 3).
    // wg_id_x is read from s28 (saved in prologue; phase 5 clobbered s15).
    if _body_has_marker(body_node, "oproj_residual_speck4_marker", 28) != 0 {
        // Slice 6.0: phase 9 m4 shape + strides derived from arch globals.
        uint64 q_dim         = MEGA_N_HEADS * MEGA_HEAD_DIM
        uint64 q_dim_pad     = q_dim + 128
        uint64 hidden_stride = MEGA_HIDDEN * 4
        uint64 q_dim_stride  = q_dim * 4
        _emit_phase9_gemv_residual_m4_inline(MEGA_HIDDEN, q_dim, q_dim_pad, 256,
                                              0x18, 0xB0, 0x00, 0xA0,
                                              q_dim_stride, hidden_stride, hidden_stride)
    } else {
        asm_u32(0xBF800000)   // s_nop 0 (phase 9 stub)
    }
    mega_emit_barrier_isa(4, MEGA_WG_PERSIST)
    asm_s_cmp_lt_u32(10, 0x85)
    uint64 mp5_cbranch_pos = asm_text_len / 4
    asm_s_cbranch_scc1(0)

    // ── Phase 11: post_norm rmsnorm × M_EFF (WG-0 gated) ─────────────────
    // Slice 4.20.1: same m4 wrapper as phase 1, with different kernarg
    // byte offsets.  in=b_mid_g_4(arg 20, 0xA0), norm=post_norm_g(arg 7,
    // 0x38), out=b_mid_norm_g_4(arg 21, 0xA8).  wg_id_x is in s28 here
    // (phase 5's rope_sin load clobbered s15 mid-kernel; the prologue
    // saved the original s15→s28 — same constraint forced phase 9 in
    // the base kernel to read s28).
    if _body_has_marker(body_node, "post_norm_speck4_marker", 23) != 0 {
        _emit_rmsnorm_wg_gated_m4_inline(0xA0, 0x38, 0xA8, 28)
    } else {
        asm_u32(0xBF800000)   // s_nop 0 (phase 11 stub)
    }
    mega_emit_barrier_isa(5, MEGA_WG_PERSIST)
    asm_s_cmp_lt_u32(10, 0x86)
    uint64 mp6_cbranch_pos = asm_text_len / 4
    asm_s_cbranch_scc1(0)

    // ── Phase 13: gate_up matmul × M_EFF (WG < 256) ──────────────────────
    // Slice 4.20.5: reuses the phase-3 m4 gemv-coop-bf16-padded-strided
    // emitter with shape (n_out=6144 = 2*FF, k=1024 HIDDEN, k_pad=1152,
    // wg_active=256).  Kernarg layout: w=gate_up_w(0x20, sgpr pair 1),
    // x=b_mid_norm_g_4(0xA8, pair 2), out=gu_scratch_4(0x80, pair 3).
    // wg_id_sgpr=28 (saved in prologue; phase 5 clobbered s15).
    if _body_has_marker(body_node, "gate_up_matmul_speck4_marker", 28) != 0 {
        // Slice 5.2: 2*FF and HIDDEN/HIDDEN_PAD derived from arch globals.
        uint64 hidden_pad = MEGA_HIDDEN + 128
        _emit_gemv_coop_bf16_padded_strided_m4_inline(2 * MEGA_FF, MEGA_HIDDEN, hidden_pad, 256,
                                                       1, 2, 3,
                                                       0x20, 0xA8, 0x80, 28)
    } else {
        asm_u32(0xBF800000)   // s_nop 0 (phase 13 stub)
    }
    mega_emit_barrier_isa(6, MEGA_WG_PERSIST)
    asm_s_cmp_lt_u32(10, 0x87)
    uint64 mp7_cbranch_pos = asm_text_len / 4
    asm_s_cbranch_scc1(0)

    // ── Phase 15: SiLU(gate)*up × M_EFF in-place over gu_scratch_4 ───────
    // Slice 4.20.6: wraps the elem-strided silu_mul body in a 4× static
    // unroll; per-m gu_scratch_4 base advances by m*N_OUT*4 = m*24576 bytes
    // (N_OUT = 2*FF = 6144, the gate_up output row stride).  WG gate (s28<256)
    // and per-lane gate (idx<FF=3072) emitted ONCE outside the unroll —
    // both predicates are m-independent.  See _emit_silu_mul_elem_strided_m4_inline
    // for the SGPR/VGPR layout.
    if _body_has_marker(body_node, "silu_mul_elem_strided_speck4_marker", 35) != 0 {
        _emit_silu_mul_elem_strided_m4_inline()
    } else {
        asm_u32(0xBF800000)   // s_nop 0 (phase 15 stub)
    }
    mega_emit_barrier_isa(7, MEGA_WG_PERSIST)

    // ── Phase 17: down_w matmul + final residual-add × M_EFF (WG < 256) ──
    // Slice 4.20.0: stub.  Slice 4.20.7 reuses the m4 gemv-residual emitter
    // with shape (1024, 3072, 3200) and per-stream input stride 2*FF*4
    // bytes (NOT FF*4 — phase 15 wrote silu*up into slot [m, 0..FF] of a
    // [m, 0..2*FF]-block).  Phase 17 is the LAST phase — no trailing
    // mega_emit_barrier_isa(8, ...).
    if _body_has_marker(body_node, "down_residual_speck4_marker", 27) != 0 {
        // Slice 6.0: phase-17 reuses the phase-9 m4 gemv-residual emitter
        // with phase-17's strides; shape derived from arch globals.  Shape:
        // (n_out=HIDDEN, k=FF, k_pad=FF+128, wg_active=256).
        // Kernarg layout: w=down_w(arg 5, byte 0x28),
        // x=gu_scratch_4(arg 16, byte 0x80),
        // res=b_mid_g_4(arg 20, byte 0xA0),
        // out=out_residual_4(arg 1, byte 0x08).
        // Stream strides: x=2*FF*4 (gu_scratch_4 rows are 2*FF wide because
        // phase 13 wrote the gate||up concat there, even though down_w only
        // reads the first FF elements per row),
        // res=HIDDEN*4, out=HIDDEN*4.
        uint64 ff_pad           = MEGA_FF + 128
        uint64 hidden_stride_p17 = MEGA_HIDDEN * 4
        uint64 gu_stride        = 2 * MEGA_FF * 4
        _emit_phase9_gemv_residual_m4_inline(MEGA_HIDDEN, MEGA_FF, ff_pad, 256,
                                              0x28, 0x80, 0xA0, 0x08,
                                              gu_stride, hidden_stride_p17, hidden_stride_p17)
    } else {
        asm_u32(0xBF800000)   // s_nop 0 (phase 17 stub)
    }

    // .Lend:
    asm_s_endpgm()

    // ── Patch all max_phase branches to .Lend ─────────────────────────────
    uint64 endpgm_pos = (asm_text_len / 4) - 1   // s_endpgm is the last dword

    uint64 mp1_simm16 = (endpgm_pos - mp1_cbranch_pos - 1) & 0xFFFF
    asm_patch_u32(mp1_cbranch_pos, 0xBFA20000 | mp1_simm16)
    uint64 mp2_simm16 = (endpgm_pos - mp2_cbranch_pos - 1) & 0xFFFF
    asm_patch_u32(mp2_cbranch_pos, 0xBFA20000 | mp2_simm16)
    uint64 mp3_simm16 = (endpgm_pos - mp3_cbranch_pos - 1) & 0xFFFF
    asm_patch_u32(mp3_cbranch_pos, 0xBFA20000 | mp3_simm16)
    uint64 mp4_simm16 = (endpgm_pos - mp4_cbranch_pos - 1) & 0xFFFF
    asm_patch_u32(mp4_cbranch_pos, 0xBFA20000 | mp4_simm16)
    uint64 mp5_simm16 = (endpgm_pos - mp5_cbranch_pos - 1) & 0xFFFF
    asm_patch_u32(mp5_cbranch_pos, 0xBFA20000 | mp5_simm16)
    uint64 mp6_simm16 = (endpgm_pos - mp6_cbranch_pos - 1) & 0xFFFF
    asm_patch_u32(mp6_cbranch_pos, 0xBFA20000 | mp6_simm16)
    uint64 mp7_simm16 = (endpgm_pos - mp7_cbranch_pos - 1) & 0xFFFF
    asm_patch_u32(mp7_cbranch_pos, 0xBFA20000 | mp7_simm16)

    // ── Snapshot ISA and register in kernel table ──────────────────────────
    uint64 k_text_size = asm_text_len
    uint64 k_text_buf  = alloc(k_text_size)
    uint64 ci = 0
    while ci < k_text_size {
        uint64 sp = asm_text_buf + ci
        uint64 b = 0
        unsafe { *(sp as uint8) -> b }
        uint64 dp = k_text_buf + ci
        uint8 b8 = b
        unsafe { *(dp as uint8) = b8 }
        ci = ci + 1
    }

    // MEGA_KERNARG_COUNT_SPECK4-arg descriptor: same kernarg layout as base
    // (args 14 = pos_base, 23 = max_phase are by-value; rest are global_buffer).
    uint64 args_desc = alloc(MEGA_KERNARG_COUNT_SPECK4 * 16)
    uint64 ai = 0
    while ai < MEGA_KERNARG_COUNT_SPECK4 {
        uint64 sz_p   = args_desc + ai * 16
        uint64 kind_p = args_desc + ai * 16 + 8
        unsafe { *(sz_p as uint64) = 8 }
        if ai == 14 {
            unsafe { *(kind_p as uint64) = AMD_ARG_KIND_BY_VALUE }
        } else if ai == 23 {
            unsafe { *(kind_p as uint64) = AMD_ARG_KIND_BY_VALUE }
        } else {
            unsafe { *(kind_p as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
        }
        ai = ai + 1
    }

    // KD: same rsrc1/rsrc2/rsrc3/props as base mega-kernel.
    //     LDS = MEGA_LDS_SPECK4 = 2080 (override base 516; phase 7 needs
    //     attn_w_lds[M_EFF*128]=2048B + wave_tmp[1]=4B at offset 0).
    uint64 rsrc1 = 0xE0AF0006
    uint64 rsrc2 = 0x0000009E
    uint64 rsrc3 = 0x00000010
    uint64 props = 0x0408

    kt_push_lds(kname_ptr, nl, k_text_buf, k_text_size,
                args_desc, MEGA_KERNARG_COUNT_SPECK4, 192,
                16, 3,
                rsrc1, rsrc2, rsrc3, props,
                MEGA_LDS_SPECK4)
    return 0
}

// Top-level AST-walking recognizer for the qwen3_layer_megakernel_speck4 @kernel.
//
// Slice 4.20.0: validates the 24-parameter signature and body block shape,
// then delegates to mega_emit_stub_kernel_speck4 to produce the stub .co.
// Marker names matched at dispatch time are *_speck4_marker (no false-fire
// risk on the base body).
//
// Returns 0 on match (kernel emitted), 1 on shape mismatch.
fn recognize_megakernel_swiglu_dense_gqa_speck4(uint64 fn_node, uint64 source,
                                                 uint64 kname_ptr, uint64 nl) -> uint64 {
    // Slice 5.0: select arch preset by kernel name before any shape/body
    // checks so subsequent slices (5.1+) can read globals during emit.
    megakernel_dispatch_arch(kname_ptr, nl)

    // ── shape: exactly MEGA_KERNARG_COUNT_SPECK4 params ──────────────────
    uint64 n_params = 0
    uint64 wp = ast_child(fn_node)
    while wp != 0 {
        n_params = n_params + 1
        wp = ast_next(wp)
    }
    if n_params != MEGA_KERNARG_COUNT_SPECK4 { return 1 }

    // ── shape: body is a non-empty Block ─────────────────────────────────
    uint32 body = ast_data3(fn_node)
    if body == 0 { return 1 }
    if ast_kind(body) != AST_KIND_BLOCK { return 1 }

    return mega_emit_stub_kernel_speck4(kname_ptr, nl, body)
}
// MLRift -- built on KernRift -- Linux x86_64 dynamic-ELF emitter
//
// Emits a self-contained dynamically-linked executable that resolves
// external symbols through the ld-linux-x86-64.so.2 loader. Layout is
// computed from the callers's inputs (symbol list + text bytes + entry
// offset) rather than being hardcoded, so any combination of imports
// and code size fits as long as each PT_LOAD stays under a 4K page.
//
// Milestones landed:
//   M2a.0.std — standalone prototype (examples/elfgen.mlr)
//   M2a.1     — byte-identical port behind emit_dynamic_elf_hello()
//   M2a.2     — @dynamic extern fn frontend + symbol registry
//   M2a.3.a   — generalise emission: sym_list + text_bytes inputs,
//               dynamic offset/vaddr computation (this file)
//
// Pending:
//   M2a.3.b — codegen: call-through-PLT lowering for @dynamic calls
//   M2a.3.c — relocation patching after layout is fixed
//   M2a.4   — driver: route exe output through here when registry
//             is non-empty

// The @dynamic symbol registry (dyn_sym_register / dyn_sym_lookup /
// dyn_sym_count_get / dyn_sym_tok_at) lives in src/dyn_sym_registry.kr
// because it needs codegen's tok_text_eq. This file stays importable
// by user programs that want to call emit_dynamic_elf directly.

// ---------------------------------------------------------------------------
// Dynamic-call-site table (M2a.3.b)
// ---------------------------------------------------------------------------
// Populated by codegen when it lowers a call to a @dynamic extern. Each
// entry is (code_off: u32, sym_idx: u32) packed in 8 bytes. M2a.3.c
// iterates this list after format_elf_dyn computes the PLT layout and
// patches the 4-byte rel32 at each code_off to point at the appropriate
// PLT entry.
//
// code_off is the byte position of the 4-byte rel32 disp inside
// codegen.kr's `out_buf`. Converting to a text-relative offset happens
// at patch time using the text_start supplied by the driver.

static uint64 DYN_CALL_MAX    = 1024
static uint64 dyn_call_sites  = 0
static uint64 dyn_call_count  = 0

fn dyn_call_init() {
    if dyn_call_sites == 0 {
        dyn_call_sites = alloc(DYN_CALL_MAX * 8)
    }
    dyn_call_count = 0
}

@export
fn dyn_call_record(uint64 code_off, uint64 sym_idx) {
    if dyn_call_sites == 0 { dyn_call_init() }
    if dyn_call_count >= DYN_CALL_MAX {
        write(2, "format_elf_dyn: too many @dynamic call sites (>1024)\n", 53)
        exit(1)
    }
    uint64 entry = dyn_call_sites + dyn_call_count * 8
    uint32 co = code_off
    unsafe { *(entry as uint32) = co }
    uint64 e4 = entry + 4
    uint32 si = sym_idx
    unsafe { *(e4 as uint32) = si }
    dyn_call_count = dyn_call_count + 1
}

@export
fn dyn_call_count_get() -> uint64 {
    return dyn_call_count
}

@export
fn dyn_call_off_at(uint64 i) -> uint64 {
    uint64 entry = dyn_call_sites + i * 8
    uint32 v = 0
    unsafe { *(entry as uint32) -> v }
    uint64 wv = v
    return wv
}

@export
fn dyn_call_sym_at(uint64 i) -> uint64 {
    uint64 entry = dyn_call_sites + i * 8 + 4
    uint32 v = 0
    unsafe { *(entry as uint32) -> v }
    uint64 wv = v
    return wv
}

// ---------------------------------------------------------------------------
// Buffer state
// ---------------------------------------------------------------------------

static uint64 edyn_buf = 0
static uint64 edyn_cap = 0
static uint64 edyn_pos = 0

// Expose edyn_buf so drivers can write the composed ELF to disk
// via codegen-style `file_write(fd, edyn_buf_ptr(), size)`.
@export
fn edyn_buf_ptr() -> uint64 {
    return edyn_buf
}

@export
fn edyn_init(uint64 capacity) {
    if edyn_buf == 0 {
        edyn_buf = alloc(capacity)
        edyn_cap = capacity
    } else {
        uint64 i = 0
        while i < edyn_cap {
            uint64 p = edyn_buf + i
            uint8 z = 0
            unsafe { *(p as uint8) = z }
            i = i + 1
        }
    }
    edyn_pos = 0
}

// ---------------------------------------------------------------------------
// Position-advancing emit helpers
// ---------------------------------------------------------------------------

fn edyn_byte(uint64 val) {
    if edyn_pos >= edyn_cap {
        write(2, "format_elf_dyn: edyn_buf overflow\n", 34)
        exit(1)
    }
    uint64 p = edyn_buf + edyn_pos
    uint8 b = val & 0xFF
    unsafe { *(p as uint8) = b }
    edyn_pos = edyn_pos + 1
}

fn edyn_u16(uint64 val) {
    edyn_byte(val & 0xFF)
    edyn_byte((val >> 8) & 0xFF)
}

fn edyn_u32(uint64 val) {
    edyn_u16(val & 0xFFFF)
    edyn_u16((val >> 16) & 0xFFFF)
}

fn edyn_u64(uint64 val) {
    edyn_u32(val & 0xFFFFFFFF)
    edyn_u32((val >> 32) & 0xFFFFFFFF)
}

fn edyn_bytes(uint64 src, uint64 len) {
    uint64 i = 0
    while i < len {
        uint64 sp = src + i
        uint64 b = 0
        unsafe { *(sp as uint8) -> b }
        edyn_byte(b)
        i = i + 1
    }
}

fn edyn_pad_to(uint64 offset) {
    while edyn_pos < offset { edyn_byte(0) }
}

@export
fn edyn_patch_u32(uint64 off, uint64 val) {
    uint64 p0 = edyn_buf + off
    uint8 b0 = val & 0xFF
    unsafe { *(p0 as uint8) = b0 }
    uint64 p1 = edyn_buf + off + 1
    uint8 b1 = (val >> 8) & 0xFF
    unsafe { *(p1 as uint8) = b1 }
    uint64 p2 = edyn_buf + off + 2
    uint8 b2 = (val >> 16) & 0xFF
    unsafe { *(p2 as uint8) = b2 }
    uint64 p3 = edyn_buf + off + 3
    uint8 b3 = (val >> 24) & 0xFF
    unsafe { *(p3 as uint8) = b3 }
}

// ---------------------------------------------------------------------------
// Fixed layout constants
// ---------------------------------------------------------------------------
// Everything at/before .dynstr has a fixed size, so the offsets up to
// and including .dynstr's start are constant. The R-segment sections
// after .dynstr (.dynsym/.hash/.rela.plt/.dynamic) move around based
// on the number of imported symbols.
//
// Page-alignment of the three PT_LOADs fixes the remaining offsets:
//   R  starts at file 0x0000  vaddr 0x400000
//   RX starts at file 0x1000  vaddr 0x401000
//   RW starts at file 0x2000  vaddr 0x402000
// Each PT_LOAD must stay under 0x1000 bytes (single 4K page) for the
// current simple layout — a future session can grow this if any
// imported-symbol table busts the ceiling.

static uint64 EDYN_BASE_VADDR  = 0x400000
static uint64 EDYN_OFF_ELF_HDR = 0
static uint64 EDYN_OFF_PHDR    = 0x40
static uint64 EDYN_OFF_INTERP  = 0x190
static uint64 EDYN_OFF_DYNSTR  = 0x1AC
static uint64 EDYN_INTERP_SIZE = 28            // "/lib64/ld-linux-x86-64.so.2\0"
static uint64 EDYN_OFF_PLT     = 0x1000
static uint64 EDYN_VA_PLT      = 0x401000
// The RW segment (.got.plt) used to be pinned at 0x2000/0x402000, but
// that locks the RX segment to a single 4K page. When .plt + .text
// overflows a page (as happens for non-toy host programs), edyn_compute
// _layout now bumps the RW offset to the next page boundary and these
// become computed statics instead of constants — see edyn_off_gotplt /
// edyn_va_gotplt below.

// .dynamic carries 10 fixed entries (STRTAB, STRSZ, SYMTAB, SYMENT,
// HASH, PLTGOT, PLTRELSZ, PLTREL, JMPREL, NULL) plus one DT_NEEDED
// per linked library. Total = 10 + lib_count.
static uint64 EDYN_N_DYN_FIXED = 10

// ---------------------------------------------------------------------------
// Emission state (inputs + derived layout)
// ---------------------------------------------------------------------------

// Inputs (set by emit_dynamic_elf at entry)
static uint64 edyn_in_lib_list    = 0    // (name_ptr(u64), name_len(u64)) × count
static uint64 edyn_in_lib_count   = 0
static uint64 edyn_in_sym_list    = 0    // (name_ptr(u64), name_len(u64)) × count
static uint64 edyn_in_sym_count   = 0
static uint64 edyn_in_text_ptr    = 0
static uint64 edyn_in_text_len    = 0
static uint64 edyn_in_entry_off   = 0

// Derived offsets (filled by edyn_compute_layout)
static uint64 edyn_off_dynsym     = 0
static uint64 edyn_off_hash       = 0
static uint64 edyn_off_relaplt    = 0
static uint64 edyn_off_dynamic    = 0
static uint64 edyn_size_r         = 0    // end of R segment
static uint64 edyn_off_text       = 0
static uint64 edyn_size_rx        = 0    // length of RX segment from file 0x1000
static uint64 edyn_size_rw        = 0
static uint64 edyn_file_end       = 0

// Derived sizes
static uint64 edyn_dynstr_size    = 0
static uint64 edyn_plt_size       = 0    // 16 (PLT0) + 16 × sym_count
static uint64 edyn_dynsym_size    = 0    // 24 × (sym_count + 1)
static uint64 edyn_hash_size      = 0    // 12 + 4 × (sym_count + 1)
static uint64 edyn_relaplt_size   = 0    // 24 × sym_count
static uint64 edyn_dynamic_size   = 0    // 16 × N_DYN
static uint64 edyn_gotplt_size    = 0    // 8 × (3 + sym_count)

// Derived virtual addresses
static uint64 edyn_va_dynstr      = 0
static uint64 edyn_va_dynsym      = 0
static uint64 edyn_va_hash        = 0
static uint64 edyn_va_relaplt     = 0
static uint64 edyn_va_dynamic     = 0
static uint64 edyn_va_text        = 0
static uint64 edyn_off_gotplt     = 0    // page-aligned, follows RX
static uint64 edyn_va_gotplt      = 0

// Writable .data section follows .got.plt inside the RW segment.
// Populated from the codegen's static-data table; the dyn-ELF path
// keeps static variables out of RX so stores like `rng_state =
// rng_state ^ (rng_state << 13)` don't SIGSEGV on the read-only
// code segment.
static uint64 edyn_in_data_ptr    = 0
static uint64 edyn_in_data_size   = 0
static uint64 edyn_off_data       = 0
static uint64 edyn_va_data        = 0

// ---------------------------------------------------------------------------
// Library-list accessors (16 bytes per entry: name_ptr + name_len)
// ---------------------------------------------------------------------------

fn edyn_lib_name(uint64 i) -> uint64 {
    uint64 p = edyn_in_lib_list + i * 16
    uint64 v = 0
    unsafe { *(p as uint64) -> v }
    return v
}

fn edyn_lib_len(uint64 i) -> uint64 {
    uint64 p = edyn_in_lib_list + i * 16 + 8
    uint64 v = 0
    unsafe { *(p as uint64) -> v }
    return v
}

// Dynstr offset where library i's null-terminated name starts.
// Layout: sentinel (1) + lib[0]+null + lib[1]+null + ... + lib[i-1]+null.
fn edyn_lib_dynstr_off(uint64 i) -> uint64 {
    uint64 off = 1
    uint64 k = 0
    while k < i {
        off = off + edyn_lib_len(k) + 1
        k = k + 1
    }
    return off
}

// Sum of lib name sizes (incl. trailing nulls) — used to skip past the
// library region when computing symbol dynstr offsets.
fn edyn_libs_total_len() -> uint64 {
    uint64 total = 0
    uint64 k = 0
    while k < edyn_in_lib_count {
        total = total + edyn_lib_len(k) + 1
        k = k + 1
    }
    return total
}

// ---------------------------------------------------------------------------
// Symbol-list accessors (sym_list layout: 16 bytes per entry)
// ---------------------------------------------------------------------------

fn edyn_sym_name(uint64 i) -> uint64 {
    uint64 p = edyn_in_sym_list + i * 16
    uint64 v = 0
    unsafe { *(p as uint64) -> v }
    return v
}

fn edyn_sym_len(uint64 i) -> uint64 {
    uint64 p = edyn_in_sym_list + i * 16 + 8
    uint64 v = 0
    unsafe { *(p as uint64) -> v }
    return v
}

// Offset of symbol i's name within the emitted .dynstr section.
// Layout: sentinel (1) + libs + sym[0]+null + ... + sym[i-1]+null.
fn edyn_sym_dynstr_off(uint64 i) -> uint64 {
    uint64 off = 1 + edyn_libs_total_len()
    uint64 k = 0
    while k < i {
        off = off + edyn_sym_len(k) + 1
        k = k + 1
    }
    return off
}

fn edyn_sym_plt_va(uint64 i) -> uint64 {
    return EDYN_VA_PLT + 16 + i * 16
}

fn edyn_sym_got_va(uint64 i) -> uint64 {
    return edyn_va_gotplt + (3 + i) * 8
}

// ---------------------------------------------------------------------------
// Layout computation
// ---------------------------------------------------------------------------

fn edyn_compute_layout() {
    uint64 n = edyn_in_sym_count
    uint64 nl = edyn_in_lib_count

    // .dynstr: sentinel + libs (each + null) + syms (each + null)
    uint64 dss = 1 + edyn_libs_total_len()
    uint64 i = 0
    while i < n {
        dss = dss + edyn_sym_len(i) + 1
        i = i + 1
    }
    edyn_dynstr_size = dss

    // 8-align .dynsym after .dynstr
    uint64 ds_end = EDYN_OFF_DYNSTR + dss
    edyn_off_dynsym = (ds_end + 7) & 0xFFFFFFFFFFFFFFF8

    edyn_dynsym_size  = 24 * (n + 1)
    edyn_off_hash     = edyn_off_dynsym + edyn_dynsym_size
    edyn_hash_size    = 12 + 4 * (n + 1)
    edyn_off_relaplt  = edyn_off_hash + edyn_hash_size
    edyn_relaplt_size = 24 * n
    edyn_off_dynamic  = edyn_off_relaplt + edyn_relaplt_size
    edyn_dynamic_size = 16 * (EDYN_N_DYN_FIXED + nl)
    edyn_size_r       = edyn_off_dynamic + edyn_dynamic_size

    edyn_plt_size  = 16 + 16 * n
    edyn_off_text  = EDYN_OFF_PLT + edyn_plt_size
    edyn_size_rx   = edyn_plt_size + edyn_in_text_len

    // Page-align the RW segment onto the next boundary after RX ends.
    // RX starts at EDYN_OFF_PLT = 0x1000; pre-M3 it was capped at one
    // page so RW pinned at 0x2000 worked. Real host programs bust that
    // ceiling — compute dynamically.
    uint64 rx_end      = EDYN_OFF_PLT + edyn_size_rx
    edyn_off_gotplt    = (rx_end + 0xFFF) & 0xFFFFFFFFFFFFF000

    edyn_gotplt_size = 8 * (3 + n)
    // .data tail inside RW: writable static variables live here so
    // the dyn-ELF binary can mutate them. When there are none the
    // section stays zero-sized and the layout matches the pre-M2a
    // shape.
    edyn_off_data    = edyn_off_gotplt + edyn_gotplt_size
    edyn_size_rw     = edyn_gotplt_size + edyn_in_data_size
    edyn_file_end    = edyn_off_gotplt + edyn_size_rw

    edyn_va_dynstr  = EDYN_BASE_VADDR + EDYN_OFF_DYNSTR
    edyn_va_dynsym  = EDYN_BASE_VADDR + edyn_off_dynsym
    edyn_va_hash    = EDYN_BASE_VADDR + edyn_off_hash
    edyn_va_relaplt = EDYN_BASE_VADDR + edyn_off_relaplt
    edyn_va_dynamic = EDYN_BASE_VADDR + edyn_off_dynamic
    edyn_va_text    = EDYN_VA_PLT + edyn_plt_size
    edyn_va_gotplt  = EDYN_BASE_VADDR + edyn_off_gotplt
    edyn_va_data    = EDYN_BASE_VADDR + edyn_off_data

    // Only the R segment is still hardcapped: it carries ELF header +
    // phdrs + dyn tables, and those fit well under one page for any
    // realistic import set. Larger libraries or symbol counts would
    // need the same page-aligned-bump treatment.
    if edyn_size_r > 0x1000 {
        write(2, "format_elf_dyn: R segment exceeds one page\n", 43)
        exit(1)
    }
}

// ---------------------------------------------------------------------------
// ELF64 header
// ---------------------------------------------------------------------------

fn edyn_write_elf_header() {
    edyn_byte(0x7F); edyn_byte(69); edyn_byte(76); edyn_byte(70)
    edyn_byte(2); edyn_byte(1); edyn_byte(1); edyn_byte(0)
    uint64 i = 0
    while i < 8 { edyn_byte(0); i = i + 1 }

    edyn_u16(2)                                              // e_type
    edyn_u16(0x3E)                                           // e_machine
    edyn_u32(1)                                              // e_version
    edyn_u64(edyn_va_text + edyn_in_entry_off)               // e_entry
    edyn_u64(EDYN_OFF_PHDR)                                  // e_phoff
    edyn_u64(0)                                              // e_shoff
    edyn_u32(0)                                              // e_flags
    edyn_u16(64)                                             // e_ehsize
    edyn_u16(56)                                             // e_phentsize
    edyn_u16(6)                                              // e_phnum
    edyn_u16(0); edyn_u16(0); edyn_u16(0)
}

// ---------------------------------------------------------------------------
// Program headers
// ---------------------------------------------------------------------------

fn edyn_write_phdr(uint64 p_type, uint64 p_flags,
                   uint64 p_offset, uint64 p_vaddr,
                   uint64 p_filesz, uint64 p_memsz,
                   uint64 p_align) {
    edyn_u32(p_type)
    edyn_u32(p_flags)
    edyn_u64(p_offset)
    edyn_u64(p_vaddr)
    edyn_u64(p_vaddr)
    edyn_u64(p_filesz)
    edyn_u64(p_memsz)
    edyn_u64(p_align)
}

fn edyn_write_phdrs() {
    edyn_write_phdr(6, 4,
                    EDYN_OFF_PHDR, EDYN_BASE_VADDR + EDYN_OFF_PHDR,
                    336, 336, 8)
    edyn_write_phdr(3, 4,
                    EDYN_OFF_INTERP, EDYN_BASE_VADDR + EDYN_OFF_INTERP,
                    EDYN_INTERP_SIZE, EDYN_INTERP_SIZE, 1)
    edyn_write_phdr(1, 4,
                    0, EDYN_BASE_VADDR,
                    edyn_size_r, edyn_size_r, 0x1000)
    edyn_write_phdr(1, 5,
                    EDYN_OFF_PLT, EDYN_VA_PLT,
                    edyn_size_rx, edyn_size_rx, 0x1000)
    edyn_write_phdr(1, 6,
                    edyn_off_gotplt, edyn_va_gotplt,
                    edyn_size_rw, edyn_size_rw, 0x1000)
    edyn_write_phdr(2, 4,
                    edyn_off_dynamic, edyn_va_dynamic,
                    edyn_dynamic_size, edyn_dynamic_size, 8)
}

// ---------------------------------------------------------------------------
// .interp
// ---------------------------------------------------------------------------

fn edyn_write_interp() {
    uint64 s = "/lib64/ld-linux-x86-64.so.2"
    edyn_bytes(s, 27)
    edyn_byte(0)
}

// ---------------------------------------------------------------------------
// .dynstr
// ---------------------------------------------------------------------------

fn edyn_write_dynstr() {
    edyn_byte(0)
    uint64 li = 0
    while li < edyn_in_lib_count {
        edyn_bytes(edyn_lib_name(li), edyn_lib_len(li))
        edyn_byte(0)
        li = li + 1
    }
    uint64 i = 0
    while i < edyn_in_sym_count {
        edyn_bytes(edyn_sym_name(i), edyn_sym_len(i))
        edyn_byte(0)
        i = i + 1
    }
}

// ---------------------------------------------------------------------------
// .dynsym
// ---------------------------------------------------------------------------

fn edyn_write_dynsym_entry(uint64 name_off, uint64 info) {
    edyn_u32(name_off)
    edyn_byte(info)
    edyn_byte(0)
    edyn_u16(0)
    edyn_u64(0)
    edyn_u64(0)
}

fn edyn_write_dynsym() {
    edyn_write_dynsym_entry(0, 0)
    uint64 i = 0
    while i < edyn_in_sym_count {
        edyn_write_dynsym_entry(edyn_sym_dynstr_off(i), 0x12)
        i = i + 1
    }
}

// ---------------------------------------------------------------------------
// .hash — single-bucket SysV chain
// ---------------------------------------------------------------------------

fn edyn_write_hash() {
    uint64 n = edyn_in_sym_count + 1    // +1 for null sentinel sym
    edyn_u32(1)                         // nbucket
    edyn_u32(n)                         // nchain
    edyn_u32(1)                         // bucket[0]
    edyn_u32(0)                         // chain[0] sentinel
    uint64 i = 1
    while i < n {
        uint64 nxt = i + 1
        if nxt >= n { nxt = 0 }
        edyn_u32(nxt)
        i = i + 1
    }
}

// ---------------------------------------------------------------------------
// .rela.plt
// ---------------------------------------------------------------------------

fn edyn_write_rela(uint64 got_va, uint64 sym_idx) {
    edyn_u64(got_va)
    uint64 r_info = (sym_idx << 32) | 7     // R_X86_64_JUMP_SLOT
    edyn_u64(r_info)
    edyn_u64(0)
}

fn edyn_write_relaplt() {
    uint64 i = 0
    while i < edyn_in_sym_count {
        edyn_write_rela(edyn_sym_got_va(i), i + 1)
        i = i + 1
    }
}

// ---------------------------------------------------------------------------
// .dynamic
// ---------------------------------------------------------------------------

fn edyn_write_dyn(uint64 tag, uint64 val) {
    edyn_u64(tag)
    edyn_u64(val)
}

fn edyn_write_dynamic() {
    // One DT_NEEDED per library, each pointing at that library's
    // dynstr offset.
    uint64 li = 0
    while li < edyn_in_lib_count {
        edyn_write_dyn(1, edyn_lib_dynstr_off(li))   // DT_NEEDED
        li = li + 1
    }
    edyn_write_dyn(5,  edyn_va_dynstr)           // DT_STRTAB
    edyn_write_dyn(10, edyn_dynstr_size)         // DT_STRSZ
    edyn_write_dyn(6,  edyn_va_dynsym)           // DT_SYMTAB
    edyn_write_dyn(11, 24)                       // DT_SYMENT
    edyn_write_dyn(4,  edyn_va_hash)             // DT_HASH
    edyn_write_dyn(3,  edyn_va_gotplt)           // DT_PLTGOT
    edyn_write_dyn(2,  edyn_relaplt_size)        // DT_PLTRELSZ
    edyn_write_dyn(20, 7)                        // DT_PLTREL = DT_RELA
    edyn_write_dyn(23, edyn_va_relaplt)          // DT_JMPREL
    edyn_write_dyn(0,  0)                        // DT_NULL
}

// ---------------------------------------------------------------------------
// .plt — x86_64 lazy-binding trampolines
// ---------------------------------------------------------------------------

fn edyn_write_plt0() {
    // push [rip + disp_to_GOT[1]] (6 bytes; rip after = VA_PLT+6)
    edyn_byte(0xFF); edyn_byte(0x35)
    uint64 disp1 = (edyn_va_gotplt + 8) - (EDYN_VA_PLT + 6)
    edyn_u32(disp1)

    // jmp [rip + disp_to_GOT[2]] (6 bytes; rip after = VA_PLT+12)
    edyn_byte(0xFF); edyn_byte(0x25)
    uint64 disp2 = (edyn_va_gotplt + 16) - (EDYN_VA_PLT + 12)
    edyn_u32(disp2)

    edyn_byte(0x0F); edyn_byte(0x1F); edyn_byte(0x40); edyn_byte(0x00)
}

fn edyn_write_plt_entry(uint64 entry_va, uint64 got_slot_va, uint64 rela_idx) {
    // jmp [rip + disp] (6 bytes; rip after = entry_va+6)
    edyn_byte(0xFF); edyn_byte(0x25)
    uint64 disp = got_slot_va - (entry_va + 6)
    edyn_u32(disp)

    // push rela_idx (5 bytes)
    edyn_byte(0x68)
    edyn_u32(rela_idx)

    // jmp rel32 to PLT0 (5 bytes; rip after = entry_va+16)
    edyn_byte(0xE9)
    uint64 rel = EDYN_VA_PLT - (entry_va + 16)
    edyn_u32(rel & 0xFFFFFFFF)
}

fn edyn_write_plt() {
    edyn_write_plt0()
    uint64 i = 0
    while i < edyn_in_sym_count {
        edyn_write_plt_entry(edyn_sym_plt_va(i),
                             edyn_sym_got_va(i),
                             i)
        i = i + 1
    }
}

// ---------------------------------------------------------------------------
// .text — caller-provided bytes
// ---------------------------------------------------------------------------

fn edyn_write_text() {
    edyn_bytes(edyn_in_text_ptr, edyn_in_text_len)
}

// ---------------------------------------------------------------------------
// .got.plt — 3 reserved slots + one per imported symbol
// ---------------------------------------------------------------------------

fn edyn_write_gotplt() {
    edyn_u64(edyn_va_dynamic)             // [0] _DYNAMIC
    edyn_u64(0)                            // [1] link_map
    edyn_u64(0)                            // [2] resolver
    uint64 i = 0
    while i < edyn_in_sym_count {
        // initial target = (PLT entry's push-imm insn, at entry_va+6)
        edyn_u64(edyn_sym_plt_va(i) + 6)
        i = i + 1
    }
}

// ---------------------------------------------------------------------------
// Layout computation hook (M2a.3.c)
// ---------------------------------------------------------------------------
// Sets the emitter's input state and runs edyn_compute_layout without
// writing anything. Drivers call this before edyn_patch_dyn_calls so
// the per-symbol PLT vaddr is available to the patcher.

@export
fn edyn_compute_dyn_layout_for(uint64 lib_list_ptr, uint64 lib_count,
                               uint64 sym_list_ptr, uint64 sym_count,
                               uint64 text_len) {
    edyn_in_lib_list  = lib_list_ptr
    edyn_in_lib_count = lib_count
    edyn_in_sym_list  = sym_list_ptr
    edyn_in_sym_count = sym_count
    edyn_in_text_len  = text_len
    edyn_in_entry_off = 0
    edyn_compute_layout()
}

// Register writable static-data bytes to emit at the end of the RW
// segment. Must be called before edyn_compute_dyn_layout_for so the
// size participates in the RW sizing. Size 0 keeps the pre-static
// layout intact.
@export
fn edyn_set_data(uint64 data_ptr, uint64 data_size) {
    edyn_in_data_ptr  = data_ptr
    edyn_in_data_size = data_size
}

// VA of the first byte of writable static data inside the RW segment.
// Callers use this to resolve RIP-relative fixups whose target lives
// in .data rather than the legacy RX-embedded data region.
@export
fn edyn_va_data_get() -> uint64 { return edyn_va_data }

// RIP-relative patch helper for static-variable accesses. The code
// stream already contains the 4-byte disp placeholder at
// (code_off - code_off_base) inside combined_text; we overwrite it
// with the disp that reaches static_va + data_off in .data. Mirrors
// edyn_patch_dyn_calls in shape; callers compute the (code_off,
// data_off) pairs from the codegen's static_fixups table.
@export
fn edyn_patch_static_fixup(uint64 text_ptr, uint64 code_off_base,
                           uint64 code_off, uint64 data_off) {
    if code_off < code_off_base {
        write(2, "format_elf_dyn: static fixup before text start\n", 47)
        exit(1)
    }
    uint64 text_off = code_off - code_off_base
    if text_off + 4 > edyn_in_text_len {
        write(2, "format_elf_dyn: static fixup past text end\n", 43)
        exit(1)
    }
    uint64 rip_after = edyn_va_text + text_off + 4
    uint64 target_va = edyn_va_data + data_off
    uint64 rel32 = (target_va - rip_after) & 0xFFFFFFFF

    uint64 p = text_ptr + text_off
    uint8 b0 = rel32 & 0xFF
    uint8 b1 = (rel32 >> 8) & 0xFF
    uint8 b2 = (rel32 >> 16) & 0xFF
    uint8 b3 = (rel32 >> 24) & 0xFF
    unsafe { *(p as uint8) = b0 }
    uint64 p1 = p + 1; unsafe { *(p1 as uint8) = b1 }
    uint64 p2 = p + 2; unsafe { *(p2 as uint8) = b2 }
    uint64 p3 = p + 3; unsafe { *(p3 as uint8) = b3 }
}

// Patch every recorded @dynamic call site in `text_ptr` with the rel32
// that reaches the corresponding PLT entry. Assumes edyn_compute_layout
// has been run so edyn_va_text and edyn_sym_plt_va(i) are valid.
//
// code_off in dyn_call_sites is the offset into the *codegen* buffer
// where the rel32 lives (codegen writes its output into out_buf, which
// may carry ELF headers ahead of .text). `code_off_base` is the offset
// of .text's first byte inside that same codegen buffer — passing 0
// means "code_off values are already text-relative".
@export
fn edyn_patch_dyn_calls(uint64 text_ptr, uint64 code_off_base) {
    uint64 n = dyn_call_count_get()
    if n == 0 { return }

    uint64 i = 0
    while i < n {
        uint64 code_off = dyn_call_off_at(i)
        uint64 sym_idx  = dyn_call_sym_at(i)
        if code_off < code_off_base {
            write(2, "format_elf_dyn: @dynamic call site before text start\n", 53)
            exit(1)
        }
        uint64 text_off = code_off - code_off_base
        if text_off + 4 > edyn_in_text_len {
            write(2, "format_elf_dyn: @dynamic call site past text end\n", 49)
            exit(1)
        }
        uint64 rip_after = edyn_va_text + text_off + 4
        uint64 plt_va = edyn_sym_plt_va(sym_idx)
        uint64 rel32 = (plt_va - rip_after) & 0xFFFFFFFF

        uint64 p = text_ptr + text_off
        uint8 b0 = rel32 & 0xFF
        uint8 b1 = (rel32 >> 8) & 0xFF
        uint8 b2 = (rel32 >> 16) & 0xFF
        uint8 b3 = (rel32 >> 24) & 0xFF
        unsafe { *(p as uint8) = b0 }
        uint64 p1 = p + 1; unsafe { *(p1 as uint8) = b1 }
        uint64 p2 = p + 2; unsafe { *(p2 as uint8) = b2 }
        uint64 p3 = p + 3; unsafe { *(p3 as uint8) = b3 }

        i = i + 1
    }
}

// ---------------------------------------------------------------------------
// Top-level generic entry
// ---------------------------------------------------------------------------

// Fill edyn_buf with a complete dynamic-ELF image.
//
// Parameters:
//   lib_list_ptr / lib_count    — packed (name_ptr, name_len) × N, 16 bytes
//                                 per entry. Each becomes a DT_NEEDED entry.
//                                 Loader searches all NEEDED libs for each
//                                 symbol, so per-symbol library binding is
//                                 implicit.
//   sym_list_ptr / sym_count    — packed array: 16 bytes per entry, each
//                                 (name_ptr: u64, name_len: u64). Order is
//                                 preserved into .dynsym / .rela.plt / PLT.
//   text_ptr / text_len         — .text section bytes (caller is responsible
//                                 for PLT-relative rel32s; they must be
//                                 pre-patched against the PLT layout
//                                 described by edyn_sym_plt_va(i))
//   entry_off                   — byte offset within `text` where _start begins
//
// Returns: total byte count written (EDYN_FILE_END equivalent).
@export
fn emit_dynamic_elf(uint64 lib_list_ptr, uint64 lib_count,
                    uint64 sym_list_ptr,  uint64 sym_count,
                    uint64 text_ptr,      uint64 text_len,
                    uint64 entry_off) -> uint64 {
    if sym_count == 0 {
        write(2, "format_elf_dyn: no dynamic symbols\n", 35)
        exit(1)
    }
    if lib_count == 0 {
        write(2, "format_elf_dyn: no DT_NEEDED libraries\n", 39)
        exit(1)
    }

    edyn_in_lib_list  = lib_list_ptr
    edyn_in_lib_count = lib_count
    edyn_in_sym_list  = sym_list_ptr
    edyn_in_sym_count = sym_count
    edyn_in_text_ptr  = text_ptr
    edyn_in_text_len  = text_len
    edyn_in_entry_off = entry_off

    edyn_compute_layout()
    edyn_init(262144)

    edyn_write_elf_header()
    edyn_pad_to(EDYN_OFF_PHDR)
    edyn_write_phdrs()
    edyn_pad_to(EDYN_OFF_INTERP)
    edyn_write_interp()
    edyn_pad_to(EDYN_OFF_DYNSTR)
    edyn_write_dynstr()
    edyn_pad_to(edyn_off_dynsym)
    edyn_write_dynsym()
    edyn_pad_to(edyn_off_hash)
    edyn_write_hash()
    edyn_pad_to(edyn_off_relaplt)
    edyn_write_relaplt()
    edyn_pad_to(edyn_off_dynamic)
    edyn_write_dynamic()
    edyn_pad_to(EDYN_OFF_PLT)
    edyn_write_plt()
    edyn_pad_to(edyn_off_text)
    edyn_write_text()
    edyn_pad_to(edyn_off_gotplt)
    edyn_write_gotplt()
    // .data: raw static-variable bytes handed in by main.kr. Written
    // inside the RW segment so `mov [rip+disp], val` stores from
    // user code land on writable pages.
    if edyn_in_data_size > 0 {
        uint64 di = 0
        while di < edyn_in_data_size {
            uint64 sp = edyn_in_data_ptr + di
            uint8 sb = 0
            unsafe { *(sp as uint8) -> sb }
            edyn_byte(sb)
            di = di + 1
        }
    }
    edyn_pad_to(edyn_file_end)

    return edyn_file_end
}

// ---------------------------------------------------------------------------
// glibc-style _start stub (M2b.3)
// ---------------------------------------------------------------------------
// When a dynamic ELF pulls in complex C++ runtimes like libamdhip64 +
// libstdc++, the loader expects MLRift's entry to set up argc/argv +
// __libc_start_main the same way gcc-emitted binaries do. The stub
// below mirrors the glibc _start sequence: fill registers per the
// System V AMD64 ABI, then call __libc_start_main@plt with the user's
// main() address in %rdi. __libc_start_main runs libc ctors, TLS, and
// .init_array for every loaded library, then invokes main.
//
// Layout (33 bytes):
//   off  bytes              asm
//    0   31 ed              xor ebp, ebp
//    2   49 89 d1           mov r9, rdx            ; rtld_fini
//    5   5e                 pop rsi                ; argc
//    6   48 89 e2           mov rdx, rsp           ; argv
//    9   48 83 e4 f0        and rsp, -16
//   13   50                 push rax               ; align to 16
//   14   54                 push rsp               ; stack_end
//   15   45 31 c0           xor r8d, r8d           ; fini = NULL
//   18   31 c9              xor ecx, ecx           ; init = NULL
//   20   48 8d 3d <disp>    lea rdi, [rip + disp]  ; main address
//   27   e8 <rel32>         call __libc_start_main@plt
//   32   f4                 hlt                    ; unreached

static uint64 EDYN_START_STUB_SIZE         = 33
static uint64 EDYN_START_STUB_LEA_DISP_OFF = 23   // 4-byte disp starts here
static uint64 EDYN_START_STUB_CALL_REL_OFF = 28   // 4-byte rel32 starts here

@export fn edyn_start_stub_size() -> uint64 { return EDYN_START_STUB_SIZE }
@export fn edyn_start_stub_call_rel32_off() -> uint64 { return EDYN_START_STUB_CALL_REL_OFF }

fn edyn_stub_emit_u8(uint64 buf, uint64 off, uint64 val) {
    uint64 p = buf + off
    uint8 b = val & 0xFF
    unsafe { *(p as uint8) = b }
}

fn edyn_stub_emit_u32(uint64 buf, uint64 off, uint64 val) {
    edyn_stub_emit_u8(buf, off,     val & 0xFF)
    edyn_stub_emit_u8(buf, off + 1, (val >> 8)  & 0xFF)
    edyn_stub_emit_u8(buf, off + 2, (val >> 16) & 0xFF)
    edyn_stub_emit_u8(buf, off + 3, (val >> 24) & 0xFF)
}

// Write the 33-byte _start stub into `buf`.
//   main_off_in_text — byte offset of user `main()` within the .text
//                      section being assembled (i.e., stub occupies
//                      [0..33), main lives at main_off_in_text; for
//                      a single-fn source where main is first, that's
//                      just STUB_SIZE).
// The call rel32 at offset 28 is left as zero — caller must patch it
// after edyn_compute_layout knows the PLT vaddr for __libc_start_main.
@export
fn edyn_write_start_stub(uint64 buf, uint64 main_off_in_text) {
    // xor ebp, ebp
    edyn_stub_emit_u8(buf, 0, 0x31); edyn_stub_emit_u8(buf, 1, 0xED)
    // mov r9, rdx
    edyn_stub_emit_u8(buf, 2, 0x49); edyn_stub_emit_u8(buf, 3, 0x89)
    edyn_stub_emit_u8(buf, 4, 0xD1)
    // pop rsi
    edyn_stub_emit_u8(buf, 5, 0x5E)
    // mov rdx, rsp
    edyn_stub_emit_u8(buf, 6, 0x48); edyn_stub_emit_u8(buf, 7, 0x89)
    edyn_stub_emit_u8(buf, 8, 0xE2)
    // and rsp, -16
    edyn_stub_emit_u8(buf,  9, 0x48); edyn_stub_emit_u8(buf, 10, 0x83)
    edyn_stub_emit_u8(buf, 11, 0xE4); edyn_stub_emit_u8(buf, 12, 0xF0)
    // push rax
    edyn_stub_emit_u8(buf, 13, 0x50)
    // push rsp
    edyn_stub_emit_u8(buf, 14, 0x54)
    // xor r8d, r8d
    edyn_stub_emit_u8(buf, 15, 0x45); edyn_stub_emit_u8(buf, 16, 0x31)
    edyn_stub_emit_u8(buf, 17, 0xC0)
    // xor ecx, ecx
    edyn_stub_emit_u8(buf, 18, 0x31); edyn_stub_emit_u8(buf, 19, 0xC9)
    // lea rdi, [rip + disp]   rip_after_lea = stub+27
    edyn_stub_emit_u8(buf, 20, 0x48); edyn_stub_emit_u8(buf, 21, 0x8D)
    edyn_stub_emit_u8(buf, 22, 0x3D)
    uint64 lea_disp = main_off_in_text - 27
    edyn_stub_emit_u32(buf, EDYN_START_STUB_LEA_DISP_OFF, lea_disp)
    // call rel32 (placeholder)
    edyn_stub_emit_u8(buf, 27, 0xE8)
    edyn_stub_emit_u32(buf, EDYN_START_STUB_CALL_REL_OFF, 0)
    // hlt
    edyn_stub_emit_u8(buf, 32, 0xF4)
}

// ---------------------------------------------------------------------------
// Backcompat wrappers for the hello-puts configuration
// ---------------------------------------------------------------------------
// Still driven by the M2a.1 API (fmtelf_test.mlr calls into this path).
// These build the same 2-symbol + 29-byte text payload as
// examples/elfgen.mlr and then call emit_dynamic_elf.

@export
fn edyn_build_hello_text(uint64 text_buf) {
    uint64 va_text = EDYN_VA_PLT + 16 + 2 * 16        // PLT0 + 2 entries
    uint64 va_plt_puts = EDYN_VA_PLT + 16
    uint64 va_plt_exit = EDYN_VA_PLT + 32
    uint64 va_hello = va_text + 23

    // sub rsp, 8
    uint8 b0 = 0x48; unsafe { *((text_buf + 0) as uint8) = b0 }
    uint8 b1 = 0x83; unsafe { *((text_buf + 1) as uint8) = b1 }
    uint8 b2 = 0xEC; unsafe { *((text_buf + 2) as uint8) = b2 }
    uint8 b3 = 0x08; unsafe { *((text_buf + 3) as uint8) = b3 }

    // lea rdi, [rip+disp_to_hello] — rip after at text+11
    uint8 b4 = 0x48; unsafe { *((text_buf + 4) as uint8) = b4 }
    uint8 b5 = 0x8D; unsafe { *((text_buf + 5) as uint8) = b5 }
    uint8 b6 = 0x3D; unsafe { *((text_buf + 6) as uint8) = b6 }
    uint64 lea_disp = va_hello - (va_text + 11)
    uint8 l0 = lea_disp & 0xFF
    uint8 l1 = (lea_disp >> 8) & 0xFF
    uint8 l2 = (lea_disp >> 16) & 0xFF
    uint8 l3 = (lea_disp >> 24) & 0xFF
    unsafe { *((text_buf + 7)  as uint8) = l0 }
    unsafe { *((text_buf + 8)  as uint8) = l1 }
    unsafe { *((text_buf + 9)  as uint8) = l2 }
    unsafe { *((text_buf + 10) as uint8) = l3 }

    // call puts_plt — rip after at text+16
    uint8 b11 = 0xE8; unsafe { *((text_buf + 11) as uint8) = b11 }
    uint64 puts_rel = va_plt_puts - (va_text + 16)
    uint8 p0 = puts_rel & 0xFF
    uint8 p1 = (puts_rel >> 8) & 0xFF
    uint8 p2 = (puts_rel >> 16) & 0xFF
    uint8 p3 = (puts_rel >> 24) & 0xFF
    unsafe { *((text_buf + 12) as uint8) = p0 }
    unsafe { *((text_buf + 13) as uint8) = p1 }
    unsafe { *((text_buf + 14) as uint8) = p2 }
    unsafe { *((text_buf + 15) as uint8) = p3 }

    // xor edi, edi
    uint8 b16 = 0x31; unsafe { *((text_buf + 16) as uint8) = b16 }
    uint8 b17 = 0xFF; unsafe { *((text_buf + 17) as uint8) = b17 }

    // call exit_plt — rip after at text+23
    uint8 b18 = 0xE8; unsafe { *((text_buf + 18) as uint8) = b18 }
    uint64 exit_rel = va_plt_exit - (va_text + 23)
    uint8 e0 = exit_rel & 0xFF
    uint8 e1 = (exit_rel >> 8) & 0xFF
    uint8 e2 = (exit_rel >> 16) & 0xFF
    uint8 e3 = (exit_rel >> 24) & 0xFF
    unsafe { *((text_buf + 19) as uint8) = e0 }
    unsafe { *((text_buf + 20) as uint8) = e1 }
    unsafe { *((text_buf + 21) as uint8) = e2 }
    unsafe { *((text_buf + 22) as uint8) = e3 }

    // "hello\0"
    uint8 h0 = 104; unsafe { *((text_buf + 23) as uint8) = h0 }
    uint8 h1 = 101; unsafe { *((text_buf + 24) as uint8) = h1 }
    uint8 h2 = 108; unsafe { *((text_buf + 25) as uint8) = h2 }
    uint8 h3 = 108; unsafe { *((text_buf + 26) as uint8) = h3 }
    uint8 h4 = 111; unsafe { *((text_buf + 27) as uint8) = h4 }
    uint8 h5 = 0;   unsafe { *((text_buf + 28) as uint8) = h5 }
}

@export
fn emit_dynamic_elf_hello() -> uint64 {
    // lib_list[1]: just libc.so.6
    uint64 lib_list = alloc(1 * 16)
    uint64 libc_s = "libc.so.6"
    unsafe { *((lib_list + 0) as uint64) = libc_s }
    uint64 libc_l = 9
    unsafe { *((lib_list + 8) as uint64) = libc_l }

    // sym_list[2]: (ptr, len) pairs
    uint64 puts_s = "puts"
    uint64 exit_s = "exit"
    uint64 sym_list = alloc(2 * 16)
    unsafe { *((sym_list +  0) as uint64) = puts_s }
    uint64 vpl = 4
    unsafe { *((sym_list +  8) as uint64) = vpl }
    unsafe { *((sym_list + 16) as uint64) = exit_s }
    uint64 vel = 4
    unsafe { *((sym_list + 24) as uint64) = vel }

    // Text: 29 bytes (23-byte _start + "hello\0")
    uint64 text_buf = alloc(64)
    edyn_build_hello_text(text_buf)

    return emit_dynamic_elf(lib_list, 1,
                            sym_list, 2,
                            text_buf, 29,
                            0)
}

@export
fn emit_dynamic_elf_to_file(uint64 out_path) -> uint64 {
    uint64 size = emit_dynamic_elf_hello()
    uint64 fd = file_open(out_path, 1)
    if fd > 0xFFFFFFFFFFFFF000 {
        write(2, "format_elf_dyn: failed to open output\n", 38)
        return 1
    }
    file_write(fd, edyn_buf, size)
    file_close(fd)
    set_executable(out_path)
    return 0
}
// MLRift -- built on KernRift -- @dynamic symbol registry (compiler-only)
//
// Holds the token-keyed name table populated by parser.kr whenever a
// `@dynamic extern fn` declaration is seen, plus the lookup helper
// codegen uses to detect @dynamic calls at Call-emission time.
//
// This lives in its own file (and not in src/format_elf_dyn.kr) because
// dyn_sym_lookup calls into codegen's `tok_text_eq`, which depends on
// the compiler-wide source/tokens globals. format_elf_dyn is reusable
// from user programs via `import`; it can't reach those globals. By
// splitting the registry out, user programs importing format_elf_dyn
// don't accidentally drag in unresolved compiler-internal references.

static uint64 DYN_SYM_MAX     = 256
static uint64 dyn_sym_tokens  = 0
static uint64 dyn_sym_count   = 0
// Per-symbol ABI kind:
//   0 = integer SysV ABI (default)
//   1 = libm float, 1-arg-1-return f32 (xmm0 in / xmm0 out)
//   2 = libm float, 2-arg-1-return f32 (xmm0 + xmm1 in / xmm0 out)
// Code paths for kinds 1 and 2 in IR Call lowering are unified — both
// route every arg through xmm0..xmm7 and read the return from xmm0 —
// but the kind tag preserves the signature shape for future extensions
// (mixed int + float args, 3-arg float, etc.). dyn_sym_any_libm()
// returns 1 for any nonzero kind, so libm.so.6 lands in DT_NEEDED for
// either flavor.
static uint64 dyn_sym_abis    = 0

fn dyn_sym_init() {
    if dyn_sym_tokens == 0 {
        dyn_sym_tokens = alloc(DYN_SYM_MAX * 4)
    }
    if dyn_sym_abis == 0 {
        dyn_sym_abis = alloc(DYN_SYM_MAX)
    }
    dyn_sym_count = 0
}

@export
fn dyn_sym_register(uint64 name_tok) -> uint64 {
    if dyn_sym_tokens == 0 { dyn_sym_init() }
    if dyn_sym_count >= DYN_SYM_MAX {
        write(2, "dyn_sym_registry: too many @dynamic symbols (>256)\n", 51)
        exit(1)
    }
    uint64 slot = dyn_sym_tokens + dyn_sym_count * 4
    uint32 nt32 = name_tok
    unsafe { *(slot as uint32) = nt32 }
    // Default ABI kind 0 (integer); parser may override via dyn_sym_set_abi.
    uint8 zero = 0
    unsafe { *((dyn_sym_abis + dyn_sym_count) as uint8) = zero }
    uint64 idx = dyn_sym_count
    dyn_sym_count = dyn_sym_count + 1
    return idx
}

// Mark a registered @dynamic symbol as using the libm float ABI
// (1-arg-1-return f32, args/return in xmm0). Looked up by token text.
// Returns 1 on success, 0 if the symbol is not registered.
@export
fn dyn_sym_set_abi(uint64 name_tok, uint64 kind) -> uint64 {
    uint64 idx = dyn_sym_lookup(name_tok)
    if idx == 0xFFFFFFFF { return 0 }
    if dyn_sym_abis == 0 { return 0 }
    uint8 k = kind
    unsafe { *((dyn_sym_abis + idx) as uint8) = k }
    return 1
}

@export
fn dyn_sym_abi_at(uint64 idx) -> uint64 {
    if dyn_sym_abis == 0 { return 0 }
    if idx >= dyn_sym_count { return 0 }
    uint64 v = 0
    unsafe { *((dyn_sym_abis + idx) as uint8) -> v }
    return v
}

// Returns 1 if any registered @dynamic symbol uses a non-integer ABI
// (i.e., wants libm.so.6 in DT_NEEDED). Driver consults this when
// building the lib_list at link time.
@export
fn dyn_sym_any_libm() -> uint64 {
    if dyn_sym_abis == 0 { return 0 }
    uint64 i = 0
    while i < dyn_sym_count {
        uint64 v = 0
        unsafe { *((dyn_sym_abis + i) as uint8) -> v }
        if v != 0 { return 1 }
        i = i + 1
    }
    return 0
}

@export
fn dyn_sym_count_get() -> uint64 {
    return dyn_sym_count
}

@export
fn dyn_sym_tok_at(uint64 idx) -> uint32 {
    uint64 p = dyn_sym_tokens + idx * 4
    uint32 v = 0
    unsafe { *(p as uint32) -> v }
    return v
}

// Search for a token by text equivalence (not by numeric token idx).
// Returns slot_idx if found, 0xFFFFFFFF otherwise. Codegen calls this
// at Call lowering to detect @dynamic-shadowed callees.
@export
fn dyn_sym_lookup(uint64 name_tok) -> uint64 {
    uint64 i = 0
    while i < dyn_sym_count {
        uint64 slot = dyn_sym_tokens + i * 4
        uint32 stored = 0
        unsafe { *(slot as uint32) -> stored }
        uint64 ws = stored
        if tok_text_eq(ws, name_tok) != 0 { return i }
        i = i + 1
    }
    return 0xFFFFFFFF
}

// Returns 1 if any registered @dynamic symbol's name starts with "hip"
// (case-sensitive). Used by the driver to decide whether
// libamdhip64.so.7 needs to be added as DT_NEEDED alongside libc.
// A future session may replace this heuristic with a per-symbol library
// annotation (e.g. `@dynamic("libamdhip64.so.7") extern fn ...`), but
// for now every real HIP binding starts with "hip" so the prefix test
// is accurate and zero-config.
@export
fn dyn_sym_any_hip_prefix() -> uint64 {
    uint64 i = 0
    while i < dyn_sym_count {
        uint32 tok = dyn_sym_tok_at(i)
        uint64 wtok = tok
        uint64 tl = tok_text_len(wtok)
        if tl >= 3 {
            uint64 ts = tok_text_start(wtok)
            uint64 p0 = cg_source + ts
            uint64 c0 = 0
            unsafe { *(p0 as uint8) -> c0 }
            uint64 c1 = 0
            unsafe { *((p0 + 1) as uint8) -> c1 }
            uint64 c2 = 0
            unsafe { *((p0 + 2) as uint8) -> c2 }
            if c0 == 104 && c1 == 105 && c2 == 112 {
                return 1
            }
        }
        i = i + 1
    }
    return 0
}
// MLRift — built on KernRift — Archive and distribution formats
//
// Implements: ar archive (staticlib), hostexe (runtime blob + user code),
// MLRBO (portable object), and MlrboFat v2 (LZ4-compressed multi-arch fat binary)

// ---------------------------------------------------------------------------
// AR archive format (staticlib)
// ---------------------------------------------------------------------------

@export
fn emit_ar_header() {
    emit_byte(33); emit_byte(60); emit_byte(97); emit_byte(114)
    emit_byte(99); emit_byte(104); emit_byte(62); emit_byte(10)
}

@export
fn emit_ar_member(uint64 name_str, uint64 name_len, uint64 content_size) {
    uint64 i = 0
    while i < 16 {
        if i < name_len {
            uint64 np = name_str + i
            uint64 nc = 0
            unsafe { *(np as uint8) -> nc }
            uint8 nb = nc
            emit_byte(nb)
        } else { emit_byte(32) }
        i = i + 1
    }
    emit_byte(48); i = 0
    while i < 11 { emit_byte(32); i = i + 1 }
    emit_byte(48); i = 0
    while i < 5 { emit_byte(32); i = i + 1 }
    emit_byte(48); i = 0
    while i < 5 { emit_byte(32); i = i + 1 }
    emit_byte(49); emit_byte(48); emit_byte(48); emit_byte(54)
    emit_byte(52); emit_byte(52); emit_byte(32); emit_byte(32)
    uint8[10] size_buf
    uint64 sl = fmt_uint(size_buf, content_size)
    i = 0
    while i < 10 - sl { emit_byte(32); i = i + 1 }
    i = 0
    while i < sl {
        uint64 sp = size_buf + i
        uint64 sc = 0
        unsafe { *(sp as uint8) -> sc }
        uint8 sb = sc
        emit_byte(sb)
        i = i + 1
    }
    emit_byte(96); emit_byte(10)
}

// ---------------------------------------------------------------------------
// MLRBO format (portable object)
// ---------------------------------------------------------------------------
// Header: "MLRBO" (5 bytes) + version(1) + arch(1) + reserved(1)
//         + entry_offset(4) + code_length(4) = 16 bytes total

// MLRBO arch constants (don't use statics — they'd be zero-initialized)
// Use inline: x86_64 = 0x01, aarch64 = 0x02

@export
fn emit_mlrbo(uint64 arch, uint64 entry_offset, uint64 code_buf, uint64 code_len) {
    // Magic: "MLRBO"
    emit_byte(77); emit_byte(76); emit_byte(82); emit_byte(66); emit_byte(79)
    // Version
    emit_byte(1)
    // Arch
    uint8 ab = arch
    emit_byte(ab)
    // Reserved
    emit_byte(0)
    // Entry offset
    emit_u32_le(entry_offset)
    // Code length
    emit_u32_le(code_len)
    // Code bytes
    uint64 i = 0
    while i < code_len {
        uint64 p = code_buf + i
        uint64 b = 0
        unsafe { *(p as uint8) -> b }
        uint8 bb = b
        emit_byte(bb)
        i = i + 1
    }
}

// ---------------------------------------------------------------------------
// LZ-Rift block compression (ported from KernRift-experimental)
// ---------------------------------------------------------------------------
// LZ4-compatible frame format with a KernRift-specific block variant:
//   - 24-bit offsets (16 MB window vs standard LZ4's 64 KB)
//   - 65536-slot hash table with 2 candidates per bucket
//   - bounded lazy matching (threshold: match_len < 48)
//   - 64-bit-then-byte match extension for speed
//
// Frame envelope: Magic(4) + FLG(1) + BD(1) + HC(1) = 7 bytes
//   Block: size(4) + data(N)   (bit 31 set => uncompressed)
//   End mark: 0x00000000 (4 bytes)
//
// Block format (bit 31 clear):
//   Sequence* = token(1) + extra_lit_len(*) + literals + offset(3, LE)
//                         + extra_match_len(*)
//   Last 5 bytes are always literals. Last match starts ≥12 bytes before EOB.

fn lz4_load_u32_le(uint64 p) -> uint64 {
    uint32 v = 0
    unsafe { *(p as uint32) -> v }
    uint64 wv = v
    return wv
}

fn lz4_load_u64_le(uint64 p) -> uint64 {
    uint64 v = 0
    unsafe { *(p as uint64) -> v }
    return v
}

fn lz4_load_u8(uint64 p) -> uint64 {
    uint64 v = 0
    unsafe { *(p as uint8) -> v }
    return v
}

fn lz4_store_u8(uint64 p, uint64 val) {
    uint8 b = val
    unsafe { *(p as uint8) = b }
}

fn lz4_hash4(uint64 x) -> uint64 {
    uint64 h = x * 2654435761
    return (h >> 16) & 0xFFFF
}

fn lz4_extend_match(uint64 src, uint64 mpos, uint64 src_pos, uint64 start_len, uint64 match_extend_limit) -> uint64 {
    uint64 match_len = start_len
    // 8-byte fast path
    while src_pos + match_len + 8 <= match_extend_limit {
        uint64 mw = lz4_load_u64_le(src + mpos + match_len)
        uint64 sw = lz4_load_u64_le(src + src_pos + match_len)
        if mw != sw { break }
        match_len = match_len + 8
    }
    // byte-wise tail
    while src_pos + match_len < match_extend_limit {
        uint64 mb = lz4_load_u8(src + mpos + match_len)
        uint64 sb = lz4_load_u8(src + src_pos + match_len)
        if mb != sb { break }
        match_len = match_len + 1
    }
    return match_len
}

fn lz4_try_match(uint64 src, uint64 src_pos, uint64 mpos, uint64 cur4, uint64 match_extend_limit) -> uint64 {
    if mpos == 0xFFFFFFFF { return 0 }
    if src_pos <= mpos { return 0 }
    uint64 offset = src_pos - mpos
    if offset > 16777215 { return 0 }
    if lz4_load_u32_le(src + mpos) != cur4 { return 0 }
    return lz4_extend_match(src, mpos, src_pos, 4, match_extend_limit)
}

fn lz4_hash_insert(uint64 hash_table, uint64 hash_table2, uint64 src_pos, uint64 cur4) {
    uint64 h = lz4_hash4(cur4)
    uint64 hp = hash_table + h * 4
    uint64 hp2 = hash_table2 + h * 4
    uint32 prev_raw = 0
    unsafe { *(hp as uint32) -> prev_raw }
    unsafe { *(hp2 as uint32) = prev_raw }
    uint32 sp32 = src_pos
    unsafe { *(hp as uint32) = sp32 }
}

fn lz4_find_best_match(
    uint64 hash_table, uint64 hash_table2,
    uint64 src, uint64 src_pos, uint64 cur4, uint64 match_extend_limit,
    uint64 out_mpos_ptr
) -> uint64 {
    uint64 h = lz4_hash4(cur4)
    uint64 hp = hash_table + h * 4
    uint64 hp2 = hash_table2 + h * 4
    uint32 mpos_raw = 0
    unsafe { *(hp as uint32) -> mpos_raw }
    uint32 mpos2_raw = 0
    unsafe { *(hp2 as uint32) -> mpos2_raw }
    uint64 mpos = mpos_raw
    uint64 mpos2 = mpos2_raw

    uint64 best_mpos = 0xFFFFFFFF
    uint64 match_len = lz4_try_match(src, src_pos, mpos, cur4, match_extend_limit)
    if match_len != 0 { best_mpos = mpos }

    // Check older candidate — often finds a longer cross-function match.
    if match_len < 32 {
        uint64 match_len2 = lz4_try_match(src, src_pos, mpos2, cur4, match_extend_limit)
        if match_len2 > match_len {
            match_len = match_len2
            best_mpos = mpos2
        }
    }

    unsafe { *(out_mpos_ptr as uint64) = best_mpos }
    return match_len
}

// Worst-case frame size for this encoder.
@export
fn lz4_compress_bound(uint64 input_len) -> uint64 {
    return input_len + 17 + (input_len / 255)
}

// Compress a single block. Returns bytes written to `dst`.
// Callers must size dst with lz4_compress_bound(input_len) or more.
@export
fn lz4_compress_block(uint64 src, uint64 src_len, uint64 dst) -> uint64 {
    uint64 dst_pos = 0

    if src_len < 13 {
        uint64 lit_code = src_len
        if lit_code >= 15 {
            lz4_store_u8(dst + dst_pos, 0xF0)
            dst_pos = dst_pos + 1
            uint64 rem = lit_code - 15
            while rem >= 255 {
                lz4_store_u8(dst + dst_pos, 255)
                dst_pos = dst_pos + 1
                rem = rem - 255
            }
            lz4_store_u8(dst + dst_pos, rem)
            dst_pos = dst_pos + 1
        } else {
            lz4_store_u8(dst + dst_pos, lit_code << 4)
            dst_pos = dst_pos + 1
        }
        memcpy(dst + dst_pos, src, src_len)
        dst_pos = dst_pos + src_len
        return dst_pos
    }

    uint64 hash_size = 65536
    uint64 hash_table = alloc(hash_size * 4)
    uint64 hash_table2 = alloc(hash_size * 4)
    memset(hash_table, 255, hash_size * 4)
    memset(hash_table2, 255, hash_size * 4)

    uint64 src_pos = 0
    uint64 lit_start = 0
    uint64 match_search_limit = src_len - 12
    uint64 match_extend_limit = src_len - 5

    // Hoist the single-slot output buffers out of the loop — KernRift compiles
    // `uint64[1] foo` to a heap alloc with no auto-free, so declaring them
    // inside the match search leaked ~8 B per iteration. On a self-compile
    // fat binary that meant ~4 million mmap(16) calls, each rounded up to a
    // full 4 KB page (~18 GB RSS — past GitHub runners' 16 GB budget).
    uint64[1] best_mpos_slot
    uint64[1] next_mpos_slot

    while src_pos < match_search_limit {
        uint64 cur4 = lz4_load_u32_le(src + src_pos)
        uint64 match_len = lz4_find_best_match(
            hash_table, hash_table2,
            src, src_pos, cur4, match_extend_limit,
            best_mpos_slot
        )
        uint64 best_mpos = 0
        unsafe { *(best_mpos_slot as uint64) -> best_mpos }
        lz4_hash_insert(hash_table, hash_table2, src_pos, cur4)

        if match_len == 0 {
            src_pos = src_pos + 1
            continue
        }

        // Bounded lazy matching
        if match_len < 48 && src_pos + 1 < match_search_limit {
            uint64 next_pos = src_pos + 1
            uint64 next_cur4 = lz4_load_u32_le(src + next_pos)
            uint64 next_match_len = lz4_find_best_match(
                hash_table, hash_table2,
                src, next_pos, next_cur4, match_extend_limit,
                next_mpos_slot
            )
            if next_match_len > match_len + 1 {
                src_pos = next_pos
                continue
            }
        }

        uint64 offset = src_pos - best_mpos

        uint64 lit_len = src_pos - lit_start
        uint64 lit_code = 15
        if lit_len < 15 { lit_code = lit_len }
        uint64 ml_code = 15
        uint64 ml_raw = match_len - 4
        if ml_raw < 15 { ml_code = ml_raw }

        lz4_store_u8(dst + dst_pos, (lit_code << 4) | ml_code)
        dst_pos = dst_pos + 1

        if lit_len >= 15 {
            uint64 rem = lit_len - 15
            while rem >= 255 {
                lz4_store_u8(dst + dst_pos, 255)
                dst_pos = dst_pos + 1
                rem = rem - 255
            }
            lz4_store_u8(dst + dst_pos, rem)
            dst_pos = dst_pos + 1
        }

        if lit_len != 0 {
            memcpy(dst + dst_pos, src + lit_start, lit_len)
            dst_pos = dst_pos + lit_len
        }

        // 24-bit offset (LZ-Rift)
        lz4_store_u8(dst + dst_pos, offset & 0xFF)
        dst_pos = dst_pos + 1
        lz4_store_u8(dst + dst_pos, (offset >> 8) & 0xFF)
        dst_pos = dst_pos + 1
        lz4_store_u8(dst + dst_pos, (offset >> 16) & 0xFF)
        dst_pos = dst_pos + 1

        if ml_raw >= 15 {
            uint64 rem_m = ml_raw - 15
            while rem_m >= 255 {
                lz4_store_u8(dst + dst_pos, 255)
                dst_pos = dst_pos + 1
                rem_m = rem_m - 255
            }
            lz4_store_u8(dst + dst_pos, rem_m)
            dst_pos = dst_pos + 1
        }

        src_pos = src_pos + match_len
        lit_start = src_pos
    }

    uint64 final_lit = src_len - lit_start
    uint64 lit_code_f = 15
    if final_lit < 15 { lit_code_f = final_lit }
    lz4_store_u8(dst + dst_pos, lit_code_f << 4)
    dst_pos = dst_pos + 1
    if final_lit >= 15 {
        uint64 rem_f = final_lit - 15
        while rem_f >= 255 {
            lz4_store_u8(dst + dst_pos, 255)
            dst_pos = dst_pos + 1
            rem_f = rem_f - 255
        }
        lz4_store_u8(dst + dst_pos, rem_f)
        dst_pos = dst_pos + 1
    }
    if final_lit != 0 {
        memcpy(dst + dst_pos, src + lit_start, final_lit)
        dst_pos = dst_pos + final_lit
    }

    dealloc(hash_table2)
    dealloc(hash_table)
    return dst_pos
}

@export
fn lz4_compress_frame(uint64 input_buf, uint64 input_len, uint64 output_buf) -> uint64 {
    uint64 out_pos = 0

    uint64 p = output_buf + out_pos
    uint32 magic = 0x184D2204
    unsafe { *(p as uint32) = magic }
    out_pos = out_pos + 4
    lz4_store_u8(output_buf + out_pos, 0x60); out_pos = out_pos + 1
    lz4_store_u8(output_buf + out_pos, 0x40); out_pos = out_pos + 1
    lz4_store_u8(output_buf + out_pos, 0x82); out_pos = out_pos + 1

    uint64 bs_off = out_pos
    out_pos = out_pos + 4
    uint64 block_data_start = out_pos

    uint64 comp_len = lz4_compress_block(input_buf, input_len, output_buf + out_pos)

    uint64 block_hdr = 0
    if comp_len < input_len {
        out_pos = block_data_start + comp_len
        block_hdr = comp_len
    } else {
        memcpy(output_buf + block_data_start, input_buf, input_len)
        out_pos = block_data_start + input_len
        block_hdr = input_len | 0x80000000
    }

    uint64 bs_p = output_buf + bs_off
    uint32 bs32 = block_hdr
    unsafe { *(bs_p as uint32) = bs32 }

    uint64 ep = output_buf + out_pos
    uint32 zero = 0
    unsafe { *(ep as uint32) = zero }
    out_pos = out_pos + 4

    return out_pos
}

// ---------------------------------------------------------------------------
// MlrboFat v2 format (LZ4-compressed multi-arch fat binary)
// ---------------------------------------------------------------------------
// Header: "MLRBOFAT" (8 bytes) + version(u32=2) + arch_count(u32) = 16 bytes
// Per-arch entry (48 bytes):
//   arch_id(u32) + compression(u32=1 for LZ4) + offset(u64) + compressed_size(u64)
//   + uncompressed_size(u64) + runtime_offset(u64) + runtime_len(u64)
// Then: compressed MLRBO blobs, then runtime blobs

@export
fn emit_mlrbofat_v2_header(uint64 arch_count) {
    // Magic: "MLRBOFAT" (8 bytes, no NUL)
    emit_byte(77); emit_byte(76); emit_byte(82); emit_byte(66)
    emit_byte(79); emit_byte(70); emit_byte(65); emit_byte(84)
    // Version = 2
    emit_u32_le(2)
    // Arch count
    emit_u32_le(arch_count)
}

@export
fn emit_mlrbofat_v2_entry_hdr(uint64 arch_id, uint64 compression, uint64 offset, uint64 compressed_size, uint64 uncompressed_size) {
    emit_u32_le(arch_id)
    emit_u32_le(compression)
    emit_u64_le(offset)
    emit_u64_le(compressed_size)
    emit_u64_le(uncompressed_size)
}

@export
fn emit_mlrbofat_v2_entry_rt(uint64 runtime_offset, uint64 runtime_len) {
    emit_u64_le(runtime_offset)
    emit_u64_le(runtime_len)
}
// MLRift — built on KernRift — Android PIE ELF output format
//
// PIE ELF for Android (ARM64 and x86_64). Minimal dynamic linking structures.
// Both arches share the same layout — only e_machine differs.
//
// Sections: .dynstr .dynsym .gnu.hash .dynamic .shstrtab
// Dynamic entries: DT_STRTAB DT_STRSZ DT_SYMTAB DT_SYMENT DT_GNU_HASH DT_NULL
//
// Program headers: PT_PHDR, PT_INTERP, PT_LOAD(RX), PT_DYNAMIC, PT_LOAD(RW)
//
// Patch offsets (same for both arches):
//   e_entry          @24
//   PT_LOAD RX:  p_filesz @208  p_memsz @216
//   PT_LOAD RW:  p_offset @296  p_vaddr @304  p_paddr @312
//                p_filesz @320  p_memsz @328

@export
fn emit_elf_header_android_a64() {
    emit_elf_header_android_pie(0xB7)
}

@export
fn emit_elf_header_android_x86_64() {
    emit_elf_header_android_pie(0x3E)
}

fn emit_elf_header_android_pie(uint64 e_machine) {
    // All offsets pre-calculated (5 phdrs):
    // phdr: 64, interp_str: 344, dynstr: 368, dynsym: 376, gnu_hash: 400
    // dynamic: 432, shstrtab: 528, shdr: 576

    // ---- ELF header [0..64) ----
    emit_byte(0x7F); emit_byte(69); emit_byte(76); emit_byte(70)
    emit_byte(2); emit_byte(1); emit_byte(1); emit_byte(0)
    uint64 i = 0
    while i < 8 { emit_byte(0); i = i + 1 }
    emit_u16_le(3)          // e_type = ET_DYN
    emit_u16_le(e_machine)  // 0xB7 arm64 | 0x3E x86_64
    emit_u32_le(1)
    emit_u64_le(0)      // e_entry @24 (patched)
    emit_u64_le(64)     // e_phoff
    emit_u64_le(576)    // e_shoff
    emit_u32_le(0)
    emit_u16_le(64)     // e_ehsize
    emit_u16_le(56)     // e_phentsize
    emit_u16_le(5)      // e_phnum
    emit_u16_le(64)     // e_shentsize
    emit_u16_le(6)      // e_shnum (null + .dynstr + .dynsym + .gnu.hash + .dynamic + .shstrtab)
    emit_u16_le(5)      // e_shstrndx = 5

    // ---- PT_PHDR [64..120) ----
    emit_u32_le(6); emit_u32_le(4)
    emit_u64_le(64); emit_u64_le(64); emit_u64_le(64)
    emit_u64_le(280); emit_u64_le(280); emit_u64_le(8)  // 5 phdrs × 56 = 280

    // ---- PT_INTERP [120..176) ----
    emit_u32_le(3); emit_u32_le(4)
    emit_u64_le(344); emit_u64_le(344); emit_u64_le(344)
    emit_u64_le(21); emit_u64_le(21); emit_u64_le(1)

    // ---- PT_LOAD RX [176..232) ----
    emit_u32_le(1); emit_u32_le(5)  // R+X
    emit_u64_le(0); emit_u64_le(0); emit_u64_le(0)
    emit_u64_le(0)      // p_filesz @208 (patched)
    emit_u64_le(0)      // p_memsz @216 (patched)
    emit_u64_le(0x10000)

    // ---- PT_DYNAMIC [232..288) ----
    emit_u32_le(2); emit_u32_le(4)  // R
    emit_u64_le(432); emit_u64_le(432); emit_u64_le(432)
    emit_u64_le(96); emit_u64_le(96); emit_u64_le(8)  // 6 entries × 16 = 96

    // ---- PT_LOAD RW [288..344) ----
    emit_u32_le(1); emit_u32_le(6)  // R+W
    emit_u64_le(0)      // p_offset @296 (patched)
    emit_u64_le(0)      // p_vaddr  @304 (patched)
    emit_u64_le(0)      // p_paddr  @312 (patched)
    emit_u64_le(0)      // p_filesz @320 (patched)
    emit_u64_le(0)      // p_memsz  @328 (patched)
    emit_u64_le(0x10000)

    // ---- Interp [344..365) = 21 bytes ----
    emit_byte(47); emit_byte(115); emit_byte(121); emit_byte(115)
    emit_byte(116); emit_byte(101); emit_byte(109); emit_byte(47)
    emit_byte(98); emit_byte(105); emit_byte(110); emit_byte(47)
    emit_byte(108); emit_byte(105); emit_byte(110); emit_byte(107)
    emit_byte(101); emit_byte(114); emit_byte(54); emit_byte(52)
    emit_byte(0)

    // ---- Padding [365..368) = 3 bytes ----
    emit_byte(0); emit_byte(0); emit_byte(0)

    // ---- .dynstr [368..376) = 8 bytes (padded to 8-align) ----
    emit_byte(0)  // just the null string
    i = 0
    while i < 7 { emit_byte(0); i = i + 1 }

    // ---- .dynsym [376..400) = 24 bytes = 1 NULL Elf64_Sym ----
    i = 0
    while i < 24 { emit_byte(0); i = i + 1 }

    // ---- .gnu.hash [400..432) = 32 bytes (28 data + 4 pad) ----
    emit_u32_le(1)      // nbuckets
    emit_u32_le(1)      // symndx
    emit_u32_le(1)      // maskwords
    emit_u32_le(0)      // shift2
    emit_u64_le(0)      // bloom[0]
    emit_u32_le(0)      // buckets[0]
    emit_u32_le(0)      // padding

    // ---- .dynamic [432..528) = 6 entries × 16 = 96 bytes ----
    // DT_STRTAB (5)
    emit_u64_le(5); emit_u64_le(368)
    // DT_STRSZ (10)
    emit_u64_le(10); emit_u64_le(1)
    // DT_SYMTAB (6)
    emit_u64_le(6); emit_u64_le(376)
    // DT_SYMENT (11)
    emit_u64_le(11); emit_u64_le(24)
    // DT_GNU_HASH (0x6FFFFEF5)
    emit_u64_le(0x6FFFFEF5); emit_u64_le(400)
    // DT_NULL
    emit_u64_le(0); emit_u64_le(0)

    // ---- .shstrtab [528..576) = 48 bytes ----
    // "\0.dynstr\0.dynsym\0.gnu.hash\0.dynamic\0.shstrtab\0" + pad
    // offsets: 0=\0, 1=.dynstr, 9=.dynsym, 17=.gnu.hash, 27=.dynamic, 36=.shstrtab
    emit_byte(0)                                                     // 0
    emit_byte(46); emit_byte(100); emit_byte(121); emit_byte(110)   // .dyn
    emit_byte(115); emit_byte(116); emit_byte(114); emit_byte(0)    // str\0 (off 1)
    emit_byte(46); emit_byte(100); emit_byte(121); emit_byte(110)   // .dyn
    emit_byte(115); emit_byte(121); emit_byte(109); emit_byte(0)    // sym\0 (off 9)
    emit_byte(46); emit_byte(103); emit_byte(110); emit_byte(117)   // .gnu
    emit_byte(46); emit_byte(104); emit_byte(97); emit_byte(115)    // .has
    emit_byte(104); emit_byte(0)                                     // h\0 (off 17)
    emit_byte(46); emit_byte(100); emit_byte(121); emit_byte(110)   // .dyn
    emit_byte(97); emit_byte(109); emit_byte(105); emit_byte(99)    // amic
    emit_byte(0)                                                     // \0 (off 27)
    emit_byte(46); emit_byte(115); emit_byte(104); emit_byte(115)   // .shs
    emit_byte(116); emit_byte(114); emit_byte(116); emit_byte(97)   // trta
    emit_byte(98); emit_byte(0)                                      // b\0 (off 36)
    // total = 1+8+8+10+9+10 = 46 bytes. Pad to 48.
    emit_byte(0); emit_byte(0)

    // ---- Section headers [576..960) = 6 × 64 ----

    // Section 0: null
    i = 0
    while i < 64 { emit_byte(0); i = i + 1 }

    // Section 1: .dynstr
    emit_u32_le(1); emit_u32_le(3)   // SHT_STRTAB
    emit_u64_le(2)                    // SHF_ALLOC
    emit_u64_le(368); emit_u64_le(368); emit_u64_le(1)
    emit_u32_le(0); emit_u32_le(0)
    emit_u64_le(1); emit_u64_le(0)

    // Section 2: .dynsym
    emit_u32_le(9); emit_u32_le(11)  // SHT_DYNSYM
    emit_u64_le(2)                    // SHF_ALLOC
    emit_u64_le(376); emit_u64_le(376); emit_u64_le(24)
    emit_u32_le(1)                    // sh_link = 1 (.dynstr)
    emit_u32_le(1)                    // sh_info = 1 (first non-local symbol)
    emit_u64_le(8); emit_u64_le(24)

    // Section 3: .gnu.hash
    emit_u32_le(17); emit_u32_le(0x6FFFFFF6) // SHT_GNU_HASH
    emit_u64_le(2)                    // SHF_ALLOC
    emit_u64_le(400); emit_u64_le(400); emit_u64_le(28)
    emit_u32_le(2)                    // sh_link = 2 (.dynsym)
    emit_u32_le(0)
    emit_u64_le(8); emit_u64_le(0)

    // Section 4: .dynamic
    emit_u32_le(27); emit_u32_le(6)  // SHT_DYNAMIC
    emit_u64_le(2)                    // SHF_ALLOC
    emit_u64_le(432); emit_u64_le(432); emit_u64_le(96)
    emit_u32_le(1)                    // sh_link = 1 (.dynstr)
    emit_u32_le(0)
    emit_u64_le(8); emit_u64_le(16)

    // Section 5: .shstrtab
    emit_u32_le(36); emit_u32_le(3)  // SHT_STRTAB
    emit_u64_le(0)
    emit_u64_le(528); emit_u64_le(528); emit_u64_le(46)
    emit_u32_le(0); emit_u32_le(0)
    emit_u64_le(1); emit_u64_le(0)

    // ---- Padding to 1024 ----
    while out_len < 1024 { emit_byte(0) }
}
// x86_64 BCJ (Branch/Call/Jump) Filter for Extreme Compression
// Normalizes E8 (CALL) and E9 (JMP) relative offsets to absolute addresses.
// Because we use a blind scan, the operation MUST be perfectly symmetric.

@export
fn filter_x86_64_bcj(uint64 buf, uint64 size, uint64 is_encode) {
    // We need at least 5 bytes to find a CALL/JMP + rel32
    if size < 5 { return }
    
    uint64 limit = size - 4
    uint64 i = 0
    
    while i < limit {
        uint64 p = buf + i
        uint8 op = 0
        unsafe { *(p as uint8) -> op }
        
        // 0xE8 = CALL, 0xE9 = JMP
        if op == 0xE8 || op == 0xE9 {
            // Read the 32-bit relative offset
            uint64 p_rel = p + 1
            uint32 rel32 = 0
            unsafe { *(p_rel as uint32) -> rel32 }
            
            uint32 new_rel32 = 0
            
            // The offset is relative to the NEXT instruction (i + 5)
            // We use 32-bit modular arithmetic to ensure perfect reversibility
            uint32 current_ip = i + 5
            
            if is_encode != 0 {
                // Encode: Relative -> Absolute
                new_rel32 = rel32 + current_ip
            } else {
                // Decode: Absolute -> Relative
                new_rel32 = rel32 - current_ip
            }
            
            // Write the transformed 32-bit value back
            unsafe { *(p_rel as uint32) = new_rel32 }
            
            // Skip the next 4 bytes since we just transformed them
            i += 4
        }
        
        i += 1
    }
}
// AArch64 BCJ (Branch/Call/Jump) Filter for Extreme LZ4 Compression
// Converts relative branch offsets to absolute virtual addresses before compression,
// and restores them after decompression. This makes function calls to the same target
// look identical in the byte stream, supercharging LZ4's dictionary match finder.

@export
fn filter_aarch64_bcj(uint64 buf, uint64 size, uint64 is_encode) {
    uint64 i = 0
    // Iterate over 4-byte instructions
    while i < size {
        uint64 p = buf + i
        uint32 insn = 0
        unsafe { *(p as uint32) -> insn }
        
        // AArch64 B (Branch) and BL (Branch with Link) share the top 6 bits (31:26)
        // B:  000101 (0x14) -> 0x14000000
        // BL: 100101 (0x94) -> 0x94000000
        // Mask: 111111 (0xFC) -> 0xFC000000
        
        uint32 op_mask = insn & 0xFC000000
        if op_mask == 0x14000000 || op_mask == 0x94000000 {
            // Extract the 26-bit immediate (rel26)
            uint32 imm26 = insn & 0x03FFFFFF
            
            // Sign-extend the 26-bit immediate to 32 bits
            // Check bit 25 (the sign bit): 0x02000000
            uint32 is_negative = imm26 & 0x02000000
            if is_negative != 0 {
                // Pad the top 6 bits with 1s
                imm26 = imm26 | 0xFC000000
            }
            
            // The actual offset in bytes is imm26 * 4
            // (But we can just do the math on the 32-bit word directly to avoid overflow)
            uint32 offset_bytes = imm26 << 2
            
            uint32 new_imm26 = 0
            
            if is_encode != 0 {
                // Encode: Relative offset -> Absolute Address
                // target_addr = current_offset + relative_offset
                uint32 current_offset = i
                uint32 target_addr = current_offset + offset_bytes
                
                // Convert back to 26-bit immediate (divided by 4)
                new_imm26 = (target_addr >> 2) & 0x03FFFFFF
            } else {
                // Decode: Absolute Address -> Relative offset
                // relative_offset = target_addr - current_offset
                uint32 current_offset = i
                
                // The 'offset_bytes' currently holds the Absolute Address we packed earlier
                uint32 target_addr = offset_bytes
                uint32 restored_offset_bytes = target_addr - current_offset
                
                // Convert back to 26-bit immediate (divided by 4)
                new_imm26 = (restored_offset_bytes >> 2) & 0x03FFFFFF
            }
            
            // Reconstruct the instruction and write it back
            uint32 new_insn = op_mask | new_imm26
            unsafe { *(p as uint32) = new_insn }
        }
        
        i = i + 4
    }
}
// MLRift — built on KernRift — Analysis Passes
//
// Implements kernel safety checks:
//   1. Context check (ctx): verify caller/callee context compatibility
//   2. Effect check (eff): verify declared effects match actual operations
//   3. Lock graph: detect potential deadlocks via lock ordering
//   4. Capability check (caps): verify module capability declarations
//   5. Critical region: no alloc/block inside critical sections
//   6. Unsafe pointer check: track raw pointer usage

// ---------------------------------------------------------------------------
// Annotation storage
// ---------------------------------------------------------------------------
// Each function can have annotations: @ctx(...), @eff(...), @caps(...)
// Store as: [fn_tok(4), ann_type(4), ann_data(8)] × 4096

static uint64 ann_table = 0
static uint64 ann_count = 0

// Semantic validation statics
static uint64 fn_sig_table = 0
static uint64 fn_sig_count = 0
static uint64 sema_errors = 0
static uint64 sema_source = 0
static uint64 sema_tok_buf = 0

// Diagnostic collection
static uint64 diag_table = 0
static uint64 diag_count = 0
static uint64 diag_error_count = 0
static uint64 diag_warn_count = 0

// Annotation types
// 0 = ctx (context: task, irq, nmi, any)
// 1 = eff (effect: io, alloc, block, net, fs, none)
// 2 = caps (capability: mmio, dma, irq, port_io, sched)
// 3 = export

@export
fn analysis_init() {
    ann_table = alloc(4096 * 16)
    ann_count = 0
}

fn ann_register(uint64 fn_tok, uint64 ann_type, uint64 ann_data) {
    uint64 entry = ann_table + ann_count * 16
    uint32 ft = fn_tok
    unsafe { *(entry as uint32) = ft }
    uint64 e4 = entry + 4
    uint32 atype = ann_type
    unsafe { *(e4 as uint32) = atype }
    uint64 e8 = entry + 8
    unsafe { *(e8 as uint64) = ann_data }
    ann_count = ann_count + 1
}

fn ann_lookup(uint64 fn_tok, uint64 ann_type) -> uint64 {
    uint64 i = 0
    while i < ann_count {
        uint64 entry = ann_table + i * 16
        uint32 stored_fn = 0
        unsafe { *(entry as uint32) -> stored_fn }
        uint64 wfn = stored_fn
        if tok_text_eq(wfn, fn_tok) != 0 {
            uint64 e4 = entry + 4
            uint32 stored_type = 0
            unsafe { *(e4 as uint32) -> stored_type }
            uint64 wt = stored_type
            if wt == ann_type {
                uint64 e8 = entry + 8
                uint64 data = 0
                unsafe { *(e8 as uint64) -> data }
                return data
            }
        }
        i = i + 1
    }
    return 0xFFFFFFFF
}

// ---------------------------------------------------------------------------
// Context check
// ---------------------------------------------------------------------------
// Context hierarchy: nmi > irq > task > any
// Rule: caller ctx must be subset of callee ctx
// If a function is @ctx(irq), it cannot call @ctx(task) functions
// Context values: 0=any, 1=task, 2=irq, 3=nmi

static uint64 ctx_errors = 0

@export
fn check_ctx(uint64 root) {
    ctx_errors = 0
    // Walk all functions, check each call site
    uint32 child = ast_child(root)
    uint64 wchild = child
    while wchild != 0 {
        uint32 ck = ast_kind(wchild)
        if ck == 2 {
            uint32 fn_tok = ast_data1(wchild)
            uint64 caller_ctx = ann_lookup(fn_tok, 0)
            if caller_ctx == 0xFFFFFFFF { caller_ctx = 0 }
            // Walk function body for calls
            uint32 body = ast_data3(wchild)
            uint64 wbody = body
            if wbody != 0 {
                check_ctx_block(wbody, fn_tok, caller_ctx)
            }
        }
        uint32 nxt = ast_next(wchild)
        wchild = nxt
    }
}

fn check_ctx_block(uint64 block_node, uint64 caller_tok, uint64 caller_ctx) {
    uint32 child = ast_child(block_node)
    uint64 wchild = child
    while wchild != 0 {
        check_ctx_stmt(wchild, caller_tok, caller_ctx)
        uint32 nxt = ast_next(wchild)
        wchild = nxt
    }
}

fn check_ctx_stmt(uint64 node, uint64 caller_tok, uint64 caller_ctx) {
    uint32 kind = ast_kind(node)
    // Expression statement containing a call
    if kind == 16 {
        uint32 expr = ast_child(node)
        uint64 wexpr = expr
        check_ctx_expr(wexpr, caller_tok, caller_ctx)
    }
    // If statement: check both branches
    if kind == 13 {
        uint32 then_body = ast_data1(node)
        uint64 wt = then_body
        if wt != 0 { check_ctx_block(wt, caller_tok, caller_ctx) }
        uint32 else_body = ast_data2(node)
        uint64 we = else_body
        if we != 0 {
            uint32 ek = ast_kind(we)
            if ek == 13 { check_ctx_stmt(we, caller_tok, caller_ctx) }
            else { check_ctx_block(we, caller_tok, caller_ctx) }
        }
    }
    // While: check body
    if kind == 14 {
        uint32 body = ast_data1(node)
        uint64 wb = body
        if wb != 0 { check_ctx_block(wb, caller_tok, caller_ctx) }
    }
}

fn check_ctx_expr(uint64 node, uint64 caller_tok, uint64 caller_ctx) {
    uint32 kind = ast_kind(node)
    if kind == 35 {
        // Function call: check callee context
        uint32 callee_tok = ast_data1(node)
        uint64 callee_ctx = ann_lookup(callee_tok, 0)
        if callee_ctx == 0xFFFFFFFF { callee_ctx = 0 }
        // If caller is in a restricted context (irq/nmi) and callee requires task context
        if caller_ctx > callee_ctx && callee_ctx != 0 {
            // Context violation!
            uint64 msg = "ctx-check: context violation in "
            write(2, msg, 33)
            uint64 ts = tok_text_start(caller_tok)
            uint64 tl = tok_text_len(caller_tok)
            write(2, cg_source + ts, tl)
            msg = "\n"
            write(2, msg, 1)
            ctx_errors = ctx_errors + 1
        }
    }
}

// ---------------------------------------------------------------------------
// Effect check
// ---------------------------------------------------------------------------
// Effects: io=1, alloc=2, block=4, net=8, fs=16
// Rule: function's actual effects must be subset of declared effects

static uint64 eff_errors = 0

@export
fn check_effects(uint64 root) {
    eff_errors = 0
    uint32 child = ast_child(root)
    uint64 wchild = child
    while wchild != 0 {
        uint32 ck = ast_kind(wchild)
        if ck == 2 {
            uint32 fn_tok = ast_data1(wchild)
            uint64 declared_eff = ann_lookup(fn_tok, 1)
            if declared_eff == 0xFFFFFFFF { declared_eff = 0xFFFF }
            // Compute actual effects from body
            uint32 body = ast_data3(wchild)
            uint64 wbody = body
            uint64 actual_eff = 0
            if wbody != 0 {
                actual_eff = compute_effects_block(wbody)
            }
            // Check: actual must be subset of declared
            if (actual_eff & ~declared_eff) != 0 {
                uint64 msg = "eff-check: undeclared effect in "
                write(2, msg, 33)
                uint64 ts = tok_text_start(fn_tok)
                uint64 tl = tok_text_len(fn_tok)
                write(2, cg_source + ts, tl)
                msg = "\n"
                write(2, msg, 1)
                eff_errors = eff_errors + 1
            }
        }
        uint32 nxt = ast_next(wchild)
        wchild = nxt
    }
}

fn compute_effects_block(uint64 block_node) -> uint64 {
    uint64 effects = 0
    uint32 child = ast_child(block_node)
    uint64 wchild = child
    while wchild != 0 {
        effects = effects | compute_effects_stmt(wchild)
        uint32 nxt = ast_next(wchild)
        wchild = nxt
    }
    return effects
}

fn compute_effects_stmt(uint64 node) -> uint64 {
    uint32 kind = ast_kind(node)
    uint64 effects = 0
    if kind == 16 {
        uint32 expr = ast_child(node)
        uint64 wexpr = expr
        effects = effects | compute_effects_expr(wexpr)
    }
    if kind == 13 {
        uint32 then_body = ast_data1(node)
        uint64 wt = then_body
        if wt != 0 { effects = effects | compute_effects_block(wt) }
        uint32 else_body = ast_data2(node)
        uint64 we = else_body
        if we != 0 { effects = effects | compute_effects_block(we) }
    }
    if kind == 14 {
        uint32 body = ast_data1(node)
        uint64 wb = body
        if wb != 0 { effects = effects | compute_effects_block(wb) }
    }
    return effects
}

fn compute_effects_expr(uint64 node) -> uint64 {
    uint32 kind = ast_kind(node)
    if kind == 35 {
        uint32 callee_tok = ast_data1(node)
        // Check for known effectful builtins
        if tok_matches(callee_tok, "alloc", 5) != 0 { return 2 }
        if tok_matches(callee_tok, "write", 5) != 0 { return 1 }
        if tok_matches(callee_tok, "file_open", 9) != 0 { return 16 }
        if tok_matches(callee_tok, "file_read", 9) != 0 { return 16 }
        if tok_matches(callee_tok, "file_write", 10) != 0 { return 16 }
        // Look up callee's declared effects (transitive)
        uint64 callee_eff = ann_lookup(callee_tok, 1)
        if callee_eff != 0xFFFFFFFF { return callee_eff }
    }
    return 0
}

// ---------------------------------------------------------------------------
// Lock graph (deadlock detection)
// ---------------------------------------------------------------------------
// Track lock acquire/release patterns
// Build directed graph: if fn A holds lock X and acquires lock Y, add edge X→Y
// Detect cycles in the graph

static uint64 lock_edges = 0
static uint64 lock_edge_count = 0

@export
fn lock_graph_init() {
    lock_edges = alloc(1024 * 16)
    lock_edge_count = 0
}

fn lock_add_edge(uint64 from_tok, uint64 to_tok) {
    uint64 entry = lock_edges + lock_edge_count * 16
    uint32 ft = from_tok
    unsafe { *(entry as uint32) = ft }
    uint64 e4 = entry + 4
    uint32 tt = to_tok
    unsafe { *(e4 as uint32) = tt }
    lock_edge_count = lock_edge_count + 1
}

// Detect cycles using DFS (simplified)
@export
fn check_lock_cycles() -> uint64 {
    // For each lock, do DFS from it. If we revisit it, cycle found.
    // Simplified: just check for direct A→B and B→A pairs
    uint64 i = 0
    while i < lock_edge_count {
        uint64 entry_i = lock_edges + i * 16
        uint32 from_i = 0
        unsafe { *(entry_i as uint32) -> from_i }
        uint64 ei4 = entry_i + 4
        uint32 to_i = 0
        unsafe { *(ei4 as uint32) -> to_i }
        // Check if reverse edge exists
        uint64 j = 0
        while j < lock_edge_count {
            if j != i {
                uint64 entry_j = lock_edges + j * 16
                uint32 from_j = 0
                unsafe { *(entry_j as uint32) -> from_j }
                uint64 ej4 = entry_j + 4
                uint32 to_j = 0
                unsafe { *(ej4 as uint32) -> to_j }
                uint64 wfi = from_i
                uint64 wfj = from_j
                uint64 wti = to_i
                uint64 wtj = to_j
                if tok_text_eq(wfi, wtj) != 0 && tok_text_eq(wti, wfj) != 0 {
                    uint64 msg = "lock-cycle: potential deadlock between locks\n"
                    write(2, msg, 42)
                    return 1
                }
            }
            j = j + 1
        }
        i = i + 1
    }
    return 0
}

// ---------------------------------------------------------------------------
// Capability check
// ---------------------------------------------------------------------------
// Verify that functions only use capabilities declared in their module

static uint64 cap_errors = 0

@export
fn check_caps(uint64 root) {
    cap_errors = 0
    // Module-level caps would be declared via @caps annotation on the module
    // For now, just count how many functions use capabilities without declaring them
    uint32 child = ast_child(root)
    uint64 wchild = child
    while wchild != 0 {
        uint32 ck = ast_kind(wchild)
        if ck == 2 {
            uint32 fn_tok = ast_data1(wchild)
            uint64 fn_caps = ann_lookup(fn_tok, 2)
            // If function has unsafe blocks but no @caps declaration, warn
            // (simplified check — full version would track specific capabilities)
        }
        uint32 nxt = ast_next(wchild)
        wchild = nxt
    }
}

// ---------------------------------------------------------------------------
// Critical region check
// ---------------------------------------------------------------------------
// Rule: no allocation or blocking operations inside critical sections
// Critical section = between acquire() and release() calls

@export
fn check_critical_regions(uint64 root) {
    // Walk each function looking for acquire/release patterns
    // Flag any alloc/block calls between them
    uint32 child = ast_child(root)
    uint64 wchild = child
    while wchild != 0 {
        uint32 ck = ast_kind(wchild)
        if ck == 2 {
            uint32 body = ast_data3(wchild)
            uint64 wbody = body
            if wbody != 0 {
                check_critical_block(wbody, 0)
            }
        }
        uint32 nxt = ast_next(wchild)
        wchild = nxt
    }
}

fn check_critical_block(uint64 block_node, uint64 in_critical) -> uint64 {
    uint64 depth = in_critical
    uint32 child = ast_child(block_node)
    uint64 wchild = child
    while wchild != 0 {
        depth = check_critical_stmt(wchild, depth)
        uint32 nxt = ast_next(wchild)
        wchild = nxt
    }
    return depth
}

fn check_critical_stmt(uint64 node, uint64 depth) -> uint64 {
    uint32 kind = ast_kind(node)
    if kind == 16 {
        uint32 expr = ast_child(node)
        uint64 wexpr = expr
        uint32 ek = ast_kind(wexpr)
        if ek == 35 {
            uint32 callee_tok = ast_data1(wexpr)
            if tok_matches(callee_tok, "acquire", 7) != 0 {
                return depth + 1
            }
            if tok_matches(callee_tok, "release", 7) != 0 {
                if depth > 0 { return depth - 1 }
                return 0
            }
            // Check for forbidden ops inside critical section
            if depth > 0 {
                if tok_matches(callee_tok, "alloc", 5) != 0 {
                    uint64 msg = "critical-region: alloc inside critical section\n"
                    write(2, msg, 48)
                }
            }
        }
    }
    return depth
}

// ---------------------------------------------------------------------------
// Run all analysis passes
// ---------------------------------------------------------------------------

@export
fn run_analysis(uint64 root) -> uint64 {
    analysis_init()
    lock_graph_init()
    check_ctx(root)
    check_effects(root)
    check_caps(root)
    check_critical_regions(root)
    uint64 cycle = check_lock_cycles()
    return ctx_errors + eff_errors + cycle
}

// ---------------------------------------------------------------------------
// Semantic validation — arg count, missing return, duplicate function checks
// ---------------------------------------------------------------------------

fn sema_init(uint64 source, uint64 tok_buf) {
    fn_sig_table = alloc(4096 * 16)
    fn_sig_count = 0
    sema_errors = 0
    sema_source = source
    sema_tok_buf = tok_buf
}

// Token helpers that use sema_tok_buf / sema_source

fn sema_tok_text_start(uint64 tok_idx) -> uint64 {
    uint64 p = sema_tok_buf + tok_idx * 16 + 4
    uint32 val = 0
    unsafe { *(p as uint32) -> val }
    return val
}

fn sema_tok_text_len(uint64 tok_idx) -> uint64 {
    uint64 p = sema_tok_buf + tok_idx * 16 + 8
    uint32 val = 0
    unsafe { *(p as uint32) -> val }
    return val
}

fn sema_tok_line(uint64 tok_idx) -> uint64 {
    uint64 p = sema_tok_buf + tok_idx * 16 + 12
    uint32 val = 0
    unsafe { *(p as uint32) -> val }
    return val
}

// ---------------------------------------------------------------------------
// Diagnostic collection
// ---------------------------------------------------------------------------

fn diag_init() {
    if diag_table == 0 {
        diag_table = alloc(1024 * 8)
    }
    diag_count = 0
    diag_error_count = 0
    diag_warn_count = 0
}

// severity: 0 = error, 1 = warning
fn diag_emit(uint64 tok_idx, uint64 severity, uint64 msg_id) {
    if diag_count >= 1024 { return }
    uint64 entry = diag_table + diag_count * 8
    uint32 ti = tok_idx
    unsafe { *(entry as uint32) = ti }
    uint64 e4 = entry + 4
    uint8 sev = severity
    unsafe { *(e4 as uint8) = sev }
    uint64 e5 = entry + 5
    uint8 mid = msg_id
    unsafe { *(e5 as uint8) = mid }
    diag_count = diag_count + 1
    if severity == 0 { diag_error_count = diag_error_count + 1 }
    if severity == 1 { diag_warn_count = diag_warn_count + 1 }
}

fn diag_msg_text(uint64 msg_id) -> uint64 {
    if msg_id == 1 { return "undefined variable" }
    if msg_id == 2 { return "type mismatch" }
    if msg_id == 3 { return "redefinition of variable in same scope" }
    if msg_id == 4 { return "unused variable (prefix with _ to suppress)" }
    if msg_id == 5 { return "unreachable code after return/break/exit" }
    if msg_id == 6 { return "implicit float-to-int conversion (use f64_to_int)" }
    if msg_id == 7 { return "implicit int-to-float conversion (use int_to_f64)" }
    if msg_id == 8 { return "narrowing conversion may lose data" }
    if msg_id == 9 { return "variable used before initialization" }
    if msg_id == 10 { return "argument type mismatch" }
    if msg_id == 11 { return "return type mismatch" }
    if msg_id == 12 { return "binary operation requires matching types" }
    if msg_id == 13 { return "comparison requires matching types" }
    return "unknown diagnostic"
}

@export
fn diag_report_all() {
    uint64 i = 0
    while i < diag_count {
        uint64 entry = diag_table + i * 8
        uint32 ti = 0
        unsafe { *(entry as uint32) -> ti }
        uint64 wti = ti
        uint64 e4 = entry + 4
        uint8 sev = 0
        unsafe { *(e4 as uint8) -> sev }
        uint64 wsev = sev
        uint64 e5 = entry + 5
        uint8 mid = 0
        unsafe { *(e5 as uint8) -> mid }
        uint64 wmid = mid
        // Use sema_source for token text access
        uint64 tstart = sema_tok_text_start(wti)
        uint64 tlen = sema_tok_text_len(wti)
        // Print file:line from srcmap
        uint64 file_path = srcmap_file(tstart)
        if file_path != 0 { write(2, file_path, str_len(file_path)) }
        write(2, ":", 1)
        uint8[24] lbuf
        uint64 tok_line = sema_tok_line(wti)
        uint64 llen = fmt_uint(lbuf, tok_line)
        write(2, lbuf, llen)
        if wsev == 0 { write(2, ": error: ", 9) }
        if wsev == 1 { write(2, ": warning: ", 11) }
        uint64 msg = diag_msg_text(wmid)
        write(2, msg, str_len(msg))
        // Append variable name for relevant diagnostics
        if wmid == 1 || wmid == 3 || wmid == 4 || wmid == 9 {
            write(2, " '", 2)
            write(2, sema_source + tstart, tlen)
            write(2, "'", 1)
        }
        write(2, "\n", 1)
        i = i + 1
    }
    // Summary line
    if diag_count > 0 {
        write(2, "\n", 1)
        uint8[24] ebuf
        uint64 elen = fmt_uint(ebuf, diag_error_count)
        write(2, ebuf, elen)
        write(2, " error(s), ", 11)
        uint64 wlen = fmt_uint(ebuf, diag_warn_count)
        write(2, ebuf, wlen)
        write(2, " warning(s)\n", 12)
    }
}

// ---------------------------------------------------------------------------
// Scope stack and variable tracking (F5 Task 2)
// ---------------------------------------------------------------------------

// Scope stack: stores first_var_idx at each scope depth
static uint64 sema_scope_stack = 0
static uint64 sema_scope_depth = 0

// Variable tracking: [name_tok(4), type_id(2), flags(2)] × 4096
// flags: bit 0 = initialized, bit 1 = used, bit 2 = is_param
static uint64 sema_var_table_v = 0
static uint64 sema_var_count_v = 0

fn sema_scope_init() {
    if sema_scope_stack == 0 { sema_scope_stack = alloc(64 * 8) }
    if sema_var_table_v == 0 { sema_var_table_v = alloc(4096 * 8) }
    sema_scope_depth = 0
    sema_var_count_v = 0
}

fn sema_scope_push() {
    if sema_scope_depth >= 64 { return }
    uint64 entry = sema_scope_stack + sema_scope_depth * 8
    uint32 vc = sema_var_count_v
    unsafe { *(entry as uint32) = vc }
    sema_scope_depth = sema_scope_depth + 1
}

fn sema_scope_pop() {
    if sema_scope_depth == 0 { return }
    sema_scope_depth = sema_scope_depth - 1
    uint64 entry = sema_scope_stack + sema_scope_depth * 8
    uint32 first_var = 0
    unsafe { *(entry as uint32) -> first_var }
    uint64 wfirst = first_var
    // Check for unused variables in the popped scope
    uint64 vi = wfirst
    while vi < sema_var_count_v {
        uint64 ve = sema_var_table_v + vi * 8
        uint32 name_tok = 0
        unsafe { *(ve as uint32) -> name_tok }
        uint64 wname = name_tok
        uint64 flags_addr = ve + 6
        uint16 flags = 0
        unsafe { *(flags_addr as uint16) -> flags }
        uint64 wflags = flags
        uint64 used = wflags & 2
        // Check if name starts with '_' — suppress unused warning
        uint64 starts_underscore = 0
        uint64 nstart = sema_tok_text_start(wname)
        uint64 nch = 0
        uint64 np = sema_source + nstart
        unsafe { *(np as uint8) -> nch }
        if nch == 95 { starts_underscore = 1 }  // '_' = 95
        if used == 0 && starts_underscore == 0 {
            diag_emit(wname, 1, 4)  // warning: unused variable
        }
        vi = vi + 1
    }
    sema_var_count_v = wfirst
}

fn sema_var_declare(uint64 name_tok, uint64 type_id, uint64 is_param) {
    // Check for redeclaration in current scope
    if sema_scope_depth > 0 {
        uint64 scope_entry = sema_scope_stack + (sema_scope_depth - 1) * 8
        uint32 scope_first = 0
        unsafe { *(scope_entry as uint32) -> scope_first }
        uint64 wfirst = scope_first
        uint64 vi = wfirst
        while vi < sema_var_count_v {
            uint64 ve = sema_var_table_v + vi * 8
            uint32 existing = 0
            unsafe { *(ve as uint32) -> existing }
            uint64 we = existing
            if sema_tok_matches_tok(we, name_tok) != 0 {
                diag_emit(name_tok, 0, 3)  // error: redefinition
                return
            }
            vi = vi + 1
        }
    }
    // Register new variable
    if sema_var_count_v >= 4096 { return }
    uint64 entry = sema_var_table_v + sema_var_count_v * 8
    uint32 nt = name_tok
    unsafe { *(entry as uint32) = nt }
    uint64 tid_addr = entry + 4
    uint16 tid = type_id
    unsafe { *(tid_addr as uint16) = tid }
    uint64 flags_addr = entry + 6
    uint16 fl = 0
    if is_param != 0 { fl = 5 }  // bits 0+2 = initialized + is_param
    unsafe { *(flags_addr as uint16) = fl }
    sema_var_count_v = sema_var_count_v + 1
}

fn sema_var_lookup_v(uint64 name_tok) -> uint64 {
    // Walk backwards through all variables (inner scopes first)
    uint64 vi = sema_var_count_v
    while vi > 0 {
        vi = vi - 1
        uint64 ve = sema_var_table_v + vi * 8
        uint32 stored = 0
        unsafe { *(ve as uint32) -> stored }
        uint64 ws = stored
        if sema_tok_matches_tok(ws, name_tok) != 0 {
            return vi
        }
    }
    return 0xFFFFFFFF
}

fn sema_var_mark_used(uint64 var_idx) {
    uint64 flags_addr = sema_var_table_v + var_idx * 8 + 6
    uint16 flags = 0
    unsafe { *(flags_addr as uint16) -> flags }
    uint16 new_flags = flags | 2
    unsafe { *(flags_addr as uint16) = new_flags }
}

fn sema_var_mark_init(uint64 var_idx) {
    uint64 flags_addr = sema_var_table_v + var_idx * 8 + 6
    uint16 flags = 0
    unsafe { *(flags_addr as uint16) -> flags }
    uint16 new_flags = flags | 1
    unsafe { *(flags_addr as uint16) = new_flags }
}

fn sema_var_is_init(uint64 var_idx) -> uint64 {
    uint64 flags_addr = sema_var_table_v + var_idx * 8 + 6
    uint16 flags = 0
    unsafe { *(flags_addr as uint16) -> flags }
    uint64 wf = flags
    return wf & 1
}

fn sema_var_type_id(uint64 var_idx) -> uint64 {
    uint64 tid_addr = sema_var_table_v + var_idx * 8 + 4
    uint16 tid = 0
    unsafe { *(tid_addr as uint16) -> tid }
    return tid
}

fn sema_tok_matches_tok(uint64 tok_a, uint64 tok_b) -> uint64 {
    uint64 a_start = sema_tok_text_start(tok_a)
    uint64 a_len = sema_tok_text_len(tok_a)
    uint64 b_start = sema_tok_text_start(tok_b)
    uint64 b_len = sema_tok_text_len(tok_b)
    if a_len != b_len { return 0 }
    uint64 i = 0
    while i < a_len {
        uint64 pa = sema_source + a_start + i
        uint64 pb = sema_source + b_start + i
        uint64 ca = 0
        uint64 cb = 0
        unsafe { *(pa as uint8) -> ca }
        unsafe { *(pb as uint8) -> cb }
        if ca != cb { return 0 }
        i = i + 1
    }
    return 1
}

fn sema_tok_to_type_id(uint64 tok) -> uint64 {
    uint64 tk = sema_tok_kind(tok)
    if tk == 80 || tk == 84 { return 1 }  // u8/uint8
    if tk == 81 || tk == 85 { return 2 }  // u16/uint16
    if tk == 82 || tk == 86 { return 3 }  // u32/uint32
    if tk == 83 || tk == 87 { return 4 }  // u64/uint64
    if tk == 94 { return 5 }              // f16
    if tk == 95 { return 6 }              // f32
    if tk == 96 { return 7 }              // f64
    // Check if struct name
    if tk == 1 {
        uint64 si = struct_lookup(tok)
        if si != 0xFFFFFFFF { return 64 + si }
    }
    return 4  // default u64
}

fn sema_tok_kind(uint64 tok_idx) -> uint64 {
    uint64 p = sema_tok_buf + tok_idx * 16
    uint32 val = 0
    unsafe { *(p as uint32) -> val }
    return val
}

fn sema_tok_matches(uint64 tok_idx, uint64 target, uint64 target_len) -> uint64 {
    uint64 tlen = sema_tok_text_len(tok_idx)
    if tlen != target_len { return 0 }
    uint64 start = sema_tok_text_start(tok_idx)
    uint64 i = 0
    while i < tlen {
        uint64 sp = sema_source + start + i
        uint64 sc = 0
        unsafe { *(sp as uint8) -> sc }
        uint64 kp = target + i
        uint64 kc = 0
        unsafe { *(kp as uint8) -> kc }
        if sc != kc { return 0 }
        i = i + 1
    }
    return 1
}

fn sema_tok_text_eq(uint64 tok_a, uint64 tok_b) -> uint64 {
    uint64 la = sema_tok_text_len(tok_a)
    uint64 lb = sema_tok_text_len(tok_b)
    if la != lb { return 0 }
    uint64 sa = sema_tok_text_start(tok_a)
    uint64 sb = sema_tok_text_start(tok_b)
    uint64 i = 0
    while i < la {
        uint64 pa = sema_source + sa + i
        uint64 pb = sema_source + sb + i
        uint64 ca = 0
        uint64 cb = 0
        unsafe { *(pa as uint8) -> ca }
        unsafe { *(pb as uint8) -> cb }
        if ca != cb { return 0 }
        i = i + 1
    }
    return 1
}

// Register a function signature: name_tok, param_count, has_return
fn fn_sig_register(uint64 name_tok, uint64 param_count, uint64 has_return) {
    uint64 entry = fn_sig_table + fn_sig_count * 16
    uint32 nt = name_tok
    unsafe { *(entry as uint32) = nt }
    uint64 e4 = entry + 4
    uint32 pc = param_count
    unsafe { *(e4 as uint32) = pc }
    uint64 e8 = entry + 8
    uint32 hr = has_return
    unsafe { *(e8 as uint32) = hr }
    fn_sig_count = fn_sig_count + 1
}

// Lookup a function signature by name. Returns param_count or 0xFFFFFFFF if not found.
fn fn_sig_lookup(uint64 name_tok) -> uint64 {
    uint64 i = 0
    while i < fn_sig_count {
        uint64 entry = fn_sig_table + i * 16
        uint32 stored_tok = 0
        unsafe { *(entry as uint32) -> stored_tok }
        uint64 wst = stored_tok
        if sema_tok_text_eq(wst, name_tok) != 0 {
            uint64 e4 = entry + 4
            uint32 pc = 0
            unsafe { *(e4 as uint32) -> pc }
            return pc
        }
        i = i + 1
    }
    return 0xFFFFFFFF
}

// Collect function signatures from top-level AST
fn sema_collect_signatures(uint64 root) {
    uint32 child = ast_child(root)
    uint64 wchild = child
    while wchild != 0 {
        uint32 ck = ast_kind(wchild)
        if ck == 2 {
            // FnDecl: count params
            uint32 name_tok = ast_data1(wchild)
            uint64 wname = name_tok
            uint64 param_count = 0
            uint32 pchild = ast_child(wchild)
            uint64 wpchild = pchild
            while wpchild != 0 {
                uint32 pk = ast_kind(wpchild)
                if pk == 3 {
                    param_count = param_count + 1
                    // Slice params take 2 positions: ptr + len
                    uint32 pflag_sp = ast_data4(wpchild)
                    uint64 wpflag_sp = pflag_sp
                    if wpflag_sp == 1 { param_count = param_count + 1 }
                }
                uint32 pnxt = ast_next(wpchild)
                wpchild = pnxt
            }
            // Check for duplicate. A duplicate is fine when both decls
            // are @dynamic extern (data4 flag bits 3 + 5 set, i.e. 0x28)
            // — happens with the --target=amdgpu-native HIP-via-KFD
            // shim path where std/kfd.mlr declares puts/exit/write/etc.
            // and a launcher file (legitimately, pre-shim) re-declares
            // them locally. Both declarations name the same dlopen
            // symbol so silently dedupe instead of erroring.
            uint64 existing = fn_sig_lookup(wname)
            if existing != 0xFFFFFFFF {
                uint32 cur_flags = ast_data4(wchild)
                uint64 wcur_flags = cur_flags
                if (wcur_flags & 0x28) == 0x28 {
                    // Skip the duplicate @dynamic extern declaration.
                } else {
                    report_error_at(wname, "redefinition of function")
                    sema_errors = sema_errors + 1
                }
            } else {
                uint32 ret_tok = ast_data2(wchild)
                uint64 has_return = 0
                if ret_tok != 0 { has_return = 1 }
                fn_sig_register(wname, param_count, has_return)
            }
        }
        uint32 nxt = ast_next(wchild)
        wchild = nxt
    }
}

// Check if a token refers to a builtin function
fn is_builtin(uint64 tok_idx) -> uint64 {
    if sema_tok_matches(tok_idx, "exit", 4) != 0 { return 1 }
    if sema_tok_matches(tok_idx, "print", 5) != 0 { return 1 }
    if sema_tok_matches(tok_idx, "println", 7) != 0 { return 1 }
    if sema_tok_matches(tok_idx, "alloc", 5) != 0 { return 1 }
    if sema_tok_matches(tok_idx, "dealloc", 7) != 0 { return 1 }
    if sema_tok_matches(tok_idx, "write", 5) != 0 { return 1 }
    if sema_tok_matches(tok_idx, "memcpy", 6) != 0 { return 1 }
    if sema_tok_matches(tok_idx, "memset", 6) != 0 { return 1 }
    if sema_tok_matches(tok_idx, "str_len", 7) != 0 { return 1 }
    if sema_tok_matches(tok_idx, "str_eq", 6) != 0 { return 1 }
    if sema_tok_matches(tok_idx, "file_open", 9) != 0 { return 1 }
    if sema_tok_matches(tok_idx, "file_read", 9) != 0 { return 1 }
    if sema_tok_matches(tok_idx, "file_write", 10) != 0 { return 1 }
    if sema_tok_matches(tok_idx, "file_close", 10) != 0 { return 1 }
    if sema_tok_matches(tok_idx, "file_size", 9) != 0 { return 1 }
    if sema_tok_matches(tok_idx, "call_ptr", 8) != 0 { return 1 }
    if sema_tok_matches(tok_idx, "fn_addr", 7) != 0 { return 1 }
    if sema_tok_matches(tok_idx, "bit_get", 7) != 0 { return 1 }
    if sema_tok_matches(tok_idx, "bit_set", 7) != 0 { return 1 }
    if sema_tok_matches(tok_idx, "bit_clear", 9) != 0 { return 1 }
    if sema_tok_matches(tok_idx, "bit_range", 9) != 0 { return 1 }
    if sema_tok_matches(tok_idx, "bit_insert", 10) != 0 { return 1 }
    if sema_tok_matches(tok_idx, "signed_lt", 9) != 0 { return 1 }
    if sema_tok_matches(tok_idx, "signed_gt", 9) != 0 { return 1 }
    if sema_tok_matches(tok_idx, "signed_le", 9) != 0 { return 1 }
    if sema_tok_matches(tok_idx, "signed_ge", 9) != 0 { return 1 }
    if sema_tok_matches(tok_idx, "get_target_os", 13) != 0 { return 1 }
    if sema_tok_matches(tok_idx, "get_arch_id", 11) != 0 { return 1 }
    if sema_tok_matches(tok_idx, "time_ns", 7) != 0 { return 1 }
    if sema_tok_matches(tok_idx, "isb", 3) != 0 { return 1 }
    if sema_tok_matches(tok_idx, "dsb", 3) != 0 { return 1 }
    if sema_tok_matches(tok_idx, "dmb", 3) != 0 { return 1 }
    if sema_tok_matches(tok_idx, "dcache_flush", 12) != 0 { return 1 }
    if sema_tok_matches(tok_idx, "icache_invalidate", 17) != 0 { return 1 }
    if sema_tok_matches(tok_idx, "exec_process", 12) != 0 { return 1 }
    if sema_tok_matches(tok_idx, "exec_process_argv", 17) != 0 { return 1 }
    if sema_tok_matches(tok_idx, "set_executable", 14) != 0 { return 1 }
    if sema_tok_matches(tok_idx, "atomic_load", 11) != 0 { return 1 }
    if sema_tok_matches(tok_idx, "atomic_store", 12) != 0 { return 1 }
    if sema_tok_matches(tok_idx, "atomic_cas", 10) != 0 { return 1 }
    if sema_tok_matches(tok_idx, "atomic_add", 10) != 0 { return 1 }
    if sema_tok_matches(tok_idx, "atomic_sub", 10) != 0 { return 1 }
    if sema_tok_matches(tok_idx, "atomic_and", 10) != 0 { return 1 }
    if sema_tok_matches(tok_idx, "atomic_or", 9) != 0 { return 1 }
    if sema_tok_matches(tok_idx, "atomic_xor", 10) != 0 { return 1 }
    if sema_tok_matches(tok_idx, "get_module_path", 15) != 0 { return 1 }
    if sema_tok_matches(tok_idx, "fmt_uint", 8) != 0 { return 1 }
    if sema_tok_matches(tok_idx, "asm", 3) != 0 { return 1 }
    if sema_tok_matches(tok_idx, "syscall_raw", 11) != 0 { return 1 }
    // String output (null-terminated, variable pointer safe)
    if sema_tok_matches(tok_idx, "print_str", 9) != 0 { return 1 }
    if sema_tok_matches(tok_idx, "println_str", 11) != 0 { return 1 }
    // Easy pointer loads — zero-extended
    if sema_tok_matches(tok_idx, "load8", 5) != 0 { return 1 }
    if sema_tok_matches(tok_idx, "load16", 6) != 0 { return 1 }
    if sema_tok_matches(tok_idx, "load32", 6) != 0 { return 1 }
    if sema_tok_matches(tok_idx, "load64", 6) != 0 { return 1 }
    // Easy pointer stores
    if sema_tok_matches(tok_idx, "store8", 6) != 0 { return 1 }
    if sema_tok_matches(tok_idx, "store16", 7) != 0 { return 1 }
    if sema_tok_matches(tok_idx, "store32", 7) != 0 { return 1 }
    if sema_tok_matches(tok_idx, "store64", 7) != 0 { return 1 }
    // Volatile loads — with memory barrier
    if sema_tok_matches(tok_idx, "vload8", 6) != 0 { return 1 }
    if sema_tok_matches(tok_idx, "vload16", 7) != 0 { return 1 }
    if sema_tok_matches(tok_idx, "vload32", 7) != 0 { return 1 }
    if sema_tok_matches(tok_idx, "vload64", 7) != 0 { return 1 }
    // Volatile stores — with memory barrier
    if sema_tok_matches(tok_idx, "vstore8", 7) != 0 { return 1 }
    if sema_tok_matches(tok_idx, "vstore16", 8) != 0 { return 1 }
    if sema_tok_matches(tok_idx, "vstore32", 8) != 0 { return 1 }
    if sema_tok_matches(tok_idx, "vstore64", 8) != 0 { return 1 }
    // GPU mega-kernel cross-WG barrier intrinsic.
    // mega_barrier(counter_ptr, phase_idx, wg_persist) -> void
    // Lowered by the AMDGPU emitter to the validated global_atomic_add_u32
    // + spin-loop ISA sequence.  Not a real function call; no IR_CALL emitted.
    if sema_tok_matches(tok_idx, "mega_barrier", 12) != 0 { return 1 }
    return 0
}

// Return expected argument count for a builtin, or 0xFFFFFFFF for variable-arg builtins
fn builtin_arg_count(uint64 tok_idx) -> uint64 {
    // 1-arg builtins
    if sema_tok_matches(tok_idx, "exit", 4) != 0 { return 1 }
    if sema_tok_matches(tok_idx, "print", 5) != 0 { return 0xFFFFFFFF }
    if sema_tok_matches(tok_idx, "println", 7) != 0 { return 0xFFFFFFFF }
    if sema_tok_matches(tok_idx, "print_str", 9) != 0 { return 1 }
    if sema_tok_matches(tok_idx, "println_str", 11) != 0 { return 1 }
    if sema_tok_matches(tok_idx, "load8", 5) != 0 { return 1 }
    if sema_tok_matches(tok_idx, "load16", 6) != 0 { return 1 }
    if sema_tok_matches(tok_idx, "load32", 6) != 0 { return 1 }
    if sema_tok_matches(tok_idx, "load64", 6) != 0 { return 1 }
    if sema_tok_matches(tok_idx, "vload8", 6) != 0 { return 1 }
    if sema_tok_matches(tok_idx, "vload16", 7) != 0 { return 1 }
    if sema_tok_matches(tok_idx, "vload32", 7) != 0 { return 1 }
    if sema_tok_matches(tok_idx, "vload64", 7) != 0 { return 1 }
    if sema_tok_matches(tok_idx, "alloc", 5) != 0 { return 1 }
    if sema_tok_matches(tok_idx, "dealloc", 7) != 0 { return 1 }
    if sema_tok_matches(tok_idx, "str_len", 7) != 0 { return 1 }
    if sema_tok_matches(tok_idx, "file_close", 10) != 0 { return 1 }
    if sema_tok_matches(tok_idx, "file_size", 9) != 0 { return 1 }
    if sema_tok_matches(tok_idx, "fn_addr", 7) != 0 { return 1 }
    if sema_tok_matches(tok_idx, "exec_process", 12) != 0 { return 1 }
    if sema_tok_matches(tok_idx, "set_executable", 14) != 0 { return 1 }
    if sema_tok_matches(tok_idx, "atomic_load", 11) != 0 { return 1 }
    if sema_tok_matches(tok_idx, "dcache_flush", 12) != 0 { return 1 }
    if sema_tok_matches(tok_idx, "icache_invalidate", 17) != 0 { return 1 }
    // 2-arg builtins
    if sema_tok_matches(tok_idx, "exec_process_argv", 17) != 0 { return 2 }
    if sema_tok_matches(tok_idx, "store8", 6) != 0 { return 2 }
    if sema_tok_matches(tok_idx, "store16", 7) != 0 { return 2 }
    if sema_tok_matches(tok_idx, "store32", 7) != 0 { return 2 }
    if sema_tok_matches(tok_idx, "store64", 7) != 0 { return 2 }
    if sema_tok_matches(tok_idx, "vstore8", 7) != 0 { return 2 }
    if sema_tok_matches(tok_idx, "vstore16", 8) != 0 { return 2 }
    if sema_tok_matches(tok_idx, "vstore32", 8) != 0 { return 2 }
    if sema_tok_matches(tok_idx, "vstore64", 8) != 0 { return 2 }
    if sema_tok_matches(tok_idx, "str_eq", 6) != 0 { return 2 }
    if sema_tok_matches(tok_idx, "file_open", 9) != 0 { return 2 }
    if sema_tok_matches(tok_idx, "bit_get", 7) != 0 { return 2 }
    if sema_tok_matches(tok_idx, "bit_set", 7) != 0 { return 2 }
    if sema_tok_matches(tok_idx, "bit_clear", 9) != 0 { return 2 }
    if sema_tok_matches(tok_idx, "signed_lt", 9) != 0 { return 2 }
    if sema_tok_matches(tok_idx, "signed_gt", 9) != 0 { return 2 }
    if sema_tok_matches(tok_idx, "signed_le", 9) != 0 { return 2 }
    if sema_tok_matches(tok_idx, "signed_ge", 9) != 0 { return 2 }
    if sema_tok_matches(tok_idx, "get_module_path", 15) != 0 { return 2 }
    if sema_tok_matches(tok_idx, "fmt_uint", 8) != 0 { return 2 }
    if sema_tok_matches(tok_idx, "atomic_store", 12) != 0 { return 2 }
    if sema_tok_matches(tok_idx, "atomic_add", 10) != 0 { return 2 }
    if sema_tok_matches(tok_idx, "atomic_sub", 10) != 0 { return 2 }
    if sema_tok_matches(tok_idx, "atomic_and", 10) != 0 { return 2 }
    if sema_tok_matches(tok_idx, "atomic_or", 9) != 0 { return 2 }
    if sema_tok_matches(tok_idx, "atomic_xor", 10) != 0 { return 2 }
    // 3-arg builtins
    if sema_tok_matches(tok_idx, "write", 5) != 0 { return 3 }
    if sema_tok_matches(tok_idx, "memcpy", 6) != 0 { return 3 }
    if sema_tok_matches(tok_idx, "memset", 6) != 0 { return 3 }
    if sema_tok_matches(tok_idx, "file_read", 9) != 0 { return 3 }
    if sema_tok_matches(tok_idx, "file_write", 10) != 0 { return 3 }
    if sema_tok_matches(tok_idx, "bit_range", 9) != 0 { return 3 }
    if sema_tok_matches(tok_idx, "atomic_cas", 10) != 0 { return 3 }
    if sema_tok_matches(tok_idx, "mega_barrier", 12) != 0 { return 3 }
    // 4-arg builtins
    if sema_tok_matches(tok_idx, "bit_insert", 10) != 0 { return 4 }
    // 7-arg builtins
    if sema_tok_matches(tok_idx, "syscall_raw", 11) != 0 { return 7 }
    // 0-arg builtins
    if sema_tok_matches(tok_idx, "get_target_os", 13) != 0 { return 0 }
    if sema_tok_matches(tok_idx, "get_arch_id", 11) != 0 { return 0 }
    if sema_tok_matches(tok_idx, "time_ns", 7) != 0 { return 0 }
    if sema_tok_matches(tok_idx, "isb", 3) != 0 { return 0 }
    if sema_tok_matches(tok_idx, "dsb", 3) != 0 { return 0 }
    if sema_tok_matches(tok_idx, "dmb", 3) != 0 { return 0 }
    // Variable-arg builtins — skip checking
    if sema_tok_matches(tok_idx, "call_ptr", 8) != 0 { return 0xFFFFFFFF }
    if sema_tok_matches(tok_idx, "asm", 3) != 0 { return 0xFFFFFFFF }
    return 0xFFFFFFFF
}

// Recursively check expressions for call argument count mismatches
fn sema_check_expr(uint64 node) {
    if node == 0 { return }
    uint32 kind = ast_kind(node)

    if kind == 35 {
        // Call node: data1=callee_tok, child=first_arg
        uint32 callee_tok = ast_data1(node)
        uint64 wcallee = callee_tok
        if is_builtin(wcallee) != 0 {
            uint64 bexpected = builtin_arg_count(wcallee)
            if bexpected != 0xFFFFFFFF {
                // Count actual args
                uint64 bactual = 0
                uint32 barg = ast_child(node)
                uint64 wbarg = barg
                while wbarg != 0 {
                    bactual = bactual + 1
                    uint32 banxt = ast_next(wbarg)
                    wbarg = banxt
                }
                if bactual != bexpected {
                    report_error_at(wcallee, "wrong number of arguments to builtin")
                    sema_errors = sema_errors + 1
                }
            }
        } else {
            uint64 expected = fn_sig_lookup(wcallee)
            if expected != 0xFFFFFFFF {
                // Count actual args
                uint64 actual = 0
                uint32 arg = ast_child(node)
                uint64 warg = arg
                while warg != 0 {
                    actual = actual + 1
                    uint32 anxt = ast_next(warg)
                    warg = anxt
                }
                if actual != expected {
                    report_error_at(wcallee, "wrong number of arguments")
                    sema_errors = sema_errors + 1
                }
            }
        }
        // Recurse into call arguments
        uint32 arg2 = ast_child(node)
        uint64 warg2 = arg2
        while warg2 != 0 {
            sema_check_expr(warg2)
            uint32 anxt2 = ast_next(warg2)
            warg2 = anxt2
        }
        return
    }

    // BinOp: child=lhs, data2=rhs_idx
    if kind == 33 {
        uint32 lhs = ast_child(node)
        uint64 wlhs = lhs
        sema_check_expr(wlhs)
        uint32 rhs = ast_data2(node)
        uint64 wrhs = rhs
        sema_check_expr(wrhs)
        return
    }

    // Compare: child=lhs, data2=rhs_idx
    if kind == 38 {
        uint32 lhs = ast_child(node)
        uint64 wlhs = lhs
        sema_check_expr(wlhs)
        uint32 rhs = ast_data2(node)
        uint64 wrhs = rhs
        sema_check_expr(wrhs)
        return
    }

    // UnaryOp: child=operand
    if kind == 34 {
        uint32 operand = ast_child(node)
        uint64 wop = operand
        sema_check_expr(wop)
        return
    }

    // LogicalAnd: child=lhs, data2=rhs_idx (data1=op_tok)
    if kind == 39 {
        uint32 lhs = ast_child(node)
        uint64 wlhs = lhs
        sema_check_expr(wlhs)
        uint32 rhs = ast_data2(node)
        uint64 wrhs = rhs
        sema_check_expr(wrhs)
        return
    }

    // LogicalOr: child=lhs, data2=rhs_idx (data1=op_tok)
    if kind == 40 {
        uint32 lhs = ast_child(node)
        uint64 wlhs = lhs
        sema_check_expr(wlhs)
        uint32 rhs = ast_data2(node)
        uint64 wrhs = rhs
        sema_check_expr(wrhs)
        return
    }

    // Index: child=index_expr (data1=ident_tok)
    if kind == 37 {
        uint32 arr_ident_tok = ast_data1(node)
        uint64 warr_tok = arr_ident_tok
        uint64 arr_vi = sema_var_lookup_v(warr_tok)
        if arr_vi != 0xFFFFFFFF { sema_var_mark_used(arr_vi) }
        uint32 idx_expr = ast_child(node)
        uint64 widx = idx_expr
        sema_check_expr(widx)
        return
    }

    // Ident: a bare variable reference. Mark the variable used so the
    // unused-variable warning knows to skip it when its scope ends.
    // Also check whether the variable has been written yet — a read of
    // a never-initialized local is almost always a bug. The check is
    // conservative (linear source-order scan): a variable is "init"
    // if it had an initializer OR if any assignment to it was seen
    // earlier in the walk. Writes inside `if`/`match` branches count
    // unconditionally — so a read gated on the same condition that
    // writes the variable won't warn, but `if c { x = 5 } exit(x)`
    // where the read is outside the branch will also be silent. That
    // is deliberately looser than a full dataflow analysis — false
    // positives are worse than false negatives for this warning.
    if kind == 32 {
        uint32 id_tok = ast_data1(node)
        uint64 wid_tok = id_tok
        uint64 vi = sema_var_lookup_v(wid_tok)
        if vi != 0xFFFFFFFF {
            if sema_var_is_init(vi) == 0 {
                // Name starts with '_' opts out, same as unused-var.
                uint64 nstart = sema_tok_text_start(wid_tok)
                uint64 nch = 0
                uint64 np = sema_source + nstart
                unsafe { *(np as uint8) -> nch }
                if nch != 95 {
                    diag_emit(wid_tok, 1, 9)
                    // Mark init now so repeated reads don't pile up
                    // diagnostics for the same variable.
                    sema_var_mark_init(vi)
                }
            }
            sema_var_mark_used(vi)
        }
        return
    }

    // FieldAccess (36): both EnumName.Field (constant access) and
    // obj.field on a variable. In the variable case the object token is
    // the base var; mark it used. Walks the object chain so struct
    // method calls and nested access (p.inner.x) flow through.
    if kind == 36 {
        uint32 fa_obj = ast_child(node)
        uint64 wfa_obj = fa_obj
        if wfa_obj != 0 { sema_check_expr(wfa_obj) }
        uint32 fa_obj_tok = ast_data1(node)
        uint64 wfa_obj_tok = fa_obj_tok
        if wfa_obj_tok != 0 {
            uint64 fi = sema_var_lookup_v(wfa_obj_tok)
            if fi != 0xFFFFFFFF { sema_var_mark_used(fi) }
        }
        return
    }

    // RangePat (52): match-arm `lo .. hi` / `lo ..= hi`. Walk both
    // bounds so idents / calls inside them count as used.
    if kind == 52 {
        uint32 rp_lo = ast_data1(node)
        uint64 wrp_lo = rp_lo
        if wrp_lo != 0 { sema_check_expr(wrp_lo) }
        uint32 rp_hi = ast_data2(node)
        uint64 wrp_hi = rp_hi
        if wrp_hi != 0 { sema_check_expr(wrp_hi) }
        return
    }
}

// Check a statement for call argument count mismatches
fn sema_check_stmt(uint64 node) {
    if node == 0 { return }
    uint32 kind = ast_kind(node)

    // ExprStmt: child=expr
    if kind == 16 {
        uint32 expr = ast_child(node)
        uint64 wexpr = expr
        sema_check_expr(wexpr)
        return
    }

    // VarDecl: child=init_expr
    if kind == 10 {
        uint32 init = ast_child(node)
        uint64 winit = init
        // Decode the declared type here so both the init-expression
        // checks and the later sema_var_declare call can see it.
        uint32 vd_type_tok_idx = ast_data1(node)
        uint64 vd_type_tok = vd_type_tok_idx
        uint64 decl_type_kind = sema_tok_kind(vd_type_tok)
        if winit != 0 {
            sema_check_expr(winit)
            // Strict bool/int separation: check type tag of initializer
            uint32 type_tok_idx = ast_data1(node)
            uint64 wtype_tok = type_tok_idx
            // Get init expression type tag (data4 for IntLit bool-tagged nodes)
            uint32 init_kind_raw = ast_kind(winit)
            uint64 winit_kind = init_kind_raw
            uint64 init_type_tag = 0
            // IntLit = 30
            if winit_kind == 30 {
                uint32 itag = ast_data4(winit)
                init_type_tag = itag
            }
            // Check if init is a BinOp/Cast (as-cast): skip (data4 == 0 means no tag)
            if decl_type_kind == 98 && init_type_tag != 98 && init_type_tag != 0 {
                // decl is bool, init is some other typed literal
                report_error_at(wtype_tok, "type mismatch: expected bool")
                sema_errors = sema_errors + 1
            }
            if decl_type_kind != 98 && init_type_tag == 98 {
                // decl is non-bool, init is a bool literal
                report_error_at(wtype_tok, "type mismatch: bool requires explicit cast")
                sema_errors = sema_errors + 1
            }
            // Strict char/int separation (KwChar = 99)
            if decl_type_kind == 99 && init_type_tag != 99 && init_type_tag != 0 {
                // decl is char, init is some other typed literal (e.g. bool)
                report_error_at(wtype_tok, "type mismatch: expected char")
                sema_errors = sema_errors + 1
            }
            if decl_type_kind != 99 && init_type_tag == 99 {
                // decl is non-char, init is a char literal
                report_error_at(wtype_tok, "type mismatch: char requires explicit cast")
                sema_errors = sema_errors + 1
            }
            // Literal-overflow warning: if the initializer is an untagged
            // IntLit (not a bool/char literal) and the declared type is
            // narrower than u64, warn when the literal doesn't fit. This
            // catches the classic `u8 b = 300` foot-gun at compile time.
            if winit_kind == 30 && init_type_tag == 0 {
                uint32 lit_tok = ast_data1(winit)
                uint64 wlit_tok = lit_tok
                uint64 lit_val = parse_int_token(wlit_tok)
                uint64 limit = 0
                if decl_type_kind == 80 || decl_type_kind == 84 { limit = 0x100 }
                if decl_type_kind == 81 || decl_type_kind == 85 { limit = 0x10000 }
                if decl_type_kind == 82 || decl_type_kind == 86 { limit = 0x100000000 }
                if limit != 0 && lit_val >= limit {
                    report_warn_at(wtype_tok, "literal initializer does not fit the declared type (truncated)")
                }
            }
        }
        // Register the new variable for unused-variable tracking. We
        // store the declared type's keyword kind (80 = u8, 81 = u16,
        // 82 = u32, …) so later Assign checks can re-derive the width
        // without a second AST lookup. If it has an initializer, also
        // mark it initialized. Params came in pre-declared in
        // sema_check_functions.
        uint32 vd_name_tok = ast_data2(node)
        uint64 wvd_name = vd_name_tok
        if wvd_name != 0 {
            sema_var_declare(wvd_name, decl_type_kind, 0)
            if winit != 0 && sema_var_count_v > 0 {
                sema_var_mark_init(sema_var_count_v - 1)
            }
        }
        return
    }

    // Assign: child=value_expr, data1=target_name_tok
    if kind == 11 {
        uint32 val = ast_child(node)
        uint64 wval = val
        if wval != 0 { sema_check_expr(wval) }
        uint32 as_target = ast_data1(node)
        uint64 was_target = as_target
        if was_target != 0 {
            uint64 asv = sema_var_lookup_v(was_target)
            if asv != 0xFFFFFFFF {
                sema_var_mark_init(asv)
                // Literal-overflow warning for assignment, same shape as
                // in VarDecl. Only fires when the RHS is a bare IntLit
                // and the declared type is narrower than u64.
                if wval != 0 {
                    uint32 rhs_kind_raw = ast_kind(wval)
                    uint64 rhs_kind = rhs_kind_raw
                    if rhs_kind == 30 {
                        uint32 rhs_tag = ast_data4(wval)
                        uint64 rhs_type_tag = rhs_tag
                        if rhs_type_tag == 0 {
                            uint32 lit_tok_a = ast_data1(wval)
                            uint64 wlit_a = lit_tok_a
                            uint64 lit_val_a = parse_int_token(wlit_a)
                            uint64 tgt_kind = sema_var_type_id(asv)
                            uint64 limit_a = 0
                            if tgt_kind == 80 || tgt_kind == 84 { limit_a = 0x100 }
                            if tgt_kind == 81 || tgt_kind == 85 { limit_a = 0x10000 }
                            if tgt_kind == 82 || tgt_kind == 86 { limit_a = 0x100000000 }
                            if limit_a != 0 && lit_val_a >= limit_a {
                                report_warn_at(was_target, "literal assignment does not fit the target type (truncated)")
                            }
                        }
                    }
                }
            }
        }
        return
    }

    // Return: child=first_expr, data3=second_expr, data4=third_expr (for 2/3-tuple returns)
    if kind == 12 {
        uint32 expr = ast_child(node)
        uint64 wexpr = expr
        if wexpr != 0 { sema_check_expr(wexpr) }
        uint32 second = ast_data3(node)
        uint64 wsecond = second
        if wsecond != 0 { sema_check_expr(wsecond) }
        uint32 third = ast_data4(node)
        uint64 wthird = third
        if wthird != 0 { sema_check_expr(wthird) }
        return
    }

    // TupleDestruct: (T1 a, T2 b) = rhs_expr — walk the RHS only; the
    // two LHS slots are fresh declarations handled entirely in codegen.
    if kind == 44 {
        uint32 rhs = ast_child(node)
        uint64 wrhs = rhs
        if wrhs != 0 { sema_check_expr(wrhs) }
        return
    }

    // TupleDestruct3: (T1 a, T2 b, T3 c) = rhs_expr — same as 2-tuple
    if kind == 47 {
        uint32 rhs3 = ast_child(node)
        uint64 wrhs3 = rhs3
        if wrhs3 != 0 { sema_check_expr(wrhs3) }
        return
    }

    // If: child=condition, data1=then_block, data2=else_block
    if kind == 13 {
        uint32 cond = ast_child(node)
        uint64 wcond = cond
        sema_check_expr(wcond)
        uint32 then_blk = ast_data1(node)
        uint64 wthen = then_blk
        if wthen != 0 { sema_check_block(wthen) }
        uint32 else_blk = ast_data2(node)
        uint64 welse = else_blk
        if welse != 0 {
            uint32 ek = ast_kind(welse)
            if ek == 13 {
                sema_check_stmt(welse)
            } else {
                sema_check_block(welse)
            }
        }
        return
    }

    // While: child=condition, data1=body
    if kind == 14 {
        uint32 cond = ast_child(node)
        uint64 wcond = cond
        sema_check_expr(wcond)
        uint32 body = ast_data1(node)
        uint64 wbody = body
        if wbody != 0 { sema_check_block(wbody) }
        return
    }

    // Block: child=first_stmt
    if kind == 15 {
        sema_check_block(node)
        return
    }

    // PtrLoad (41): unsafe { *(addr as TYPE) -> dest_var }.
    // Walk the address expression and mark the destination as
    // initialized (the unsafe read gives it a value).
    if kind == 41 {
        uint32 pl_addr = ast_child(node)
        uint64 wpl_addr = pl_addr
        if wpl_addr != 0 { sema_check_expr(wpl_addr) }
        uint32 pl_dest = ast_data2(node)
        uint64 wpl_dest = pl_dest
        if wpl_dest != 0 {
            uint64 pli = sema_var_lookup_v(wpl_dest)
            if pli != 0xFFFFFFFF { sema_var_mark_init(pli) }
        }
        return
    }

    // PtrStore (42): unsafe { *(addr as TYPE) = val }.
    if kind == 42 {
        uint32 ps_addr = ast_child(node)
        uint64 wps_addr = ps_addr
        if wps_addr != 0 { sema_check_expr(wps_addr) }
        uint32 ps_val = ast_data2(node)
        uint64 wps_val = ps_val
        if wps_val != 0 { sema_check_expr(wps_val) }
        return
    }

    // Defer (51): walk the body in a nested scope so variables used
    // only inside the defer are counted as used.
    if kind == 51 {
        uint32 def_body = ast_data1(node)
        uint64 wdef_body = def_body
        if wdef_body != 0 { sema_check_block(wdef_body) }
        return
    }

    // Match: child=scrutinee, data1=first_arm
    if kind == 19 {
        uint32 scrut = ast_child(node)
        uint64 wscrut = scrut
        sema_check_expr(wscrut)
        uint32 arm = ast_data1(node)
        uint64 warm = arm
        while warm != 0 {
            uint32 arm_body = ast_data2(warm)
            uint64 wab = arm_body
            if wab != 0 { sema_check_block(wab) }
            uint32 anxt = ast_next(warm)
            warm = anxt
        }
        return
    }
}

// Check all statements in a block
fn sema_check_block(uint64 block_node) {
    if block_node == 0 { return }
    sema_scope_push()
    uint32 child = ast_child(block_node)
    uint64 wchild = child
    while wchild != 0 {
        sema_check_stmt(wchild)
        uint32 nxt = ast_next(wchild)
        wchild = nxt
    }
    sema_scope_pop()
}

// Check all functions' bodies for call argument count mismatches
fn sema_check_functions(uint64 root) {
    sema_scope_init()
    uint32 child = ast_child(root)
    uint64 wchild = child
    while wchild != 0 {
        uint32 ck = ast_kind(wchild)
        if ck == 2 {
            // Outer per-function scope that holds the parameter bindings.
            // sema_check_block will push a second, nested scope for the
            // body itself — that matches C-family "parameters are in the
            // enclosing scope" semantics and keeps block locals distinct.
            sema_scope_push()
            // Declare params as "used already" so they never trigger the
            // unused-variable warning — callers dictate signatures.
            uint32 param = ast_child(wchild)
            uint64 wparam = param
            while wparam != 0 {
                uint32 pname_tok = ast_data2(wparam)
                uint64 wpname = pname_tok
                sema_var_declare(wpname, 0, 1)
                if sema_var_count_v > 0 {
                    sema_var_mark_used(sema_var_count_v - 1)
                }
                uint32 pnxt = ast_next(wparam)
                wparam = pnxt
            }
            uint32 body = ast_data3(wchild)
            uint64 wbody = body
            if wbody != 0 { sema_check_block(wbody) }
            sema_scope_pop()
        }
        uint32 nxt = ast_next(wchild)
        wchild = nxt
    }
}

// Check if a block ends with a return statement (recursively through if/else)
fn block_has_return(uint64 block_node) -> uint64 {
    if block_node == 0 { return 0 }
    // Find last statement in block
    uint32 child = ast_child(block_node)
    uint64 wchild = child
    uint64 last = 0
    while wchild != 0 {
        last = wchild
        uint32 nxt = ast_next(wchild)
        wchild = nxt
    }
    if last == 0 { return 0 }
    uint32 lk = ast_kind(last)
    if lk == 12 { return 1 }
    if lk == 13 {
        // If with else: check both branches
        uint32 then_blk = ast_data1(last)
        uint64 wthen = then_blk
        uint32 else_blk = ast_data2(last)
        uint64 welse = else_blk
        if welse == 0 { return 0 }
        uint64 then_ret = block_has_return(wthen)
        if then_ret == 0 { return 0 }
        uint32 ek = ast_kind(welse)
        if ek == 13 {
            // else-if chain: check recursively as a statement
            // Wrap in a virtual check: the if-stmt itself must have return
            uint32 eif_then = ast_data1(welse)
            uint64 wet = eif_then
            uint32 eif_else = ast_data2(welse)
            uint64 wee = eif_else
            if wee == 0 { return 0 }
            uint64 et_ret = block_has_return(wet)
            if et_ret == 0 { return 0 }
            // Recurse on the else-if's else
            uint32 eek = ast_kind(wee)
            if eek == 13 { return block_has_return(wee) }
            return block_has_return(wee)
        }
        return block_has_return(welse)
    }
    return 0
}

// Check that all functions with return types actually return on all paths.
// Extern functions (no body) are declarations, not definitions — skip them.
fn sema_check_returns(uint64 root) {
    uint32 child = ast_child(root)
    uint64 wchild = child
    while wchild != 0 {
        uint32 ck = ast_kind(wchild)
        if ck == 2 {
            uint32 ret_tok = ast_data2(wchild)
            uint32 body = ast_data3(wchild)
            uint64 wbody = body
            if ret_tok != 0 && wbody != 0 {
                if block_has_return(wbody) == 0 {
                    uint32 name_tok = ast_data1(wchild)
                    uint64 wname = name_tok
                    report_error_at(wname, "function with return type may not return a value on all paths")
                    sema_errors = sema_errors + 1
                }
            }
        }
        uint32 nxt = ast_next(wchild)
        wchild = nxt
    }
}

// ---------------------------------------------------------------------------
// Unreachable code detection
// ---------------------------------------------------------------------------
// Walk each block's statement list. After a return/break/continue/exit(),
// any subsequent statement is unreachable. Emit warning (severity 1, msg 5)
// once per block, then stop scanning that block.

fn sema_ur_block(uint64 block_node) {
    uint64 terminated = 0
    uint32 child = ast_child(block_node)
    uint64 wchild = child
    while wchild != 0 {
        if terminated != 0 {
            // This statement is unreachable
            uint32 ur_tok = ast_tok(wchild)
            if ur_tok == 0 { ur_tok = ast_data1(wchild) }
            if ur_tok == 0 { ur_tok = ast_data2(wchild) }
            uint64 wur = ur_tok
            if wur != 0 {
                diag_emit(wur, 1, 5)
            }
            // Only warn once per block
            break
        }
        uint32 sk = ast_kind(wchild)
        uint64 wsk = sk
        // Check if this statement terminates the block
        if wsk == 12 { terminated = 1 }
        if wsk == 17 { terminated = 1 }
        if wsk == 18 { terminated = 1 }
        // Check for exit() call: ExprStmt(16) containing Call(35) to "exit"
        if wsk == 16 {
            uint32 expr_child = ast_child(wchild)
            uint32 expr_kind = ast_kind(expr_child)
            uint64 wek = expr_kind
            if wek == 35 {
                uint32 callee = ast_data1(expr_child)
                uint64 wcallee = callee
                if sema_tok_matches(wcallee, "exit", 4) != 0 {
                    terminated = 1
                }
            }
        }
        // Recurse into sub-blocks (if/else, while, nested blocks)
        if wsk == 13 {
            uint32 then_body = ast_data1(wchild)
            uint64 wthen = then_body
            if wthen != 0 { sema_ur_block(wthen) }
            uint32 else_body = ast_data2(wchild)
            uint64 welse = else_body
            if welse != 0 { sema_ur_block(welse) }
        }
        if wsk == 14 {
            uint32 while_body = ast_data1(wchild)
            uint64 wwbody = while_body
            if wwbody != 0 { sema_ur_block(wwbody) }
        }
        if wsk == 15 {
            sema_ur_block(wchild)
        }
        uint32 nxt = ast_next(wchild)
        wchild = nxt
    }
}

fn sema_check_unreachable(uint64 root) {
    uint32 child = ast_child(root)
    uint64 wchild = child
    while wchild != 0 {
        uint32 ck = ast_kind(wchild)
        if ck == 2 {
            uint32 body = ast_data3(wchild)
            uint64 wbody = body
            if wbody != 0 {
                sema_ur_block(wbody)
            }
        }
        uint32 nxt = ast_next(wchild)
        wchild = nxt
    }
}

// Entry point for semantic validation
@export
fn run_semantic_checks(uint64 root, uint64 source, uint64 tok_buf) -> uint64 {
    sema_init(source, tok_buf)
    diag_init()
    sema_collect_signatures(root)
    sema_check_functions(root)
    sema_check_returns(root)
    sema_check_unreachable(root)
    return sema_errors + diag_error_count
}
// KernRift self-hosted compiler — AST-level function inliner.
//
// Eligibility (conservative MVP):
//   - Body is a Block containing exactly one Return with a value
//   - Return expr uses only "pure" kinds: IntLit, FloatLitNode, Ident,
//     BinOp, Compare, UnaryOp, LogicalAnd, LogicalOr (no calls, no
//     loads, no stores, no field/index, no f-strings, no asm)
//   - Each parameter is referenced at most once in the body so that
//     substituting the call's argument expression doesn't duplicate
//     side effects. Argument purity isn't checked — single-use means
//     one evaluation regardless of arg shape
//   - Function is not the entry point and isn't recursive (caller
//     never inlines its own body)
//
// At every Call site whose callee matches a candidate, we deep-copy the
// body expression into fresh AST nodes, replacing each Ident that names
// a parameter with a clone of the corresponding argument subtree. Then
// we mutate the Call node IN PLACE — overwrite kind/data fields with
// the substituted root's, leaving `next` intact so the Call's slot in
// any sibling chain is preserved. No parent-pointer rewiring needed.

static uint64 INLINE_TABLE_CAP = 256
static uint64 inline_table_buf = 0      // [name_tok(u32), body_expr_idx(u32)] x cap
static uint64 inline_table_count = 0
static uint64 inline_current_fn_tok = 0 // for recursion check

// Per-call body-locals table for the rotation-shape inliner. Populated
// by inline_try_call from the callee's VarDecl prefix before
// clone-subst expands the Return expression. Each entry stores
// (name_tok, init_expr_idx) so an Ident in the Return that names a
// body-local gets recursively expanded (with param substitution
// applied) instead of treated as a free variable.
static uint64 INLINE_LOCALS_CAP = 8
static uint64 inline_locals_buf = 0
static uint64 inline_locals_count = 0

// Parallel flag table: 1 bit per inline_table entry. Bit 0 set means
// "rotation shape — require trivial args (Ident or literal) at the
// call site to avoid duplicating side-effecting arguments." Stored
// alongside inline_table for cache locality.
static uint64 inline_flags_buf = 0

@export
fn inline_init() {
    if inline_table_buf == 0 {
        inline_table_buf = alloc(INLINE_TABLE_CAP * 8)
    }
    if inline_flags_buf == 0 {
        inline_flags_buf = alloc(INLINE_TABLE_CAP)
    }
    if inline_locals_buf == 0 {
        inline_locals_buf = alloc(INLINE_LOCALS_CAP * 8)
    }
    inline_table_count = 0
    inline_locals_count = 0
    memset(inline_flags_buf, 0, INLINE_TABLE_CAP)
}

fn inline_local_register(uint64 name_tok, uint64 init_expr) {
    if inline_locals_count >= INLINE_LOCALS_CAP { return }
    uint64 entry = inline_locals_buf + inline_locals_count * 8
    uint32 nt = name_tok
    unsafe { *(entry as uint32) = nt }
    uint64 e4 = entry + 4
    uint32 ie = init_expr
    unsafe { *(e4 as uint32) = ie }
    inline_locals_count = inline_locals_count + 1
}

fn inline_local_lookup(uint64 name_tok) -> uint64 {
    uint64 i = 0
    while i < inline_locals_count {
        uint64 entry = inline_locals_buf + i * 8
        uint32 nt = 0
        unsafe { *(entry as uint32) -> nt }
        uint64 wnt = nt
        if tok_text_eq(wnt, name_tok) != 0 {
            uint64 e4 = entry + 4
            uint32 ie = 0
            unsafe { *(e4 as uint32) -> ie }
            return ie
        }
        i = i + 1
    }
    return 0
}

fn inline_flag_set(uint64 idx, uint64 v) {
    if idx >= INLINE_TABLE_CAP { return }
    uint64 p = inline_flags_buf + idx
    uint8 b = v
    unsafe { *(p as uint8) = b }
}

fn inline_flag_get(uint64 idx) -> uint64 {
    if idx >= INLINE_TABLE_CAP { return 0 }
    uint64 p = inline_flags_buf + idx
    uint64 b = 0
    unsafe { *(p as uint8) -> b }
    return b
}

// True iff `expr` is trivially duplicable — substituting it K times
// has the same cost as evaluating it once. Allowed: Ident, IntLit,
// FloatLitNode, SizeofLit. Used to gate rotation-shape inlining where
// params show up multiple times in the inlined body.
fn inline_arg_is_trivial(uint64 expr) -> uint64 {
    if expr == 0 { return 0 }
    uint32 k = ast_kind(expr)
    uint64 wk = k
    if wk == 30 { return 1 }   // IntLit
    if wk == 32 { return 1 }   // Ident
    if wk == 46 { return 1 }   // FloatLitNode
    if wk == 49 { return 1 }   // SizeofLit
    return 0
}

// True if `kind` is one of the allowed pure-expression kinds.
fn inline_kind_is_pure(uint64 kind) -> uint64 {
    if kind == 30 { return 1 }   // IntLit
    if kind == 32 { return 1 }   // Ident
    if kind == 33 { return 1 }   // BinOp
    if kind == 34 { return 1 }   // UnaryOp
    if kind == 38 { return 1 }   // Compare
    if kind == 39 { return 1 }   // LogicalAnd
    if kind == 40 { return 1 }   // LogicalOr
    if kind == 46 { return 1 }   // FloatLitNode
    if kind == 49 { return 1 }   // SizeofLit
    return 0
}

// Recursively check that `expr` consists only of pure-kind nodes.
fn inline_expr_is_pure(uint64 expr) -> uint64 {
    if expr == 0 { return 1 }
    uint32 k = ast_kind(expr)
    uint64 wk = k
    if inline_kind_is_pure(wk) == 0 { return 0 }

    // Leaf kinds: nothing to recurse into.
    if wk == 30 { return 1 }
    if wk == 32 { return 1 }
    if wk == 46 { return 1 }
    if wk == 49 { return 1 }

    // UnaryOp: child = operand
    if wk == 34 {
        uint32 ch = ast_child(expr)
        return inline_expr_is_pure(ch)
    }

    // BinOp / Compare / LogicalAnd / LogicalOr: child = lhs, data2 = rhs
    uint32 lhs = ast_child(expr)
    uint32 rhs = ast_data2(expr)
    if inline_expr_is_pure(lhs) == 0 { return 0 }
    if inline_expr_is_pure(rhs) == 0 { return 0 }
    return 1
}

// Count how many times `expr` references the parameter named `pname_tok`
// via an Ident. Saturates at 2 — caller only cares about "at most once".
fn inline_count_uses(uint64 expr, uint64 pname_tok) -> uint64 {
    if expr == 0 { return 0 }
    uint32 k = ast_kind(expr)
    uint64 wk = k

    // Ident: data1 holds the name token.
    if wk == 32 {
        uint32 nt = ast_data1(expr)
        uint64 wnt = nt
        if tok_text_eq(wnt, pname_tok) != 0 { return 1 }
        return 0
    }

    // Leaves with no name tokens.
    if wk == 30 { return 0 }
    if wk == 46 { return 0 }
    if wk == 49 { return 0 }

    // UnaryOp.
    if wk == 34 {
        uint32 ch = ast_child(expr)
        return inline_count_uses(ch, pname_tok)
    }

    // BinOp / Compare / LogicalAnd / LogicalOr.
    uint32 lhs = ast_child(expr)
    uint32 rhs = ast_data2(expr)
    uint64 a = inline_count_uses(lhs, pname_tok)
    if a >= 2 { return 2 }
    uint64 b = inline_count_uses(rhs, pname_tok)
    uint64 sum = a + b
    if sum > 2 { return 2 }
    return sum
}

// True iff every parameter of `fn_node` is referenced at most once in
// the body expression. Empty parameter lists trivially pass.
fn inline_params_single_use(uint64 fn_node, uint64 body_expr) -> uint64 {
    uint32 p = ast_child(fn_node)
    while p != 0 {
        uint32 ptype = ast_kind(p)
        if ptype != 3 {
            // Not a Param — bail. (Slice params, etc., land here.)
            return 0
        }
        uint32 pname_tok = ast_data2(p)
        uint64 cnt = inline_count_uses(body_expr, pname_tok)
        if cnt > 1 { return 0 }
        uint32 nxt = ast_next(p)
        p = nxt
    }
    return 1
}

// True iff `fn_node` matches the canonical 32-bit-rotation idiom
// (rotr32-shape). Returns 1 on match. Detecting this at AST time lets
// us relax the param-multi-use rule that normally blocks inlining of
// such bodies — rotation params are referenced 2x by definition. After
// inlining, the IR-level ROR pattern matcher collapses the body to a
// single ROR instruction, so the duplication has no register-pressure
// cost.
//
// The shape we accept (32-bit only — sha-256 / sha-1 / md5 all match):
//   {
//     T lo = (x >> n) & 0xFFFFFFFF
//     T hi = (x << (32 - n)) & 0xFFFFFFFF
//     return (lo | hi) & 0xFFFFFFFF
//   }
fn inline_is_rotation_shape(uint64 body, uint64 fn_node) -> uint64 {
    if body == 0 { return 0 }
    if ast_kind(body) != 15 { return 0 }
    // Need exactly 2 params.
    uint32 p1 = ast_child(fn_node)
    if p1 == 0 || ast_kind(p1) != 3 { return 0 }
    uint32 p2 = ast_next(p1)
    if p2 == 0 || ast_kind(p2) != 3 { return 0 }
    if ast_next(p2) != 0 { return 0 }
    uint32 x_tok = ast_data2(p1)
    uint32 n_tok = ast_data2(p2)
    // Three statements: VarDecl, VarDecl, Return.
    uint32 vd1 = ast_child(body)
    if vd1 == 0 || ast_kind(vd1) != 10 { return 0 }
    uint32 vd2 = ast_next(vd1)
    if vd2 == 0 || ast_kind(vd2) != 10 { return 0 }
    uint32 ret = ast_next(vd2)
    if ret == 0 || ast_kind(ret) != 12 { return 0 }
    if ast_next(ret) != 0 { return 0 }
    uint32 lo_tok = ast_data2(vd1)
    uint32 hi_tok = ast_data2(vd2)
    // VarDecl init = AND(SHR(x, n), 0xFFFFFFFF)
    uint32 init1 = ast_child(vd1)
    if init1 == 0 || ast_kind(init1) != 33 { write(2, "[rot] init1 not BinOp\n", 22); return 0 }
    uint64 op1_kind = tok_kind_at_raw(ast_data1(init1))
    if op1_kind != 23 { return 0 }
    uint32 lhs1 = ast_child(init1)
    uint32 rhs1 = ast_data2(init1)
    if rhs1 == 0 || ast_kind(rhs1) != 30 { return 0 }   // not IntLit
    // IntLit's data1 is the TOKEN INDEX of the literal text — parse it
    // to get the value.
    uint64 rhs1_tok = ast_data1(rhs1)
    if parse_int_token(rhs1_tok) != 0xFFFFFFFF { return 0 }
    if lhs1 == 0 || ast_kind(lhs1) != 33 { return 0 }   // not BinOp
    uint64 shr_kind = tok_kind_at_raw(ast_data1(lhs1))
    if shr_kind != 44 { return 0 }    // not >>
    uint32 shr_lhs = ast_child(lhs1)
    uint32 shr_rhs = ast_data2(lhs1)
    uint64 wxt = x_tok
    uint64 wnt = n_tok
    if shr_lhs == 0 || ast_kind(shr_lhs) != 32 { return 0 }
    if tok_text_eq(ast_data1(shr_lhs), wxt) == 0 { return 0 }
    if shr_rhs == 0 || ast_kind(shr_rhs) != 32 { return 0 }
    if tok_text_eq(ast_data1(shr_rhs), wnt) == 0 { return 0 }
    // VarDecl 2 init = AND(SHL(x, SUB(32, n)), 0xFFFFFFFF)
    uint32 init2 = ast_child(vd2)
    if init2 == 0 || ast_kind(init2) != 33 { return 0 }
    uint64 op2_kind = tok_kind_at_raw(ast_data1(init2))
    if op2_kind != 23 { return 0 }
    uint32 lhs2 = ast_child(init2)
    uint32 rhs2 = ast_data2(init2)
    if rhs2 == 0 || ast_kind(rhs2) != 30 { return 0 }
    uint64 rhs2_tok = ast_data1(rhs2)
    if parse_int_token(rhs2_tok) != 0xFFFFFFFF { return 0 }
    if lhs2 == 0 || ast_kind(lhs2) != 33 { return 0 }
    uint64 shl_kind = tok_kind_at_raw(ast_data1(lhs2))
    if shl_kind != 43 { return 0 }    // not <<
    uint32 shl_lhs = ast_child(lhs2)
    uint32 shl_rhs = ast_data2(lhs2)
    if shl_lhs == 0 || ast_kind(shl_lhs) != 32 { return 0 }
    if tok_text_eq(ast_data1(shl_lhs), wxt) == 0 { return 0 }
    if shl_rhs == 0 || ast_kind(shl_rhs) != 33 { return 0 }
    uint64 sub_kind = tok_kind_at_raw(ast_data1(shl_rhs))
    if sub_kind != 31 { return 0 }    // not -
    uint32 sub_lhs = ast_child(shl_rhs)
    uint32 sub_rhs = ast_data2(shl_rhs)
    if sub_lhs == 0 || ast_kind(sub_lhs) != 30 { return 0 }
    uint64 sub_lhs_tok = ast_data1(sub_lhs)
    if parse_int_token(sub_lhs_tok) != 32 { return 0 }
    if sub_rhs == 0 || ast_kind(sub_rhs) != 32 { return 0 }
    if tok_text_eq(ast_data1(sub_rhs), wnt) == 0 { return 0 }
    // Return expr = AND(OR(lo, hi), 0xFFFFFFFF)
    uint32 ret_expr = ast_child(ret)
    if ret_expr == 0 || ast_kind(ret_expr) != 33 { return 0 }
    uint64 ret_op = tok_kind_at_raw(ast_data1(ret_expr))
    if ret_op != 23 { return 0 }      // not &
    uint32 ret_lhs = ast_child(ret_expr)
    uint32 ret_rhs = ast_data2(ret_expr)
    if ret_rhs == 0 || ast_kind(ret_rhs) != 30 { return 0 }
    uint64 ret_rhs_tok = ast_data1(ret_rhs)
    if parse_int_token(ret_rhs_tok) != 0xFFFFFFFF { return 0 }
    if ret_lhs == 0 || ast_kind(ret_lhs) != 33 { return 0 }
    uint64 or_op = tok_kind_at_raw(ast_data1(ret_lhs))
    if or_op != 24 { return 0 }       // not |
    uint32 or_lhs = ast_child(ret_lhs)
    uint32 or_rhs = ast_data2(ret_lhs)
    uint64 wlt = lo_tok
    uint64 wht = hi_tok
    if or_lhs == 0 || ast_kind(or_lhs) != 32 { return 0 }
    if tok_text_eq(ast_data1(or_lhs), wlt) == 0 { return 0 }
    if or_rhs == 0 || ast_kind(or_rhs) != 32 { return 0 }
    if tok_text_eq(ast_data1(or_rhs), wht) == 0 { return 0 }
    return 1
}

// Returns the body Return-value expression if `fn_node` is eligible,
// else 0. Two acceptable shapes:
//   (a) Single Return statement with a pure expression and per-param
//       single-use (the original conservative case).
//   (b) The 32-bit rotation idiom — three statements (VarDecl lo,
//       VarDecl hi, Return) matching `inline_is_rotation_shape`. The
//       multi-use param check is relaxed for this shape because the
//       IR-level ROR matcher collapses the inlined body to a single
//       instruction, so the duplication carries zero runtime cost.
fn inline_body_expr(uint64 fn_node) -> uint64 {
    uint32 body = ast_data3(fn_node)
    if body == 0 { return 0 }
    if ast_kind(body) != 15 { return 0 }   // not a Block

    uint32 stmt = ast_child(body)
    if stmt == 0 { return 0 }
    // Path (a): single-statement Return.
    if ast_next(stmt) == 0 && ast_kind(stmt) == 12 {
        uint32 expr = ast_child(stmt)
        if expr == 0 { return 0 }
        if ast_data3(stmt) != 0 { return 0 }
        if ast_data4(stmt) != 0 { return 0 }
        if inline_expr_is_pure(expr) == 0 { return 0 }
        if inline_params_single_use(fn_node, expr) == 0 { return 0 }
        return expr
    }
    // Path (b): rotation idiom. Return the AST node of the Return's expr
    // for the substitution machinery to clone. inline_try_call's body
    // walker handles VarDecl-prefix substitution.
    if inline_is_rotation_shape(body, fn_node) != 0 {
        // Walk to the third statement (the Return) and return its expr.
        uint32 vd1 = ast_child(body)
        uint32 vd2 = ast_next(vd1)
        uint32 ret = ast_next(vd2)
        return ast_child(ret)
    }
    return 0
}

// Walk Module's FnDecls and register every eligible candidate.
@export
fn inline_collect(uint64 root) {
    if root == 0 { return }
    uint32 fn_n = ast_child(root)
    while fn_n != 0 {
        uint32 k = ast_kind(fn_n)
        if k == 2 {
            uint32 name_tok = ast_data1(fn_n)
            uint64 wnt = name_tok

            // Skip the entry point and anything carrying annotations
            // (@export keeps the symbol live; @naked / @noreturn change
            // codegen; @section pins the function to a specific output
            // section). data4 holds the bit-packed annotation flags.
            // @section is stored in a side-table keyed by name token.
            uint64 skip = 0
            if tok_matches(wnt, "main", 4) != 0 { skip = 1 }
            if ast_data4(fn_n) != 0 { skip = 1 }
            if fn_section_lookup(wnt) != 0 { skip = 1 }

            if skip == 0 {
                uint64 body_expr = inline_body_expr(fn_n)
                if body_expr != 0 {
                    if inline_table_count < INLINE_TABLE_CAP {
                        uint64 slot = inline_table_buf + inline_table_count * 8
                        uint32 nt32 = name_tok
                        unsafe { *(slot as uint32) = nt32 }
                        uint64 slot4 = slot + 4
                        uint32 be32 = body_expr
                        unsafe { *(slot4 as uint32) = be32 }
                        // Flag rotation-shape candidates so inline_try_call
                        // can populate the body-locals table and require
                        // trivial args.
                        uint32 fn_body = ast_data3(fn_n)
                        uint64 wfb = fn_body
                        uint64 is_rot = inline_is_rotation_shape(wfb, fn_n)
                        inline_flag_set(inline_table_count, is_rot)
                        inline_table_count = inline_table_count + 1
                    }
                }
            }
        }
        uint32 nxt = ast_next(fn_n)
        fn_n = nxt
    }
}

// Look up a callee by token. Returns table index or 0xFFFFFFFF.
fn inline_lookup(uint64 callee_tok) -> uint64 {
    uint64 i = 0
    while i < inline_table_count {
        uint64 slot = inline_table_buf + i * 8
        uint32 nt = 0
        unsafe { *(slot as uint32) -> nt }
        uint64 wnt = nt
        if tok_text_eq(wnt, callee_tok) != 0 { return i }
        i = i + 1
    }
    return 0xFFFFFFFF
}

// Locate the n-th argument node (0-indexed) in a Call's argument
// linked list. Returns 0 if out of range.
fn inline_nth_arg(uint64 args_first, uint64 n) -> uint64 {
    uint64 cur = args_first
    uint64 i = 0
    while cur != 0 && i < n {
        uint32 nxt = ast_next(cur)
        cur = nxt
        i = i + 1
    }
    return cur
}

// Find the parameter index whose name matches `pname_tok` in the
// callee's parameter list. Returns 0xFFFFFFFF if not found.
fn inline_param_index(uint64 fn_node, uint64 pname_tok) -> uint64 {
    uint32 p = ast_child(fn_node)
    uint64 i = 0
    while p != 0 {
        uint32 nt = ast_data2(p)
        uint64 wnt = nt
        if tok_text_eq(wnt, pname_tok) != 0 { return i }
        uint32 nxt = ast_next(p)
        p = nxt
        i = i + 1
    }
    return 0xFFFFFFFF
}

// Deep-copy an arbitrary AST subtree. Used for cloning argument
// expressions that get substituted into the body. Recurses through
// child + data2 for binops/compares/etc., and walks `next`-linked
// sibling chains too. Returns the new root index.
fn inline_clone(uint64 src) -> uint64 {
    if src == 0 { return 0 }
    uint64 dst = ast_alloc(0)
    if dst == 0 { return 0 }
    // Copy 32 bytes wholesale.
    uint64 sb = ast_buf + (src - 1) * 32
    uint64 db = ast_buf + (dst - 1) * 32
    uint64 i = 0
    while i < 32 {
        uint64 sp = sb + i
        uint64 dp = db + i
        uint64 b = 0
        unsafe { *(sp as uint8) -> b }
        uint8 b8 = b
        unsafe { *(dp as uint8) = b8 }
        i = i + 1
    }
    // Recurse into structural references and rewrite them.
    uint32 src_kind = ast_kind(src)
    uint64 wk = src_kind

    // child sub-tree: first arg / lhs / operand / first stmt / ...
    uint32 sch = ast_child(src)
    uint64 dch = inline_clone(sch)
    uint32 dch32 = dch
    ast_set_child(dst, dch32)

    // sibling (next) — clone the chain too. For top-level invocations
    // we usually pass roots of stand-alone exprs whose `next` is 0,
    // but child lists rely on this.
    uint32 sn = ast_next(src)
    uint64 dn = inline_clone(sn)
    uint32 dn32 = dn
    ast_set_next(dst, dn32)

    // data2 holds rhs for BinOp/Compare/LogicalAnd/LogicalOr.
    if wk == 33 || wk == 38 || wk == 39 || wk == 40 {
        uint32 srhs = ast_data2(src)
        uint64 drhs = inline_clone(srhs)
        uint32 drhs32 = drhs
        ast_set_data2(dst, drhs32)
    }
    return dst
}

// Deep-copy `expr` into fresh nodes. Whenever we hit an Ident whose
// name matches a parameter of `fn_node`, clone the corresponding
// argument subtree from `args_first` instead.
fn inline_clone_subst(uint64 expr, uint64 fn_node, uint64 args_first) -> uint64 {
    if expr == 0 { return 0 }
    uint32 k = ast_kind(expr)
    uint64 wk = k

    if wk == 32 {
        // Ident: maybe a parameter, maybe a body-local, else free var.
        uint32 nt = ast_data1(expr)
        uint64 wnt = nt
        uint64 pidx = inline_param_index(fn_node, wnt)
        if pidx != 0xFFFFFFFF {
            uint64 arg = inline_nth_arg(args_first, pidx)
            if arg == 0 { return 0 }
            // Clone the argument subtree. Its `next` must be cleared
            // since the cloned arg is being placed at a different
            // structural position than the original (where `next`
            // pointed at the next sibling argument).
            uint64 c = inline_clone(arg)
            if c != 0 {
                uint32 zero = 0
                ast_set_next(c, zero)
            }
            return c
        }
        // Body-local (rotation-shape inliner only): recursively
        // clone-subst its init expression so its embedded params get
        // substituted too.
        uint64 init = inline_local_lookup(wnt)
        if init != 0 {
            uint64 sub = inline_clone_subst(init, fn_node, args_first)
            if sub != 0 {
                uint32 zero = 0
                ast_set_next(sub, zero)
            }
            return sub
        }
        // Free variable — copy as-is.
        uint64 idn = ast_alloc(32)
        uint32 nt32 = nt
        ast_set_data1(idn, nt32)
        uint32 tk = ast_tok(expr)
        ast_set_tok(idn, tk)
        return idn
    }

    if wk == 30 || wk == 46 || wk == 49 {
        // Literal — copy data1/data2/data3/data4/tok, no children.
        uint64 nn = ast_alloc(wk)
        uint32 d1 = ast_data1(expr)
        ast_set_data1(nn, d1)
        uint32 d2 = ast_data2(expr)
        ast_set_data2(nn, d2)
        uint32 d3 = ast_data3(expr)
        ast_set_data3(nn, d3)
        uint32 d4 = ast_data4(expr)
        ast_set_data4(nn, d4)
        uint32 tk = ast_tok(expr)
        ast_set_tok(nn, tk)
        return nn
    }

    if wk == 34 {
        // UnaryOp: child = operand.
        uint64 nn = ast_alloc(34)
        uint32 d1 = ast_data1(expr)
        ast_set_data1(nn, d1)
        uint32 tk = ast_tok(expr)
        ast_set_tok(nn, tk)
        uint32 ch = ast_child(expr)
        uint64 dch = inline_clone_subst(ch, fn_node, args_first)
        uint32 dch32 = dch
        ast_set_child(nn, dch32)
        return nn
    }

    // BinOp / Compare / LogicalAnd / LogicalOr — child = lhs, data2 = rhs.
    if wk == 33 || wk == 38 || wk == 39 || wk == 40 {
        uint64 nn = ast_alloc(wk)
        uint32 d1 = ast_data1(expr)
        ast_set_data1(nn, d1)
        uint32 tk = ast_tok(expr)
        ast_set_tok(nn, tk)
        uint32 lhs = ast_child(expr)
        uint64 dlhs = inline_clone_subst(lhs, fn_node, args_first)
        uint32 dlhs32 = dlhs
        ast_set_child(nn, dlhs32)
        uint32 rhs = ast_data2(expr)
        uint64 drhs = inline_clone_subst(rhs, fn_node, args_first)
        uint32 drhs32 = drhs
        ast_set_data2(nn, drhs32)
        return nn
    }

    // Anything else — shouldn't reach here because purity check
    // guarded against it. Be defensive: bail with 0 so the caller
    // skips the inline.
    return 0
}

// Find the FnDecl node whose name token is `tok`. Linear scan over
// Module's children — fine for the modest function counts we deal
// with at compile time.
fn inline_find_fn(uint64 root, uint64 tok) -> uint64 {
    if root == 0 { return 0 }
    uint32 fn_n = ast_child(root)
    while fn_n != 0 {
        if ast_kind(fn_n) == 2 {
            uint32 nt = ast_data1(fn_n)
            uint64 wnt = nt
            if tok_text_eq(wnt, tok) != 0 { return fn_n }
        }
        uint32 nxt = ast_next(fn_n)
        fn_n = nxt
    }
    return 0
}

// Count the number of Call arguments (linked via `next` from `child`).
fn inline_arg_count(uint64 call_node) -> uint64 {
    uint32 a = ast_child(call_node)
    uint64 c = 0
    while a != 0 {
        c = c + 1
        uint32 nxt = ast_next(a)
        a = nxt
    }
    return c
}

// Count parameter slots in `fn_node`.
fn inline_param_count(uint64 fn_node) -> uint64 {
    uint32 p = ast_child(fn_node)
    uint64 c = 0
    while p != 0 {
        c = c + 1
        uint32 nxt = ast_next(p)
        p = nxt
    }
    return c
}

// Try to inline a single Call node. If successful, mutates the Call
// in-place to become the substituted root expression. Returns 1 on
// success, 0 otherwise.
fn inline_try_call(uint64 call_node, uint64 root) -> uint64 {
    if call_node == 0 { return 0 }
    uint32 ctok = ast_data1(call_node)
    uint64 wct = ctok

    // Skip recursive call — caller's own fn token matches the callee.
    if inline_current_fn_tok != 0 {
        if tok_text_eq(wct, inline_current_fn_tok) != 0 { return 0 }
    }

    uint64 tidx = inline_lookup(wct)
    if tidx == 0xFFFFFFFF { return 0 }

    // Resolve the FnDecl so we can inspect the param list.
    uint64 fn_node = inline_find_fn(root, wct)
    if fn_node == 0 { return 0 }

    // Arity check — sema already verified, but defend against any
    // weirdness like inlining into a context where the call hasn't
    // been validated.
    uint64 expected = inline_param_count(fn_node)
    uint64 actual = inline_arg_count(call_node)
    if expected != actual { return 0 }

    // Pull body expr from the table.
    uint64 slot = inline_table_buf + tidx * 8 + 4
    uint32 be = 0
    unsafe { *(slot as uint32) -> be }
    uint64 body_expr = be
    if body_expr == 0 { return 0 }

    uint32 args_first = ast_child(call_node)
    uint64 wargs = args_first

    // Rotation-shape candidates: require all args to be trivial (Ident
    // or literal), and populate the body-locals table from the
    // callee's VarDecl prefix so clone-subst can expand `lo` and `hi`.
    uint64 flag = inline_flag_get(tidx)
    inline_locals_count = 0
    if flag != 0 {
        uint64 walk_arg = wargs
        while walk_arg != 0 {
            if inline_arg_is_trivial(walk_arg) == 0 { return 0 }
            uint32 anxt = ast_next(walk_arg)
            walk_arg = anxt
        }
        // Walk the callee's body block; register VarDecls.
        uint32 body_blk = ast_data3(fn_node)
        uint64 wbb = body_blk
        if wbb != 0 {
            uint32 stmt = ast_child(body_blk)
            uint64 wstmt = stmt
            while wstmt != 0 {
                if ast_kind(wstmt) == 10 {
                    uint32 vname = ast_data2(wstmt)
                    uint32 vinit = ast_child(wstmt)
                    uint64 wvn = vname
                    uint64 wvi = vinit
                    inline_local_register(wvn, wvi)
                }
                uint32 nxt = ast_next(wstmt)
                wstmt = nxt
            }
        }
    }

    // Build the substituted expression.
    uint64 new_expr = inline_clone_subst(body_expr, fn_node, wargs)
    if new_expr == 0 { return 0 }

    // Mutate the Call node IN PLACE so its slot in any sibling chain
    // (statement seq, arg list, …) is preserved. Copy kind, data1,
    // data2, data3, data4, tok, child from `new_expr`. Keep the
    // call's existing `next`.
    uint32 new_kind = ast_kind(new_expr)
    uint64 cb = ast_buf + (call_node - 1) * 32
    uint64 nb = ast_buf + (new_expr - 1) * 32

    // Bytes 0..24 hold kind/data1..data4/tok. Byte 24..28 is child;
    // byte 28..32 is next (preserved).
    uint64 i = 0
    while i < 28 {
        uint64 sp = nb + i
        uint64 dp = cb + i
        uint64 b = 0
        unsafe { *(sp as uint8) -> b }
        uint8 b8 = b
        unsafe { *(dp as uint8) = b8 }
        i = i + 1
    }
    return 1
}

// Walk an arbitrary AST subtree and try to inline every Call node we
// find. Recurses through child + sibling chains and also through the
// kind-specific extra references (BinOp.data2, If.data1/data2,
// While.data1, Match.data1, FnDecl.data3 etc.) so we don't miss
// expressions hidden behind those side links.
fn inline_walk(uint64 node, uint64 root) {
    if node == 0 { return }
    uint32 k = ast_kind(node)
    uint64 wk = k

    if wk == 35 {
        // Try to inline before we recurse — children get substituted
        // into the new tree and don't need a second visit.
        uint64 ok = inline_try_call(node, root)
        if ok != 0 { return }
    }

    // Children list (linked via `next`).
    uint32 c = ast_child(node)
    while c != 0 {
        // Save next BEFORE recursion since inline_try_call mutates the
        // visited node's contents but not its `next` slot, so this is
        // safe — but defensive.
        uint32 nxt = ast_next(c)
        inline_walk(c, root)
        c = nxt
    }

    // Side links per kind.
    if wk == 33 || wk == 38 || wk == 39 || wk == 40 {
        uint32 rhs = ast_data2(node)
        if rhs != 0 { inline_walk(rhs, root) }
    }
    if wk == 13 {
        // If: data1 = then_block, data2 = else_block.
        uint32 tb = ast_data1(node)
        if tb != 0 { inline_walk(tb, root) }
        uint32 eb = ast_data2(node)
        if eb != 0 { inline_walk(eb, root) }
    }
    if wk == 14 {
        // While: data1 = body block.
        uint32 wb = ast_data1(node)
        if wb != 0 { inline_walk(wb, root) }
    }
    if wk == 19 {
        // Match: data1 = first arm.
        uint32 a = ast_data1(node)
        while a != 0 {
            // Each MatchArm has data2 = body block. Walk both arm and
            // body just in case.
            inline_walk(a, root)
            uint32 abody = ast_data2(a)
            if abody != 0 { inline_walk(abody, root) }
            uint32 anxt = ast_next(a)
            a = anxt
        }
    }
    if wk == 51 {
        // Defer: data1 = body block.
        uint32 db = ast_data1(node)
        if db != 0 { inline_walk(db, root) }
    }
    if wk == 12 {
        // Return tuple extras.
        uint32 r3 = ast_data3(node)
        if r3 != 0 { inline_walk(r3, root) }
        uint32 r4 = ast_data4(node)
        if r4 != 0 { inline_walk(r4, root) }
    }
    if wk == 37 {
        // Index: data1 = index expr.
        uint32 ix = ast_data1(node)
        if ix != 0 { inline_walk(ix, root) }
    }
    if wk == 2 {
        // FnDecl: data3 = body block.
        uint32 b = ast_data3(node)
        if b != 0 {
            uint32 saved = inline_current_fn_tok
            uint32 fnt = ast_data1(node)
            inline_current_fn_tok = fnt
            inline_walk(b, root)
            inline_current_fn_tok = saved
        }
    }
}

// Top-level entry point. Call after sema has validated the AST and
// before DCE / IR lowering. Idempotent — running twice is safe but
// useless. The pass always runs regardless of emit mode: call sites
// get their callees folded inline. For emit modes where the original
// function definitions also need to survive (--emit=obj, --emit=asm,
// --emit=ir), the caller sets dce_set_keep_all(1) so DCE doesn't
// prune the now-uncalled bodies.
@export
fn inline_pass(uint64 root) {
    inline_init()
    inline_collect(root)
    if inline_table_count == 0 { return }
    inline_walk(root, root)
}
// MLRift — built on KernRift — Living Compiler
//
// Implements the blueprint vision (see docs/LIVING_COMPILER.md) at its
// current maturity stage: a governed, two-layer analysis that separates
// stable semantic-core concerns from adaptive surface suggestions.
//
// Two layers, explicitly:
//
//   SEMANTIC CORE — correctness, safety, structural health. Patterns here
//     reflect things that can cause wrong behavior or hide real bugs.
//
//   ADAPTIVE SURFACE — ergonomic/stylistic improvements. Patterns here
//     suggest migrating to newer syntax that lowers to the same IR. These
//     are candidates for an automated migration pass.
//
// The blueprint also calls for: a proposal engine, a governance layer,
// versioned language profiles, and a full migration engine. Those are
// future work — this file lays the ground rules they will build on.
//
// Patterns currently detected
//
//   Core:
//     - unchecked_call       — high fraction of discarded call results
//     - large_unsafe_ratio   — too many unsafe pointer ops vs total ops
//     - high_call_density    — complex call graph, hard to audit
//
//   Surface:
//     - legacy_ptr_ops       — unsafe { *(addr as T) -> v } — can migrate
//                              to load8/16/32/64 or store8/16/32/64
//     - many_trivial_fns     — many 1-2 statement functions (inline hints)

// ---------------------------------------------------------------------------
// Telemetry struct (80 bytes, 10 fields × 8)
// ---------------------------------------------------------------------------

struct Telemetry {
    uint64 fn_count
    uint64 extern_count
    uint64 call_count
    uint64 unsafe_count
    uint64 lock_edge_count
    uint64 irq_fn_count
    uint64 total_ops
    uint64 exprstmt_call_count
    uint64 trivial_fn_count
    uint64 tail_call_candidates
    // v2.6 additions — proposal triggers
    uint64 long_type_count       // count of long-form uint8..int64 tokens
    uint64 ptrlen_param_count    // count of functions with a (ptr, *_len/*_count) adjacent pair
    uint64 volatile_op_count     // count of vloadN/vstoreN AST nodes (sequential pattern candidate)
}

// ---------------------------------------------------------------------------
// Pattern entry (48 bytes: 6 × 8)
// ---------------------------------------------------------------------------
// [0]  id string ptr
// [8]  title string ptr
// [16] suggestion string ptr
// [24] fitness (uint64)
// [32] signal value (uint64, context-dependent)
// [40] flags: bit 0 = layer (0 = semantic core, 1 = adaptive surface),
//             bit 1 = auto-fix available

static uint64 lc_patterns = 0
static uint64 lc_pattern_count = 0

fn lc_add_pattern(uint64 id, uint64 title, uint64 suggestion, uint64 fitness, uint64 signal_val, uint64 flags) {
    uint64 entry = lc_patterns + lc_pattern_count * 48
    unsafe { *(entry as uint64) = id }
    uint64 e8 = entry + 8
    unsafe { *(e8 as uint64) = title }
    uint64 e16 = entry + 16
    unsafe { *(e16 as uint64) = suggestion }
    uint64 e24 = entry + 24
    unsafe { *(e24 as uint64) = fitness }
    uint64 e32 = entry + 32
    unsafe { *(e32 as uint64) = signal_val }
    uint64 e40 = entry + 40
    unsafe { *(e40 as uint64) = flags }
    lc_pattern_count = lc_pattern_count + 1
}

fn lc_get_pattern_id(uint64 idx) -> uint64 {
    uint64 entry = lc_patterns + idx * 48
    uint64 val = 0
    unsafe { *(entry as uint64) -> val }
    return val
}

fn lc_get_pattern_title(uint64 idx) -> uint64 {
    uint64 entry = lc_patterns + idx * 48 + 8
    uint64 val = 0
    unsafe { *(entry as uint64) -> val }
    return val
}

fn lc_get_pattern_suggestion(uint64 idx) -> uint64 {
    uint64 entry = lc_patterns + idx * 48 + 16
    uint64 val = 0
    unsafe { *(entry as uint64) -> val }
    return val
}

fn lc_get_pattern_fitness(uint64 idx) -> uint64 {
    uint64 entry = lc_patterns + idx * 48 + 24
    uint64 val = 0
    unsafe { *(entry as uint64) -> val }
    return val
}

fn lc_get_pattern_signal(uint64 idx) -> uint64 {
    uint64 entry = lc_patterns + idx * 48 + 32
    uint64 val = 0
    unsafe { *(entry as uint64) -> val }
    return val
}

fn lc_get_pattern_flags(uint64 idx) -> uint64 {
    uint64 entry = lc_patterns + idx * 48 + 40
    uint64 val = 0
    unsafe { *(entry as uint64) -> val }
    return val
}

// Layer classification: 0 = semantic core, 1 = adaptive surface
fn lc_pattern_layer(uint64 idx) -> uint64 {
    uint64 f = lc_get_pattern_flags(idx)
    return f & 1
}

fn lc_pattern_can_fix(uint64 idx) -> uint64 {
    uint64 f = lc_get_pattern_flags(idx)
    return (f >> 1) & 1
}

// ---------------------------------------------------------------------------
// Telemetry collection
// ---------------------------------------------------------------------------

fn tel_set(uint64 tel, uint64 field, uint64 val) {
    uint64 p = tel + field * 8
    unsafe { *(p as uint64) = val }
}

fn tel_get(uint64 tel, uint64 field) -> uint64 {
    uint64 p = tel + field * 8
    uint64 val = 0
    unsafe { *(p as uint64) -> val }
    return val
}

fn tel_inc(uint64 tel, uint64 field) {
    uint64 p = tel + field * 8
    uint64 val = 0
    unsafe { *(p as uint64) -> val }
    val = val + 1
    unsafe { *(p as uint64) = val }
}

// Return 1 if the given token is a long-form type keyword (uint8..int64),
// 0 if it's a short alias or something else. Long forms start with 'u' or
// 'i' and have text length >= 4.
fn lc_is_long_type_tok(uint64 tok) -> uint64 {
    uint64 tlen = tok_text_len(tok)
    if tlen < 4 { return 0 }
    uint64 tstart = tok_text_start(tok)
    uint64 sp = cg_source + tstart
    uint64 c0 = 0
    unsafe { *(sp as uint8) -> c0 }
    if c0 != 117 && c0 != 105 { return 0 }  // 'u' or 'i'
    // Second char: long forms have 'i' (uint*) or a digit (int*)
    uint64 sp1 = cg_source + tstart + 1
    uint64 c1 = 0
    unsafe { *(sp1 as uint8) -> c1 }
    // u-prefix: uintN — second char 'i', third 'n', fourth 't'
    if c0 == 117 && c1 == 105 { return 1 }
    // i-prefix: intN — second char 'n', third 't'
    if c0 == 105 && c1 == 110 { return 1 }
    return 0
}

// Return 1 if param_name (a token) ends in "_len", "_count", or "_size".
// Used to detect adjacent (ptr, *_len) pairs that could become a slice.
fn lc_is_len_name(uint64 name_tok) -> uint64 {
    uint64 nlen = tok_text_len(name_tok)
    uint64 nstart = tok_text_start(name_tok)
    if nlen >= 4 {
        // _len
        uint64 p1 = cg_source + nstart + nlen - 4
        uint64 c1 = 0
        unsafe { *(p1 as uint8) -> c1 }
        if c1 == 95 {
            uint64 p2 = cg_source + nstart + nlen - 3
            uint64 c2 = 0
            unsafe { *(p2 as uint8) -> c2 }
            uint64 p3 = cg_source + nstart + nlen - 2
            uint64 c3 = 0
            unsafe { *(p3 as uint8) -> c3 }
            uint64 p4 = cg_source + nstart + nlen - 1
            uint64 c4 = 0
            unsafe { *(p4 as uint8) -> c4 }
            if c2 == 108 && c3 == 101 && c4 == 110 { return 1 }  // "len"
        }
    }
    if nlen >= 5 {
        // _size
        uint64 q1 = cg_source + nstart + nlen - 5
        uint64 qc1 = 0
        unsafe { *(q1 as uint8) -> qc1 }
        if qc1 == 95 {
            uint64 qp = cg_source + nstart + nlen - 4
            uint64 qpc = 0
            unsafe { *(qp as uint8) -> qpc }
            if qpc == 115 { return 1 }  // _s... treat as potential size
        }
    }
    if nlen >= 6 {
        // _count
        uint64 r1 = cg_source + nstart + nlen - 6
        uint64 rc1 = 0
        unsafe { *(r1 as uint8) -> rc1 }
        if rc1 == 95 {
            uint64 rp = cg_source + nstart + nlen - 5
            uint64 rpc = 0
            unsafe { *(rp as uint8) -> rpc }
            if rpc == 99 { return 1 }  // _c... treat as potential count
        }
    }
    return 0
}

@export
fn collect_telemetry(uint64 root) -> uint64 {
    uint64 tel = alloc(128)
    // Zero fill
    uint64 i = 0
    while i < 128 {
        uint64 p = tel + i
        uint8 z = 0
        unsafe { *(p as uint8) = z }
        i = i + 1
    }

    // Walk top-level declarations
    uint32 child = ast_child(root)
    uint64 wchild = child
    while wchild != 0 {
        uint32 ck = ast_kind(wchild)

        if ck == 2 {
            // FnDecl
            tel_inc(tel, 0)

            // Scan param list: count long-form types and detect (ptr, _len) pairs
            uint32 first_param = ast_child(wchild)
            uint64 wp = first_param
            uint64 prev_was_ptr_like = 0
            while wp != 0 {
                uint32 pk = ast_kind(wp)
                if pk == 3 {
                    uint32 ptype_tok = ast_data1(wp)
                    uint64 wpt = ptype_tok
                    if lc_is_long_type_tok(wpt) != 0 {
                        tel_inc(tel, 10)
                    }
                    // Pointer-like param: a u64 (short) or uint64 (long) with
                    // a name that doesn't look like a length. If the next
                    // param's name ends in _len/_count/_size, count as a
                    // ptrlen pair.
                    uint32 pname_tok = ast_data2(wp)
                    uint64 wpn = pname_tok
                    if prev_was_ptr_like != 0 && lc_is_len_name(wpn) != 0 {
                        tel_inc(tel, 11)
                        prev_was_ptr_like = 0
                    } else {
                        // Is this param a plain u64/uint64 that could be a pointer?
                        if tok_text_eq(wpt, wpt) != 0 {
                            // (placeholder — actual is-u64 test below)
                        }
                        uint64 ptlen = tok_text_len(wpt)
                        prev_was_ptr_like = 0
                        if ptlen == 3 {
                            // "u64"
                            uint64 tp = cg_source + tok_text_start(wpt)
                            uint64 tc0 = 0
                            unsafe { *(tp as uint8) -> tc0 }
                            if tc0 == 117 { prev_was_ptr_like = 1 }
                        }
                        if ptlen == 6 {
                            // "uint64"
                            uint64 tp2 = cg_source + tok_text_start(wpt)
                            uint64 tc2 = 0
                            unsafe { *(tp2 as uint8) -> tc2 }
                            if tc2 == 117 { prev_was_ptr_like = 1 }
                        }
                    }
                }
                uint32 pnxt = ast_next(wp)
                wp = pnxt
            }

            // Check if it has a body — no body means extern-like
            uint32 body = ast_data3(wchild)
            uint64 wb = body
            if wb == 0 {
                tel_inc(tel, 1)
            } else {
                // Count statements in body
                uint64 stmt_count = 0
                uint32 bchild = ast_child(wb)
                uint64 wbc = bchild
                while wbc != 0 {
                    stmt_count = stmt_count + 1
                    uint32 bnxt = ast_next(wbc)
                    wbc = bnxt
                }
                if stmt_count <= 2 {
                    tel_inc(tel, 8)
                }

                // Count calls, unsafe, etc. in body
                lc_count_in_block(wb, tel)

                // Check tail call candidate
                if check_tail_call_candidate(wb) != 0 {
                    tel_inc(tel, 9)
                }
            }
        }

        uint32 nxt = ast_next(wchild)
        wchild = nxt
    }

    // Get lock edge count from analysis module
    tel_set(tel, 4, lock_edge_count)

    return tel
}

fn lc_count_in_block(uint64 block_node, uint64 tel) {
    uint32 child = ast_child(block_node)
    uint64 wchild = child
    while wchild != 0 {
        lc_count_in_stmt(wchild, tel)
        uint32 nxt = ast_next(wchild)
        wchild = nxt
    }
}

fn lc_count_in_stmt(uint64 node, uint64 tel) {
    uint32 kind = ast_kind(node)
    // Count total ops
    tel_inc(tel, 6)

    // VarDecl: check the declared type for long-form
    if kind == 10 {
        uint32 vtype_tok = ast_data1(node)
        uint64 wvt = vtype_tok
        if wvt != 0 && lc_is_long_type_tok(wvt) != 0 {
            tel_inc(tel, 10)
        }
    }

    // ExprStmt containing a Call = unchecked call result
    if kind == 16 {
        uint32 expr = ast_child(node)
        uint64 wexpr = expr
        if wexpr != 0 {
            uint32 ek = ast_kind(wexpr)
            if ek == 35 {
                // Call in ExprStmt — result discarded
                tel_inc(tel, 2)
                tel_inc(tel, 7)
            }
        }
    }

    // Count calls in other contexts (not ExprStmt)
    // We already counted ExprStmt calls above; also count calls in expressions
    if kind == 12 {
        // Return — check if child is a call
        uint32 rexpr = ast_child(node)
        uint64 wre = rexpr
        if wre != 0 {
            uint32 rek = ast_kind(wre)
            if rek == 35 {
                tel_inc(tel, 2)
            }
        }
    }

    // Unsafe PtrLoad/PtrStore — legacy syntax that can migrate to load*/store*
    if kind == 41 || kind == 42 {
        tel_inc(tel, 3)
    }

    // Recurse into if/while blocks
    if kind == 13 {
        uint32 tb = ast_data1(node)
        uint64 wtb = tb
        if wtb != 0 { lc_count_in_block(wtb, tel) }
        uint32 eb = ast_data2(node)
        uint64 web = eb
        if web != 0 { lc_count_in_block(web, tel) }
    }
    if kind == 14 {
        uint32 lb = ast_data1(node)
        uint64 wlb = lb
        if wlb != 0 { lc_count_in_block(wlb, tel) }
    }
}

fn check_tail_call_candidate(uint64 block_node) -> uint64 {
    // Find last statement. If it's a return with a call expr, it's a candidate.
    uint32 child = ast_child(block_node)
    uint64 wchild = child
    uint64 last = 0
    while wchild != 0 {
        last = wchild
        uint32 nxt = ast_next(wchild)
        wchild = nxt
    }
    if last != 0 {
        uint32 lk = ast_kind(last)
        uint64 wlk = lk
        if wlk == 12 {
            uint32 ret_expr = ast_child(last)
            uint64 wre = ret_expr
            if wre != 0 {
                uint32 rek = ast_kind(wre)
                uint64 wrek = rek
                if wrek == 35 { return 1 }
            }
        }
    }
    return 0
}

// ---------------------------------------------------------------------------
// Pattern detection
// ---------------------------------------------------------------------------
// Flag layout: bit 0 = layer (0 core, 1 surface), bit 1 = auto-fix available

@export
fn detect_patterns(uint64 root, uint64 tel) -> uint64 {
    lc_patterns = alloc(4096)
    lc_pattern_count = 0

    uint64 fn_c = tel_get(tel, 0)
    uint64 ext_c = tel_get(tel, 1)
    uint64 call_c = tel_get(tel, 2)
    uint64 unsafe_c = tel_get(tel, 3)
    uint64 total_ops = tel_get(tel, 6)
    uint64 exprstmt_c = tel_get(tel, 7)
    uint64 trivial_c = tel_get(tel, 8)

    // --- SEMANTIC CORE patterns ---

    // large_unsafe_ratio — too many raw unsafe ops vs total ops
    if total_ops > 0 && unsafe_c * 4 > total_ops {
        uint64 pct = unsafe_c * 100 / total_ops
        uint64 fit = 20 + pct
        if fit > 80 { fit = 80 }
        lc_add_pattern(
            "large_unsafe_ratio",
            "High unsafe operation density",
            "Consider wrapping repeated unsafe patterns in safe helper functions, or migrate to the load*/store* builtins.",
            fit,
            pct,
            0
        )
    }

    // unchecked_call — significant fraction of calls discard their results
    if call_c > 0 && exprstmt_c * 5 > call_c * 4 && exprstmt_c > 10 {
        uint64 pct = exprstmt_c * 100 / call_c
        uint64 fit = 20 + pct / 4
        if fit > 60 { fit = 60 }
        lc_add_pattern(
            "unchecked_call",
            "Unchecked call results",
            "Check return values of calls, especially for file I/O and allocation.",
            fit,
            pct,
            0
        )
    }

    // high_call_density — complex call graph (> 10 calls per function average)
    if fn_c > 0 && call_c > fn_c * 10 {
        uint64 ratio = call_c / fn_c
        uint64 fit = 20 + ratio * 3
        if fit > 70 { fit = 70 }
        lc_add_pattern(
            "high_call_density",
            "Complex call graph",
            "Consider splitting functions with many call sites to improve readability and auditability.",
            fit,
            ratio,
            0
        )
    }

    // --- ADAPTIVE SURFACE patterns ---

    // legacy_ptr_ops — raw unsafe { *(addr as T) -> v } / = val syntax
    // These migrate mechanically to load8/16/32/64 and store8/16/32/64 builtins
    // which produce identical code but are much easier to read.
    if unsafe_c > 0 {
        uint64 fit = 25 + unsafe_c * 2
        if fit > 60 { fit = 60 }
        // flags: layer=1 (surface), can_fix=1 (bit 1 = 2)
        lc_add_pattern(
            "legacy_ptr_ops",
            "Legacy unsafe{} pointer syntax",
            "Migrate `unsafe { *(addr as T) -> dest }` to `dest = loadN(addr)` and `unsafe { *(addr as T) = val }` to `storeN(addr, val)`. Same codegen, much cleaner.",
            fit,
            unsafe_c,
            3
        )
    }

    // many_trivial_fns — many 1-2 statement functions suggest inlining
    if fn_c > 4 && trivial_c * 10 > fn_c * 3 {
        uint64 fit = 15 + trivial_c * 5
        if fit > 50 { fit = 50 }
        lc_add_pattern(
            "many_trivial_fns",
            "Many trivial functions",
            "Consider inlining trivial 1-2 statement functions at call sites.",
            fit,
            trivial_c,
            1
        )
    }

    return lc_pattern_count
}

// ---------------------------------------------------------------------------
// Fitness scoring (0-100)
// ---------------------------------------------------------------------------
// Global fitness = base score with deductions for detected issues.
// Core-layer issues weigh more than surface-layer suggestions.

@export
fn compute_fitness(uint64 tel, uint64 patterns, uint64 has_lock_cycles) -> uint64 {
    uint64 score = 100

    uint64 fn_c = tel_get(tel, 0)
    uint64 unsafe_c = tel_get(tel, 3)
    uint64 total_ops = tel_get(tel, 6)

    // No functions: can't score meaningfully
    if fn_c == 0 { return 50 }

    // Deduct for each detected pattern based on its fitness and layer
    uint64 i = 0
    while i < lc_pattern_count {
        uint64 fit = lc_get_pattern_fitness(i)
        uint64 layer = lc_pattern_layer(i)
        // Core issues: bigger deduction (fit/4). Surface: smaller (fit/8).
        uint64 deduct = fit / 4
        if layer == 1 { deduct = fit / 8 }
        if deduct > 15 { deduct = 15 }
        if score > deduct {
            score = score - deduct
        } else {
            score = 0
        }
        i = i + 1
    }

    // Deduct for lock cycles (if the analysis module reported any)
    if has_lock_cycles != 0 {
        if score > 20 { score = score - 20 } else { score = 0 }
    }

    // Deduct for high unsafe ratio (>10% of all ops)
    if total_ops > 0 {
        if unsafe_c * 10 > total_ops {
            if score > 10 { score = score - 10 } else { score = 0 }
        }
    }

    return score
}

// ---------------------------------------------------------------------------
// Report helpers
// ---------------------------------------------------------------------------

fn lc_write_str(uint64 s) {
    uint64 slen = 0
    uint64 p = s
    uint64 c = 0
    unsafe { *(p as uint8) -> c }
    while c != 0 {
        slen = slen + 1
        p = s + slen
        unsafe { *(p as uint8) -> c }
    }
    write(1, s, slen)
}

fn lc_write_num(uint64 val) {
    uint8[32] nb
    uint64 nl = fmt_uint(nb, val)
    write(1, nb, nl)
}

// Print one pattern entry. Numbering index `n` (1-based) is caller-supplied.
fn lc_print_pattern(uint64 idx, uint64 n) {
    uint64 msg = "  ["
    write(1, msg, 3)
    lc_write_num(n)
    msg = "] "
    write(1, msg, 2)
    lc_write_str(lc_get_pattern_id(idx))
    msg = "  fitness: "
    write(1, msg, 11)
    lc_write_num(lc_get_pattern_fitness(idx))
    if lc_pattern_can_fix(idx) != 0 {
        msg = "  (auto-fix available)"
        write(1, msg, 22)
    }
    msg = "\n      title: "
    write(1, msg, 14)
    lc_write_str(lc_get_pattern_title(idx))
    msg = "\n      signal: "
    write(1, msg, 15)
    lc_write_num(lc_get_pattern_signal(idx))
    msg = " occurrence(s)\n      suggestion: "
    write(1, msg, 33)
    lc_write_str(lc_get_pattern_suggestion(idx))
    msg = "\n\n"
    write(1, msg, 2)
}

// ---------------------------------------------------------------------------
// Full report
// ---------------------------------------------------------------------------

@export
fn print_living_report(uint64 tel, uint64 patterns, uint64 fitness) {
    uint64 msg = "=== KernRift Living Compiler Report ===\n"
    write(1, msg, 40)
    msg = "    stable semantic core + adaptive surface layer\n"
    write(1, msg, 51)
    // Show the active language profile from #lang (if any)
    uint64 prof = get_lang_profile()
    if prof == 0 {
        msg = "    #lang stable        (default — production-safe features only)\n\n"
        write(1, msg, 68)
    } else {
        msg = "    #lang experimental (also allows features under active development)\n\n"
        write(1, msg, 73)
    }

    msg = "Telemetry\n"
    write(1, msg, 10)
    msg = "  Functions:   "
    write(1, msg, 15)
    lc_write_num(tel_get(tel, 0))
    msg = "\n  Calls:       "
    write(1, msg, 15)
    lc_write_num(tel_get(tel, 2))
    msg = "\n  Unsafe ops:  "
    write(1, msg, 15)
    lc_write_num(tel_get(tel, 3))
    msg = "\n  Total ops:   "
    write(1, msg, 15)
    lc_write_num(tel_get(tel, 6))
    msg = "\n  Patterns:    "
    write(1, msg, 15)
    lc_write_num(patterns)
    msg = "\n\nFitness: "
    write(1, msg, 10)
    lc_write_num(fitness)
    msg = "/100\n\n"
    write(1, msg, 6)

    if patterns == 0 {
        msg = "No patterns detected.\n"
        write(1, msg, 22)
        return
    }

    // Count patterns per layer
    uint64 core_count = 0
    uint64 surface_count = 0
    uint64 ci = 0
    while ci < lc_pattern_count {
        uint64 layer = lc_pattern_layer(ci)
        if layer == 0 {
            core_count = core_count + 1
        } else {
            surface_count = surface_count + 1
        }
        ci = ci + 1
    }

    // Core section
    if core_count > 0 {
        msg = "--- Semantic Core ("
        write(1, msg, 19)
        lc_write_num(core_count)
        msg = ") ---\n\n"
        write(1, msg, 7)
        uint64 n = 0
        uint64 i = 0
        while i < lc_pattern_count {
            if lc_pattern_layer(i) == 0 {
                n = n + 1
                lc_print_pattern(i, n)
            }
            i = i + 1
        }
    }

    // Surface section
    if surface_count > 0 {
        msg = "--- Adaptive Surface ("
        write(1, msg, 22)
        lc_write_num(surface_count)
        msg = ") ---\n\n"
        write(1, msg, 7)
        uint64 n2 = 0
        uint64 j = 0
        while j < lc_pattern_count {
            if lc_pattern_layer(j) == 1 {
                n2 = n2 + 1
                lc_print_pattern(j, n2)
            }
            j = j + 1
        }
    }
}

// ---------------------------------------------------------------------------
// CI gating
// ---------------------------------------------------------------------------
// Returns 1 if any pattern fitness >= threshold, 0 otherwise

@export
fn lc_check_ci_gate(uint64 min_fitness) -> uint64 {
    uint64 i = 0
    while i < lc_pattern_count {
        uint64 fit = lc_get_pattern_fitness(i)
        if fit >= min_fitness {
            return 1
        }
        i = i + 1
    }
    return 0
}

// ---------------------------------------------------------------------------
// Filtered report (only patterns >= threshold)
// ---------------------------------------------------------------------------

@export
fn print_living_report_filtered(uint64 tel, uint64 patterns, uint64 fitness, uint64 min_fitness) {
    uint64 msg = "=== KernRift Living Compiler Report ===\n"
    write(1, msg, 40)
    msg = "    stable semantic core + adaptive surface layer\n\n"
    write(1, msg, 52)

    msg = "Telemetry\n"
    write(1, msg, 10)
    msg = "  Functions:   "
    write(1, msg, 15)
    lc_write_num(tel_get(tel, 0))
    msg = "\n  Calls:       "
    write(1, msg, 15)
    lc_write_num(tel_get(tel, 2))
    msg = "\n  Unsafe ops:  "
    write(1, msg, 15)
    lc_write_num(tel_get(tel, 3))
    msg = "\n  Total ops:   "
    write(1, msg, 15)
    lc_write_num(tel_get(tel, 6))
    msg = "\n\nFitness: "
    write(1, msg, 10)
    lc_write_num(fitness)
    msg = "/100\n\n"
    write(1, msg, 6)

    // Count filtered patterns per layer
    uint64 shown_core = 0
    uint64 shown_surface = 0
    uint64 i = 0
    while i < lc_pattern_count {
        uint64 fit = lc_get_pattern_fitness(i)
        if fit >= min_fitness {
            if lc_pattern_layer(i) == 0 {
                shown_core = shown_core + 1
            } else {
                shown_surface = shown_surface + 1
            }
        }
        i = i + 1
    }

    uint64 shown = shown_core + shown_surface

    if shown == 0 {
        msg = "living-compiler: 0 suggestion(s) at fitness >= "
        write(1, msg, 47)
        lc_write_num(min_fitness)
        msg = "\n"
        write(1, msg, 1)
        return
    }

    msg = "living-compiler: "
    write(1, msg, 17)
    lc_write_num(shown)
    msg = " suggestion(s) at fitness >= "
    write(1, msg, 28)
    lc_write_num(min_fitness)
    msg = "\n\n"
    write(1, msg, 2)

    if shown_core > 0 {
        msg = "--- Semantic Core ("
        write(1, msg, 19)
        lc_write_num(shown_core)
        msg = ") ---\n\n"
        write(1, msg, 7)
        uint64 n = 0
        uint64 j = 0
        while j < lc_pattern_count {
            uint64 fit = lc_get_pattern_fitness(j)
            if fit >= min_fitness && lc_pattern_layer(j) == 0 {
                n = n + 1
                lc_print_pattern(j, n)
            }
            j = j + 1
        }
    }

    if shown_surface > 0 {
        msg = "--- Adaptive Surface ("
        write(1, msg, 22)
        lc_write_num(shown_surface)
        msg = ") ---\n\n"
        write(1, msg, 7)
        uint64 n2 = 0
        uint64 k = 0
        while k < lc_pattern_count {
            uint64 fit = lc_get_pattern_fitness(k)
            if fit >= min_fitness && lc_pattern_layer(k) == 1 {
                n2 = n2 + 1
                lc_print_pattern(k, n2)
            }
            k = k + 1
        }
    }
}

// ---------------------------------------------------------------------------
// Proposal engine + Governance layer
// ---------------------------------------------------------------------------
//
// Proposals are candidate syntax forms generated from observed friction.
// Each has a lifecycle state (governance layer):
//   0 = experimental  — opt-in, under active development
//   1 = stable        — promoted after evaluation, safe for production
//   2 = deprecated    — replaced by something better, still accepted
//
// A proposal table holds the current state. `krc lc --list-proposals`
// prints it. Triggered proposals also appear inline in the report with
// their current lifecycle state.
//
// The state table is currently hardcoded per compiler version. A future
// iteration (post-v2.7) will move it to a persistent .kernrift/proposals
// file so projects can pin their own governance decisions.
//
// Proposal entry (56 bytes, 7 × 8):
//   [0]  name ptr
//   [8]  state (0/1/2)
//   [16] trigger description ptr
//   [24] before snippet ptr
//   [32] after snippet ptr
//   [40] rationale ptr
//   [48] fires_flag (0/1, set by detect_proposals)

static uint64 prop_table = 0
static uint64 prop_count = 0

fn prop_add(uint64 name, uint64 state, uint64 trigger, uint64 before, uint64 after, uint64 rationale) {
    uint64 entry = prop_table + prop_count * 56
    unsafe { *(entry as uint64) = name }
    uint64 e8 = entry + 8
    unsafe { *(e8 as uint64) = state }
    uint64 e16 = entry + 16
    unsafe { *(e16 as uint64) = trigger }
    uint64 e24 = entry + 24
    unsafe { *(e24 as uint64) = before }
    uint64 e32 = entry + 32
    unsafe { *(e32 as uint64) = after }
    uint64 e40 = entry + 40
    unsafe { *(e40 as uint64) = rationale }
    uint64 e48 = entry + 48
    unsafe { *(e48 as uint64) = 0 }
    prop_count = prop_count + 1
}

fn prop_get_name(uint64 idx) -> uint64 {
    uint64 e = prop_table + idx * 56
    uint64 v = 0
    unsafe { *(e as uint64) -> v }
    return v
}
fn prop_get_state(uint64 idx) -> uint64 {
    uint64 e = prop_table + idx * 56 + 8
    uint64 v = 0
    unsafe { *(e as uint64) -> v }
    return v
}
fn prop_get_trigger(uint64 idx) -> uint64 {
    uint64 e = prop_table + idx * 56 + 16
    uint64 v = 0
    unsafe { *(e as uint64) -> v }
    return v
}
fn prop_get_before(uint64 idx) -> uint64 {
    uint64 e = prop_table + idx * 56 + 24
    uint64 v = 0
    unsafe { *(e as uint64) -> v }
    return v
}
fn prop_get_after(uint64 idx) -> uint64 {
    uint64 e = prop_table + idx * 56 + 32
    uint64 v = 0
    unsafe { *(e as uint64) -> v }
    return v
}
fn prop_get_rationale(uint64 idx) -> uint64 {
    uint64 e = prop_table + idx * 56 + 40
    uint64 v = 0
    unsafe { *(e as uint64) -> v }
    return v
}
fn prop_get_fires(uint64 idx) -> uint64 {
    uint64 e = prop_table + idx * 56 + 48
    uint64 v = 0
    unsafe { *(e as uint64) -> v }
    return v
}
fn prop_set_fires(uint64 idx, uint64 fires) {
    uint64 e = prop_table + idx * 56 + 48
    unsafe { *(e as uint64) = fires }
}

// Initialize the proposal registry with the current compiler's set of
// candidate syntax evolutions. This is the governance layer's hardcoded
// state — future versions will read from a per-project state file.
@export
fn init_proposals() {
    prop_table = alloc(64 * 56)
    prop_count = 0

    // Proposal: slice_for_buffer_params — stable (already in the language)
    prop_add(
        "slice_for_buffer_params",
        1,  // stable (actually implemented in v2.6)
        "Functions that take a (ptr, len) pair as separate params",
        "fn foo(u64 data, u64 len) { ... }",
        "fn foo([u8] data) { u64 n = data.len; ... }",
        "Symbolic length makes the buffer's boundary obvious at every use site."
    )

    // Proposal: device_block_from_mmio — stable (already implemented)
    prop_add(
        "device_block_from_mmio",
        1,  // stable
        "Three or more volatile ops on addresses at fixed offsets from a common base",
        "vstore32(0x3F201000 + 0x00, val); vstore32(0x3F201000 + 0x18, flag)",
        "device UART0 at 0x3F201000 { Data at 0x00 : u32; Flag at 0x18 : u32 }",
        "A device block is self-documenting and compiler-checked for width mismatches."
    )

    // Proposal: load_store_builtins — stable (already implemented)
    prop_add(
        "load_store_builtins",
        1,  // stable
        "unsafe{} blocks wrapping a single pointer load or store",
        "u32 v = 0; unsafe { *(addr as u32) -> v }",
        "u32 v = loadN(addr)",
        "Direct builtins are shorter, clearer, and auto-migratable."
    )

    // Proposal: short_type_aliases — stable (already implemented)
    prop_add(
        "short_type_aliases",
        1,  // stable
        "Frequent use of long-form uint32/uint64 type names",
        "uint64 count = 0; uint32 flags = 1",
        "u64 count = 0; u32 flags = 1",
        "Short aliases reduce visual noise without losing precision."
    )

    // Proposal: versioned_language_profiles — experimental (parser accepts them)
    prop_add(
        "versioned_language_profiles",
        0,  // experimental
        "Files targeting different language stability guarantees",
        "(no way to declare which surface features a file depends on)",
        "#lang stable\n...\n#lang experimental\n...",
        "Pinned profiles let old files keep compiling while new syntax evolves."
    )

    // Proposal: tail_call_intrinsic — experimental (not yet implemented)
    prop_add(
        "tail_call_intrinsic",
        0,  // experimental
        "Recursive calls in tail position in fixed-stack (@noreturn/@naked) contexts",
        "fn poll(u64 head) { ...; poll(next_head) }",
        "fn poll(u64 head) { ...; tail_call(poll, next_head) }",
        "Zero stack growth per iteration — required for infinite polling loops in kernels."
    )

    // Proposal: extern_fn_decls — experimental (deferred)
    prop_add(
        "extern_fn_decls",
        0,  // experimental
        "Source depends on external C or assembly symbols",
        "(not currently possible — asm() or syscall_raw only)",
        "extern fn platform_barrier()\nextern fn kmalloc(u64 size) -> u64",
        "Link against existing C runtimes, kernel APIs, or hand-rolled assembly shims."
    )
}

// Evaluate which proposals fire against the current telemetry.
// Returns the number of proposals marked as firing.
//
// Language profile gating: proposals in the experimental state only fire
// when the file has `#lang experimental`. Stable proposals always fire.
// This is the governance layer's live effect — files pinned to stable
// don't get pestered about features that are still under evaluation.
@export
fn detect_proposals(uint64 tel) -> uint64 {
    uint64 fired = 0
    uint64 unsafe_c = tel_get(tel, 3)
    uint64 fn_c = tel_get(tel, 0)
    uint64 profile = get_lang_profile()
    // Clear fire flags first
    uint64 j = 0
    while j < prop_count {
        prop_set_fires(j, 0)
        j = j + 1
    }
    uint64 long_type_c = tel_get(tel, 10)
    uint64 ptrlen_c = tel_get(tel, 11)

    // load_store_builtins: any legacy unsafe op fires it (stable, always)
    if unsafe_c > 0 {
        uint64 i = 0
        while i < prop_count {
            uint64 np = prop_get_name(i)
            if str_eq(np, "load_store_builtins") != 0 {
                uint64 st = prop_get_state(i)
                if st == 1 || profile == 1 {
                    prop_set_fires(i, 1)
                    fired = fired + 1
                }
            }
            i = i + 1
        }
    }

    // short_type_aliases: fires if there are 3+ long-form type uses
    if long_type_c >= 3 {
        uint64 i2 = 0
        while i2 < prop_count {
            uint64 np2 = prop_get_name(i2)
            if str_eq(np2, "short_type_aliases") != 0 {
                prop_set_fires(i2, 1)
                fired = fired + 1
            }
            i2 = i2 + 1
        }
    }

    // slice_for_buffer_params: fires if any function has a (ptr, _len/_size/_count) pair
    if ptrlen_c > 0 {
        uint64 i3 = 0
        while i3 < prop_count {
            uint64 np3 = prop_get_name(i3)
            if str_eq(np3, "slice_for_buffer_params") != 0 {
                prop_set_fires(i3, 1)
                fired = fired + 1
            }
            i3 = i3 + 1
        }
    }
    // Under #lang experimental, also surface the experimental-state proposals
    // as "coming soon" hints so users see what's planned.
    if profile == 1 {
        uint64 k = 0
        while k < prop_count {
            uint64 st2 = prop_get_state(k)
            if st2 == 0 && prop_get_fires(k) == 0 {
                prop_set_fires(k, 1)
                fired = fired + 1
            }
            k = k + 1
        }
    }
    return fired
}

fn prop_write_state(uint64 state) {
    if state == 0 {
        uint64 m = "experimental"
        write(1, m, 12)
    }
    if state == 1 {
        uint64 m = "stable"
        write(1, m, 6)
    }
    if state == 2 {
        uint64 m = "deprecated"
        write(1, m, 10)
    }
}

// Set the state of a proposal by name. Returns 1 if found, 0 if not.
fn prop_set_state_by_name(uint64 name, uint64 state) -> uint64 {
    uint64 i = 0
    while i < prop_count {
        uint64 np = prop_get_name(i)
        if str_eq(np, name) != 0 {
            uint64 e = prop_table + i * 56 + 8
            unsafe { *(e as uint64) = state }
            return 1
        }
        i = i + 1
    }
    return 0
}

// Persistent governance: load overrides from .kernrift/proposals and apply
// them to the in-memory proposal table. The file format is one line per
// proposal:
//
//   name experimental
//   name stable
//   name deprecated
//
// Anything else is ignored. Missing file is a no-op.
@export
fn load_proposal_overrides() {
    uint64 fd = file_open(".kernrift/proposals", 0)
    if fd > 0xFFFFFFFFFFFFF000 { return }
    uint64 fsize = file_size(fd)
    if fsize == 0 { file_close(fd); return }
    uint64 buf = alloc(fsize + 1)
    file_read(fd, buf, fsize)
    file_close(fd)
    uint64 tpn = buf + fsize
    uint8 nulc = 0
    unsafe { *(tpn as uint8) = nulc }
    // Walk the file line by line. For each line, split at the first space.
    // Left side = name, right side = state keyword.
    uint64 pos = 0
    while pos < fsize {
        uint64 line_start = pos
        uint64 sp_pos = 0
        uint64 line_end = pos
        while line_end < fsize {
            uint64 lbp = buf + line_end
            uint64 lc = 0
            unsafe { *(lbp as uint8) -> lc }
            if lc == 10 || lc == 0 { break }
            if lc == 32 && sp_pos == 0 { sp_pos = line_end }
            line_end = line_end + 1
        }
        if sp_pos > line_start {
            // Null-terminate name
            uint64 np = buf + sp_pos
            uint8 zn = 0
            unsafe { *(np as uint8) = zn }
            // Skip space
            uint64 val_start = sp_pos + 1
            // Null-terminate state value at line_end
            uint64 vep = buf + line_end
            uint8 ze = 0
            unsafe { *(vep as uint8) = ze }
            uint64 name_ptr = buf + line_start
            uint64 state_ptr = buf + val_start
            uint64 st_val = 0
            if str_eq(state_ptr, "stable") != 0 { st_val = 1 }
            if str_eq(state_ptr, "experimental") != 0 { st_val = 0 }
            if str_eq(state_ptr, "deprecated") != 0 { st_val = 2 }
            prop_set_state_by_name(name_ptr, st_val)
        }
        pos = line_end + 1
    }
}

// Save a proposal state override to .kernrift/proposals.
// Simplest approach: replace or append in a freshly-written file.
// Creates .kernrift/ directory on demand (mkdir via syscall).
fn save_proposal_override(uint64 name, uint64 new_state) {
    // Ensure .kernrift directory exists. Ignore failure (likely exists).
    // x86_64 Linux has `mkdir(path, mode)` at nr 83 (2 args).
    // arm64 Linux has only `mkdirat(dirfd, path, mode)` at nr 34 (3 args),
    // where dirfd=AT_FDCWD (-100) means "relative to cwd".
    u64 aid = get_arch_id()
    if aid == 2 || aid == 7 {
        // arm64 Linux / Android — use mkdirat
        u64 at_fdcwd = 0xFFFFFFFFFFFFFF9C
        syscall_raw(34, at_fdcwd, ".kernrift", 0x1C0, 0, 0, 0)
    } else {
        // x86_64 Linux (and freebsd/macos share mkdir nr 83)
        syscall_raw(83, ".kernrift", 0x1C0, 0, 0, 0, 0)
    }

    // Apply the override in memory first
    prop_set_state_by_name(name, new_state)

    // Rewrite the whole file from prop_table (simple, robust)
    uint64 out = alloc(4096)
    uint64 off = 0
    uint64 i = 0
    while i < prop_count {
        uint64 np = prop_get_name(i)
        uint64 st = prop_get_state(i)
        // Write name
        uint64 nl = 0
        uint64 npw = np
        uint64 nc = 0
        unsafe { *(npw as uint8) -> nc }
        while nc != 0 {
            uint64 op = out + off + nl
            uint8 cb = nc
            unsafe { *(op as uint8) = cb }
            nl = nl + 1
            npw = np + nl
            unsafe { *(npw as uint8) -> nc }
        }
        off = off + nl
        // Write " "
        uint64 spp = out + off
        uint8 sp = 32
        unsafe { *(spp as uint8) = sp }
        off = off + 1
        // Write state name
        uint64 state_str = "experimental"
        uint64 state_len = 12
        if st == 1 { state_str = "stable"; state_len = 6 }
        if st == 2 { state_str = "deprecated"; state_len = 10 }
        uint64 sj = 0
        while sj < state_len {
            uint64 ssp = state_str + sj
            uint64 ssc = 0
            unsafe { *(ssp as uint8) -> ssc }
            uint64 dsp = out + off + sj
            uint8 dsb = ssc
            unsafe { *(dsp as uint8) = dsb }
            sj = sj + 1
        }
        off = off + state_len
        // Write newline
        uint64 nlp = out + off
        uint8 nlc = 10
        unsafe { *(nlp as uint8) = nlc }
        off = off + 1
        i = i + 1
    }

    // Write the buffer back to .kernrift/proposals
    uint64 fd = file_open(".kernrift/proposals", 1)
    if fd > 0xFFFFFFFFFFFFF000 {
        write(2, "error: cannot write .kernrift/proposals\n", 40)
        return
    }
    file_write(fd, out, off)
    file_close(fd)
}

@export
fn promote_proposal(uint64 name) {
    save_proposal_override(name, 1)  // stable
    write(1, "promoted: ", 10)
    lc_write_str(name)
    write(1, " → stable\n", 12)
}

@export
fn deprecate_proposal(uint64 name) {
    save_proposal_override(name, 2)  // deprecated
    write(1, "deprecated: ", 12)
    lc_write_str(name)
    write(1, " → deprecated\n", 16)
}

@export
fn reject_proposal(uint64 name) {
    save_proposal_override(name, 0)  // experimental (rejected from stable)
    write(1, "reverted: ", 10)
    lc_write_str(name)
    write(1, " → experimental\n", 18)
}

// Print all proposals and their lifecycle state.
@export
fn list_proposals() {
    uint64 msg = "=== KernRift Proposal Registry ===\n"
    write(1, msg, 35)
    msg = "  telemetry -> proposals -> fitness -> governance -> migration\n\n"
    write(1, msg, 64)
    msg = "Total proposals: "
    write(1, msg, 17)
    lc_write_num(prop_count)
    msg = "\n\n"
    write(1, msg, 2)

    uint64 i = 0
    while i < prop_count {
        msg = "  ["
        write(1, msg, 3)
        lc_write_num(i + 1)
        msg = "] "
        write(1, msg, 2)
        lc_write_str(prop_get_name(i))
        msg = "\n      state:      "
        write(1, msg, 19)
        prop_write_state(prop_get_state(i))
        msg = "\n      trigger:    "
        write(1, msg, 19)
        lc_write_str(prop_get_trigger(i))
        msg = "\n      before:     "
        write(1, msg, 19)
        lc_write_str(prop_get_before(i))
        msg = "\n      after:      "
        write(1, msg, 19)
        lc_write_str(prop_get_after(i))
        msg = "\n      rationale:  "
        write(1, msg, 19)
        lc_write_str(prop_get_rationale(i))
        msg = "\n\n"
        write(1, msg, 2)
        i = i + 1
    }

    // Use lc_write_str to avoid length miscounts on multi-line footers
    lc_write_str("Governance: the state above is the compiler's baseline.\n")
    lc_write_str("Per-project overrides live in .kernrift/proposals, managed via:\n")
    lc_write_str("  krc lc --promote <name>     move a proposal to stable\n")
    lc_write_str("  krc lc --deprecate <name>   move a proposal to deprecated\n")
    lc_write_str("  krc lc --reject <name>      revert to experimental\n")
}

// Print proposals that are firing against the current telemetry (for use
// inside the regular lc report).
@export
fn print_firing_proposals() {
    uint64 any = 0
    uint64 i = 0
    while i < prop_count {
        if prop_get_fires(i) != 0 { any = 1 }
        i = i + 1
    }
    if any == 0 { return }

    uint64 msg = "--- Proposals triggered by telemetry ---\n\n"
    write(1, msg, 42)
    uint64 n = 0
    uint64 j = 0
    while j < prop_count {
        if prop_get_fires(j) != 0 {
            n = n + 1
            msg = "  ["
            write(1, msg, 3)
            lc_write_num(n)
            msg = "] "
            write(1, msg, 2)
            lc_write_str(prop_get_name(j))
            msg = "  state: "
            write(1, msg, 9)
            prop_write_state(prop_get_state(j))
            msg = "\n      before: "
            write(1, msg, 15)
            lc_write_str(prop_get_before(j))
            msg = "\n      after:  "
            write(1, msg, 15)
            lc_write_str(prop_get_after(j))
            msg = "\n      why:    "
            write(1, msg, 15)
            lc_write_str(prop_get_rationale(j))
            msg = "\n\n"
            write(1, msg, 2)
        }
        j = j + 1
    }
}

// ---------------------------------------------------------------------------
// Migration engine (source-to-source rewriter)
// ---------------------------------------------------------------------------
//
// Applies auto-fixes identified by the pattern detection pass. Today this
// implements a single rewrite:
//
//   unsafe { *(addr as T) -> dest }   →   dest = loadN(addr)
//   unsafe { *(addr as T) = val }      →   storeN(addr, val)
//
// The two forms produce identical code at the codegen level, so the
// rewrite is safe by construction.
//
// Scan strategy: byte-level walk over the source. For each occurrence of
// the literal "unsafe" at a word boundary, parse the following block as a
// pointer op. If it matches, record the byte span and the replacement
// text; otherwise leave it alone.

// Check whether source[off..off+len] equals a literal string
fn mig_text_eq(uint64 source, uint64 off, uint64 src_len_arg, uint64 literal, uint64 lit_len) -> uint64 {
    if off + lit_len > src_len_arg { return 0 }
    uint64 i = 0
    while i < lit_len {
        uint64 sp = source + off + i
        uint64 lp = literal + i
        uint64 sc = 0
        uint64 lc = 0
        unsafe { *(sp as uint8) -> sc }
        unsafe { *(lp as uint8) -> lc }
        if sc != lc { return 0 }
        i = i + 1
    }
    return 1
}

// Is this byte a word character (identifier continuation)?
fn mig_is_word(uint64 c) -> uint64 {
    if c >= 48 && c <= 57 { return 1 }   // 0-9
    if c >= 65 && c <= 90 { return 1 }   // A-Z
    if c >= 97 && c <= 122 { return 1 }  // a-z
    if c == 95 { return 1 }              // _
    return 0
}

// Skip whitespace (space, tab, CR, LF) from pos. Returns new position.
fn mig_skip_ws(uint64 source, uint64 p, uint64 src_end) -> uint64 {
    while p < src_end {
        uint64 sp = source + p
        uint64 c = 0
        unsafe { *(sp as uint8) -> c }
        if c != 32 && c != 9 && c != 13 && c != 10 { return p }
        p = p + 1
    }
    return p
}

// Read an expression span (up to but not including the matching close delim).
// Tracks paren depth; stops when we see " as " at depth 0 (within our enclosing parens).
// Returns the byte position of the first char of ` as ` (or src_end on failure).
fn mig_find_as(uint64 source, uint64 p, uint64 src_end) -> uint64 {
    uint64 depth = 0
    while p + 4 <= src_end {
        uint64 sp = source + p
        uint64 c = 0
        unsafe { *(sp as uint8) -> c }
        if c == 40 { depth = depth + 1 }
        if c == 41 {
            if depth == 0 { return src_end }
            depth = depth - 1
        }
        if depth == 0 && c == 32 {
            // Check for " as " — space, a, s, space
            uint64 p1 = source + p + 1
            uint64 p2 = source + p + 2
            uint64 p3 = source + p + 3
            uint64 c1 = 0
            uint64 c2 = 0
            uint64 c3 = 0
            unsafe { *(p1 as uint8) -> c1 }
            unsafe { *(p2 as uint8) -> c2 }
            unsafe { *(p3 as uint8) -> c3 }
            if c1 == 97 && c2 == 115 && c3 == 32 { return p }
        }
        p = p + 1
    }
    return src_end
}

// Parse a type keyword starting at `p`, return (width, new_p). Width=0 on failure.
// Recognizes: u8, u16, u32, u64, uint8, uint16, uint32, uint64,
//             i8, i16, i32, i64, int8, int16, int32, int64,
//             byte (=1), addr (=8)
fn mig_parse_type(uint64 source, uint64 p, uint64 src_end, uint64 width_out) -> uint64 {
    // Read an identifier word starting at p
    uint64 start = p
    while p < src_end {
        uint64 sp = source + p
        uint64 c = 0
        unsafe { *(sp as uint8) -> c }
        if mig_is_word(c) == 0 { break }
        p = p + 1
    }
    uint64 tlen = p - start
    if tlen == 0 {
        unsafe { *(width_out as uint64) = 0 }
        return p
    }
    uint64 w = 0
    if tlen == 2 {
        // u8 or i8
        if mig_text_eq(source, start, src_end, "u8", 2) != 0 { w = 1 }
        if mig_text_eq(source, start, src_end, "i8", 2) != 0 { w = 1 }
    }
    if tlen == 3 {
        if mig_text_eq(source, start, src_end, "u16", 3) != 0 { w = 2 }
        if mig_text_eq(source, start, src_end, "u32", 3) != 0 { w = 4 }
        if mig_text_eq(source, start, src_end, "u64", 3) != 0 { w = 8 }
        if mig_text_eq(source, start, src_end, "i16", 3) != 0 { w = 2 }
        if mig_text_eq(source, start, src_end, "i32", 3) != 0 { w = 4 }
        if mig_text_eq(source, start, src_end, "i64", 3) != 0 { w = 8 }
    }
    if tlen == 4 {
        if mig_text_eq(source, start, src_end, "int8", 4) != 0 { w = 1 }
        if mig_text_eq(source, start, src_end, "byte", 4) != 0 { w = 1 }
        if mig_text_eq(source, start, src_end, "addr", 4) != 0 { w = 8 }
    }
    if tlen == 5 {
        if mig_text_eq(source, start, src_end, "uint8", 5) != 0 { w = 1 }
        if mig_text_eq(source, start, src_end, "int16", 5) != 0 { w = 2 }
        if mig_text_eq(source, start, src_end, "int32", 5) != 0 { w = 4 }
        if mig_text_eq(source, start, src_end, "int64", 5) != 0 { w = 8 }
    }
    if tlen == 6 {
        if mig_text_eq(source, start, src_end, "uint16", 6) != 0 { w = 2 }
        if mig_text_eq(source, start, src_end, "uint32", 6) != 0 { w = 4 }
        if mig_text_eq(source, start, src_end, "uint64", 6) != 0 { w = 8 }
    }
    unsafe { *(width_out as uint64) = w }
    return p
}

// Append bytes from `src[src_off..src_off+len]` to `dst[*dst_pos]` and advance dst_pos
fn mig_append_bytes(uint64 dst, uint64 dst_pos_ptr, uint64 src, uint64 src_off, uint64 len) {
    uint64 dp = 0
    unsafe { *(dst_pos_ptr as uint64) -> dp }
    uint64 i = 0
    while i < len {
        uint64 sp = src + src_off + i
        uint64 c = 0
        unsafe { *(sp as uint8) -> c }
        uint64 tp = dst + dp + i
        uint8 cb = c
        unsafe { *(tp as uint8) = cb }
        i = i + 1
    }
    dp = dp + len
    unsafe { *(dst_pos_ptr as uint64) = dp }
}

// Append a null-terminated literal string
fn mig_append_str(uint64 dst, uint64 dst_pos_ptr, uint64 s) {
    uint64 len = 0
    uint64 p = s
    uint64 c = 0
    unsafe { *(p as uint8) -> c }
    while c != 0 {
        len = len + 1
        p = s + len
        unsafe { *(p as uint8) -> c }
    }
    mig_append_bytes(dst, dst_pos_ptr, s, 0, len)
}

// Append a width suffix (1/2/4/8 → "8"/"16"/"32"/"64")
fn mig_append_width(uint64 dst, uint64 dst_pos_ptr, uint64 width) {
    if width == 1 { mig_append_str(dst, dst_pos_ptr, "8") }
    if width == 2 { mig_append_str(dst, dst_pos_ptr, "16") }
    if width == 4 { mig_append_str(dst, dst_pos_ptr, "32") }
    if width == 8 { mig_append_str(dst, dst_pos_ptr, "64") }
}

// Main migration pass. Scans `source` and builds a rewritten output in `out_buf`.
// Returns (bytes_written, matches_applied).
// If dry_run is non-zero, nothing is written, but matches are still counted.
@export
fn mig_scan_and_rewrite(uint64 source, uint64 src_size, uint64 out_buf_a, uint64 matches_out) -> uint64 {
    uint64 sp_pos = 0
    uint64 dp = 0
    uint64 last_copied = 0
    uint64 applied = 0

    while sp_pos < src_size {
        uint64 bp = source + sp_pos
        uint64 ch = 0
        unsafe { *(bp as uint8) -> ch }

        // Look for 'u' or 'i' at a word boundary and try to match a long-form
        // type name (uint8..int64). If matched, emit the short form alias.
        if (ch == 117 || ch == 105) && sp_pos + 4 <= src_size {
            uint64 lprev_ok = 1
            if sp_pos > 0 {
                uint64 lpbp = source + sp_pos - 1
                uint64 lpc = 0
                unsafe { *(lpbp as uint8) -> lpc }
                if mig_is_word(lpc) != 0 { lprev_ok = 0 }
            }
            if lprev_ok != 0 {
                uint64 matched_long = 0
                uint64 short_form = 0
                uint64 match_len = 0
                // Try longest matches first to avoid prefix ambiguity
                if mig_text_eq(source, sp_pos, src_size, "uint64", 6) != 0 {
                    matched_long = 1; short_form = "u64"; match_len = 6
                }
                if matched_long == 0 && mig_text_eq(source, sp_pos, src_size, "uint32", 6) != 0 {
                    matched_long = 1; short_form = "u32"; match_len = 6
                }
                if matched_long == 0 && mig_text_eq(source, sp_pos, src_size, "uint16", 6) != 0 {
                    matched_long = 1; short_form = "u16"; match_len = 6
                }
                if matched_long == 0 && mig_text_eq(source, sp_pos, src_size, "int64", 5) != 0 {
                    matched_long = 1; short_form = "i64"; match_len = 5
                }
                if matched_long == 0 && mig_text_eq(source, sp_pos, src_size, "int32", 5) != 0 {
                    matched_long = 1; short_form = "i32"; match_len = 5
                }
                if matched_long == 0 && mig_text_eq(source, sp_pos, src_size, "int16", 5) != 0 {
                    matched_long = 1; short_form = "i16"; match_len = 5
                }
                if matched_long == 0 && mig_text_eq(source, sp_pos, src_size, "uint8", 5) != 0 {
                    matched_long = 1; short_form = "u8"; match_len = 5
                }
                if matched_long == 0 && mig_text_eq(source, sp_pos, src_size, "int8", 4) != 0 {
                    matched_long = 1; short_form = "i8"; match_len = 4
                }
                if matched_long != 0 {
                    // Verify the next char is NOT a word character (word boundary)
                    uint64 nafter = sp_pos + match_len
                    uint64 nafter_ok = 1
                    if nafter < src_size {
                        uint64 nap = source + nafter
                        uint64 nac = 0
                        unsafe { *(nap as uint8) -> nac }
                        if mig_is_word(nac) != 0 { nafter_ok = 0 }
                    }
                    if nafter_ok != 0 {
                        // Copy pre-match bytes
                        uint64 pre_len = sp_pos - last_copied
                        uint8[8] dp_bufm
                        uint64 dpm = dp_bufm
                        unsafe { *(dpm as uint64) = dp }
                        mig_append_bytes(out_buf_a, dpm, source, last_copied, pre_len)
                        // Emit short form
                        mig_append_str(out_buf_a, dpm, short_form)
                        unsafe { *(dpm as uint64) -> dp }
                        last_copied = sp_pos + match_len
                        sp_pos = sp_pos + match_len
                        applied = applied + 1
                        unsafe { *(matches_out as uint64) = applied }
                        continue
                    }
                }
            }
        }

        // Look for 'u' and try to match "unsafe" at a word boundary
        if ch == 117 && sp_pos + 6 <= src_size {
            // Word-boundary check: previous char must not be a word character
            uint64 prev_ok = 1
            if sp_pos > 0 {
                uint64 pbp = source + sp_pos - 1
                uint64 pc = 0
                unsafe { *(pbp as uint8) -> pc }
                if mig_is_word(pc) != 0 { prev_ok = 0 }
            }
            if prev_ok != 0 && mig_text_eq(source, sp_pos, src_size, "unsafe", 6) != 0 {
                // Next char after "unsafe" must not be a word character
                uint64 after = sp_pos + 6
                uint64 after_ok = 1
                if after < src_size {
                    uint64 abp = source + after
                    uint64 ac = 0
                    unsafe { *(abp as uint8) -> ac }
                    if mig_is_word(ac) != 0 { after_ok = 0 }
                }
                if after_ok != 0 {
                    // Try to parse an unsafe pointer-op block starting at sp_pos
                    uint64 mig_start = sp_pos
                    uint64 p = after
                    p = mig_skip_ws(source, p, src_size)
                    // Expect '{'
                    if p < src_size {
                        uint64 bp1 = source + p
                        uint64 c1 = 0
                        unsafe { *(bp1 as uint8) -> c1 }
                        if c1 == 123 {
                            p = p + 1
                            p = mig_skip_ws(source, p, src_size)
                            // Expect '*'
                            if p < src_size {
                                uint64 bp2 = source + p
                                uint64 c2 = 0
                                unsafe { *(bp2 as uint8) -> c2 }
                                if c2 == 42 {
                                    p = p + 1
                                    p = mig_skip_ws(source, p, src_size)
                                    // Expect '('
                                    if p < src_size {
                                        uint64 bp3 = source + p
                                        uint64 c3 = 0
                                        unsafe { *(bp3 as uint8) -> c3 }
                                        if c3 == 40 {
                                            p = p + 1
                                            uint64 expr_start = p
                                            // Find " as " at depth 0
                                            uint64 as_pos = mig_find_as(source, p, src_size)
                                            if as_pos != src_size {
                                                uint64 expr_end = as_pos
                                                // Trim trailing whitespace from EXPR
                                                while expr_end > expr_start {
                                                    uint64 ep = source + expr_end - 1
                                                    uint64 ec = 0
                                                    unsafe { *(ep as uint8) -> ec }
                                                    if ec != 32 && ec != 9 { break }
                                                    expr_end = expr_end - 1
                                                }
                                                p = as_pos + 4  // skip " as "
                                                p = mig_skip_ws(source, p, src_size)
                                                uint64 width = 0
                                                uint64 wp = 0 + 0
                                                // Actually allocate a local to capture the width
                                                uint8[8] width_buf
                                                uint64 wp_addr = width_buf
                                                p = mig_parse_type(source, p, src_size, wp_addr)
                                                unsafe { *(wp_addr as uint64) -> width }
                                                if width != 0 {
                                                    p = mig_skip_ws(source, p, src_size)
                                                    // Expect ')'
                                                    if p < src_size {
                                                        uint64 bp4 = source + p
                                                        uint64 c4 = 0
                                                        unsafe { *(bp4 as uint8) -> c4 }
                                                        if c4 == 41 {
                                                            p = p + 1
                                                            p = mig_skip_ws(source, p, src_size)
                                                            // Now either "-> DEST" or "= VAL"
                                                            uint64 is_load = 0
                                                            uint64 is_store = 0
                                                            if p + 2 <= src_size {
                                                                uint64 tp0 = source + p
                                                                uint64 tp1 = source + p + 1
                                                                uint64 t0 = 0
                                                                uint64 t1 = 0
                                                                unsafe { *(tp0 as uint8) -> t0 }
                                                                unsafe { *(tp1 as uint8) -> t1 }
                                                                if t0 == 45 && t1 == 62 {
                                                                    is_load = 1
                                                                    p = p + 2
                                                                }
                                                                if t0 == 61 && t1 != 61 {
                                                                    is_store = 1
                                                                    p = p + 1
                                                                }
                                                            }
                                                            if is_load != 0 || is_store != 0 {
                                                                p = mig_skip_ws(source, p, src_size)
                                                                uint64 rhs_start = p
                                                                // Scan until '}' at depth 0
                                                                uint64 depth = 0
                                                                while p < src_size {
                                                                    uint64 spb = source + p
                                                                    uint64 sc = 0
                                                                    unsafe { *(spb as uint8) -> sc }
                                                                    if sc == 40 { depth = depth + 1 }
                                                                    if sc == 41 {
                                                                        if depth > 0 { depth = depth - 1 }
                                                                    }
                                                                    if depth == 0 && sc == 125 { break }
                                                                    p = p + 1
                                                                }
                                                                if p < src_size {
                                                                    uint64 rhs_end = p
                                                                    // Trim trailing whitespace
                                                                    while rhs_end > rhs_start {
                                                                        uint64 rp2 = source + rhs_end - 1
                                                                        uint64 rc2 = 0
                                                                        unsafe { *(rp2 as uint8) -> rc2 }
                                                                        if rc2 != 32 && rc2 != 9 { break }
                                                                        rhs_end = rhs_end - 1
                                                                    }
                                                                    uint64 mig_end = p + 1  // past '}'

                                                                    // Copy pre-match bytes
                                                                    uint64 pre_len = mig_start - last_copied
                                                                    uint64 dpr = dp
                                                                    unsafe { *(matches_out as uint64) -> applied }
                                                                    uint8[8] dp_buf
                                                                    uint64 dp_addr = dp_buf
                                                                    unsafe { *(dp_addr as uint64) = dpr }
                                                                    mig_append_bytes(out_buf_a, dp_addr, source, last_copied, pre_len)
                                                                    // Emit the replacement
                                                                    if is_load != 0 {
                                                                        // dest = loadN(expr)
                                                                        mig_append_bytes(out_buf_a, dp_addr, source, rhs_start, rhs_end - rhs_start)
                                                                        mig_append_str(out_buf_a, dp_addr, " = load")
                                                                        mig_append_width(out_buf_a, dp_addr, width)
                                                                        mig_append_str(out_buf_a, dp_addr, "(")
                                                                        mig_append_bytes(out_buf_a, dp_addr, source, expr_start, expr_end - expr_start)
                                                                        mig_append_str(out_buf_a, dp_addr, ")")
                                                                    } else {
                                                                        // storeN(expr, val)
                                                                        mig_append_str(out_buf_a, dp_addr, "store")
                                                                        mig_append_width(out_buf_a, dp_addr, width)
                                                                        mig_append_str(out_buf_a, dp_addr, "(")
                                                                        mig_append_bytes(out_buf_a, dp_addr, source, expr_start, expr_end - expr_start)
                                                                        mig_append_str(out_buf_a, dp_addr, ", ")
                                                                        mig_append_bytes(out_buf_a, dp_addr, source, rhs_start, rhs_end - rhs_start)
                                                                        mig_append_str(out_buf_a, dp_addr, ")")
                                                                    }
                                                                    unsafe { *(dp_addr as uint64) -> dp }
                                                                    applied = applied + 1
                                                                    unsafe { *(matches_out as uint64) = applied }
                                                                    last_copied = mig_end
                                                                    sp_pos = mig_end
                                                                    continue
                                                                }
                                                            }
                                                        }
                                                    }
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
        sp_pos = sp_pos + 1
    }

    // Copy the tail
    uint64 tail_len = src_size - last_copied
    uint8[8] dp_buf2
    uint64 dp_addr2 = dp_buf2
    unsafe { *(dp_addr2 as uint64) = dp }
    mig_append_bytes(out_buf_a, dp_addr2, source, last_copied, tail_len)
    unsafe { *(dp_addr2 as uint64) -> dp }
    return dp
}

// Run the migration engine on `input_path`. If dry_run, print the rewritten
// source and match count to stdout. If not, write back to the file.
@export
fn run_migration(uint64 input_path, uint64 dry_run) {
    uint64 fd = file_open(input_path, 0)
    if fd > 0xFFFFFFFFFFFFF000 {
        write(2, "error: cannot open input file\n", 30)
        exit(1)
    }
    uint64 fsize = file_size(fd)
    uint64 src_buf = alloc(fsize + 1)
    file_read(fd, src_buf, fsize)
    file_close(fd)
    uint64 tp = src_buf + fsize
    uint8 z = 0
    unsafe { *(tp as uint8) = z }

    // Worst-case output: every unsafe{} block becomes a slightly longer
    // form (never more than 2x), so 4x is a safe upper bound.
    uint64 out_buf_m = alloc(fsize * 4 + 1024)
    uint64 matches = 0
    uint8[8] mbuf
    uint64 m_addr = mbuf
    unsafe { *(m_addr as uint64) = 0 }

    uint64 new_size = mig_scan_and_rewrite(src_buf, fsize, out_buf_m, m_addr)
    unsafe { *(m_addr as uint64) -> matches }

    if dry_run != 0 {
        // Print matches count and the first 1K of the rewritten file
        write(1, "migration: ", 11)
        uint8[32] nb
        uint64 nl = fmt_uint(nb, matches)
        write(1, nb, nl)
        write(1, " migration site(s) rewritten\n", 34)
        write(1, "--- dry-run output preview (first 512 bytes) ---\n", 49)
        uint64 preview = new_size
        if preview > 512 { preview = 512 }
        write(1, out_buf_m, preview)
        write(1, "\n", 1)
        return
    }

    if matches == 0 {
        write(1, "migration: no sites found\n", 26)
        return
    }

    // Write rewritten source back to the same file
    uint64 ofd = file_open(input_path, 1)
    if ofd > 0xFFFFFFFFFFFFF000 {
        write(2, "error: cannot open output file for writing\n", 44)
        exit(1)
    }
    file_write(ofd, out_buf_m, new_size)
    file_close(ofd)

    write(1, "migration: ", 11)
    uint8[32] nb2
    uint64 nl2 = fmt_uint(nb2, matches)
    write(1, nb2, nl2)
    write(1, " migration site(s) rewritten in ", 32)
    uint64 pl = 0
    uint64 pp = input_path
    uint64 pc = 0
    unsafe { *(pp as uint8) -> pc }
    while pc != 0 {
        pl = pl + 1
        pp = input_path + pl
        unsafe { *(pp as uint8) -> pc }
    }
    write(1, input_path, pl)
    write(1, "\n", 1)
}
// MLRift — built on KernRift — Runtime helpers

fn fmt_uint(uint64 buf, uint64 val) -> uint64 {
    if val == 0 {
        uint8 zero = 48
        unsafe { *(buf as uint8) = zero }
        return 1
    }
    uint64 len = 0
    uint64 tmp = val
    while tmp > 0 {
        len = len + 1
        tmp = tmp / 10
    }
    uint64 i = len
    tmp = val
    while i > 0 {
        i = i - 1
        uint64 digit = tmp - tmp / 10 * 10
        uint64 ch = digit + 48
        uint64 p = buf + i
        uint8 cb = ch
        unsafe { *(p as uint8) = cb }
        tmp = tmp / 10
    }
    return len
}

// Write "true" or "false" to buf, return byte length.
@export
fn fmt_bool(uint64 buf, uint64 val) -> uint64 {
    if val != 0 {
        uint8 t = 116
        uint8 r = 114
        uint8 u = 117
        uint8 e = 101
        uint64 p0 = buf
        unsafe { *(p0 as uint8) = t }
        uint64 p1 = buf + 1
        unsafe { *(p1 as uint8) = r }
        uint64 p2 = buf + 2
        unsafe { *(p2 as uint8) = u }
        uint64 p3 = buf + 3
        unsafe { *(p3 as uint8) = e }
        return 4
    }
    uint8 f = 102
    uint8 a = 97
    uint8 l = 108
    uint8 s = 115
    uint8 e = 101
    uint64 p0 = buf
    unsafe { *(p0 as uint8) = f }
    uint64 p1 = buf + 1
    unsafe { *(p1 as uint8) = a }
    uint64 p2 = buf + 2
    unsafe { *(p2 as uint8) = l }
    uint64 p3 = buf + 3
    unsafe { *(p3 as uint8) = s }
    uint64 p4 = buf + 4
    unsafe { *(p4 as uint8) = e }
    return 5
}

// Format an f64 as "[sign][int].[6 frac]" into buf, return byte length.
// Special cases: |x| >= 1e18 -> "big", negative zero handled via sign check.
@export
fn fmt_f64(uint64 buf, f64 val) -> uint64 {
    uint64 len = 0

    // Check sign by comparing val < 0.0
    f64 zero_f = 0.0
    if val < zero_f {
        uint8 m = 45
        uint64 ps = buf
        unsafe { *(ps as uint8) = m }
        len = 1
        val = zero_f - val
    }

    // Check for very large values
    f64 big = 1000000000000000000.0
    if val >= big {
        uint8 b = 98
        uint8 i = 105
        uint8 g = 103
        uint64 pb = buf + len
        unsafe { *(pb as uint8) = b }
        uint64 pi = buf + len + 1
        unsafe { *(pi as uint8) = i }
        uint64 pg = buf + len + 2
        unsafe { *(pg as uint8) = g }
        return len + 3
    }

    // Integer part: truncate via f64_to_int
    uint64 int_part = f64_to_int(val)
    f64 int_f = int_to_f64(int_part)
    f64 frac = val - int_f
    uint64 int_len = fmt_uint(buf + len, int_part)
    len = len + int_len

    // Decimal point
    uint8 dot = 46
    uint64 pd = buf + len
    unsafe { *(pd as uint8) = dot }
    len = len + 1

    // 6 fractional digits
    f64 scale = 1000000.0
    f64 frac_scaled = frac * scale
    uint64 frac_int = f64_to_int(frac_scaled)

    // Count digits in frac_int to determine padding needed
    uint64 digits = 0
    uint64 tmp_c = frac_int
    if tmp_c == 0 {
        digits = 1
    }
    while tmp_c > 0 {
        digits = digits + 1
        tmp_c = tmp_c / 10
    }
    uint64 pad = 0
    if digits < 6 {
        pad = 6 - digits
    }
    uint64 pi2 = 0
    while pi2 < pad {
        uint8 zero = 48
        uint64 pp = buf + len + pi2
        unsafe { *(pp as uint8) = zero }
        pi2 = pi2 + 1
    }
    uint64 fl = fmt_uint(buf + len + pad, frac_int)
    len = len + pad + fl
    return len
}
// KernRift auto-formatter — character-level source reformatter
// Usage: krc fmt <file.kr>
// Outputs formatted source to stdout.

fn fmt_file(uint64 path) {
    uint64 fd = file_open(path, 0)
    if fd >= 0xFFFFFFFF {
        write(2, "fmt: cannot open '", 18)
        write(2, path, str_len(path))
        write(2, "'\n", 2)
        exit(1)
    }
    uint64 size = file_size(fd)
    uint64 src = alloc(size + 1)
    file_read(fd, src, size)
    file_close(fd)

    // Null-terminate
    uint64 ep = src + size
    uint8 z = 0
    unsafe { *(ep as uint8) = z }

    // Output buffer (generous: 2x input)
    uint64 out_cap = size * 2 + 1024
    uint64 out = alloc(out_cap)
    uint64 op = 0

    uint64 depth = 0
    uint64 at_line_start = 1
    uint64 in_string = 0
    uint64 in_line_comment = 0
    uint64 prev_nl = 1
    uint64 line_len = 0
    uint64 i = 0

    while i < size {
        uint64 cp = src + i
        uint64 ch = 0
        unsafe { *(cp as uint8) -> ch }

        // --- Inside line comment: pass through until newline ---
        if in_line_comment != 0 {
            if ch == 10 {
                in_line_comment = 0
                // Emit newline
                uint64 wp = out + op
                uint8 nl = 10
                unsafe { *(wp as uint8) = nl }
                op = op + 1
                at_line_start = 1
                prev_nl = 1
                line_len = 0
            } else {
                uint64 wp = out + op
                uint8 cb = ch
                unsafe { *(wp as uint8) = cb }
                op = op + 1
            }
            i = i + 1
            continue
        }

        // --- Inside string: pass through, handle escape sequences ---
        if in_string != 0 {
            uint64 wp = out + op
            uint8 cb = ch
            unsafe { *(wp as uint8) = cb }
            op = op + 1
            if ch == 92 {
                // Backslash: copy next char too (escape)
                i = i + 1
                if i < size {
                    uint64 np = src + i
                    uint64 nc = 0
                    unsafe { *(np as uint8) -> nc }
                    uint64 wp2 = out + op
                    uint8 nb = nc
                    unsafe { *(wp2 as uint8) = nb }
                    op = op + 1
                }
            } else if ch == 34 {
                in_string = 0
            }
            i = i + 1
            continue
        }

        // --- Check for line comment start ---
        if ch == 47 && i + 1 < size {
            uint64 np = src + i + 1
            uint64 nc = 0
            unsafe { *(np as uint8) -> nc }
            if nc == 47 {
                // Emit indent if at line start
                if at_line_start != 0 {
                    uint64 sp = 0
                    while sp < depth * 4 {
                        uint64 wp = out + op
                        uint8 sb = 32
                        unsafe { *(wp as uint8) = sb }
                        op = op + 1
                        sp = sp + 1
                    }
                    at_line_start = 0
                }
                in_line_comment = 1
                uint64 wp = out + op
                uint8 cb = 47
                unsafe { *(wp as uint8) = cb }
                op = op + 1
                i = i + 1
                uint64 wp2 = out + op
                unsafe { *(wp2 as uint8) = cb }
                op = op + 1
                i = i + 1
                continue
            }
        }

        // --- Newline ---
        if ch == 10 {
            // Strip trailing whitespace from output
            while op > 0 {
                uint64 pp = out + op - 1
                uint64 pc = 0
                unsafe { *(pp as uint8) -> pc }
                if pc == 32 || pc == 9 {
                    op = op - 1
                } else {
                    break
                }
            }
            uint64 wp = out + op
            uint8 nl = 10
            unsafe { *(wp as uint8) = nl }
            op = op + 1
            at_line_start = 1
            prev_nl = 1
            line_len = 0
            i = i + 1
            continue
        }

        // --- Skip whitespace at line start (we re-indent) ---
        if at_line_start != 0 && (ch == 32 || ch == 9) {
            i = i + 1
            continue
        }

        // --- At line start: check for } to decrement before indent ---
        if at_line_start != 0 {
            // Peek: if first non-space char is }, decrement depth first
            if ch == 125 {
                if depth > 0 { depth = depth - 1 }
            }

            // Check if this line starts fn/struct/enum — insert blank line
            if prev_nl != 0 && op > 1 {
                uint64 is_decl = 0
                if ch == 102 && i + 1 < size {
                    uint64 np = src + i + 1
                    uint64 nc = 0
                    unsafe { *(np as uint8) -> nc }
                    if nc == 110 { is_decl = 1 }
                }
                if ch == 115 && i + 5 < size {
                    uint64 np = src + i + 1
                    uint64 nc = 0
                    unsafe { *(np as uint8) -> nc }
                    if nc == 116 { is_decl = 1 }
                }
                if ch == 101 && i + 3 < size {
                    uint64 np = src + i + 1
                    uint64 nc = 0
                    unsafe { *(np as uint8) -> nc }
                    if nc == 110 { is_decl = 1 }
                }
                // Only at depth 0 (top-level declarations)
                if is_decl != 0 && depth == 0 {
                    // Check if previous line was already blank
                    uint64 need_blank = 1
                    if op >= 2 {
                        uint64 p1 = out + op - 1
                        uint64 p2 = out + op - 2
                        uint64 c1 = 0; uint64 c2 = 0
                        unsafe { *(p1 as uint8) -> c1 }
                        unsafe { *(p2 as uint8) -> c2 }
                        if c1 == 10 && c2 == 10 { need_blank = 0 }
                    }
                    if need_blank != 0 {
                        uint64 wp = out + op
                        uint8 nl = 10
                        unsafe { *(wp as uint8) = nl }
                        op = op + 1
                    }
                }
            }

            // Emit indent
            uint64 sp = 0
            while sp < depth * 4 {
                uint64 wp = out + op
                uint8 sb = 32
                unsafe { *(wp as uint8) = sb }
                op = op + 1
                sp = sp + 1
            }
            at_line_start = 0
            prev_nl = 0
        }

        // --- String start ---
        if ch == 34 {
            in_string = 1
        }

        // --- Emit char ---
        uint64 wp = out + op
        uint8 cb = ch
        unsafe { *(wp as uint8) = cb }
        op = op + 1

        // --- Track brace depth (mid-line only) ---
        if ch == 123 {
            depth = depth + 1
        }
        if ch == 125 && line_len > 0 {
            if depth > 0 { depth = depth - 1 }
        }
        line_len = line_len + 1

        i = i + 1
    }

    // Ensure file ends with exactly one newline
    // Strip trailing newlines
    while op > 0 {
        uint64 pp = out + op - 1
        uint64 pc = 0
        unsafe { *(pp as uint8) -> pc }
        if pc == 10 {
            op = op - 1
        } else {
            break
        }
    }
    // Add single newline
    uint64 wp = out + op
    uint8 nl = 10
    unsafe { *(wp as uint8) = nl }
    op = op + 1

    // Write to stdout
    write(1, out, op)
}
import "lexer.mlr"
import "ast.mlr"
import "parser.mlr"
import "codegen.mlr"
import "codegen_aarch64.mlr"
import "format_macho.mlr"
import "format_pe.mlr"
import "format_archive.mlr"
import "format_android.mlr"
import "bcj.mlr"
import "analysis.mlr"
import "inliner.mlr"
import "living.mlr"
import "runtime.mlr"
import "formatter.mlr"
// formatter.kr is included via cat command, not import

// MLRift — built on KernRift — main

// Windows command line parser: called from main() when cli_argc == 0xFFFFFFFF
// cli_argv contains the raw GetCommandLineA pointer; parse it into proper argc/argv
fn win_init_args() {
    uint64 cmdline = cli_argv
    // Allocate argv buffer (up to 64 pointers = 512 bytes)
    uint64 argv_buf = alloc(512)
    uint64 argc = 0
    uint64 pos = cmdline
    uint64 ch = 0
    unsafe { *(pos as uint8) -> ch }
    while ch != 0 {
        // Skip spaces
        while ch == 32 {
            pos = pos + 1
            unsafe { *(pos as uint8) -> ch }
        }
        if ch == 0 { break }
        // Store start of this arg
        uint64 slot = argv_buf + argc * 8
        unsafe { *(slot as uint64) = pos }
        argc = argc + 1
        // Advance to next space or null
        while ch != 0 && ch != 32 {
            pos = pos + 1
            unsafe { *(pos as uint8) -> ch }
        }
        // Null-terminate this arg (replace space with 0)
        if ch == 32 {
            uint8 z = 0
            unsafe { *(pos as uint8) = z }
            pos = pos + 1
            unsafe { *(pos as uint8) -> ch }
        }
    }
    cli_argc = argc
    cli_argv = argv_buf
}

fn str_len(uint64 s) -> uint64 {
    uint64 i = 0
    uint64 p = s + i
    uint64 c = 0
    unsafe { *(p as uint8) -> c }
    while c != 0 {
        i = i + 1
        p = s + i
        unsafe { *(p as uint8) -> c }
    }
    return i
}

fn str_starts_with(uint64 s, uint64 prefix, uint64 plen) -> uint64 {
    uint64 i = 0
    while i < plen {
        uint64 pa = s + i
        uint64 pb = prefix + i
        uint64 ca = 0
        uint64 cb = 0
        unsafe { *(pa as uint8) -> ca }
        unsafe { *(pb as uint8) -> cb }
        if ca != cb { return 0 }
        i = i + 1
    }
    return 1
}

fn str_eq_full(uint64 a, uint64 b) -> uint64 {
    uint64 la = str_len(a)
    uint64 lb = str_len(b)
    if la != lb { return 0 }
    return str_starts_with(a, b, la)
}

// Import system state
static uint64 import_buf = 0
static uint64 import_buf_len = 0
static uint64 import_buf_cap = 0
static uint64 import_seen = 0
static uint64 import_seen_count = 0
static uint64 srcmap_table = 0
static uint64 srcmap_count = 0

fn import_init() {
    import_buf_cap = 4194304
    import_buf = alloc(import_buf_cap)
    import_buf_len = 0
    import_seen = alloc(16384)
    import_seen_count = 0
    srcmap_table = alloc(1024 * 16)
    srcmap_count = 0
}

fn import_is_seen(uint64 path) -> uint64 {
    uint64 plen = str_len(path)
    uint64 i = 0
    while i < import_seen_count {
        uint64 entry = import_seen + i * 256
        if str_starts_with(entry, path, plen) != 0 {
            uint64 elen = str_len(entry)
            if elen == plen { return 1 }
        }
        i = i + 1
    }
    return 0
}

fn import_mark_seen(uint64 path) {
    uint64 plen = str_len(path)
    uint64 entry = import_seen + import_seen_count * 256
    uint64 i = 0
    while i < plen && i < 255 {
        uint64 sp = path + i
        uint64 dp = entry + i
        uint64 ch = 0
        unsafe { *(sp as uint8) -> ch }
        uint8 cb = ch
        unsafe { *(dp as uint8) = cb }
        i = i + 1
    }
    uint64 tp = entry + i
    uint8 z = 0
    unsafe { *(tp as uint8) = z }
    import_seen_count = import_seen_count + 1
}

fn import_append(uint64 src, uint64 len, uint64 file_path) {
    uint64 sm_entry = srcmap_table + srcmap_count * 16
    uint64 sm_off = import_buf_len
    unsafe { *(sm_entry as uint64) = sm_off }
    uint64 sm_fp = sm_entry + 8
    unsafe { *(sm_fp as uint64) = file_path }
    srcmap_count = srcmap_count + 1
    uint64 i = 0
    while i < len {
        uint64 sp = src + i
        uint64 dp = import_buf + import_buf_len
        uint64 b = 0
        unsafe { *(sp as uint8) -> b }
        uint8 bb = b
        unsafe { *(dp as uint8) = bb }
        import_buf_len = import_buf_len + 1
        i = i + 1
    }
    // Add newline separator
    uint64 np = import_buf + import_buf_len
    uint8 nl = 10
    unsafe { *(np as uint8) = nl }
    import_buf_len = import_buf_len + 1
}

@export
fn srcmap_file(uint64 byte_offset) -> uint64 {
    uint64 file_path = 0
    uint64 i = 0
    while i < srcmap_count {
        uint64 entry = srcmap_table + i * 16
        uint64 entry_off = 0
        unsafe { *(entry as uint64) -> entry_off }
        if entry_off > byte_offset { break }
        uint64 fp_ptr = entry + 8
        unsafe { *(fp_ptr as uint64) -> file_path }
        i = i + 1
    }
    return file_path
}

@export
fn srcmap_line(uint64 byte_offset) -> uint64 {
    uint64 file_start = 0
    uint64 i = 0
    while i < srcmap_count {
        uint64 entry = srcmap_table + i * 16
        uint64 entry_off = 0
        unsafe { *(entry as uint64) -> entry_off }
        if entry_off > byte_offset { break }
        file_start = entry_off
        i = i + 1
    }
    uint64 line = 1
    uint64 p = file_start
    while p < byte_offset {
        uint64 cp = import_buf + p
        uint64 ch = 0
        unsafe { *(cp as uint8) -> ch }
        if ch == 10 { line = line + 1 }
        p = p + 1
    }
    return line
}

@export
fn report_error_at(uint64 tok_idx, uint64 msg) {
    uint64 tok_start = tok_text_start(tok_idx)
    uint64 file_path = srcmap_file(tok_start)
    if file_path != 0 {
        write(2, file_path, str_len(file_path))
    }
    write(2, ":", 1)
    uint8[24] lbuf
    uint64 llen = fmt_uint(lbuf, srcmap_line(tok_start))
    write(2, lbuf, llen)
    write(2, ": error: ", 9)
    write(2, msg, str_len(msg))
    write(2, "\n", 1)
}

@export
fn report_warn_at(uint64 tok_idx, uint64 msg) {
    uint64 tok_start = tok_text_start(tok_idx)
    uint64 file_path = srcmap_file(tok_start)
    if file_path != 0 {
        write(2, file_path, str_len(file_path))
    }
    write(2, ":", 1)
    uint8[24] lbuf
    uint64 llen = fmt_uint(lbuf, srcmap_line(tok_start))
    write(2, lbuf, llen)
    write(2, ": warning: ", 11)
    write(2, msg, str_len(msg))
    write(2, "\n", 1)
    // Keep the end-of-compile summary accurate — same counter used
    // by diag_emit so 'N error(s), M warning(s)' reflects every warning.
    diag_warn_count = diag_warn_count + 1
}

fn import_dir_of(uint64 path) -> uint64 {
    // Find last '/' in path, return length including the slash
    uint64 len = str_len(path)
    uint64 last_slash = 0
    uint64 i = 0
    while i < len {
        uint64 pp = path + i
        uint64 ch = 0
        unsafe { *(pp as uint8) -> ch }
        if ch == 47 { last_slash = i + 1 }
        i = i + 1
    }
    return last_slash
}

// When --target=amdgpu-native is on, route std/hip.mlr imports to the
// KFD-backed shim std/hip_kfd.mlr so launchers run with zero ROCm
// linkage. Match on a "hip.mlr" suffix; leave everything else alone.
fn _maybe_redirect_hip_to_kfd(uint64 path) -> uint64 {
    if target_amdgpu_native == 0 { return path }
    uint64 plen = str_len(path)
    if plen < 7 { return path }                      // "hip.mlr" is 7 chars
    // Already redirected? "hip_kfd.mlr" ends in "kfd.mlr" — leave alone.
    if plen >= 11 {
        uint64 t11 = path + plen - 11
        uint64 c = 0; unsafe { *(t11 as uint8) -> c }
        if c == 104 {                                  // 'h'
            uint64 c1 = 0; unsafe { *((t11 + 1) as uint8) -> c1 }
            uint64 c2 = 0; unsafe { *((t11 + 2) as uint8) -> c2 }
            uint64 c3 = 0; unsafe { *((t11 + 3) as uint8) -> c3 }
            if c1 == 105 && c2 == 112 && c3 == 95 {    // "hip_"
                return path
            }
        }
    }
    uint64 t = path + plen - 7
    uint64 b0 = 0; unsafe { *(t as uint8) -> b0 }
    uint64 b1 = 0; unsafe { *((t + 1) as uint8) -> b1 }
    uint64 b2 = 0; unsafe { *((t + 2) as uint8) -> b2 }
    uint64 b3 = 0; unsafe { *((t + 3) as uint8) -> b3 }
    uint64 b4 = 0; unsafe { *((t + 4) as uint8) -> b4 }
    uint64 b5 = 0; unsafe { *((t + 5) as uint8) -> b5 }
    uint64 b6 = 0; unsafe { *((t + 6) as uint8) -> b6 }
    // "hip.mlr" = 104 105 112 46 109 108 114
    // (Don't auto-redirect .kr files — they may live in sibling
    // projects without a hip_kfd.mlr alongside, and a redirect there
    // would loudly fail rather than silently no-op.  Users who want
    // amdgpu-native should import MLRift/std/hip.mlr explicitly.)
    if b0 != 104 { return path }
    if b1 != 105 { return path }
    if b2 != 112 { return path }
    if b3 != 46 { return path }
    if b4 != 109 { return path }
    if b5 != 108 { return path }
    if b6 != 114 { return path }
    uint64 prefix_len = plen - 7
    // Build redirected path: <dir>/hip_kfd.mlr.  prefix_len was set
    // to plen-7 (.mlr match) or plen-6 (.kr match) above.
    uint64 redirected = alloc(prefix_len + 11 + 1)    // "hip_kfd.mlr" + NUL
    memcpy(redirected, path, prefix_len)
    uint64 suffix = "hip_kfd.mlr"
    memcpy(redirected + prefix_len, suffix, 11)
    uint64 tp = redirected + prefix_len + 11
    uint8 z = 0
    unsafe { *(tp as uint8) = z }
    return redirected
}

fn import_resolve(uint64 base_path, uint64 name, uint64 name_len) -> uint64 {
    uint64 dir_len = import_dir_of(base_path)
    uint64 result = alloc(dir_len + name_len + 1)
    uint64 i = 0
    while i < dir_len {
        uint64 sp = base_path + i
        uint64 dp = result + i
        uint64 ch = 0
        unsafe { *(sp as uint8) -> ch }
        uint8 cb = ch
        unsafe { *(dp as uint8) = cb }
        i = i + 1
    }
    uint64 j = 0
    while j < name_len {
        uint64 sp = name + j
        uint64 dp = result + dir_len + j
        uint64 ch = 0
        unsafe { *(sp as uint8) -> ch }
        uint8 cb = ch
        unsafe { *(dp as uint8) = cb }
        j = j + 1
    }
    uint64 tp = result + dir_len + name_len
    uint8 z = 0
    unsafe { *(tp as uint8) = z }
    return _maybe_redirect_hip_to_kfd(result)
}

fn import_check_import_line(uint64 buf, uint64 size, uint64 pos) -> uint64 {
    // Check if buf[pos..] starts with: import "filename"
    // Returns 0 if not import, or the position just past the opening quote
    if pos + 8 >= size { return 0 }
    uint64 bp = buf + pos
    uint64 c0 = 0; uint64 c1 = 0; uint64 c2 = 0; uint64 c3 = 0; uint64 c4 = 0; uint64 c5 = 0
    unsafe { *(bp as uint8) -> c0 }
    uint64 bp1 = bp + 1; unsafe { *(bp1 as uint8) -> c1 }
    uint64 bp2 = bp + 2; unsafe { *(bp2 as uint8) -> c2 }
    uint64 bp3 = bp + 3; unsafe { *(bp3 as uint8) -> c3 }
    uint64 bp4 = bp + 4; unsafe { *(bp4 as uint8) -> c4 }
    uint64 bp5 = bp + 5; unsafe { *(bp5 as uint8) -> c5 }
    // "import" = 105 109 112 111 114 116
    if c0 != 105 || c1 != 109 || c2 != 112 || c3 != 111 || c4 != 114 || c5 != 116 { return 0 }
    // Skip whitespace after "import"
    uint64 p = pos + 6
    uint64 ch = 0
    uint64 pp = buf + p
    if p < size { unsafe { *(pp as uint8) -> ch } }
    while p < size && (ch == 32 || ch == 9) {
        p = p + 1
        pp = buf + p
        if p < size { unsafe { *(pp as uint8) -> ch } }
    }
    // Expect opening quote
    if ch != 34 { return 0 }
    p = p + 1
    return p
}

// Stdlib search paths for imports not found relative to source file
static uint64 import_search_paths = 0
static uint64 import_search_count = 0

// Stub for bootstrap: overridden by get_module_path built-in in new compiler
fn get_module_path(uint64 buf, uint64 size) -> uint64 { return 0 }

// Stub for bootstrap: overridden by exec_process built-in in new compiler
fn exec_process(uint64 path) { exit(1) }

fn import_read_home() -> uint64 {
    // Read HOME from /proc/self/environ (Linux-specific)
    uint64 fd = file_open("/proc/self/environ", 0)
    if fd >= 0xFFFFFFFF { return 0 }
    uint64 buf = alloc(4096)
    file_read(fd, buf, 4096)
    file_close(fd)
    // environ is null-separated: VAR=VALUE\0VAR=VALUE\0...
    uint64 pos = 0
    while pos < 4096 {
        uint64 p = buf + pos
        uint64 ch = 0
        unsafe { *(p as uint8) -> ch }
        if ch == 0 { break }
        // Check for "HOME="
        if ch == 72 {
            uint64 p1 = p + 1; uint64 c1 = 0; unsafe { *(p1 as uint8) -> c1 }
            uint64 p2 = p + 2; uint64 c2 = 0; unsafe { *(p2 as uint8) -> c2 }
            uint64 p3 = p + 3; uint64 c3 = 0; unsafe { *(p3 as uint8) -> c3 }
            uint64 p4 = p + 4; uint64 c4 = 0; unsafe { *(p4 as uint8) -> c4 }
            if c1 == 79 && c2 == 77 && c3 == 69 && c4 == 61 {
                // Found HOME=, copy value to new buffer
                uint64 home_ptr = p + 5
                uint64 home_len = str_len(home_ptr)
                uint64 home_copy = alloc(home_len + 1)
                memcpy(home_copy, home_ptr, home_len)
                uint64 htp = home_copy + home_len
                uint8 hz = 0
                unsafe { *(htp as uint8) = hz }
                return home_copy
            }
        }
        // Skip to next null
        while pos < 4096 {
            p = buf + pos
            unsafe { *(p as uint8) -> ch }
            if ch == 0 { pos = pos + 1; break }
            pos = pos + 1
        }
    }
    return 0
}

fn import_init_search_paths() {
    if import_search_paths != 0 { return }
    import_search_paths = alloc(2048)
    import_search_count = 0

    uint64 host_os = get_target_os()
    if host_os == 2 {
        // Windows: look relative to exe location
        // Get exe path via GetModuleFileNameA
        uint64 exe_buf = alloc(512)
        uint64 exe_len = get_module_path(exe_buf, 512)
        if exe_len > 0 {
            // Strip filename: walk backwards to last backslash
            uint64 dir_len = exe_len
            while dir_len > 0 {
                dir_len = dir_len - 1
                uint64 cp = exe_buf + dir_len
                uint64 ch = 0
                unsafe { *(cp as uint8) -> ch }
                if ch == 92 { dir_len = dir_len + 1; break }
            }
            // Try <exe_dir>..\std\ (install.ps1 puts std next to bin)
            uint64 up_std = alloc(dir_len + 8)
            memcpy(up_std, exe_buf, dir_len)
            uint64 suffix = "..\\std\\"
            memcpy(up_std + dir_len, suffix, 7)
            uint8 z = 0
            uint64 tp = up_std + dir_len + 7
            unsafe { *(tp as uint8) = z }
            import_add_search_path(up_std)
            // Also try <exe_dir>std\ (alternative layout)
            uint64 dir_std = alloc(dir_len + 5)
            memcpy(dir_std, exe_buf, dir_len)
            uint64 suffix2 = "std\\"
            memcpy(dir_std + dir_len, suffix2, 4)
            uint64 tp2 = dir_std + dir_len + 4
            unsafe { *(tp2 as uint8) = z }
            import_add_search_path(dir_std)
        }
    } else {
        // Linux/macOS: system paths
        import_add_search_path("/usr/local/share/kernrift/")
        import_add_search_path("/usr/share/kernrift/")
        // Add user path: $HOME/.local/share/kernrift/
        uint64 home = import_read_home()
        if home != 0 {
            uint64 hlen = str_len(home)
            uint64 suffix = "/.local/share/kernrift/"
            uint64 slen = 23
            uint64 full = alloc(hlen + slen + 1)
            memcpy(full, home, hlen)
            memcpy(full + hlen, suffix, slen)
            uint8 z = 0
            uint64 tp = full + hlen + slen
            unsafe { *(tp as uint8) = z }
            import_add_search_path(full)
        }
    }
}

fn import_add_search_path(uint64 path) {
    uint64 plen = str_len(path)
    uint64 entry = import_search_paths + import_search_count * 256
    memcpy(entry, path, plen)
    uint64 tp = entry + plen
    uint8 z = 0
    unsafe { *(tp as uint8) = z }
    import_search_count = import_search_count + 1
}

fn import_resolve_stdlib(uint64 import_path) -> uint64 {
    import_init_search_paths()
    uint64 plen = str_len(import_path)
    uint64 i = 0
    while i < import_search_count {
        uint64 base = import_search_paths + i * 256
        uint64 blen = str_len(base)
        uint64 full = alloc(blen + plen + 1)
        memcpy(full, base, blen)
        memcpy(full + blen, import_path, plen)
        uint64 tp = full + blen + plen
        uint8 z = 0
        unsafe { *(tp as uint8) = z }
        uint64 fd = file_open(full, 0)
        if fd < 0xFFFFFFFF {
            file_close(fd)
            return full
        }
        i = i + 1
    }
    return 0
}

fn import_check_file(uint64 path) {
    uint64 fd = file_open(path, 0)
    if fd >= 0xFFFFFFFF {
        write(2, "error: cannot open '", 20)
        write(2, path, str_len(path))
        write(2, "': file not found\n", 18)
        exit(1)
    }
    file_close(fd)
}

fn import_process(uint64 file_path) {
    if import_is_seen(file_path) != 0 { return }
    import_mark_seen(file_path)

    uint64 fd = file_open(file_path, 0)
    // If not found, try ~/.local/share/kernrift/ as fallback
    if fd >= 0xFFFFFFFF {
        uint64 fallback = import_resolve_stdlib(file_path)
        if fallback != 0 {
            fd = file_open(fallback, 0)
        }
    }
    if fd >= 0xFFFFFFFF {
        uint64 msg = "error: cannot open import: "
        write(2, msg, 27)
        write(2, file_path, str_len(file_path))
        write(2, "\n", 1)
        // Don't exit — let compilation continue with what we have
        // This allows the parser to report the actual error
        return
    }
    uint64 size = file_size(fd)
    uint64 tmp = alloc(size + 1)
    file_read(fd, tmp, size)
    file_close(fd)

    // Scan for import lines at the beginning
    uint64 pos = 0
    while pos < size {
        // Skip whitespace/newlines and // line comments so imports can live
        // after header comments. Block comments (/* */) are not supported.
        uint64 skipped = 1
        while skipped != 0 {
            skipped = 0
            uint64 ch = 0
            uint64 pp = tmp + pos
            if pos < size { unsafe { *(pp as uint8) -> ch } }
            while pos < size && (ch == 32 || ch == 9 || ch == 13 || ch == 10) {
                pos = pos + 1
                pp = tmp + pos
                if pos < size { unsafe { *(pp as uint8) -> ch } }
                skipped = 1
            }
            // Line comment // — consume until newline
            if pos + 1 < size {
                uint64 cp0 = tmp + pos
                uint64 cp1 = tmp + pos + 1
                uint64 cc0 = 0
                uint64 cc1 = 0
                unsafe { *(cp0 as uint8) -> cc0 }
                unsafe { *(cp1 as uint8) -> cc1 }
                if cc0 == 47 && cc1 == 47 {
                    pos = pos + 2
                    uint64 lc = 0
                    uint64 lcp = tmp + pos
                    if pos < size { unsafe { *(lcp as uint8) -> lc } }
                    while pos < size && lc != 10 {
                        pos = pos + 1
                        lcp = tmp + pos
                        if pos < size { unsafe { *(lcp as uint8) -> lc } }
                    }
                    skipped = 1
                }
            }
        }
        if pos >= size { break }

        // Check if this line starts with "import"
        uint64 name_start = import_check_import_line(tmp, size, pos)
        if name_start != 0 {
            // Extract filename between quotes
            uint64 ns = name_start
            uint64 ne = ns
            uint64 qch = 0
            uint64 qp = tmp + ne
            if ne < size { unsafe { *(qp as uint8) -> qch } }
            while ne < size && qch != 34 {
                ne = ne + 1
                qp = tmp + ne
                if ne < size { unsafe { *(qp as uint8) -> qch } }
            }
            uint64 name_len = ne - ns
            uint64 name_ptr = tmp + ns
            // Resolve full path relative to source file
            uint64 full_path = import_resolve(file_path, name_ptr, name_len)
            // Check if resolved path exists
            uint64 check_fd = file_open(full_path, 0)
            if check_fd < 0xFFFFFFFF {
                file_close(check_fd)
            } else {
                // Not found locally — try stdlib search paths
                // Build a null-terminated copy of the import name
                uint64 name_copy = alloc(name_len + 1)
                memcpy(name_copy, name_ptr, name_len)
                uint64 ntp = name_copy + name_len
                uint8 nz = 0
                unsafe { *(ntp as uint8) = nz }
                uint64 stdlib_path = import_resolve_stdlib(name_copy)
                if stdlib_path != 0 { full_path = _maybe_redirect_hip_to_kfd(stdlib_path) }
            }
            // Recurse
            import_process(full_path)
            // Skip past closing quote and rest of line
            pos = ne + 1
        }
        if name_start == 0 {
            // Not an import — stop scanning for imports (only imports at top of file)
            break
        }
    }

    // Append entire file content (including import lines — parser ignores them)
    import_append(tmp, size, file_path)
}

fn hex_nibble(uint64 v) -> uint64 {
    if v < 10 { return v + 48 }
    return v + 87
}

fn write_hex8(uint64 fd, uint64 val) {
    uint8 h = hex_nibble((val >> 4) & 0xF)
    uint8 l = hex_nibble(val & 0xF)
    uint8[2] hb
    unsafe { *(hb as uint8) = h }
    uint64 p1 = hb + 1
    unsafe { *(p1 as uint8) = l }
    write(fd, hb, 2)
}

fn write_hex32(uint64 fd, uint64 val) {
    write_hex8(fd, (val >> 24) & 0xFF)
    write_hex8(fd, (val >> 16) & 0xFF)
    write_hex8(fd, (val >> 8) & 0xFF)
    write_hex8(fd, val & 0xFF)
}

fn write_a64_xreg(uint64 fd, uint64 reg) {
    uint8[4] rb
    if reg == 31 {
        write(fd, "sp", 2)
    } else {
        write(fd, "x", 1)
        uint64 rl = fmt_uint(rb, reg)
        write(fd, rb, rl)
    }
}

fn write_a64_wreg(uint64 fd, uint64 reg) {
    uint8[4] rb
    if reg == 31 {
        write(fd, "wzr", 3)
    } else {
        write(fd, "w", 1)
        uint64 rl = fmt_uint(rb, reg)
        write(fd, rb, rl)
    }
}

fn write_a64_sysreg(uint64 fd, uint64 op0, uint64 op1, uint64 crn, uint64 crm, uint64 op2) {
    // Common system registers
    if op0 == 3 && op1 == 3 && crn == 13 && crm == 0 && op2 == 2 {
        write(fd, "tpidr_el0", 9)
    } else if op0 == 3 && op1 == 0 && crn == 4 && crm == 0 && op2 == 1 {
        write(fd, "elr_el1", 7)
    } else if op0 == 3 && op1 == 0 && crn == 4 && crm == 0 && op2 == 0 {
        write(fd, "spsr_el1", 8)
    } else if op0 == 3 && op1 == 0 && crn == 5 && crm == 2 && op2 == 0 {
        write(fd, "esr_el1", 7)
    } else if op0 == 3 && op1 == 0 && crn == 6 && crm == 0 && op2 == 0 {
        write(fd, "far_el1", 7)
    } else if op0 == 3 && op1 == 0 && crn == 1 && crm == 0 && op2 == 0 {
        write(fd, "sctlr_el1", 9)
    } else if op0 == 3 && op1 == 0 && crn == 2 && crm == 0 && op2 == 0 {
        write(fd, "ttbr0_el1", 9)
    } else if op0 == 3 && op1 == 0 && crn == 2 && crm == 0 && op2 == 1 {
        write(fd, "ttbr1_el1", 9)
    } else if op0 == 3 && op1 == 0 && crn == 12 && crm == 0 && op2 == 0 {
        write(fd, "vbar_el1", 8)
    } else if op0 == 3 && op1 == 3 && crn == 4 && crm == 2 && op2 == 0 {
        write(fd, "nzcv", 4)
    } else if op0 == 3 && op1 == 3 && crn == 4 && crm == 2 && op2 == 1 {
        write(fd, "daif", 4)
    } else if op0 == 3 && op1 == 0 && crn == 0 && crm == 0 && op2 == 0 {
        write(fd, "midr_el1", 8)
    } else if op0 == 3 && op1 == 0 && crn == 0 && crm == 0 && op2 == 5 {
        write(fd, "mpidr_el1", 9)
    } else if op0 == 3 && op1 == 3 && crn == 14 && crm == 0 && op2 == 1 {
        write(fd, "cntpct_el0", 10)
    } else {
        // Fallback: print s<op0>_<op1>_c<crn>_c<crm>_<op2>
        uint8[4] rb
        write(fd, "s", 1)
        uint64 rl = fmt_uint(rb, op0)
        write(fd, rb, rl)
        write(fd, "_", 1)
        rl = fmt_uint(rb, op1)
        write(fd, rb, rl)
        write(fd, "_c", 2)
        rl = fmt_uint(rb, crn)
        write(fd, rb, rl)
        write(fd, "_c", 2)
        rl = fmt_uint(rb, crm)
        write(fd, rb, rl)
        write(fd, "_", 1)
        rl = fmt_uint(rb, op2)
        write(fd, rb, rl)
    }
}

// x86_64 64-bit register name. Accepts 0..15; the high-bit encoded
// r8..r15 come from the REX.R/B prefix bits added upstream.
fn write_x86_reg64(uint64 fd, uint64 r) {
    uint8[4] rb
    if r == 0 { write(fd, "rax", 3) }
    else if r == 1 { write(fd, "rcx", 3) }
    else if r == 2 { write(fd, "rdx", 3) }
    else if r == 3 { write(fd, "rbx", 3) }
    else if r == 4 { write(fd, "rsp", 3) }
    else if r == 5 { write(fd, "rbp", 3) }
    else if r == 6 { write(fd, "rsi", 3) }
    else if r == 7 { write(fd, "rdi", 3) }
    else {
        write(fd, "r", 1)
        uint64 rl = fmt_uint(rb, r)
        write(fd, rb, rl)
    }
}

// Decode and print an x86_64 memory operand from a ModR/M byte.
// `bp_modrm` points to the ModR/M byte; disp/SIB bytes follow.
// `base_hi` is 1 if REX.B is set (base register is r8..r15).
// Returns the number of bytes consumed after the ModR/M (SIB + disp).
fn write_x86_mem(uint64 fd, uint64 bp_modrm, uint64 base_hi) -> uint64 {
    uint64 modrm = 0
    unsafe { *(bp_modrm as uint8) -> modrm }
    uint64 mod_f = (modrm >> 6) & 3
    uint64 rm_f  = modrm & 7
    uint64 base_r = rm_f | (base_hi << 3)
    uint64 disp_ofs = 1
    uint64 has_sib = 0
    uint64 sib_base = 0
    if mod_f != 3 && rm_f == 4 {
        uint64 bp_s = bp_modrm + 1
        uint64 sib_b = 0
        unsafe { *(bp_s as uint8) -> sib_b }
        sib_base = (sib_b & 7) | (base_hi << 3)
        base_r = sib_base
        has_sib = 1
        disp_ofs = 2
    }
    write(fd, "[", 1)
    if mod_f == 0 && rm_f == 5 {
        write(fd, "rip", 3)
    } else {
        write_x86_reg64(fd, base_r)
    }
    uint64 consumed = disp_ofs - 1
    if mod_f == 1 {
        uint64 bp_d = bp_modrm + disp_ofs
        uint64 d8v = 0
        unsafe { *(bp_d as uint8) -> d8v }
        write(fd, "+0x", 3)
        write_hex8(fd, d8v)
        consumed = consumed + 1
    } else if mod_f == 2 || (mod_f == 0 && rm_f == 5) {
        uint64 bp_d0 = bp_modrm + disp_ofs
        uint64 bp_d1 = bp_modrm + disp_ofs + 1
        uint64 bp_d2 = bp_modrm + disp_ofs + 2
        uint64 bp_d3 = bp_modrm + disp_ofs + 3
        uint64 d32_0 = 0
        uint64 d32_1 = 0
        uint64 d32_2 = 0
        uint64 d32_3 = 0
        unsafe { *(bp_d0 as uint8) -> d32_0 }
        unsafe { *(bp_d1 as uint8) -> d32_1 }
        unsafe { *(bp_d2 as uint8) -> d32_2 }
        unsafe { *(bp_d3 as uint8) -> d32_3 }
        uint64 d32 = d32_0 | (d32_1 << 8) | (d32_2 << 16) | (d32_3 << 24)
        write(fd, "+0x", 3)
        write_hex32(fd, d32)
        consumed = consumed + 4
    }
    write(fd, "]", 1)
    return consumed
}

// Length of an x86_64 ModR/M operand (SIB + displacement), not counting the
// ModR/M byte itself. Mirrors the consumed-bytes computation in write_x86_mem.
fn x86_modrm_extra(uint64 modrm) -> uint64 {
    uint64 mod_f = (modrm >> 6) & 3
    uint64 rm_f  = modrm & 7
    if mod_f == 3 { return 0 }
    uint64 extra = 0
    if rm_f == 4 { extra = extra + 1 }
    if mod_f == 1 { extra = extra + 1 }
    if mod_f == 2 { extra = extra + 4 }
    if mod_f == 0 && rm_f == 5 { extra = extra + 4 }
    return extra
}

fn emit_asm_listing(uint64 output_path, uint64 arch, uint64 text_start, uint64 source, uint64 tokens) {
    uint64 fd = file_open(output_path, 1)
    uint64 code_end = codegen_output_len()
    write(fd, "; KernRift assembly listing\n", 27)
    if arch == 0 {
        write(fd, "; Architecture: x86_64\n", 23)
    } else {
        write(fd, "; Architecture: ARM64\n", 22)
    }
    write(fd, "\n", 1)

    // Build sorted function offset list for labeling
    uint64 fi = 0
    while fi < fn_count {
        uint64 fentry = fn_table + fi * 8
        uint32 fn_tok = 0
        unsafe { *(fentry as uint32) -> fn_tok }
        uint64 fe4 = fentry + 4
        uint32 fn_off = 0
        unsafe { *(fe4 as uint32) -> fn_off }
        uint64 woff = fn_off

        // If this function carries a @section("name") annotation, emit
        // a gas-style `.section <name>,"ax",@progbits` directive so the
        // listing round-trips cleanly through an external assembler.
        uint64 sect_info = fn_section_lookup(fn_tok)
        if sect_info != 0 {
            uint64 sect_start = (sect_info >> 32) & 0xFFFFFFFF
            uint64 sect_len = sect_info & 0xFFFFFFFF
            write(fd, "\n.section ", 10)
            write(fd, source + sect_start, sect_len)
            if arch == 0 {
                write(fd, ",\"ax\",@progbits\n", 16)
            } else {
                write(fd, ",\"ax\",%progbits\n", 16)
            }
        }
        // Print function label
        write(fd, "\n", 1)
        uint64 tstart = tok_text_start(fn_tok)
        uint64 tlen = tok_text_len(fn_tok)
        uint64 name_ptr = source + tstart
        write(fd, name_ptr, tlen)
        write(fd, ":\n", 2)

        // Find end of this function (next function offset or code_end)
        uint64 fn_end = code_end
        uint64 fj = 0
        while fj < fn_count {
            uint64 fe2 = fn_table + fj * 8 + 4
            uint32 next_off = 0
            unsafe { *(fe2 as uint32) -> next_off }
            uint64 wnext = next_off
            if wnext > woff && wnext < fn_end {
                fn_end = wnext
            }
            fj = fj + 1
        }

        // Dump instructions
        uint64 pos = woff
        if arch == 1 {
            // ARM64: fixed 4-byte instructions
            while pos + 4 <= fn_end {
                write(fd, "  ", 2)
                write_hex32(fd, pos - text_start)
                write(fd, ": ", 2)
                uint64 bp = out_buf + pos
                uint32 insn = 0
                unsafe { *(bp as uint32) -> insn }
                uint64 wi = insn
                write_hex32(fd, wi)
                write(fd, "  ", 2)
                uint8[16] drb
                uint64 drl = 0
                uint64 rd = wi & 0x1F
                uint64 rn = (wi >> 5) & 0x1F
                uint64 rm = (wi >> 16) & 0x1F
                // Decode common ARM64 instructions
                if wi == 0xD503201F { write(fd, "nop", 3) }
                else if wi == 0xD65F03C0 { write(fd, "ret", 3) }
                else if wi == 0xD503207F { write(fd, "wfi", 3) }
                else if wi == 0xD5033FDF { write(fd, "isb", 3) }
                else if wi == 0xD5033BBF { write(fd, "dmb ish", 7) }
                else if wi == 0xD5033B9F { write(fd, "dsb ish", 7) }
                else if wi == 0xD5033F9F { write(fd, "dsb sy", 6) }
                else if wi == 0xD5033FBF { write(fd, "dmb sy", 6) }
                else if (wi & 0xFFFFFFE0) == 0xD50B7E20 {
                    write(fd, "dc civac, ", 10)
                    write_a64_xreg(fd, rd)
                }
                else if (wi & 0xFFFFFFE0) == 0xD50B7520 {
                    write(fd, "ic ivau, ", 9)
                    write_a64_xreg(fd, rd)
                }
                else if wi == 0xD69F03E0 { write(fd, "eret", 4) }
                else if wi == 0xD4000001 { write(fd, "svc #0", 6) }
                // MOVZ 64-bit
                else if (wi & 0xFF800000) == 0xD2800000 {
                    write(fd, "movz ", 5)
                    write_a64_xreg(fd, rd)
                    write(fd, ", #", 3)
                    uint64 imm16 = (wi >> 5) & 0xFFFF
                    drl = fmt_uint(drb, imm16)
                    write(fd, drb, drl)
                    uint64 hw = (wi >> 21) & 0x3
                    if hw != 0 {
                        write(fd, ", lsl #", 7)
                        drl = fmt_uint(drb, hw * 16)
                        write(fd, drb, drl)
                    }
                }
                // MOVK 64-bit
                else if (wi & 0xFF800000) == 0xF2800000 {
                    write(fd, "movk ", 5)
                    write_a64_xreg(fd, rd)
                    write(fd, ", #", 3)
                    uint64 imm16 = (wi >> 5) & 0xFFFF
                    drl = fmt_uint(drb, imm16)
                    write(fd, drb, drl)
                    uint64 hw = (wi >> 21) & 0x3
                    if hw != 0 {
                        write(fd, ", lsl #", 7)
                        drl = fmt_uint(drb, hw * 16)
                        write(fd, drb, drl)
                    }
                }
                // ADD/SUB immediate (bits 28:24 = 10001)
                else if (wi & 0x1F000000) == 0x11000000 && (wi & 0x20000000) == 0 {
                    uint64 is_64 = (wi >> 31) & 1
                    if (wi & 0x40000000) != 0 {
                        write(fd, "sub ", 4)
                    } else {
                        write(fd, "add ", 4)
                    }
                    if is_64 != 0 {
                        write_a64_xreg(fd, rd)
                        write(fd, ", ", 2)
                        write_a64_xreg(fd, rn)
                    } else {
                        write_a64_wreg(fd, rd)
                        write(fd, ", ", 2)
                        write_a64_wreg(fd, rn)
                    }
                    write(fd, ", #", 3)
                    uint64 imm12 = (wi >> 10) & 0xFFF
                    drl = fmt_uint(drb, imm12)
                    write(fd, drb, drl)
                }
                // ADD/SUB register (shifted): bits 28:24 = 01011, bit 21 = 0
                else if (wi & 0x1F200000) == 0x0B000000 {
                    uint64 is_64 = (wi >> 31) & 1
                    if (wi & 0x40000000) != 0 {
                        write(fd, "sub ", 4)
                    } else {
                        write(fd, "add ", 4)
                    }
                    if is_64 != 0 {
                        write_a64_xreg(fd, rd)
                        write(fd, ", ", 2)
                        write_a64_xreg(fd, rn)
                        write(fd, ", ", 2)
                        write_a64_xreg(fd, rm)
                    } else {
                        write_a64_wreg(fd, rd)
                        write(fd, ", ", 2)
                        write_a64_wreg(fd, rn)
                        write(fd, ", ", 2)
                        write_a64_wreg(fd, rm)
                    }
                }
                // LDR 64-bit unsigned offset
                else if (wi & 0xFFC00000) == 0xF9400000 {
                    write(fd, "ldr ", 4)
                    write_a64_xreg(fd, rd)
                    write(fd, ", [", 3)
                    write_a64_xreg(fd, rn)
                    uint64 imm12 = (wi >> 10) & 0xFFF
                    uint64 off = imm12 * 8
                    if off != 0 {
                        write(fd, ", #", 3)
                        drl = fmt_uint(drb, off)
                        write(fd, drb, drl)
                    }
                    write(fd, "]", 1)
                }
                // STR 64-bit unsigned offset
                else if (wi & 0xFFC00000) == 0xF9000000 {
                    write(fd, "str ", 4)
                    write_a64_xreg(fd, rd)
                    write(fd, ", [", 3)
                    write_a64_xreg(fd, rn)
                    uint64 imm12 = (wi >> 10) & 0xFFF
                    uint64 off = imm12 * 8
                    if off != 0 {
                        write(fd, ", #", 3)
                        drl = fmt_uint(drb, off)
                        write(fd, drb, drl)
                    }
                    write(fd, "]", 1)
                }
                // LDR 32-bit unsigned offset
                else if (wi & 0xFFC00000) == 0xB9400000 {
                    write(fd, "ldr ", 4)
                    write_a64_wreg(fd, rd)
                    write(fd, ", [", 3)
                    write_a64_xreg(fd, rn)
                    uint64 imm12 = (wi >> 10) & 0xFFF
                    uint64 off = imm12 * 4
                    if off != 0 {
                        write(fd, ", #", 3)
                        drl = fmt_uint(drb, off)
                        write(fd, drb, drl)
                    }
                    write(fd, "]", 1)
                }
                // STR 32-bit unsigned offset
                else if (wi & 0xFFC00000) == 0xB9000000 {
                    write(fd, "str ", 4)
                    write_a64_wreg(fd, rd)
                    write(fd, ", [", 3)
                    write_a64_xreg(fd, rn)
                    uint64 imm12 = (wi >> 10) & 0xFFF
                    uint64 off = imm12 * 4
                    if off != 0 {
                        write(fd, ", #", 3)
                        drl = fmt_uint(drb, off)
                        write(fd, drb, drl)
                    }
                    write(fd, "]", 1)
                }
                // LDRB unsigned offset
                else if (wi & 0xFFC00000) == 0x39400000 {
                    write(fd, "ldrb ", 5)
                    write_a64_wreg(fd, rd)
                    write(fd, ", [", 3)
                    write_a64_xreg(fd, rn)
                    uint64 imm12 = (wi >> 10) & 0xFFF
                    if imm12 != 0 {
                        write(fd, ", #", 3)
                        drl = fmt_uint(drb, imm12)
                        write(fd, drb, drl)
                    }
                    write(fd, "]", 1)
                }
                // STRB unsigned offset
                else if (wi & 0xFFC00000) == 0x39000000 {
                    write(fd, "strb ", 5)
                    write_a64_wreg(fd, rd)
                    write(fd, ", [", 3)
                    write_a64_xreg(fd, rn)
                    uint64 imm12 = (wi >> 10) & 0xFFF
                    if imm12 != 0 {
                        write(fd, ", #", 3)
                        drl = fmt_uint(drb, imm12)
                        write(fd, drb, drl)
                    }
                    write(fd, "]", 1)
                }
                // STP 64-bit: signed offset / pre-index / post-index
                else if (wi & 0xFFC00000) == 0xA9000000 || (wi & 0xFFC00000) == 0xA9800000 || (wi & 0xFFC00000) == 0xA8800000 {
                    write(fd, "stp ", 4)
                    write_a64_xreg(fd, rd)
                    write(fd, ", ", 2)
                    uint64 rt2 = (wi >> 10) & 0x1F
                    write_a64_xreg(fd, rt2)
                    write(fd, ", [", 3)
                    write_a64_xreg(fd, rn)
                    uint64 imm7 = (wi >> 15) & 0x7F
                    uint64 soff = imm7
                    if (imm7 & 0x40) != 0 { soff = soff | 0xFFFFFFFFFFFFFF80 }
                    soff = soff * 8
                    if soff != 0 {
                        write(fd, ", #", 3)
                        if (soff & 0x8000000000000000) != 0 {
                            write(fd, "-", 1)
                            soff = 0 - soff
                        }
                        drl = fmt_uint(drb, soff)
                        write(fd, drb, drl)
                    }
                    write(fd, "]", 1)
                    if (wi & 0xFFC00000) == 0xA9800000 {
                        write(fd, "!", 1)
                    }
                }
                // LDP 64-bit: signed offset / pre-index / post-index
                else if (wi & 0xFFC00000) == 0xA9400000 || (wi & 0xFFC00000) == 0xA9C00000 || (wi & 0xFFC00000) == 0xA8C00000 {
                    write(fd, "ldp ", 4)
                    write_a64_xreg(fd, rd)
                    write(fd, ", ", 2)
                    uint64 rt2 = (wi >> 10) & 0x1F
                    write_a64_xreg(fd, rt2)
                    write(fd, ", [", 3)
                    write_a64_xreg(fd, rn)
                    uint64 imm7 = (wi >> 15) & 0x7F
                    uint64 soff = imm7
                    if (imm7 & 0x40) != 0 { soff = soff | 0xFFFFFFFFFFFFFF80 }
                    soff = soff * 8
                    if soff != 0 {
                        write(fd, ", #", 3)
                        if (soff & 0x8000000000000000) != 0 {
                            write(fd, "-", 1)
                            soff = 0 - soff
                        }
                        drl = fmt_uint(drb, soff)
                        write(fd, drb, drl)
                    }
                    write(fd, "]", 1)
                    if (wi & 0xFFC00000) == 0xA9C00000 {
                        write(fd, "!", 1)
                    }
                }
                // BL: 1001 01 imm26
                else if (wi & 0xFC000000) == 0x94000000 {
                    write(fd, "bl ", 3)
                    uint64 imm26 = wi & 0x3FFFFFF
                    if (imm26 & 0x2000000) != 0 {
                        uint64 soff = (0x4000000 - imm26) * 4
                        write(fd, "<-", 2)
                        drl = fmt_uint(drb, soff)
                        write(fd, drb, drl)
                    } else {
                        uint64 soff = imm26 * 4
                        write(fd, "<+", 2)
                        drl = fmt_uint(drb, soff)
                        write(fd, drb, drl)
                    }
                    write(fd, ">", 1)
                }
                // B: 0001 01 imm26
                else if (wi & 0xFC000000) == 0x14000000 {
                    write(fd, "b ", 2)
                    uint64 imm26 = wi & 0x3FFFFFF
                    if (imm26 & 0x2000000) != 0 {
                        uint64 soff = (0x4000000 - imm26) * 4
                        write(fd, "<-", 2)
                        drl = fmt_uint(drb, soff)
                        write(fd, drb, drl)
                    } else {
                        uint64 soff = imm26 * 4
                        write(fd, "<+", 2)
                        drl = fmt_uint(drb, soff)
                        write(fd, drb, drl)
                    }
                    write(fd, ">", 1)
                }
                // B.cond: 0101 0100 imm19 0 cond
                else if (wi & 0xFF000010) == 0x54000000 {
                    write(fd, "b.", 2)
                    uint64 cond = wi & 0xF
                    if cond == 0 { write(fd, "eq", 2) }
                    else if cond == 1 { write(fd, "ne", 2) }
                    else if cond == 2 { write(fd, "cs", 2) }
                    else if cond == 3 { write(fd, "cc", 2) }
                    else if cond == 4 { write(fd, "mi", 2) }
                    else if cond == 5 { write(fd, "pl", 2) }
                    else if cond == 6 { write(fd, "vs", 2) }
                    else if cond == 7 { write(fd, "vc", 2) }
                    else if cond == 8 { write(fd, "hi", 2) }
                    else if cond == 9 { write(fd, "ls", 2) }
                    else if cond == 10 { write(fd, "ge", 2) }
                    else if cond == 11 { write(fd, "lt", 2) }
                    else if cond == 12 { write(fd, "gt", 2) }
                    else if cond == 13 { write(fd, "le", 2) }
                    else if cond == 14 { write(fd, "al", 2) }
                    else { write(fd, "nv", 2) }
                    write(fd, " ", 1)
                    uint64 imm19 = (wi >> 5) & 0x7FFFF
                    if (imm19 & 0x40000) != 0 {
                        uint64 soff = (0x80000 - imm19) * 4
                        write(fd, "<-", 2)
                        drl = fmt_uint(drb, soff)
                        write(fd, drb, drl)
                    } else {
                        uint64 soff = imm19 * 4
                        write(fd, "<+", 2)
                        drl = fmt_uint(drb, soff)
                        write(fd, drb, drl)
                    }
                    write(fd, ">", 1)
                }
                // CBNZ 64-bit
                else if (wi & 0xFF000000) == 0xB5000000 {
                    write(fd, "cbnz ", 5)
                    write_a64_xreg(fd, rd)
                    write(fd, ", ", 2)
                    uint64 imm19 = (wi >> 5) & 0x7FFFF
                    if (imm19 & 0x40000) != 0 {
                        uint64 soff = (0x80000 - imm19) * 4
                        write(fd, "<-", 2)
                        drl = fmt_uint(drb, soff)
                        write(fd, drb, drl)
                    } else {
                        uint64 soff = imm19 * 4
                        write(fd, "<+", 2)
                        drl = fmt_uint(drb, soff)
                        write(fd, drb, drl)
                    }
                    write(fd, ">", 1)
                }
                // CBZ 64-bit
                else if (wi & 0xFF000000) == 0xB4000000 {
                    write(fd, "cbz ", 4)
                    write_a64_xreg(fd, rd)
                    write(fd, ", ", 2)
                    uint64 imm19 = (wi >> 5) & 0x7FFFF
                    if (imm19 & 0x40000) != 0 {
                        uint64 soff = (0x80000 - imm19) * 4
                        write(fd, "<-", 2)
                        drl = fmt_uint(drb, soff)
                        write(fd, drb, drl)
                    } else {
                        uint64 soff = imm19 * 4
                        write(fd, "<+", 2)
                        drl = fmt_uint(drb, soff)
                        write(fd, drb, drl)
                    }
                    write(fd, ">", 1)
                }
                // CBNZ 32-bit
                else if (wi & 0xFF000000) == 0x35000000 {
                    write(fd, "cbnz ", 5)
                    write_a64_wreg(fd, rd)
                    write(fd, ", ", 2)
                    uint64 imm19 = (wi >> 5) & 0x7FFFF
                    if (imm19 & 0x40000) != 0 {
                        uint64 soff = (0x80000 - imm19) * 4
                        write(fd, "<-", 2)
                        drl = fmt_uint(drb, soff)
                        write(fd, drb, drl)
                    } else {
                        uint64 soff = imm19 * 4
                        write(fd, "<+", 2)
                        drl = fmt_uint(drb, soff)
                        write(fd, drb, drl)
                    }
                    write(fd, ">", 1)
                }
                // CBZ 32-bit
                else if (wi & 0xFF000000) == 0x34000000 {
                    write(fd, "cbz ", 4)
                    write_a64_wreg(fd, rd)
                    write(fd, ", ", 2)
                    uint64 imm19 = (wi >> 5) & 0x7FFFF
                    if (imm19 & 0x40000) != 0 {
                        uint64 soff = (0x80000 - imm19) * 4
                        write(fd, "<-", 2)
                        drl = fmt_uint(drb, soff)
                        write(fd, drb, drl)
                    } else {
                        uint64 soff = imm19 * 4
                        write(fd, "<+", 2)
                        drl = fmt_uint(drb, soff)
                        write(fd, drb, drl)
                    }
                    write(fd, ">", 1)
                }
                // MRS
                else if (wi & 0xFFF00000) == 0xD5300000 {
                    write(fd, "mrs ", 4)
                    write_a64_xreg(fd, rd)
                    write(fd, ", ", 2)
                    uint64 sop0 = ((wi >> 19) & 1) + 2
                    uint64 sop1 = (wi >> 16) & 0x7
                    uint64 scrn = (wi >> 12) & 0xF
                    uint64 scrm = (wi >> 8) & 0xF
                    uint64 sop2 = (wi >> 5) & 0x7
                    write_a64_sysreg(fd, sop0, sop1, scrn, scrm, sop2)
                }
                // MSR
                else if (wi & 0xFFF00000) == 0xD5100000 {
                    write(fd, "msr ", 4)
                    uint64 sop0 = ((wi >> 19) & 1) + 2
                    uint64 sop1 = (wi >> 16) & 0x7
                    uint64 scrn = (wi >> 12) & 0xF
                    uint64 scrm = (wi >> 8) & 0xF
                    uint64 sop2 = (wi >> 5) & 0x7
                    write_a64_sysreg(fd, sop0, sop1, scrn, scrm, sop2)
                    write(fd, ", ", 2)
                    write_a64_xreg(fd, rd)
                }
                // LDXR/LDAR
                else if (wi & 0x3FE00000) == 0x08400000 {
                    if (wi & 0x00800000) != 0 {
                        write(fd, "ldar ", 5)
                    } else {
                        write(fd, "ldxr ", 5)
                    }
                    uint64 is_64 = (wi >> 30) & 1
                    if is_64 != 0 {
                        write_a64_xreg(fd, rd)
                    } else {
                        write_a64_wreg(fd, rd)
                    }
                    write(fd, ", [", 3)
                    write_a64_xreg(fd, rn)
                    write(fd, "]", 1)
                }
                // STXR/STLR
                else if (wi & 0x3FE00000) == 0x08000000 {
                    if (wi & 0x00800000) != 0 {
                        write(fd, "stlr ", 5)
                    } else {
                        write(fd, "stxr ", 5)
                    }
                    uint64 is_64 = (wi >> 30) & 1
                    if is_64 != 0 {
                        write_a64_xreg(fd, rd)
                    } else {
                        write_a64_wreg(fd, rd)
                    }
                    write(fd, ", [", 3)
                    write_a64_xreg(fd, rn)
                    write(fd, "]", 1)
                }
                write(fd, "\n", 1)
                pos = pos + 4
            }
        } else {
            // x86_64: variable length — hex dump with basic decode
            while pos < fn_end {
                write(fd, "  ", 2)
                write_hex32(fd, pos - text_start)
                write(fd, ": ", 2)
                uint64 bp = out_buf + pos
                uint64 b0 = 0
                unsafe { *(bp as uint8) -> b0 }
                // Decode some common patterns
                if b0 == 0xC3 {
                    write_hex8(fd, b0)
                    write(fd, "                 ret", 20)
                    pos = pos + 1
                } else if b0 == 0x0F {
                    uint64 bp1 = bp + 1
                    uint64 b1 = 0
                    unsafe { *(bp1 as uint8) -> b1 }
                    if b1 == 0x05 {
                        write_hex8(fd, b0)
                        write(fd, " ", 1)
                        write_hex8(fd, b1)
                        write(fd, "              syscall", 21)
                        pos = pos + 2
                    } else if b1 == 0xAE {
                        uint64 bp2 = bp + 2
                        uint64 b2 = 0
                        unsafe { *(bp2 as uint8) -> b2 }
                        if b2 == 0xF0 {
                            write_hex8(fd, b0)
                            write(fd, " ", 1)
                            write_hex8(fd, b1)
                            write(fd, " ", 1)
                            write_hex8(fd, b2)
                            write(fd, "           mfence", 18)
                            pos = pos + 3
                        } else {
                            write_hex8(fd, b0)
                            write(fd, " ", 1)
                            write_hex8(fd, b1)
                            write(fd, " ", 1)
                            write_hex8(fd, b2)
                            pos = pos + 3
                        }
                    } else if b1 >= 0x80 && b1 <= 0x8F && pos + 6 <= fn_end {
                        // jcc rel32: 0F 80-8F + imm32
                        uint64 bp2 = bp + 2
                        uint64 i0 = 0
                        uint64 i1 = 0
                        uint64 i2 = 0
                        uint64 i3 = 0
                        unsafe { *(bp2 as uint8) -> i0 }
                        uint64 bp3 = bp + 3
                        unsafe { *(bp3 as uint8) -> i1 }
                        uint64 bp4 = bp + 4
                        unsafe { *(bp4 as uint8) -> i2 }
                        uint64 bp5 = bp + 5
                        unsafe { *(bp5 as uint8) -> i3 }
                        write_hex8(fd, b0)
                        write(fd, " ", 1)
                        write_hex8(fd, b1)
                        write(fd, " ", 1)
                        write_hex8(fd, i0)
                        write(fd, " ", 1)
                        write_hex8(fd, i1)
                        write(fd, " ", 1)
                        write_hex8(fd, i2)
                        write(fd, " ", 1)
                        write_hex8(fd, i3)
                        write(fd, "  ", 2)
                        uint64 jcc32_cc = b1 - 0x80
                        if jcc32_cc == 0 { write(fd, "jo 0x", 5) }
                        else if jcc32_cc == 1 { write(fd, "jno 0x", 6) }
                        else if jcc32_cc == 2 { write(fd, "jb 0x", 5) }
                        else if jcc32_cc == 3 { write(fd, "jnb 0x", 6) }
                        else if jcc32_cc == 4 { write(fd, "je 0x", 5) }
                        else if jcc32_cc == 5 { write(fd, "jne 0x", 6) }
                        else if jcc32_cc == 6 { write(fd, "jbe 0x", 6) }
                        else if jcc32_cc == 7 { write(fd, "ja 0x", 5) }
                        else if jcc32_cc == 8 { write(fd, "js 0x", 5) }
                        else if jcc32_cc == 9 { write(fd, "jns 0x", 6) }
                        else if jcc32_cc == 10 { write(fd, "jp 0x", 5) }
                        else if jcc32_cc == 11 { write(fd, "jnp 0x", 6) }
                        else if jcc32_cc == 12 { write(fd, "jl 0x", 5) }
                        else if jcc32_cc == 13 { write(fd, "jge 0x", 6) }
                        else if jcc32_cc == 14 { write(fd, "jle 0x", 6) }
                        else { write(fd, "jg 0x", 5) }
                        uint64 jcc32_imm = i0 | (i1 << 8) | (i2 << 16) | (i3 << 24)
                        write_hex32(fd, jcc32_imm)
                        pos = pos + 6
                    } else {
                        // Dump up to 4 bytes
                        uint64 cnt = 2
                        uint64 di = 0
                        while di < cnt {
                            uint64 dp = bp + di
                            uint64 db = 0
                            unsafe { *(dp as uint8) -> db }
                            write_hex8(fd, db)
                            write(fd, " ", 1)
                            di = di + 1
                        }
                        pos = pos + cnt
                    }
                } else if b0 == 0xF0 {
                    // LOCK prefix
                    write_hex8(fd, b0)
                    write(fd, " ", 1)
                    write(fd, "...          lock ...", 20)
                    // Dump rest of instruction (up to 7 more bytes)
                    uint64 li = 1
                    while li < 8 && pos + li < fn_end {
                        uint64 lp = bp + li
                        uint64 lb = 0
                        unsafe { *(lp as uint8) -> lb }
                        if lb == 0x48 || lb == 0x0F || (lb >= 0x80 && lb <= 0xCF) {
                            li = li + 1
                        } else {
                            li = li + 1
                            break
                        }
                    }
                    pos = pos + li
                } else if b0 >= 0x50 && b0 <= 0x57 {
                    // push reg (0x50-0x57)
                    write_hex8(fd, b0)
                    write(fd, "                 push ", 22)
                    uint64 push_r = b0 - 0x50
                    if push_r == 0 { write(fd, "rax", 3) }
                    else if push_r == 1 { write(fd, "rcx", 3) }
                    else if push_r == 2 { write(fd, "rdx", 3) }
                    else if push_r == 3 { write(fd, "rbx", 3) }
                    else if push_r == 4 { write(fd, "rsp", 3) }
                    else if push_r == 5 { write(fd, "rbp", 3) }
                    else if push_r == 6 { write(fd, "rsi", 3) }
                    else { write(fd, "rdi", 3) }
                    pos = pos + 1
                } else if b0 >= 0x58 && b0 <= 0x5F {
                    // pop reg (0x58-0x5F)
                    write_hex8(fd, b0)
                    write(fd, "                 pop ", 21)
                    uint64 pop_r = b0 - 0x58
                    if pop_r == 0 { write(fd, "rax", 3) }
                    else if pop_r == 1 { write(fd, "rcx", 3) }
                    else if pop_r == 2 { write(fd, "rdx", 3) }
                    else if pop_r == 3 { write(fd, "rbx", 3) }
                    else if pop_r == 4 { write(fd, "rsp", 3) }
                    else if pop_r == 5 { write(fd, "rbp", 3) }
                    else if pop_r == 6 { write(fd, "rsi", 3) }
                    else { write(fd, "rdi", 3) }
                    pos = pos + 1
                } else if b0 == 0x90 {
                    // nop
                    write_hex8(fd, b0)
                    write(fd, "                 nop", 20)
                    pos = pos + 1
                } else if b0 == 0xE8 && pos + 5 <= fn_end {
                    // call rel32
                    uint64 bp1 = bp + 1
                    uint64 bp2 = bp + 2
                    uint64 bp3 = bp + 3
                    uint64 bp4 = bp + 4
                    uint64 c0 = 0
                    uint64 c1 = 0
                    uint64 c2 = 0
                    uint64 c3 = 0
                    unsafe { *(bp1 as uint8) -> c0 }
                    unsafe { *(bp2 as uint8) -> c1 }
                    unsafe { *(bp3 as uint8) -> c2 }
                    unsafe { *(bp4 as uint8) -> c3 }
                    write_hex8(fd, b0)
                    write(fd, " ", 1)
                    write_hex8(fd, c0)
                    write(fd, " ", 1)
                    write_hex8(fd, c1)
                    write(fd, " ", 1)
                    write_hex8(fd, c2)
                    write(fd, " ", 1)
                    write_hex8(fd, c3)
                    write(fd, "     call 0x", 12)
                    uint64 call_imm = c0 | (c1 << 8) | (c2 << 16) | (c3 << 24)
                    write_hex32(fd, call_imm)
                    pos = pos + 5
                } else if b0 == 0xE9 && pos + 5 <= fn_end {
                    // jmp rel32
                    uint64 bp1 = bp + 1
                    uint64 bp2 = bp + 2
                    uint64 bp3 = bp + 3
                    uint64 bp4 = bp + 4
                    uint64 j0 = 0
                    uint64 j1 = 0
                    uint64 j2 = 0
                    uint64 j3 = 0
                    unsafe { *(bp1 as uint8) -> j0 }
                    unsafe { *(bp2 as uint8) -> j1 }
                    unsafe { *(bp3 as uint8) -> j2 }
                    unsafe { *(bp4 as uint8) -> j3 }
                    write_hex8(fd, b0)
                    write(fd, " ", 1)
                    write_hex8(fd, j0)
                    write(fd, " ", 1)
                    write_hex8(fd, j1)
                    write(fd, " ", 1)
                    write_hex8(fd, j2)
                    write(fd, " ", 1)
                    write_hex8(fd, j3)
                    write(fd, "     jmp 0x", 11)
                    uint64 jmp32_imm = j0 | (j1 << 8) | (j2 << 16) | (j3 << 24)
                    write_hex32(fd, jmp32_imm)
                    pos = pos + 5
                } else if b0 == 0xEB && pos + 2 <= fn_end {
                    // jmp rel8
                    uint64 bp1 = bp + 1
                    uint64 jmp8_off = 0
                    unsafe { *(bp1 as uint8) -> jmp8_off }
                    write_hex8(fd, b0)
                    write(fd, " ", 1)
                    write_hex8(fd, jmp8_off)
                    write(fd, "              jmp 0x", 20)
                    write_hex8(fd, jmp8_off)
                    pos = pos + 2
                } else if b0 >= 0x70 && b0 <= 0x7F && pos + 2 <= fn_end {
                    // jcc rel8 (0x70-0x7F)
                    uint64 bp1 = bp + 1
                    uint64 jcc8_off = 0
                    unsafe { *(bp1 as uint8) -> jcc8_off }
                    write_hex8(fd, b0)
                    write(fd, " ", 1)
                    write_hex8(fd, jcc8_off)
                    write(fd, "              ", 14)
                    uint64 jcc8_cc = b0 - 0x70
                    if jcc8_cc == 0 { write(fd, "jo 0x", 5) }
                    else if jcc8_cc == 1 { write(fd, "jno 0x", 6) }
                    else if jcc8_cc == 2 { write(fd, "jb 0x", 5) }
                    else if jcc8_cc == 3 { write(fd, "jnb 0x", 6) }
                    else if jcc8_cc == 4 { write(fd, "je 0x", 5) }
                    else if jcc8_cc == 5 { write(fd, "jne 0x", 6) }
                    else if jcc8_cc == 6 { write(fd, "jbe 0x", 6) }
                    else if jcc8_cc == 7 { write(fd, "ja 0x", 5) }
                    else if jcc8_cc == 8 { write(fd, "js 0x", 5) }
                    else if jcc8_cc == 9 { write(fd, "jns 0x", 6) }
                    else if jcc8_cc == 10 { write(fd, "jp 0x", 5) }
                    else if jcc8_cc == 11 { write(fd, "jnp 0x", 6) }
                    else if jcc8_cc == 12 { write(fd, "jl 0x", 5) }
                    else if jcc8_cc == 13 { write(fd, "jge 0x", 6) }
                    else if jcc8_cc == 14 { write(fd, "jle 0x", 6) }
                    else { write(fd, "jg 0x", 5) }
                    write_hex8(fd, jcc8_off)
                    pos = pos + 2
                } else if b0 == 0xB8 && pos + 5 <= fn_end {
                    // mov eax, imm32
                    uint64 bp1 = bp + 1
                    uint64 bp2 = bp + 2
                    uint64 bp3 = bp + 3
                    uint64 bp4 = bp + 4
                    uint64 m0 = 0
                    uint64 m1 = 0
                    uint64 m2 = 0
                    uint64 m3 = 0
                    unsafe { *(bp1 as uint8) -> m0 }
                    unsafe { *(bp2 as uint8) -> m1 }
                    unsafe { *(bp3 as uint8) -> m2 }
                    unsafe { *(bp4 as uint8) -> m3 }
                    write_hex8(fd, b0)
                    write(fd, " ", 1)
                    write_hex8(fd, m0)
                    write(fd, " ", 1)
                    write_hex8(fd, m1)
                    write(fd, " ", 1)
                    write_hex8(fd, m2)
                    write(fd, " ", 1)
                    write_hex8(fd, m3)
                    write(fd, "     mov eax, 0x", 16)
                    uint64 mov_eax_imm = m0 | (m1 << 8) | (m2 << 16) | (m3 << 24)
                    write_hex32(fd, mov_eax_imm)
                    pos = pos + 5
                } else if (b0 == 0x4C) && pos + 3 <= fn_end {
                    // REX.WR prefix (r8-r15 in reg field) + mov r/m,r or mov r,r/m
                    uint64 bp1_c = bp + 1
                    uint64 b1_c = 0
                    unsafe { *(bp1_c as uint8) -> b1_c }
                    if (b1_c == 0x89 || b1_c == 0x8B) && pos + 3 <= fn_end {
                        uint64 bp2c = bp + 2
                        uint64 modrm_c = 0
                        unsafe { *(bp2c as uint8) -> modrm_c }
                        uint64 mod_c = (modrm_c >> 6) & 3
                        uint64 rm_c  = modrm_c & 7
                        uint64 reg_c = (modrm_c >> 3) & 7
                        uint64 extra_c = x86_modrm_extra(modrm_c)
                        uint64 tlen_c = 3 + extra_c
                        if pos + tlen_c > fn_end { tlen_c = fn_end - pos }
                        uint64 dbic = 0
                        while dbic < tlen_c {
                            uint64 dppc = bp + dbic
                            uint64 dbbc = 0
                            unsafe { *(dppc as uint8) -> dbbc }
                            write_hex8(fd, dbbc)
                            if dbic + 1 < tlen_c { write(fd, " ", 1) }
                            dbic = dbic + 1
                        }
                        write(fd, "  mov ", 6)
                        // REX.R → reg field (bit 3); REX.B would be 0x4D, unhandled here
                        // so rm stays 0..7 (rax..rdi), reg becomes r8..r15.
                        uint64 reg_hi = reg_c | 8
                        if mod_c == 3 {
                            if b1_c == 0x89 {
                                write_x86_reg64(fd, rm_c)
                                write(fd, ", ", 2)
                                write_x86_reg64(fd, reg_hi)
                            } else {
                                write_x86_reg64(fd, reg_hi)
                                write(fd, ", ", 2)
                                write_x86_reg64(fd, rm_c)
                            }
                        } else {
                            if b1_c == 0x89 {
                                write_x86_mem(fd, bp2c, 0)
                                write(fd, ", ", 2)
                                write_x86_reg64(fd, reg_hi)
                            } else {
                                write_x86_reg64(fd, reg_hi)
                                write(fd, ", ", 2)
                                write_x86_mem(fd, bp2c, 0)
                            }
                        }
                        pos = pos + tlen_c
                    } else {
                        // Unknown 4C-prefixed — dump 3 bytes raw
                        uint64 cnt_c = 3
                        if cnt_c + pos > fn_end { cnt_c = fn_end - pos }
                        uint64 dic = 0
                        while dic < cnt_c {
                            uint64 dpc = bp + dic
                            uint64 dbc = 0
                            unsafe { *(dpc as uint8) -> dbc }
                            write_hex8(fd, dbc)
                            write(fd, " ", 1)
                            dic = dic + 1
                        }
                        pos = pos + cnt_c
                    }
                } else if b0 == 0x48 && pos + 3 <= fn_end {
                    // REX.W instructions
                    uint64 bp1 = bp + 1
                    uint64 b1 = 0
                    unsafe { *(bp1 as uint8) -> b1 }
                    if b1 == 0xC7 && pos + 7 <= fn_end {
                        // REX.W mov r64, imm32: 48 C7 C0+reg imm32
                        uint64 bp2 = bp + 2
                        uint64 modrm = 0
                        unsafe { *(bp2 as uint8) -> modrm }
                        if modrm >= 0xC0 && modrm <= 0xC7 {
                            uint64 bp3 = bp + 3
                            uint64 bp4 = bp + 4
                            uint64 bp5 = bp + 5
                            uint64 bp6 = bp + 6
                            uint64 ri0 = 0
                            uint64 ri1 = 0
                            uint64 ri2 = 0
                            uint64 ri3 = 0
                            unsafe { *(bp3 as uint8) -> ri0 }
                            unsafe { *(bp4 as uint8) -> ri1 }
                            unsafe { *(bp5 as uint8) -> ri2 }
                            unsafe { *(bp6 as uint8) -> ri3 }
                            write_hex8(fd, b0)
                            write(fd, " ", 1)
                            write_hex8(fd, b1)
                            write(fd, " ", 1)
                            write_hex8(fd, modrm)
                            write(fd, " ", 1)
                            write_hex8(fd, ri0)
                            write(fd, " ", 1)
                            write_hex8(fd, ri1)
                            write(fd, " ", 1)
                            write_hex8(fd, ri2)
                            write(fd, " ", 1)
                            write_hex8(fd, ri3)
                            write(fd, " mov ", 5)
                            uint64 mov_reg = modrm - 0xC0
                            if mov_reg == 0 { write(fd, "rax", 3) }
                            else if mov_reg == 1 { write(fd, "rcx", 3) }
                            else if mov_reg == 2 { write(fd, "rdx", 3) }
                            else if mov_reg == 3 { write(fd, "rbx", 3) }
                            else if mov_reg == 4 { write(fd, "rsp", 3) }
                            else if mov_reg == 5 { write(fd, "rbp", 3) }
                            else if mov_reg == 6 { write(fd, "rsi", 3) }
                            else { write(fd, "rdi", 3) }
                            write(fd, ", 0x", 4)
                            uint64 mov_imm = ri0 | (ri1 << 8) | (ri2 << 16) | (ri3 << 24)
                            write_hex32(fd, mov_imm)
                            pos = pos + 7
                        } else {
                            // C7 with non-register modrm, dump 7 bytes raw
                            uint64 cnt = 7
                            if cnt + pos > fn_end { cnt = fn_end - pos }
                            uint64 di = 0
                            while di < cnt {
                                uint64 dp = bp + di
                                uint64 db = 0
                                unsafe { *(dp as uint8) -> db }
                                write_hex8(fd, db)
                                write(fd, " ", 1)
                                di = di + 1
                            }
                            pos = pos + cnt
                        }
                    } else if b1 == 0x81 && pos + 7 <= fn_end {
                        // REX.W op rsp, imm32: 48 81 EC/C4 imm32
                        uint64 bp2 = bp + 2
                        uint64 modrm81 = 0
                        unsafe { *(bp2 as uint8) -> modrm81 }
                        if modrm81 == 0xEC || modrm81 == 0xC4 {
                            uint64 bp3 = bp + 3
                            uint64 bp4 = bp + 4
                            uint64 bp5 = bp + 5
                            uint64 bp6 = bp + 6
                            uint64 si0 = 0
                            uint64 si1 = 0
                            uint64 si2 = 0
                            uint64 si3 = 0
                            unsafe { *(bp3 as uint8) -> si0 }
                            unsafe { *(bp4 as uint8) -> si1 }
                            unsafe { *(bp5 as uint8) -> si2 }
                            unsafe { *(bp6 as uint8) -> si3 }
                            write_hex8(fd, b0)
                            write(fd, " ", 1)
                            write_hex8(fd, b1)
                            write(fd, " ", 1)
                            write_hex8(fd, modrm81)
                            write(fd, " ", 1)
                            write_hex8(fd, si0)
                            write(fd, " ", 1)
                            write_hex8(fd, si1)
                            write(fd, " ", 1)
                            write_hex8(fd, si2)
                            write(fd, " ", 1)
                            write_hex8(fd, si3)
                            if modrm81 == 0xEC {
                                write(fd, " sub rsp, 0x", 12)
                            } else {
                                write(fd, " add rsp, 0x", 12)
                            }
                            uint64 sub_imm32 = si0 | (si1 << 8) | (si2 << 16) | (si3 << 24)
                            write_hex32(fd, sub_imm32)
                            pos = pos + 7
                        } else {
                            // 81 with other modrm, dump 7 bytes raw
                            uint64 cnt = 7
                            if cnt + pos > fn_end { cnt = fn_end - pos }
                            uint64 di = 0
                            while di < cnt {
                                uint64 dp = bp + di
                                uint64 db = 0
                                unsafe { *(dp as uint8) -> db }
                                write_hex8(fd, db)
                                write(fd, " ", 1)
                                di = di + 1
                            }
                            pos = pos + cnt
                        }
                    } else if b1 == 0x83 && pos + 4 <= fn_end {
                        // REX.W op rsp, imm8: 48 83 EC/C4 imm8
                        uint64 bp2 = bp + 2
                        uint64 modrm83 = 0
                        unsafe { *(bp2 as uint8) -> modrm83 }
                        if modrm83 == 0xEC || modrm83 == 0xC4 {
                            uint64 bp3 = bp + 3
                            uint64 si8 = 0
                            unsafe { *(bp3 as uint8) -> si8 }
                            write_hex8(fd, b0)
                            write(fd, " ", 1)
                            write_hex8(fd, b1)
                            write(fd, " ", 1)
                            write_hex8(fd, modrm83)
                            write(fd, " ", 1)
                            write_hex8(fd, si8)
                            if modrm83 == 0xEC {
                                write(fd, "        sub rsp, 0x", 19)
                            } else {
                                write(fd, "        add rsp, 0x", 19)
                            }
                            write_hex8(fd, si8)
                            pos = pos + 4
                        } else {
                            // 83 with other modrm, dump 4 bytes raw
                            uint64 cnt = 4
                            if cnt + pos > fn_end { cnt = fn_end - pos }
                            uint64 di = 0
                            while di < cnt {
                                uint64 dp = bp + di
                                uint64 db = 0
                                unsafe { *(dp as uint8) -> db }
                                write_hex8(fd, db)
                                write(fd, " ", 1)
                                di = di + 1
                            }
                            pos = pos + cnt
                        }
                    } else if b1 == 0x31 && pos + 3 <= fn_end {
                        // REX.W xor reg, reg: 48 31 XX
                        uint64 bp2 = bp + 2
                        uint64 modrm_xor = 0
                        unsafe { *(bp2 as uint8) -> modrm_xor }
                        write_hex8(fd, b0)
                        write(fd, " ", 1)
                        write_hex8(fd, b1)
                        write(fd, " ", 1)
                        write_hex8(fd, modrm_xor)
                        write(fd, "           xor ", 15)
                        // rm field = modrm & 0x07, reg field = (modrm >> 3) & 0x07
                        uint64 xor_rm = modrm_xor & 0x07
                        uint64 xor_reg = (modrm_xor >> 3) & 0x07
                        if xor_rm == 0 { write(fd, "rax", 3) }
                        else if xor_rm == 1 { write(fd, "rcx", 3) }
                        else if xor_rm == 2 { write(fd, "rdx", 3) }
                        else if xor_rm == 3 { write(fd, "rbx", 3) }
                        else if xor_rm == 4 { write(fd, "rsp", 3) }
                        else if xor_rm == 5 { write(fd, "rbp", 3) }
                        else if xor_rm == 6 { write(fd, "rsi", 3) }
                        else { write(fd, "rdi", 3) }
                        write(fd, ", ", 2)
                        if xor_reg == 0 { write(fd, "rax", 3) }
                        else if xor_reg == 1 { write(fd, "rcx", 3) }
                        else if xor_reg == 2 { write(fd, "rdx", 3) }
                        else if xor_reg == 3 { write(fd, "rbx", 3) }
                        else if xor_reg == 4 { write(fd, "rsp", 3) }
                        else if xor_reg == 5 { write(fd, "rbp", 3) }
                        else if xor_reg == 6 { write(fd, "rsi", 3) }
                        else { write(fd, "rdi", 3) }
                        pos = pos + 3
                    } else if b1 == 0x87 && pos + 3 <= fn_end {
                        // xchg reg, r/m
                        uint64 bp2x = bp + 2
                        uint64 modrm_x = 0
                        unsafe { *(bp2x as uint8) -> modrm_x }
                        uint64 extra_x = x86_modrm_extra(modrm_x)
                        uint64 tlen_x = 3 + extra_x
                        if pos + tlen_x > fn_end { tlen_x = fn_end - pos }
                        uint64 dbi_x = 0
                        while dbi_x < tlen_x {
                            uint64 dp_x = bp + dbi_x
                            uint64 db_x = 0
                            unsafe { *(dp_x as uint8) -> db_x }
                            write_hex8(fd, db_x)
                            if dbi_x + 1 < tlen_x { write(fd, " ", 1) }
                            dbi_x = dbi_x + 1
                        }
                        write(fd, "  xchg ", 7)
                        uint64 xch_reg = (modrm_x >> 3) & 7
                        write_x86_reg64(fd, xch_reg)
                        write(fd, ", ", 2)
                        if (modrm_x >> 6) == 3 {
                            write_x86_reg64(fd, modrm_x & 7)
                        } else {
                            write_x86_mem(fd, bp2x, 0)
                        }
                        pos = pos + tlen_x
                    } else if (b1 == 0x01 || b1 == 0x29) && pos + 3 <= fn_end {
                        // 0x01 = add r/m, reg ; 0x29 = sub r/m, reg
                        uint64 bp2a = bp + 2
                        uint64 modrm_a = 0
                        unsafe { *(bp2a as uint8) -> modrm_a }
                        uint64 extra_a = x86_modrm_extra(modrm_a)
                        uint64 tlen_a = 3 + extra_a
                        if pos + tlen_a > fn_end { tlen_a = fn_end - pos }
                        uint64 dbi_a = 0
                        while dbi_a < tlen_a {
                            uint64 dp_a = bp + dbi_a
                            uint64 db_a = 0
                            unsafe { *(dp_a as uint8) -> db_a }
                            write_hex8(fd, db_a)
                            if dbi_a + 1 < tlen_a { write(fd, " ", 1) }
                            dbi_a = dbi_a + 1
                        }
                        if b1 == 0x01 { write(fd, "  add ", 6) }
                        else           { write(fd, "  sub ", 6) }
                        if (modrm_a >> 6) == 3 {
                            write_x86_reg64(fd, modrm_a & 7)
                        } else {
                            write_x86_mem(fd, bp2a, 0)
                        }
                        write(fd, ", ", 2)
                        write_x86_reg64(fd, (modrm_a >> 3) & 7)
                        pos = pos + tlen_a
                    } else if b1 == 0x0F && pos + 4 <= fn_end {
                        // Two-byte opcode under REX.W
                        uint64 bp2o = bp + 2
                        uint64 b2 = 0
                        unsafe { *(bp2o as uint8) -> b2 }
                        if b2 == 0xAF && pos + 4 <= fn_end {
                            // imul reg, r/m
                            uint64 bp3o = bp + 3
                            uint64 modrm_im = 0
                            unsafe { *(bp3o as uint8) -> modrm_im }
                            uint64 extra_im = x86_modrm_extra(modrm_im)
                            uint64 tlen_im = 4 + extra_im
                            if pos + tlen_im > fn_end { tlen_im = fn_end - pos }
                            uint64 dbi2 = 0
                            while dbi2 < tlen_im {
                                uint64 dpp2 = bp + dbi2
                                uint64 dbb2 = 0
                                unsafe { *(dpp2 as uint8) -> dbb2 }
                                write_hex8(fd, dbb2)
                                if dbi2 + 1 < tlen_im { write(fd, " ", 1) }
                                dbi2 = dbi2 + 1
                            }
                            write(fd, "  imul ", 7)
                            uint64 im_reg = (modrm_im >> 3) & 7
                            write_x86_reg64(fd, im_reg)
                            write(fd, ", ", 2)
                            if (modrm_im >> 6) == 3 {
                                write_x86_reg64(fd, modrm_im & 7)
                            } else {
                                write_x86_mem(fd, bp3o, 0)
                            }
                            pos = pos + tlen_im
                        } else {
                            // Other 0F xx under REX.W — dump 4 bytes raw
                            uint64 cnt_o = 4
                            if cnt_o + pos > fn_end { cnt_o = fn_end - pos }
                            uint64 di_o = 0
                            while di_o < cnt_o {
                                uint64 dp_o = bp + di_o
                                uint64 db_o = 0
                                unsafe { *(dp_o as uint8) -> db_o }
                                write_hex8(fd, db_o)
                                write(fd, " ", 1)
                                di_o = di_o + 1
                            }
                            pos = pos + cnt_o
                        }
                    } else if (b1 == 0x89 || b1 == 0x8B) && pos + 3 <= fn_end {
                        // REX.W mov  — 0x89 = mov r/m, reg (store direction)
                        //               0x8B = mov reg, r/m (load direction)
                        // ModR/M: mod:2, reg:3, rm:3.
                        // mod==3 → reg-reg (3 bytes total)
                        // mod!=3 → memory operand; rm==4 adds SIB;
                        //          mod==1 adds disp8; mod==2 adds disp32;
                        //          mod==0 && rm==5 is RIP-relative disp32.
                        uint64 bp2 = bp + 2
                        uint64 modrm_mov = 0
                        unsafe { *(bp2 as uint8) -> modrm_mov }
                        uint64 mod_f = (modrm_mov >> 6) & 3
                        uint64 rm_f  = modrm_mov & 7
                        uint64 reg_f = (modrm_mov >> 3) & 7
                        // Compute number of bytes after ModR/M
                        uint64 extra = 0
                        if mod_f != 3 {
                            if rm_f == 4 { extra = extra + 1 }   // SIB
                            if mod_f == 1 { extra = extra + 1 }  // disp8
                            if mod_f == 2 { extra = extra + 4 }  // disp32
                            if mod_f == 0 && rm_f == 5 { extra = extra + 4 }  // rip+disp32
                        }
                        uint64 total_len = 3 + extra
                        if pos + total_len > fn_end { total_len = fn_end - pos }
                        // Dump raw bytes (space-separated)
                        uint64 dbi = 0
                        while dbi < total_len {
                            uint64 dpp = bp + dbi
                            uint64 dbb = 0
                            unsafe { *(dpp as uint8) -> dbb }
                            write_hex8(fd, dbb)
                            if dbi + 1 < total_len { write(fd, " ", 1) }
                            dbi = dbi + 1
                        }
                        write(fd, "  mov ", 6)
                        if mod_f == 3 {
                            // reg-reg: "mov <rm>, <reg>" for 0x89; "mov <reg>, <rm>" for 0x8B
                            uint64 left = rm_f
                            uint64 right = reg_f
                            if b1 == 0x8B { left = reg_f; right = rm_f }
                            if left == 0 { write(fd, "rax", 3) }
                            else if left == 1 { write(fd, "rcx", 3) }
                            else if left == 2 { write(fd, "rdx", 3) }
                            else if left == 3 { write(fd, "rbx", 3) }
                            else if left == 4 { write(fd, "rsp", 3) }
                            else if left == 5 { write(fd, "rbp", 3) }
                            else if left == 6 { write(fd, "rsi", 3) }
                            else { write(fd, "rdi", 3) }
                            write(fd, ", ", 2)
                            if right == 0 { write(fd, "rax", 3) }
                            else if right == 1 { write(fd, "rcx", 3) }
                            else if right == 2 { write(fd, "rdx", 3) }
                            else if right == 3 { write(fd, "rbx", 3) }
                            else if right == 4 { write(fd, "rsp", 3) }
                            else if right == 5 { write(fd, "rbp", 3) }
                            else if right == 6 { write(fd, "rsi", 3) }
                            else { write(fd, "rdi", 3) }
                        } else {
                            // Memory operand. Resolve base register (SIB if rm==4).
                            uint64 base_r = rm_f
                            uint64 disp_ofs = 3
                            if rm_f == 4 {
                                uint64 bp_s = bp + 3
                                uint64 sib_b = 0
                                unsafe { *(bp_s as uint8) -> sib_b }
                                base_r = sib_b & 7
                                disp_ofs = 4
                            }
                            if b1 == 0x89 {
                                // store: mov [base+disp], reg
                                write(fd, "[", 1)
                            } else {
                                // load: mov reg, [base+disp]
                                if reg_f == 0 { write(fd, "rax", 3) }
                                else if reg_f == 1 { write(fd, "rcx", 3) }
                                else if reg_f == 2 { write(fd, "rdx", 3) }
                                else if reg_f == 3 { write(fd, "rbx", 3) }
                                else if reg_f == 4 { write(fd, "rsp", 3) }
                                else if reg_f == 5 { write(fd, "rbp", 3) }
                                else if reg_f == 6 { write(fd, "rsi", 3) }
                                else { write(fd, "rdi", 3) }
                                write(fd, ", [", 3)
                            }
                            if mod_f == 0 && rm_f == 5 {
                                write(fd, "rip", 3)
                            } else if base_r == 0 { write(fd, "rax", 3) }
                            else if base_r == 1 { write(fd, "rcx", 3) }
                            else if base_r == 2 { write(fd, "rdx", 3) }
                            else if base_r == 3 { write(fd, "rbx", 3) }
                            else if base_r == 4 { write(fd, "rsp", 3) }
                            else if base_r == 5 { write(fd, "rbp", 3) }
                            else if base_r == 6 { write(fd, "rsi", 3) }
                            else { write(fd, "rdi", 3) }
                            if mod_f == 1 {
                                write(fd, "+0x", 3)
                                uint64 bp_d = bp + disp_ofs
                                uint64 d8v = 0
                                unsafe { *(bp_d as uint8) -> d8v }
                                write_hex8(fd, d8v)
                            } else if mod_f == 2 || (mod_f == 0 && rm_f == 5) {
                                write(fd, "+0x", 3)
                                uint64 bp_d0 = bp + disp_ofs
                                uint64 bp_d1 = bp + disp_ofs + 1
                                uint64 bp_d2 = bp + disp_ofs + 2
                                uint64 bp_d3 = bp + disp_ofs + 3
                                uint64 d32_0 = 0
                                uint64 d32_1 = 0
                                uint64 d32_2 = 0
                                uint64 d32_3 = 0
                                unsafe { *(bp_d0 as uint8) -> d32_0 }
                                unsafe { *(bp_d1 as uint8) -> d32_1 }
                                unsafe { *(bp_d2 as uint8) -> d32_2 }
                                unsafe { *(bp_d3 as uint8) -> d32_3 }
                                uint64 d32 = d32_0 | (d32_1 << 8) | (d32_2 << 16) | (d32_3 << 24)
                                write_hex32(fd, d32)
                            }
                            if b1 == 0x89 {
                                write(fd, "], ", 3)
                                if reg_f == 0 { write(fd, "rax", 3) }
                                else if reg_f == 1 { write(fd, "rcx", 3) }
                                else if reg_f == 2 { write(fd, "rdx", 3) }
                                else if reg_f == 3 { write(fd, "rbx", 3) }
                                else if reg_f == 4 { write(fd, "rsp", 3) }
                                else if reg_f == 5 { write(fd, "rbp", 3) }
                                else if reg_f == 6 { write(fd, "rsi", 3) }
                                else { write(fd, "rdi", 3) }
                            } else {
                                write(fd, "]", 1)
                            }
                        }
                        pos = pos + total_len
                    } else if b1 == 0x8D && pos + 3 <= fn_end {
                        // LEA reg, [mem]: 48 8D <modrm> [sib] [disp]
                        uint64 bp2 = bp + 2
                        uint64 modrm_lea = 0
                        unsafe { *(bp2 as uint8) -> modrm_lea }
                        uint64 extra_lea = x86_modrm_extra(modrm_lea)
                        uint64 total_len = 3 + extra_lea
                        if pos + total_len > fn_end { total_len = fn_end - pos }
                        uint64 dbi = 0
                        while dbi < total_len {
                            uint64 dpp = bp + dbi
                            uint64 dbb = 0
                            unsafe { *(dpp as uint8) -> dbb }
                            write_hex8(fd, dbb)
                            if dbi + 1 < total_len { write(fd, " ", 1) }
                            dbi = dbi + 1
                        }
                        write(fd, "  lea ", 6)
                        uint64 lea_reg = (modrm_lea >> 3) & 7
                        write_x86_reg64(fd, lea_reg)
                        write(fd, ", ", 2)
                        write_x86_mem(fd, bp2, 0)
                        pos = pos + total_len
                    } else {
                        // Other REX.W instructions — dump with byte count heuristic
                        uint64 cnt = 3
                        if b1 == 0x8B { cnt = 3 }
                        else if b1 >= 0x00 && b1 <= 0x3F { cnt = 3 }
                        if cnt + pos > fn_end { cnt = fn_end - pos }
                        uint64 di = 0
                        while di < cnt {
                            uint64 dp = bp + di
                            uint64 db = 0
                            unsafe { *(dp as uint8) -> db }
                            write_hex8(fd, db)
                            write(fd, " ", 1)
                            di = di + 1
                        }
                        pos = pos + cnt
                    }
                } else {
                    // Generic: dump 1 byte per line for simple format
                    uint64 cnt = 1
                    // REX prefix? Read more bytes
                    if b0 >= 0x40 && b0 <= 0x4F { cnt = 2 }
                    if b0 == 0x49 {
                        uint64 bp1 = bp + 1
                        uint64 b1 = 0
                        unsafe { *(bp1 as uint8) -> b1 }
                        if b1 == 0xC7 { cnt = 7 }
                        else if b1 == 0x89 || b1 == 0x8B { cnt = 3 }
                        else if b1 == 0x81 { cnt = 7 }
                        else if b1 == 0x83 { cnt = 4 }
                        else if b1 == 0x31 { cnt = 3 }
                        else { cnt = 3 }
                    }
                    if b0 == 0xB9 || b0 == 0xBA { cnt = 5 }
                    if cnt + pos > fn_end { cnt = fn_end - pos }
                    uint64 di = 0
                    while di < cnt {
                        uint64 dp = bp + di
                        uint64 db = 0
                        unsafe { *(dp as uint8) -> db }
                        write_hex8(fd, db)
                        write(fd, " ", 1)
                        di = di + 1
                    }
                    pos = pos + cnt
                }
                write(fd, "\n", 1)
            }
        }
        fi = fi + 1
    }
    file_close(fd)
}

// time_ns — monotonic nanoseconds. Recognized as a built-in by krc ≥ 2.6.2
// (emits inline clock_gettime on Linux x86_64). This fallback body exists
// only so that pre-2.6.2 compilers can resolve the symbol during bootstrap;
// in the new compiler the built-in dispatch matches first and this body is
// never reached.
fn time_ns() -> uint64 {
    return 0
}

// arch: 0=x86_64, 1=arm64
// emit: 0=elfexe, 1=machoexe, 2=peexe, 3=obj (ELF relocatable), 5=asm listing, 6=ir dump
fn compile(uint64 input_path, uint64 output_path, uint64 arch, uint64 emit_mode) {
    uint64 t_start = time_ns()
    set_target_arch(arch)
    import_init()
    import_check_file(input_path)
    import_process(input_path)
    uint64 source = import_buf
    uint64 size = import_buf_len

    uint64 max_tok = 524288
    uint64 my_tokens = alloc(max_tok * 16)
    lexer_init(source, size, my_tokens, max_tok)
    uint64 tcount = lexer_run()

    ast_init(524288)
    codegen_init(4194304, source, my_tokens)
    parser_init(my_tokens, tcount)
    uint64 root = parse_module()

    // Semantic validation: check arg counts, missing returns, duplicate functions
    uint64 sema_errs = run_semantic_checks(root, source, my_tokens)
    diag_report_all()
    if sema_errs != 0 {
        uint8[24] ebuf
        uint64 elen = fmt_uint(ebuf, sema_errs)
        write(2, ebuf, elen)
        write(2, " error(s) found\n", 16)
        exit(1)
    }

    // @dynamic extern fn count: the parser registered these in
    // format_elf_dyn.kr's symbol table. Until M2a.3/M2a.4 actually
    // emit a dynamic ELF, report the count so the frontend plumbing
    // is observable in isolation.
    uint64 dyn_n = dyn_sym_count_get()
    if dyn_n > 0 {
        uint8[24] dn_buf
        uint64 dn_len = fmt_uint(dn_buf, dyn_n)
        write(2, "mlrc: registered ", 17)
        write(2, dn_buf, dn_len)
        write(2, " @dynamic symbol(s)\n", 20)
    }

    // GPU target: emit a `<output>.hip` side-file for every @kernel fn,
    // then fork hipcc to compile it into a `.co` code object. The CPU
    // binary is still produced (host side is hand-written C during
    // phase 1 per docs/GPU_BACKEND.md).
    if target_gpu != 0 {
        uint64 hrc = emit_hip_artifacts(root, source, output_path)
        if hrc == 1 {
            write(2, "mlrc: --target=hip-amd but no @kernel functions found\n", 55)
        } else if hrc == 2 {
            write(2, "mlrc: failed to write HIP side-file\n", 36)
            exit(1)
        } else {
            uint64 opl = str_len(output_path)
            write(1, "wrote ", 6)
            write(1, output_path, opl)
            write(1, ".hip (", 6)
            uint8[24] hbuf
            uint64 hln = fmt_uint(hbuf, emit_hip_len())
            write(1, hbuf, hln)
            write(1, " bytes)\n", 8)

            // Fork + run hipcc on the just-written .hip file.
            uint64 cc = invoke_hipcc(output_path)
            if cc == 0 {
                write(1, "wrote ", 6)
                write(1, output_path, opl)
                write(1, ".co\n", 4)
            } else if cc >= 1000 {
                // invoke_hipcc already printed a diagnostic
                exit(1)
            } else {
                write(2, "mlrc: hipcc exited with status ", 31)
                uint8[24] cbuf
                uint64 cln = fmt_uint(cbuf, cc)
                write(2, cbuf, cln)
                write(2, "\n", 1)
                exit(1)
            }
        }
    }

    // Stage-1 native AMDGPU path (M1d): same slot as --target=hip-amd
    // but driven by our own emitter. Produces <output_path>.co. Current
    // lowering only recognises the narrow sentinel-kernel shape (one
    // uint64 arg, body = one u32 PtrStore of an IntLit); every other
    // shape prints a diagnostic and exits.
    if target_amdgpu_native != 0 {
        uint64 co_suffix = ".co"
        uint64 opl_an = str_len(output_path)
        uint8[1024] co_path_buf
        uint64 ai_cp = 0
        while ai_cp < opl_an {
            uint64 sp = output_path + ai_cp
            uint64 b = 0
            unsafe { *(sp as uint8) -> b }
            uint64 dp = co_path_buf + ai_cp
            uint8 b8 = b
            unsafe { *(dp as uint8) = b8 }
            ai_cp = ai_cp + 1
        }
        // Append ".co\0"
        uint64 dpa = co_path_buf + opl_an
        uint8 dot = 46;  unsafe { *(dpa as uint8) = dot }
        uint64 dpb = co_path_buf + opl_an + 1
        uint8 cc1 = 99;  unsafe { *(dpb as uint8) = cc1 }
        uint64 dpc = co_path_buf + opl_an + 2
        uint8 co1 = 111; unsafe { *(dpc as uint8) = co1 }
        uint64 dpd = co_path_buf + opl_an + 3
        uint8 z   = 0;   unsafe { *(dpd as uint8) = z }

        uint64 anrc = emit_amdgpu_from_module(root, source, co_path_buf)
        if anrc == 3 {
            // No @kernel functions: this is a launcher-only source
            // (kernel .co is being emitted separately via
            // --emit-amdgpu-<flag>=). Don't error — the import_resolve
            // hook has already routed std/hip.mlr through the KFD
            // shim, so the launcher we are about to compile will
            // dispatch via raw KFD ioctls regardless.
        } else if anrc == 1 {
            // emit_amdgpu_from_module already printed a pointed-at-shape
            // diagnostic pointing at the offending kernel.
            exit(1)
        } else if anrc == 2 {
            write(2, "mlrc: failed to write .co for --target=amdgpu-native\n", 53)
            exit(1)
        }
        if anrc == 0 {
            write(1, "wrote ", 6)
            write(1, co_path_buf, opl_an + 3)
            write(1, " (native amdgpu code object)\n", 29)
        }
    }

    // Inliner: fold pure single-expression callees into their call
    // sites so DCE can drop the originals (executable emit modes).
    // Translation-unit emit modes (.o / asm / IR dump) keep every
    // top-level fn live so the original definitions still appear in
    // the output.
    inline_pass(root)

    // Dead code elimination: scan AST for reachable functions
    dce_init()
    if emit_mode == 3 || emit_mode == 5 || emit_mode == 6 {
        dce_set_keep_all(1)
    }
    dce_scan(root)

    // IR dump: lower each function to IR and print, then exit early
    if emit_mode == 6 {
        ir_init()
        uint32 child = ast_child(root)
        uint64 wchild = child
        while wchild != 0 {
            uint32 ck = ast_kind(wchild)
            if ck == 2 {
                uint32 fn_name = ast_data1(wchild)
                if dce_is_live(fn_name) != 0 {
                    uint64 ns = tok_text_start(fn_name)
                    uint64 nl = tok_text_len(fn_name)
                    write(1, "function ", 9)
                    write(1, source + ns, nl)
                    write(1, ":\n", 2)
                    ir_lower_function(wchild)
                    ir_dump()
                    write(1, "\n", 1)
                }
            }
            uint32 nxt = ast_next(wchild)
            wchild = nxt
        }
        // Print summary
        uint8[64] nb
        uint64 tl = fmt_uint(nb, tcount)
        write(1, nb, tl)
        write(1, " tokens, ", 9)
        uint64 nl2 = fmt_uint(nb, ast_count)
        write(1, nb, nl2)
        write(1, " nodes -> IR dump\n", 18)
        exit(0)
    }

    // Emit headers based on format (skip for .o — code goes at offset 0)
    uint64 header_size = 120
    if emit_mode == 0 {
        // ELF
        if arch == 0 {
            emit_elf_header()
        } else {
            emit_elf_header_a64()
        }
        emit_program_header(0)
    } else if emit_mode == 1 {
        // Mach-O
        if arch == 0 {
            header_size = emit_macho_headers_x64(0)
        } else {
            header_size = emit_macho_headers_a64(0)
        }
    } else if emit_mode == 2 {
        // PE
        if arch == 0 {
            header_size = emit_pe_headers_x64(0)
        } else {
            header_size = emit_pe_headers_a64(0)
        }
    } else if emit_mode == 3 {
        // ELF relocatable (.o) — no header at start, code goes at offset 0
        header_size = 0
    } else if emit_mode == 4 {
        // Android PIE ELF (ARM64 or x86_64)
        if arch == 0 {
            emit_elf_header_android_x86_64()
        } else {
            emit_elf_header_android_a64()
        }
        header_size = 1024
    } else if emit_mode == 5 {
        // ASM listing — no header, code at offset 0
        header_size = 0
    }

    uint64 text_start = codegen_output_len()

    // Generate code for each function (skip dead functions via DCE)
    uint32 child = ast_child(root)
    uint64 wchild = child
    while wchild != 0 {
        uint32 ck = ast_kind(wchild)
        if ck == 2 {
            uint32 fn_name = ast_data1(wchild)
            if dce_is_live(fn_name) != 0 {
                if emit_ir_mode != 0 && arch == 0 && emit_mode != 3 {
                    // IR codegen (skip for --emit=obj which needs legacy for extern relocations)
                    fn_register(fn_name, out_len)
                    // Record a DWARF line-table entry at the function's
                    // entry address so GDB can correlate `break <name>`
                    // with the first source line.
                    line_table_record_fn_entry(fn_name)
                    ir_init()
                    ir_emit_x86_function(wchild)
                } else if emit_ir_mode != 0 && arch == 1 && emit_mode != 3 {
                    // IR codegen ARM64 (default; --legacy bypasses)
                    fn_register(fn_name, out_len)
                    line_table_record_fn_entry(fn_name)
                    ir_init()
                    ir_emit_arm64_function(wchild)
                } else if arch == 0 {
                    // Legacy x86: gen_function registers internally.
                    // Record the entry-address line first so DWARF sees it.
                    line_table_record_fn_entry(fn_name)
                    gen_function(wchild)
                } else {
                    // Legacy ARM64: gen_function_a64 registers internally.
                    line_table_record_fn_entry(fn_name)
                    gen_function_a64(wchild)
                }
            }
        }
        uint32 nxt = ast_next(wchild)
        wchild = nxt
    }

    // Resolve call fixups
    if arch == 0 {
        resolve_fixups()
        resolve_fnaddr_fixups()
        resolve_teardown_fixups()
    } else {
        resolve_fixups_a64()
        resolve_fnaddr_fixups_a64()
    }

    // Emit string data BEFORE static data so trailing zero bytes from
    // uninitialised static arrays end up at the tail of the file — the
    // BSS optimisation below can then truncate them. (Ordering affects
    // only byte layout; resolve_*_fixups is called with its start
    // offset so either order works.)
    // Align to 8 bytes on arm64 first so the 64-bit LDR (imm12 scaled
    // by 8) can encode any slot offset exactly — without padding, a
    // static at a non-8-aligned offset silently rounds down and reads
    // trailing code bytes instead of its own value.
    if arch == 1 {
        while (codegen_output_len() & 7) != 0 { emit_byte(0) }
    }
    uint64 str_start = codegen_output_len()
    emit_string_data()
    if arch == 0 {
        resolve_string_fixups(str_start)
    } else {
        resolve_string_fixups_a64(str_start)
    }
    // Re-align to 8 bytes on arm64 between strings and statics.
    if arch == 1 {
        while (codegen_output_len() & 7) != 0 { emit_byte(0) }
    }
    uint64 data_start = codegen_output_len()
    emit_static_data()
    // In the dyn-ELF path, static data is relocated into the RW .data
    // section so mutations don't fault on the RX code page. Defer
    // fixup resolution to the dyn-ELF branch in that case — calling
    // resolve_static_fixups here would point the disps at the RX copy
    // and leave the RW copy unreachable.
    uint64 dyn_elf_active = 0
    if dyn_sym_count_get() > 0 {
        if emit_mode == 0 { dyn_elf_active = 1 }
    }
    if dyn_elf_active == 0 {
        if arch == 0 {
            resolve_static_fixups(data_start)
        } else {
            resolve_static_fixups_a64(data_start)
        }
    }

    uint64 text_size = codegen_output_len() - text_start

    // For .o relocatable, pick format from target_os:
    //   0 linux  → ELF
    //   1 macOS  → Mach-O
    //   2 win    → COFF (PE object)
    //   3 android → ELF
    //   4 freebsd → ELF
    if emit_mode == 3 {
        uint64 total_code = codegen_output_len()
        if target_os == 1 {
            emit_macho_relocatable(total_code, 0, arch)
        } else if target_os == 2 {
            emit_coff_relocatable(total_code, 0, arch)
        } else {
            emit_elf_relocatable(total_code, 0, arch)
        }
        codegen_write_output(output_path)

        uint8[64] nb
        uint64 tl = fmt_uint(nb, tcount)
        write(1, nb, tl)
        uint64 msg = " tokens, "
        write(1, msg, 9)
        uint64 al = fmt_uint(nb, ast_count)
        write(1, nb, al)
        msg = " nodes, "
        write(1, msg, 8)
        uint64 cl = fmt_uint(nb, text_size)
        write(1, nb, cl)
        msg = " bytes -> "
        write(1, msg, 10)
        uint64 olen = str_len(output_path)
        write(1, output_path, olen)
        msg = " (relocatable)\n"
        write(1, msg, 15)
        return
    }

    // For ASM listing, output text disassembly
    if emit_mode == 5 {
        emit_asm_listing(output_path, arch, text_start, source, 0)

        uint8[64] nb
        uint64 tl = fmt_uint(nb, tcount)
        write(1, nb, tl)
        uint64 msg = " tokens, "
        write(1, msg, 9)
        uint64 al = fmt_uint(nb, ast_count)
        write(1, nb, al)
        msg = " nodes, "
        write(1, msg, 8)
        uint64 cl = fmt_uint(nb, text_size)
        write(1, nb, cl)
        msg = " bytes -> "
        write(1, msg, 10)
        uint64 olen = str_len(output_path)
        write(1, output_path, olen)
        msg = " (asm listing)\n"
        write(1, msg, 15)
        return
    }

    // Patch headers
    uint64 entry_off = find_main_offset()
    if entry_off == 0xFFFFFFFF {
        write(2, "error: no 'main' function found\n", 32)
        write(2, "Every KernRift program needs: fn main() { ... }\n", 49)
        exit(1)
    }

    // Dynamic-linked ELF path (M2a.4, refined by M2b.3): when the module
    // declares one or more `@dynamic extern fn`, hand the output off to
    // format_elf_dyn instead of the static-ELF header-patching path. We
    // prepend a glibc-compatible _start stub that calls __libc_start_main
    // (see edyn_write_start_stub) so libstdc++/libamdhip64's .init_array
    // constructors fire and TLS/stdio end up fully initialised before
    // user main() runs.
    if dyn_sym_count_get() > 0 && emit_mode == 0 {
        uint64 text_start_dyn = header_size            // 120 for elfexe
        // Exclude the static-data bytes that emit_static_data wrote
        // after the code — those will live in the RW segment's .data
        // tail, not RX. `data_start` is the byte offset inside the
        // codegen buffer where those bytes begin.
        uint64 sdata_size_dyn = codegen_static_data_size_get()
        uint64 text_len_orig = (data_start - text_start_dyn)
        uint64 main_off_orig = entry_off - text_start_dyn

        // Combined .text layout: [stub_size bytes of _start] + [original
        // codegen output]. main() ends up at stub_size + main_off_orig.
        uint64 stub_size = edyn_start_stub_size()
        uint64 text_len_dyn = stub_size + text_len_orig
        uint64 main_off_in_text = stub_size + main_off_orig

        // Build extended sym_list: existing @dynamic syms then the
        // synthesised __libc_start_main entry that the stub needs.
        uint64 nsym_user = dyn_sym_count_get()
        uint64 nsym_ext = nsym_user + 1
        uint64 lsm_idx = nsym_user                     // slot for libc_start_main
        uint64 sym_list = alloc(nsym_ext * 16)
        uint64 si_dyn = 0
        while si_dyn < nsym_user {
            uint32 nt_dyn = dyn_sym_tok_at(si_dyn)
            uint64 wnt = nt_dyn
            uint64 ts = tok_text_start(wnt)
            uint64 tl = tok_text_len(wnt)
            uint64 slot_a = sym_list + si_dyn * 16
            uint64 name_addr = source + ts
            unsafe { *(slot_a as uint64) = name_addr }
            uint64 slot_b = sym_list + si_dyn * 16 + 8
            unsafe { *(slot_b as uint64) = tl }
            si_dyn = si_dyn + 1
        }
        uint64 lsm_name = "__libc_start_main"
        uint64 lsm_slot = sym_list + lsm_idx * 16
        unsafe { *(lsm_slot as uint64) = lsm_name }
        uint64 lsm_slot_len = lsm_slot + 8
        uint64 lsm_len = 17
        unsafe { *(lsm_slot_len as uint64) = lsm_len }

        // Library list: libc.so.6 always, libm.so.6 when any @dynamic
        // symbol uses the libm float ABI (set by parser when the name
        // matches a known libm function — see dyn_sym_any_libm), and
        // libamdhip64.so.7 when any @dynamic symbol name starts with
        // "hip". Order: libc, libm, libhip — DT_NEEDED is searched in
        // this order at load time.
        uint64 add_hip  = dyn_sym_any_hip_prefix()
        uint64 add_libm = dyn_sym_any_libm()
        uint64 lib_count = 1
        if add_libm != 0 { lib_count = lib_count + 1 }
        if add_hip  != 0 { lib_count = lib_count + 1 }
        uint64 lib_list = alloc(lib_count * 16)
        uint64 lib_off = 0
        uint64 libc_s = "libc.so.6"
        unsafe { *((lib_list + lib_off + 0) as uint64) = libc_s }
        uint64 libc_l = 9
        unsafe { *((lib_list + lib_off + 8) as uint64) = libc_l }
        lib_off = lib_off + 16
        if add_libm != 0 {
            uint64 libm_s = "libm.so.6"
            unsafe { *((lib_list + lib_off + 0) as uint64) = libm_s }
            uint64 libm_l = 9
            unsafe { *((lib_list + lib_off + 8) as uint64) = libm_l }
            lib_off = lib_off + 16
        }
        if add_hip != 0 {
            uint64 libhip_s = "libamdhip64.so.7"
            unsafe { *((lib_list + lib_off + 0) as uint64) = libhip_s }
            uint64 libhip_l = 16
            unsafe { *((lib_list + lib_off + 8) as uint64) = libhip_l }
            lib_off = lib_off + 16
        }

        // Build the combined text: stub bytes ahead of codegen's text.
        uint64 combined_text = alloc(text_len_dyn + 64)
        edyn_write_start_stub(combined_text, main_off_in_text)
        uint64 cg_buf = codegen_buf_ptr()
        memcpy(combined_text + stub_size, cg_buf + text_start_dyn, text_len_orig)

        // Tell the dyn-ELF layout about the writable static data so
        // it reserves space inside the RW segment. emit_static_data
        // already serialized the bytes at cg_buf + data_start above;
        // we just point the emitter at them.
        if sdata_size_dyn > 0 {
            edyn_set_data(cg_buf + data_start, sdata_size_dyn)
        }

        // Pass 1: compute layout so va_text + plt_va(i) are known.
        edyn_compute_dyn_layout_for(lib_list, lib_count, sym_list, nsym_ext, text_len_dyn)

        // Pass 2: patch the original recorded @dynamic call sites. Each
        // code_off in dyn_call_sites is an out_buf absolute offset; in
        // combined_text the same call lives at (code_off - text_start +
        // stub_size), which means passing text_start - stub_size as the
        // patcher's code_off_base.
        uint64 base = text_start_dyn - stub_size
        edyn_patch_dyn_calls(combined_text, base)

        // Pass 2b: resolve static-variable RIP-relative fixups. Each
        // entry's code_off is out_buf-relative, data_off is an offset
        // inside the static-data blob; edyn_patch_static_fixup
        // rewrites the 4-byte disp placeholder in combined_text so
        // the load/store reaches edyn_va_data + data_off in RW.
        uint64 sfx_n = codegen_static_fixup_count_get()
        uint64 sfi = 0
        while sfi < sfx_n {
            uint64 sfx_co = codegen_static_fixup_code_off_at(sfi)
            uint64 sfx_do = codegen_static_fixup_data_off_at(sfi)
            edyn_patch_static_fixup(combined_text, base, sfx_co, sfx_do)
            sfi = sfi + 1
        }

        // Pass 3: patch the stub's own `call __libc_start_main@plt`
        // rel32 now that edyn_sym_plt_va() is valid.
        uint64 stub_call_off = edyn_start_stub_call_rel32_off()
        uint64 stub_call_rip_after = edyn_va_text + stub_call_off + 4
        uint64 lsm_plt_va = edyn_sym_plt_va(lsm_idx)
        uint64 lsm_rel32 = (lsm_plt_va - stub_call_rip_after) & 0xFFFFFFFF
        uint64 rb0 = combined_text + stub_call_off
        uint8 rlsm0 = lsm_rel32 & 0xFF
        unsafe { *(rb0 as uint8) = rlsm0 }
        uint64 rb1 = rb0 + 1
        uint8 rlsm1 = (lsm_rel32 >> 8) & 0xFF
        unsafe { *(rb1 as uint8) = rlsm1 }
        uint64 rb2 = rb0 + 2
        uint8 rlsm2 = (lsm_rel32 >> 16) & 0xFF
        unsafe { *(rb2 as uint8) = rlsm2 }
        uint64 rb3 = rb0 + 3
        uint8 rlsm3 = (lsm_rel32 >> 24) & 0xFF
        unsafe { *(rb3 as uint8) = rlsm3 }

        // Pass 4: emit the dynamic ELF into edyn_buf.
        uint64 elf_size = emit_dynamic_elf(lib_list, lib_count,
                                            sym_list, nsym_ext,
                                            combined_text, text_len_dyn,
                                            0)

        // Flush edyn_buf to output_path, bypassing the normal
        // codegen_write_output (which would write the static-ELF
        // bytes sitting in out_buf).
        uint64 ofd = file_open(output_path, 1)
        if ofd > 0xFFFFFFFFFFFFF000 {
            write(2, "error: failed to open output\n", 29)
            exit(1)
        }
        file_write(ofd, edyn_buf_ptr(), elf_size)
        file_close(ofd)
        set_executable(output_path)

        // Stats line + dyn-call report (matches the normal codepath's format)
        uint64 dcall_n2 = dyn_call_count_get()
        if dcall_n2 > 0 {
            uint8[24] dc_buf2
            uint64 dc_len2 = fmt_uint(dc_buf2, dcall_n2)
            write(2, "mlrc: recorded ", 15)
            write(2, dc_buf2, dc_len2)
            write(2, " @dynamic call site(s)\n", 23)
        }
        uint64 t_end_dyn = time_ns()
        uint64 elapsed_dyn = t_end_dyn - t_start
        uint8[64] nb_dyn
        uint64 tl_dyn = fmt_uint(nb_dyn, tcount)
        write(1, nb_dyn, tl_dyn)
        write(1, " tokens, ", 9)
        uint64 al_dyn = fmt_uint(nb_dyn, ast_count)
        write(1, nb_dyn, al_dyn)
        write(1, " nodes, ", 8)
        uint64 cl_dyn = fmt_uint(nb_dyn, elf_size)
        write(1, nb_dyn, cl_dyn)
        write(1, " bytes -> ", 10)
        uint64 olen_dyn = str_len(output_path)
        write(1, output_path, olen_dyn)
        if t_start != 0 {
            uint64 ms_whole_d = elapsed_dyn / 1000000
            uint64 ms_hund_d  = (elapsed_dyn / 10000) % 100
            write(1, "  (", 3)
            uint8[24] ms_buf_d
            uint64 mw_len_d = fmt_uint(ms_buf_d, ms_whole_d)
            write(1, ms_buf_d, mw_len_d)
            write(1, ".", 1)
            if ms_hund_d < 10 { write(1, "0", 1) }
            uint64 mh_len_d = fmt_uint(ms_buf_d, ms_hund_d)
            write(1, ms_buf_d, mh_len_d)
            write(1, " ms dyn-elf)\n", 13)
        } else {
            write(1, "\n", 1)
        }
        return
    }

    if emit_mode == 0 {
        // ELF entry point
        uint64 entry_va = 0x400000 + entry_off
        patch_u32(24, entry_va & 0xFFFFFFFF)
        patch_u32(28, (entry_va >> 32) & 0xFFFFFFFF)
        uint64 total_size = header_size + text_size
        // BSS optimisation: trailing zeros from uninitialised static
        // arrays don't need to live in the file. Scan for the last
        // non-zero byte; if the gap is worth it, truncate the output
        // and keep p_memsz at the full size so the ELF loader zero-
        // fills the rest at load time. Skip when DWARF is enabled —
        // debug sections get emitted after this patch and reject
        // truncation of the main load segment.
        uint64 p_filesz = total_size
        if debug_info_mode == 0 {
            uint64 tail_start = codegen_last_nonzero_end()
            uint64 bss_bytes = total_size - tail_start
            // 4 KB page threshold — anything smaller isn't worth the
            // extra segment bookkeeping.
            if bss_bytes >= 4096 {
                codegen_truncate(tail_start)
                p_filesz = tail_start
            }
        }
        patch_u32(96, p_filesz & 0xFFFFFFFF)
        patch_u32(100, (p_filesz >> 32) & 0xFFFFFFFF)
        patch_u32(104, total_size & 0xFFFFFFFF)
        patch_u32(108, (total_size >> 32) & 0xFFFFFFFF)
        // Emit DWARF debug sections if -g active
        if debug_info_mode != 0 {
            emit_elf_debug_footer(text_start, input_path)
        }
    } else if emit_mode == 1 {
        // Mach-O
        uint64 page_size = 4096
        if arch == 1 { page_size = 16384 }
        uint64 total_file = codegen_output_len()
        uint64 total_aligned = (total_file + page_size - 1) & ~(page_size - 1)
        while codegen_output_len() < total_aligned { emit_byte(0) }
        patch_u32(136, total_aligned & 0xFFFFFFFF)
        patch_u32(140, (total_aligned >> 32) & 0xFFFFFFFF)
        patch_u32(152, total_aligned & 0xFFFFFFFF)
        patch_u32(156, (total_aligned >> 32) & 0xFFFFFFFF)
        uint64 main_off_macho = find_main_offset()
        if arch == 0 {
            // x86_64: LC_UNIXTHREAD — absolute VA
            uint64 entry_va = 0x100000000 + main_off_macho
            patch_u32(320, entry_va & 0xFFFFFFFF)
            patch_u32(324, (entry_va >> 32) & 0xFFFFFFFF)
        } else {
            // ARM64 LC_MAIN entryoff = file offset of main
            patch_u32(608, main_off_macho & 0xFFFFFFFF)
            patch_u32(612, (main_off_macho >> 32) & 0xFFFFFFFF)
        }
        // ARM64 Mach-O: patch __text section + separate __DATA segment for W^X
        if arch == 1 {
            // __text section size at offset 216
            uint64 m_textsz = total_aligned - 16384
            patch_u32(216, m_textsz & 0xFFFFFFFF)
            patch_u32(220, (m_textsz >> 32) & 0xFFFFFFFF)
            uint64 m_dfoff = codegen_output_len()
            emit_static_data()
            uint64 m_draw = codegen_output_len() - m_dfoff
            uint64 m_dal = (m_draw + 16383) & ~16383
            if m_dal == 0 { m_dal = 16384 }
            while codegen_output_len() < m_dfoff + m_dal { emit_byte(0) }
            resolve_static_fixups_a64(m_dfoff)
            uint64 m_dva = 0x100000000 + total_aligned
            patch_u32(280, m_dva & 0xFFFFFFFF)
            patch_u32(284, (m_dva >> 32) & 0xFFFFFFFF)
            patch_u32(288, m_dal & 0xFFFFFFFF)
            patch_u32(292, (m_dal >> 32) & 0xFFFFFFFF)
            patch_u32(296, total_aligned & 0xFFFFFFFF)
            patch_u32(300, (total_aligned >> 32) & 0xFFFFFFFF)
            patch_u32(304, m_dal & 0xFFFFFFFF)
            patch_u32(308, (m_dal >> 32) & 0xFFFFFFFF)
            // __LINKEDIT: call helper to emit chained fixups + symtab + strtab
            uint64 m_lva = m_dva + m_dal
            uint64 m_lfoff = m_dfoff + m_dal
            emit_macho_linkedit_a64(m_lfoff, main_off_macho)
            uint64 m_lraw = codegen_output_len() - m_lfoff
            uint64 m_lsz = (m_lraw + 16383) & ~16383
            if m_lsz == 0 { m_lsz = 16384 }
            while codegen_output_len() < m_lfoff + m_lsz { emit_byte(0) }
            patch_u32(352, m_lva & 0xFFFFFFFF)
            patch_u32(356, (m_lva >> 32) & 0xFFFFFFFF)
            patch_u32(360, m_lsz & 0xFFFFFFFF)
            patch_u32(364, (m_lsz >> 32) & 0xFFFFFFFF)
            patch_u32(368, m_lfoff & 0xFFFFFFFF)
            patch_u32(372, (m_lfoff >> 32) & 0xFFFFFFFF)
            patch_u32(376, m_lraw & 0xFFFFFFFF)
            patch_u32(380, (m_lraw >> 32) & 0xFFFFFFFF)
        }
    } else if emit_mode == 2 {
        // PE: patch entry point to main function
        uint64 main_off = find_main_offset()
        uint64 pe_entry = 0x1000 + main_off - text_start
        patch_u32(0x68, pe_entry)

        uint64 text_aligned = 0
        uint64 text_va_size = 0
        uint64 idata_rva = 0

        if arch == 1 {
            // ARM64 PE: separate .data section for statics (W^X enforcement)
            // .text = code + strings only (RX)
            // .data = statics (RW)
            // .idata = imports (RW)
            uint64 code_end = data_start  // data_start from earlier = end of code
            uint64 code_with_strings = codegen_output_len() - text_start
            // Rewind: remove statics from output (they were emitted into .text)
            // We can't rewind, but we can just note where code+strings end vs statics begin
            // Actually, statics are already in the buffer. We'll re-emit them into .data.
            // For the .text section, include code + statics + strings (the whole text_size)
            // but mark it as RX. Then emit .data with a copy of statics.
            text_aligned = (text_size + 0x1FF) & ~0x1FF
            while codegen_output_len() < header_size + text_aligned { emit_byte(0) }
            // Emit .data section: re-emit statics
            uint64 data_file_off = codegen_output_len()
            emit_static_data()
            uint64 data_raw_size = codegen_output_len() - data_file_off
            uint64 data_aligned = (data_raw_size + 0x1FF) & ~0x1FF
            if data_aligned == 0 { data_aligned = 0x200 }
            while codegen_output_len() < data_file_off + data_aligned { emit_byte(0) }
            // Re-resolve static fixups to point into .data
            text_va_size = (text_size + 0xFFF) & ~0xFFF
            uint64 data_rva = 0x1000 + text_va_size
            uint64 data_va_size = (data_raw_size + 0xFFF) & ~0xFFF
            if data_va_size == 0 { data_va_size = 0x1000 }
            // Static fixups: re-resolve for .data section
            // For PE ADRP: the resolve function uses a64_compute_va which adds 0x140000E00.
            // We need target_va = 0x140000000 + data_rva + offset.
            // Pass data_rva - 0xE00 so that a64_compute_va(base + offset) = correct VA.
            // BUT for ADRP mode, code_va is also computed via a64_compute_va — which IS correct
            // for code in .text. So we need data_start such that:
            // a64_compute_va(data_start + offset) = 0x140000000 + data_rva + offset
            // 0x140000E00 + data_start + offset = 0x140000000 + data_rva + offset
            // data_start = data_rva - 0xE00
            uint64 data_va_base = data_rva - 0xE00
            resolve_static_fixups_a64(data_va_base)
            // Emit .idata
            idata_rva = 0x1000 + text_va_size + data_va_size
            uint64 iat_rva_val = emit_pe_idata(idata_rva)
            pe_iat_rva = iat_rva_val
            // Patch .text header at 0x148
            uint64 t_hdr = 0x148
            patch_u32(t_hdr + 8, text_size)        // VirtualSize
            patch_u32(t_hdr + 16, text_aligned)     // RawSize
            // Patch .data header at 0x170
            uint64 d_hdr = 0x170
            patch_u32(d_hdr + 8, data_raw_size)     // VirtualSize
            patch_u32(d_hdr + 12, data_rva)          // VirtualAddress
            patch_u32(d_hdr + 16, data_aligned)      // RawSize
            patch_u32(d_hdr + 20, data_file_off)     // PointerToRawData
            // Patch .idata header at 0x198
            uint64 i_hdr = 0x198
            uint64 idata_file_off = data_file_off + data_aligned
            patch_u32(i_hdr + 8, pe_idata_size())    // VirtualSize
            patch_u32(i_hdr + 12, idata_rva)          // VirtualAddress
            patch_u32(i_hdr + 16, pe_idata_size())    // RawSize
            patch_u32(i_hdr + 20, idata_file_off)     // PointerToRawData
            // Patch import directory RVA
            patch_u32(0xD0, idata_rva)
            // Patch SizeOfCode
            patch_u32(0x5C, text_aligned)
            // Patch ImageSize
            uint64 image_size = 0x1000 + text_va_size + data_va_size + 0x1000
            patch_u32(0x90, image_size)
            // Resolve ARM64 IAT fixups
            resolve_a64_win_iat_fixups(text_start, iat_rva_val)
        } else {
            // x86_64 PE: statics in .text (RWX) — x86_64 allows this
            text_aligned = (text_size + 0x1FF) & ~0x1FF
            while codegen_output_len() < header_size + text_aligned { emit_byte(0) }
            text_va_size = (text_size + 0xFFF) & ~0xFFF
            idata_rva = 0x1000 + text_va_size
            uint64 iat_rva_val = emit_pe_idata(idata_rva)
            pe_iat_rva = iat_rva_val
            // Patch .text header at 0x148
            uint64 text_hdr = 0x148
            patch_u32(text_hdr + 8, text_size)
            patch_u32(text_hdr + 16, text_aligned)
            // Patch .idata header at 0x170
            uint64 idata_hdr = 0x170
            patch_u32(idata_hdr + 12, idata_rva)
            uint64 idata_file_off = header_size + text_aligned
            patch_u32(idata_hdr + 20, idata_file_off)
            // Import directory RVA
            patch_u32(0xD0, idata_rva)
            // SizeOfCode
            patch_u32(0x5C, text_aligned)
            // ImageSize
            uint64 image_size = 0x1000 + text_va_size + 0x1000
            patch_u32(0x90, image_size)
            // Resolve x86_64 IAT fixups
            resolve_win_iat_fixups(text_start, iat_rva_val)
        }
    } else if emit_mode == 4 {
        // Android PIE ELF: separate RX code + RW data segments
        uint64 android_entry = entry_off
        patch_u32(24, android_entry & 0xFFFFFFFF)
        patch_u32(28, (android_entry >> 32) & 0xFFFFFFFF)
        // PT_LOAD RX: code + strings only (up to current output)
        uint64 rx_size = codegen_output_len()
        patch_u32(208, rx_size & 0xFFFFFFFF)
        patch_u32(212, (rx_size >> 32) & 0xFFFFFFFF)
        patch_u32(216, rx_size & 0xFFFFFFFF)
        patch_u32(220, (rx_size >> 32) & 0xFFFFFFFF)
        // Pad to 64KB page boundary for PT_LOAD RW
        uint64 rx_aligned = (rx_size + 0xFFFF) & ~0xFFFF
        while codegen_output_len() < rx_aligned { emit_byte(0) }
        // Emit data segment (statics)
        uint64 a_dfoff = codegen_output_len()
        emit_static_data()
        uint64 a_draw = codegen_output_len() - a_dfoff
        uint64 a_dal = (a_draw + 0xFFFF) & ~0xFFFF
        if a_dal == 0 { a_dal = 0x10000 }
        while codegen_output_len() < a_dfoff + a_dal { emit_byte(0) }
        // Re-resolve static fixups to point into RW segment.
        // x86_64: RIP-relative disp from (code_off + 4) to (a_dfoff + data_off).
        // arm64: a64_compute_va returns file_offset for target_os==3, so
        // passing a_dfoff directly gives the right VA for the RW data copy.
        if arch == 0 {
            resolve_static_fixups(a_dfoff)
        } else {
            resolve_static_fixups_a64(a_dfoff)
        }
        // Patch PT_LOAD RW @288: p_offset, p_vaddr, p_paddr, p_filesz, p_memsz
        patch_u32(296, a_dfoff & 0xFFFFFFFF)
        patch_u32(300, (a_dfoff >> 32) & 0xFFFFFFFF)
        // vaddr = rx_aligned (page-aligned, contiguous after RX in VA space)
        patch_u32(304, rx_aligned & 0xFFFFFFFF)
        patch_u32(308, (rx_aligned >> 32) & 0xFFFFFFFF)
        // paddr = same as vaddr
        patch_u32(312, rx_aligned & 0xFFFFFFFF)
        patch_u32(316, (rx_aligned >> 32) & 0xFFFFFFFF)
        patch_u32(320, a_draw & 0xFFFFFFFF)
        patch_u32(324, (a_draw >> 32) & 0xFFFFFFFF)
        // p_memsz uses the page-aligned size (a_dal), not the raw data size.
        // Android's bionic linker refuses to map a LOAD segment whose p_memsz
        // is 0 — the resulting process SIGBUSes the moment it touches the
        // corresponding VA. Pinning p_memsz to at least one page keeps the
        // linker happy even for programs with no declared statics.
        patch_u32(328, a_dal & 0xFFFFFFFF)
        patch_u32(332, (a_dal >> 32) & 0xFFFFFFFF)
    }

    codegen_write_output(output_path)
    // Mark the output executable so `./out` works immediately.
    // No-op on Windows; safe on Linux/macOS/Android.
    set_executable(output_path)

    // Dynamic-call-site count: reports on how many @dynamic extern
    // call sites codegen recorded. M2a.3.c consumes this table to
    // patch rel32s once format_elf_dyn computes the PLT layout. Until
    // then, the call-site rel32s are placeholder zeros in the emitted
    // binary — do NOT invoke any @dynamic extern in a CPU target yet.
    uint64 dcall_n = dyn_call_count_get()
    if dcall_n > 0 {
        uint8[24] dc_buf
        uint64 dc_len = fmt_uint(dc_buf, dcall_n)
        write(2, "mlrc: recorded ", 15)
        write(2, dc_buf, dc_len)
        write(2, " @dynamic call site(s)\n", 23)
    }

    uint64 t_end = time_ns()
    uint64 elapsed_ns = t_end - t_start

    uint8[64] nb
    uint64 tl = fmt_uint(nb, tcount)
    write(1, nb, tl)
    uint64 msg = " tokens, "
    write(1, msg, 9)
    uint64 al = fmt_uint(nb, ast_count)
    write(1, nb, al)
    msg = " nodes, "
    write(1, msg, 8)
    uint64 cl = fmt_uint(nb, text_size)
    write(1, nb, cl)
    msg = " bytes -> "
    write(1, msg, 10)
    uint64 olen = str_len(output_path)
    write(1, output_path, olen)
    if t_start != 0 {
        // Format as "x.xx ms" — hundredths-of-ms precision from ns.
        // ms_whole = ns / 1_000_000; hundredths = (ns / 10_000) % 100
        uint64 ms_whole = elapsed_ns / 1000000
        uint64 ms_hund  = (elapsed_ns / 10000) % 100
        msg = "  ("
        write(1, msg, 3)
        uint64 w_len = fmt_uint(nb, ms_whole)
        write(1, nb, w_len)
        msg = "."
        write(1, msg, 1)
        // Two-digit hundredths with leading zero
        uint8[2] hb
        uint8 d0 = 48 + (ms_hund / 10)
        uint8 d1 = 48 + (ms_hund % 10)
        unsafe { *(hb as uint8) = d0 }
        uint64 hb1 = hb + 1
        unsafe { *(hb1 as uint8) = d1 }
        write(1, hb, 2)
        msg = " ms)\n"
        write(1, msg, 5)
    } else {
        msg = "\n"
        write(1, msg, 1)
    }
}

// Produce MlrboFat: compile for both x86_64 and ARM64, LZ4-compress, wrap in fat binary
// Restore source and token buffers from snapshot before a re-parse in compile_fat.
// The for-loop parser (and others) destructively mutate both; this rolls them back.
fn restore_src_and_tokens(uint64 source, uint64 size, uint64 src_snap, uint64 tokens, uint64 tok_bytes, uint64 tok_snap) {
    memcpy(source, src_snap, size)
    memcpy(tokens, tok_snap, tok_bytes)
}

// --targets=<list> bitmask. 0 = unset (default: all 8, paired layout).
// Bit i (0..7) maps to MlrboFat arch_id i+1:
//   0 linux-x64, 1 linux-arm64, 2 win-x64, 3 win-arm64,
//   4 macos-x64, 5 macos-arm64, 6 android-arm64, 7 android-x64.
static uint64 target_mask = 0

// Compare a fixed-length string `s` of length `len` against a nul-terminated
// literal `lit`. Return 1 iff they match exactly (including length).
fn targets_name_eq(uint64 s, uint64 len, uint64 lit) -> uint64 {
    uint64 llen = str_len(lit)
    if len != llen { return 0 }
    return str_starts_with(s, lit, len)
}

// Return the target bit (0..7) for a platform name slice, or 0xFF if
// unrecognised. Accepts several common aliases.
fn parse_target_name(uint64 s, uint64 len) -> uint64 {
    if targets_name_eq(s, len, "linux-x64") != 0 { return 0 }
    if targets_name_eq(s, len, "linux-x86_64") != 0 { return 0 }
    if targets_name_eq(s, len, "linux-arm64") != 0 { return 1 }
    if targets_name_eq(s, len, "linux-aarch64") != 0 { return 1 }
    if targets_name_eq(s, len, "win-x64") != 0 { return 2 }
    if targets_name_eq(s, len, "windows-x64") != 0 { return 2 }
    if targets_name_eq(s, len, "win-arm64") != 0 { return 3 }
    if targets_name_eq(s, len, "windows-arm64") != 0 { return 3 }
    if targets_name_eq(s, len, "mac-x64") != 0 { return 4 }
    if targets_name_eq(s, len, "macos-x64") != 0 { return 4 }
    if targets_name_eq(s, len, "mac-arm64") != 0 { return 5 }
    if targets_name_eq(s, len, "macos-arm64") != 0 { return 5 }
    if targets_name_eq(s, len, "android-arm64") != 0 { return 6 }
    if targets_name_eq(s, len, "android-x64") != 0 { return 7 }
    if targets_name_eq(s, len, "android-x86_64") != 0 { return 7 }
    return 0xFF
}

// Parse "a,b,c" or "all" into target_mask. Unknown names produce a warning
// on stderr; recognised ones each flip one bit. "all" sets all 8 bits.
fn parse_targets_arg(uint64 list) {
    uint64 mask = 0
    uint64 i = 0
    uint64 c = 0
    uint64 p0 = list + i
    unsafe { *(p0 as uint8) -> c }
    while c != 0 {
        uint64 start = i
        while c != 0 && c != 44 {
            i = i + 1
            uint64 pn = list + i
            unsafe { *(pn as uint8) -> c }
        }
        uint64 tok_start = list + start
        uint64 tok_len = i - start
        if tok_len > 0 {
            if targets_name_eq(tok_start, tok_len, "all") != 0 {
                mask = mask | 0xFF
            } else {
                uint64 bit = parse_target_name(tok_start, tok_len)
                if bit != 0xFF {
                    mask = mask | (1 << bit)
                } else {
                    write(2, "warning: unknown --targets name: ", 33)
                    write(2, tok_start, tok_len)
                    write(2, "\n", 1)
                }
            }
        }
        if c == 44 {
            i = i + 1
            uint64 pc = list + i
            unsafe { *(pc as uint8) -> c }
        }
    }
    target_mask = mask
}

fn slot_load_u64(uint64 p) -> uint64 {
    uint64 v = 0
    unsafe { *(p as uint64) -> v }
    return v
}

fn emit_raw_bytes(uint64 buf, uint64 len) {
    uint64 i = 0
    while i < len {
        uint64 p = buf + i
        uint64 bv = 0
        unsafe { *(p as uint8) -> bv }
        uint8 bb = bv
        emit_byte(bb)
        i = i + 1
    }
}

fn compress_pair_best(
    uint64 a_buf, uint64 a_len, uint64 b_buf, uint64 b_len,
    uint64 out_comp_ptr, uint64 out_comp_len_ptr,
    uint64 out_a_off_ptr, uint64 out_b_off_ptr,
    uint64 out_pair_len_ptr
) {
    uint64 pair_len = a_len + b_len
    uint64 cap = lz4_compress_bound(pair_len)

    uint64 pair_ab = alloc(pair_len)
    memcpy(pair_ab, a_buf, a_len)
    memcpy(pair_ab + a_len, b_buf, b_len)
    uint64 comp_ab = alloc(cap)
    uint64 len_ab = lz4_compress_frame(pair_ab, pair_len, comp_ab)

    uint64 pair_ba = alloc(pair_len)
    memcpy(pair_ba, b_buf, b_len)
    memcpy(pair_ba + b_len, a_buf, a_len)
    uint64 comp_ba = alloc(cap)
    uint64 len_ba = lz4_compress_frame(pair_ba, pair_len, comp_ba)

    dealloc(pair_ab)
    dealloc(pair_ba)

    if len_ab <= len_ba {
        unsafe { *(out_comp_ptr as uint64) = comp_ab }
        unsafe { *(out_comp_len_ptr as uint64) = len_ab }
        unsafe { *(out_a_off_ptr as uint64) = 0 }
        unsafe { *(out_b_off_ptr as uint64) = a_len }
        dealloc(comp_ba)
    } else {
        unsafe { *(out_comp_ptr as uint64) = comp_ba }
        unsafe { *(out_comp_len_ptr as uint64) = len_ba }
        unsafe { *(out_a_off_ptr as uint64) = b_len }
        unsafe { *(out_b_off_ptr as uint64) = 0 }
        dealloc(comp_ab)
    }

    unsafe { *(out_pair_len_ptr as uint64) = pair_len }
}

fn compile_fat(uint64 input_path, uint64 output_path) {
    uint64 t_start_fat = time_ns()
    import_init()
    import_check_file(input_path)
    import_process(input_path)
    uint64 source = import_buf
    uint64 size = import_buf_len

    uint64 max_tok = 524288
    uint64 my_tokens = alloc(max_tok * 16)
    lexer_init(source, size, my_tokens, max_tok)
    uint64 tcount = lexer_run()

    // Save token count for reuse
    uint64 saved_tcount = tcount

    // Snapshot source and tokens before the first parse.
    // The parser MUTATES source and tokens (the for-loop parser in
    // particular rewrites byte positions and token kinds). compile_fat
    // re-parses once per platform slice, so we need to restore the
    // pristine state between passes.
    uint64 src_snapshot = alloc(size)
    uint64 cpi = 0
    while cpi < size {
        uint64 sp_src = source + cpi
        uint64 dp_src = src_snapshot + cpi
        uint64 bv_src = 0
        unsafe { *(sp_src as uint8) -> bv_src }
        uint8 bb_src = bv_src
        unsafe { *(dp_src as uint8) = bb_src }
        cpi = cpi + 1
    }
    uint64 tok_bytes = saved_tcount * 16
    uint64 tok_snapshot = alloc(tok_bytes)
    uint64 cti = 0
    while cti < tok_bytes {
        uint64 sp_tk = my_tokens + cti
        uint64 dp_tk = tok_snapshot + cti
        uint64 bv_tk = 0
        unsafe { *(sp_tk as uint8) -> bv_tk }
        uint8 bb_tk = bv_tk
        unsafe { *(dp_tk as uint8) = bb_tk }
        cti = cti + 1
    }

    // === Compile x86_64 ELF (Linux) ===
    target_os = 0
    set_target_arch(0)
    ast_init(524288)
    codegen_init(4194304, source, my_tokens)
    parser_init(my_tokens, saved_tcount)
    uint64 root = parse_module()

    // Semantic validation: check arg counts, missing returns, duplicate functions
    uint64 sema_errs = run_semantic_checks(root, source, my_tokens)
    diag_report_all()
    if sema_errs != 0 {
        uint8[24] ebuf2
        uint64 elen2 = fmt_uint(ebuf2, sema_errs)
        write(2, ebuf2, elen2)
        write(2, " error(s) found\n", 16)
        exit(1)
    }

    // Inline + Dead code elimination
    inline_pass(root)
    dce_init()
    dce_scan(root)

    // Generate x86_64 ELF into temp buffer.
    // The per-slice buffer is allocated AFTER codegen (same pattern as the
    // arm64 / pe / macho / android slices below) because the 1 MB upfront
    // allocation the code used to make silently overflowed once the slice
    // grew past that size — harmlessly on Linux (the overflow lands in
    // mapped heap pages) but as a SIGSEGV on Windows, where VirtualAlloc
    // leaves guard pages between reservations.
    uint64 x86_len = 0

    emit_elf_header()
    emit_program_header(0)
    uint64 text_start = codegen_output_len()

    uint32 child = ast_child(root)
    uint64 wchild = child
    while wchild != 0 {
        uint32 ck = ast_kind(wchild)
        if ck == 2 {
            uint32 fn_name = ast_data1(wchild)
            // IR is the default for every slice. `--legacy` (emit_ir_mode==0)
            // opts a release build back onto the direct-walking codegen if a
            // downstream issue is ever traced to the IR path; the old codegen
            // is kept intact for that reason.
            if dce_is_live(fn_name) != 0 {
                if emit_ir_mode != 0 {
                    fn_register(fn_name, out_len)
                    ir_init()
                    ir_emit_x86_function(wchild)
                } else {
                    gen_function(wchild)
                }
            }
        }
        uint32 nxt = ast_next(wchild)
        wchild = nxt
    }
    resolve_fixups()
    resolve_fnaddr_fixups()
    resolve_teardown_fixups()
    uint64 data_start = codegen_output_len()
    emit_static_data()
    resolve_static_fixups(data_start)
    uint64 str_start = codegen_output_len()
    emit_string_data()
    resolve_string_fixups(str_start)
    uint64 text_size = codegen_output_len() - text_start
    uint64 entry_off = find_main_offset()
    if entry_off == 0xFFFFFFFF {
        write(2, "error: no 'main' function found\n", 32)
        write(2, "Every KernRift program needs: fn main() { ... }\n", 49)
        exit(1)
    }
    uint64 entry_va = 0x400000 + entry_off
    patch_u32(24, entry_va & 0xFFFFFFFF)
    patch_u32(28, (entry_va >> 32) & 0xFFFFFFFF)
    uint64 total_size_x86 = 120 + text_size
    patch_u32(96, total_size_x86 & 0xFFFFFFFF)
    patch_u32(100, (total_size_x86 >> 32) & 0xFFFFFFFF)
    patch_u32(104, total_size_x86 & 0xFFFFFFFF)
    patch_u32(108, (total_size_x86 >> 32) & 0xFFFFFFFF)

