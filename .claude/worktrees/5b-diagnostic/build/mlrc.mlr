        // IR_DCACHE_FLUSH: CLFLUSH [ptr] + MFENCE on x86. Resolves the
        // address vreg into a register, then emits the two instructions.
        uint64 ptr_r = ir_resolve_src(s1_v, 0)
        if ptr_r >= 8 { emit_byte(0x41) }     // REX.B for r8..r15
        emit_byte(0x0F); emit_byte(0xAE)
        uint64 r_low = ptr_r & 7
        if r_low == 4 {
            emit_byte(0x3C); emit_byte(0x24)  // CLFLUSH [rsp] via SIB
        } else if r_low == 5 {
            emit_byte(0x7D); emit_byte(0x00)  // CLFLUSH [rbp+0] via disp8
        } else {
