    }

    if op == 31 {
        // IR_STORE: *(src1) = src2, width in dest field (1, 4, or 8)
        uint64 addr_reg = ir_resolve_src(s1_v, 0)
        uint64 val_reg = ir_resolve_src(s2_v, 1)
        uint64 width = dest_v
        if width == 8 {
            // mov [addr_reg], val_reg: REX.W 89 modrm
            uint8 st_rex = 0x48
            if val_reg >= 8 { st_rex = st_rex | 4 }
            if addr_reg >= 8 { st_rex = st_rex | 1 }
            emit_byte(st_rex)
            emit_byte(0x89)
            uint64 st_modrm = ((val_reg & 7) << 3) | (addr_reg & 7)
            if (addr_reg & 7) == 4 {
                uint8 stm = st_modrm
                emit_byte(stm)
                emit_byte(0x24)
            } else if (addr_reg & 7) == 5 {
                uint8 stm = st_modrm | 0x40
                emit_byte(stm)
                emit_byte(0)
            } else {
                uint8 stm = st_modrm
                emit_byte(stm)
            }
        } else if width == 4 {
            // mov [addr_reg], val_reg32: no REX.W
            uint8 st_rex = 0x40
            if val_reg >= 8 { st_rex = st_rex | 4 }
            if addr_reg >= 8 { st_rex = st_rex | 1 }
            if st_rex != 0x40 { emit_byte(st_rex) }
            emit_byte(0x89)
            uint64 st_modrm = ((val_reg & 7) << 3) | (addr_reg & 7)
            if (addr_reg & 7) == 4 {
                uint8 stm = st_modrm
                emit_byte(stm)
                emit_byte(0x24)
            } else if (addr_reg & 7) == 5 {
                uint8 stm = st_modrm | 0x40
                emit_byte(stm)
                emit_byte(0)
            } else {
