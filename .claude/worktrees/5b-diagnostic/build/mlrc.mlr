        uint64 argv_r = ir_a64_resolve_src(s2_v, 10)
        if target_os == 2 {
            // Windows ARM64: build quoted cmdline from argv and pass as
            // lpCommandLine. Frame extends the existing 0xD0 layout by
            // 0x400 for the cmdline buffer at sp+0xD0.
            // Stash path & argv in x19/x20 BEFORE sub sp — regalloc scratch
            // regs would be clobbered by the zero-init and cmdline loop.
