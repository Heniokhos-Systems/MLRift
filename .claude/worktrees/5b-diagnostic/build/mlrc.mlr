        if errno_off != 0xFFFFFFFF {
            emit_a64_static_store(errno_off)
        }
        if dst_r != 0xFFFFFFFF && dst_r != 0 {
            emit_a64_mov(dst_r, 0)
        }
        if dst_r == 0xFFFFFFFF {
            ir_a64_emit_store_spill(0, dest_v)
        }
        return
    }

    // ----- IR_EXEC_ARGV (114): execve on Linux/macOS, CreateProcessA on Windows -----
    if op == 114 {
