    set_target_arch(1)
    // Reset codegen for ARM64 pass
    out_len = 0
    fn_count = 0
    fixup_count = 0
    static_fixup_count = 0
    str_fixup_count = 0
    str_len = 0
    extern_fn_count = 0
    extern_call_count = 0
    fnaddr_fixup_count = 0
