// Phase 3c-11 — extract_q_qwen3_f32 (2D-grid Q-slice extract).
//
// Discriminator: 2 params + presence of a `block_idx_y()` Call.
// 2-param kernels otherwise go to Phase 3a's unary recognisers.
fn amdgpu_lower_extract_q_qwen3_f32_3c(uint64 fn_node, uint64 source,
                                        uint64 kname_ptr, uint64 nl) -> uint64 {
    uint64 n_params = 0
    uint64 wp = ast_child(fn_node)
    while wp != 0 {
        n_params = n_params + 1
        wp = ast_next(wp)
    }
    if n_params != 2 { return 1 }

