        uint64 fb_buf = ir_resolve_src(s1_v, 0)
        uint64 fb_val = ir_resolve_src(s2_v, 1)
        // mov r10, buf (use r10 as buffer write ptr; caller-saved)
        ir_emit_mov_r64_r64(10, fb_buf)
        // mov rax, val
        ir_emit_mov_r64_r64(0, fb_val)
        // test rax, rax
        emit_byte(0x48); emit_byte(0x85); emit_byte(0xC0)
        // jz .false_path  (jz rel8)
        emit_byte(0x74)
        uint64 fb_jz_patch = out_len
        emit_byte(0)   // placeholder
        // .true_path:
        // mov dword [r10], 0x65757274   ('true' LE = t=74,r=72,u=75,e=65)
        // REX.B needed for r10: 41 C7 02 74 72 75 65
        emit_byte(0x41); emit_byte(0xC7); emit_byte(0x02)
        emit_byte(0x74); emit_byte(0x72); emit_byte(0x75); emit_byte(0x65)
        // mov eax, 4
        emit_byte(0xB8); emit_byte(0x04); emit_byte(0x00); emit_byte(0x00); emit_byte(0x00)
        // jmp .done (rel8)
        emit_byte(0xEB)
        uint64 fb_jmp_patch = out_len
        emit_byte(0)   // placeholder
        // .false_path:
        uint64 fb_false = out_len
        uint8 fb_jz_disp = fb_false - fb_jz_patch - 1
        uint64 fb_jz_p = out_buf + fb_jz_patch
        unsafe { *(fb_jz_p as uint8) = fb_jz_disp }
        // mov dword [r10], 0x736C6166  ('fals' LE = f=66,a=61,l=6C,s=73)
        emit_byte(0x41); emit_byte(0xC7); emit_byte(0x02)
        emit_byte(0x66); emit_byte(0x61); emit_byte(0x6C); emit_byte(0x73)
        // mov byte [r10+4], 0x65  ('e')
        // REX.B: 41 C6 42 04 65
        emit_byte(0x41); emit_byte(0xC6); emit_byte(0x42); emit_byte(0x04); emit_byte(0x65)
        // mov eax, 5
        emit_byte(0xB8); emit_byte(0x05); emit_byte(0x00); emit_byte(0x00); emit_byte(0x00)
        // .done:
        uint64 fb_done = out_len
        uint8 fb_jmp_disp = fb_done - fb_jmp_patch - 1
        uint64 fb_jmp_p = out_buf + fb_jmp_patch
        unsafe { *(fb_jmp_p as uint8) = fb_jmp_disp }
        // rax = result length
        if dst_r != 0xFFFFFFFF {
            ir_emit_mov_r64_r64(dst_r, 0)
        } else {
            ir_emit_store_spill(0, dest_v)
