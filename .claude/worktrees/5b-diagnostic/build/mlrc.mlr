                exit(0)
            } else if str_starts_with(arg, "--target=", 9) != 0 {
                uint64 tgt_str = arg + 9
                if str_starts_with(tgt_str, "hip-amd", 7) != 0 {
                    // GPU target: trigger format_hip.kr emission alongside
                    // the normal CPU codegen. See docs/GPU_BACKEND.md.
                    target_gpu = 1
                } else if str_starts_with(tgt_str, "amdgpu-native", 13) != 0 {
                    // Stage-1 native AMDGPU target (M1d): bypass hipcc,
                    // lower the @kernel fn ourselves into a gfx1100 code
                    // object via src/format_amdgpu.kr. Peer of hip-amd —
                    // the two target paths are mutually exclusive on a
                    // per-invocation basis because both would write
                    // `<output>.co`.
                    target_amdgpu_native = 1
                    // amdgpu-native is Linux-only (KFD shim is /dev/kfd),
                    // and the .co emit lives in compile(), not in
                    // compile_fat()'s per-slice pipeline.  Force a single
                    // linux-x64 host binary so `--target=amdgpu-native`
                    // alone behaves like `--arch=x86_64 --target=amdgpu-native`.
                    arch_set = 1
                    target_os = 0
                } else if str_starts_with(tgt_str, "macos", 5) != 0 {
                    target_os = 1
                } else if str_starts_with(tgt_str, "darwin", 6) != 0 {
                    target_os = 1
                } else if str_starts_with(tgt_str, "windows", 7) != 0 {
                    target_os = 2
                } else if str_starts_with(tgt_str, "win", 3) != 0 {
                    target_os = 2
                } else if str_starts_with(tgt_str, "linux", 5) != 0 {
                    target_os = 0
                } else if str_starts_with(tgt_str, "android", 7) != 0 {
                    target_os = 3
                    emit_mode = 4
                }
            } else if str_starts_with(arg, "--target-arch=", 14) != 0 {
                // Slice B: select AMDGPU target arch for --target=amdgpu-native.
                // Default (no flag) = gfx1100 (RX 7800 XT — current dev box).
                uint64 ta_str = arg + 14
                if str_starts_with(ta_str, "gfx1100", 7) != 0 {
                    amdgpu_target_arch_set(0)
                } else if str_starts_with(ta_str, "gfx1030", 7) != 0 {
                    amdgpu_target_arch_set(1)
                } else if str_starts_with(ta_str, "gfx1031", 7) != 0 {
                    amdgpu_target_arch_set(2)
                } else if str_starts_with(ta_str, "gfx1033", 7) != 0 {
                    amdgpu_target_arch_set(3)
                } else if str_starts_with(ta_str, "gfx1101", 7) != 0 {
                    amdgpu_target_arch_set(4)
                } else if str_starts_with(ta_str, "gfx1200", 7) != 0 {
                    amdgpu_target_arch_set(5)
                } else {
                    write(2, "mlrc: unknown --target-arch (expected gfx1030|gfx1031|gfx1033|gfx1100|gfx1101|gfx1200)\n", 87)
                    exit(1)
                }
            } else if str_starts_with(arg, "--help", 6) != 0 || str_eq_full(arg, "-h") != 0 {
                write(1, "usage: mlrc [options] <file.mlr> [-o output]\n", 45)
                write(1, "       mlrc <command> <file.mlr> [options]\n\n", 44)
                write(1, "default: emit a .mlrbo fat binary covering the supported CPU targets\n", 69)
                write(1, "(linux/macos/windows/android x x86_64/arm64). The mlr runner extracts\n", 70)
                write(1, "and execs the matching slice at startup. AMDGPU code objects are\n", 65)
                write(1, "emitted via the --emit-amdgpu-* family of flags.\n\n", 50)

                write(1, "output:\n", 8)
                write(1, "  --arch=x86_64|arm64       single-arch binary (no fat-binary wrap)\n", 68)
                write(1, "  --target=linux|macos|windows|android   single-target binary\n", 62)
                write(1, "  --target-arch=<gfxNNNN>   AMDGPU sub-target (gfx1030/1100/1200/...)\n", 70)
                write(1, "  --targets=<list>         custom fat binary subset\n", 52)
                write(1, "                              e.g. linux-x64,macos-arm64,win-x64\n", 65)
                write(1, "  --emit=elfexe|macho|pe|android        single-target executable\n", 65)
                write(1, "  --emit=obj                relocatable .o (.obj on Windows)\n", 61)
                write(1, "  --emit=asm                annotated assembly listing\n", 55)
                write(1, "  --emit=ir                 dump SSA IR per function\n", 53)
                write(1, "  --emit-amdgpu-*=<spec>    emit a specific AMDGPU code object\n", 63)
                write(1, "  -c                        shorthand for --emit=obj\n", 53)
                write(1, "  -o <path>                 output path\n\n", 41)

                write(1, "code generation:\n", 17)
                write(1, "  --ir                      force IR backend (default)\n", 55)
                write(1, "  --legacy                  legacy direct codegen path\n", 55)
                write(1, "  --coalesce                Briggs/George copy coalescing (default on)\n", 71)
                write(1, "  --no-coalesce             disable copy coalescing\n", 52)
                write(1, "  --O0                      disable IR optimizations (CF/DCE/CSE/LICM)\n", 71)
                write(1, "  --freestanding            no startup code, no libc\n", 53)
                write(1, "  --no-auto-teardown        disable auto hipkfd_teardown injection\n", 67)
                write(1, "  --debug                   runtime safety checks (bounds, null)\n", 65)
                write(1, "  -g                        emit DWARF debug info\n\n", 51)

                write(1, "commands (living compiler):\n", 28)
                write(1, "  check <file.mlr>          safety analysis\n", 44)
                write(1, "  lc <file.mlr>             propose / classify changes\n", 55)
                write(1, "  fmt <file.mlr>            auto-format source\n\n", 48)

                write(1, "info:\n", 6)
                write(1, "  --version                 show version\n", 41)
                write(1, "  --help, -h                show this help\n", 43)
                exit(0)
            } else if str_starts_with(arg, "--version", 9) != 0 {
                uint64 msg = "mlrc 0.1.1 (MLRift — built on KernRift v2.8.24)\n"
                write(1, msg, 50)
                exit(0)
            } else if str_starts_with(arg, "--freestanding", 14) != 0 {
                freestanding = 1
            } else if str_starts_with(arg, "--no-auto-teardown", 18) != 0 {
                // Suppress compiler-level hipkfd_teardown auto-injection
                // for --target=amdgpu-native binaries. Power-user escape
                // hatch — default is auto-inject ON so the foot-gun of
                // forgetting to drain KFD queues at exit is removed.
                auto_teardown_disabled = 1
            } else if str_starts_with(arg, "--legacy", 8) != 0 {
                emit_ir_mode = 0
            } else if str_starts_with(arg, "--ir", 4) != 0 {
                emit_ir_mode = 2
            } else if str_starts_with(arg, "--O0", 4) != 0 {
                ir_opt_level = 0
            } else if str_starts_with(arg, "--no-coalesce", 13) != 0 {
                ir_set_coalesce(0)
            } else if str_starts_with(arg, "--coalesce", 10) != 0 {
                ir_set_coalesce(1)
            } else if str_starts_with(arg, "--debug", 7) != 0 {
                debug_mode = 1
            } else if str_starts_with(arg, "-g", 2) != 0 {
                debug_info_mode = 1
            } else if str_starts_with(arg, "--ci", 4) != 0 {
                lc_ci_mode = 1
            } else if str_starts_with(arg, "--fix", 5) != 0 {
                lc_fix_mode = 1
            } else if str_starts_with(arg, "--dry-run", 9) != 0 {
                lc_dry_run = 1
            } else if str_starts_with(arg, "--list-proposals", 16) != 0 {
                lc_list_proposals = 1
                mode = 2
            } else if str_starts_with(arg, "--promote=", 10) != 0 {
                lc_promote_name = arg + 10
                mode = 2
            } else if str_starts_with(arg, "--promote", 9) != 0 {
                i = i + 1
                uint64 pnext_ptr = cli_argv + i * 8
                uint64 pnext_arg = 0
                unsafe { *(pnext_ptr as uint64) -> pnext_arg }
                lc_promote_name = pnext_arg
                mode = 2
            } else if str_starts_with(arg, "--deprecate=", 12) != 0 {
                lc_deprecate_name = arg + 12
                mode = 2
            } else if str_starts_with(arg, "--deprecate", 11) != 0 {
                i = i + 1
                uint64 dnext_ptr = cli_argv + i * 8
                uint64 dnext_arg = 0
                unsafe { *(dnext_ptr as uint64) -> dnext_arg }
                lc_deprecate_name = dnext_arg
                mode = 2
            } else if str_starts_with(arg, "--reject=", 9) != 0 {
                lc_reject_name = arg + 9
                mode = 2
            } else if str_starts_with(arg, "--reject", 8) != 0 {
                i = i + 1
                uint64 rnext_ptr = cli_argv + i * 8
                uint64 rnext_arg = 0
                unsafe { *(rnext_ptr as uint64) -> rnext_arg }
                lc_reject_name = rnext_arg
                mode = 2
            } else if str_starts_with(arg, "--min-fitness=", 14) != 0 {
                lc_min_fitness = parse_uint_arg(arg + 14)
            } else if str_starts_with(arg, "--min-fitness", 13) != 0 {
                // --min-fitness N (next arg)
                i = i + 1
                uint64 next_ptr = cli_argv + i * 8
                uint64 next_arg = 0
                unsafe { *(next_ptr as uint64) -> next_arg }
                lc_min_fitness = parse_uint_arg(next_arg)
            } else if str_starts_with(arg, "check", 5) != 0 {
                mode = 1
            } else if str_starts_with(arg, "lc", 2) != 0 {
                mode = 2
            } else if str_starts_with(arg, "fmt", 3) != 0 {
                mode = 3
            } else {
                input_path = arg
            }
            i = i + 1
        }
    }



    // Auto-set target_os from emit_mode if not explicitly set
    if emit_mode == 1 && target_os == 0 { target_os = 1 }
    if emit_mode == 2 && target_os == 0 { target_os = 2 }
    if emit_mode == 4 && target_os == 0 { target_os = 3 }
    // emit_mode=4 (android): default to arm64 unless --arch was explicitly set
    if emit_mode == 4 && arch_set == 0 { arch = 1 }

    // Derive output name from input if not specified with -o
    if str_eq_full(output_path, "a.mlrbo") != 0 && input_path != 0 {
        uint64 ilen = str_len(input_path)
        // Strip .kr or .mlr extension if present, then add appropriate extension.
        // Without this, `foo.mlr` would become `foo.mlr.mlrbo` (and worse, any
        // future emit-extension that collided with the input suffix could write
        // back over the source file).
        uint64 base_len = ilen
        if ilen > 3 {
            uint64 dp = input_path + ilen - 3
            uint64 d0 = 0; uint64 d1 = 0; uint64 d2 = 0
            unsafe { *(dp as uint8) -> d0 }
            uint64 dp1 = dp + 1; unsafe { *(dp1 as uint8) -> d1 }
            uint64 dp2 = dp + 2; unsafe { *(dp2 as uint8) -> d2 }
            if d0 == 46 && d1 == 107 && d2 == 114 { base_len = ilen - 3 }
        }
        if ilen > 4 {
            uint64 dq = input_path + ilen - 4
            uint64 q0 = 0; uint64 q1 = 0; uint64 q2 = 0; uint64 q3 = 0
            unsafe { *(dq as uint8) -> q0 }
            uint64 dq1 = dq + 1; unsafe { *(dq1 as uint8) -> q1 }
            uint64 dq2 = dq + 2; unsafe { *(dq2 as uint8) -> q2 }
            uint64 dq3 = dq + 3; unsafe { *(dq3 as uint8) -> q3 }
            // ".mlr" = 0x2E 0x6D 0x6C 0x72
            if q0 == 46 && q1 == 109 && q2 == 108 && q3 == 114 { base_len = ilen - 4 }
        }
        if emit_mode == 3 {
            // Object file: input.kr → input.o
            uint64 out = alloc(base_len + 3)
            memcpy(out, input_path, base_len)
            uint64 ep = out + base_len
            uint8 e0 = 46; uint8 e1 = 111
            unsafe { *(ep as uint8) = e0 }
            uint64 ep1 = ep + 1; unsafe { *(ep1 as uint8) = e1 }
            uint64 ep2 = ep + 2; uint8 z = 0
            unsafe { *(ep2 as uint8) = z }
            output_path = out
        } else if emit_mode == 2 {
            // PE: input.kr → input.exe
            uint64 out = alloc(base_len + 5)
            memcpy(out, input_path, base_len)
            uint64 ep = out + base_len
            uint8 e0 = 46; uint8 e1 = 101; uint8 e2 = 120; uint8 e3 = 101
            unsafe { *(ep as uint8) = e0 }
            uint64 ep1 = ep + 1; unsafe { *(ep1 as uint8) = e1 }
            uint64 ep2 = ep + 2; unsafe { *(ep2 as uint8) = e2 }
            uint64 ep3 = ep + 3; unsafe { *(ep3 as uint8) = e3 }
            uint64 ep4 = ep + 4; uint8 z = 0
            unsafe { *(ep4 as uint8) = z }
            output_path = out
        } else if arch_set != 0 || emit_set != 0 {
            // Single arch: input.kr → input (no extension, native binary)
            uint64 out = alloc(base_len + 1)
            memcpy(out, input_path, base_len)
            uint64 tp = out + base_len
            uint8 z = 0
            unsafe { *(tp as uint8) = z }
            output_path = out
        } else {
            // Fat binary: input.kr → input.mlrbo
            uint64 out = alloc(base_len + 7)
            memcpy(out, input_path, base_len)
            uint64 ep = out + base_len
            uint8 e0 = 46; uint8 e1 = 109; uint8 e2 = 108; uint8 e3 = 114; uint8 e4 = 98; uint8 e5 = 111
            unsafe { *(ep as uint8) = e0 }
            uint64 ep1 = ep + 1; unsafe { *(ep1 as uint8) = e1 }
            uint64 ep2 = ep + 2; unsafe { *(ep2 as uint8) = e2 }
            uint64 ep3 = ep + 3; unsafe { *(ep3 as uint8) = e3 }
            uint64 ep4 = ep + 4; unsafe { *(ep4 as uint8) = e4 }
            uint64 ep5 = ep + 5; unsafe { *(ep5 as uint8) = e5 }
            uint64 ep6 = ep + 6; uint8 z = 0
            unsafe { *(ep6 as uint8) = z }
            output_path = out
        }
    }

    // --list-proposals doesn't need an input file
    if lc_list_proposals != 0 && input_path == 0 {
        init_proposals()
        load_proposal_overrides()
        list_proposals()
        exit(0)
    }

    // --promote / --deprecate / --reject: governance commands, no input file
    if lc_promote_name != 0 && input_path == 0 {
        init_proposals()
        load_proposal_overrides()
        promote_proposal(lc_promote_name)
        exit(0)
    }
    if lc_deprecate_name != 0 && input_path == 0 {
        init_proposals()
        load_proposal_overrides()
        deprecate_proposal(lc_deprecate_name)
        exit(0)
    }
    if lc_reject_name != 0 && input_path == 0 {
        init_proposals()
        load_proposal_overrides()
        reject_proposal(lc_reject_name)
        exit(0)
    }

    if input_path == 0 {
        if cli_argc > 0 {
            write(2, "mlrc: no input file\n\n", 21)
            write(2, "usage: mlrc [options] <file.mlr> [-o output]\n\n", 46)
            write(2, "options:\n", 9)
            write(2, "  --arch=x86_64|arm64\n", 22)
            write(2, "  --emit=elfexe|macho|pe|obj|android|asm\n", 41)
            write(2, "  -c                        emit relocatable .o\n", 48)
            write(2, "  --target=linux|macos|windows\n", 31)
            write(2, "  --version\n\n", 13)
            write(2, "commands:\n", 10)
            write(2, "  check <file.mlr>  safety analysis\n", 36)
            write(2, "  lc <file.mlr>     living compiler\n", 36)
            write(2, "  fmt <file.mlr>    auto-format source\n", 39)
            exit(0)
        }
        input_path = "test_input.kr"
    }

    if mode == 1 {
        import_init()
    import_check_file(input_path)
        import_process(input_path)
        uint64 source = import_buf
        uint64 size = import_buf_len
        uint64 max_tok = 524288
        uint64 my_tokens = alloc(max_tok * 16)
        lexer_init(source, size, my_tokens, max_tok)
        uint64 tcount = lexer_run()
        ast_init(524288)
        codegen_init(1048576, source, my_tokens)
        parser_init(my_tokens, tcount)
        uint64 root = parse_module()
        uint64 errors = run_analysis(root)
        if errors > 0 {
            uint8[32] nb
            write(2, "\nkrc: ", 6)
            uint64 nl = fmt_uint(nb, errors)
            write(2, nb, nl)
            write(2, " analysis error(s) found in ", 28)
            write(2, input_path, str_len(input_path))
            write(2, "\n", 1)
            exit(1)
        }
        write(1, "mlrc check: ", 12)
        write(1, input_path, str_len(input_path))
        write(1, " — OK\n", 6)
        exit(0)
    }

    if mode == 2 {
        // --list-proposals: print the governance-layer proposal registry
        if lc_list_proposals != 0 {
            init_proposals()
            load_proposal_overrides()
            list_proposals()
            exit(0)
        }
        // --fix mode: run the migration engine on the input file
        if lc_fix_mode != 0 {
            run_migration(input_path, lc_dry_run)
            exit(0)
        }
        import_init()
    import_check_file(input_path)
        import_process(input_path)
        uint64 source = import_buf
        uint64 size = import_buf_len
        uint64 max_tok = 524288
        uint64 my_tokens = alloc(max_tok * 16)
        lexer_init(source, size, my_tokens, max_tok)
        uint64 tcount = lexer_run()
        ast_init(524288)
        codegen_init(1048576, source, my_tokens)
        parser_init(my_tokens, tcount)
        uint64 root = parse_module()
        // Run analysis first to populate lock graph
        analysis_init()
        uint64 tel = collect_telemetry(root)
        uint64 patterns = detect_patterns(root, tel)
        uint64 cycles = check_lock_cycles()
        uint64 fitness = compute_fitness(tel, patterns, cycles)
        init_proposals()
        load_proposal_overrides()
        detect_proposals(tel)
        if lc_min_fitness > 0 {
            print_living_report_filtered(tel, patterns, fitness, lc_min_fitness)
        } else {
            print_living_report(tel, patterns, fitness)
        }
        print_firing_proposals()
        if lc_ci_mode != 0 {
            uint64 gate_threshold = lc_min_fitness
            if gate_threshold == 0 { gate_threshold = 50 }
            if lc_check_ci_gate(gate_threshold) != 0 {
                exit(1)
            }
        }
        exit(0)
    }

    if mode == 3 {
        fmt_file(input_path)
        exit(0)
    }

    // Defensive: refuse to write the compiled output over the source file.
    // Guards against bugs in the output-derivation logic above ever producing
    // output_path == input_path (which would silently truncate user source).
    if input_path != 0 && str_eq_full(output_path, input_path) != 0 {
        write(2, "mlrc: refusing to overwrite input file with output: ", 52)
        write(2, input_path, str_len(input_path))
        write(2, "\n", 1)
        exit(2)
    }

    // Default: produce fat binary unless --arch or --emit specified.
    // On Windows / macOS: default to the host's native format so that
    // `mlrc hello.mlr` just works without flags. The user can still
    // explicitly request a fat binary with `mlrc hello.mlr -o hello.mlrbo`
    // via --emit=... if they want cross-platform output.
    // --targets=<list> always forces fat-binary emission (custom slice set).
    if target_mask != 0 || (arch_set == 0 && emit_set == 0 && cli_argc > 0) {
        compile_fat(input_path, output_path)
    } else {
        compile(input_path, output_path, arch, emit_mode)
    }
    exit(0)
}
