// Confirm: `obj.field = local` followed by mutating `obj.field` does
// NOT clobber `local`.
//
// Predicted SAFE because Field-LHS Assign (kind 36 with data4=1) emits
// IR_STORE with `val` as the source vreg — there's no back-edge IR_COPY
// that would alias-write `local`.

import "../std/io.mlr"
import "../std/fmt.mlr"

struct B {
    u64 v
}

fn main() {
    u64 fail = 0
    u64 src = 7

    // Allocate B explicitly. Field-LHS Assign with bare-Ident RHS.
    B b = B { 0 }
    b.v = src   // FieldAccess statement, not a vreg-assign

    // Now mutate b.v repeatedly inside a loop via compound store and
    // through reads/writes through the struct.
    u64 i = 0
    while i < 5 {
        b.v = b.v + 1
        i = i + 1
    }

    if src != 7 {
        print_str("BUG: field-LHS assign aliased; src=")
        u64 s = fmt_dec(src); print_str(s); dealloc(s); print_str("\n")
        fail = fail + 1
    }
    if b.v != 12 {
        print_str("BUG: b.v != 12, got=")
        u64 s = fmt_dec(b.v); print_str(s); dealloc(s); print_str("\n")
        fail = fail + 1
    }

    if fail == 0 {
        print_str("PASS\n")
    } else {
        print_str("FAIL\n")
    }
}
