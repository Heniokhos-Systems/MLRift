// Tiny standalone test for qwen3_silu_mul_avx2. Compares its output to
// the scalar version (reached via the legacy exp_f32_fast path) on a
// 16-element input with mixed-magnitude gate values.

import "../std/qwen3.mlr"
import "../std/inference.mlr"
import "../std/fmt.mlr"
import "../std/io.mlr"

fn put(u64 s) { print_str(s) }

fn silu_scalar(u64 out_ptr, u64 gate_ptr, u64 up_ptr, u64 dim) {
    f32 one = 1.0f
    u64 i = 0
    while i < dim {
        f32 g = 0.0f; unsafe { *((gate_ptr + i * 4) as f32) -> g }
        f32 u = 0.0f; unsafe { *((up_ptr   + i * 4) as f32) -> u }
        f32 sig = one / (one + exp_f32_fast(0.0f - g))
        f32 y = g * sig * u
        unsafe { *((out_ptr + i * 4) as f32) = y }
        i = i + 1
    }
}

fn dump_vec(u64 label, u64 ptr, u64 n) {
    put(label); put(" = [")
    u64 i = 0
    while i < n {
        if i != 0 { put(", ") }
        f32 v = 0.0f
        unsafe { *((ptr + i * 4) as f32) -> v }
        u64 s = fmt_f32(v, 6); put(s); dealloc(s)
        i = i + 1
    }
    put("]\n")
}

fn main() {
    u64 n = 16
    u64 g_buf = alloc(n * 4)
    u64 u_buf = alloc(n * 4)
    u64 o_avx = alloc(n * 4)
    u64 o_ref = alloc(n * 4)

    // Fill gate with a mix of magnitudes + signs
    u64 i = 0
    while i < n {
        i64 s = i
        f32 fi = int_to_f32(i)
        f32 g = fi * 0.5f - 3.75f  // -3.75, -3.25, ..., 3.75
        f32 u = 1.0f + fi * 0.25f
        unsafe { *((g_buf + i * 4) as f32) = g }
        unsafe { *((u_buf + i * 4) as f32) = u }
        i = i + 1
    }

    silu_scalar(o_ref, g_buf, u_buf, n)
    qwen3_silu_mul_avx2(o_avx, g_buf, u_buf, n)

    dump_vec("gate   ", g_buf, n)
    dump_vec("up     ", u_buf, n)
    dump_vec("scalar ", o_ref, n)
    dump_vec("avx2   ", o_avx, n)
    exit(0)
}
