// Compare GGUF-embedded tokenizer vs HF tokenizer.json on the same prompt.
//
// Usage: tokenizer_gguf_vs_json <model.gguf> <tokenizer.json> [prompt]

import "../std/tokenizer.mlr"
import "../std/gguf.mlr"
import "../std/io.mlr"
import "../std/fmt.mlr"
import "../std/string.mlr"

static uint64 cli_argc = 0
static uint64 cli_argv = 0

fn put(u64 s) { print_str(s) }
fn putu(u64 v) { u64 s = fmt_dec(v); put(s); dealloc(s) }

fn argv_at(u64 i) -> u64 {
    u64 slot = cli_argv + i * 8
    u64 v = 0
    unsafe { *(slot as u64) -> v }
    return v
}

fn encode_and_print(Tokenizer tk, u64 prompt, u64 label) {
    u64 plen = str_len(prompt)
    u64 ids = 0
    u64 cnt = 0
    u64 ids_box = alloc(8); unsafe { *(ids_box as u64) = 0 }
    u64 cnt_box = alloc(8); unsafe { *(cnt_box as u64) = 0 }
    tokenizer_encode(tk, prompt, plen, ids_box, cnt_box)
    unsafe { *(ids_box as u64) -> ids }
    unsafe { *(cnt_box as u64) -> cnt }
    dealloc(ids_box); dealloc(cnt_box)
    put(label); put(": cnt="); putu(cnt); put(" ids=[")
    u64 j = 0
    while j < cnt {
        if j != 0 { put(", ") }
        u32 id32 = 0
        unsafe { *((ids + j * 4) as uint32) -> id32 }
        u64 id = id32
        putu(id)
        j = j + 1
    }
    put("]\n")
    if ids != 0 { dealloc(ids) }
}

fn main() {
    if cli_argc < 3 {
        put("usage: tokenizer_gguf_vs_json <model.gguf> <tokenizer.json> [prompt]\n")
        exit(1)
    }
    u64 gguf_path = argv_at(1)
    u64 json_path = argv_at(2)
    u64 prompt = "Hello world"
    if cli_argc >= 4 { prompt = argv_at(3) }

    put("prompt=\""); put(prompt); put("\"\n")

    // GGUF path.
    GGUFFile gf = gguf_open(gguf_path)
    if gf.file_size == 0 { put("gguf open failed\n"); exit(1) }
    Tokenizer tk_gguf = tokenizer_load_from_gguf(gf)
    encode_and_print(tk_gguf, prompt, "gguf")

    // tokenizer.json path. The two tokenizers share global GPT-2 state;
    // we must call tokenizer_free on tk_gguf first (it cleans up tk_gpt2_*)
    // before the JSON loader can re-establish its own state.
    tokenizer_free(tk_gguf)
    gguf_free(gf)

    Tokenizer tk_json = tokenizer_load(json_path)
    if tk_json.file_size == 0 { put("json open failed\n"); exit(1) }
    // Llama-3 / Qwen3 are GPT-2 byte-level; force the same mode the chat
    // REPLs use, to match the encoder behaviour we're comparing against.
    tokenizer_set_kind_gpt2(tk_json)
    encode_and_print(tk_json, prompt, "json")

    tokenizer_free(tk_json)
    exit(0)
}
