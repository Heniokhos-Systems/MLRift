// Isolated test: load the unbundled hipcc .co into KFD shim and try to
// resolve csr_build by name. Used to bisect the segfault when running
// noesis_60m_gpu_launch via dual-.co fallback.

import "../std/hip.mlr"
import "../std/io.mlr"
import "../std/fmt.mlr"

fn putu(uint64 v) { uint64 s = fmt_dec(v); print_str(s); dealloc(s) }

fn main() {
    uint32 err = hipSetDevice(0)
    print_str("hipSetDevice err="); putu(err); print_str("\n")

    uint64 fd = file_open("/tmp/co_hip_inner.co", 0)
    if fd > 0xFFFFFFFFFFFFF000 { print_str("open fail\n"); exit(1) }
    uint64 sz = file_size(fd)
    uint64 blob = alloc(sz)
    file_read(fd, blob, sz)
    file_close(fd)
    print_str("blob_size="); putu(sz); print_str("\n")

    uint64 mod_slot = alloc(8)
    err = hipModuleLoadData(mod_slot, blob)
    print_str("hipModuleLoadData err="); putu(err); print_str("\n")
    if err != 0 { exit(1) }
    uint64 mod = 0
    unsafe { *(mod_slot as uint64) -> mod }
    print_str("mod="); putu(mod); print_str("\n")

    uint64 fn_slot = alloc(8)
    err = hipModuleGetFunction(fn_slot, mod, "csr_build")
    print_str("hipModuleGetFunction(csr_build) err="); putu(err); print_str("\n")
    if err != 0 { exit(1) }
    uint64 fh = 0
    unsafe { *(fn_slot as uint64) -> fh }
    print_str("fn_handle="); putu(fh); print_str("\n")

    print_str("OK\n")
    exit(0)
}
