// Mistral-7B-Instruct-v0.3 Q8_0 greedy decode — second non-Qwen3 LLM
// through the MLRift pipeline.  Reads the GGUF blob that
// `ollama pull mistral:7b-instruct-q8_0` left on disk.
//
// Mistral-7B-Instruct-v0.3 architecture (from the GGUF metadata):
//   architecture            = llama       (Mistral uses llama arch in GGUF)
//   layers                  = 32
//   embedding_length        = 4096
//   feed_forward_length     = 14336
//   attention.head_count    = 32
//   attention.head_count_kv = 8         (GQA 4:1, same as Llama-3.1-8B)
//   attention.key_length    = 128       (head_dim, full RoPE)
//   attention.layer_norm_rms_epsilon = 1e-5
//   rope.freq_base          = 1_000_000 (1e6 — same as Qwen3, NOT 5e5)
//   vocab_size              = 32768
//   tokenizer.ggml.bos      = 1
//   tokenizer.ggml.eos      = 2
//   tie_word_embeddings     = false     (separate output.weight)
//   quantization            = Q8_0
//
// Differences from Llama-3.2-1B (arch knob deltas only):
//   * RoPE theta = 1_000_000 (was 500_000 for Llama-3)
//   * NO rope_freqs.weight (Mistral doesn't ship NTK scaling)
//   * Separate output.weight (NOT tied to token_embd)
//   * head_dim = 128 (was 64)
//   * Different shape: hidden=4096 vs 2048, ff=14336 vs 8192,
//     32 layers vs 16, vocab=32768 vs 128256
//
// Same arch knobs reused:
//   * No qknorm (qwen3_set_qknorm(0))
//   * RMSNorm eps = 1e-5 (qwen3_set_rmsnorm_eps_bits(0x3727C5AC))
//   * matmul_kind = 1 (Q8_0)
//   * norm_kind = 1 (F32 norms — Llama/Mistral both use f32 norms in
//     GGUF, vs Qwen3-0.6B which has bf16 norms)
//   * fuse_qkv = 0 (no weight duplication)
//
// First-cut bench: hardcoded BOS-prepended prompt, 20-token greedy
// decode, print token IDs only.  Cross-reference against
// `ollama run mistral:7b-instruct-q8_0` raw=true greedy output.
// Tokenizer integration is a follow-up slice (Mistral uses SentencePiece
// llama-style tokenizer, different from Llama-3's tiktoken/byte-BPE).
//
// Build:
//   ./build/mlrc --emit=elfexe examples/mistral_generate.mlr -o /tmp/mistral7b
//   /tmp/mistral7b

import "../std/qwen3.mlr"
import "../std/gguf.mlr"
import "../std/matmul.mlr"
import "../std/inference.mlr"
import "../std/io.mlr"
import "../std/fmt.mlr"
import "../std/string.mlr"
import "../std/thread.mlr"
import "../std/time.mlr"
import "../std/model_path.mlr"

static u64 g_fd = 0
fn eout(u64 s) {
    print_str(s)
    if g_fd != 0 {
        u64 n = str_len(s)
        file_write(g_fd, s, n)
    }
}
fn eu64(u64 v) {
    u64 s = fmt_dec(v)
    eout(s)
    dealloc(s)
}

// Slice 7.2a (2026-05-13) — madvise(MADV_DONTNEED) wrapper.  Mirrors
// the slice 4.27 host-RSS optimization from examples/llama3_generate.mlr.
// At Mistral-7B scale the Q8_0 source mmap (~7.5 GiB) is paged in for
// dequant; without madvise it stays resident alongside the bf16 layer
// buffers (~13.3 GiB), pushing peak host RSS to ~21 GiB.  Dropping the
// Q8_0 pages after each tensor brings peak down to ~14 GiB.
// Linux x86_64: syscall 28, MADV_DONTNEED = 4.
fn madv_dontneed(u64 addr, u64 length) {
    u64 page  = 4096
    u64 mask  = 0 - page
    u64 start = (addr + page - 1) & mask
    u64 end   = (addr + length)   & mask
    if end <= start { return }
    u64 len = end - start
    syscall_raw(28, start, len, 4, 0, 0, 0)
}

// Q8_0 → bf16 dequantizer (copied from llama3_generate.mlr).
// Each Q8_0 block: 2-byte f16 scale + 32 int8 quants. Output is bf16
// (high 16 bits of f32 representation). Used by the destroy-PyTorch CPU
// slice (MLRIFT_CPU_BF16=1) to feed MLRift's AVX2 bf16-matmul path.
fn q8_0_to_bf16_alloc(u64 src_q8, u64 n_elements) -> u64 {
    u64 dst_bf16 = alloc(n_elements * 2)
    u64 n_blocks = n_elements / 32
    u64 scratch = alloc(4)
    u64 bi = 0
    while bi < n_blocks {
        u64 block = src_q8 + bi * 34
        u64 lo = load8(block)
        u64 hi = load8(block + 1)
        u64 dbits = lo | (hi << 8)
        f32 d = gguf_f16_to_f32_exact(dbits)
        u64 qs_base = block + 2
        u64 j = 0
        while j < 32 {
            u64 bval = load8(qs_base + j)
            f32 q = 0.0f
            if bval >= 128 {
                f32 pos = int_to_f32_gguf(256 - bval)
                q = 0.0f - pos
            } else {
                q = int_to_f32_gguf(bval)
            }
            f32 out_val = d * q
            unsafe { *(scratch as f32) = out_val }
            u64 b0 = load8(scratch + 2)
            u64 b1 = load8(scratch + 3)
            u64 dst_off = (bi * 32 + j) * 2
            u8 b0_8 = b0
            u8 b1_8 = b1
            unsafe { *((dst_bf16 + dst_off + 0) as u8) = b0_8 }
            unsafe { *((dst_bf16 + dst_off + 1) as u8) = b1_8 }
            j = j + 1
        }
        bi = bi + 1
    }
    dealloc(scratch)
    return dst_bf16
}

fn main() {
    u64 num_workers = 24
    thread_pool_init(num_workers)
    g_fd = file_open("/tmp/mistral7b_gen.out", 1)

    // --- Reconfigure qwen3.mlr for Mistral-7B-Instruct-v0.3 Q8_0 ---
    // Destroy-PyTorch CPU slice (2026-05-12): MLRIFT_CPU_BF16=1 dequantises
    // every Q8_0 layer weight + the lm_head (separate output.weight) to
    // bf16 at load and routes matmul through MLRift's AVX2 bf16 path.
    // Cost: ~14 GiB extra RAM (verified to fit on 30 GiB system).
    u64 cpu_bf16 = 0
    u64 ev_cpu_bf16 = getenv("MLRIFT_CPU_BF16")
    if ev_cpu_bf16 != 0 {
        u8 c0bf = 0; unsafe { *(ev_cpu_bf16 as u8) -> c0bf }
        if c0bf != 48 { cpu_bf16 = 1 }
    }

    qwen3_set_arch(4096, 128, 32, 8, 14336)  // hidden, head_dim, nh, nkv, ff
    if cpu_bf16 == 0 {
        qwen3_set_matmul_kind(1)              // Q8_0 (default, bit-exact w/ llama.cpp)
    } else {
        qwen3_set_matmul_kind(0)              // bf16 (destroy-PyTorch path)
    }
    qwen3_set_norm_kind(1)                    // F32 norms
    qwen3_set_fuse_qkv(0)                     // no weight duplication
    qwen3_set_qknorm(0)                       // Mistral: no per-head Q/K RMSNorm
    qwen3_set_rope_base(10000)                // Mistral 7B-Instruct (v0.1/v0.2) theta = 1e4
    qwen3_set_rmsnorm_eps_bits(0x3727C5AC)    // rms_norm_eps = 1e-5
    qwen3_set_rope_pair_layout(1)             // Mistral: NORM consecutive pairs (Llama family)
    qwen3_set_q8_bitexact(1)                  // bit-exact Q8_0×Q8_0 matches llama.cpp; ignored when matmul_kind=0

    u64 path = resolve_model_path("MLRIFT_MISTRAL_7B_GGUF",
                                   "models/mistral-7b-instruct-v0.3-q8_0.gguf",
                                   "mistral-7b")
    eout("[mistral7b] loading weights from ")
    eout(path)
    eout("\n")
    u64 load_start_ns = time_now()
    GGUFFile gf = gguf_open(path)
    if gf.file_size == 0 {
        eout("open fail (blob path needs updating after `ollama pull`)\n")
        thread_pool_shutdown(); file_close(g_fd); exit(1)
    }

    u64 hidden    = QWEN3_HIDDEN
    u64 kv_dim    = QWEN3_KV_DIM
    u64 n_layers  = 32
    u64 vocab     = 32000
    u64 max_seq   = 64
    u64 max_new   = 20

    // ---- Get top-level tensors ----
    GGUFTensor embed_t = gguf_get(gf, "token_embd.weight")
    if embed_t.ptr == 0 {
        eout("missing token_embd.weight\n")
        gguf_free(gf); thread_pool_shutdown(); file_close(g_fd); exit(1)
    }
    GGUFTensor norm_t = gguf_get(gf, "output_norm.weight")
    if norm_t.ptr == 0 {
        eout("missing output_norm.weight\n")
        gguf_free(gf); thread_pool_shutdown(); file_close(g_fd); exit(1)
    }
    // Mistral does NOT tie embeddings — separate output.weight.
    GGUFTensor lmhead_t = gguf_get(gf, "output.weight")
    if lmhead_t.ptr == 0 {
        eout("missing output.weight\n")
        gguf_free(gf); thread_pool_shutdown(); file_close(g_fd); exit(1)
    }
    u64 lmhead_ptr = lmhead_t.ptr

    // ---- Per-layer weight pointer table (88 bytes per Qwen3LayerWeights). ----
    u64 layers_arr = alloc(n_layers * 88)
    u64 li = 0
    while li < n_layers {
        u64 base = layers_arr + li * 88
        u64 li_s = fmt_dec(li)
        u64 pre0 = str_cat("blk.", li_s)
        u64 prefix = str_cat(pre0, ".")
        dealloc(li_s); dealloc(pre0)

        u64 n01 = str_cat(prefix, "attn_norm.weight")
        GGUFTensor t01 = gguf_get(gf, n01)
        unsafe { *((base + 0 * 8) as u64) = t01.ptr }
        dealloc(n01)

        u64 n02 = str_cat(prefix, "attn_q.weight")
        GGUFTensor t02 = gguf_get(gf, n02)
        unsafe { *((base + 1 * 8) as u64) = t02.ptr }
        dealloc(n02)

        u64 n03 = str_cat(prefix, "attn_k.weight")
        GGUFTensor t03 = gguf_get(gf, n03)
        unsafe { *((base + 2 * 8) as u64) = t03.ptr }
        dealloc(n03)

        u64 n04 = str_cat(prefix, "attn_v.weight")
        GGUFTensor t04 = gguf_get(gf, n04)
        unsafe { *((base + 3 * 8) as u64) = t04.ptr }
        dealloc(n04)

        // Slots 4 (q_norm), 5 (k_norm) — leave at 0 for Mistral.
        unsafe { *((base + 4 * 8) as u64) = 0 }
        unsafe { *((base + 5 * 8) as u64) = 0 }

        u64 n07 = str_cat(prefix, "attn_output.weight")
        GGUFTensor t07 = gguf_get(gf, n07)
        unsafe { *((base + 6 * 8) as u64) = t07.ptr }
        dealloc(n07)

        u64 n08 = str_cat(prefix, "ffn_norm.weight")
        GGUFTensor t08 = gguf_get(gf, n08)
        unsafe { *((base + 7 * 8) as u64) = t08.ptr }
        dealloc(n08)

        u64 n09 = str_cat(prefix, "ffn_gate.weight")
        GGUFTensor t09 = gguf_get(gf, n09)
        unsafe { *((base + 8 * 8) as u64) = t09.ptr }
        dealloc(n09)

        u64 n10 = str_cat(prefix, "ffn_up.weight")
        GGUFTensor t10 = gguf_get(gf, n10)
        unsafe { *((base + 9 * 8) as u64) = t10.ptr }
        dealloc(n10)

        u64 n11 = str_cat(prefix, "ffn_down.weight")
        GGUFTensor t11 = gguf_get(gf, n11)
        unsafe { *((base + 10 * 8) as u64) = t11.ptr }
        dealloc(n11)

        dealloc(prefix)
        li = li + 1
    }
    u64 load_elapsed_ns = time_elapsed(load_start_ns)
    eout("[mistral7b] 32 layers indexed; load_ms=")
    eu64(load_elapsed_ns / 1000000); eout("\n")

    // ── Destroy-PyTorch CPU slice: Q8_0 → bf16 dequant for layer + lm_head ──
    // Mistral has a SEPARATE output.weight (not tied), so the lm_head
    // dequant uses lmhead_t.ptr — not embed_t.ptr.
    u64 lmhead_bf16_ptr = 0
    if cpu_bf16 != 0 {
        eout("[mistral7b] MLRIFT_CPU_BF16=1: dequantising layer weights Q8_0 → bf16...\n")
        u64 q_dim_l    = QWEN3_Q_DIM
        u64 ff_l       = QWEN3_INTERMEDIATE
        u64 q_elems    = q_dim_l * hidden
        u64 kv_elems   = kv_dim  * hidden
        u64 o_elems    = hidden  * q_dim_l
        u64 gate_elems = ff_l    * hidden
        u64 up_elems   = ff_l    * hidden
        u64 down_elems = hidden  * ff_l
        // Q8_0 block-byte sizes for the madvise step.  Q8_0: 34 B / 32 elems.
        u64 q_q8_bytes    = (q_elems    / 32) * 34
        u64 kv_q8_bytes   = (kv_elems   / 32) * 34
        u64 o_q8_bytes    = (o_elems    / 32) * 34
        u64 gate_q8_bytes = (gate_elems / 32) * 34
        u64 up_q8_bytes   = (up_elems   / 32) * 34
        u64 down_q8_bytes = (down_elems / 32) * 34
        u64 deq_start = time_now()
        // Dequant lm_head FIRST so the Q8_0 source can be released before
        // the 13 GiB of layer bf16 buffers accumulates.  Mistral has an
        // UNTIED output.weight (separate from token_embd.weight) — so
        // unlike Llama-1B's slice 4.27, the per-token embedding lookup
        // here can NOT reuse lmhead_bf16_ptr (it still has to decode from
        // embed_t.ptr).  We do skip the lmhead Q8_0 mmap residency though.
        eout("[mistral7b] dequantising untied lm_head Q8_0 → bf16 ("); eu64(vocab * hidden * 2); eout(" bytes)...\n")
        lmhead_bf16_ptr = q8_0_to_bf16_alloc(lmhead_t.ptr, vocab * hidden)
        u64 lmhead_q8_bytes = (vocab * hidden / 32) * 34
        madv_dontneed(lmhead_t.ptr, lmhead_q8_bytes)
        u64 lf = 0
        while lf < n_layers {
            u64 base = layers_arr + lf * 88
            u64 qp = 0; unsafe { *((base + 1 * 8) as u64) -> qp }
            u64 kp = 0; unsafe { *((base + 2 * 8) as u64) -> kp }
            u64 vp = 0; unsafe { *((base + 3 * 8) as u64) -> vp }
            u64 op = 0; unsafe { *((base + 6 * 8) as u64) -> op }
            u64 gp = 0; unsafe { *((base + 8 * 8) as u64) -> gp }
            u64 up = 0; unsafe { *((base + 9 * 8) as u64) -> up }
            u64 dp = 0; unsafe { *((base + 10 * 8) as u64) -> dp }
            unsafe { *((base + 1 * 8) as u64) = q8_0_to_bf16_alloc(qp, q_elems) }
            madv_dontneed(qp, q_q8_bytes)
            unsafe { *((base + 2 * 8) as u64) = q8_0_to_bf16_alloc(kp, kv_elems) }
            madv_dontneed(kp, kv_q8_bytes)
            unsafe { *((base + 3 * 8) as u64) = q8_0_to_bf16_alloc(vp, kv_elems) }
            madv_dontneed(vp, kv_q8_bytes)
            unsafe { *((base + 6 * 8) as u64) = q8_0_to_bf16_alloc(op, o_elems) }
            madv_dontneed(op, o_q8_bytes)
            unsafe { *((base + 8 * 8) as u64) = q8_0_to_bf16_alloc(gp, gate_elems) }
            madv_dontneed(gp, gate_q8_bytes)
            unsafe { *((base + 9 * 8) as u64) = q8_0_to_bf16_alloc(up, up_elems) }
            madv_dontneed(up, up_q8_bytes)
            unsafe { *((base + 10 * 8) as u64) = q8_0_to_bf16_alloc(dp, down_elems) }
            madv_dontneed(dp, down_q8_bytes)
            lf = lf + 1
        }
        u64 deq_ms = time_elapsed(deq_start) / 1000000
        eout("[mistral7b] dequant_ms="); eu64(deq_ms); eout(" (Q8_0 source pages released via MADV_DONTNEED)\n")
    }

    // ---- KV cache + scratch buffers ----
    u64 kv_row_bytes = kv_dim * 4
    u64 layer_stride = max_seq * kv_row_bytes
    u64 total_cache  = n_layers * layer_stride
    u64 k_cache = alloc(total_cache)
    u64 v_cache = alloc(total_cache)
    eout("[mistral7b] KV cache allocated (")
    eu64(total_cache * 2); eout(" bytes)\n")

    u64 x_cur     = alloc(hidden * 4)
    u64 x_nxt     = alloc(hidden * 4)
    u64 final_out = alloc(hidden * 4)
    u64 logits    = alloc(vocab * 4)

    u64 embed_base = embed_t.ptr
    u64 row_blocks = hidden / 32
    u64 row_bytes  = row_blocks * 34
    eout("[mistral7b] embed row decoded on demand ("); eu64(row_bytes); eout(" B/row)\n")

    // ---- Hardcoded prompt ([BOS, "▁hello"]) ----
    // Mistral SentencePiece tokenisation of "hello" (lowercase, no leading
    // space).  Verified via llama.cpp's dump-tokens against this Q8_0 blob:
    //   prompt_tokens = 1 6312 28709
    //                   <s> ▁hell o
    // The vocab does NOT have a single token for "▁hello" — only the
    // capitalised "▁Hello" (22557).  Three tokens, not two.
    u64 prompt_count = 3
    u64 seq_cap = prompt_count + max_new
    u64 seq_ids32 = alloc(seq_cap * 4)
    u32 t0 = 1        // BOS = <s>
    u32 t1 = 6312     // "▁hell"
    u32 t2 = 28709    // "o"
    unsafe { *((seq_ids32 + 0 * 4) as uint32) = t0 }
    unsafe { *((seq_ids32 + 1 * 4) as uint32) = t1 }
    unsafe { *((seq_ids32 + 2 * 4) as uint32) = t2 }
    u64 seq_len = prompt_count

    eout("[mistral7b] prompt_tokens="); eu64(prompt_count); eout(" ids=[1, 6312, 28709] (\"<s>▁hell o\")\n")

    // ---- Prefill: forward over prompt[0..N-2] to populate K/V cache. ----
    u64 pos = 0
    u64 prefill_start_ns = time_now()
    while pos + 1 < prompt_count {
        u32 pt32 = 0
        unsafe { *((seq_ids32 + pos * 4) as uint32) -> pt32 }
        u64 pt = pt32
        gguf_deq_q8_0(x_cur, embed_base + pt * row_bytes, hidden)
        u64 layer = 0
        while layer < n_layers {
            Qwen3LayerWeights w = layers_arr + layer * 88
            u64 kc = k_cache + layer * layer_stride
            u64 vc = v_cache + layer * layer_stride
            qwen3_forward_layer(x_nxt, x_cur, w, pos, kc, vc, num_workers)
            u64 tmp = x_cur
            x_cur = x_nxt
            x_nxt = tmp
            layer = layer + 1
        }
        pos = pos + 1
    }
    u64 prefill_ns = time_elapsed(prefill_start_ns)
    eout("[mistral7b] prefill_ms="); eu64(prefill_ns / 1000000); eout("\n")

    u32 last_pt32 = 0
    unsafe { *((seq_ids32 + (prompt_count - 1) * 4) as uint32) -> last_pt32 }
    u64 last_pt = last_pt32
    gguf_deq_q8_0(x_cur, embed_base + last_pt * row_bytes, hidden)

    qwen3_profile_reset()
    u64 step = 0
    u64 decode_start_ns = time_now()
    while step < max_new {
        u64 step_start_ns = time_now()
        eout("step "); eu64(step); eout(" pos="); eu64(pos); eout("\n")

        u64 layer = 0
        while layer < n_layers {
            Qwen3LayerWeights w = layers_arr + layer * 88
            u64 kc = k_cache + layer * layer_stride
            u64 vc = v_cache + layer * layer_stride
            qwen3_forward_layer(x_nxt, x_cur, w, pos, kc, vc, num_workers)
            u64 tmp = x_cur
            x_cur = x_nxt
            x_nxt = tmp
            layer = layer + 1
        }

        // Final F32 RMSNorm + lm_head against the SEPARATE output.weight.
        qwen3_rmsnorm_f32_weights(final_out, x_cur, norm_t.ptr, hidden)
        if cpu_bf16 != 0 {
            matmul_bf16_weights_f32(logits, final_out, lmhead_bf16_ptr, 1, vocab, hidden, num_workers, 0)
        } else {
            matmul_q8_0_q8_0_f32(logits, final_out, lmhead_ptr, 1, vocab, hidden, num_workers)
        }

        u64 best_id = 0
        f32 best_val = 0.0f
        u64 first = 1
        u64 j = 0
        while j < vocab {
            f32 v = 0.0f
            unsafe { *((logits + j * 4) as f32) -> v }
            if first == 1 {
                best_val = v; best_id = j; first = 0
            } else {
                if v > best_val { best_val = v; best_id = j }
            }
            j = j + 1
        }
        u64 step_elapsed_ns = time_elapsed(step_start_ns)
        eout("  -> next_id = "); eu64(best_id); eout(" logit=")
        u64 lvs = fmt_f32(best_val, 4); eout(lvs); dealloc(lvs)
        eout(" step_ms="); eu64(step_elapsed_ns / 1000000); eout("\n")

        u32 best_id32 = best_id
        unsafe { *((seq_ids32 + seq_len * 4) as uint32) = best_id32 }
        seq_len = seq_len + 1

        gguf_deq_q8_0(x_cur, embed_base + best_id * row_bytes, hidden)
        pos = pos + 1
        step = step + 1
    }
    u64 total_decode_ns = time_elapsed(decode_start_ns)
    u64 total_ms = total_decode_ns / 1000000
    u64 tokps_milli = 0
    if total_decode_ns != 0 {
        tokps_milli = (max_new * 1000 * 1000000000) / total_decode_ns
    }

    eout("\n=== GENERATED IDs ===\n")
    u64 gi = 0
    while gi < seq_len {
        if gi != 0 { eout(", ") }
        u32 gid32 = 0
        unsafe { *((seq_ids32 + gi * 4) as uint32) -> gid32 }
        u64 gid = gid32
        eu64(gid)
        gi = gi + 1
    }
    eout("\n")

    eout("\n=== TIMING ===\n")
    eout("prompt_tokens="); eu64(prompt_count); eout("\n")
    eout("prefill_ms="); eu64(prefill_ns / 1000000); eout("\n")
    eout("total_decode_ms="); eu64(total_ms); eout("\n")
    eout("tokens_per_sec_x1000="); eu64(tokps_milli); eout("\n")
    eout("tokens_generated="); eu64(max_new); eout("\n")
    qwen3_profile_dump()

    dealloc(x_cur); dealloc(x_nxt); dealloc(final_out); dealloc(logits)
    dealloc(seq_ids32); dealloc(layers_arr)
    dealloc(k_cache); dealloc(v_cache)
    gguf_free(gf)
    thread_pool_shutdown()
    file_close(g_fd)
    exit(0)
}
