    unsafe { *((ids1_ptr + 104) as u64) = 7 }
    unsafe { *((ids1_ptr + 112) as u64) = 6 }
    unsafe { *((ids1_ptr + 120) as u64) = 8 }
    // ids_view2 [4, 4]
    unsafe { *((ids2_ptr + 0) as u64) = 8 }
    unsafe { *((ids2_ptr + 8) as u64) = 12 }
    unsafe { *((ids2_ptr + 16) as u64) = 10 }
    unsafe { *((ids2_ptr + 24) as u64) = 1 }
    unsafe { *((ids2_ptr + 32) as u64) = 6 }
    unsafe { *((ids2_ptr + 40) as u64) = 7 }
    unsafe { *((ids2_ptr + 48) as u64) = 7 }
    unsafe { *((ids2_ptr + 56) as u64) = 14 }
    unsafe { *((ids2_ptr + 64) as u64) = 8 }
    unsafe { *((ids2_ptr + 72) as u64) = 1 }
    unsafe { *((ids2_ptr + 80) as u64) = 5 }
    unsafe { *((ids2_ptr + 88) as u64) = 9 }
    unsafe { *((ids2_ptr + 96) as u64) = 13 }
    unsafe { *((ids2_ptr + 104) as u64) = 8 }
    unsafe { *((ids2_ptr + 112) as u64) = 9 }
    unsafe { *((ids2_ptr + 120) as u64) = 4 }
}

fn main() {
    u64 D = DD
    u64 K = KB
    u64 R = RR
    u64 B = BB
    u64 S = SS

    // Allocate weight buffers
    u64 emb_ptr  = alloc(VOCAB * D * 4)  // [16, 8] f32
    u64 U_ptr    = alloc(K * D * R * 4)  // [2, 8, 4] f32
    u64 V_ptr    = alloc(K * R * D * 4)  // [2, 4, 8] f32
    u64 gw_ptr   = alloc(K * D * 4)      // [2, 8] f32
    u64 gb_ptr   = alloc(K * 4)          // [2] f32
    u64 bias_ptr = alloc(D * 4)          // [8] f32  (zeros)

    // Token id buffers
    u64 ids1_ptr = alloc(B * S * 8)  // [4, 4] u64
    u64 ids2_ptr = alloc(B * S * 8)  // [4, 4] u64

    // Intermediate activation buffers
    u64 x1_ptr  = alloc(B * S * D * 4)  // [4, 4, 8] f32  embed(view1)
    u64 x2_ptr  = alloc(B * S * D * 4)  // [4, 4, 8] f32  embed(view2)
    u64 z1_ptr  = alloc(B * S * D * 4)  // [4, 4, 8] f32  wzma(view1)
    u64 z2_ptr  = alloc(B * S * D * 4)  // [4, 4, 8] f32  wzma(view2)
    u64 q1_ptr  = alloc(B * D * 4)      // [4, 8]    f32  pooled+norm view1
    u64 q2_ptr  = alloc(B * D * 4)      // [4, 8]    f32  pooled+norm view2

    // Fill weights and ids
    init_weights(emb_ptr, U_ptr, V_ptr, gw_ptr, gb_ptr, bias_ptr)
    init_ids(ids1_ptr, ids2_ptr)

    // Forward pass
    embed_f32(x1_ptr, emb_ptr, ids1_ptr, B, S, D)
    embed_f32(x2_ptr, emb_ptr, ids2_ptr, B, S, D)

    wzma_f32(x1_ptr, z1_ptr, U_ptr, V_ptr, gw_ptr, gb_ptr, bias_ptr, B, S, D, K, R)
    wzma_f32(x2_ptr, z2_ptr, U_ptr, V_ptr, gw_ptr, gb_ptr, bias_ptr, B, S, D, K, R)

    mean_pool_s_f32(z1_ptr, q1_ptr, B, S, D)
    mean_pool_s_f32(z2_ptr, q2_ptr, B, S, D)

    l2_normalize_f32(q1_ptr, B, D)
    l2_normalize_f32(q2_ptr, B, D)

    f32 tau = 0.1f
    f32 loss = infonce_f32(q1_ptr, q2_ptr, tau, B, D)

    // Print result
    print_str("loss = ")
    u64 ls = fmt_f32(loss, 6)
    print_str(ls)
    dealloc(ls)
    print_str("\n")

    // Assert |loss - 0.705242| < 1e-4
    f32 ref_loss = 0.705241561f
    f32 diff = loss - ref_loss
    if diff < 0.0f { diff = 0.0f - diff }
    f32 tol = 0.0001f
    if diff < tol {
        print_str("PASS |loss - 0.705242| < 1e-4\n")
    } else {
        print_str("FAIL diff = ")
        u64 ds = fmt_f32(diff, 8)
        print_str(ds)
        dealloc(ds)
        print_str("\n")
        exit(1)
    }

    dealloc(emb_ptr); dealloc(U_ptr); dealloc(V_ptr)
    dealloc(gw_ptr); dealloc(gb_ptr); dealloc(bias_ptr)
    dealloc(ids1_ptr); dealloc(ids2_ptr)
    dealloc(x1_ptr); dealloc(x2_ptr)
    dealloc(z1_ptr); dealloc(z2_ptr)
    dealloc(q1_ptr); dealloc(q2_ptr)

    exit(0)
}
