// bp_wzma_smoke — backprop SP1 Task 2: forward path in CPU f32.
//
// Hardcoded tiny dims: d=8, K=2 banks, r=4, B=4, S=4, vocab=16
// Weights come from tools/bp_ref.json (seed-0 initialisation).
// Expected loss[0] = 0.705242 (tau=0.1, InfoNCE, arange labels).
//
// Build:
//   ./build/mlrc --arch=x86_64 --target=linux --emit=elfexe \
//       examples/bp_wzma_smoke.mlr -o /tmp/bp_wzma_smoke
// Run:
//   /tmp/bp_wzma_smoke
// Expected output: loss = 0.705242 (within 1e-4 of reference)

import "../std/train.mlr"
import "../std/math_float.mlr"
import "../std/fmt.mlr"

// Dims
static u64 DD     = 8       // embedding / hidden dim
static u64 KB     = 2       // WZMA banks
static u64 RR     = 4       // rank
static u64 BB     = 4       // batch
static u64 SS     = 4       // seq len
static u64 VOCAB  = 16      // vocab size

