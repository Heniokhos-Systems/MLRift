// phase3_atom_special_test.mlr — synthetic-bytecode smoke for ATOM opcode
// batch 3 (special ops): setport, setregblock, setfbbase, setdatablock,
// savereg, restorereg, beep, postcard, debug, delay, processds.
//
// 5 scenarios.
// Exit codes:
//   0 = all GREEN
//   1 = scenario 1 failed (setport chain)
//   2 = scenario 2 failed (setregblock)
//   3 = scenario 3 failed (NOP-like: savereg/restorereg/beep/postcard/debug)
//   4 = scenario 4 failed (delay 1 µs)
//   5 = scenario 5 failed (setfbbase from IMM_DWORD)

import "../std/atom.mlr"
import "../std/atom_constants.mlr"
import "../std/sys.mlr"

@dynamic extern fn exit(uint64 code)
@dynamic extern fn puts(uint64 s) -> uint32

// -------------------------------------------------------------------
// Print helpers
// -------------------------------------------------------------------
fn _phex(uint64 lab, uint64 ll, uint64 v) {
    uint64 b = alloc(80)
    uint64 i = 0
    while i < ll {
        uint8 c = 0; unsafe { *((lab + i) as uint8) -> c }
        unsafe { *((b + i) as uint8) = c }; i = i + 1
    }
    uint8 eq = 61; unsafe { *((b + ll) as uint8) = eq }
    uint8 z0 = 48; unsafe { *((b + ll + 1) as uint8) = z0 }
    uint8 zx = 120; unsafe { *((b + ll + 2) as uint8) = zx }
    uint64 j = 0
    while j < 8 {
        uint64 sh = (7 - j) * 4
        uint64 nyb = (v >> sh) & 0xF
        uint8 ch = nyb + 48
        if nyb >= 10 { ch = nyb + 87 }
        unsafe { *((b + ll + 3 + j) as uint8) = ch }
        j = j + 1
    }
    uint8 nul = 0; unsafe { *((b + ll + 11) as uint8) = nul }
    puts(b); dealloc(b)
}

// -------------------------------------------------------------------
// Helper: allocate a minimal atom_context + image with a single cmd-table
// at ct_off; bytecode starts at ct_off + ATOM_CT_CODE_PTR.
// Sets a generous table size of 128 bytes.
// Writes ctx* to *out_ctx_p, image* to *out_image_p.
// -------------------------------------------------------------------
fn _mk_ctx(uint64 image_sz, uint64 ct_off, uint64 ws_dwords,
           uint64 out_ctx_p, uint64 out_image_p) {
    uint64 image = alloc(image_sz)
    uint64 i = 0
    while i < image_sz { uint8 z = 0; unsafe { *((image + i) as uint8) = z }; i = i + 1 }

    // ct header at ct_off: size=128 (generous), WS dwords at byte 4.
    uint16 ct_size = 128; unsafe { *((image + ct_off + 0) as uint16) = ct_size }
    uint8 ws_b = ws_dwords; unsafe { *((image + ct_off + 4) as uint8) = ws_b }

    uint64 ctx = alloc(ATOM_CONTEXT_SIZE)
    uint64 j = 0
    while j < ATOM_CONTEXT_SIZE { uint8 z = 0; unsafe { *((ctx + j) as uint8) = z }; j = j + 1 }
    unsafe { *((ctx + AC_OFF_IMAGE_BUF)  as uint64) = image }
    unsafe { *((ctx + AC_OFF_IMAGE_SIZE) as uint64) = image_sz }

    unsafe { *(out_ctx_p   as uint64) = ctx }
    unsafe { *(out_image_p as uint64) = image }
}

// -------------------------------------------------------------------
// Scenario 1 — setport sequence: ATI(0), ATI(1), PCI, SYSIO.
//
// Expected: after SYSIO the last write to AC_OFF_IO_MODE = ATOM_IO_SYSIO.
//
// Opcodes (from opcode_table in atom.c):
//   setport ATI  = op 55, arg=0 (ATOM_PORT_ATI)  — reads u16 port
//   setport PCI  = op 56, arg=1 (ATOM_PORT_PCI)  — consumes 1 byte
//   setport SYSIO= op 57, arg=2 (ATOM_PORT_SYSIO)— consumes 1 byte
//   EOT          = op 91
//
// Bytecode:
//   [55, 0x00,0x00]     → setport ATI port=0  → io_mode=ATOM_IO_MM(0)
//   [55, 0x01,0x00]     → setport ATI port=1  → io_mode=ATOM_IO_IIO|1(0x81)
//   [56, 0xAA]          → setport PCI          → io_mode=ATOM_IO_PCI(1)
//   [57, 0xBB]          → setport SYSIO        → io_mode=ATOM_IO_SYSIO(2)
//   [91]                → EOT
// total bytecode bytes = 10
// -------------------------------------------------------------------
fn run_s1(uint64 ctx_p, uint64 img_p) -> uint64 {
    uint64 ct_off   = 8
    uint64 bc_start = ct_off + ATOM_CT_CODE_PTR
    uint64 img_sz   = 256

    _mk_ctx(img_sz, ct_off, 0, ctx_p, img_p)
    uint64 ctx = 0; unsafe { *(ctx_p as uint64) -> ctx }
    uint64 image = 0; unsafe { *(img_p as uint64) -> image }

    // setport ATI port=0
    uint8 b0 = 55; unsafe { *((image + bc_start + 0) as uint8) = b0 }
    uint8 b1 = 0;  unsafe { *((image + bc_start + 1) as uint8) = b1 }
    uint8 b2 = 0;  unsafe { *((image + bc_start + 2) as uint8) = b2 }
    // setport ATI port=1
    uint8 b3 = 55; unsafe { *((image + bc_start + 3) as uint8) = b3 }
    uint8 b4 = 1;  unsafe { *((image + bc_start + 4) as uint8) = b4 }
    uint8 b5 = 0;  unsafe { *((image + bc_start + 5) as uint8) = b5 }
    // setport PCI (op=56, consumes 1 pad byte)
    uint8 b6 = 56; unsafe { *((image + bc_start + 6) as uint8) = b6 }
    uint8 b7 = 0xAA; unsafe { *((image + bc_start + 7) as uint8) = b7 }
    // setport SYSIO (op=57, consumes 1 pad byte)
    uint8 b8 = 57; unsafe { *((image + bc_start + 8) as uint8) = b8 }
    uint8 b9 = 0xBB; unsafe { *((image + bc_start + 9) as uint8) = b9 }
    // EOT
    uint8 b10 = 91; unsafe { *((image + bc_start + 10) as uint8) = b10 }

    uint64 rc = atom_execute_table(ctx, ct_off, 0, 0)
    _phex("s1_rc", 5, rc)
    if rc != 0 { return 1 }

    // io_mode should be ATOM_IO_SYSIO = 2 (last setport was SYSIO)
    uint64 io_mode = 0; unsafe { *((ctx + AC_OFF_IO_MODE) as uint64) -> io_mode }
    _phex("s1_io_mode", 10, io_mode)
    if io_mode != ATOM_IO_SYSIO { return 1 }
    return 0
}

// -------------------------------------------------------------------
// Scenario 2 — setregblock sets reg_block from u16.
//
// Opcode: 58, arg=0.
// Bytecode: [58, 0x34,0x12,  91]  → reg_block = 0x1234
// -------------------------------------------------------------------
fn run_s2(uint64 ctx_p, uint64 img_p) -> uint64 {
    uint64 ct_off   = 8
    uint64 bc_start = ct_off + ATOM_CT_CODE_PTR
    uint64 img_sz   = 256

    _mk_ctx(img_sz, ct_off, 0, ctx_p, img_p)
    uint64 ctx = 0; unsafe { *(ctx_p as uint64) -> ctx }
    uint64 image = 0; unsafe { *(img_p as uint64) -> image }

    uint8 b0 = 58;   unsafe { *((image + bc_start + 0) as uint8) = b0 }
    uint8 b1 = 0x34; unsafe { *((image + bc_start + 1) as uint8) = b1 }
    uint8 b2 = 0x12; unsafe { *((image + bc_start + 2) as uint8) = b2 }
    uint8 b3 = 91;   unsafe { *((image + bc_start + 3) as uint8) = b3 }

    uint64 rc = atom_execute_table(ctx, ct_off, 0, 0)
    _phex("s2_rc", 5, rc)
    if rc != 0 { return 1 }

    uint64 rb = 0; unsafe { *((ctx + AC_OFF_REG_BLOCK) as uint64) -> rb }
    _phex("s2_reg_block", 12, rb)
    if rb != 0x1234 { return 1 }
    return 0
}

// -------------------------------------------------------------------
// Scenario 3 — NOP-like opcodes: savereg, restorereg, beep, postcard, debug.
//
// All must dispatch without panic (rc=0) and leave reg_block unchanged at 0.
//
// Opcode numbers:
//   savereg    = 100 — consumes 1 byte
//   restorereg = 101 — consumes 1 byte
//   beep       = 99  — no parameter consumed
//   postcard   = 98  — consumes 1 byte
//   debug      = 121 — consumes 1 byte
//
// Bytecode:
//   [100, 0x11]         savereg    idx=0x11
//   [101, 0x22]         restorereg idx=0x22
//   [99]                beep       (no param)
//   [98, 0xCA]          postcard   code=0xCA
//   [121, 0xFE]         debug      val=0xFE
//   [91]                EOT
// -------------------------------------------------------------------
fn run_s3(uint64 ctx_p, uint64 img_p) -> uint64 {
    uint64 ct_off   = 8
    uint64 bc_start = ct_off + ATOM_CT_CODE_PTR
    uint64 img_sz   = 256

    _mk_ctx(img_sz, ct_off, 0, ctx_p, img_p)
    uint64 ctx = 0; unsafe { *(ctx_p as uint64) -> ctx }
    uint64 image = 0; unsafe { *(img_p as uint64) -> image }

    uint8 b0  = 100;  unsafe { *((image + bc_start + 0)  as uint8) = b0 }
    uint8 b1  = 0x11; unsafe { *((image + bc_start + 1)  as uint8) = b1 }
    uint8 b2  = 101;  unsafe { *((image + bc_start + 2)  as uint8) = b2 }
    uint8 b3  = 0x22; unsafe { *((image + bc_start + 3)  as uint8) = b3 }
    uint8 b4  = 99;   unsafe { *((image + bc_start + 4)  as uint8) = b4 }
    uint8 b5  = 98;   unsafe { *((image + bc_start + 5)  as uint8) = b5 }
    uint8 b6  = 0xCA; unsafe { *((image + bc_start + 6)  as uint8) = b6 }
    uint8 b7  = 121;  unsafe { *((image + bc_start + 7)  as uint8) = b7 }
    uint8 b8  = 0xFE; unsafe { *((image + bc_start + 8)  as uint8) = b8 }
    uint8 b9  = 91;   unsafe { *((image + bc_start + 9)  as uint8) = b9 }

    uint64 rc = atom_execute_table(ctx, ct_off, 0, 0)
    _phex("s3_rc", 5, rc)
    if rc != 0 { return 1 }

    // reg_block must still be 0 (none of these ops modify it)
    uint64 rb = 0; unsafe { *((ctx + AC_OFF_REG_BLOCK) as uint64) -> rb }
    _phex("s3_reg_block", 12, rb)
    if rb != 0 { return 1 }
    return 0
}

// -------------------------------------------------------------------
// Scenario 4 — delay 1 µs: functional (no panic), no measurable side effect.
//
// Opcode: 81 → arg=0 (ATOM_UNIT_MICROSEC)
// Bytecode: [81, 0x01,  91]
// -------------------------------------------------------------------
fn run_s4(uint64 ctx_p, uint64 img_p) -> uint64 {
    uint64 ct_off   = 8
    uint64 bc_start = ct_off + ATOM_CT_CODE_PTR
    uint64 img_sz   = 256

    _mk_ctx(img_sz, ct_off, 0, ctx_p, img_p)
    uint64 ctx = 0; unsafe { *(ctx_p as uint64) -> ctx }
    uint64 image = 0; unsafe { *(img_p as uint64) -> image }

    uint8 b0 = 81;  unsafe { *((image + bc_start + 0) as uint8) = b0 }
    uint8 b1 = 1;   unsafe { *((image + bc_start + 1) as uint8) = b1 }
    uint8 b2 = 91;  unsafe { *((image + bc_start + 2) as uint8) = b2 }

    uint64 rc = atom_execute_table(ctx, ct_off, 0, 0)
    _phex("s4_rc", 5, rc)
    if rc != 0 { return 1 }
    return 0
}

// -------------------------------------------------------------------
// Scenario 5 — setfbbase from IMM_DWORD 0x1000.
//
// setfbbase = op 59, arg=0.
// It reads an attr byte then calls atom_get_src.
// attr must encode: arg=ATOM_ARG_IMM(5), align=ATOM_SRC_DWORD(0)
//   → attr = 5 | (0 << 3) = 0x05
//
// Bytecode:
//   [59, 0x05, 0x00,0x10,0x00,0x00,  91]
//   setfbbase attr=0x05 → IMM_DWORD = 0x00001000
// -------------------------------------------------------------------
fn run_s5(uint64 ctx_p, uint64 img_p) -> uint64 {
    uint64 ct_off   = 8
    uint64 bc_start = ct_off + ATOM_CT_CODE_PTR
    uint64 img_sz   = 256

    _mk_ctx(img_sz, ct_off, 0, ctx_p, img_p)
    uint64 ctx = 0; unsafe { *(ctx_p as uint64) -> ctx }
    uint64 image = 0; unsafe { *(img_p as uint64) -> image }

    uint8 b0 = 59;   unsafe { *((image + bc_start + 0) as uint8) = b0 }  // setfbbase op
    uint8 b1 = 0x05; unsafe { *((image + bc_start + 1) as uint8) = b1 }  // attr: IMM, DWORD
    uint8 b2 = 0x00; unsafe { *((image + bc_start + 2) as uint8) = b2 }  // 0x1000 lo
    uint8 b3 = 0x10; unsafe { *((image + bc_start + 3) as uint8) = b3 }
    uint8 b4 = 0x00; unsafe { *((image + bc_start + 4) as uint8) = b4 }
    uint8 b5 = 0x00; unsafe { *((image + bc_start + 5) as uint8) = b5 }
    uint8 b6 = 91;   unsafe { *((image + bc_start + 6) as uint8) = b6 }  // EOT

    uint64 rc = atom_execute_table(ctx, ct_off, 0, 0)
    _phex("s5_rc", 5, rc)
    if rc != 0 { return 1 }

    // AC_OFF_FB_WINDOW at byte 120 — stored as uint32
    uint32 fw = 0; unsafe { *((ctx + AC_OFF_FB_WINDOW) as uint32) -> fw }
    uint64 fbw = fw
    _phex("s5_fb_window", 12, fbw)
    if fbw != 0x1000 { return 1 }
    return 0
}

fn main() {
    puts("phase3_atom_special_test")

    uint64 ctx_p = alloc(8); unsafe { *(ctx_p as uint64) = 0 }
    uint64 img_p = alloc(8); unsafe { *(img_p as uint64) = 0 }
    uint64 ctx = 0; uint64 image = 0

    // --- Scenario 1: setport chain (ATI/IIO/PCI/SYSIO) ---
    uint64 r1 = run_s1(ctx_p, img_p)
    ctx = 0; unsafe { *(ctx_p as uint64) -> ctx }
    image = 0; unsafe { *(img_p as uint64) -> image }
    dealloc(ctx); dealloc(image)
    if r1 != 0 { puts("FAIL s1: setport"); dealloc(ctx_p); dealloc(img_p); exit(1) }
    puts("PASS s1: setport")

    // --- Scenario 2: setregblock ---
    uint64 r2 = run_s2(ctx_p, img_p)
    ctx = 0; unsafe { *(ctx_p as uint64) -> ctx }
    image = 0; unsafe { *(img_p as uint64) -> image }
    dealloc(ctx); dealloc(image)
    if r2 != 0 { puts("FAIL s2: setregblock"); dealloc(ctx_p); dealloc(img_p); exit(2) }
    puts("PASS s2: setregblock")

    // --- Scenario 3: NOP-like (savereg/restorereg/beep/postcard/debug) ---
    uint64 r3 = run_s3(ctx_p, img_p)
    ctx = 0; unsafe { *(ctx_p as uint64) -> ctx }
    image = 0; unsafe { *(img_p as uint64) -> image }
    dealloc(ctx); dealloc(image)
    if r3 != 0 { puts("FAIL s3: NOP opcodes"); dealloc(ctx_p); dealloc(img_p); exit(3) }
    puts("PASS s3: savereg/restorereg/beep/postcard/debug")

    // --- Scenario 4: delay 1 µs ---
    uint64 r4 = run_s4(ctx_p, img_p)
    ctx = 0; unsafe { *(ctx_p as uint64) -> ctx }
    image = 0; unsafe { *(img_p as uint64) -> image }
    dealloc(ctx); dealloc(image)
    if r4 != 0 { puts("FAIL s4: delay"); dealloc(ctx_p); dealloc(img_p); exit(4) }
    puts("PASS s4: delay 1us")

    // --- Scenario 5: setfbbase from IMM_DWORD ---
    uint64 r5 = run_s5(ctx_p, img_p)
    ctx = 0; unsafe { *(ctx_p as uint64) -> ctx }
    image = 0; unsafe { *(img_p as uint64) -> image }
    dealloc(ctx); dealloc(image)
    if r5 != 0 { puts("FAIL s5: setfbbase"); dealloc(ctx_p); dealloc(img_p); exit(5) }
    puts("PASS s5: setfbbase")

    dealloc(ctx_p); dealloc(img_p)
    puts("phase3_atom_special_test: GREEN")
    exit(0)
}
