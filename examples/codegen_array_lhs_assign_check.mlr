// Confirm: `arr[i] = local` followed by mutating `arr[i]` inside a loop
// does NOT clobber `local`.
//
// Predicted SAFE because Index-LHS Assign emits IR_STORE through an addr
// vreg — there's no back-edge IR_COPY aliasing the local.

import "../std/io.mlr"
import "../std/fmt.mlr"

fn main() {
    u64 fail = 0
    u64 src = 7

    u64[8] arr
    arr[0] = src   // bare-Ident RHS into array slot

    u64 i = 0
    while i < 5 {
        arr[0] = arr[0] + 1
        i = i + 1
    }

    if src != 7 {
        print_str("BUG: arr[i] = src aliased; src=")
        u64 s = fmt_dec(src); print_str(s); dealloc(s); print_str("\n")
        fail = fail + 1
    }
    u64 v = arr[0]
    if v != 12 {
        print_str("BUG: arr[0] != 12, got=")
        u64 s = fmt_dec(v); print_str(s); dealloc(s); print_str("\n")
        fail = fail + 1
    }

    if fail == 0 {
        print_str("PASS\n")
    } else {
        print_str("FAIL\n")
    }
}
