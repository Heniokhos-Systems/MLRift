// Bit-exact validation harness: read 32 f32s from /tmp/q8_in.bin, run
// quantize_row_q8_0 on them, dump the 34-byte block to /tmp/q8_mlrift.bin.
// A separate Python script then diffs the bytes against ggml's
// quantize_row_q8_0_ref output for the same input.
import "../std/io.mlr"
import "../std/matmul.mlr"
import "../std/fmt.mlr"

fn main() {
    u64 in_buf  = alloc(32 * 4)
    u64 out_buf = alloc(34)
    u64 fd_in = file_open("/tmp/q8_in.bin", 0)  // 0 = read
    if fd_in == 0 {
        print_str("open in fail\n"); exit(1)
    }
    u64 nr = file_read(fd_in, in_buf, 32 * 4)
    if nr != 128 {
        print_str("read fail\n"); exit(1)
    }
    file_close(fd_in)

    quantize_row_q8_0(out_buf, in_buf, 32)

    u64 fd_out = file_open("/tmp/q8_mlrift.bin", 1)  // 1 = write
    if fd_out == 0 {
        print_str("open out fail\n"); exit(1)
    }
    file_write(fd_out, out_buf, 34)
    file_close(fd_out)

    // Also test fp16-RNE on a pile of f32s to spot algorithm bugs.
    u64 fd_h = file_open("/tmp/q8_h_in.bin", 0)
    if fd_h != 0 {
        u64 fd_h_out = file_open("/tmp/q8_h_out.bin", 1)
        u64 buf4 = alloc(4)
        u64 buf2 = alloc(2)
        while 1 == 1 {
            u64 got = file_read(fd_h, buf4, 4)
            if got != 4 { break }
            f32 v = 0.0f
            unsafe { *(buf4 as f32) -> v }
            u64 h = _q8q8_fp32_to_fp16_rne(v)
            u8 lo = h & 0xFF
            u8 hi = (h >> 8) & 0xFF
            store8(buf2 + 0, lo)
            store8(buf2 + 1, hi)
            file_write(fd_h_out, buf2, 2)
        }
        file_close(fd_h)
        file_close(fd_h_out)
        dealloc(buf4); dealloc(buf2)
    }

    print_str("ok\n")
    dealloc(in_buf); dealloc(out_buf)
    exit(0)
}
