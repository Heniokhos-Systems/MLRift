// Gemma-2-2B (Q8_0) greedy decode through MLRift's CPU pipeline.
//
// First non-Llama, non-Qwen3 LLM family. Required real arch work in
// std/gemma2.mlr (post-block RMSNorms, soft-cap on attn + lm_head,
// alternating sliding-window attention, GeLU(tanh) activation, embed
// scale by sqrt(hidden), (1 + w) RMSNorm weights).
//
// Specs (from GGUF metadata):
//   architecture            = gemma2
//   layers                  = 26
//   hidden / head_dim       = 2304 / 256
//   q_dim / kv_dim          = 2048 / 1024     (8 / 4 heads, GQA 2:1)
//   ff                      = 9216
//   eps                     = 1e-6
//   attn_logit_softcapping  = 50.0
//   final_logit_softcapping = 30.0
//   attention.sliding_window= 4096           (alternates per layer)
//   rope.freq_base          = 10000          (default; not in metadata)
//   vocab                   = 256000
//   tokenizer.ggml.bos      = 2 (<bos>)
//   tie_word_embeddings     = true            (no output.weight)
//
// Tensor naming (gemma2 GGUF):
//   blk.N.attn_norm.weight              [hidden]   pre-attn RMSNorm w
//   blk.N.attn_q.weight       [hidden, q_dim]      Q proj
//   blk.N.attn_k.weight       [hidden, kv_dim]     K proj
//   blk.N.attn_v.weight       [hidden, kv_dim]     V proj
//   blk.N.attn_output.weight  [q_dim, hidden]      O proj
//   blk.N.post_attention_norm.weight    [hidden]   post-attn RMSNorm w  (NEW)
//   blk.N.ffn_norm.weight               [hidden]   pre-ffn RMSNorm w
//   blk.N.ffn_gate.weight     [hidden, ff]         gate proj
//   blk.N.ffn_up.weight       [hidden, ff]         up proj
//   blk.N.ffn_down.weight     [ff, hidden]         down proj
//   blk.N.post_ffw_norm.weight          [hidden]   post-ffn RMSNorm w  (NEW)
//   token_embd.weight         [hidden, vocab]      tied lm_head
//   output_norm.weight                  [hidden]   final RMSNorm w
//
// Build & run:
//   ./build/mlrc --emit=elfexe examples/gemma2_2b_generate.mlr -o /tmp/gemma2_2b
//   /tmp/gemma2_2b

import "../std/qwen3.mlr"
import "../std/gemma2.mlr"
import "../std/gguf.mlr"
import "../std/matmul.mlr"
import "../std/inference.mlr"
import "../std/io.mlr"
import "../std/fmt.mlr"
import "../std/string.mlr"
import "../std/thread.mlr"
import "../std/time.mlr"
import "../std/math_float.mlr"

static u64 g_fd = 0
fn eout(u64 s) {
    print_str(s)
    if g_fd != 0 {
        u64 n = str_len(s)
        file_write(g_fd, s, n)
    }
}
fn eu64(u64 v) {
    u64 s = fmt_dec(v)
    eout(s)
    dealloc(s)
}
fn ef32(f32 v) {
    u64 s = fmt_f32(v, 4)
    eout(s)
    dealloc(s)
}

fn main() {
    u64 num_workers = 24
    thread_pool_init(num_workers)
    g_fd = file_open("/tmp/gemma2_2b_gen.out", 1)

    // ── Configure shared qwen3 dispatchers for Q8_0 + F32 norms ──
    qwen3_set_arch(2304, 256, 8, 4, 9216)    // hidden, head_dim, nh, nkv, ff
    qwen3_set_matmul_kind(1)                  // Q8_0
    qwen3_set_norm_kind(1)                    // F32 norms
    qwen3_set_rmsnorm_eps_bits(0x358637BD)    // 1e-6 IEEE bits
    qwen3_set_q8_bitexact(1)                  // bit-exact Q8_0×Q8_0 (matches llama.cpp)
    // Gemma2 uses NEOX RoPE pair layout — leave qwen3_rope_pair_layout = 0 (default).

    // ── Configure gemma2-specific knobs ──
    gemma2_set_arch(2304, 256, 8, 4, 9216)
    gemma2_set_attn_softcap(50.0f)   // wired but currently unused (gemma2_attn_cached_softcap WIP)
    gemma2_set_lm_softcap(30.0f)
    gemma2_set_sliding_window(4096)  // wired but currently unused (no-op for short decode)
    gemma2_set_rope_base(10000)               // default, no metadata override

    u64 path = "/usr/share/ollama/.ollama/models/blobs/sha256-9a31a1608e139e7ba6ceb61db8c49022eb26886d715363b21a01943f93fbc0d6"
    eout("[gemma2_2b] loading weights from ollama blob\n")
    u64 load_start_ns = time_now()
    GGUFFile gf = gguf_open(path)
    if gf.file_size == 0 {
        eout("open fail\n")
        thread_pool_shutdown(); file_close(g_fd); exit(1)
    }

    u64 hidden    = 2304
    u64 q_dim     = 2048
    u64 kv_dim    = 1024
    u64 ff        = 9216
    u64 n_layers  = 26
    u64 vocab     = 256000
    u64 max_seq   = 64
    u64 max_new   = 20

    GGUFTensor embed_t = gguf_get(gf, "token_embd.weight")
    if embed_t.ptr == 0 {
        eout("missing token_embd.weight\n")
        gguf_free(gf); thread_pool_shutdown(); file_close(g_fd); exit(1)
    }
    GGUFTensor norm_t = gguf_get(gf, "output_norm.weight")
    if norm_t.ptr == 0 {
        eout("missing output_norm.weight\n")
        gguf_free(gf); thread_pool_shutdown(); file_close(g_fd); exit(1)
    }
    // Final RMSNorm uses (1 + w) like the per-layer norms.
    // GGUF stores (1+w) pre-baked for Gemma2 (per llama.cpp's
    // convert_hf_to_gguf.py: norm tensors get `+1` at conversion). Use the
    // raw F32 weight pointer directly — do NOT re-bake.
    u64 output_norm_w = norm_t.ptr

    // Tied lm_head — token_embd is the [vocab, hidden] Q8_0 row matrix.
    u64 lmhead_ptr = embed_t.ptr

    // ── Per-layer weight pointer table ──
    // 11 u64 slots × 8 = 88 bytes per layer (Gemma2LayerWeights). The four
    // RMSNorm weight slots hold the GGUF (1 + w)-baked f32 pointers.
    // gemma2_forward_layer reinterprets each 88-byte chunk as a struct.
    u64 layers_arr = alloc(n_layers * 88)

    // Track baked-norm allocations for cleanup at exit.
    u64 baked_norm_buffers = alloc(n_layers * 4 * 8)  // 4 norms × n_layers, ptrs

    u64 li = 0
    while li < n_layers {
        u64 base = layers_arr + li * 88
        u64 li_s = fmt_dec(li)
        u64 pre0 = str_cat("blk.", li_s)
        u64 prefix = str_cat(pre0, ".")
        dealloc(li_s); dealloc(pre0)

        // attn_norm → slot 0 (GGUF already stores (1+w) for gemma2)
        u64 n_an = str_cat(prefix, "attn_norm.weight")
        GGUFTensor t_an = gguf_get(gf, n_an)
        unsafe { *((base + 0 * 8) as u64) = t_an.ptr }
        unsafe { *((baked_norm_buffers + (li * 4 + 0) * 8) as u64) = 0 }
        dealloc(n_an)

        // q/k/v projections → slots 1, 2, 3
        u64 n_q = str_cat(prefix, "attn_q.weight")
        GGUFTensor t_q = gguf_get(gf, n_q)
        unsafe { *((base + 1 * 8) as u64) = t_q.ptr }
        dealloc(n_q)

        u64 n_k = str_cat(prefix, "attn_k.weight")
        GGUFTensor t_k = gguf_get(gf, n_k)
        unsafe { *((base + 2 * 8) as u64) = t_k.ptr }
        dealloc(n_k)

        u64 n_v = str_cat(prefix, "attn_v.weight")
        GGUFTensor t_v = gguf_get(gf, n_v)
        unsafe { *((base + 3 * 8) as u64) = t_v.ptr }
        dealloc(n_v)

        // o_proj → slot 4
        u64 n_o = str_cat(prefix, "attn_output.weight")
        GGUFTensor t_o = gguf_get(gf, n_o)
        unsafe { *((base + 4 * 8) as u64) = t_o.ptr }
        dealloc(n_o)

        // post_attention_norm → slot 5 (GGUF already stores (1+w))
        u64 n_pan = str_cat(prefix, "post_attention_norm.weight")
        GGUFTensor t_pan = gguf_get(gf, n_pan)
        unsafe { *((base + 5 * 8) as u64) = t_pan.ptr }
        unsafe { *((baked_norm_buffers + (li * 4 + 1) * 8) as u64) = 0 }
        dealloc(n_pan)

        // ffn_norm → slot 6 (GGUF already stores (1+w))
        u64 n_fn = str_cat(prefix, "ffn_norm.weight")
        GGUFTensor t_fn = gguf_get(gf, n_fn)
        unsafe { *((base + 6 * 8) as u64) = t_fn.ptr }
        unsafe { *((baked_norm_buffers + (li * 4 + 2) * 8) as u64) = 0 }
        dealloc(n_fn)

        // gate/up/down → slots 7, 8, 9
        u64 n_g = str_cat(prefix, "ffn_gate.weight")
        GGUFTensor t_g = gguf_get(gf, n_g)
        unsafe { *((base + 7 * 8) as u64) = t_g.ptr }
        dealloc(n_g)

        u64 n_u = str_cat(prefix, "ffn_up.weight")
        GGUFTensor t_u = gguf_get(gf, n_u)
        unsafe { *((base + 8 * 8) as u64) = t_u.ptr }
        dealloc(n_u)

        u64 n_d = str_cat(prefix, "ffn_down.weight")
        GGUFTensor t_d = gguf_get(gf, n_d)
        unsafe { *((base + 9 * 8) as u64) = t_d.ptr }
        dealloc(n_d)

        // post_ffw_norm → slot 10 (GGUF already stores (1+w))
        u64 n_pfn = str_cat(prefix, "post_ffw_norm.weight")
        GGUFTensor t_pfn = gguf_get(gf, n_pfn)
        unsafe { *((base + 10 * 8) as u64) = t_pfn.ptr }
        unsafe { *((baked_norm_buffers + (li * 4 + 3) * 8) as u64) = 0 }
        dealloc(n_pfn)

        dealloc(prefix)
        li = li + 1
    }
    u64 load_elapsed_ns = time_elapsed(load_start_ns)
    eout("[gemma2_2b] 26 layers indexed (norms baked +1); load_ms=")
    eu64(load_elapsed_ns / 1000000); eout("\n")


    // ── KV cache (per-layer, max_seq slots) ──
    u64 kv_row_bytes = kv_dim * 4
    u64 layer_stride = max_seq * kv_row_bytes
    u64 total_cache  = n_layers * layer_stride
    u64 k_cache = alloc(total_cache)
    u64 v_cache = alloc(total_cache)
    eout("[gemma2_2b] KV cache allocated ("); eu64(total_cache * 2); eout(" bytes)\n")

    u64 x_cur     = alloc(hidden * 4)
    u64 x_nxt     = alloc(hidden * 4)
    u64 final_out = alloc(hidden * 4)
    u64 logits    = alloc(vocab * 4)

    // Per-row Q8_0 decode geometry for the embedding lookup.
    u64 embed_base = embed_t.ptr
    u64 row_blocks = hidden / 32
    u64 row_bytes  = row_blocks * 34
    eout("[gemma2_2b] embed row decoded on demand ("); eu64(row_bytes); eout(" B/row)\n")

    // ── Hardcoded prompt seed ──
    // Gemma 2 BOS = 2 (<bos>).  Greedy "hello" — token id 17534 in the
    // SentencePiece vocab (verified against tokenizer.ggml.tokens dump).
    u64 prompt_count = 2
    u64 seq_cap = prompt_count + max_new
    u64 seq_ids32 = alloc(seq_cap * 4)
    u32 t0 = 2
    u32 t1 = 17534
    unsafe { *((seq_ids32 + 0 * 4) as uint32) = t0 }
    unsafe { *((seq_ids32 + 1 * 4) as uint32) = t1 }
    u64 seq_len = prompt_count

    eout("[gemma2_2b] prompt_tokens="); eu64(prompt_count); eout(" ids=[2, 17534] (\"<bos>hello\")\n")


    // ── Prefill: every prompt token except the last needs its K/V cached. ──
    u64 pos = 0
    u64 prefill_start_ns = time_now()
    while pos + 1 < prompt_count {
        u32 pt32 = 0
        unsafe { *((seq_ids32 + pos * 4) as uint32) -> pt32 }
        u64 pt = pt32
        gguf_deq_q8_0(x_cur, embed_base + pt * row_bytes, hidden)
        gemma2_scale_embed_inplace(x_cur, hidden)
        u64 layer = 0
        while layer < n_layers {
            Gemma2LayerWeights w = layers_arr + layer * 88
            u64 kc = k_cache + layer * layer_stride
            u64 vc = v_cache + layer * layer_stride
            gemma2_forward_layer(x_nxt, x_cur, w, pos, kc, vc, num_workers, layer)
            u64 tmp = x_cur
            x_cur = x_nxt
            x_nxt = tmp
            layer = layer + 1
        }
        pos = pos + 1
    }
    u64 prefill_ns = time_elapsed(prefill_start_ns)
    eout("[gemma2_2b] prefill_ms="); eu64(prefill_ns / 1000000); eout("\n")

    // Load last prompt token embedding for step 0.
    u32 last_pt32 = 0
    unsafe { *((seq_ids32 + (prompt_count - 1) * 4) as uint32) -> last_pt32 }
    u64 last_pt = last_pt32
    gguf_deq_q8_0(x_cur, embed_base + last_pt * row_bytes, hidden)
    gemma2_scale_embed_inplace(x_cur, hidden)

    u64 step = 0
    u64 decode_start_ns = time_now()
    while step < max_new {
        u64 step_start_ns = time_now()
        eout("step "); eu64(step); eout(" pos="); eu64(pos); eout("\n")

        u64 layer = 0
        while layer < n_layers {
            Gemma2LayerWeights w = layers_arr + layer * 88
            u64 kc = k_cache + layer * layer_stride
            u64 vc = v_cache + layer * layer_stride
            gemma2_forward_layer(x_nxt, x_cur, w, pos, kc, vc, num_workers, layer)
            u64 tmp = x_cur
            x_cur = x_nxt
            x_nxt = tmp
            layer = layer + 1
        }

        // Final RMSNorm (with baked output_norm_w (1 + w)) + lm_head.
        qwen3_rmsnorm_f32_weights(final_out, x_cur, output_norm_w, hidden)
        matmul_q8_0_q8_0_f32(logits, final_out, lmhead_ptr, 1, vocab, hidden, num_workers)

        gemma2_softcap_logits(logits, vocab)

        u64 best_id = 0
        f32 best_val = 0.0f
        u64 first = 1
        u64 j = 0
        while j < vocab {
            f32 v = 0.0f
            unsafe { *((logits + j * 4) as f32) -> v }
            if first == 1 {
                best_val = v; best_id = j; first = 0
            } else {
                if v > best_val { best_val = v; best_id = j }
            }
            j = j + 1
        }
        u64 step_elapsed_ns = time_elapsed(step_start_ns)
        eout("  -> next_id = "); eu64(best_id); eout(" logit=")
        ef32(best_val)
        eout(" step_ms="); eu64(step_elapsed_ns / 1000000); eout("\n")

        u32 best_id32 = best_id
        unsafe { *((seq_ids32 + seq_len * 4) as uint32) = best_id32 }
        seq_len = seq_len + 1

        gguf_deq_q8_0(x_cur, embed_base + best_id * row_bytes, hidden)
        gemma2_scale_embed_inplace(x_cur, hidden)
        pos = pos + 1
        step = step + 1
    }
    u64 total_decode_ns = time_elapsed(decode_start_ns)
    u64 total_ms = total_decode_ns / 1000000
    u64 tokps_milli = 0
    if total_decode_ns != 0 {
        tokps_milli = (max_new * 1000 * 1000000000) / total_decode_ns
    }

    eout("\n=== GENERATED IDs ===\n")
    u64 gi = 0
    while gi < seq_len {
        if gi != 0 { eout(", ") }
        u32 gid32 = 0
        unsafe { *((seq_ids32 + gi * 4) as uint32) -> gid32 }
        u64 gid = gid32
        eu64(gid)
        gi = gi + 1
    }
    eout("\n")

    eout("\n=== TIMING ===\n")
    eout("prompt_tokens="); eu64(prompt_count); eout("\n")
    eout("prefill_ms="); eu64(prefill_ns / 1000000); eout("\n")
    eout("total_decode_ms="); eu64(total_ms); eout("\n")
    eout("tokens_per_sec_x1000="); eu64(tokps_milli); eout("\n")
    eout("tokens_generated="); eu64(max_new); eout("\n")

    // Cleanup baked norms.
    u64 bi = 0
    while bi < n_layers * 4 {
        u64 p = 0
        unsafe { *((baked_norm_buffers + bi * 8) as u64) -> p }
        if p != 0 { dealloc(p) }
        bi = bi + 1
    }
    dealloc(output_norm_w)

    dealloc(x_cur); dealloc(x_nxt); dealloc(final_out); dealloc(logits)
    dealloc(seq_ids32); dealloc(layers_arr); dealloc(baked_norm_buffers)
    dealloc(k_cache); dealloc(v_cache)
    gguf_free(gf)
    thread_pool_shutdown()
    file_close(g_fd)
    exit(0)
}
