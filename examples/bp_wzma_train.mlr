    unsafe { *((ptr + 0) as f32) = 0.43383464f }
    unsafe { *((ptr + 4) as f32) = -0.4338343f }
}

// Reference losses [5] from bp_ref.json cpu.losses
fn ref_loss(u64 step) -> f32 {
    if step == 0 { return 0.705241561f }
    if step == 1 { return 1.231822848f }
    if step == 2 { return 1.157875299f }
    if step == 3 { return 1.166963339f }
    return 1.165753603f
}

// =========================================================================
// main
// =========================================================================
fn main() {
    u64 D = DD
    u64 K = KB
    u64 R = RR
    u64 B = BB
    u64 S = SS

    // --- Allocate weight buffers ---
    u64 emb_ptr  = alloc(VOCAB * D * 4)
    u64 U_ptr    = alloc(K * D * R * 4)
    u64 V_ptr    = alloc(K * R * D * 4)
    u64 gw_ptr   = alloc(K * D * 4)
    u64 gb_ptr   = alloc(K * 4)
    u64 bias_ptr = alloc(D * 4)

    // --- Gradient buffers (zeroed when needed) ---
    u64 demb_ptr  = alloc(VOCAB * D * 4)
    u64 dU_ptr    = alloc(K * D * R * 4)
    u64 dV_ptr    = alloc(K * R * D * 4)
    u64 dgw_ptr   = alloc(K * D * 4)
    u64 dgb_ptr   = alloc(K * 4)
    u64 dbias_ptr = alloc(D * 4)

    // --- AdamW moment buffers (zeroed) ---
    u64 m_emb  = alloc(VOCAB * D * 4)
    u64 v_emb  = alloc(VOCAB * D * 4)
    u64 m_U    = alloc(K * D * R * 4)
    u64 v_U    = alloc(K * D * R * 4)
    u64 m_V    = alloc(K * R * D * 4)
    u64 v_V    = alloc(K * R * D * 4)
    u64 m_gw   = alloc(K * D * 4)
    u64 v_gw   = alloc(K * D * 4)
    u64 m_gb   = alloc(K * 4)
    u64 v_gb   = alloc(K * 4)
    u64 m_bias = alloc(D * 4)
    u64 v_bias = alloc(D * 4)

    // --- Token id buffers ---
    u64 ids1_ptr = alloc(B * S * 8)
    u64 ids2_ptr = alloc(B * S * 8)

    // --- Activation buffers ---
    u64 x1_ptr    = alloc(B * S * D * 4)
    u64 x2_ptr    = alloc(B * S * D * 4)
    u64 z1_ptr    = alloc(B * S * D * 4)
    u64 z2_ptr    = alloc(B * S * D * 4)
    u64 alpha1    = alloc(B * S * K * 4)
    u64 inter1    = alloc(B * S * K * R * 4)
    u64 outk1     = alloc(B * S * K * D * 4)
    u64 alpha2    = alloc(B * S * K * 4)
    u64 inter2    = alloc(B * S * K * R * 4)
    u64 outk2     = alloc(B * S * K * D * 4)
    u64 q1_ptr    = alloc(B * D * 4)
    u64 q2_ptr    = alloc(B * D * 4)
    u64 norms1    = alloc(B * 4)
    u64 norms2    = alloc(B * 4)

    // --- Fill weights and ids ---
    init_weights(emb_ptr, U_ptr, V_ptr, gw_ptr, gb_ptr, bias_ptr)
    init_ids(ids1_ptr, ids2_ptr)

    // =====================================================================
    // Step 1: Single forward + backward to get analytic grads
    // =====================================================================
    memset(demb_ptr,  0, VOCAB * D * 4)
    memset(dU_ptr,    0, K * D * R * 4)
    memset(dV_ptr,    0, K * R * D * 4)
    memset(dgw_ptr,   0, K * D * 4)
    memset(dgb_ptr,   0, K * 4)
    memset(dbias_ptr, 0, D * 4)

    f32 loss0 = full_forward(emb_ptr, U_ptr, V_ptr, gw_ptr, gb_ptr, bias_ptr,
                              ids1_ptr, ids2_ptr,
                              x1_ptr, x2_ptr, z1_ptr, z2_ptr,
                              alpha1, inter1, outk1, alpha2, inter2, outk2,
                              q1_ptr, q2_ptr, norms1, norms2,
                              B, S, D, K, R)

    full_backward(q1_ptr, q2_ptr, z1_ptr, z2_ptr, x1_ptr, x2_ptr,
                  alpha1, inter1, outk1, alpha2, inter2, outk2,
                  norms1, norms2, U_ptr, V_ptr, gw_ptr, ids1_ptr, ids2_ptr,
                  B, S, D, K, R,
                  dU_ptr, dV_ptr, dgw_ptr, dgb_ptr, dbias_ptr, demb_ptr)

    // =====================================================================
    // Step 2: Finite-difference gradient check
    // =====================================================================
    print_str("\n=== Finite-difference gradient checks ===\n")

    // FD tolerance: ~1e-2 rel as per spec.
    // eps chosen per-param: small-gradient params use 1e-3; bias uses 3e-5
    // (bias has large grads ~500 so eps*grad must be << 1 to stay in linear regime)
    f32 fd_tol = 0.01f
    u64 fd_ok = 1

    // Check bias: use eps=3e-5 to stay in linear regime (grad~500, 500*3e-5=0.015 << loss=0.7)
    f32 eps_bias = 0.00003f
    f32 fd_bias = fd_check_param(bias_ptr, dbias_ptr, D,
                                  emb_ptr, U_ptr, V_ptr, gw_ptr, gb_ptr, bias_ptr,
                                  ids1_ptr, ids2_ptr, B, S, D, K, R, eps_bias)
    print_str("  bias    max_rel_err = ")
    u64 ss = fmt_f32(fd_bias, 4)
    print_str(ss); dealloc(ss)
    if fd_bias < fd_tol {
        print_str("  PASS\n")
    } else {
        print_str("  FAIL\n")
        fd_ok = 0
    }

    // Check gate.bias (K=2 elements), eps=1e-3
    f32 eps_std = 0.001f
    f32 fd_gb = fd_check_param(gb_ptr, dgb_ptr, K,
                                emb_ptr, U_ptr, V_ptr, gw_ptr, gb_ptr, bias_ptr,
                                ids1_ptr, ids2_ptr, B, S, D, K, R, eps_std)
    print_str("  gate.bias max_rel_err = ")
    ss = fmt_f32(fd_gb, 4)
    print_str(ss); dealloc(ss)
    if fd_gb < fd_tol {
        print_str("  PASS\n")
    } else {
        print_str("  FAIL\n")
        fd_ok = 0
    }

    // Check gate.weight (K*D=16 elements), eps=1e-3
    f32 fd_gw = fd_check_param(gw_ptr, dgw_ptr, K * D,
                                emb_ptr, U_ptr, V_ptr, gw_ptr, gb_ptr, bias_ptr,
                                ids1_ptr, ids2_ptr, B, S, D, K, R, eps_std)
    print_str("  gate.weight max_rel_err = ")
    ss = fmt_f32(fd_gw, 4)
    print_str(ss); dealloc(ss)
    if fd_gw < fd_tol {
        print_str("  PASS\n")
    } else {
        print_str("  FAIL\n")
        fd_ok = 0
    }

    // Check V (K*R*D=64 elements), eps=5e-4
    f32 eps_V = 0.0005f
    f32 fd_V = fd_check_param(V_ptr, dV_ptr, K * R * D,
                               emb_ptr, U_ptr, V_ptr, gw_ptr, gb_ptr, bias_ptr,
                               ids1_ptr, ids2_ptr, B, S, D, K, R, eps_V)
    print_str("  V       max_rel_err = ")
    ss = fmt_f32(fd_V, 4)
    print_str(ss); dealloc(ss)
    if fd_V < fd_tol {
        print_str("  PASS\n")
    } else {
        print_str("  FAIL\n")
        fd_ok = 0
    }

    // Check U (K*D*R=64 elements), eps=5e-4
    f32 fd_U = fd_check_param(U_ptr, dU_ptr, K * D * R,
                               emb_ptr, U_ptr, V_ptr, gw_ptr, gb_ptr, bias_ptr,
                               ids1_ptr, ids2_ptr, B, S, D, K, R, eps_V)
    print_str("  U       max_rel_err = ")
    ss = fmt_f32(fd_U, 4)
    print_str(ss); dealloc(ss)
    if fd_U < fd_tol {
        print_str("  PASS\n")
    } else {
        print_str("  FAIL\n")
        fd_ok = 0
    }

    // Check embed (VOCAB*D=128 elements), eps=1e-3
    f32 fd_emb = fd_check_param(emb_ptr, demb_ptr, VOCAB * D,
                                 emb_ptr, U_ptr, V_ptr, gw_ptr, gb_ptr, bias_ptr,
                                 ids1_ptr, ids2_ptr, B, S, D, K, R, eps_std)
    print_str("  embed   max_rel_err = ")
    ss = fmt_f32(fd_emb, 4)
    print_str(ss); dealloc(ss)
    if fd_emb < fd_tol {
        print_str("  PASS\n")
    } else {
        print_str("  FAIL\n")
        fd_ok = 0
    }

    if fd_ok == 0 {
        print_str("FAIL: finite-diff check\n")
        exit(1)
    }

    // =====================================================================
    // Step 3: Analytic grad vs torch reference (grads_after_step1)
    // =====================================================================
    print_str("\n=== Analytic grad vs torch reference ===\n")

    u64 ref_buf = alloc(VOCAB * D * 4)
    u64 an_ok = 1
    f32 tol_normal = 0.0002f
    f32 tol_bias   = 0.001f   // bias is large (~569), allow 5e-4 abs

    load_ref_bias_grad(ref_buf)
    f32 d_bias = check_grad_vs_ref(dbias_ptr, ref_buf, D, tol_bias)
    print_str("  bias    max_abs_diff = ")
    ss = fmt_f32(d_bias, 4)
    print_str(ss); dealloc(ss)
    if d_bias < tol_bias { print_str("  PASS\n") } else { print_str("  FAIL\n"); an_ok = 0 }

    load_ref_gb_grad(ref_buf)
    f32 d_gb = check_grad_vs_ref(dgb_ptr, ref_buf, K, tol_normal)
    print_str("  gate.bias max_abs_diff = ")
    ss = fmt_f32(d_gb, 5)
    print_str(ss); dealloc(ss)
    if d_gb < tol_normal { print_str("  PASS\n") } else { print_str("  FAIL\n"); an_ok = 0 }

    load_ref_gw_grad(ref_buf)
    f32 d_gw = check_grad_vs_ref(dgw_ptr, ref_buf, K * D, tol_normal)
    print_str("  gate.weight max_abs_diff = ")
    ss = fmt_f32(d_gw, 5)
    print_str(ss); dealloc(ss)
    if d_gw < tol_normal { print_str("  PASS\n") } else { print_str("  FAIL\n"); an_ok = 0 }

    load_ref_V_grad(ref_buf)
    f32 d_V = check_grad_vs_ref(dV_ptr, ref_buf, K * R * D, tol_normal)
    print_str("  V       max_abs_diff = ")
    ss = fmt_f32(d_V, 5)
    print_str(ss); dealloc(ss)
    if d_V < tol_normal { print_str("  PASS\n") } else { print_str("  FAIL\n"); an_ok = 0 }

    load_ref_U_grad(ref_buf)
    f32 d_U = check_grad_vs_ref(dU_ptr, ref_buf, K * D * R, tol_normal)
    print_str("  U       max_abs_diff = ")
    ss = fmt_f32(d_U, 5)
    print_str(ss); dealloc(ss)
    if d_U < tol_normal { print_str("  PASS\n") } else { print_str("  FAIL\n"); an_ok = 0 }

    load_ref_emb_grad(ref_buf)
    f32 d_emb = check_grad_vs_ref(demb_ptr, ref_buf, VOCAB * D, tol_normal)
    print_str("  embed   max_abs_diff = ")
    ss = fmt_f32(d_emb, 5)
    print_str(ss); dealloc(ss)
    if d_emb < tol_normal { print_str("  PASS\n") } else { print_str("  FAIL\n"); an_ok = 0 }

    dealloc(ref_buf)

    if an_ok == 0 {
        print_str("FAIL: analytic grad vs torch reference\n")
        exit(1)
    }

    // =====================================================================
    // Step 4: 5 AdamW training steps, compare losses to cpu.losses
    // =====================================================================
    print_str("\n=== 5 AdamW training steps ===\n")

    // Reset weights to init
    init_weights(emb_ptr, U_ptr, V_ptr, gw_ptr, gb_ptr, bias_ptr)

    // Zero AdamW moment buffers
    memset(m_emb,  0, VOCAB * D * 4)
    memset(v_emb,  0, VOCAB * D * 4)
    memset(m_U,    0, K * D * R * 4)
    memset(v_U,    0, K * D * R * 4)
    memset(m_V,    0, K * R * D * 4)
    memset(v_V,    0, K * R * D * 4)
    memset(m_gw,   0, K * D * 4)
    memset(v_gw,   0, K * D * 4)
    memset(m_gb,   0, K * 4)
    memset(v_gb,   0, K * 4)
    memset(m_bias, 0, D * 4)
    memset(v_bias, 0, D * 4)

    f32 lr    = 0.001f
    f32 beta1 = 0.9f
    f32 beta2 = 0.999f
    f32 eps_adam = 0.00000001f
    f32 wd    = 0.01f
    f32 loss_tol = 0.0001f

    u64 loss_ok = 1
    u64 step = 1
    while step <= 5 {
        // Zero grads
        memset(demb_ptr,  0, VOCAB * D * 4)
        memset(dU_ptr,    0, K * D * R * 4)
        memset(dV_ptr,    0, K * R * D * 4)
        memset(dgw_ptr,   0, K * D * 4)
        memset(dgb_ptr,   0, K * 4)
        memset(dbias_ptr, 0, D * 4)

        // Forward
        f32 loss = full_forward(emb_ptr, U_ptr, V_ptr, gw_ptr, gb_ptr, bias_ptr,
                                ids1_ptr, ids2_ptr,
                                x1_ptr, x2_ptr, z1_ptr, z2_ptr,
                                alpha1, inter1, outk1, alpha2, inter2, outk2,
                                q1_ptr, q2_ptr, norms1, norms2,
                                B, S, D, K, R)

        // Backward
        full_backward(q1_ptr, q2_ptr, z1_ptr, z2_ptr, x1_ptr, x2_ptr,
                      alpha1, inter1, outk1, alpha2, inter2, outk2,
                      norms1, norms2, U_ptr, V_ptr, gw_ptr, ids1_ptr, ids2_ptr,
                      B, S, D, K, R,
                      dU_ptr, dV_ptr, dgw_ptr, dgb_ptr, dbias_ptr, demb_ptr)

        // AdamW step for each param
        u64 step_idx = step
        adamw_step(emb_ptr,  demb_ptr,  m_emb,  v_emb,  VOCAB * D, step_idx, lr, beta1, beta2, eps_adam, wd)
        adamw_step(U_ptr,    dU_ptr,    m_U,    v_U,    K * D * R, step_idx, lr, beta1, beta2, eps_adam, wd)
        adamw_step(V_ptr,    dV_ptr,    m_V,    v_V,    K * R * D, step_idx, lr, beta1, beta2, eps_adam, wd)
        adamw_step(gw_ptr,   dgw_ptr,   m_gw,   v_gw,   K * D,     step_idx, lr, beta1, beta2, eps_adam, wd)
        adamw_step(gb_ptr,   dgb_ptr,   m_gb,   v_gb,   K,         step_idx, lr, beta1, beta2, eps_adam, wd)
        adamw_step(bias_ptr, dbias_ptr, m_bias, v_bias, D,          step_idx, lr, beta1, beta2, eps_adam, wd)

        // Print and check
        u64 step_n = step - 1
        f32 ref = ref_loss(step_n)
        f32 diff = abs_f32(loss - ref)
        print_str("  step ")
        u64 sn = fmt_dec(step_n)
        print_str(sn); dealloc(sn)
        print_str(": loss = ")
        ss = fmt_f32(loss, 7)
        print_str(ss); dealloc(ss)
        print_str("  ref = ")
        ss = fmt_f32(ref, 7)
        print_str(ss); dealloc(ss)
        print_str("  diff = ")
        ss = fmt_f32(diff, 6)
        print_str(ss); dealloc(ss)
        if diff < loss_tol {
            print_str("  PASS\n")
        } else {
            print_str("  FAIL\n")
            loss_ok = 0
        }

        step = step + 1
    }

    if loss_ok == 0 {
        print_str("FAIL: AdamW training losses\n")
        exit(1)
    }

    print_str("\nALL TESTS PASS\n")

    // Cleanup
    dealloc(emb_ptr); dealloc(U_ptr); dealloc(V_ptr)
    dealloc(gw_ptr); dealloc(gb_ptr); dealloc(bias_ptr)
    dealloc(demb_ptr); dealloc(dU_ptr); dealloc(dV_ptr)
    dealloc(dgw_ptr); dealloc(dgb_ptr); dealloc(dbias_ptr)
    dealloc(m_emb); dealloc(v_emb)
    dealloc(m_U); dealloc(v_U)
    dealloc(m_V); dealloc(v_V)
    dealloc(m_gw); dealloc(v_gw)
    dealloc(m_gb); dealloc(v_gb)
    dealloc(m_bias); dealloc(v_bias)
    dealloc(ids1_ptr); dealloc(ids2_ptr)
    dealloc(x1_ptr); dealloc(x2_ptr)
    dealloc(z1_ptr); dealloc(z2_ptr)
    dealloc(alpha1); dealloc(inter1); dealloc(outk1)
    dealloc(alpha2); dealloc(inter2); dealloc(outk2)
    dealloc(q1_ptr); dealloc(q2_ptr)
    dealloc(norms1); dealloc(norms2)

    exit(0)
}
