    unsafe { *((ids2_ptr + 16) as u64) = 10 }
    unsafe { *((ids2_ptr + 24) as u64) = 1 }
    unsafe { *((ids2_ptr + 32) as u64) = 6 }
    unsafe { *((ids2_ptr + 40) as u64) = 7 }
    unsafe { *((ids2_ptr + 48) as u64) = 7 }
    unsafe { *((ids2_ptr + 56) as u64) = 14 }
    unsafe { *((ids2_ptr + 64) as u64) = 8 }
    unsafe { *((ids2_ptr + 72) as u64) = 1 }
    unsafe { *((ids2_ptr + 80) as u64) = 5 }
    unsafe { *((ids2_ptr + 88) as u64) = 9 }
    unsafe { *((ids2_ptr + 96) as u64) = 13 }
    unsafe { *((ids2_ptr + 104) as u64) = 8 }
    unsafe { *((ids2_ptr + 112) as u64) = 9 }
    unsafe { *((ids2_ptr + 120) as u64) = 4 }
}

// =========================================================================
// Full forward pass: returns InfoNCE loss, writes activations to save bufs
// =========================================================================
fn full_forward(u64 emb_ptr, u64 U_ptr, u64 V_ptr,
                u64 gw_ptr, u64 gb_ptr, u64 bias_ptr,
                u64 ids1_ptr, u64 ids2_ptr,
                u64 x1_ptr, u64 x2_ptr,
                u64 z1_ptr, u64 z2_ptr,
                u64 alpha1_ptr, u64 inter1_ptr, u64 outk1_ptr,
                u64 alpha2_ptr, u64 inter2_ptr, u64 outk2_ptr,
                u64 q1_ptr, u64 q2_ptr,
                u64 norms1_ptr, u64 norms2_ptr,
                u64 B, u64 S, u64 D, u64 K, u64 R) -> f32 {
    embed_f32(x1_ptr, emb_ptr, ids1_ptr, B, S, D)
    embed_f32(x2_ptr, emb_ptr, ids2_ptr, B, S, D)
    wzma_f32_fwd(x1_ptr, z1_ptr, U_ptr, V_ptr, gw_ptr, gb_ptr, bias_ptr,
                 B, S, D, K, R, alpha1_ptr, inter1_ptr, outk1_ptr)
    wzma_f32_fwd(x2_ptr, z2_ptr, U_ptr, V_ptr, gw_ptr, gb_ptr, bias_ptr,
                 B, S, D, K, R, alpha2_ptr, inter2_ptr, outk2_ptr)
    mean_pool_s_f32(z1_ptr, q1_ptr, B, S, D)
    mean_pool_s_f32(z2_ptr, q2_ptr, B, S, D)
    l2_normalize_f32_save(q1_ptr, B, D, norms1_ptr)
    l2_normalize_f32_save(q2_ptr, B, D, norms2_ptr)
    f32 tau = 0.1f
    f32 loss = infonce_f32(q1_ptr, q2_ptr, tau, B, D)
    return loss
}

// =========================================================================
// Full backward pass (both views, grads accumulated)
// =========================================================================
fn full_backward(u64 q1_ptr, u64 q2_ptr,
                 u64 z1_ptr, u64 z2_ptr,
                 u64 x1_ptr, u64 x2_ptr,
                 u64 alpha1_ptr, u64 inter1_ptr, u64 outk1_ptr,
                 u64 alpha2_ptr, u64 inter2_ptr, u64 outk2_ptr,
                 u64 norms1_ptr, u64 norms2_ptr,
                 u64 U_ptr, u64 V_ptr, u64 gw_ptr,
                 u64 ids1_ptr, u64 ids2_ptr,
                 u64 B, u64 S, u64 D, u64 K, u64 R,
                 u64 dU_ptr, u64 dV_ptr, u64 dgw_ptr, u64 dgb_ptr,
                 u64 dbias_ptr, u64 demb_ptr) {
    // dq1, dq2: [B,D]
    u64 dq1_ptr = alloc(B * D * 4)
    u64 dq2_ptr = alloc(B * D * 4)
    // dp1, dp2: [B,D]
    u64 dp1_ptr = alloc(B * D * 4)
    u64 dp2_ptr = alloc(B * D * 4)
    // dz1, dz2: [B,S,D]
    u64 dz1_ptr = alloc(B * S * D * 4)
    u64 dz2_ptr = alloc(B * S * D * 4)
    // dx1, dx2: [B,S,D]
    u64 dx1_ptr = alloc(B * S * D * 4)
    u64 dx2_ptr = alloc(B * S * D * 4)

    f32 tau = 0.1f
    infonce_bwd(q1_ptr, q2_ptr, tau, B, D, dq1_ptr, dq2_ptr)

    l2norm_bwd(dq1_ptr, q1_ptr, norms1_ptr, B, D, dp1_ptr)
    l2norm_bwd(dq2_ptr, q2_ptr, norms2_ptr, B, D, dp2_ptr)

    meanpool_bwd(dp1_ptr, B, S, D, dz1_ptr)
    meanpool_bwd(dp2_ptr, B, S, D, dz2_ptr)

    wzma_bwd(dz1_ptr, x1_ptr,
             alpha1_ptr, inter1_ptr, outk1_ptr,
             U_ptr, V_ptr, gw_ptr,
             B, S, D, K, R,
             dU_ptr, dV_ptr, dgw_ptr, dgb_ptr, dbias_ptr,
             dx1_ptr)
    wzma_bwd(dz2_ptr, x2_ptr,
             alpha2_ptr, inter2_ptr, outk2_ptr,
             U_ptr, V_ptr, gw_ptr,
             B, S, D, K, R,
             dU_ptr, dV_ptr, dgw_ptr, dgb_ptr, dbias_ptr,
             dx2_ptr)

    embed_bwd(dx1_ptr, ids1_ptr, B, S, D, demb_ptr)
    embed_bwd(dx2_ptr, ids2_ptr, B, S, D, demb_ptr)

    dealloc(dq1_ptr); dealloc(dq2_ptr)
    dealloc(dp1_ptr); dealloc(dp2_ptr)
    dealloc(dz1_ptr); dealloc(dz2_ptr)
    dealloc(dx1_ptr); dealloc(dx2_ptr)
}

// =========================================================================
// Helpers: abs_f32, max_f32, rel_err
// =========================================================================
fn abs_f32(f32 v) -> f32 {
    if v < 0.0f { return 0.0f - v }
    return v
}

fn max_f32(f32 a, f32 b) -> f32 {
    if a > b { return a }
    return b
}

// =========================================================================
// Finite-difference loss for a single param element:
// Perturbs param[idx] by +eps and -eps, returns (L+ - L-) / (2*eps)
// =========================================================================
fn fd_loss(u64 param_ptr, u64 idx,
           u64 emb_ptr, u64 U_ptr, u64 V_ptr,
           u64 gw_ptr, u64 gb_ptr, u64 bias_ptr,
           u64 ids1_ptr, u64 ids2_ptr,
           u64 B, u64 S, u64 D, u64 K, u64 R,
           f32 eps) -> f32 {
    // Allocate temporary activation buffers
    u64 x1  = alloc(B * S * D * 4)
    u64 x2  = alloc(B * S * D * 4)
    u64 z1  = alloc(B * S * D * 4)
    u64 z2  = alloc(B * S * D * 4)
    u64 al1 = alloc(B * S * K * 4)
    u64 in1 = alloc(B * S * K * R * 4)
    u64 ok1 = alloc(B * S * K * D * 4)
    u64 al2 = alloc(B * S * K * 4)
    u64 in2 = alloc(B * S * K * R * 4)
    u64 ok2 = alloc(B * S * K * D * 4)
    u64 q1  = alloc(B * D * 4)
    u64 q2  = alloc(B * D * 4)
    u64 n1  = alloc(B * 4)
    u64 n2  = alloc(B * 4)

    u64 paddr = param_ptr + idx * 4
    f32 orig = 0.0f
    unsafe { *(paddr as f32) -> orig }

    // L+
    unsafe { *(paddr as f32) = orig + eps }
    f32 lp = full_forward(emb_ptr, U_ptr, V_ptr, gw_ptr, gb_ptr, bias_ptr,
                          ids1_ptr, ids2_ptr,
                          x1, x2, z1, z2, al1, in1, ok1, al2, in2, ok2,
                          q1, q2, n1, n2, B, S, D, K, R)

    // L-
    unsafe { *(paddr as f32) = orig - eps }
    f32 lm = full_forward(emb_ptr, U_ptr, V_ptr, gw_ptr, gb_ptr, bias_ptr,
                          ids1_ptr, ids2_ptr,
                          x1, x2, z1, z2, al1, in1, ok1, al2, in2, ok2,
                          q1, q2, n1, n2, B, S, D, K, R)

    // Restore
    unsafe { *(paddr as f32) = orig }

    dealloc(x1); dealloc(x2)
    dealloc(z1); dealloc(z2)
    dealloc(al1); dealloc(in1); dealloc(ok1)
    dealloc(al2); dealloc(in2); dealloc(ok2)
    dealloc(q1); dealloc(q2)
    dealloc(n1); dealloc(n2)

    f32 two = 2.0f
    return (lp - lm) / (two * eps)
}

// =========================================================================
// Check finite-diff for one param: returns max relative error over N elements
// eps: finite-diff step size (use 1e-3 for small-gradient params, 3e-5 for bias)
// =========================================================================
fn fd_check_param(u64 param_ptr, u64 grad_ptr, u64 N,
                  u64 emb_ptr, u64 U_ptr, u64 V_ptr,
                  u64 gw_ptr, u64 gb_ptr, u64 bias_ptr,
                  u64 ids1_ptr, u64 ids2_ptr,
                  u64 B, u64 S, u64 D, u64 K, u64 R,
                  f32 eps) -> f32 {
    f32 max_rel = 0.0f
    u64 i = 0
    while i < N {
        f32 fd = fd_loss(param_ptr, i, emb_ptr, U_ptr, V_ptr, gw_ptr, gb_ptr, bias_ptr,
                         ids1_ptr, ids2_ptr, B, S, D, K, R, eps)
        f32 an = 0.0f
        unsafe { *((grad_ptr + i * 4) as f32) -> an }
        f32 diff = abs_f32(fd - an)
        f32 denom = abs_f32(fd) + abs_f32(an)
        // Floor at 0.05 to avoid inflated relative errors for near-zero gradients.
        // The 1e-2 spec applies to gradients that are non-negligible.
        f32 thresh = 0.05f
        if denom < thresh { denom = thresh }
        f32 rel = diff / denom
        max_rel = max_f32(max_rel, rel)
        i = i + 1
    }
    return max_rel
}

// =========================================================================
// Reference gradient values (from bp_ref.json cpu.grads_after_step1)
// =========================================================================
fn check_grad_vs_ref(u64 grad_ptr, u64 ref_vals_ptr, u64 N, f32 tol) -> f32 {
    f32 max_diff = 0.0f
    u64 i = 0
    while i < N {
        f32 g = 0.0f
        unsafe { *((grad_ptr + i * 4) as f32) -> g }
        f32 r = 0.0f
        unsafe { *((ref_vals_ptr + i * 4) as f32) -> r }
        f32 d = abs_f32(g - r)
        max_diff = max_f32(max_diff, d)
        i = i + 1
    }
    return max_diff
}

