// bp_wzma_train — SP1 Task 3: backward + AdamW for the WZMA encoder.
//
// Dims: d=8 K=2 r=4 B=4 S=4 vocab=16
// Weights from tools/bp_ref.json (seed-0 init).
//
// Tests performed:
//  1. Finite-difference gradient check (central diff, eps=1e-3) for each param.
//     Passes if max relative error < 1e-2.
//  2. Analytic grad vs ref (tools/bp_ref.json cpu.grads_after_step1).
//     Passes if max abs diff <= 2e-4 per param (5e-4 for bias which has large values).
//  3. 5 AdamW steps; assert each loss vs cpu.losses within 1e-4.
//
// Build:
//   ./build/mlrc --arch=x86_64 --target=linux --emit=elfexe \
//       examples/bp_wzma_train.mlr -o /tmp/bp_wzma_train
// Run:
//   /tmp/bp_wzma_train

import "../std/train.mlr"
import "../std/math_float.mlr"
import "../std/fmt.mlr"

// Dims
static u64 DD    = 8
static u64 KB    = 2
static u64 RR    = 4
static u64 BB    = 4
static u64 SS    = 4
static u64 VOCAB = 16

