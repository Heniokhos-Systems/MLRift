// Confirm: compound-assign `t += t_lo` is safe (does NOT alias t to t_lo).
//
// Compound assign is parser-desugared to `t = (t + t_lo)`. The RHS is now
// a BinOp (kind 33), not a bare Ident — so the today fix's bare-Ident
// detection skips it. But BinOp lowering ALWAYS produces a fresh dest
// vreg (ir_new_vreg + IR_ADD), so no alias is created.

import "../std/io.mlr"
import "../std/fmt.mlr"

fn main() {
    u64 fail = 0

    u64 t_lo = 0
    u64 t = 0
    t += t_lo   // desugars to t = t + t_lo (fresh vreg from BinOp)

    while t < 4 {
        t += 1
    }

    if t_lo != 0 {
        print_str("BUG: t_lo clobbered after compound-assign loop; t_lo=")
        u64 s = fmt_dec(t_lo); print_str(s); dealloc(s); print_str("\n")
        fail = fail + 1
    }

    // Now also test compound mul/sub/etc.
    u64 src = 5
    u64 acc = 1
    acc *= src
    while acc < 100 {
        acc *= 2
    }
    if src != 5 {
        print_str("BUG: compound mul aliased src; src=")
        u64 s = fmt_dec(src); print_str(s); dealloc(s); print_str("\n")
        fail = fail + 1
    }

    if fail == 0 {
        print_str("PASS\n")
    } else {
        print_str("FAIL count=")
        u64 s = fmt_dec(fail); print_str(s); dealloc(s); print_str("\n")
    }
}
