import "../std/fmt.mlr"
import "../std/math_float.mlr"

fn main() {
    // Test asm block: inter[0:32] += xval * bf16_row[0:32]
    // bf16 for 1.0f = LE bytes: 0x80, 0x3F (f32=0x3F800000, bf16=0x3F80)
    u64 inter = alloc(32 * 4)
    memset(inter, 0, 32 * 4)
    u64 u_row = alloc(32 * 2)
    memset(u_row, 0, 32 * 2)
    // inter[0] += 2.0 * bf16[0] where bf16[0]=1.0 → expect 2.0
    store8(u_row + 0, 0x80)
    store8(u_row + 1, 0x3F)
    u64 xbuf = alloc(16)
    unsafe { *(xbuf as f32) = 2.0f }
    asm {
        "0x62 0xF2 0x7D 0x48 0x18 0x19"
        "0x62 0xF1 0x7C 0x48 0x10 0x27"
        "0x62 0xF1 0x7C 0x48 0x10 0x6F 0x01"
        "0x62 0xF2 0x7D 0x48 0x33 0x0E"
        "0x62 0xF1 0x75 0x48 0x72 0xF1 0x10"
        "0x62 0xF2 0x7D 0x48 0x33 0x56 0x01"
        "0x62 0xF1 0x6D 0x48 0x72 0xF2 0x10"
        "0x62 0xF2 0x65 0x48 0xB8 0xE1"
        "0x62 0xF2 0x65 0x48 0xB8 0xEA"
        "0x62 0xF1 0x7C 0x48 0x11 0x27"
        "0x62 0xF1 0x7C 0x48 0x11 0x6F 0x01"
        "0xC5 0xF8 0x77"
    } in(inter -> rdi, u_row -> rsi, xbuf -> rcx)
    f32 v0 = 0.0f
    unsafe { *(inter as f32) -> v0 }
    print_str("expect 2.0: ")
    u64 s = fmt_f32(v0, 4); print_str(s); dealloc(s); print_str("\n")
    dealloc(inter); dealloc(u_row); dealloc(xbuf)
    exit(0)
}
