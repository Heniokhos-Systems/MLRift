// Phase 3 slice δ.0g — ATOM arithmetic + movement opcode smoke test.
//
// 12 hand-crafted scenarios, each with a fresh image + context.
// Each test encodes a minimal bytecode program, runs atom_execute_table,
// and asserts the WS / divmul state after EOT.
//
// All tests use ATOM_ARG_WS (op variants +2 in each family) so that
// operand bytes are simple 1-byte WS indices. IMM sources are mostly
// DWORD for clarity; test 2 uses BYTE0 to exercise the align path.
//
// Exit codes:
//   0 = all GREEN
//   1..12 = test N failed

import "../std/atom.mlr"
import "../std/atom_constants.mlr"
import "../std/sys.mlr"

@dynamic extern fn exit(uint64 code)
@dynamic extern fn puts(uint64 s) -> uint32

// -------------------------------------------------------------------
// Print helpers
// -------------------------------------------------------------------
fn _pdec(uint64 lab, uint64 ll, uint64 v) {
    uint64 b = alloc(80)
    uint64 i = 0
    while i < ll {
        uint8 c = 0; unsafe { *((lab + i) as uint8) -> c }
        unsafe { *((b + i) as uint8) = c }; i = i + 1
    }
    uint8 eq = 61; unsafe { *((b + ll) as uint8) = eq }
    uint64 digits = 0
    if v == 0 {
        uint8 z = 48; unsafe { *((b + ll + 1) as uint8) = z }; digits = 1
    } else {
        uint64 t = v
        while t > 0 { digits = digits + 1; t = t / 10 }
        uint64 k = digits; t = v
        while k > 0 {
            k = k - 1
            uint64 d = t - (t / 10) * 10
            uint8 db = d + 48; unsafe { *((b + ll + 1 + k) as uint8) = db }
            t = t / 10
        }
    }
    uint8 nul = 0; unsafe { *((b + ll + 1 + digits) as uint8) = nul }
    puts(b); dealloc(b)
}

fn _phex(uint64 lab, uint64 ll, uint64 v) {
    uint64 b = alloc(80)
    uint64 i = 0
    while i < ll {
        uint8 c = 0; unsafe { *((lab + i) as uint8) -> c }
        unsafe { *((b + i) as uint8) = c }; i = i + 1
    }
    uint8 eq = 61; unsafe { *((b + ll) as uint8) = eq }
    uint8 z0 = 48; unsafe { *((b + ll + 1) as uint8) = z0 }
    uint8 zx = 120; unsafe { *((b + ll + 2) as uint8) = zx }
    uint64 j = 0
    while j < 8 {
        uint64 sh = (7 - j) * 4
        uint64 nyb = (v >> sh) & 0xF
        uint8 ch = nyb + 48
        if nyb >= 10 { ch = nyb + 87 }
        unsafe { *((b + ll + 3 + j) as uint8) = ch }
        j = j + 1
    }
    uint8 nul = 0; unsafe { *((b + ll + 11) as uint8) = nul }
    puts(b); dealloc(b)
}

// -------------------------------------------------------------------
// Helper: allocate a minimal atom_context + image + cmd-table.
//   image_sz  — total image bytes to allocate (>= ct_off + table_bytes)
//   ct_off    — byte offset within image where the cmd-table header lives
//   ws_dwords — WS[] slots to provision (written into ct header byte 4)
//
// Writes ctx* to *out_ctx_p, image* to *out_image_p.
// Caller fills bytecode at image+ct_off+ATOM_CT_CODE_PTR onward.
// -------------------------------------------------------------------
fn _mk_ctx(uint64 image_sz, uint64 ct_off, uint64 ws_dwords,
           uint64 out_ctx_p, uint64 out_image_p) {
    uint64 image = alloc(image_sz)
    uint64 i = 0
    while i < image_sz { uint8 z = 0; unsafe { *((image + i) as uint8) = z }; i = i + 1 }

    // ct header: size covers header(6)+bytecode; we set a generous 64.
    uint16 ct_size = 64; unsafe { *((image + ct_off + 0) as uint16) = ct_size }
    uint8 ws_b = ws_dwords; unsafe { *((image + ct_off + 4) as uint8) = ws_b }
    // ps_dwords = 0 already (zeroed)

    uint64 ctx = alloc(ATOM_CONTEXT_SIZE)
    uint64 j = 0
    while j < ATOM_CONTEXT_SIZE { uint8 z = 0; unsafe { *((ctx + j) as uint8) = z }; j = j + 1 }
    unsafe { *((ctx + AC_OFF_IMAGE_BUF)  as uint64) = image }
    unsafe { *((ctx + AC_OFF_IMAGE_SIZE) as uint64) = image_sz }

    unsafe { *(out_ctx_p   as uint64) = ctx }
    unsafe { *(out_image_p as uint64) = image }
}

fn main() {
    puts("phase3_atom_arith_test")

    // ---------------------------------------------------------------
    // Bytecode encoding constants (image-relative offsets within a
    // single cmd-table slot at ct_off=8).
    // ---------------------------------------------------------------
    uint64 ct_off   = 8
    uint64 bc_start = ct_off + ATOM_CT_CODE_PTR   // = 8+6 = 14
    uint64 img_sz   = 128

    // ctx/image pointers shared across tests.
    uint64 ctx_p   = alloc(8); unsafe { *(ctx_p   as uint64) = 0 }
    uint64 img_p   = alloc(8); unsafe { *(img_p   as uint64) = 0 }
    uint64 ctx = 0; uint64 image = 0

    // ---------------------------------------------------------------
    // TEST 1: move WS[0], IMM_DWORD 0x12345678  → WS[0]=0x12345678
    // Opcode: 3 (move_WS, arg=ATOM_ARG_WS=2)
    // attr=5  (src=IMM=5, align=DWORD=0, idx=0)
    // Bytecode: [3, attr=5, ws_idx=0, 0x78,0x56,0x34,0x12, EOT=91]
    // move with DWORD: skip_dst (advances 1 byte past ws_idx), then IMM reads 4.
    // ---------------------------------------------------------------
    _mk_ctx(img_sz, ct_off, 4, ctx_p, img_p)
    ctx = 0; unsafe { *(ctx_p as uint64) -> ctx }
    image = 0; unsafe { *(img_p as uint64) -> image }

    uint8 op3 = 3;  unsafe { *((image + bc_start + 0) as uint8) = op3 }
    uint8 a5  = 5;  unsafe { *((image + bc_start + 1) as uint8) = a5 }   // attr: IMM,DWORD
    uint8 wi0 = 0;  unsafe { *((image + bc_start + 2) as uint8) = wi0 }  // WS idx 0
    uint8 b0  = 0x78; unsafe { *((image + bc_start + 3) as uint8) = b0 }
    uint8 b1  = 0x56; unsafe { *((image + bc_start + 4) as uint8) = b1 }
    uint8 b2  = 0x34; unsafe { *((image + bc_start + 5) as uint8) = b2 }
    uint8 b3  = 0x12; unsafe { *((image + bc_start + 6) as uint8) = b3 }
    uint8 eot = 91; unsafe { *((image + bc_start + 7) as uint8) = eot }

    uint64 rc = atom_execute_table(ctx, ct_off, 0, 0)
    _pdec("t1_rc", 5, rc)
    if rc != 0 { puts("FAIL t1: rc != 0"); dealloc(ctx); dealloc(image); dealloc(ctx_p); dealloc(img_p); exit(1) }
    // atom_execute_table frees ws_buf before returning; we need to check
    // WS by re-running with a caller-supplied ws_buf approach.
    // Since atom_execute_table currently allocates/frees ws internally,
    // we verify indirectly: re-use a second run that reads WS[0] via a move
    // to WS[1] (src=WS), then we inspect... Actually we cannot since ws is freed.
    //
    // Alternative: use the scratchpad FB mechanism to exfiltrate the WS value.
    // Easier: set up TWO move ops: move WS[0], IMM_DWORD val; move WS[QUOTIENT], WS[0].
    // After EOT, ctx->divmul[0] holds the value → readable directly from ctx!
    //
    // Redo: also write ctx->divmul via WS_QUOTIENT move.
    dealloc(ctx); dealloc(image)

    // Re-run with exfil: move WS[0], IMM_DWORD 0x12345678; move WS[QUOTIENT], WS[0]; EOT
    // For the second move: op=3 (move_WS), src=WS → attr must have src_type=ATOM_ARG_WS=2.
    // attr = 2 | (DWORD<<3) | (0<<6) = 2 | 0 = 2
    // Bytecode: [3,5, ws0, 0x78,0x56,0x34,0x12,  3,2, ws0, WS_QUOTIENT=0x40,  91]
    _mk_ctx(img_sz, ct_off, 4, ctx_p, img_p)
    ctx = 0; unsafe { *(ctx_p as uint64) -> ctx }
    image = 0; unsafe { *(img_p as uint64) -> image }

    // move WS[0], IMM_DWORD 0x12345678
    uint8 xop3=3; unsafe { *((image + bc_start + 0) as uint8) = xop3 }
    uint8 xa5=5;  unsafe { *((image + bc_start + 1) as uint8) = xa5 }
    uint8 xw0=0;  unsafe { *((image + bc_start + 2) as uint8) = xw0 }
    uint8 xb0=0x78; unsafe { *((image + bc_start + 3) as uint8) = xb0 }
    uint8 xb1=0x56; unsafe { *((image + bc_start + 4) as uint8) = xb1 }
    uint8 xb2=0x34; unsafe { *((image + bc_start + 5) as uint8) = xb2 }
    uint8 xb3=0x12; unsafe { *((image + bc_start + 6) as uint8) = xb3 }
    // move WS[QUOTIENT], WS[0]  (exfil to divmul[0])
    // attr=2: src_type=WS=2, align=DWORD=0 → (attr>>3)&7=0, no DWORD skip branch since
    // _atom_op_move checks ((attr>>3)&7) != ATOM_SRC_DWORD... attr=2: (2>>3)&7=0=DWORD →
    // skip_dst will be used and saved=0xCDCDCDCD. That's fine — we just need the write.
    uint8 xop3b=3; unsafe { *((image + bc_start + 7) as uint8) = xop3b }
    uint8 xa2=2;   unsafe { *((image + bc_start + 8) as uint8) = xa2 }    // attr: WS,DWORD
    uint8 xwq=0x40; unsafe { *((image + bc_start + 9) as uint8) = xwq }   // WS_QUOTIENT idx
    uint8 xws0b=0;  unsafe { *((image + bc_start + 10) as uint8) = xws0b } // WS[0] idx (src)
    uint8 xeot=91; unsafe { *((image + bc_start + 11) as uint8) = xeot }

    rc = atom_execute_table(ctx, ct_off, 0, 0)
    _pdec("t1_rc2", 6, rc)
    if rc != 0 { puts("FAIL t1: rc2 != 0"); dealloc(ctx); dealloc(image); dealloc(ctx_p); dealloc(img_p); exit(1) }
    uint32 t1_val = 0; unsafe { *((ctx + AC_OFF_DIVMUL_Q) as uint32) -> t1_val }
    _phex("t1_ws0", 5, t1_val)
    if t1_val != 0x12345678 { puts("FAIL t1: ws0 != 0x12345678"); dealloc(ctx); dealloc(image); dealloc(ctx_p); dealloc(img_p); exit(1) }
    puts("PASS t1: move WS DWORD")
    dealloc(ctx); dealloc(image)

    // ---------------------------------------------------------------
    // TEST 2: and WS[0], IMM_BYTE0 0x0F  after WS[0]=0xFF → WS[0]=0x0F
    // Use pre-loaded WS[0]=0xFF via a move first.
    // and_WS opcode = 9 (arg=ATOM_ARG_WS=2).
    // attr for "WS[0] &= IMM_BYTE0": src=IMM=5, align=BYTE0=4, idx=0
    //   attr = 5 | (4<<3) | (0<<6) = 5 | 32 = 37
    // Bytecode: [3, attr=5, ws0, 0xFF,0,0,0,  9, attr=37, ws0, 0x0F,  3,2, wq, ws0, 91]
    // (load 0xFF, and with 0x0F, exfil to divmul[0])
    // ---------------------------------------------------------------
    _mk_ctx(img_sz, ct_off, 4, ctx_p, img_p)
    ctx = 0; unsafe { *(ctx_p as uint64) -> ctx }
    image = 0; unsafe { *(img_p as uint64) -> image }

    // move WS[0], IMM_DWORD 0xFF
    uint8 t2_0=3;    unsafe { *((image + bc_start + 0) as uint8) = t2_0 }
    uint8 t2_1=5;    unsafe { *((image + bc_start + 1) as uint8) = t2_1 }
    uint8 t2_2=0;    unsafe { *((image + bc_start + 2) as uint8) = t2_2 }
    uint8 t2_3=0xFF; unsafe { *((image + bc_start + 3) as uint8) = t2_3 }
    uint8 t2_4=0;    unsafe { *((image + bc_start + 4) as uint8) = t2_4 }
    uint8 t2_5=0;    unsafe { *((image + bc_start + 5) as uint8) = t2_5 }
    uint8 t2_6=0;    unsafe { *((image + bc_start + 6) as uint8) = t2_6 }
    // and WS[0], IMM_BYTE0 0x0F
    uint8 t2_7=9;    unsafe { *((image + bc_start + 7) as uint8) = t2_7 }
    uint8 t2_8=37;   unsafe { *((image + bc_start + 8) as uint8) = t2_8 }  // attr=37
    uint8 t2_9=0;    unsafe { *((image + bc_start + 9) as uint8) = t2_9 }  // WS idx
    uint8 t2_10=0x0F; unsafe { *((image + bc_start + 10) as uint8) = t2_10 } // imm byte
    // exfil: move WS[QUOTIENT], WS[0]
    uint8 t2_11=3;   unsafe { *((image + bc_start + 11) as uint8) = t2_11 }
    uint8 t2_12=2;   unsafe { *((image + bc_start + 12) as uint8) = t2_12 }
    uint8 t2_13=0x40; unsafe { *((image + bc_start + 13) as uint8) = t2_13 }
    uint8 t2_14=0;   unsafe { *((image + bc_start + 14) as uint8) = t2_14 }
    uint8 t2_15=91;  unsafe { *((image + bc_start + 15) as uint8) = t2_15 }

    rc = atom_execute_table(ctx, ct_off, 0, 0)
    _pdec("t2_rc", 5, rc)
    if rc != 0 { puts("FAIL t2: rc != 0"); dealloc(ctx); dealloc(image); dealloc(ctx_p); dealloc(img_p); exit(2) }
    uint32 t2_val = 0; unsafe { *((ctx + AC_OFF_DIVMUL_Q) as uint32) -> t2_val }
    _phex("t2_ws0", 5, t2_val)
    if t2_val != 0x0F { puts("FAIL t2: ws0 != 0x0F"); dealloc(ctx); dealloc(image); dealloc(ctx_p); dealloc(img_p); exit(2) }
    puts("PASS t2: and WS BYTE0")
    dealloc(ctx); dealloc(image)

    // ---------------------------------------------------------------
    // TEST 3: or WS[1], IMM_BYTE0 0x80  after WS[1]=0x01 → WS[1]=0x81
    // or_WS opcode = 15 (arg=2).
    // attr=37 (src=IMM,BYTE0 as in t2)
    // Bytecode: [3,5, ws1, 0x01,0,0,0,  15,37, ws1, 0x80,  3,2, wq, ws1, 91]
    // ---------------------------------------------------------------
    _mk_ctx(img_sz, ct_off, 4, ctx_p, img_p)
    ctx = 0; unsafe { *(ctx_p as uint64) -> ctx }
    image = 0; unsafe { *(img_p as uint64) -> image }

    // move WS[1], IMM_DWORD 0x01
    uint8 t3_0=3;    unsafe { *((image + bc_start + 0) as uint8) = t3_0 }
    uint8 t3_1=5;    unsafe { *((image + bc_start + 1) as uint8) = t3_1 }
    uint8 t3_2=1;    unsafe { *((image + bc_start + 2) as uint8) = t3_2 }  // WS[1]
    uint8 t3_3=1;    unsafe { *((image + bc_start + 3) as uint8) = t3_3 }  // 0x01
    uint8 t3_4=0;    unsafe { *((image + bc_start + 4) as uint8) = t3_4 }
    uint8 t3_5=0;    unsafe { *((image + bc_start + 5) as uint8) = t3_5 }
    uint8 t3_6=0;    unsafe { *((image + bc_start + 6) as uint8) = t3_6 }
    // or WS[1], IMM_BYTE0 0x80
    uint8 t3_7=15;   unsafe { *((image + bc_start + 7) as uint8) = t3_7 }
    uint8 t3_8=37;   unsafe { *((image + bc_start + 8) as uint8) = t3_8 }
    uint8 t3_9=1;    unsafe { *((image + bc_start + 9) as uint8) = t3_9 }  // WS[1]
    uint8 t3_10=0x80; unsafe { *((image + bc_start + 10) as uint8) = t3_10 }
    // exfil: move WS[QUOTIENT], WS[1]
    uint8 t3_11=3;   unsafe { *((image + bc_start + 11) as uint8) = t3_11 }
    uint8 t3_12=2;   unsafe { *((image + bc_start + 12) as uint8) = t3_12 }
    uint8 t3_13=0x40; unsafe { *((image + bc_start + 13) as uint8) = t3_13 }
    uint8 t3_14=1;   unsafe { *((image + bc_start + 14) as uint8) = t3_14 }  // WS[1]
    uint8 t3_15=91;  unsafe { *((image + bc_start + 15) as uint8) = t3_15 }

    rc = atom_execute_table(ctx, ct_off, 0, 0)
    _pdec("t3_rc", 5, rc)
    if rc != 0 { puts("FAIL t3: rc != 0"); dealloc(ctx); dealloc(image); dealloc(ctx_p); dealloc(img_p); exit(3) }
    uint32 t3_val = 0; unsafe { *((ctx + AC_OFF_DIVMUL_Q) as uint32) -> t3_val }
    _phex("t3_ws1", 5, t3_val)
    if t3_val != 0x81 { puts("FAIL t3: ws1 != 0x81"); dealloc(ctx); dealloc(image); dealloc(ctx_p); dealloc(img_p); exit(3) }
    puts("PASS t3: or WS BYTE0")
    dealloc(ctx); dealloc(image)

    // ---------------------------------------------------------------
    // TEST 4: xor WS[2], IMM_DWORD 0xFFFFFFFF  after WS[2]=0xAA55AA55 → 0x55AA55AA
    // xor_WS opcode = 105 (arg=2).
    // attr=5 (IMM, DWORD).
    // ---------------------------------------------------------------
    _mk_ctx(img_sz, ct_off, 4, ctx_p, img_p)
    ctx = 0; unsafe { *(ctx_p as uint64) -> ctx }
    image = 0; unsafe { *(img_p as uint64) -> image }

    // move WS[2], IMM_DWORD 0xAA55AA55
    uint8 t4_0=3;    unsafe { *((image + bc_start + 0) as uint8) = t4_0 }
    uint8 t4_1=5;    unsafe { *((image + bc_start + 1) as uint8) = t4_1 }
    uint8 t4_2=2;    unsafe { *((image + bc_start + 2) as uint8) = t4_2 }  // WS[2]
    uint8 t4_3=0x55; unsafe { *((image + bc_start + 3) as uint8) = t4_3 }
    uint8 t4_4=0xAA; unsafe { *((image + bc_start + 4) as uint8) = t4_4 }
    uint8 t4_5=0x55; unsafe { *((image + bc_start + 5) as uint8) = t4_5 }
    uint8 t4_6=0xAA; unsafe { *((image + bc_start + 6) as uint8) = t4_6 }
    // xor WS[2], IMM_DWORD 0xFFFFFFFF
    uint8 t4_7=105;  unsafe { *((image + bc_start + 7) as uint8) = t4_7 }
    uint8 t4_8=5;    unsafe { *((image + bc_start + 8) as uint8) = t4_8 }
    uint8 t4_9=2;    unsafe { *((image + bc_start + 9) as uint8) = t4_9 }  // WS[2]
    uint8 t4_10=0xFF; unsafe { *((image + bc_start + 10) as uint8) = t4_10 }
    uint8 t4_11=0xFF; unsafe { *((image + bc_start + 11) as uint8) = t4_11 }
    uint8 t4_12=0xFF; unsafe { *((image + bc_start + 12) as uint8) = t4_12 }
    uint8 t4_13=0xFF; unsafe { *((image + bc_start + 13) as uint8) = t4_13 }
    // exfil: move WS[QUOTIENT], WS[2]
    uint8 t4_14=3;   unsafe { *((image + bc_start + 14) as uint8) = t4_14 }
    uint8 t4_15=2;   unsafe { *((image + bc_start + 15) as uint8) = t4_15 }
    uint8 t4_16=0x40; unsafe { *((image + bc_start + 16) as uint8) = t4_16 }
    uint8 t4_17=2;   unsafe { *((image + bc_start + 17) as uint8) = t4_17 }  // WS[2]
    uint8 t4_18=91;  unsafe { *((image + bc_start + 18) as uint8) = t4_18 }

    rc = atom_execute_table(ctx, ct_off, 0, 0)
    _pdec("t4_rc", 5, rc)
    if rc != 0 { puts("FAIL t4: rc != 0"); dealloc(ctx); dealloc(image); dealloc(ctx_p); dealloc(img_p); exit(4) }
    uint32 t4_val = 0; unsafe { *((ctx + AC_OFF_DIVMUL_Q) as uint32) -> t4_val }
    _phex("t4_ws2", 5, t4_val)
    if t4_val != 0x55AA55AA { puts("FAIL t4: ws2 != 0x55AA55AA"); dealloc(ctx); dealloc(image); dealloc(ctx_p); dealloc(img_p); exit(4) }
    puts("PASS t4: xor WS DWORD")
    dealloc(ctx); dealloc(image)

    // ---------------------------------------------------------------
    // TEST 5: add WS[0], IMM_DWORD 5  after WS[0]=10 → 15
    // add_WS opcode = 45 (arg=2).
    // attr=5 (IMM, DWORD).
    // ---------------------------------------------------------------
    _mk_ctx(img_sz, ct_off, 4, ctx_p, img_p)
    ctx = 0; unsafe { *(ctx_p as uint64) -> ctx }
    image = 0; unsafe { *(img_p as uint64) -> image }

    uint8 t5_0=3;  unsafe { *((image + bc_start + 0) as uint8) = t5_0 }
    uint8 t5_1=5;  unsafe { *((image + bc_start + 1) as uint8) = t5_1 }
    uint8 t5_2=0;  unsafe { *((image + bc_start + 2) as uint8) = t5_2 }
    uint8 t5_3=10; unsafe { *((image + bc_start + 3) as uint8) = t5_3 }  // 10 LE
    uint8 t5_4=0;  unsafe { *((image + bc_start + 4) as uint8) = t5_4 }
    uint8 t5_5=0;  unsafe { *((image + bc_start + 5) as uint8) = t5_5 }
    uint8 t5_6=0;  unsafe { *((image + bc_start + 6) as uint8) = t5_6 }
    uint8 t5_7=45; unsafe { *((image + bc_start + 7) as uint8) = t5_7 }  // add_WS
    uint8 t5_8=5;  unsafe { *((image + bc_start + 8) as uint8) = t5_8 }
    uint8 t5_9=0;  unsafe { *((image + bc_start + 9) as uint8) = t5_9 }
    uint8 t5_10=5; unsafe { *((image + bc_start + 10) as uint8) = t5_10 } // IMM=5
    uint8 t5_11=0; unsafe { *((image + bc_start + 11) as uint8) = t5_11 }
    uint8 t5_12=0; unsafe { *((image + bc_start + 12) as uint8) = t5_12 }
    uint8 t5_13=0; unsafe { *((image + bc_start + 13) as uint8) = t5_13 }
    // exfil
    uint8 t5_14=3;    unsafe { *((image + bc_start + 14) as uint8) = t5_14 }
    uint8 t5_15=2;    unsafe { *((image + bc_start + 15) as uint8) = t5_15 }
    uint8 t5_16=0x40; unsafe { *((image + bc_start + 16) as uint8) = t5_16 }
    uint8 t5_17=0;    unsafe { *((image + bc_start + 17) as uint8) = t5_17 }
    uint8 t5_18=91;   unsafe { *((image + bc_start + 18) as uint8) = t5_18 }

    rc = atom_execute_table(ctx, ct_off, 0, 0)
    _pdec("t5_rc", 5, rc)
    if rc != 0 { puts("FAIL t5: rc != 0"); dealloc(ctx); dealloc(image); dealloc(ctx_p); dealloc(img_p); exit(5) }
    uint32 t5_val = 0; unsafe { *((ctx + AC_OFF_DIVMUL_Q) as uint32) -> t5_val }
    _pdec("t5_ws0", 5, t5_val)
    if t5_val != 15 { puts("FAIL t5: ws0 != 15"); dealloc(ctx); dealloc(image); dealloc(ctx_p); dealloc(img_p); exit(5) }
    puts("PASS t5: add WS DWORD")
    dealloc(ctx); dealloc(image)

    // ---------------------------------------------------------------
    // TEST 6: sub WS[0], IMM_DWORD 3  after WS[0]=10 → 7
    // sub_WS opcode = 51 (arg=2). attr=5.
    // ---------------------------------------------------------------
    _mk_ctx(img_sz, ct_off, 4, ctx_p, img_p)
    ctx = 0; unsafe { *(ctx_p as uint64) -> ctx }
    image = 0; unsafe { *(img_p as uint64) -> image }

    uint8 t6_0=3;  unsafe { *((image + bc_start + 0) as uint8) = t6_0 }
    uint8 t6_1=5;  unsafe { *((image + bc_start + 1) as uint8) = t6_1 }
    uint8 t6_2=0;  unsafe { *((image + bc_start + 2) as uint8) = t6_2 }
    uint8 t6_3=10; unsafe { *((image + bc_start + 3) as uint8) = t6_3 }
    uint8 t6_4=0;  unsafe { *((image + bc_start + 4) as uint8) = t6_4 }
    uint8 t6_5=0;  unsafe { *((image + bc_start + 5) as uint8) = t6_5 }
    uint8 t6_6=0;  unsafe { *((image + bc_start + 6) as uint8) = t6_6 }
    uint8 t6_7=51; unsafe { *((image + bc_start + 7) as uint8) = t6_7 }  // sub_WS
    uint8 t6_8=5;  unsafe { *((image + bc_start + 8) as uint8) = t6_8 }
    uint8 t6_9=0;  unsafe { *((image + bc_start + 9) as uint8) = t6_9 }
    uint8 t6_10=3; unsafe { *((image + bc_start + 10) as uint8) = t6_10 }
    uint8 t6_11=0; unsafe { *((image + bc_start + 11) as uint8) = t6_11 }
    uint8 t6_12=0; unsafe { *((image + bc_start + 12) as uint8) = t6_12 }
    uint8 t6_13=0; unsafe { *((image + bc_start + 13) as uint8) = t6_13 }
    uint8 t6_14=3;    unsafe { *((image + bc_start + 14) as uint8) = t6_14 }
    uint8 t6_15=2;    unsafe { *((image + bc_start + 15) as uint8) = t6_15 }
    uint8 t6_16=0x40; unsafe { *((image + bc_start + 16) as uint8) = t6_16 }
    uint8 t6_17=0;    unsafe { *((image + bc_start + 17) as uint8) = t6_17 }
    uint8 t6_18=91;   unsafe { *((image + bc_start + 18) as uint8) = t6_18 }

    rc = atom_execute_table(ctx, ct_off, 0, 0)
    _pdec("t6_rc", 5, rc)
    if rc != 0 { puts("FAIL t6: rc != 0"); dealloc(ctx); dealloc(image); dealloc(ctx_p); dealloc(img_p); exit(6) }
    uint32 t6_val = 0; unsafe { *((ctx + AC_OFF_DIVMUL_Q) as uint32) -> t6_val }
    _pdec("t6_ws0", 5, t6_val)
    if t6_val != 7 { puts("FAIL t6: ws0 != 7"); dealloc(ctx); dealloc(image); dealloc(ctx_p); dealloc(img_p); exit(6) }
    puts("PASS t6: sub WS DWORD")
    dealloc(ctx); dealloc(image)

    // ---------------------------------------------------------------
    // TEST 7: mul WS[0], IMM_DWORD 4  after WS[0]=6 → divmul[0]=24
    // mul_WS opcode = 33 (arg=2). attr=5. No put_dst — result in divmul[0].
    // Bytecode: [3,5, ws0, 6,0,0,0,  33,5, ws0, 4,0,0,0,  91]
    // ---------------------------------------------------------------
    _mk_ctx(img_sz, ct_off, 4, ctx_p, img_p)
    ctx = 0; unsafe { *(ctx_p as uint64) -> ctx }
    image = 0; unsafe { *(img_p as uint64) -> image }

    uint8 t7_0=3;  unsafe { *((image + bc_start + 0) as uint8) = t7_0 }
    uint8 t7_1=5;  unsafe { *((image + bc_start + 1) as uint8) = t7_1 }
    uint8 t7_2=0;  unsafe { *((image + bc_start + 2) as uint8) = t7_2 }
    uint8 t7_3=6;  unsafe { *((image + bc_start + 3) as uint8) = t7_3 }
    uint8 t7_4=0;  unsafe { *((image + bc_start + 4) as uint8) = t7_4 }
    uint8 t7_5=0;  unsafe { *((image + bc_start + 5) as uint8) = t7_5 }
    uint8 t7_6=0;  unsafe { *((image + bc_start + 6) as uint8) = t7_6 }
    uint8 t7_7=33; unsafe { *((image + bc_start + 7) as uint8) = t7_7 }  // mul_WS
    uint8 t7_8=5;  unsafe { *((image + bc_start + 8) as uint8) = t7_8 }
    uint8 t7_9=0;  unsafe { *((image + bc_start + 9) as uint8) = t7_9 }
    uint8 t7_10=4; unsafe { *((image + bc_start + 10) as uint8) = t7_10 }
    uint8 t7_11=0; unsafe { *((image + bc_start + 11) as uint8) = t7_11 }
    uint8 t7_12=0; unsafe { *((image + bc_start + 12) as uint8) = t7_12 }
    uint8 t7_13=0; unsafe { *((image + bc_start + 13) as uint8) = t7_13 }
    uint8 t7_14=91; unsafe { *((image + bc_start + 14) as uint8) = t7_14 }

    rc = atom_execute_table(ctx, ct_off, 0, 0)
    _pdec("t7_rc", 5, rc)
    if rc != 0 { puts("FAIL t7: rc != 0"); dealloc(ctx); dealloc(image); dealloc(ctx_p); dealloc(img_p); exit(7) }
    uint32 t7_q = 0; unsafe { *((ctx + AC_OFF_DIVMUL_Q) as uint32) -> t7_q }
    _pdec("t7_divmul0", 10, t7_q)
    if t7_q != 24 { puts("FAIL t7: divmul[0] != 24"); dealloc(ctx); dealloc(image); dealloc(ctx_p); dealloc(img_p); exit(7) }
    puts("PASS t7: mul WS DWORD")
    dealloc(ctx); dealloc(image)

    // ---------------------------------------------------------------
    // TEST 8: div WS[0], IMM_DWORD 7  after WS[0]=23 → divmul[0]=3, divmul[1]=2
    // div_WS opcode = 39 (arg=2). attr=5.
    // ---------------------------------------------------------------
    _mk_ctx(img_sz, ct_off, 4, ctx_p, img_p)
    ctx = 0; unsafe { *(ctx_p as uint64) -> ctx }
    image = 0; unsafe { *(img_p as uint64) -> image }

    uint8 t8_0=3;  unsafe { *((image + bc_start + 0) as uint8) = t8_0 }
    uint8 t8_1=5;  unsafe { *((image + bc_start + 1) as uint8) = t8_1 }
    uint8 t8_2=0;  unsafe { *((image + bc_start + 2) as uint8) = t8_2 }
    uint8 t8_3=23; unsafe { *((image + bc_start + 3) as uint8) = t8_3 }
    uint8 t8_4=0;  unsafe { *((image + bc_start + 4) as uint8) = t8_4 }
    uint8 t8_5=0;  unsafe { *((image + bc_start + 5) as uint8) = t8_5 }
    uint8 t8_6=0;  unsafe { *((image + bc_start + 6) as uint8) = t8_6 }
    uint8 t8_7=39; unsafe { *((image + bc_start + 7) as uint8) = t8_7 }  // div_WS
    uint8 t8_8=5;  unsafe { *((image + bc_start + 8) as uint8) = t8_8 }
    uint8 t8_9=0;  unsafe { *((image + bc_start + 9) as uint8) = t8_9 }
    uint8 t8_10=7; unsafe { *((image + bc_start + 10) as uint8) = t8_10 }
    uint8 t8_11=0; unsafe { *((image + bc_start + 11) as uint8) = t8_11 }
    uint8 t8_12=0; unsafe { *((image + bc_start + 12) as uint8) = t8_12 }
    uint8 t8_13=0; unsafe { *((image + bc_start + 13) as uint8) = t8_13 }
    uint8 t8_14=91; unsafe { *((image + bc_start + 14) as uint8) = t8_14 }

    rc = atom_execute_table(ctx, ct_off, 0, 0)
    _pdec("t8_rc", 5, rc)
    if rc != 0 { puts("FAIL t8: rc != 0"); dealloc(ctx); dealloc(image); dealloc(ctx_p); dealloc(img_p); exit(8) }
    uint32 t8_q = 0; unsafe { *((ctx + AC_OFF_DIVMUL_Q) as uint32) -> t8_q }
    uint32 t8_r = 0; unsafe { *((ctx + AC_OFF_DIVMUL_R) as uint32) -> t8_r }
    _pdec("t8_q", 4, t8_q)
    _pdec("t8_r", 4, t8_r)
    if t8_q != 3 { puts("FAIL t8: divmul[0] != 3"); dealloc(ctx); dealloc(image); dealloc(ctx_p); dealloc(img_p); exit(8) }
    if t8_r != 2 { puts("FAIL t8: divmul[1] != 2"); dealloc(ctx); dealloc(image); dealloc(ctx_p); dealloc(img_p); exit(8) }
    puts("PASS t8: div WS DWORD")
    dealloc(ctx); dealloc(image)

    // ---------------------------------------------------------------
    // TEST 9: shl WS[0], IMM_DWORD 4  after WS[0]=0x01 → 0x10
    // shl_WS opcode = 111 (arg=2). attr=5 (IMM,DWORD). shift=get_src=4.
    // In _atom_op_shl: dst=saved=WS[0]; dst<<=4; mask=0xFFFFFFFF; shift=0.
    // Bytecode: [3,5, ws0, 1,0,0,0,  111,5, ws0, 4,0,0,0,  exfil, 91]
    // ---------------------------------------------------------------
    _mk_ctx(img_sz, ct_off, 4, ctx_p, img_p)
    ctx = 0; unsafe { *(ctx_p as uint64) -> ctx }
    image = 0; unsafe { *(img_p as uint64) -> image }

    uint8 t9_0=3;    unsafe { *((image + bc_start + 0) as uint8) = t9_0 }
    uint8 t9_1=5;    unsafe { *((image + bc_start + 1) as uint8) = t9_1 }
    uint8 t9_2=0;    unsafe { *((image + bc_start + 2) as uint8) = t9_2 }
    uint8 t9_3=1;    unsafe { *((image + bc_start + 3) as uint8) = t9_3 }  // WS[0]=1
    uint8 t9_4=0;    unsafe { *((image + bc_start + 4) as uint8) = t9_4 }
    uint8 t9_5=0;    unsafe { *((image + bc_start + 5) as uint8) = t9_5 }
    uint8 t9_6=0;    unsafe { *((image + bc_start + 6) as uint8) = t9_6 }
    uint8 t9_7=111;  unsafe { *((image + bc_start + 7) as uint8) = t9_7 }  // shl_WS
    uint8 t9_8=5;    unsafe { *((image + bc_start + 8) as uint8) = t9_8 }
    uint8 t9_9=0;    unsafe { *((image + bc_start + 9) as uint8) = t9_9 }
    uint8 t9_10=4;   unsafe { *((image + bc_start + 10) as uint8) = t9_10 } // shift=4
    uint8 t9_11=0;   unsafe { *((image + bc_start + 11) as uint8) = t9_11 }
    uint8 t9_12=0;   unsafe { *((image + bc_start + 12) as uint8) = t9_12 }
    uint8 t9_13=0;   unsafe { *((image + bc_start + 13) as uint8) = t9_13 }
    uint8 t9_14=3;   unsafe { *((image + bc_start + 14) as uint8) = t9_14 }
    uint8 t9_15=2;   unsafe { *((image + bc_start + 15) as uint8) = t9_15 }
    uint8 t9_16=0x40; unsafe { *((image + bc_start + 16) as uint8) = t9_16 }
    uint8 t9_17=0;   unsafe { *((image + bc_start + 17) as uint8) = t9_17 }
    uint8 t9_18=91;  unsafe { *((image + bc_start + 18) as uint8) = t9_18 }

    rc = atom_execute_table(ctx, ct_off, 0, 0)
    _pdec("t9_rc", 5, rc)
    if rc != 0 { puts("FAIL t9: rc != 0"); dealloc(ctx); dealloc(image); dealloc(ctx_p); dealloc(img_p); exit(9) }
    uint32 t9_val = 0; unsafe { *((ctx + AC_OFF_DIVMUL_Q) as uint32) -> t9_val }
    _phex("t9_ws0", 5, t9_val)
    if t9_val != 0x10 { puts("FAIL t9: ws0 != 0x10"); dealloc(ctx); dealloc(image); dealloc(ctx_p); dealloc(img_p); exit(9) }
    puts("PASS t9: shl WS DWORD")
    dealloc(ctx); dealloc(image)

    // ---------------------------------------------------------------
    // TEST 10: shr WS[0], IMM_DWORD 4  after WS[0]=0x10 → 0x01
    // shr_WS opcode = 117 (arg=2). attr=5.
    // ---------------------------------------------------------------
    _mk_ctx(img_sz, ct_off, 4, ctx_p, img_p)
    ctx = 0; unsafe { *(ctx_p as uint64) -> ctx }
    image = 0; unsafe { *(img_p as uint64) -> image }

    uint8 ta_0=3;   unsafe { *((image + bc_start + 0) as uint8) = ta_0 }
    uint8 ta_1=5;   unsafe { *((image + bc_start + 1) as uint8) = ta_1 }
    uint8 ta_2=0;   unsafe { *((image + bc_start + 2) as uint8) = ta_2 }
    uint8 ta_3=0x10; unsafe { *((image + bc_start + 3) as uint8) = ta_3 } // WS[0]=0x10
    uint8 ta_4=0;   unsafe { *((image + bc_start + 4) as uint8) = ta_4 }
    uint8 ta_5=0;   unsafe { *((image + bc_start + 5) as uint8) = ta_5 }
    uint8 ta_6=0;   unsafe { *((image + bc_start + 6) as uint8) = ta_6 }
    uint8 ta_7=117; unsafe { *((image + bc_start + 7) as uint8) = ta_7 }  // shr_WS
    uint8 ta_8=5;   unsafe { *((image + bc_start + 8) as uint8) = ta_8 }
    uint8 ta_9=0;   unsafe { *((image + bc_start + 9) as uint8) = ta_9 }
    uint8 ta_10=4;  unsafe { *((image + bc_start + 10) as uint8) = ta_10 } // shift=4
    uint8 ta_11=0;  unsafe { *((image + bc_start + 11) as uint8) = ta_11 }
    uint8 ta_12=0;  unsafe { *((image + bc_start + 12) as uint8) = ta_12 }
    uint8 ta_13=0;  unsafe { *((image + bc_start + 13) as uint8) = ta_13 }
    uint8 ta_14=3;  unsafe { *((image + bc_start + 14) as uint8) = ta_14 }
    uint8 ta_15=2;  unsafe { *((image + bc_start + 15) as uint8) = ta_15 }
    uint8 ta_16=0x40; unsafe { *((image + bc_start + 16) as uint8) = ta_16 }
    uint8 ta_17=0;  unsafe { *((image + bc_start + 17) as uint8) = ta_17 }
    uint8 ta_18=91; unsafe { *((image + bc_start + 18) as uint8) = ta_18 }

    rc = atom_execute_table(ctx, ct_off, 0, 0)
    _pdec("t10_rc", 6, rc)
    if rc != 0 { puts("FAIL t10: rc != 0"); dealloc(ctx); dealloc(image); dealloc(ctx_p); dealloc(img_p); exit(10) }
    uint32 ta_val = 0; unsafe { *((ctx + AC_OFF_DIVMUL_Q) as uint32) -> ta_val }
    _pdec("t10_ws0", 7, ta_val)
    if ta_val != 1 { puts("FAIL t10: ws0 != 1"); dealloc(ctx); dealloc(image); dealloc(ctx_p); dealloc(img_p); exit(10) }
    puts("PASS t10: shr WS DWORD")
    dealloc(ctx); dealloc(image)

    // ---------------------------------------------------------------
    // TEST 11: clear WS[3]  after WS[3]=0xFFFFFFFF → 0
    // clear_WS opcode = 86 (arg=2).
    // For clear: attr byte = raw byte in bytecode. We need attr&0x38 to give
    // the WS dword alignment. DWORD=0, so any byte with bits 5:3 = 0 works.
    // Use attr=0x00. After mask: attr=0&0x38=0; attr|=def_dst[0]<<6=0. Final attr=0.
    // get_dst(arg=2, attr=0): dst_to_src(0,0)=0, new_attr=2; arg=WS,align=DWORD → reads 1 byte idx.
    // put_dst(arg=2, attr=0, 0, saved): writes 0 to WS[idx].
    // Bytecode: [3,5, ws3, 0xFF,0xFF,0xFF,0xFF,  86, 0x00, ws3,  exfil(ws3→divmul),  91]
    // ---------------------------------------------------------------
    _mk_ctx(img_sz, ct_off, 4, ctx_p, img_p)
    ctx = 0; unsafe { *(ctx_p as uint64) -> ctx }
    image = 0; unsafe { *(img_p as uint64) -> image }

    // move WS[3], IMM_DWORD 0xFFFFFFFF
    uint8 tb_0=3;    unsafe { *((image + bc_start + 0) as uint8) = tb_0 }
    uint8 tb_1=5;    unsafe { *((image + bc_start + 1) as uint8) = tb_1 }
    uint8 tb_2=3;    unsafe { *((image + bc_start + 2) as uint8) = tb_2 }  // WS[3]
    uint8 tb_3=0xFF; unsafe { *((image + bc_start + 3) as uint8) = tb_3 }
    uint8 tb_4=0xFF; unsafe { *((image + bc_start + 4) as uint8) = tb_4 }
    uint8 tb_5=0xFF; unsafe { *((image + bc_start + 5) as uint8) = tb_5 }
    uint8 tb_6=0xFF; unsafe { *((image + bc_start + 6) as uint8) = tb_6 }
    // clear WS[3]
    uint8 tb_7=86;   unsafe { *((image + bc_start + 7) as uint8) = tb_7 }  // clear_WS
    uint8 tb_8=0;    unsafe { *((image + bc_start + 8) as uint8) = tb_8 }  // attr=0x00
    uint8 tb_9=3;    unsafe { *((image + bc_start + 9) as uint8) = tb_9 }  // WS[3]
    // exfil
    uint8 tb_10=3;   unsafe { *((image + bc_start + 10) as uint8) = tb_10 }
    uint8 tb_11=2;   unsafe { *((image + bc_start + 11) as uint8) = tb_11 }
    uint8 tb_12=0x40; unsafe { *((image + bc_start + 12) as uint8) = tb_12 }
    uint8 tb_13=3;   unsafe { *((image + bc_start + 13) as uint8) = tb_13 }  // WS[3]
    uint8 tb_14=91;  unsafe { *((image + bc_start + 14) as uint8) = tb_14 }

    rc = atom_execute_table(ctx, ct_off, 0, 0)
    _pdec("t11_rc", 6, rc)
    if rc != 0 { puts("FAIL t11: rc != 0"); dealloc(ctx); dealloc(image); dealloc(ctx_p); dealloc(img_p); exit(11) }
    uint32 tb_val = 0; unsafe { *((ctx + AC_OFF_DIVMUL_Q) as uint32) -> tb_val }
    _pdec("t11_ws3", 7, tb_val)
    if tb_val != 0 { puts("FAIL t11: ws3 != 0"); dealloc(ctx); dealloc(image); dealloc(ctx_p); dealloc(img_p); exit(11) }
    puts("PASS t11: clear WS")
    dealloc(ctx); dealloc(image)

    // ---------------------------------------------------------------
    // TEST 12: compare WS[0], IMM_DWORD 5  after WS[0]=5 → last_dst = 0 (5-5)
    //          also verify WS[0] is unchanged (compare has no write-back)
    // compare_WS opcode = 62 (arg=2). attr=5.
    // Bytecode: [3,5, ws0, 5,0,0,0,  62,5, ws0, 5,0,0,0,  exfil(ws0), 91]
    // After EOT: ctx->divmul[0] = WS[0] (still 5 via exfil)
    //            ectx->last_dst freed with ectx, but we can also exfil last_dst
    //            to divmul[1] via a move to WS[REMAINDER] using last_dst slot.
    // Actually we can only check last_dst is 0 indirectly; test verifies
    // WS[0] is unchanged (5) after compare — that's the no-writeback check.
    // ---------------------------------------------------------------
    _mk_ctx(img_sz, ct_off, 4, ctx_p, img_p)
    ctx = 0; unsafe { *(ctx_p as uint64) -> ctx }
    image = 0; unsafe { *(img_p as uint64) -> image }

    // move WS[0], IMM_DWORD 5
    uint8 tc_0=3;  unsafe { *((image + bc_start + 0) as uint8) = tc_0 }
    uint8 tc_1=5;  unsafe { *((image + bc_start + 1) as uint8) = tc_1 }
    uint8 tc_2=0;  unsafe { *((image + bc_start + 2) as uint8) = tc_2 }
    uint8 tc_3=5;  unsafe { *((image + bc_start + 3) as uint8) = tc_3 }
    uint8 tc_4=0;  unsafe { *((image + bc_start + 4) as uint8) = tc_4 }
    uint8 tc_5=0;  unsafe { *((image + bc_start + 5) as uint8) = tc_5 }
    uint8 tc_6=0;  unsafe { *((image + bc_start + 6) as uint8) = tc_6 }
    // compare WS[0], IMM_DWORD 5
    uint8 tc_7=62; unsafe { *((image + bc_start + 7) as uint8) = tc_7 }  // compare_WS
    uint8 tc_8=5;  unsafe { *((image + bc_start + 8) as uint8) = tc_8 }
    uint8 tc_9=0;  unsafe { *((image + bc_start + 9) as uint8) = tc_9 }
    uint8 tc_10=5; unsafe { *((image + bc_start + 10) as uint8) = tc_10 }
    uint8 tc_11=0; unsafe { *((image + bc_start + 11) as uint8) = tc_11 }
    uint8 tc_12=0; unsafe { *((image + bc_start + 12) as uint8) = tc_12 }
    uint8 tc_13=0; unsafe { *((image + bc_start + 13) as uint8) = tc_13 }
    // exfil WS[0] to divmul[0] to confirm no writeback
    uint8 tc_14=3;    unsafe { *((image + bc_start + 14) as uint8) = tc_14 }
    uint8 tc_15=2;    unsafe { *((image + bc_start + 15) as uint8) = tc_15 }
    uint8 tc_16=0x40; unsafe { *((image + bc_start + 16) as uint8) = tc_16 }
    uint8 tc_17=0;    unsafe { *((image + bc_start + 17) as uint8) = tc_17 }
    uint8 tc_18=91;   unsafe { *((image + bc_start + 18) as uint8) = tc_18 }

    rc = atom_execute_table(ctx, ct_off, 0, 0)
    _pdec("t12_rc", 6, rc)
    if rc != 0 { puts("FAIL t12: rc != 0"); dealloc(ctx); dealloc(image); dealloc(ctx_p); dealloc(img_p); exit(12) }
    uint32 tc_val = 0; unsafe { *((ctx + AC_OFF_DIVMUL_Q) as uint32) -> tc_val }
    _pdec("t12_ws0", 7, tc_val)
    // WS[0] must still be 5 (no writeback)
    if tc_val != 5 { puts("FAIL t12: ws0 changed after compare"); dealloc(ctx); dealloc(image); dealloc(ctx_p); dealloc(img_p); exit(12) }
    puts("PASS t12: compare WS no writeback")
    dealloc(ctx); dealloc(image)

    dealloc(ctx_p); dealloc(img_p)
    puts("phase3_atom_arith_test: GREEN")
    exit(0)
}
