// bwd_uv_smoke — ISOLATED bisect of the bwd_uv GEMM dispatch SEQUENCE for ONE
// bank, with the SAME shapes / grids / buffer-reuse as the GEMM-ified backward
// in examples/wzma_train_md.mlr (the uncommitted full-step backward).
//
// PURPOSE: gemm_f32_accum was proven GREEN in isolation at the dV shape
// (M=R=32 N=D=384 K=BS=128; commit 6a0dadf, examples/gemm_accum_smoke.mlr).  The
// GEMM-ified bwd_uv still wedges on its first per-bank GEMM group.  So the wedge
// must be in the SEQUENCE — a transpose shape/OOB, the OTHER accum shapes
// (dU M=384 N=32 K=128; dx M=128 N=384 K=32), or a mis-sized scratch buffer.
//
// This fires the EXACT one-bank bwd_uv dispatch chain (mirroring lines 833-886
// of wzma_train_md.mlr), each dispatch followed by hipDeviceSynchronize + a
// print, so the LAST print before a wedge names the culprit dispatch+shape.
// Each producing dispatch is D2H-validated against a CPU reference.
//
// Math (per bank k, ONE view):
//   doutk_k[bs,d]  = alpha_k[bs] * dz[bs,d]                 (row_scale)
//   V_k^T[D,R]     = transpose(V_k[R,D])                    (transpose)
//   dinter_k[bs,r] = doutk_k[BS,D] @ V_k^T[D,R]             (gemm)        M=128 N=32  K=384
//   inter_k^T[R,BS]= transpose(inter_k[BS,R])              (transpose)
//   dV_k[r,d]     += inter_k^T[R,BS] @ doutk_k[BS,D]        (gemm_accum)  M=32  N=384 K=128
//   dU_k[d,r]     += x^T[D,BS] @ dinter_k[BS,R]             (gemm_accum)  M=384 N=32  K=128
//   x^T[D,BS]      = transpose(x[BS,D])                     (transpose)
//   U_k^T[R,D]     = transpose(U_k[D,R])                    (transpose)
//   dx[bs,d]      += dinter_k[BS,R] @ U_k^T[R,D]            (gemm_accum)  M=128 N=384 K=32
//
// Shapes: BS=128 D=384 K=4 R=32 (== wzma_train_md dims).
//
// Build (kfd-safe — hipkfd_teardown on every exit path, --target=amdgpu-native):
//   ./build/mlrc --arch=x86_64 --target=amdgpu-native \
//       examples/bwd_uv_smoke.mlr -o ~/mlrift_bin/wzma_train/bwd_uv_smoke
// Run:
//   ~/mlrift_bin/wzma_train/bwd_uv_smoke
//
// Required .co (load paths below; all from MLRift native emit, no hipcc):
//   transpose_f32.co  gemm_f32_native.co  gemm_f32_accum.co  row_scale_f32.co

import "../std/train.mlr"
import "../std/math_float.mlr"
import "../std/fmt.mlr"
import "../std/hip.mlr"

static u64 BS_DIM = 128
static u64 D_DIM  = 384
static u64 R_DIM  = 32

fn abs_f32(f32 v) -> f32 { if v < 0.0f { return 0.0f - v } return v }

fn die_gpu(u64 msg, u64 code) {
    print_str(msg); print_str(" err="); u64 s = fmt_dec(code); print_str(s); dealloc(s); print_str("\n")
    hipkfd_teardown(); exit(1)
}

fn load_co(u64 co_path, u64 fn_name) -> u64 {
    u64 fd = file_open(co_path, 0)
    if fd > 0xFFFFFFFFFFFFF000 {
        print_str("Cannot open .co: "); print_str(co_path); print_str("\n"); hipkfd_teardown(); exit(1)
    }
    u64 sz = file_size(fd); u64 blob = alloc(sz); file_read(fd, blob, sz); file_close(fd)
    u64 mod_slot = alloc(8)
    u32 err = hipModuleLoadData(mod_slot, blob)
    if err != 0 { die_gpu("hipModuleLoadData", err) }
    u64 mod = 0; unsafe { *(mod_slot as u64) -> mod }
    u64 fh_slot = alloc(8)
    err = hipModuleGetFunction(fh_slot, mod, fn_name)
    if err != 0 { die_gpu("hipModuleGetFunction", err) }
    u64 fh = 0; unsafe { *(fh_slot as u64) -> fh }
    dealloc(mod_slot); dealloc(fh_slot); return fh
}

fn gpu_alloc(u64 nbytes) -> u64 {
    u64 slot = alloc(8); u32 err = hipMalloc(slot, nbytes)
    if err != 0 { die_gpu("hipMalloc", err) }
    u64 p = 0; unsafe { *(slot as u64) -> p }; dealloc(slot); return p
}

// ── launch helpers (verbatim ABI/grid from wzma_train_md.mlr) ──────────────
fn launch_row_scale(u64 fh, u64 d_in, u64 d_scale, u64 d_out, u64 n, u64 row_width) {
    u64 p0 = alloc(8); unsafe { *(p0 as u64) = d_in }
    u64 p1 = alloc(8); unsafe { *(p1 as u64) = d_scale }
    u64 p2 = alloc(8); unsafe { *(p2 as u64) = d_out }
    u64 p3 = alloc(8); unsafe { *(p3 as u64) = n }
    u64 p4 = alloc(8); unsafe { *(p4 as u64) = row_width }
    u64 kp = alloc(5 * 8)
    unsafe { *(kp as u64) = p0 } unsafe { *((kp + 8) as u64) = p1 } unsafe { *((kp + 16) as u64) = p2 }
    unsafe { *((kp + 24) as u64) = p3 } unsafe { *((kp + 32) as u64) = p4 }
    u64 grid_u = (n + 255) / 256
    u32 grid = grid_u; u32 block = 256
    u32 err = hipModuleLaunchKernel(fh, grid, 1, 1, block, 1, 1, 0, 0, kp, 0)
    if err != 0 { die_gpu("launch row_scale", err) }
    dealloc(p0); dealloc(p1); dealloc(p2); dealloc(p3); dealloc(p4); dealloc(kp)
}

fn launch_transpose(u64 fh, u64 d_in, u64 d_out, u64 m, u64 n) {
    u64 p0 = alloc(8); unsafe { *(p0 as u64) = d_in }
    u64 p1 = alloc(8); unsafe { *(p1 as u64) = d_out }
    u64 p2 = alloc(8); unsafe { *(p2 as u64) = m }
    u64 p3 = alloc(8); unsafe { *(p3 as u64) = n }
    u64 kp = alloc(4 * 8)
    unsafe { *(kp as u64) = p0 } unsafe { *((kp + 8) as u64) = p1 }
    unsafe { *((kp + 16) as u64) = p2 } unsafe { *((kp + 24) as u64) = p3 }
    u64 tiles_m = (m + 15) / 16; u64 tiles_n = (n + 15) / 16
    u64 grid_u = tiles_m * tiles_n
    u32 grid = grid_u; u32 block = 256
    u32 err = hipModuleLaunchKernel(fh, grid, 1, 1, block, 1, 1, 0, 0, kp, 0)
    if err != 0 { die_gpu("launch transpose", err) }
    dealloc(p0); dealloc(p1); dealloc(p2); dealloc(p3); dealloc(kp)
}

fn launch_gemm6(u64 fh, u64 d_a, u64 d_b, u64 d_c, u64 m, u64 n, u64 k_dim) {
    u64 p0 = alloc(8); unsafe { *(p0 as u64) = d_a }
    u64 p1 = alloc(8); unsafe { *(p1 as u64) = d_b }
    u64 p2 = alloc(8); unsafe { *(p2 as u64) = d_c }
    u64 p3 = alloc(8); unsafe { *(p3 as u64) = m }
    u64 p4 = alloc(8); unsafe { *(p4 as u64) = n }
    u64 p5 = alloc(8); unsafe { *(p5 as u64) = k_dim }
    u64 kp = alloc(6 * 8)
    unsafe { *(kp as u64) = p0 } unsafe { *((kp + 8) as u64) = p1 } unsafe { *((kp + 16) as u64) = p2 }
    unsafe { *((kp + 24) as u64) = p3 } unsafe { *((kp + 32) as u64) = p4 } unsafe { *((kp + 40) as u64) = p5 }
    u64 tiles_m = (m + 15) / 16; u64 tiles_n = (n + 15) / 16
    u64 grid_u = tiles_m * tiles_n
    u32 grid = grid_u; u32 block = 256
    u32 err = hipModuleLaunchKernel(fh, grid, 1, 1, block, 1, 1, 0, 0, kp, 0)
    if err != 0 { die_gpu("launch gemm", err) }
    dealloc(p0); dealloc(p1); dealloc(p2); dealloc(p3); dealloc(p4); dealloc(p5); dealloc(kp)
}

fn sync_or_die(u64 tag) {
    u32 err = hipDeviceSynchronize()
    if err != 0 { die_gpu(tag, err) }
    print_str("  sync OK: "); print_str(tag); print_str("\n")
}

// Compare D2H buffer vs CPU reference over n elems; print max_err + PASS/FAIL.
fn check(u64 tag, u64 d_buf, u64 h_ref, u64 h_dev, u64 n, f32 tol) {
    u32 err = hipMemcpy(h_dev, d_buf, n * 4, 2)
    if err != 0 { die_gpu("D2H check", err) }
    f32 max_err = 0.0f; u64 wi = 0; f32 wd = 0.0f; f32 wr = 0.0f
    u64 i = 0
    while i < n {
        f32 dv = 0.0f; f32 rv = 0.0f
        unsafe { *((h_dev + i * 4) as f32) -> dv }
        unsafe { *((h_ref + i * 4) as f32) -> rv }
        f32 e = abs_f32(dv - rv)
        if e > max_err { max_err = e; wi = i; wd = dv; wr = rv }
        i = i + 1
    }
    print_str("  CHECK "); print_str(tag); print_str(": max_err=")
    u64 s = fmt_f32(max_err, 9); print_str(s); dealloc(s)
    print_str(" worst[i="); s = fmt_dec(wi); print_str(s); dealloc(s)
    print_str(" dev="); s = fmt_f32(wd, 6); print_str(s); dealloc(s)
    print_str(" ref="); s = fmt_f32(wr, 6); print_str(s); dealloc(s); print_str("] ")
    if max_err < tol { print_str("PASS\n") } else { print_str("FAIL\n") }
}

fn main() {
    u64 BS = BS_DIM; u64 D = D_DIM; u64 R = R_DIM

    print_str("=== bwd_uv_smoke: ONE-bank bwd_uv dispatch sequence (BS=128 D=384 R=32) ===\n")
    print_str("Each dispatch -> sync + print; LAST print before a wedge = culprit.\n")

    u32 err = hipSetDevice(0)
    if err != 0 { print_str("hipSetDevice failed\n"); exit(1) }

    u64 fh_transp = load_co("/tmp/transpose_f32.co",    "transpose_f32")
    u64 fh_gemm   = load_co("/tmp/gemm_f32_native.co",  "gemm_f32")
    u64 fh_gaccum = load_co("/tmp/gemm_f32_accum.co",   "gemm_f32_accum")
    u64 fh_rscale = load_co("/tmp/row_scale_f32.co",    "row_scale_f32")
    print_str("Kernels loaded (transpose, gemm_f32, gemm_f32_accum, row_scale; native).\n")

    // ── host input buffers (small deterministic patterns) ──────────────────
    u64 h_dz    = alloc(BS * D * 4)   // dz[BS,D]
    u64 h_alpha = alloc(BS * 4)       // alpha_k[BS]
    u64 h_V     = alloc(R * D * 4)    // V_k[R,D]
    u64 h_U     = alloc(D * R * 4)    // U_k[D,R]
    u64 h_x     = alloc(BS * D * 4)   // x[BS,D]
    u64 h_inter = alloc(BS * R * 4)   // inter_k[BS,R]
    // scratch readbacks + refs
    u64 h_dev   = alloc(BS * D * 4)   // largest D2H readback
    u64 h_doutk_ref = alloc(BS * D * 4)
    u64 h_dinter_ref= alloc(BS * R * 4)
    u64 h_dV_ref    = alloc(R * D * 4)
    u64 h_dU_ref    = alloc(D * R * 4)
    u64 h_dx_ref    = alloc(BS * D * 4)
    u64 h_dV_init   = alloc(R * D * 4)
    u64 h_dU_init   = alloc(D * R * 4)
    u64 h_dx_init   = alloc(BS * D * 4)

    // dz[bs,d], x[bs,d]
    u64 b = 0
    while b < BS {
        u64 d = 0
        while d < D {
            u64 v = (b * 3 + d * 7); u64 vm = v - (v / 13) * 13
            f32 dzv = f64_to_f32(int_to_f64(vm) * 0.01)
            unsafe { *((h_dz + (b * D + d) * 4) as f32) = dzv }
            u64 v2 = (b * 5 + d * 2); u64 vm2 = v2 - (v2 / 11) * 11
            f32 xv = f64_to_f32(int_to_f64(vm2) * 0.01)
            unsafe { *((h_x + (b * D + d) * 4) as f32) = xv }
            d = d + 1
        }
        u64 va = (b * 2 + 1); u64 vam = va - (va / 7) * 7
        f32 al = f64_to_f32(int_to_f64(vam) * 0.1 + 0.05)
        unsafe { *((h_alpha + b * 4) as f32) = al }
        b = b + 1
    }
    // V_k[r,d]
    u64 r = 0
    while r < R {
        u64 d = 0
        while d < D {
            u64 v = (r * 4 + d * 3); u64 vm = v - (v / 9) * 9
            f32 vv = f64_to_f32(int_to_f64(vm) * 0.01)
            unsafe { *((h_V + (r * D + d) * 4) as f32) = vv }
            d = d + 1
        }
        r = r + 1
    }
    // U_k[d,r]  and inter_k[bs,r]
    u64 d2 = 0
    while d2 < D {
        u64 rr = 0
        while rr < R {
            u64 v = (d2 * 2 + rr * 5); u64 vm = v - (v / 8) * 8
            f32 uv = f64_to_f32(int_to_f64(vm) * 0.01)
            unsafe { *((h_U + (d2 * R + rr) * 4) as f32) = uv }
            rr = rr + 1
        }
        d2 = d2 + 1
    }
    u64 bi = 0
    while bi < BS {
        u64 rr = 0
        while rr < R {
            u64 v = (bi * 6 + rr * 2); u64 vm = v - (v / 10) * 10
            f32 iv = f64_to_f32(int_to_f64(vm) * 0.01)
            unsafe { *((h_inter + (bi * R + rr) * 4) as f32) = iv }
            rr = rr + 1
        }
        bi = bi + 1
    }
    // dV / dU / dx accumulate-init: known NONZERO so the accum must ADD onto them
    u64 i = 0
    while i < R * D { u64 vm = i - (i / 17) * 17; unsafe { *((h_dV_init + i * 4) as f32) = f64_to_f32(int_to_f64(vm) * 0.5 + 1.0) } i = i + 1 }
    i = 0
    while i < D * R { u64 vm = i - (i / 19) * 19; unsafe { *((h_dU_init + i * 4) as f32) = f64_to_f32(int_to_f64(vm) * 0.5 + 1.0) } i = i + 1 }
    i = 0
    while i < BS * D { u64 vm = i - (i / 23) * 23; unsafe { *((h_dx_init + i * 4) as f32) = f64_to_f32(int_to_f64(vm) * 0.5 + 1.0) } i = i + 1 }

    // ── CPU reference ───────────────────────────────────────────────────────
    // doutk[bs,d] = alpha[bs]*dz[bs,d]
    b = 0
    while b < BS {
        f32 al = 0.0f; unsafe { *((h_alpha + b * 4) as f32) -> al }
        u64 d = 0
        while d < D {
            f32 dzv = 0.0f; unsafe { *((h_dz + (b * D + d) * 4) as f32) -> dzv }
            unsafe { *((h_doutk_ref + (b * D + d) * 4) as f32) = al * dzv }
            d = d + 1
        }
        b = b + 1
    }
    // dinter[bs,r] = doutk[bs,:] . V_k[r,:]   (doutk @ V_k^T)
    b = 0
    while b < BS {
        u64 rr = 0
        while rr < R {
            f32 acc = 0.0f; u64 d = 0
            while d < D {
                f32 du = 0.0f; f32 vv = 0.0f
                unsafe { *((h_doutk_ref + (b * D + d) * 4) as f32) -> du }
                unsafe { *((h_V + (rr * D + d) * 4) as f32) -> vv }
                acc = acc + du * vv; d = d + 1
            }
            unsafe { *((h_dinter_ref + (b * R + rr) * 4) as f32) = acc }
            rr = rr + 1
        }
        b = b + 1
    }
    // dV[r,d] = init + sum_bs inter[bs,r]*doutk[bs,d]
    r = 0
    while r < R {
        u64 d = 0
        while d < D {
            f32 acc = 0.0f; u64 bs2 = 0
            while bs2 < BS {
                f32 iv = 0.0f; f32 du = 0.0f
                unsafe { *((h_inter + (bs2 * R + r) * 4) as f32) -> iv }
                unsafe { *((h_doutk_ref + (bs2 * D + d) * 4) as f32) -> du }
                acc = acc + iv * du; bs2 = bs2 + 1
            }
            f32 c0 = 0.0f; unsafe { *((h_dV_init + (r * D + d) * 4) as f32) -> c0 }
            unsafe { *((h_dV_ref + (r * D + d) * 4) as f32) = c0 + acc }
            d = d + 1
        }
        r = r + 1
    }
    // dU[d,r] = init + sum_bs x[bs,d]*dinter[bs,r]
    d2 = 0
    while d2 < D {
        u64 rr = 0
        while rr < R {
            f32 acc = 0.0f; u64 bs2 = 0
            while bs2 < BS {
                f32 xv = 0.0f; f32 di = 0.0f
                unsafe { *((h_x + (bs2 * D + d2) * 4) as f32) -> xv }
                unsafe { *((h_dinter_ref + (bs2 * R + rr) * 4) as f32) -> di }
                acc = acc + xv * di; bs2 = bs2 + 1
            }
            f32 c0 = 0.0f; unsafe { *((h_dU_init + (d2 * R + rr) * 4) as f32) -> c0 }
            unsafe { *((h_dU_ref + (d2 * R + rr) * 4) as f32) = c0 + acc }
            rr = rr + 1
        }
        d2 = d2 + 1
    }
    // dx[bs,d] = init + sum_r dinter[bs,r]*U_k[d,r]
    b = 0
    while b < BS {
        u64 d = 0
        while d < D {
            f32 acc = 0.0f; u64 rr = 0
            while rr < R {
                f32 di = 0.0f; f32 uv = 0.0f
                unsafe { *((h_dinter_ref + (b * R + rr) * 4) as f32) -> di }
                unsafe { *((h_U + (d * R + rr) * 4) as f32) -> uv }
                acc = acc + di * uv; rr = rr + 1
            }
            f32 c0 = 0.0f; unsafe { *((h_dx_init + (b * D + d) * 4) as f32) -> c0 }
            unsafe { *((h_dx_ref + (b * D + d) * 4) as f32) = c0 + acc }
            d = d + 1
        }
        b = b + 1
    }

    // ── GPU buffers (mirror wzma_train_md scratch sizes EXACTLY) ────────────
    u64 d_dz     = gpu_alloc(BS * D * 4)
    u64 d_alpha  = gpu_alloc(BS * 4)
    u64 d_V      = gpu_alloc(R * D * 4)
    u64 d_U      = gpu_alloc(D * R * 4)
    u64 d_x      = gpu_alloc(BS * D * 4)
    u64 d_inter  = gpu_alloc(BS * R * 4)
    u64 d_doutk  = gpu_alloc(BS * D * 4)   // doutk_k [BS,D]
    u64 d_xT     = gpu_alloc(D * BS * 4)   // x^T [D,BS]
    u64 d_interT = gpu_alloc(R * BS * 4)   // inter_k^T [R,BS]
    u64 d_VkT    = gpu_alloc(D * R * 4)    // V_k^T [D,R]
    u64 d_UkT    = gpu_alloc(R * D * 4)    // U_k^T [R,D]
    u64 d_dinter = gpu_alloc(BS * R * 4)   // dinter_k [BS,R]
    u64 d_dV     = gpu_alloc(R * D * 4)
    u64 d_dU     = gpu_alloc(D * R * 4)
    u64 d_dx     = gpu_alloc(BS * D * 4)

    err = hipMemcpy(d_dz,    h_dz,    BS * D * 4, 1); if err != 0 { die_gpu("H2D dz", err) }
    err = hipMemcpy(d_alpha, h_alpha, BS * 4,     1); if err != 0 { die_gpu("H2D alpha", err) }
    err = hipMemcpy(d_V,     h_V,     R * D * 4,  1); if err != 0 { die_gpu("H2D V", err) }
    err = hipMemcpy(d_U,     h_U,     D * R * 4,  1); if err != 0 { die_gpu("H2D U", err) }
    err = hipMemcpy(d_x,     h_x,     BS * D * 4, 1); if err != 0 { die_gpu("H2D x", err) }
    err = hipMemcpy(d_inter, h_inter, BS * R * 4, 1); if err != 0 { die_gpu("H2D inter", err) }
    err = hipMemcpy(d_dV,    h_dV_init, R * D * 4, 1); if err != 0 { die_gpu("H2D dV_init", err) }
    err = hipMemcpy(d_dU,    h_dU_init, D * R * 4, 1); if err != 0 { die_gpu("H2D dU_init", err) }
    err = hipMemcpy(d_dx,    h_dx_init, BS * D * 4, 1); if err != 0 { die_gpu("H2D dx_init", err) }
    print_str("Inputs uploaded.\n")

    f32 tol = 0.01f

    // ── FIRE THE EXACT bwd_uv ONE-BANK SEQUENCE ─────────────────────────────
    print_str("\n--- DISPATCH 1: row_scale doutk = alpha . dz  (n=BS*D=49152 rw=D=384) ---\n")
    launch_row_scale(fh_rscale, d_dz, d_alpha, d_doutk, BS * D, D)
    sync_or_die("D1 row_scale")
    check("doutk[BS,D]", d_doutk, h_doutk_ref, h_dev, BS * D, tol)

    print_str("\n--- DISPATCH 2: transpose V_k[R=32,D=384] -> VkT[D,R]  grid=2*24=48 ---\n")
    launch_transpose(fh_transp, d_V, d_VkT, R, D)
    sync_or_die("D2 transpose Vk")

    print_str("\n--- DISPATCH 3: gemm dinter = doutk[BS,D] @ VkT[D,R]  M=128 N=32 K=384 grid=8*2=16 ---\n")
    launch_gemm6(fh_gemm, d_doutk, d_VkT, d_dinter, BS, R, D)
    sync_or_die("D3 gemm dinter")
    check("dinter[BS,R]", d_dinter, h_dinter_ref, h_dev, BS * R, tol)

    print_str("\n--- DISPATCH 4: transpose inter_k[BS=128,R=32] -> interT[R,BS]  grid=8*2=16 ---\n")
    launch_transpose(fh_transp, d_inter, d_interT, BS, R)
    sync_or_die("D4 transpose interk")

    print_str("\n--- DISPATCH 5: gemm_accum dV += interT[R,BS] @ doutk[BS,D]  M=32 N=384 K=128 grid=2*24=48 ---\n")
    launch_gemm6(fh_gaccum, d_interT, d_doutk, d_dV, R, D, BS)
    sync_or_die("D5 gemm_accum dV")
    check("dV[R,D]", d_dV, h_dV_ref, h_dev, R * D, tol)

    print_str("\n--- DISPATCH 6: transpose x[BS=128,D=384] -> xT[D,BS]  grid=8*24=192 ---\n")
    launch_transpose(fh_transp, d_x, d_xT, BS, D)
    sync_or_die("D6 transpose x")

    print_str("\n--- DISPATCH 7: gemm_accum dU += xT[D,BS] @ dinter[BS,R]  M=384 N=32 K=128 grid=24*2=48 ---\n")
    launch_gemm6(fh_gaccum, d_xT, d_dinter, d_dU, D, R, BS)
    sync_or_die("D7 gemm_accum dU")
    check("dU[D,R]", d_dU, h_dU_ref, h_dev, D * R, tol)

    print_str("\n--- DISPATCH 8: transpose U_k[D=384,R=32] -> UkT[R,D]  grid=24*2=48 ---\n")
    launch_transpose(fh_transp, d_U, d_UkT, D, R)
    sync_or_die("D8 transpose Uk")

    print_str("\n--- DISPATCH 9: gemm_accum dx += dinter[BS,R] @ UkT[R,D]  M=128 N=384 K=32 grid=8*24=192 ---\n")
    launch_gemm6(fh_gaccum, d_dinter, d_UkT, d_dx, BS, D, R)
    sync_or_die("D9 gemm_accum dx")
    check("dx[BS,D]", d_dx, h_dx_ref, h_dev, BS * D, tol)

    print_str("\n=== PHASE A: ALL 9 ONE-BANK DISPATCHES RAN (per-dispatch sync) ===\n")

    // ════════════════════════════════════════════════════════════════════════
    // PHASE B — reproduce the REAL bwd_uv chaining that wzma_train_md uses:
    //   (1) dbias gemm_accum at M=1 N=384 K=128 (NEW untested tile-edge shape),
    //   (2) alphaT transpose at BS=128,K=4 (K=4→16 padded; row_scale reads slices),
    //   (3) FULL K=4 multi-bank loop with the EXACT batched per-bank sync cadence
    //       (8 packets queued THEN one sync) + scratch reuse across banks +
    //       the [K,BS,D]/[K,BS,R]/[K,BS] k-major buffer layout.
    // This is the chaining the task says to test when the one-bank core passes.
    // No CPU re-validation here (PHASE A already validated the math); PHASE B is
    // a pure WEDGE bisect — whichever bank/dispatch's post-sync print is last
    // before a hang = the chaining culprit.
    print_str("\n=== PHASE B: real multi-bank chaining (K=4 banks, batched per-bank sync) ===\n")

    u64 K = 4
    // k-major scratch (mirrors wzma_train_md: d_doutk[K,BS,D], d_inter_kr[K,BS,R],
    // d_alphaT[K,BS]); per-bank weights packed [K,*].
    u64 d_doutkK   = gpu_alloc(K * BS * D * 4)   // [K,BS,D]
    u64 d_interKR  = gpu_alloc(K * BS * R * 4)    // [K,BS,R] raw inter, k-major
    u64 d_alphaT   = gpu_alloc(K * BS * 4)        // alpha^T [K,BS]
    u64 d_Uall     = gpu_alloc(K * D * R * 4)     // U [K,D,R]
    u64 d_Vall     = gpu_alloc(K * R * D * 4)     // V [K,R,D]
    u64 d_dUall    = gpu_alloc(K * D * R * 4)     // dU [K,D,R]
    u64 d_dVall    = gpu_alloc(K * R * D * 4)     // dV [K,R,D]
    u64 d_alphaBK  = gpu_alloc(BS * K * 4)        // alpha[BS,K] (pre-transpose source)
    u64 d_dbias    = gpu_alloc(D * 4)             // dbias[D]
    u64 d_ones_bs  = gpu_alloc(BS * 4)            // ones[1,BS] for dbias gemm

    // host fill: alpha[BS,K], U/V per bank, ones, dbias init
    u64 hbuf = alloc(K * BS * D * 4)
    u64 j = 0
    while j < BS * K { u64 vm = j - (j / 7) * 7; unsafe { *((hbuf + j * 4) as f32) = f64_to_f32(int_to_f64(vm) * 0.1 + 0.05) } j = j + 1 }
    err = hipMemcpy(d_alphaBK, hbuf, BS * K * 4, 1); if err != 0 { die_gpu("H2D alphaBK", err) }
    j = 0
    while j < BS { unsafe { *((hbuf + j * 4) as f32) = 1.0f } j = j + 1 }
    err = hipMemcpy(d_ones_bs, hbuf, BS * 4, 1); if err != 0 { die_gpu("H2D ones", err) }
    j = 0
    while j < K * D * R { u64 vm = j - (j / 8) * 8; unsafe { *((hbuf + j * 4) as f32) = f64_to_f32(int_to_f64(vm) * 0.01) } j = j + 1 }
    err = hipMemcpy(d_Uall, hbuf, K * D * R * 4, 1); if err != 0 { die_gpu("H2D Uall", err) }
    err = hipMemcpy(d_dUall, hbuf, K * D * R * 4, 1); if err != 0 { die_gpu("H2D dUall", err) }
    j = 0
    while j < K * R * D { u64 vm = j - (j / 9) * 9; unsafe { *((hbuf + j * 4) as f32) = f64_to_f32(int_to_f64(vm) * 0.01) } j = j + 1 }
    err = hipMemcpy(d_Vall, hbuf, K * R * D * 4, 1); if err != 0 { die_gpu("H2D Vall", err) }
    err = hipMemcpy(d_dVall, hbuf, K * R * D * 4, 1); if err != 0 { die_gpu("H2D dVall", err) }
    j = 0
    while j < K * BS * R { u64 vm = j - (j / 10) * 10; unsafe { *((hbuf + j * 4) as f32) = f64_to_f32(int_to_f64(vm) * 0.01) } j = j + 1 }
    err = hipMemcpy(d_interKR, hbuf, K * BS * R * 4, 1); if err != 0 { die_gpu("H2D interKR", err) }
    j = 0
    while j < D { unsafe { *((hbuf + j * 4) as f32) = 1.0f } j = j + 1 }
    err = hipMemcpy(d_dbias, hbuf, D * 4, 1); if err != 0 { die_gpu("H2D dbias", err) }

    // view-prep packets (queued, then ONE sync — matches real cadence):
    print_str("--- view-prep: dbias gemm_accum (M=1 N=384 K=128) + alphaT transpose (BS=128,K=4) ---\n")
    launch_gemm6(fh_gaccum, d_ones_bs, d_dz, d_dbias, 1, D, BS)   // dbias[1,D] += ones[1,BS]@dz[BS,D]
    launch_transpose(fh_transp, d_alphaBK, d_alphaT, BS, K)        // alpha[BS,K]->alphaT[K,BS]
    launch_transpose(fh_transp, d_x, d_xT, BS, D)                  // x^T[D,BS]
    sync_or_die("B view-prep (3 packets)")

    u64 kk = 0
    while kk < K {
        u64 d_Uk      = d_Uall    + kk * D * R * 4
        u64 d_Vk      = d_Vall    + kk * R * D * 4
        u64 d_dUk     = d_dUall   + kk * D * R * 4
        u64 d_dVk     = d_dVall   + kk * R * D * 4
        u64 d_intk    = d_interKR + kk * BS * R * 4
        u64 d_doutk_k = d_doutkK  + kk * BS * D * 4
        u64 d_alphak  = d_alphaT  + kk * BS * 4
        // 8 packets queued, THEN one sync (exactly the real per-bank cadence):
        launch_row_scale(fh_rscale, d_dz, d_alphak, d_doutk_k, BS * D, D)
        launch_transpose(fh_transp, d_Vk, d_VkT, R, D)
        launch_gemm6(fh_gemm, d_doutk_k, d_VkT, d_dinter, BS, R, D)
        launch_transpose(fh_transp, d_intk, d_interT, BS, R)
        launch_gemm6(fh_gaccum, d_interT, d_doutk_k, d_dVk, R, D, BS)
        launch_gemm6(fh_gaccum, d_xT, d_dinter, d_dUk, D, R, BS)
        launch_transpose(fh_transp, d_Uk, d_UkT, D, R)
        launch_gemm6(fh_gaccum, d_dinter, d_UkT, d_dx, BS, D, R)
        print_str("  (bank "); u64 sb = fmt_dec(kk); print_str(sb); dealloc(sb); print_str(" — 8 packets queued, syncing...)\n")
        sync_or_die("B bank")
        kk = kk + 1
    }
    print_str("\n=== PHASE B: ALL 4 BANKS RAN — multi-bank bwd_uv chaining GREEN ===\n")

    err = hipFree(d_doutkK); err = hipFree(d_interKR); err = hipFree(d_alphaT)
    err = hipFree(d_Uall); err = hipFree(d_Vall); err = hipFree(d_dUall); err = hipFree(d_dVall)
    err = hipFree(d_alphaBK); err = hipFree(d_dbias); err = hipFree(d_ones_bs)
    dealloc(hbuf)

    print_str("\n=== ALL PHASES GREEN — neither one-bank nor multi-bank bwd_uv wedges in isolation ===\n")

    err = hipFree(d_dz); err = hipFree(d_alpha); err = hipFree(d_V); err = hipFree(d_U)
    err = hipFree(d_x); err = hipFree(d_inter); err = hipFree(d_doutk); err = hipFree(d_xT)
    err = hipFree(d_interT); err = hipFree(d_VkT); err = hipFree(d_UkT); err = hipFree(d_dinter)
    err = hipFree(d_dV); err = hipFree(d_dU); err = hipFree(d_dx)

    hipkfd_teardown()
    print_str("teardown OK — done.\n")
    exit(0)
}
