// Llama-3.2-1B greedy decode — first non-Qwen3 LLM through the MLRift
// pipeline. Reads the GGUF blob that `ollama pull llama3.2:1b` left on
// disk and runs CPU greedy decode through std/qwen3.mlr's forward path
// with three arch knobs flipped:
//
//   qwen3_set_qknorm(0)       Llama-3 has no per-head Q/K RMSNorm.
//   qwen3_set_rope_base(500000)  Llama-3 RoPE theta is 5e5 (Qwen3 = 1e6).
//   qwen3_set_arch(2048, 64, 32, 8, 8192)
//                              hidden=2048, head_dim=64, n_heads=32,
//                              n_kv_heads=8 (GQA 4:1), ff=8192.
//
// Llama-3.2-1B specifics (from GGUF metadata):
//   architecture            = llama
//   layers                  = 16
//   embedding_length        = 2048
//   feed_forward_length     = 8192
//   attention.head_count    = 32
//   attention.head_count_kv = 8
//   attention.key_length    = 64       (head_dim, full RoPE)
//   attention.layer_norm_rms_epsilon = 1e-5
//   rope.freq_base          = 500000.0
//   vocab_size              = 128256
//   tokenizer.ggml.bos      = 128000
//   tokenizer.ggml.eos      = 128009
//   tie_word_embeddings     = true     (no separate output.weight)
//   quantization            = Q8_0
//
// Tensor naming (Llama GGUF convention — same as Qwen3-14B Q8_0):
//   blk.N.attn_norm / attn_q / attn_k / attn_v / attn_output
//   blk.N.ffn_norm / ffn_gate / ffn_up / ffn_down
//   token_embd / output_norm           (no output.weight — tied)
//
// First-cut bench: hardcoded seed token id 15339 ("hello" in the Llama-3
// tiktoken vocab), 20-token greedy decode, print token IDs only. Cross-
// reference against `ollama run llama3.2:1b "hello"` greedy output for
// correctness validation. Tokenizer integration is a follow-up slice.
//
// Build:
//   ./build/mlrc --emit=elfexe examples/llama3_generate.mlr -o /tmp/llama32_1b
//   /tmp/llama32_1b

import "../std/qwen3.mlr"
import "../std/gguf.mlr"
import "../std/matmul.mlr"
import "../std/inference.mlr"
import "../std/io.mlr"
import "../std/fmt.mlr"
import "../std/string.mlr"
import "../std/thread.mlr"
import "../std/time.mlr"
import "../std/model_path.mlr"

static u64 g_fd = 0
fn eout(u64 s) {
    print_str(s)
    if g_fd != 0 {
        u64 n = str_len(s)
        file_write(g_fd, s, n)
    }
}
fn eu64(u64 v) {
    u64 s = fmt_dec(v)
    eout(s)
    dealloc(s)
}

// madvise(MADV_DONTNEED) wrapper.  Releases physical pages back to the
// kernel for the page-aligned subrange of [addr, addr+len).  Bytes at
// page-aligned edges stay resident (negligible at GGUF tensor sizes).
// Linux x86_64 syscall: 28; MADV_DONTNEED = 4.  Returns 0 on success.
// Used by the MLRIFT_CPU_BF16=1 path to drop the Q8_0 source pages
// after each tensor's bf16 dequant, dropping peak RSS by ~1.2 GiB on
// Llama-3.2-1B (Q8_0 mmap stays "open" but its pages are evicted).
fn madv_dontneed(u64 addr, u64 length) {
    u64 page  = 4096
    u64 mask  = 0 - page                             // round-down mask
    u64 start = (addr + page - 1) & mask              // round up to page
    u64 end   = (addr + length)   & mask              // round down to page
    if end <= start { return }
    u64 len = end - start
    syscall_raw(28, start, len, 4, 0, 0, 0)           // MADV_DONTNEED = 4
}

// Expand a row of bf16 into f32 (high-16-bits-of-f32 convention).  Used
// by the MLRIFT_CPU_BF16=1 embedding lookup when the tied lm_head has
// already been dequant'd to bf16 — saves a per-token Q8_0 decode pass
// and lets us drop the Q8_0 embed mmap region after the dequant phase.
fn bf16_row_to_f32(u64 dst_f32, u64 src_bf16, u64 n) {
    u64 i = 0
    while i < n {
        u16 b16 = 0
        unsafe { *((src_bf16 + i * 2) as u16) -> b16 }
        u64 b64 = b16
        u32 expanded = b64 << 16
        unsafe { *((dst_f32 + i * 4) as u32) = expanded }
        i = i + 1
    }
}

// Q8_0 → bf16 dequantizer (copied from llama3_1b_gpu_generate.mlr).
// Each Q8_0 block: 2-byte f16 scale + 32 int8 quants. Output is bf16
// (high 16 bits of f32 representation). Used by the destroy-PyTorch CPU
// slice (MLRIFT_CPU_BF16=1) to feed MLRift's AVX2 bf16-matmul path.
fn q8_0_to_bf16_alloc(u64 src_q8, u64 n_elements) -> u64 {
    u64 dst_bf16 = alloc(n_elements * 2)
    u64 n_blocks = n_elements / 32
    u64 scratch = alloc(4)
    u64 bi = 0
    while bi < n_blocks {
        u64 block = src_q8 + bi * 34
        u64 lo = load8(block)
        u64 hi = load8(block + 1)
        u64 dbits = lo | (hi << 8)
        f32 d = gguf_f16_to_f32_exact(dbits)
        u64 qs_base = block + 2
        u64 j = 0
        while j < 32 {
            u64 bval = load8(qs_base + j)
            f32 q = 0.0f
            if bval >= 128 {
                f32 pos = int_to_f32_gguf(256 - bval)
                q = 0.0f - pos
            } else {
                q = int_to_f32_gguf(bval)
            }
            f32 out_val = d * q
            unsafe { *(scratch as f32) = out_val }
            u64 b0 = load8(scratch + 2)
            u64 b1 = load8(scratch + 3)
            u64 dst_off = (bi * 32 + j) * 2
            u8 b0_8 = b0
            u8 b1_8 = b1
            unsafe { *((dst_bf16 + dst_off + 0) as u8) = b0_8 }
            unsafe { *((dst_bf16 + dst_off + 1) as u8) = b1_8 }
            j = j + 1
        }
        bi = bi + 1
    }
    dealloc(scratch)
    return dst_bf16
}

fn main() {
    u64 num_workers = 24
    thread_pool_init(num_workers)
    g_fd = file_open("/tmp/llama32_1b_gen.out", 1)

    // --- Reconfigure qwen3.mlr for Llama-3.2-1B ---
    // Destroy-PyTorch CPU slice (2026-05-12): MLRIFT_CPU_BF16=1 dequantises
    // every Q8_0 layer weight + the tied lm_head to bf16 at load and routes
    // matmul through MLRift's AVX2 bf16 path (used by Qwen3-0.6B CPU
    // baseline that runs at 28 tok/s). Cost: +~2 GiB RAM. Without the env,
    // legacy Q8_0×Q8_0 bit-exact path (matches llama.cpp).
    u64 cpu_bf16 = 0
    u64 ev_cpu_bf16 = getenv("MLRIFT_CPU_BF16")
    if ev_cpu_bf16 != 0 {
        u8 c0bf = 0; unsafe { *(ev_cpu_bf16 as u8) -> c0bf }
        if c0bf != 48 { cpu_bf16 = 1 }
    }

    qwen3_set_arch(2048, 64, 32, 8, 8192)   // hidden, head_dim, nh, nkv, ff
    if cpu_bf16 == 0 {
        qwen3_set_matmul_kind(1)            // Q8_0 (default, bit-exact w/ llama.cpp)
    } else {
        qwen3_set_matmul_kind(0)            // bf16 (destroy-PyTorch path)
    }
    qwen3_set_norm_kind(1)                  // F32 norms (Llama)
    qwen3_set_fuse_qkv(0)                   // no weight duplication
    qwen3_set_qknorm(0)                     // Llama: no per-head Q/K RMSNorm
    qwen3_set_rope_base(500000)             // Llama-3.x theta = 5e5
    qwen3_set_rmsnorm_eps_bits(0x3727C5AC)  // Llama: rms_norm_eps = 1e-5 (Qwen3 = 1e-6)
    qwen3_set_rope_pair_layout(1)           // Llama: rotate consecutive pairs (Qwen3 splits halves)
    qwen3_set_q8_bitexact(1)                // bit-exact Q8_0×Q8_0 path (matches llama.cpp); ignored when matmul_kind=0

    u64 path = resolve_model_path("MLRIFT_LLAMA3_1B_GGUF",
                                   "models/llama-3.2-1b-instruct-q8_0.gguf",
                                   "llama-3.2-1b")
    eout("[llama32_1b] loading weights from ")
    eout(path)
    eout("\n")
    u64 load_start_ns = time_now()
    GGUFFile gf = gguf_open(path)
    if gf.file_size == 0 {
        eout("open fail\n")
        thread_pool_shutdown(); file_close(g_fd); exit(1)
    }

    u64 hidden    = QWEN3_HIDDEN
    u64 kv_dim    = QWEN3_KV_DIM
    u64 n_layers  = 16
    u64 vocab     = 128256
    u64 max_seq   = 64        // tight; bench is short
    u64 max_new   = 20

    // ---- Get top-level tensors ----
    GGUFTensor embed_t = gguf_get(gf, "token_embd.weight")
    if embed_t.ptr == 0 {
        eout("missing token_embd.weight\n")
        gguf_free(gf); thread_pool_shutdown(); file_close(g_fd); exit(1)
    }
    GGUFTensor norm_t = gguf_get(gf, "output_norm.weight")
    if norm_t.ptr == 0 {
        eout("missing output_norm.weight\n")
        gguf_free(gf); thread_pool_shutdown(); file_close(g_fd); exit(1)
    }
    // Llama-3.2-1B has tie_word_embeddings=true, so the lm_head matmul
    // reuses token_embd.weight directly. matmul_q8_0_weights_f32 reads
    // a [N=vocab, K=hidden] Q8_0 row-blocked tensor; token_embd's shape
    // is exactly [hidden, vocab] in GGUF dim order, which matches our
    // expected [vocab, hidden] row-major layout (vocab as the outer dim
    // means each "row" is one token's hidden-dim embedding, exactly
    // what the lm_head matmul wants for c[v] = embed[v, :] @ x).
    u64 lmhead_ptr = embed_t.ptr

    // Llama-3.1+ ships rope_freqs.weight (head_dim/2 = 32 f32 entries)
    // for NTK-aware long-context inv_freq scaling. Wire it through; on
    // llama3.2-1b the values are [1×15, 1.65, 3.29, 9.67, 32×14] which
    // stretch the highest-frequency channels by 32× for the extended
    // 128k context. Without this, even pos=1 RoPE differs from
    // llama.cpp / Ollama and decoded tokens diverge after the first.
    GGUFTensor rope_freqs_t = gguf_get(gf, "rope_freqs.weight")
    if rope_freqs_t.ptr != 0 {
        qwen3_set_rope_freqs(rope_freqs_t.ptr)
        eout("[llama32_1b] rope_freqs.weight wired (NTK-scaled inv_freq)\n")
    }

    // Per-layer weight pointer table. 11 u64 pointers × 8 = 88 bytes
    // (matches Qwen3LayerWeights). Slots 4 (q_norm) and 5 (k_norm) stay
    // at 0 — Llama has no qknorm and qwen3_set_qknorm(0) gates the
    // forward path so the null pointers are never dereferenced.
    u64 layers_arr = alloc(n_layers * 88)
    u64 li = 0
    while li < n_layers {
        u64 base = layers_arr + li * 88
        u64 li_s = fmt_dec(li)
        u64 pre0 = str_cat("blk.", li_s)
        u64 prefix = str_cat(pre0, ".")
        dealloc(li_s); dealloc(pre0)

        u64 n01 = str_cat(prefix, "attn_norm.weight")
        GGUFTensor t01 = gguf_get(gf, n01)
        unsafe { *((base + 0 * 8) as u64) = t01.ptr }
        dealloc(n01)

        u64 n02 = str_cat(prefix, "attn_q.weight")
        GGUFTensor t02 = gguf_get(gf, n02)
        unsafe { *((base + 1 * 8) as u64) = t02.ptr }
        dealloc(n02)

        u64 n03 = str_cat(prefix, "attn_k.weight")
        GGUFTensor t03 = gguf_get(gf, n03)
        unsafe { *((base + 2 * 8) as u64) = t03.ptr }
        dealloc(n03)

        u64 n04 = str_cat(prefix, "attn_v.weight")
        GGUFTensor t04 = gguf_get(gf, n04)
        unsafe { *((base + 3 * 8) as u64) = t04.ptr }
        dealloc(n04)

        // Slots 4 (q_norm), 5 (k_norm) — leave at 0 for Llama.
        unsafe { *((base + 4 * 8) as u64) = 0 }
        unsafe { *((base + 5 * 8) as u64) = 0 }

        u64 n07 = str_cat(prefix, "attn_output.weight")
        GGUFTensor t07 = gguf_get(gf, n07)
        unsafe { *((base + 6 * 8) as u64) = t07.ptr }
        dealloc(n07)

        u64 n08 = str_cat(prefix, "ffn_norm.weight")
        GGUFTensor t08 = gguf_get(gf, n08)
        unsafe { *((base + 7 * 8) as u64) = t08.ptr }
        dealloc(n08)

        u64 n09 = str_cat(prefix, "ffn_gate.weight")
        GGUFTensor t09 = gguf_get(gf, n09)
        unsafe { *((base + 8 * 8) as u64) = t09.ptr }
        dealloc(n09)

        u64 n10 = str_cat(prefix, "ffn_up.weight")
        GGUFTensor t10 = gguf_get(gf, n10)
        unsafe { *((base + 9 * 8) as u64) = t10.ptr }
        dealloc(n10)

        u64 n11 = str_cat(prefix, "ffn_down.weight")
        GGUFTensor t11 = gguf_get(gf, n11)
        unsafe { *((base + 10 * 8) as u64) = t11.ptr }
        dealloc(n11)

        dealloc(prefix)
        li = li + 1
    }
    u64 load_elapsed_ns = time_elapsed(load_start_ns)
    eout("[llama32_1b] 16 layers indexed; load_ms=")
    eu64(load_elapsed_ns / 1000000); eout("\n")

    // ── Destroy-PyTorch CPU slice: Q8_0 → bf16 dequant for layer + lm_head ──
    // When MLRIFT_CPU_BF16=1, dequantise every Q8_0 weight to bf16 once
    // and overwrite the layer-struct slots. lm_head (tied embedding) is
    // dequantised separately and stored in lmhead_bf16_ptr.
    u64 lmhead_bf16_ptr = 0
    if cpu_bf16 != 0 {
        eout("[llama32_1b] MLRIFT_CPU_BF16=1: dequantising layer weights Q8_0 → bf16...\n")
        u64 q_dim_l    = QWEN3_Q_DIM
        u64 ff_l       = QWEN3_INTERMEDIATE
        u64 q_elems    = q_dim_l * hidden
        u64 kv_elems   = kv_dim  * hidden
        u64 o_elems    = hidden  * q_dim_l
        u64 gate_elems = ff_l    * hidden
        u64 up_elems   = ff_l    * hidden
        u64 down_elems = hidden  * ff_l
        // Q8_0 block-byte sizes for the madvise step.  Q8_0: 34 B / 32 elems.
        u64 q_q8_bytes    = (q_elems    / 32) * 34
        u64 kv_q8_bytes   = (kv_elems   / 32) * 34
        u64 o_q8_bytes    = (o_elems    / 32) * 34
        u64 gate_q8_bytes = (gate_elems / 32) * 34
        u64 up_q8_bytes   = (up_elems   / 32) * 34
        u64 down_q8_bytes = (down_elems / 32) * 34
        u64 deq_start = time_now()
        // Dequant lm_head FIRST so the embed Q8_0 region can be released
        // before the layer bf16 buffers start filling the heap — keeps peak
        // RSS bounded by (lmhead_bf16 + sum_of_layer_bf16) instead of also
        // including the 279 MB embed Q8_0 source.  Saves ~150 MB peak on
        // Llama-3.2-1B vs the natural layer-then-lmhead order.
        eout("[llama32_1b] dequantising tied lm_head Q8_0 → bf16 ("); eu64(vocab * hidden * 2); eout(" bytes)...\n")
        lmhead_bf16_ptr = q8_0_to_bf16_alloc(embed_t.ptr, vocab * hidden)
        u64 embed_q8_bytes = (vocab * hidden / 32) * 34
        madv_dontneed(embed_t.ptr, embed_q8_bytes)
        u64 lf = 0
        while lf < n_layers {
            u64 base = layers_arr + lf * 88
            u64 qp = 0; unsafe { *((base + 1 * 8) as u64) -> qp }
            u64 kp = 0; unsafe { *((base + 2 * 8) as u64) -> kp }
            u64 vp = 0; unsafe { *((base + 3 * 8) as u64) -> vp }
            u64 op = 0; unsafe { *((base + 6 * 8) as u64) -> op }
            u64 gp = 0; unsafe { *((base + 8 * 8) as u64) -> gp }
            u64 up = 0; unsafe { *((base + 9 * 8) as u64) -> up }
            u64 dp = 0; unsafe { *((base + 10 * 8) as u64) -> dp }
            unsafe { *((base + 1 * 8) as u64) = q8_0_to_bf16_alloc(qp, q_elems) }
            madv_dontneed(qp, q_q8_bytes)
            unsafe { *((base + 2 * 8) as u64) = q8_0_to_bf16_alloc(kp, kv_elems) }
            madv_dontneed(kp, kv_q8_bytes)
            unsafe { *((base + 3 * 8) as u64) = q8_0_to_bf16_alloc(vp, kv_elems) }
            madv_dontneed(vp, kv_q8_bytes)
            unsafe { *((base + 6 * 8) as u64) = q8_0_to_bf16_alloc(op, o_elems) }
            madv_dontneed(op, o_q8_bytes)
            unsafe { *((base + 8 * 8) as u64) = q8_0_to_bf16_alloc(gp, gate_elems) }
            madv_dontneed(gp, gate_q8_bytes)
            unsafe { *((base + 9 * 8) as u64) = q8_0_to_bf16_alloc(up, up_elems) }
            madv_dontneed(up, up_q8_bytes)
            unsafe { *((base + 10 * 8) as u64) = q8_0_to_bf16_alloc(dp, down_elems) }
            madv_dontneed(dp, down_q8_bytes)
            lf = lf + 1
        }
        u64 deq_ms = time_elapsed(deq_start) / 1000000
        eout("[llama32_1b] dequant_ms="); eu64(deq_ms); eout(" (Q8_0 source pages released via MADV_DONTNEED)\n")
    }

    // ---- KV cache + scratch buffers ----
    u64 kv_row_bytes = kv_dim * 4
    u64 layer_stride = max_seq * kv_row_bytes
    u64 total_cache  = n_layers * layer_stride
    u64 k_cache = alloc(total_cache)
    u64 v_cache = alloc(total_cache)
    eout("[llama32_1b] KV cache allocated (")
    eu64(total_cache * 2); eout(" bytes)\n")

    u64 x_cur     = alloc(hidden * 4)
    u64 x_nxt     = alloc(hidden * 4)
    u64 final_out = alloc(hidden * 4)
    u64 logits    = alloc(vocab * 4)

    // Per-row Q8_0 decode geometry for the embedding lookup.
    u64 embed_base = embed_t.ptr
    u64 row_blocks = hidden / 32
    u64 row_bytes  = row_blocks * 34
    eout("[llama32_1b] embed row decoded on demand ("); eu64(row_bytes); eout(" B/row)\n")

    // ---- Hardcoded prompt (no tokenizer integration this slice) ----
    // Llama-3 chat models implicitly prepend BOS=128000 to plain text
    // (Ollama's raw=true mode does this too — `prompt_eval_count: 2` for
    // a 1-character prompt confirms it). Feed [BOS, hello] so our pos-0
    // K/V matches the reference exactly. 15339 = "hello".
    u64 prompt_count = 2
    u64 seq_cap = prompt_count + max_new
    u64 seq_ids32 = alloc(seq_cap * 4)
    u32 t0 = 128000   // BOS
    u32 t1 = 15339    // "hello"
    unsafe { *((seq_ids32 + 0 * 4) as uint32) = t0 }
    unsafe { *((seq_ids32 + 1 * 4) as uint32) = t1 }
    u64 seq_len = prompt_count

    eout("[llama32_1b] prompt_tokens="); eu64(prompt_count); eout(" ids=[128000, 15339] (\"<|begin_of_text|>hello\")\n")

    // ---- Prompt prefill: every prompt token except the last needs the
    // layer stack run over it so its K/V is cached. The LAST prompt
    // token's forward pass produces the first generation logits, so we
    // fold that into the decode loop (step 0). ----
    u64 pos = 0
    u64 prefill_start_ns = time_now()
    while pos + 1 < prompt_count {
        u32 pt32 = 0
        unsafe { *((seq_ids32 + pos * 4) as uint32) -> pt32 }
        u64 pt = pt32
        if cpu_bf16 != 0 {
            bf16_row_to_f32(x_cur, lmhead_bf16_ptr + pt * hidden * 2, hidden)
        } else {
            gguf_deq_q8_0(x_cur, embed_base + pt * row_bytes, hidden)
        }
        u64 layer = 0
        while layer < n_layers {
            Qwen3LayerWeights w = layers_arr + layer * 88
            u64 kc = k_cache + layer * layer_stride
            u64 vc = v_cache + layer * layer_stride
            qwen3_forward_layer(x_nxt, x_cur, w, pos, kc, vc, num_workers)
            u64 tmp = x_cur
            x_cur = x_nxt
            x_nxt = tmp
            layer = layer + 1
        }
        pos = pos + 1
    }
    u64 prefill_ns = time_elapsed(prefill_start_ns)
    eout("[llama32_1b] prefill_ms="); eu64(prefill_ns / 1000000); eout("\n")

    // Load the last prompt token's embedding — the decode loop will run
    // its forward pass as step 0 and argmax the result.
    u32 last_pt32 = 0
    unsafe { *((seq_ids32 + (prompt_count - 1) * 4) as uint32) -> last_pt32 }
    u64 last_pt = last_pt32
    if cpu_bf16 != 0 {
        bf16_row_to_f32(x_cur, lmhead_bf16_ptr + last_pt * hidden * 2, hidden)
    } else {
        gguf_deq_q8_0(x_cur, embed_base + last_pt * row_bytes, hidden)
    }

    qwen3_profile_reset()
    u64 step = 0
    u64 decode_start_ns = time_now()
    while step < max_new {
        u64 step_start_ns = time_now()
        eout("step "); eu64(step); eout(" pos="); eu64(pos); eout("\n")

        u64 layer = 0
        while layer < n_layers {
            Qwen3LayerWeights w = layers_arr + layer * 88
            u64 kc = k_cache + layer * layer_stride
            u64 vc = v_cache + layer * layer_stride
            qwen3_forward_layer(x_nxt, x_cur, w, pos, kc, vc, num_workers)
            u64 tmp = x_cur
            x_cur = x_nxt
            x_nxt = tmp
            layer = layer + 1
        }

        // Final F32 RMSNorm + lm_head against the tied embedding matrix.
        qwen3_rmsnorm_f32_weights(final_out, x_cur, norm_t.ptr, hidden)
        if cpu_bf16 != 0 {
            matmul_bf16_weights_f32(logits, final_out, lmhead_bf16_ptr, 1, vocab, hidden, num_workers, 0)
        } else {
            matmul_q8_0_q8_0_f32(logits, final_out, lmhead_ptr, 1, vocab, hidden, num_workers)
        }

        // Greedy argmax.
        u64 best_id = 0
        f32 best_val = 0.0f
        u64 first = 1
        u64 j = 0
        while j < vocab {
            f32 v = 0.0f
            unsafe { *((logits + j * 4) as f32) -> v }
            if first == 1 {
                best_val = v; best_id = j; first = 0
            } else {
                if v > best_val { best_val = v; best_id = j }
            }
            j = j + 1
        }
        u64 step_elapsed_ns = time_elapsed(step_start_ns)
        eout("  -> next_id = "); eu64(best_id); eout(" logit=")
        u64 lvs = fmt_f32(best_val, 4); eout(lvs); dealloc(lvs)
        eout(" step_ms="); eu64(step_elapsed_ns / 1000000); eout("\n")

        u32 best_id32 = best_id
        unsafe { *((seq_ids32 + seq_len * 4) as uint32) = best_id32 }
        seq_len = seq_len + 1

        if cpu_bf16 != 0 {
            bf16_row_to_f32(x_cur, lmhead_bf16_ptr + best_id * hidden * 2, hidden)
        } else {
            gguf_deq_q8_0(x_cur, embed_base + best_id * row_bytes, hidden)
        }
        pos = pos + 1
        step = step + 1
    }
    u64 total_decode_ns = time_elapsed(decode_start_ns)
    u64 total_ms = total_decode_ns / 1000000
    u64 tokps_milli = 0
    if total_decode_ns != 0 {
        tokps_milli = (max_new * 1000 * 1000000000) / total_decode_ns
    }

    eout("\n=== GENERATED IDs ===\n")
    u64 gi = 0
    while gi < seq_len {
        if gi != 0 { eout(", ") }
        u32 gid32 = 0
        unsafe { *((seq_ids32 + gi * 4) as uint32) -> gid32 }
        u64 gid = gid32
        eu64(gid)
        gi = gi + 1
    }
    eout("\n")

    eout("\n=== TIMING ===\n")
    eout("prompt_tokens="); eu64(prompt_count); eout("\n")
    eout("prefill_ms="); eu64(prefill_ns / 1000000); eout("\n")
    eout("total_decode_ms="); eu64(total_ms); eout("\n")
    eout("tokens_per_sec_x1000="); eu64(tokps_milli); eout("\n")
    eout("tokens_generated="); eu64(max_new); eout("\n")
    qwen3_profile_dump()

    dealloc(x_cur); dealloc(x_nxt); dealloc(final_out); dealloc(logits)
    dealloc(seq_ids32); dealloc(layers_arr)
    dealloc(k_cache); dealloc(v_cache)
    gguf_free(gf)
    thread_pool_shutdown()
    file_close(g_fd)
    exit(0)
}
