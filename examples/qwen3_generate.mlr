// Qwen3 Phase 3 — KV-cache autoregressive greedy decode on Qwen3-0.6B.
//
// Seeds with token 14990 "hello" at position 0, then runs a greedy decode
// loop. Each iteration:
//   1. Run all 28 transformer layers at the current position (each layer
//      writes this step's K and V into its cache slot).
//   2. Final RMSNorm + lm_head (matmul vs embed_tokens.weight, tie=true).
//   3. Argmax over the 151 936-vocab logits — that's the next token.
//   4. Embed the new token into x_cur and increment pos.
//
// Stops after MAX_NEW tokens (no EOS check — base model rarely emits EOS
// anyway). Prints the full sequence of token ids.
//
// PyTorch greedy reference (do_sample=False, max_new_tokens=20):
//   [14990, 14582, 284, 330, 9707, 11, 4337, 17199, 1350, 3203,
//    4791, 14582, 692, 2, 1173, 279, 1156, 3409, 198, 1350, 3203]

import "../std/qwen3.mlr"
import "../std/safetensors.mlr"
import "../std/inference.mlr"
import "../std/io.mlr"
import "../std/fmt.mlr"
import "../std/string.mlr"
import "../std/thread.mlr"
import "../std/time.mlr"
import "../std/model_path.mlr"

static u64 g_fd = 0
fn eout(u64 s) {
    print_str(s)
    if g_fd != 0 {
        u64 n = str_len(s)
        file_write(g_fd, s, n)
    }
}
fn eu64(u64 v) {
    u64 s = fmt_dec(v)
    eout(s)
    dealloc(s)
}

// Multi-shard wrapper.  Single-file mode (mode=0): only `st_single`
// is populated.  Sharded mode (mode=1): `st_shard` is populated and
// st_single is unused.  All weight lookups go through wt_get().
static u64 _wt_mode      = 0
static u64 _wt_st_single = 0          // SafetensorFile (heap struct ptr)
static u64 _wt_sh        = 0          // SafetensorShard (heap struct ptr)

fn wt_get(u64 name) -> SafetensorView {
    if _wt_mode == 1 {
        SafetensorShard sh = _wt_sh
        return safetensors_shard_get(sh, name)
    } else {
        SafetensorFile st = _wt_st_single
        return safetensors_get(st, name)
    }
}

fn main() {
    u64 num_workers = 16
    thread_pool_init(num_workers)
    g_fd = file_open("/tmp/qw3_gen.out", 1)

    // Model selection.  MLRIFT_QWEN3_MODEL=14b switches to Qwen3-14B
    // (8 shards, hidden=5120, ff=17408, n_layers=40, n_heads=40, kv=8).
    // Default is the single-file Qwen3-0.6B at the hardcoded path.
    u64 model_14b = 0
    u64 ev_model = getenv("MLRIFT_QWEN3_MODEL")
    if ev_model != 0 {
        u8 ec = 0; unsafe { *(ev_model as u8) -> ec }
        // Match "1" prefix (covers "14b" / "1.4b" / etc).
        if ec == 49 { model_14b = 1 }
    }

    u64 hidden = 0
    u64 kv_dim = 0
    u64 q_dim  = 0
    u64 ff     = 0
    u64 n_layers = 0
    u64 vocab = 151936
    u64 max_seq = 128
    u64 max_new = 20
    u64 ev_mn = getenv("MLRIFT_QWEN3_MAX_NEW")
    if ev_mn != 0 {
        u64 parsed = 0; u64 mi = 0
        u8 mc = 0; unsafe { *(ev_mn as u8) -> mc }
        while mc >= 48 && mc <= 57 {
            parsed = parsed * 10 + (mc - 48); mi = mi + 1
            unsafe { *((ev_mn + mi) as u8) -> mc }
        }
        if parsed > 0 { max_new = parsed }
    }

    u64 load_start_ns = time_now()
    if model_14b != 0 {
        // 14B arch.  Hidden=5120, head_dim=128, n_heads=40, n_kv_heads=8,
        // ff=17408, num_layers=40.
        qwen3_set_arch(5120, 128, 40, 8, 17408)
        u64 dir14 = resolve_model_path("MLRIFT_QWEN3_14B_DIR",
                                       "models/qwen3-14b",
                                       "qwen3-14b")
        eout("[qwen3_generate] loading weights from ")
        eout(dir14)
        eout("\n")
        SafetensorShard sh = safetensors_shard_open(dir14, 8)
        if sh.n_shards != 8 {
            eout("14B shard open fail\n")
            thread_pool_shutdown(); file_close(g_fd); exit(1)
        }
        _wt_sh = sh
        _wt_mode = 1
        n_layers = 40
        eout("[qwen3_generate] Qwen3-14B mode (8 shards)\n")
    } else {
        u64 path = resolve_model_path("MLRIFT_QWEN3_0_6B_DIR",
                                       "models/qwen3-0.6b/model.safetensors",
                                       "qwen3-0.6b")
        eout("[qwen3_generate] loading weights from ")
        eout(path)
        eout("\n")
        SafetensorFile st = safetensors_open(path)
        if st.file_size == 0 {
            eout("open fail\n")
            thread_pool_shutdown(); file_close(g_fd); exit(1)
        }
        _wt_st_single = st
        _wt_mode = 0
        n_layers = 28
    }

    hidden = QWEN3_HIDDEN
    kv_dim = QWEN3_KV_DIM
    q_dim  = QWEN3_Q_DIM
    ff     = QWEN3_INTERMEDIATE

    SafetensorView embed_v = wt_get("model.embed_tokens.weight")
    u64 embed_ptr = embed_v.ptr
    SafetensorView norm_v = wt_get("model.norm.weight")
    u64 norm_ptr = norm_v.ptr
    if embed_ptr == 0 || norm_ptr == 0 {
        eout("missing embed or final norm\n")
        thread_pool_shutdown(); file_close(g_fd); exit(1)
    }

    // Per-layer weight pointer table (see qwen3_forward.mlr for field layout).
    // 11 u64 pointers × 8 bytes = 88 bytes per layer.
    u64 layers_arr = alloc(n_layers * 88)
    u64 li = 0
    while li < n_layers {
        u64 base = layers_arr + li * 88
        u64 li_s = fmt_dec(li)
        u64 pre0 = str_cat("model.layers.", li_s)
        u64 prefix = str_cat(pre0, ".")
        dealloc(li_s); dealloc(pre0)

        u64 n01 = str_cat(prefix, "input_layernorm.weight")
        SafetensorView v01 = wt_get(n01)
        unsafe { *((base + 0 * 8) as u64) = v01.ptr }
        dealloc(n01)

        u64 n02 = str_cat(prefix, "self_attn.q_proj.weight")
        SafetensorView v02 = wt_get(n02)
        unsafe { *((base + 1 * 8) as u64) = v02.ptr }
        dealloc(n02)

        u64 n03 = str_cat(prefix, "self_attn.k_proj.weight")
        SafetensorView v03 = wt_get(n03)
        unsafe { *((base + 2 * 8) as u64) = v03.ptr }
        dealloc(n03)

        u64 n04 = str_cat(prefix, "self_attn.v_proj.weight")
        SafetensorView v04 = wt_get(n04)
        unsafe { *((base + 3 * 8) as u64) = v04.ptr }
        dealloc(n04)

        u64 n05 = str_cat(prefix, "self_attn.q_norm.weight")
        SafetensorView v05 = wt_get(n05)
        unsafe { *((base + 4 * 8) as u64) = v05.ptr }
        dealloc(n05)

        u64 n06 = str_cat(prefix, "self_attn.k_norm.weight")
        SafetensorView v06 = wt_get(n06)
        unsafe { *((base + 5 * 8) as u64) = v06.ptr }
        dealloc(n06)

        u64 n07 = str_cat(prefix, "self_attn.o_proj.weight")
        SafetensorView v07 = wt_get(n07)
        unsafe { *((base + 6 * 8) as u64) = v07.ptr }
        dealloc(n07)

        u64 n08 = str_cat(prefix, "post_attention_layernorm.weight")
        SafetensorView v08 = wt_get(n08)
        unsafe { *((base + 7 * 8) as u64) = v08.ptr }
        dealloc(n08)

        u64 n09 = str_cat(prefix, "mlp.gate_proj.weight")
        SafetensorView v09 = wt_get(n09)
        unsafe { *((base + 8 * 8) as u64) = v09.ptr }
        dealloc(n09)

        u64 n10 = str_cat(prefix, "mlp.up_proj.weight")
        SafetensorView v10 = wt_get(n10)
        unsafe { *((base + 9 * 8) as u64) = v10.ptr }
        dealloc(n10)

        u64 n11 = str_cat(prefix, "mlp.down_proj.weight")
        SafetensorView v11 = wt_get(n11)
        unsafe { *((base + 10 * 8) as u64) = v11.ptr }
        dealloc(n11)

        dealloc(prefix)
        li = li + 1
    }

    // Fuse Q / K / V weights into a single stacked [q_dim + 2*kv_dim,
    // hidden] bf16 matrix per layer. qwen3_forward_layer then does 1
    // matmul instead of 3. Stacked ptr overwrites the q_proj_w slot
    // (1*8) in Qwen3LayerWeights; k_proj_w / v_proj_w (2, 3) unused.
    // Also fuse gate_proj + up_proj into [2*ff, hidden]; stacked ptr
    // lands in the gate_proj_w slot (8*8), up_proj_w (9*8) unused.
    u64 qkv_dim_elems = QWEN3_Q_DIM + 2 * QWEN3_KV_DIM
    u64 qkv_row_bytes = QWEN3_HIDDEN * 2
    u64 q_bytes       = QWEN3_Q_DIM  * qkv_row_bytes
    u64 kv_bytes      = QWEN3_KV_DIM * qkv_row_bytes
    u64 stacked_bytes = qkv_dim_elems * qkv_row_bytes
    u64 gu_dim_elems  = 2 * QWEN3_INTERMEDIATE
    u64 gu_row_bytes  = QWEN3_HIDDEN * 2
    u64 gate_bytes    = QWEN3_INTERMEDIATE * gu_row_bytes
    u64 gu_stacked_bytes = gu_dim_elems * gu_row_bytes
    // Fusion materialises ~3 GB of bf16 page-ins on Qwen3-0.6B (worse on
    // 14B: ~17 GB of pages touched).  At 14B with 30 GB host RAM this
    // triggers swap thrashing.  Skip when MLRIFT_QWEN3_NO_FUSE=1 — caller
    // accepts the slower 3-matmul path for QKV / 2-matmul for gate_up.
    u64 no_fuse = 0
    u64 ev_nf = getenv("MLRIFT_QWEN3_NO_FUSE")
    if ev_nf != 0 {
        u8 nfc = 0; unsafe { *(ev_nf as u8) -> nfc }
        if nfc != 48 { no_fuse = 1 }
    }
    if no_fuse == 0 {
        eout("[qwen3_generate] fusing QKV + gate/up weights (")
        eu64((stacked_bytes + gu_stacked_bytes) * n_layers); eout(" bytes total)\n")
        li = 0
        while li < n_layers {
            u64 base  = layers_arr + li * 88
            u64 qp = 0; unsafe { *((base + 1 * 8) as u64) -> qp }
            u64 kp = 0; unsafe { *((base + 2 * 8) as u64) -> kp }
            u64 vp = 0; unsafe { *((base + 3 * 8) as u64) -> vp }
            u64 stacked = alloc(stacked_bytes)
            memcpy(stacked,               qp, q_bytes)
            memcpy(stacked + q_bytes,     kp, kv_bytes)
            memcpy(stacked + q_bytes + kv_bytes, vp, kv_bytes)
            unsafe { *((base + 1 * 8) as u64) = stacked }

            u64 gpw = 0; unsafe { *((base + 8 * 8) as u64) -> gpw }
            u64 upw = 0; unsafe { *((base + 9 * 8) as u64) -> upw }
            u64 gu_stacked = alloc(gu_stacked_bytes)
            memcpy(gu_stacked,              gpw, gate_bytes)
            memcpy(gu_stacked + gate_bytes, upw, gate_bytes)
            unsafe { *((base + 8 * 8) as u64) = gu_stacked }
            li = li + 1
        }
    } else {
        eout("[qwen3_generate] QKV/gate_up fusion SKIPPED (MLRIFT_QWEN3_NO_FUSE=1)\n")
        // Tell qwen3_forward_layer to take the 3-matmul / 2-matmul path
        // instead of expecting pre-stacked weights at the q_proj/gate_proj
        // slots.
        qwen3_set_fuse_qkv(0)
    }
    u64 load_elapsed_ns = time_elapsed(load_start_ns)
    eout("[qwen3_generate] "); eu64(n_layers); eout(" layers indexed; load_ms=")
    eu64(load_elapsed_ns / 1000000); eout("\n")

    // MLRIFT_QWEN3_LOAD_ONLY=1: exit immediately after layer indexing.
    // Used for validating the multi-shard loader on huge models without
    // running a full forward pass (which would need GB of further
    // working memory).
    u64 ev_lo = getenv("MLRIFT_QWEN3_LOAD_ONLY")
    if ev_lo != 0 {
        u8 loc = 0; unsafe { *(ev_lo as u8) -> loc }
        if loc != 48 {
            eout("[qwen3_generate] LOAD_ONLY exit\n")
            thread_pool_shutdown(); file_close(g_fd); exit(0)
        }
    }

    // Detect MLRIFT_GPU_FULL_FORWARD early so we know whether to put
    // the kv_cache in GTT (needed for the fused-attention kernel that
    // reads K/V via device VA).
    u64 want_gpu_full = 0
    u64 ev_full_early = getenv("MLRIFT_GPU_FULL_FORWARD")
    if ev_full_early != 0 {
        u8 cf_e = 0; unsafe { *(ev_full_early as u8) -> cf_e }
        if cf_e != 48 { want_gpu_full = 1 }
    }

    // KV cache — 4D slab [batch, layer, max_seq, n_kv_heads, head_dim].
    //   bytes per (batch, layer): max_seq * kv_dim * 4 = max_seq * 4096
    //   layout is layer-major: addr = layer*batch*layer_stride + batch_idx*layer_stride
    //   Phase 1 starts with batch_size = 1 (env-overridable later); the
    //   layout is bit-identical to the prior 3D form when batch=1.
    u64 batch_size     = 1
    u64 ev_batch       = getenv("MLRIFT_BATCH")
    if ev_batch != 0 {
        u64 ofs = 0
        while ofs < 4 {
            u8 cb = 0; unsafe { *((ev_batch + ofs) as u8) -> cb }
            if cb == 0 { break }
            if cb >= 48 && cb <= 57 {
                if ofs == 0 { batch_size = cb - 48 }
                else        { batch_size = batch_size * 10 + (cb - 48) }
            }
            ofs = ofs + 1
        }
        if batch_size == 0 { batch_size = 1 }
    }
    // Phase 2 Slice 2.0+ spec_K: speculative decoding.  Parse here (before
    // GPU buffer sizing) so M_eff = max(batch_size, spec_K) drives all
    // downstream sizing.  Only spec_K = 4 + batch_size = 1 is supported.
    u64 spec_K = 1
    u64 ev_speck = getenv("MLRIFT_SPEC_K")
    if ev_speck != 0 {
        u64 sk_ofs = 0
        while sk_ofs < 4 {
            u8 sk_c = 0; unsafe { *((ev_speck + sk_ofs) as u8) -> sk_c }
            if sk_c == 0 { break }
            if sk_c >= 48 { if sk_c <= 57 {
                if sk_ofs == 0 { spec_K = sk_c - 48 }
                else           { spec_K = spec_K * 10 + (sk_c - 48) }
            } }
            sk_ofs = sk_ofs + 1
        }
        if spec_K == 0 { spec_K = 1 }
    }
    if spec_K > 1 {
        if batch_size != 1 {
            eout("[qwen3_generate] spec_K > 1 requires batch_size = 1; got batch_size=")
            eu64(batch_size); eout("\n"); exit(1)
        }
        if spec_K != 4 && spec_K != 8 && spec_K != 16 {
            eout("[qwen3_generate] spec_K = "); eu64(spec_K)
            eout(" — only spec_K=4, 8, or 16 supported (attn kernel grid hardcoded)\n"); exit(1)
        }
    }
    u64 M_eff = batch_size
    if spec_K > 1 { M_eff = spec_K }
    u64 is_spec = 0
    if spec_K > 1 { is_spec = 1 }
    if is_spec != 0 {
        eout("[qwen3_generate] MLRIFT_SPEC_K="); eu64(spec_K)
        eout(" — speculative chain dispatch (M_eff="); eu64(M_eff); eout(")\n")
    }
    u64 kv_row_bytes   = kv_dim * 4
    u64 layer_stride   = max_seq * kv_row_bytes
    u64 batch_stride   = batch_size * layer_stride
    u64 total_cache    = n_layers * batch_stride
    u64 k_cache = 0
    u64 v_cache = 0
    u64 k_cache_dev = 0
    u64 v_cache_dev = 0
    if want_gpu_full != 0 {
        // Trigger HIP-shim lazy init first via a dummy hipMalloc, then
        // force GTT (system RAM mapped to GPU) for the kv_cache —
        // hipMalloc itself prefers VRAM-host-vis which gives the CPU
        // 0.8 MB/s BAR1 reads (catastrophic when the CPU attention
        // path reads K/V every step).  GTT gives full DRAM speed for
        // CPU reads while still being addressable by GPU kernels.
        u64 dummy_slot = alloc(8)
        u32 de = hipMalloc(dummy_slot, 64)
        if de == 0 {
            u64 dummy_va = 0
            unsafe { *(dummy_slot as u64) -> dummy_va }
            hipFree(dummy_va)   // immediately release; just needed init
            k_cache_dev = dev_try_alloc_host_visible(total_cache)
            v_cache_dev = dev_try_alloc_host_visible(total_cache)
            if k_cache_dev != 0 && v_cache_dev != 0 {
                k_cache = dev_host_ptr(k_cache_dev)
                v_cache = dev_host_ptr(v_cache_dev)
                qwen3_gpu_set_kv_cache_dev(k_cache_dev, v_cache_dev, layer_stride, batch_size)
                qwen3_gpu_set_batch_size(M_eff)
                eout("[qwen3_generate] KV cache allocated as GTT (")
                eu64(total_cache * 2); eout(" bytes total)\n")
            }
        }
    }
    if k_cache == 0 {
        k_cache = alloc(total_cache)
        v_cache = alloc(total_cache)
        eout("[qwen3_generate] KV cache allocated on host ("); eu64(total_cache * 2); eout(" bytes total)\n")
    }

    // Per-stream working buffers (Phase 1 batched-decode plumbing).
    // At batch_size = 1 this keeps the original single-stream layout
    // bit-identical; at batch_size > 1 each stream gets its own
    // hidden-vector buffers + token sequence + seed.
    u64 final_out = alloc(hidden * 4)
    u64 logits    = alloc(vocab * 4)

    // seq_cap must hold prompt prefill (up to 64 tokens) + max_new × spec_K
    // (slice 2.4 can write up to spec_K tokens per step).  Worst case at
    // spec_K=4: 64 + 20*4 = 144.  Use 256 for safety.
    u64 seq_cap = 256
    u64 x_cur_arr   = alloc(batch_size * 8)        // batch_size pointers
    u64 x_nxt_arr   = alloc(batch_size * 8)
    u64 seq_ids_arr = alloc(batch_size * 8)
    u64 tok_arr     = alloc(batch_size * 8)
    u64 seq_len     = 1

    // Same seed for all streams initially — verifies cross-batch
    // isolation by producing N copies of the canonical decode.
    u64 seed_tok = 14990
    eout("[qwen3_generate] batch_size="); eu64(batch_size); eout(" seed_tok="); eu64(seed_tok); eout("\n")
    u64 b_init = 0
    while b_init < batch_size {
        u64 xc_b   = alloc(hidden * 4)
        u64 xn_b   = alloc(hidden * 4)
        u64 sids_b = alloc(seq_cap * 8)
        unsafe { *((sids_b + 0 * 8) as u64) = seed_tok }
        u64 row_b = embed_ptr + seed_tok * hidden * 2
        u64 i0 = 0
        while i0 < hidden {
            f32 v = bf16_to_f32(row_b + i0 * 2)
            unsafe { *((xc_b + i0 * 4) as f32) = v }
            i0 = i0 + 1
        }
        unsafe { *((x_cur_arr   + b_init * 8) as u64) = xc_b }
        unsafe { *((x_nxt_arr   + b_init * 8) as u64) = xn_b }
        unsafe { *((seq_ids_arr + b_init * 8) as u64) = sids_b }
        unsafe { *((tok_arr     + b_init * 8) as u64) = seed_tok }
        b_init = b_init + 1
    }

    // Optional full-GPU forward path: keep the residual carry device-
    // resident throughout the 28-layer sweep, sync only at the layer-
    // half boundaries.  Gated by MLRIFT_GPU_FULL_FORWARD=1.  At
    // batch_size > 1 each stream gets its own ping-pong pair.
    u64 use_gpu_full = 0
    // Pointer arrays must hold M_eff entries (= K rows in spec mode), not
    // just batch_size — the use_gpu_full chain feeds these to batched
    // dispatch with M_eff lanes.  Pre-spec the arrays were sized
    // batch_size and the M_eff > batch_size loop in
    // qwen3_forward_layer_qkv_batched_gpu OOB-read garbage pointers and
    // hung the GPU at the first rmsnorm.
    u64 d_x_a_arr   = alloc(M_eff * 8)
    u64 d_x_b_arr   = alloc(M_eff * 8)
    u64 d_x_a_h_arr = alloc(M_eff * 8)
    u64 d_x_b_h_arr = alloc(M_eff * 8)
    // Slice 1.6: contiguous [batch, hidden] residual buffers (one A, one B
    // for ping-pong).  Per-stream pointers in d_x_a_arr / d_x_b_arr now
    // reference slots inside the single contiguous allocation, so the
    // 2 resid_adds per layer can fire as ONE batched dispatch each.
    u64 d_x_A = 0; u64 d_x_A_h = 0
    u64 d_x_B = 0; u64 d_x_B_h = 0
    u64 ev_full = getenv("MLRIFT_GPU_FULL_FORWARD")
    if ev_full != 0 {
        u8 cf = 0; unsafe { *(ev_full as u8) -> cf }
        if cf != 48 {
            // Force _gpu_mm_init_once via gpu_matmul_enabled() so
            // gpu_pipeline_ready() can return 1.  Without this, the
            // pipeline_ready check returns 0 at startup (no GPU op has
            // fired yet) and use_gpu_full stays dormant.
            uint64 _force_init = gpu_matmul_enabled()
            if gpu_pipeline_ready() == 1 {
                d_x_A = dev_try_alloc_host_visible(M_eff * hidden * 4)
                d_x_B = dev_try_alloc_host_visible(M_eff * hidden * 4)
                if d_x_A != 0 {
                    if d_x_B != 0 {
                        d_x_A_h = dev_host_ptr(d_x_A)
                        d_x_B_h = dev_host_ptr(d_x_B)
                        // Populate ALL M_eff slots (K rows in spec mode share
                        // batch_size==1 but live at consecutive offsets in
                        // the contiguous d_x_A allocation).
                        u64 b_dx = 0
                        while b_dx < M_eff {
                            u64 da = d_x_A + b_dx * hidden * 4
                            u64 db = d_x_B + b_dx * hidden * 4
                            unsafe { *((d_x_a_arr   + b_dx * 8) as u64) = da }
                            unsafe { *((d_x_b_arr   + b_dx * 8) as u64) = db }
                            unsafe { *((d_x_a_h_arr + b_dx * 8) as u64) = d_x_A_h + b_dx * hidden * 4 }
                            unsafe { *((d_x_b_h_arr + b_dx * 8) as u64) = d_x_B_h + b_dx * hidden * 4 }
                            b_dx = b_dx + 1
                        }
                        use_gpu_full = 1
                        eout("[qwen3_generate] full-GPU forward ENABLED for "); eu64(batch_size); eout(" stream(s) (contiguous residuals, M_eff="); eu64(M_eff); eout(")\n")
                    }
                }
            }
        }
    }

    // Slice 1.5: batched lm_head buffers (allocated when M_eff > 1, i.e.
    // batch_size > 1 OR spec_K > 1).
    u64 d_final_out_batched   = 0
    u64 d_final_out_batched_h = 0
    u64 d_logits_batched      = 0
    u64 d_logits_batched_h    = 0
    if M_eff > 1 {
        if gpu_pipeline_ready() == 1 {
            d_final_out_batched = dev_try_alloc_host_visible(M_eff * hidden * 4)
            d_logits_batched    = dev_try_alloc_host_visible(M_eff * vocab * 4)
            if d_final_out_batched != 0 {
                if d_logits_batched != 0 {
                    d_final_out_batched_h = dev_host_ptr(d_final_out_batched)
                    d_logits_batched_h    = dev_host_ptr(d_logits_batched)
                    eout("[qwen3_generate] batched lm_head buffers allocated\n")
                }
            }
        }
    }

    u64 pos = 0
    u64 step = 0
    u64 prompt_initial_len = 1   // bumped by prefill block below if MLRIFT_LONG_PROMPT
    u64 decode_start_ns = time_now()
    u64 sum_decode_ns = 0
    u64 sum_layer_ns  = 0
    u64 sum_norm_ns   = 0
    u64 sum_lmhead_ns = 0
    u64 sum_argmax_ns = 0
    u64 sum_embed_ns  = 0

    // ====================================================================
    // Optional prefill of a longer prompt to exercise PLD speculative
    // decoding.  Gated by MLRIFT_LONG_PROMPT=1 — when set, seq_ids[] is
    // pre-filled with a hardcoded 2-gram-repeating pattern (8 alternations
    // of [14990, 14582]) and pos / x_cur are advanced via N-1 CPU forward
    // passes that fill K-cache without sampling.  After prefill the main
    // decode loop runs as usual; PLD's last-2-gram lookup will hit on
    // every step.
    u64 ev_long = getenv("MLRIFT_LONG_PROMPT")
    if ev_long != 0 {
        u8 lc = 0; unsafe { *(ev_long as u8) -> lc }
        if lc != 48 {
            // MLRIFT_PLD_BENCH=1 swaps in a 16-token [14990,14582] repeating
            // bigram pattern for PLD speculative-decode benchmarking — every
            // last-2-gram lookup hits, exercising the mks-K paths at their
            // designed peak acceptance.  Default (unset) keeps the
            // human-readable "Hello, who are you?" prompt used by the CPU
            // driver agreement smoke.
            u64 ev_pld = getenv("MLRIFT_PLD_BENCH")
            u64 use_pld_pattern = 0
            if ev_pld != 0 {
                u8 pc = 0; unsafe { *(ev_pld as u8) -> pc }
                if pc != 48 { use_pld_pattern = 1 }
            }
            u64 prompt_len = 6
            if use_pld_pattern != 0 { prompt_len = 16 }
            u64 prompt_tokens = alloc(prompt_len * 8)
            if use_pld_pattern != 0 {
                u64 pi = 0
                while pi < prompt_len {
                    u64 tk = 14990
                    if (pi & 1) != 0 { tk = 14582 }
                    unsafe { *((prompt_tokens + pi * 8) as u64) = tk }
                    pi = pi + 1
                }
            } else {
                unsafe { *((prompt_tokens + 0 * 8) as u64) = 9707 }   // "Hello"
                unsafe { *((prompt_tokens + 1 * 8) as u64) =   11 }   // ","
                unsafe { *((prompt_tokens + 2 * 8) as u64) =  879 }   // " who"
                unsafe { *((prompt_tokens + 3 * 8) as u64) =  525 }   // " are"
                unsafe { *((prompt_tokens + 4 * 8) as u64) =  498 }   // " you"
                unsafe { *((prompt_tokens + 5 * 8) as u64) =   30 }   // "?"
            }
            // Overwrite seq_ids[0..prompt_len-1] with the pattern.
            u64 sids_p = 0; unsafe { *((seq_ids_arr + 0) as u64) -> sids_p }
            u64 si = 0
            while si < prompt_len {
                u64 tk = 0; unsafe { *((prompt_tokens + si * 8) as u64) -> tk }
                unsafe { *((sids_p + si * 8) as u64) = tk }
                si = si + 1
            }
            seq_len = prompt_len
            // Prefill K-cache via legacy CPU forward, N-1 passes (positions
            // 0..N-2).  After the loop, x_cur = embed(prompt[N-1]) so the
            // first decode step runs at pos = N-1, fills K[N-1], and
            // predicts seq_ids[N].
            u64 x_cur_p = 0; unsafe { *((x_cur_arr + 0) as u64) -> x_cur_p }
            u64 x_nxt_p = 0; unsafe { *((x_nxt_arr + 0) as u64) -> x_nxt_p }
            u64 pp = 0
            while pp < (prompt_len - 1) {
                u64 tk = 0; unsafe { *((prompt_tokens + pp * 8) as u64) -> tk }
                u64 row_p = embed_ptr + tk * hidden * 2
                u64 ii = 0
                while ii < hidden {
                    f32 v = bf16_to_f32(row_p + ii * 2)
                    unsafe { *((x_cur_p + ii * 4) as f32) = v }
                    ii = ii + 1
                }
                u64 layer = 0
                while layer < n_layers {
                    Qwen3LayerWeights w = layers_arr + layer * 88
                    u64 kc = k_cache + layer * batch_stride
                    u64 vc = v_cache + layer * batch_stride
                    qwen3_forward_layer(x_nxt_p, x_cur_p, w, pp, kc, vc, num_workers)
                    u64 tmp = x_cur_p; x_cur_p = x_nxt_p; x_nxt_p = tmp
                    layer = layer + 1
                }
                pp = pp + 1
            }
            // Restore x_cur to embedding of last prompt token (the
            // forward loop above leaves x_cur as L27 output of pp = N-2
            // pass, which we'd discard anyway in legacy decode).
            u64 last_p = 0; unsafe { *((prompt_tokens + (prompt_len - 1) * 8) as u64) -> last_p }
            u64 row_l = embed_ptr + last_p * hidden * 2
            u64 jj = 0
            while jj < hidden {
                f32 v = bf16_to_f32(row_l + jj * 2)
                unsafe { *((x_cur_p + jj * 4) as f32) = v }
                jj = jj + 1
            }
            unsafe { *((x_cur_arr + 0) as u64) = x_cur_p }
            unsafe { *((x_nxt_arr + 0) as u64) = x_nxt_p }
            pos = prompt_len - 1
            prompt_initial_len = prompt_len
            dealloc(prompt_tokens)
            eout("[qwen3_generate] MLRIFT_LONG_PROMPT prefilled "); eu64(prompt_len); eout(" tokens; pos="); eu64(pos); eout("\n")
        }
    }

    // (spec_K parsed above near batch_size; M_eff and is_spec already set.)

    // Slice 4.13: pre-decode warmup of the padded-row weight cache.  The
    // first time each layer hits the mega-kernel, gpu_get_or_upload_bf16_
    // weight_padded uploads ~3 MB of bf16 (one row-strided H2D per matmul);
    // 28 layers × 4 matmuls × ~3 MB ≈ 3 s cold-start that would otherwise
    // be charged against decode.  Walk every layer here (BEFORE the timer)
    // and trigger the uploads — subsequent calls hit the cache.
    u64 ev_megak_warmup = getenv("MLRIFT_QWEN3_MEGAKERNEL")
    u64 want_warmup = 0
    if ev_megak_warmup != 0 {
        u8 c0w = 0; unsafe { *(ev_megak_warmup as u8) -> c0w }
        if c0w != 48 { want_warmup = 1 }
    }
    if want_warmup != 0 {
        u64 ev_vt0 = getenv("MLRIFT_VRAM_TRACE")
        u64 want_vt0 = 0
        if ev_vt0 != 0 { u8 cv0 = 0; unsafe { *(ev_vt0 as u8) -> cv0 } if cv0 != 48 { want_vt0 = 1 } }
        if want_vt0 != 0 {
            u64 vmb_pre = gpu_buf_pool_total() / 1048576
            u64 nu_pre = gpu_mm_bf16_cache_total()
            u64 np_pre = gpu_mm_bf16_pad_cache_total()
            eout("[vram] pre-warmup buf_pool="); eu64(vmb_pre); eout(" MiB unpad_cache="); eu64(nu_pre); eout(" pad_cache="); eu64(np_pre); eout("\n")
        }

        u64 lyr = 0
        while lyr < n_layers {
            Qwen3LayerWeights w = layers_arr + lyr * 88
            u64 _wq = gpu_get_or_upload_bf16_weight_padded(w.q_proj_w,    hidden, q_dim + 2 * kv_dim, 1152)
            u64 _wo = gpu_get_or_upload_bf16_weight_padded(w.o_proj_w,    q_dim,  hidden,             2176)
            u64 _wg = gpu_get_or_upload_bf16_weight_padded(w.gate_proj_w, hidden, 2 * ff,             1152)
            u64 _wd = gpu_get_or_upload_bf16_weight_padded(w.down_proj_w, ff,     hidden,             3200)
            lyr = lyr + 1
        }
        eout("[qwen3_generate] padded-row weight cache warmed for "); eu64(n_layers); eout(" layers\n")

        if want_vt0 != 0 {
            u64 vmb_post = gpu_buf_pool_total() / 1048576
            u64 nu_post = gpu_mm_bf16_cache_total()
            u64 np_post = gpu_mm_bf16_pad_cache_total()
            eout("[vram] post-warmup buf_pool="); eu64(vmb_post); eout(" MiB unpad_cache="); eu64(nu_post); eout(" pad_cache="); eu64(np_post); eout("\n")
        }
    }

    // Slice 4.19 memory optimisation: when the mega-kernel path is the
    // active decode path, the unpadded bf16 weight cache (used by per-op
    // gemv_coop_bf16) is dead weight — the padded-row cache covers the
    // mega-kernel's needs and per-op fallback is rare in steady-state.
    // Free the unpadded cache after warmup to reclaim ~880 MiB of VRAM.
    // Opt-out via MLRIFT_KEEP_PEROP_CACHE=1 if you need the per-op
    // fallback during decode (e.g., shape that bypasses mega).
    u64 ev_keep = getenv("MLRIFT_KEEP_PEROP_CACHE")
    u64 keep_perop = 0
    if ev_keep != 0 {
        u8 c0k = 0; unsafe { *(ev_keep as u8) -> c0k }
        if c0k != 48 { keep_perop = 1 }
    }
    if want_warmup != 0 {
        if keep_perop == 0 {
            u64 dropped = gpu_mm_drop_bf16_cache()
            u64 dropped_f32 = gpu_mm_drop_f32_cache()
            eout("[qwen3_generate] dropped per-op bf16 cache ("); eu64(dropped); eout(" entries) + f32 dequant cache ("); eu64(dropped_f32); eout(" entries) to reclaim ~880 MiB\n")
        }
    }

    u64 ev_vt1 = getenv("MLRIFT_VRAM_TRACE")
    u64 want_vt1 = 0
    if ev_vt1 != 0 { u8 cv1 = 0; unsafe { *(ev_vt1 as u8) -> cv1 } if cv1 != 48 { want_vt1 = 1 } }
    if want_vt1 != 0 {
        u64 vmb_dec = gpu_buf_pool_total() / 1048576
        u64 nu_dec = gpu_mm_bf16_cache_total()
        u64 np_dec = gpu_mm_bf16_pad_cache_total()
        eout("[vram] pre-decode buf_pool="); eu64(vmb_dec); eout(" MiB unpad_cache="); eu64(nu_dec); eout(" pad_cache="); eu64(np_dec); eout("\n")
    }

    decode_start_ns = time_now()
    while step < max_new {
        u64 step_start_ns = time_now()
        u64 step_launch_start  = hipkfd_get_launch_count()
        u64 step_sync_start    = hipkfd_get_sync_count()
        u64 step_sync_ns_start = hipkfd_get_sync_total_ns()
        u64 step_sync_busy_start = hipkfd_get_sync_busy_calls()
        eout("step "); eu64(step); eout(" pos="); eu64(pos); eout("\n")

        // Slice 2.3: PLD draft proposal (computed once per step, used
        // both to fill input rows 1..K-1 and to verify after lmhead).
        u64 draft_arr = 0
        u64 K_minus_1 = 0
        if is_spec != 0 {
            K_minus_1 = M_eff - 1
            draft_arr = alloc(K_minus_1 * 8)
            u64 di = 0
            while di < K_minus_1 {
                unsafe { *((draft_arr + di * 8) as u64) = 0 }
                di = di + 1
            }
            u64 sids0 = 0; unsafe { *((seq_ids_arr + 0) as u64) -> sids0 }
            if seq_len >= 3 {
                u64 last_a = 0; unsafe { *((sids0 + (seq_len - 2) * 8) as u64) -> last_a }
                u64 last_b = 0; unsafe { *((sids0 + (seq_len - 1) * 8) as u64) -> last_b }
                u64 ii = 1
                u64 limit = seq_len - 1
                while ii < limit {
                    u64 a = 0; unsafe { *((sids0 + (ii - 1) * 8) as u64) -> a }
                    u64 b = 0; unsafe { *((sids0 + ii * 8) as u64) -> b }
                    if a == last_a {
                        if b == last_b {
                            u64 m = 0
                            while m < K_minus_1 {
                                u64 src = ii + 1 + m
                                u64 tk  = 0
                                if src < seq_len {
                                    unsafe { *((sids0 + src * 8) as u64) -> tk }
                                }
                                unsafe { *((draft_arr + m * 8) as u64) = tk }
                                m = m + 1
                            }
                            ii = limit
                        }
                    }
                    ii = ii + 1
                }
            }
        }

        u64 layer_start_ns = time_now()
        if use_gpu_full != 0 {
            // GPU path: per-stream H2D into d_x_a, layer-major outer loop
            // with ONE batched qkv matmul per layer for all M streams.
            u64 b_init = 0
            while b_init < batch_size {
                u64 xc_b   = 0; unsafe { *((x_cur_arr   + b_init * 8) as u64) -> xc_b }
                u64 dxah_b = 0; unsafe { *((d_x_a_h_arr + b_init * 8) as u64) -> dxah_b }
                memcpy(dxah_b, xc_b, hidden * 4)
                b_init = b_init + 1
            }
            // Fill rows 1..K-1 with embeddings of the step-scoped draft
            // tokens (computed via PLD at step start).
            if is_spec != 0 {
                u64 row0_dst = 0
                unsafe { *((d_x_a_h_arr + 0) as u64) -> row0_dst }
                u64 r = 1
                while r < M_eff {
                    u64 dtk = 0
                    unsafe { *((draft_arr + (r - 1) * 8) as u64) -> dtk }
                    u64 d_row = row0_dst + r * hidden * 4
                    u64 e_row = embed_ptr + dtk * hidden * 2
                    u64 ie = 0
                    while ie < hidden {
                        f32 ev = bf16_to_f32(e_row + ie * 2)
                        unsafe { *((d_row + ie * 4) as f32) = ev }
                        ie = ie + 1
                    }
                    r = r + 1
                }
            }
            // Per-row d_in/d_out pointer arrays (ping-pong across layers).
            // Sized M_eff so the batched-chain dispatch reads valid pointers
            // for every K row in spec mode.
            u64 d_in_arr   = alloc(M_eff * 8)
            u64 d_out_arr  = alloc(M_eff * 8)
            u64 d_in_h_arr = alloc(M_eff * 8)
            u64 b_set = 0
            while b_set < M_eff {
                u64 da   = 0; unsafe { *((d_x_a_arr   + b_set * 8) as u64) -> da }
                u64 db   = 0; unsafe { *((d_x_b_arr   + b_set * 8) as u64) -> db }
                u64 dah  = 0; unsafe { *((d_x_a_h_arr + b_set * 8) as u64) -> dah }
                unsafe { *((d_in_arr   + b_set * 8) as u64) = da }
                unsafe { *((d_out_arr  + b_set * 8) as u64) = db }
                unsafe { *((d_in_h_arr + b_set * 8) as u64) = dah }
                b_set = b_set + 1
            }

            u64 layer = 0
            // Slice 4.14 — speck4 mega-kernel: at spec_K=4 + env, replaces
            // the entire per-op M_eff=4 chain with a single kernel dispatch
            // per layer.  Falls through to per-op when env unset / kernel
            // missing / shape unsupported.
            u64 use_mks4 = 0
            if is_spec != 0 {
                if M_eff == 4 {
                    if qwen3_megakernel_speck4_use() != 0 {
                        if qwen3_megakernel_speck4_ready() != 0 {
                            if hidden == 1024 {
                                // mks4 LDS: attn_w_lds[M_EFF*128] → pos cap 128.
                                if pos + 4 <= 128 {
                                    use_mks4 = 1
                                }
                            }
                        }
                    }
                }
            }
            // Slice 4.15 — speck8 mega-kernel: spec_K=8 path.
            u64 use_mks8 = 0
            if is_spec != 0 {
                if M_eff == 8 {
                    if qwen3_megakernel_speck8_use() != 0 {
                        if qwen3_megakernel_speck8_ready() != 0 {
                            if hidden == 1024 {
                                // mks8 LDS: attn_w_lds[M_EFF*128] → pos cap 128.
                                if pos + 8 <= 128 {
                                    use_mks8 = 1
                                }
                            }
                        }
                    }
                }
            }
            // Slice 4.18 — speck16 mega-kernel: spec_K=16 path.
            // Slice 4.20: LDS cap bumped from 64 to 96 (kernel constant
            // MAX_SEQ_LDS=96, attn_w_lds size 6 KB).  Tried 128 (8 KB)
            // but it deadlocked: gfx1100 LDS budget caps concurrent
            // WGs/CU at 8 with 8 KB LDS, dropping total active grid
            // below 512 — the persistent-WG cross-barrier never reaches
            // the 512 expected count.  6 KB allows ~10 WGs/CU = 600
            // capacity, comfortably above the 512 needed.
            u64 use_mks16 = 0
            if is_spec != 0 {
                if M_eff == 16 {
                    if qwen3_megakernel_speck16_use() != 0 {
                        if qwen3_megakernel_speck16_ready() != 0 {
                            if hidden == 1024 {
                                if pos + 16 <= 96 {
                                    use_mks16 = 1
                                }
                            }
                        }
                    }
                }
            }
            while layer < n_layers {
                Qwen3LayerWeights w = layers_arr + layer * 88
                if use_mks16 != 0 {
                    u64 kc_l = k_cache + layer * batch_stride
                    u64 vc_l = v_cache + layer * batch_stride
                    if qwen3_forward_layer_megakernel_speck16_gpu(
                            d_in_arr, d_out_arr, w, pos, kc_l, vc_l, layer) != 0 { exit(1) }
                    // Ping-pong pointers (same as mks8 path).
                    u64 b_sw16 = 0
                    while b_sw16 < M_eff {
                        u64 di = 0; unsafe { *((d_in_arr   + b_sw16 * 8) as u64) -> di }
                        u64 do_ = 0; unsafe { *((d_out_arr  + b_sw16 * 8) as u64) -> do_ }
                        u64 dih = 0; unsafe { *((d_in_h_arr + b_sw16 * 8) as u64) -> dih }
                        u64 doh = 0
                        if do_ != 0 {
                            u64 b_lk = 0
                            while b_lk < M_eff {
                                u64 dxa  = 0; unsafe { *((d_x_a_arr   + b_lk * 8) as u64) -> dxa }
                                u64 dxah = 0; unsafe { *((d_x_a_h_arr + b_lk * 8) as u64) -> dxah }
                                u64 dxb  = 0; unsafe { *((d_x_b_arr   + b_lk * 8) as u64) -> dxb }
                                u64 dxbh = 0; unsafe { *((d_x_b_h_arr + b_lk * 8) as u64) -> dxbh }
                                if b_lk == b_sw16 {
                                    if do_ == dxa { doh = dxah }
                                    if do_ == dxb { doh = dxbh }
                                }
                                b_lk = b_lk + 1
                            }
                        }
                        unsafe { *((d_in_arr   + b_sw16 * 8) as u64) = do_ }
                        unsafe { *((d_out_arr  + b_sw16 * 8) as u64) = di }
                        unsafe { *((d_in_h_arr + b_sw16 * 8) as u64) = doh }
                        b_sw16 = b_sw16 + 1
                    }
                    layer = layer + 1
                    continue
                }
                if use_mks8 != 0 {
                    u64 kc_l = k_cache + layer * batch_stride
                    u64 vc_l = v_cache + layer * batch_stride
                    if qwen3_forward_layer_megakernel_speck8_gpu(
                            d_in_arr, d_out_arr, w, pos, kc_l, vc_l, layer) != 0 { exit(1) }
                    // Ping-pong pointers (same as mks4 path).
                    u64 b_sw8 = 0
                    while b_sw8 < M_eff {
                        u64 di = 0; unsafe { *((d_in_arr   + b_sw8 * 8) as u64) -> di }
                        u64 do_ = 0; unsafe { *((d_out_arr  + b_sw8 * 8) as u64) -> do_ }
                        u64 dih = 0; unsafe { *((d_in_h_arr + b_sw8 * 8) as u64) -> dih }
                        u64 doh = 0
                        if do_ != 0 {
                            u64 b_lk = 0
                            while b_lk < M_eff {
                                u64 dxa  = 0; unsafe { *((d_x_a_arr   + b_lk * 8) as u64) -> dxa }
                                u64 dxah = 0; unsafe { *((d_x_a_h_arr + b_lk * 8) as u64) -> dxah }
                                u64 dxb  = 0; unsafe { *((d_x_b_arr   + b_lk * 8) as u64) -> dxb }
                                u64 dxbh = 0; unsafe { *((d_x_b_h_arr + b_lk * 8) as u64) -> dxbh }
                                if b_lk == b_sw8 {
                                    if do_ == dxa { doh = dxah }
                                    if do_ == dxb { doh = dxbh }
                                }
                                b_lk = b_lk + 1
                            }
                        }
                        unsafe { *((d_in_arr   + b_sw8 * 8) as u64) = do_ }
                        unsafe { *((d_out_arr  + b_sw8 * 8) as u64) = di }
                        unsafe { *((d_in_h_arr + b_sw8 * 8) as u64) = doh }
                        b_sw8 = b_sw8 + 1
                    }
                    layer = layer + 1
                    continue
                }
                if use_mks4 != 0 {
                    u64 kc_l = k_cache + layer * batch_stride
                    u64 vc_l = v_cache + layer * batch_stride
                    if qwen3_forward_layer_megakernel_speck4_gpu(
                            d_in_arr, d_out_arr, w, pos, kc_l, vc_l, layer) != 0 { exit(1) }
                    // Ping-pong pointers.
                    u64 b_sw = 0
                    while b_sw < M_eff {
                        u64 di = 0; unsafe { *((d_in_arr   + b_sw * 8) as u64) -> di }
                        u64 do_ = 0; unsafe { *((d_out_arr  + b_sw * 8) as u64) -> do_ }
                        u64 dih = 0; unsafe { *((d_in_h_arr + b_sw * 8) as u64) -> dih }
                        u64 doh = 0
                        if do_ != 0 {
                            u64 b_lk = 0
                            while b_lk < M_eff {
                                u64 dxa  = 0; unsafe { *((d_x_a_arr   + b_lk * 8) as u64) -> dxa }
                                u64 dxah = 0; unsafe { *((d_x_a_h_arr + b_lk * 8) as u64) -> dxah }
                                u64 dxb  = 0; unsafe { *((d_x_b_arr   + b_lk * 8) as u64) -> dxb }
                                u64 dxbh = 0; unsafe { *((d_x_b_h_arr + b_lk * 8) as u64) -> dxbh }
                                if b_lk == b_sw {
                                    if do_ == dxa { doh = dxah }
                                    if do_ == dxb { doh = dxbh }
                                }
                                b_lk = b_lk + 1
                            }
                        }
                        unsafe { *((d_in_arr   + b_sw * 8) as u64) = do_ }
                        unsafe { *((d_out_arr  + b_sw * 8) as u64) = di }
                        unsafe { *((d_in_h_arr + b_sw * 8) as u64) = doh }
                        b_sw = b_sw + 1
                    }
                    layer = layer + 1
                    continue
                }
                if M_eff > 1 {
                    if qwen3_forward_layer_qkv_batched_gpu(d_in_arr, w, M_eff) != 0 { exit(1) }
                    // Refresh GPU rope cos/sin for the current pos.  The
                    // legacy qwen3_forward_layer_gpu does this lazily, but
                    // the M_eff > 1 batched chain skips that function — so
                    // without an explicit refresh every step would re-use
                    // whatever rope state was left from a prior pos.
                    // Done here (post _qwen3_gpu_pipeline_init via the
                    // qkv_batched call above) so _gpuq_d_rope_cos_h is set.
                    if layer == 0 {
                        if _gpuq_rope_cache_pos != pos {
                            f64 rope_theta = 1000000.0
                            qwen3_rope_compute(_gpuq_d_rope_cos_h, _gpuq_d_rope_sin_h, pos, QWEN3_HEAD_DIM, rope_theta)
                            _gpuq_rope_cache_pos = pos
                        }
                    }
                    // Pre-compute layer's K/V slab base.  In spec mode
                    // batch_size=1 so this is also the single-sequence
                    // layer base.
                    u64 d_kc_layer_b = _gpuq_kv_k_dev_base + layer * (batch_size * layer_stride)
                    u64 d_vc_layer_b = _gpuq_kv_v_dev_base + layer * (batch_size * layer_stride)
                    u64 d_k_pos_b = d_kc_layer_b + pos * (kv_dim * 4)
                    u64 d_v_pos_b = d_vc_layer_b + pos * (kv_dim * 4)
                    if is_spec != 0 {
                        if gpu_qkv_split_f32_speck4_to_dev(_gpuq_d_qkv, d_k_pos_b, d_v_pos_b, M_eff) != 0 { exit(1) }
                    } else {
                        if gpu_qkv_split_f32_batched_to_dev(_gpuq_d_qkv, d_k_pos_b, d_v_pos_b, batch_size) != 0 { exit(1) }
                    }
                    if is_spec == 0 {
                        u64 b_attn_phase = 0
                        while b_attn_phase < batch_size {
                            u64 d_in_b  = 0; unsafe { *((d_in_arr  + b_attn_phase * 8) as u64) -> d_in_b }
                            u64 d_out_b = 0; unsafe { *((d_out_arr + b_attn_phase * 8) as u64) -> d_out_b }
                            u64 kc = k_cache + layer * batch_stride + b_attn_phase * layer_stride
                            u64 vc = v_cache + layer * batch_stride + b_attn_phase * layer_stride
                            // 0x02 attn region; skip everything that's batched
                            // separately: Q-rope, attn, qknorm Q, qkv_split,
                            // qknorm K, K-rope.
                            if qwen3_forward_layer_gpu(d_in_b, d_out_b, w, pos, kc, vc, num_workers, b_attn_phase, 0x7E02) != 0 { exit(1) }
                            b_attn_phase = b_attn_phase + 1
                        }
                    }
                    if gpu_extract_q_qwen3_f32_to_dev(_gpuq_d_qkv, _gpuq_d_q_attn, M_eff) != 0 { exit(1) }
                    u64 d_q_gamma_b = gpu_cache_bf16_as_f32(w.q_norm_w, QWEN3_HEAD_DIM)
                    if d_q_gamma_b == 0 { exit(1) }
                    if gpu_qknorm_f32_to_dev(_gpuq_d_q_attn, _gpuq_d_q_attn, d_q_gamma_b,
                                              M_eff * QWEN3_N_HEADS) != 0 { exit(1) }
                    if gpu_rope_f32_to_dev(_gpuq_d_q_attn, _gpuq_d_rope_cos, _gpuq_d_rope_sin,
                                            M_eff * QWEN3_N_HEADS) != 0 { exit(1) }
                    // K extract → batched qknorm K → batched K-rope → K insert.
                    if is_spec != 0 {
                        if gpu_extract_k_qwen3_f32_speck4_to_dev(d_k_pos_b, _gpuq_d_k_stage, M_eff) != 0 { exit(1) }
                    } else {
                        if gpu_extract_k_qwen3_f32_to_dev(d_k_pos_b, _gpuq_d_k_stage, batch_size) != 0 { exit(1) }
                    }
                    u64 d_k_gamma_b = gpu_cache_bf16_as_f32(w.k_norm_w, QWEN3_HEAD_DIM)
                    if d_k_gamma_b == 0 { exit(1) }
                    if gpu_qknorm_f32_to_dev(_gpuq_d_k_stage, _gpuq_d_k_stage, d_k_gamma_b,
                                              M_eff * QWEN3_N_KV_HEADS) != 0 { exit(1) }
                    if gpu_rope_f32_to_dev(_gpuq_d_k_stage, _gpuq_d_rope_cos, _gpuq_d_rope_sin,
                                            M_eff * QWEN3_N_KV_HEADS) != 0 { exit(1) }
                    if is_spec != 0 {
                        if gpu_insert_k_qwen3_f32_speck4_to_dev(_gpuq_d_k_stage, d_k_pos_b, M_eff) != 0 { exit(1) }
                    } else {
                        if gpu_insert_k_qwen3_f32_to_dev(_gpuq_d_k_stage, d_k_pos_b, batch_size) != 0 { exit(1) }
                    }
                    if step == 0 { if layer == 0 {
                        // SELF-TEST: allocate fresh GPU bufs with known data,
                        // run attn_decode_batched, verify output. If correct,
                        // kernel works at this point in chain; if NaN, GPU
                        // state is corrupt.
                        gpu_pipeline_flush()
                        u64 q_b   = batch_size * q_dim * 4
                        u64 kvb   = batch_size * 64 * 1024 * 4   // max_seq=64, kv_dim=1024
                        u64 fq = 0; u64 fkc = 0; u64 fvc = 0; u64 fout = 0
                        u64 sl = alloc(8); hipMalloc(sl, q_b);  unsafe { *(sl as u64) -> fq }
                        sl = alloc(8); hipMalloc(sl, kvb); unsafe { *(sl as u64) -> fkc }
                        sl = alloc(8); hipMalloc(sl, kvb); unsafe { *(sl as u64) -> fvc }
                        sl = alloc(8); hipMalloc(sl, q_b);  unsafe { *(sl as u64) -> fout }
                        u64 hb = alloc(q_b)
                        u64 ii = 0
                        while ii < (batch_size * q_dim) { unsafe { *((hb + ii*4) as f32) = 0.5f }; ii = ii+1 }
                        hipMemcpy(fq, hb, q_b, 1)
                        u64 hbk = alloc(kvb)
                        ii = 0
                        while ii < (batch_size * 64 * 1024) { unsafe { *((hbk + ii*4) as f32) = 0.25f }; ii = ii+1 }
                        hipMemcpy(fkc, hbk, kvb, 1)
                        ii = 0
                        while ii < (batch_size * 64 * 1024) { unsafe { *((hbk + ii*4) as f32) = 0.75f }; ii = ii+1 }
                        hipMemcpy(fvc, hbk, kvb, 1)
                        if gpu_attn_decode_to_dev_batched(fq, fkc, fvc, fout, 1, batch_size) != 0 { exit(1) }
                        gpu_pipeline_flush()
                        u64 hout = alloc(q_b)
                        hipMemcpy(hout, fout, q_b, 2)
                        u32 ot0 = 0; unsafe { *(hout as u32) -> ot0 }
                        u32 ot1 = 0; unsafe { *((hout + 8192) as u32) -> ot1 }
                        eout("[selftest] expected=0.75 (0x3F400000) got_b0="); eu64(ot0); eout(" got_b1="); eu64(ot1); eout("\n")
                        hipFree(fq); hipFree(fkc); hipFree(fvc); hipFree(fout)
                        dealloc(hb); dealloc(hbk); dealloc(hout)
                    } }
                    if is_spec != 0 {
                        if gpu_attn_decode_to_dev_speck4(_gpuq_d_q_attn, d_kc_layer_b, d_vc_layer_b,
                                                          _gpuq_d_attn, pos + M_eff) != 0 { exit(1) }
                    } else {
                        if gpu_attn_decode_to_dev_batched(_gpuq_d_q_attn, d_kc_layer_b, d_vc_layer_b,
                                                           _gpuq_d_attn, pos + 1, batch_size) != 0 { exit(1) }
                    }
                    if gpu_matmul_to_dev_batched(_gpuq_d_o, _gpuq_d_attn, w.o_proj_w,
                                                  hidden, q_dim, M_eff) != 0 { exit(1) }
                    u64 d_in_full_pa = 0; unsafe { *((d_in_arr + 0) as u64) -> d_in_full_pa }
                    if gpu_resid_add_to_dev(_gpuq_d_mid, d_in_full_pa, _gpuq_d_o, M_eff * hidden) != 0 { exit(1) }
                    u64 d_post_gamma_b = gpu_cache_bf16_as_f32(w.post_norm_w, hidden)
                    if d_post_gamma_b == 0 { exit(1) }
                    if gpu_rmsnorm_hidden_to_dev(_gpuq_d_mid_norm, _gpuq_d_mid, d_post_gamma_b, M_eff, hidden) != 0 { exit(1) }
                    // gate/up matmul: fused (one matmul of 2*ff) when
                    // qwen3_fuse_qkv != 0, otherwise two separate matmuls
                    // writing into the gate and up halves of _gpuq_d_gu.
                    if qwen3_fuse_qkv != 0 {
                        if gpu_matmul_to_dev_batched(_gpuq_d_gu, _gpuq_d_mid_norm, w.gate_proj_w,
                                                      2 * ff, hidden, M_eff) != 0 { exit(1) }
                    } else {
                        if M_eff != 1 { eout("no-fuse gate_up requires M_eff=1\n"); exit(1) }
                        if gpu_matmul_to_dev_batched(_gpuq_d_gu,           _gpuq_d_mid_norm, w.gate_proj_w,
                                                      ff, hidden, 1) != 0 { exit(1) }
                        if gpu_matmul_to_dev_batched(_gpuq_d_gu + ff * 4, _gpuq_d_mid_norm, w.up_proj_w,
                                                      ff, hidden, 1) != 0 { exit(1) }
                    }
                    if gpu_silu_mul_f32_batched_to_dev(_gpuq_d_ff, _gpuq_d_gu, _gpuq_d_gu + ff * 4,
                                                        ff, M_eff) != 0 { exit(1) }
                    if gpu_matmul_to_dev_batched(_gpuq_d_ff_out, _gpuq_d_ff, w.down_proj_w,
                                                  hidden, ff, M_eff) != 0 { exit(1) }
                    u64 d_out_full_pa = 0; unsafe { *((d_out_arr + 0) as u64) -> d_out_full_pa }
                    if gpu_resid_add_to_dev(d_out_full_pa, _gpuq_d_mid, _gpuq_d_ff_out, M_eff * hidden) != 0 { exit(1) }
                    // Per-layer flush: required for correctness, not just
                    // crash prevention.  Tested 2026-05-01: skipping causes
                    // numerical drift that crashes spec accept rate from
                    // 2.05 tok/step to 1.35 tok/step (41 → 27 tokens).  The
                    // flush forces the chain to re-converge to a clean
                    // state every 17 dispatches.  Removing this needs
                    // either a deeper queue-tracking fix or a mega-kernel
                    // that doesn't accumulate the drifting state.
                    gpu_pipeline_flush()
                } else {
                    // M_eff == 1: legacy single-stream path.
                    // Slice 2b cross-layer fusion: when N=1024 (qwen3-0.6B
                    // hidden), chain layer L's final resid into layer L+1's
                    // input_norm via gpu_residual_rmsnorm — saves 1 launch
                    // per layer boundary.  Adds 0x10000 to skip the
                    // intra-layer final resid for L < n-1, then issues the
                    // fused dispatch with next layer's gamma; layer L+1
                    // gets 0x8000 to skip its own input_norm.
                    u64 d_in_b  = 0; unsafe { *((d_in_arr  + 0) as u64) -> d_in_b }
                    u64 d_out_b = 0; unsafe { *((d_out_arr + 0) as u64) -> d_out_b }
                    u64 kc = k_cache + layer * batch_stride
                    u64 vc = v_cache + layer * batch_stride
                    u64 mask_self = 0xFF
                    // Slice 4.8: when MLRIFT_QWEN3_MEGAKERNEL=1, the
                    // single-dispatch mega-kernel always handles input
                    // norm + final residual itself.  Suppress the
                    // cross-layer fusion bits 0x8000 / 0x10000 so the
                    // callee can take the mega-kernel path (which
                    // requires a clean 0xFF mask) and skip the post-
                    // call qwen3_gpu_chain_resid_to_next_norm.
                    u64 _ev_megak = getenv("MLRIFT_QWEN3_MEGAKERNEL")
                    u64 _use_megak_self = 0
                    if _ev_megak != 0 {
                        u8 _mk_c0 = 0; unsafe { *(_ev_megak as u8) -> _mk_c0 }
                        if _mk_c0 != 48 { _use_megak_self = 1 }
                    }
                    if hidden == 1024 && _use_megak_self == 0 {
                        if layer > 0 { mask_self = mask_self | 0x8000 }
                        if layer < n_layers - 1 { mask_self = mask_self | 0x10000 }
                    }
                    // Slice 2c opt-out: env MLRIFT_NO_QKNORM_ROPE_FUSED=1
                    u64 _no_fused_env = getenv("MLRIFT_NO_QKNORM_ROPE_FUSED")
                    if _no_fused_env != 0 {
                        u8 _nfe_c = 0; unsafe { *(_no_fused_env as u8) -> _nfe_c }
                        if _nfe_c != 48 { mask_self = mask_self | 0x40000 }
                    }
                    if qwen3_forward_layer_gpu(d_in_b, d_out_b, w, pos, kc, vc, num_workers, 0, mask_self) != 0 { exit(1) }
                    if hidden == 1024 && layer < n_layers - 1 && _use_megak_self == 0 {
                        Qwen3LayerWeights w_next = layers_arr + (layer + 1) * 88
                        if qwen3_gpu_chain_resid_to_next_norm(d_out_b, w_next.input_norm_w, 0) != 0 { exit(1) }
                    }
                }
                // Swap ping-pong pointers — every M_eff row, not just the
                // batch_size streams (in spec mode batch_size=1 but we have
                // M_eff=K rows that all need their pointers flipped).
                u64 b_sw = 0
                while b_sw < M_eff {
                    u64 di = 0; unsafe { *((d_in_arr   + b_sw * 8) as u64) -> di }
                    u64 do_ = 0; unsafe { *((d_out_arr  + b_sw * 8) as u64) -> do_ }
                    u64 dih = 0; unsafe { *((d_in_h_arr + b_sw * 8) as u64) -> dih }
                    // Find the matching host pointer for d_out by index lookup.
                    u64 doh = 0
                    if do_ == 0 { } else {
                        u64 b_lk = 0
                        while b_lk < M_eff {
                            u64 dxa  = 0; unsafe { *((d_x_a_arr   + b_lk * 8) as u64) -> dxa }
                            u64 dxah = 0; unsafe { *((d_x_a_h_arr + b_lk * 8) as u64) -> dxah }
                            u64 dxb  = 0; unsafe { *((d_x_b_arr   + b_lk * 8) as u64) -> dxb }
                            u64 dxbh = 0; unsafe { *((d_x_b_h_arr + b_lk * 8) as u64) -> dxbh }
                            if b_lk == b_sw {
                                if do_ == dxa { doh = dxah }
                                if do_ == dxb { doh = dxbh }
                            }
                            b_lk = b_lk + 1
                        }
                    }
                    unsafe { *((d_in_arr   + b_sw * 8) as u64) = do_ }
                    unsafe { *((d_out_arr  + b_sw * 8) as u64) = di }
                    unsafe { *((d_in_h_arr + b_sw * 8) as u64) = doh }
                    b_sw = b_sw + 1
                }
                layer = layer + 1
            }
            // After the layer sweep, d_in_arr[b] holds the final residual
            // device VA for stream b.  Non-spec: D2H row 0 to x_cur for
            // the legacy lmhead path.  Spec: run slice 2.4 verify+accept
            // here (inline, while d_in_h_arr is still in scope), then
            // skip the post-layer lmhead block below.
            if is_spec == 0 {
                u64 b_d2h = 0
                while b_d2h < batch_size {
                    u64 dih_f = 0; unsafe { *((d_in_h_arr + b_d2h * 8) as u64) -> dih_f }
                    u64 xc_f  = 0; unsafe { *((x_cur_arr  + b_d2h * 8) as u64) -> xc_f }
                    memcpy(xc_f, dih_f, hidden * 4)
                    b_d2h = b_d2h + 1
                }
            } else {
                // Slice 2.4: speculative verify + accept.  Per-row final
                // norm + lmhead + argmax → pred[r].  Walk the predictions
                // vs drafts to decide how many tokens to accept.
                // pred[0] is always accepted (= true next token at pos+1).
                // For r >= 1: accept pred[r] iff draft[r-1] == pred[r-1].
                u64 sids_s = 0; unsafe { *((seq_ids_arr + 0) as u64) -> sids_s }
                u64 x_cur_s = 0; unsafe { *((x_cur_arr + 0) as u64) -> x_cur_s }
                u64 pred_arr = alloc(M_eff * 8)
                u64 lm_start = time_now()
                u64 r_pred = 0
                while r_pred < M_eff {
                    u64 dih_r = 0; unsafe { *((d_in_h_arr + r_pred * 8) as u64) -> dih_r }
                    qwen3_rmsnorm_bf16(final_out, dih_r, norm_ptr, hidden)
                    qwen3_main_matmul(logits, final_out, embed_ptr, 1, vocab, hidden, num_workers, 0)
                    u64 best_id = 0
                    f32 best_val = 0.0f
                    u64 first = 1
                    u64 j = 0
                    while j < vocab {
                        f32 v = 0.0f
                        unsafe { *((logits + j * 4) as f32) -> v }
                        if first == 1 { best_val = v; best_id = j; first = 0 }
                        else          { if v > best_val { best_val = v; best_id = j } }
                        j = j + 1
                    }
                    unsafe { *((pred_arr + r_pred * 8) as u64) = best_id }
                    r_pred = r_pred + 1
                }
                sum_lmhead_ns = sum_lmhead_ns + time_elapsed(lm_start)
                u64 pred0 = 0; unsafe { *((pred_arr + 0) as u64) -> pred0 }
                unsafe { *((sids_s + seq_len * 8) as u64) = pred0 }
                u64 n_accept = 1
                u64 ai = 1
                while ai < M_eff {
                    u64 di = 0; unsafe { *((draft_arr + (ai - 1) * 8) as u64) -> di }
                    u64 pi_prev = 0; unsafe { *((pred_arr + (ai - 1) * 8) as u64) -> pi_prev }
                    if di != pi_prev {
                        ai = M_eff
                    } else {
                        u64 pi = 0; unsafe { *((pred_arr + ai * 8) as u64) -> pi }
                        unsafe { *((sids_s + (seq_len + n_accept) * 8) as u64) = pi }
                        n_accept = n_accept + 1
                        ai = ai + 1
                    }
                }
                dealloc(pred_arr)
                dealloc(draft_arr)
                u64 last_tok = 0; unsafe { *((sids_s + (seq_len + n_accept - 1) * 8) as u64) -> last_tok }
                u64 emb_start = time_now()
                u64 row_e_s = embed_ptr + last_tok * hidden * 2
                u64 ie = 0
                while ie < hidden {
                    f32 ev = bf16_to_f32(row_e_s + ie * 2)
                    unsafe { *((x_cur_s + ie * 4) as f32) = ev }
                    ie = ie + 1
                }
                sum_embed_ns = sum_embed_ns + time_elapsed(emb_start)
                unsafe { *((tok_arr + 0) as u64) = last_tok }
                eout("[spec] step "); eu64(step); eout(" accepted "); eu64(n_accept); eout(" / "); eu64(M_eff); eout("\n")
                seq_len = seq_len + n_accept
                pos    = pos    + n_accept
            }
            dealloc(d_in_arr); dealloc(d_out_arr); dealloc(d_in_h_arr)
        } else {
            // CPU path stays per-stream sequential.
            u64 b_step = 0
            while b_step < batch_size {
                u64 x_cur = 0; unsafe { *((x_cur_arr + b_step * 8) as u64) -> x_cur }
                u64 x_nxt = 0; unsafe { *((x_nxt_arr + b_step * 8) as u64) -> x_nxt }
                u64 layer = 0
                while layer < n_layers {
                    Qwen3LayerWeights w = layers_arr + layer * 88
                    u64 kc = k_cache + layer * batch_stride + b_step * layer_stride
                    u64 vc = v_cache + layer * batch_stride + b_step * layer_stride
                    qwen3_forward_layer(x_nxt, x_cur, w, pos, kc, vc, num_workers)
                    u64 tmp = x_cur; x_cur = x_nxt; x_nxt = tmp
                    layer = layer + 1
                }
                unsafe { *((x_cur_arr + b_step * 8) as u64) = x_cur }
                unsafe { *((x_nxt_arr + b_step * 8) as u64) = x_nxt }
                b_step = b_step + 1
            }
        }
        sum_layer_ns = sum_layer_ns + time_elapsed(layer_start_ns)

        // Slice 1.5: when batch > 1 and the batched lm_head buffers are
        // allocated, run final_norm × M into the batched final_out buffer,
        // then ONE batched lm_head matmul for all streams, then per-stream
        // argmax + embed.  In spec mode the verify+accept already ran
        // inline within the use_gpu_full block above; skip this block.
        if is_spec == 0 {
            u64 use_batched_lmhead = 0
            if batch_size > 1 {
                if d_logits_batched != 0 { use_batched_lmhead = 1 }
            }
            if use_batched_lmhead != 0 {
                u64 norm_start_ns = time_now()
                u64 b_n = 0
                while b_n < batch_size {
                    u64 x_cur_n = 0; unsafe { *((x_cur_arr + b_n * 8) as u64) -> x_cur_n }
                    qwen3_rmsnorm_bf16(d_final_out_batched_h + b_n * hidden * 4, x_cur_n, norm_ptr, hidden)
                    b_n = b_n + 1
                }
                sum_norm_ns = sum_norm_ns + time_elapsed(norm_start_ns)
                u64 lmhead_start_ns = time_now()
                if gpu_matmul_to_dev_batched(d_logits_batched, d_final_out_batched, embed_ptr,
                                              vocab, hidden, batch_size) != 0 { exit(1) }
                gpu_pipeline_flush()
                sum_lmhead_ns = sum_lmhead_ns + time_elapsed(lmhead_start_ns)
            }

            // Per-stream argmax + embed (and per-stream final_norm + lm_head
            // when use_batched_lmhead == 0).
            u64 b_step = 0
            while b_step < batch_size {
                u64 x_cur = 0; unsafe { *((x_cur_arr + b_step * 8) as u64) -> x_cur }
                u64 sids  = 0; unsafe { *((seq_ids_arr + b_step * 8) as u64) -> sids }

                u64 logits_for_b = logits
                if use_batched_lmhead != 0 {
                    logits_for_b = d_logits_batched_h + b_step * vocab * 4
                } else {
                    u64 norm_start_ns = time_now()
                    qwen3_rmsnorm_bf16(final_out, x_cur, norm_ptr, hidden)
                    sum_norm_ns = sum_norm_ns + time_elapsed(norm_start_ns)
                    u64 lmhead_start_ns = time_now()
                    qwen3_main_matmul(logits, final_out, embed_ptr, 1, vocab, hidden, num_workers, 0)
                    sum_lmhead_ns = sum_lmhead_ns + time_elapsed(lmhead_start_ns)
                }

                u64 argmax_start_ns = time_now()
                u64 best_id = 0
                f32 best_val = 0.0f
                u64 first = 1
                u64 j = 0
                while j < vocab {
                    f32 v = 0.0f
                    unsafe { *((logits_for_b + j * 4) as f32) -> v }
                    if first == 1 { best_val = v; best_id = j; first = 0 }
                    else          { if v > best_val { best_val = v; best_id = j } }
                    j = j + 1
                }
                sum_argmax_ns = sum_argmax_ns + time_elapsed(argmax_start_ns)

                unsafe { *((sids + seq_len * 8) as u64) = best_id }

                u64 embed_start_ns = time_now()
                row = embed_ptr + best_id * hidden * 2
                u64 i1 = 0
                while i1 < hidden {
                    f32 v = bf16_to_f32(row + i1 * 2)
                    unsafe { *((x_cur + i1 * 4) as f32) = v }
                    i1 = i1 + 1
                }
                sum_embed_ns = sum_embed_ns + time_elapsed(embed_start_ns)
                unsafe { *((tok_arr + b_step * 8) as u64) = best_id }
                b_step = b_step + 1
            }

            seq_len = seq_len + 1
            pos = pos + 1
        }
        u64 step_elapsed_ns = time_elapsed(step_start_ns)
        sum_decode_ns = sum_decode_ns + step_elapsed_ns
        u64 step_ms = step_elapsed_ns / 1000000
        u64 step_launches      = hipkfd_get_launch_count() - step_launch_start
        u64 step_syncs         = hipkfd_get_sync_count()   - step_sync_start
        u64 step_sync_ns       = hipkfd_get_sync_total_ns() - step_sync_ns_start
        u64 step_sync_busy     = hipkfd_get_sync_busy_calls() - step_sync_busy_start
        u64 step_sync_us       = step_sync_ns / 1000
        eout("  step "); eu64(step); eout(" took "); eu64(step_ms); eout(" ms ")
        eout("launches="); eu64(step_launches)
        eout(" syncs="); eu64(step_syncs)
        eout(" sync_us="); eu64(step_sync_us)
        eout(" sync_busy="); eu64(step_sync_busy); eout("\n")
        // Slice 4.20 chase prints (kept off by default; flip MLRIFT_VRAM_TRACE
        // to capture per-step cache counts when investigating leaks).
        u64 ev_vt = getenv("MLRIFT_VRAM_TRACE")
        u64 want_vt = 0
        if ev_vt != 0 { u8 cv = 0; unsafe { *(ev_vt as u8) -> cv } if cv != 48 { want_vt = 1 } }
        if want_vt != 0 {
            u64 vmb_si = gpu_buf_pool_total() / 1048576
            u64 nu_si = gpu_mm_bf16_cache_total()
            u64 np_si = gpu_mm_bf16_pad_cache_total()
            eout("[vram] post-step"); eu64(step); eout(" buf_pool="); eu64(vmb_si); eout(" MiB unpad_cache="); eu64(nu_si); eout(" pad_cache="); eu64(np_si); eout("\n")
        }
        step = step + 1
    }
    u64 total_decode_ns = time_elapsed(decode_start_ns)
    u64 total_ms = total_decode_ns / 1000000
    eout("\n=== TIMING ===\n")
    eout("total_decode_ms=");  eu64(total_ms); eout("\n")
    eout("sum_per_step_ms=");  eu64(sum_decode_ns / 1000000); eout("\n")
    eout("mean_step_ms=");     eu64(total_decode_ns / max_new / 1000000); eout("\n")
    // tokens/sec * 1000 (fixed-point, integer math only).  Counts the
    // actual number of tokens generated (= seq_len delta) so spec_K's
    // multi-token-accept advances are reflected in the throughput
    // number.  Without this, the counter would report `max_new` even
    // when slice 2.4 emits 2-4× that many tokens per step.
    // generated_tokens = post-decode seq_len minus pre-decode seq_len.
    // For non-spec paths this equals max_new; for slice 2.4 spec it
    // equals sum(n_accept) over all steps.
    u64 generated_tokens = (seq_len - prompt_initial_len) * batch_size
    if generated_tokens == 0 { generated_tokens = max_new * batch_size }
    u64 tokps_milli = 0
    if total_decode_ns != 0 {
        tokps_milli = (generated_tokens * 1000 * 1000000000) / total_decode_ns
    }
    eout("generated_tokens="); eu64(generated_tokens); eout("\n")
    eout("tokens_per_sec_x1000="); eu64(tokps_milli)
    if batch_size > 1 {
        u64 perstream_milli = tokps_milli / batch_size
        eout(" (per_stream="); eu64(perstream_milli); eout(")")
    }
    eout("\n")
    eout("\n=== BREAKDOWN (ms) ===\n")
    eout("layer_sweep_ms=");     eu64(sum_layer_ns  / 1000000); eout("\n")
    eout("final_norm_ms=");      eu64(sum_norm_ns   / 1000000); eout("\n")
    eout("lmhead_ms=");          eu64(sum_lmhead_ns / 1000000); eout("\n")
    eout("argmax_ms=");          eu64(sum_argmax_ns / 1000000); eout("\n")
    eout("embed_ms=");           eu64(sum_embed_ns  / 1000000); eout("\n")
    qwen3_profile_dump()

    // Print final sequences (one per stream).
    eout("\n=== GENERATED SEQUENCE ===\n")
    u64 b_print = 0
    while b_print < batch_size {
        if batch_size > 1 { eout("[stream "); eu64(b_print); eout("] ") }
        u64 sids_p = 0; unsafe { *((seq_ids_arr + b_print * 8) as u64) -> sids_p }
        u64 si = 0
        while si < seq_len {
            if si != 0 { eout(", ") }
            u64 id = 0
            unsafe { *((sids_p + si * 8) as u64) -> id }
            eu64(id)
            si = si + 1
        }
        eout("\n")
        b_print = b_print + 1
    }
    eout("=== PYTORCH REF (for eyeball diff) ===\n")
    eout("14990, 14582, 284, 330, 9707, 11, 4337, 17199, 1350, 3203, 4791, 14582, 692, 2, 1173, 279, 1156, 3409, 198, 1350, 3203\n")

    dealloc(final_out); dealloc(logits); dealloc(layers_arr)
    dealloc(k_cache); dealloc(v_cache)
    if _wt_mode == 1 {
        SafetensorShard sh_close = _wt_sh
        safetensors_shard_free(sh_close)
    } else {
        SafetensorFile st_close = _wt_st_single
        safetensors_free(st_close)
    }
    thread_pool_shutdown()
    file_close(g_fd)
    exit(0)
}
