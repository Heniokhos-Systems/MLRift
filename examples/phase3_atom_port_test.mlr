// Phase 3 slice δ.0j — ATOM I/O port handler smoke test.
//
// Validates the FB read/write paths through the real opcode dispatch
// (no GPU, no sudo required).
//
// Synthetic ATOM program:
//   [op=4  0x05 0x00 0xBE 0xBA 0xFE 0xCA]  move FB[0] <- IMM 0xCAFEBABE
//   [op=2  0x03 0x00 0x00]                  move PS[0] <- FB[0]
//   [op=91]                                  EOT
//
// After atom_execute_table returns 0:
//   PS[0] must equal 0xCAFEBABE
//
// This confirms:
//   - _atom_put_dst  (arg=ATOM_ARG_FB) correctly writes into scratch
//   - _atom_get_src_int (arg=ATOM_ARG_FB) correctly reads from scratch
//   - _atom_put_dst  (arg=ATOM_ARG_PS) correctly writes PS slot
//   - the real opcode dispatch for MOVE FB and MOVE PS runs end-to-end

import "../std/atom.mlr"
import "../std/atom_constants.mlr"
import "../std/sys.mlr"

@dynamic extern fn exit(uint64 code)
@dynamic extern fn puts(uint64 s) -> uint32

fn _hex32(uint64 lab, uint64 ll, uint64 v) {
    uint64 b = alloc(64)
    uint64 i = 0
    while i < ll {
        uint8 c = 0; unsafe { *((lab + i) as uint8) -> c }
        unsafe { *((b + i) as uint8) = c }; i = i + 1
    }
    uint8 eq = 61; unsafe { *((b + ll) as uint8) = eq }
    uint8 zx = 48; unsafe { *((b + ll + 1) as uint8) = zx }
    uint8 xc = 120; unsafe { *((b + ll + 2) as uint8) = xc }
    uint64 j = 0
    while j < 8 {
        uint64 sh = (7 - j) * 4
        uint64 nyb = (v >> sh) & 0xF
        uint8 ch = nyb + 48
        if nyb >= 10 { ch = nyb + 87 }
        unsafe { *((b + ll + 3 + j) as uint8) = ch }
        j = j + 1
    }
    uint8 nul = 0; unsafe { *((b + ll + 11) as uint8) = nul }
    puts(b); dealloc(b)
}

fn main() {
    puts("phase3_atom_port_test")

    // -----------------------------------------------------------------
    // Build the synthetic ATOM image.
    //
    // atom_execute_table rejects cmd_table_offset == 0, so we start
    // the command table at offset 8 (leaving 8 bytes of padding).
    //
    // Layout:
    //   [0x00..0x07]  padding (8 bytes, all zero)
    //   [0x08..0x0D]  command-table header (6 bytes):
    //     [8..9]  uint16  size   = 6 + 12 = 18 (header + bytecode)
    //     [10]    uint8   fmt_rev = 0
    //     [11]    uint8   content_rev = 0
    //     [12]    uint8   ws_dwords = 0
    //     [13]    uint8   ps_dwords = 1  (we supply ps externally)
    //   [0x0E..0x19]  bytecode (12 bytes, starting at ct+ATOM_CT_CODE_PTR=8+6=14):
    //     [14] 0x04  op=4 (move FB)
    //     [15] 0x05  attr=(0<<3)|5 = src_align=DWORD, src_arg=IMM
    //     [16] 0x00  dst: FB slot index 0
    //     [17..20] 0xBE 0xBA 0xFE 0xCA  IMM DWORD 0xCAFEBABE (little-endian)
    //     [21] 0x02  op=2 (move PS)
    //     [22] 0x03  attr=(0<<3)|3 = src_align=DWORD, src_arg=FB
    //     [23] 0x00  dst: PS slot index 0
    //     [24] 0x00  src: FB slot index 0
    //     [25] 91    op=91 (EOT)
    // -----------------------------------------------------------------

    uint64 image_size = 28
    uint64 image = alloc(image_size)
    uint64 zi = 0
    while zi < image_size {
        uint8 z = 0; unsafe { *((image + zi) as uint8) = z }; zi = zi + 1
    }

    // Command-table header at offset 8.
    uint64 ct = 8
    uint16 ct_size = 18; unsafe { *((image + ct + 0) as uint16) = ct_size }
    uint8 ps_b = 1;      unsafe { *((image + ct + 5) as uint8)  = ps_b }

    // Bytecode starts at ct + ATOM_CT_CODE_PTR = 8 + 6 = 14.
    // Instruction 1: move FB[0] <- IMM 0xCAFEBABE
    uint8 op4 = 4;    unsafe { *((image + 14) as uint8)  = op4  }
    uint8 at1 = 5;    unsafe { *((image + 15) as uint8)  = at1  }   // attr=0x05
    uint8 fb0 = 0;    unsafe { *((image + 16) as uint8)  = fb0  }   // FB slot 0
    uint8 b0  = 0xBE; unsafe { *((image + 17) as uint8)  = b0   }   // IMM[0] LE
    uint8 b1  = 0xBA; unsafe { *((image + 18) as uint8)  = b1   }   // IMM[1]
    uint8 b2  = 0xFE; unsafe { *((image + 19) as uint8)  = b2   }   // IMM[2]
    uint8 b3  = 0xCA; unsafe { *((image + 20) as uint8)  = b3   }   // IMM[3]

    // Instruction 2: move PS[0] <- FB[0]
    uint8 op2 = 2;    unsafe { *((image + 21) as uint8)  = op2  }
    uint8 at2 = 3;    unsafe { *((image + 22) as uint8)  = at2  }   // attr=0x03
    uint8 ps0 = 0;    unsafe { *((image + 23) as uint8)  = ps0  }   // PS slot 0
    uint8 fs0 = 0;    unsafe { *((image + 24) as uint8)  = fs0  }   // FB slot 0

    // EOT
    uint8 eot = 91;   unsafe { *((image + 25) as uint8)  = eot  }

    // -----------------------------------------------------------------
    // Allocate and populate atom_context.
    //   - bar5_host = 0  (no GPU — smoke runs without hardware)
    //   - scratch    = 16-byte host buffer for FB operations
    //   - scratch_size = 16
    //   - fb_base (AC_OFF_FB_BASE) = 0  (window = 0)
    //   - io_mode = ATOM_IO_MM = 0 (default, unchanged)
    // -----------------------------------------------------------------
    uint64 scratch = alloc(16)
    zi = 0
    while zi < 16 {
        uint8 z = 0; unsafe { *((scratch + zi) as uint8) = z }; zi = zi + 1
    }

    uint64 ctx = alloc(ATOM_CONTEXT_SIZE)
    zi = 0
    while zi < ATOM_CONTEXT_SIZE {
        uint8 z = 0; unsafe { *((ctx + zi) as uint8) = z }; zi = zi + 1
    }
    unsafe { *((ctx + AC_OFF_IMAGE_BUF)    as uint64) = image   }
    unsafe { *((ctx + AC_OFF_IMAGE_SIZE)   as uint64) = image_size }
    unsafe { *((ctx + AC_OFF_SCRATCH)      as uint64) = scratch }
    unsafe { *((ctx + AC_OFF_SCRATCH_SIZE) as uint64) = 16      }
    // AC_OFF_FB_BASE (32) = 0 — window offset into scratch; left as 0
    // AC_OFF_BAR5_HOST (88) = 0 — no GPU, smoke mode

    // -----------------------------------------------------------------
    // Allocate PS buffer (1 dword) and run the program.
    // -----------------------------------------------------------------
    uint64 ps_buf = alloc(4)
    uint32 psinit = 0; unsafe { *(ps_buf as uint32) = psinit }

    // cmd_table_offset = 8 (the header starts at offset 8).
    // ps_ptr = ps_buf, ps_size = 1.
    uint64 rc = atom_execute_table(ctx, ct, ps_buf, 1)

    _hex32("rc", 2, rc)
    if rc != 0 {
        puts("FAIL: atom_execute_table returned non-zero")
        dealloc(ps_buf); dealloc(ctx); dealloc(scratch); dealloc(image)
        exit(1)
    }

    // Read back PS[0].
    uint32 got32 = 0; unsafe { *(ps_buf as uint32) -> got32 }
    uint64 got = got32
    _hex32("PS[0]", 5, got)

    if got != 0xCAFEBABE {
        puts("FAIL: PS[0] != 0xCAFEBABE")
        dealloc(ps_buf); dealloc(ctx); dealloc(scratch); dealloc(image)
        exit(2)
    }

    dealloc(ps_buf); dealloc(ctx); dealloc(scratch); dealloc(image)
    puts("phase3_atom_port_test: GREEN")
    exit(0)
}
