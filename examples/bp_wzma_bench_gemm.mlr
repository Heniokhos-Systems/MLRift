// bp_wzma_bench_gemm — GEMM-tiled + fused-bank WZMA CPU bench.
//
// Base: bp_wzma_bench_avx512.mlr (42 ms/step @ 16T).
//
// Optimisations over avx512 bench:
//
//   Lever 1 — blocked/register-tiled GEMV for U·x and V·inter:
//     inter_k = U_k^T @ x  (U_k: [D=384, R=32] bf16)
//     - Process 6 rows of U at a time (6 x values broadcast to 6 ZMM scalars)
//       × 2 ZMM accumulators (R=32 = 2 ZMM) = 12 registers held across 6 FMAs
//     - All 6 x loads come from the same cache line region; U rows are sequential
//     - Reduces vbroadcastss overhead from 1 per d to 1 per 6d (6x fewer stores)
//     - Unrolled body: load 6 x scalars, 12 vfmadd231ps (6 rows × 2 ZMM of R),
//       advance 6 rows in one go
//     - Tail (D mod 6) handled scalar
//
//   Lever 3 — fuse U·V einsums, keep inter in L2, stack K:
//     For each bs, compute all K banks in one pass over x:
//       for each block of 6 rows of x/U:
//         accumulate into inter[k=0..3][r=0..31] simultaneously
//     Then immediately compute outk += inter[k][r] * V_k[r,:] before inter
//     is evicted from L2/registers.
//     K stacking: process all K=4 banks together for the same bs row, so
//     x[d] is loaded once and used 4×(inter) + stays hot for outk fold.
//
//   Additional: bf16 U/V storage (same as avx512 bench), 16 threads,
//   f32 precision gate (matching avx512 convergence behaviour).
//
// Dims: B=8 S=16 D=384 K=4 R=32 vocab=8192 NW=16
//
// Build:
//   mlrc --arch=x86_64 --target=linux --emit=elfexe \
//       examples/bp_wzma_bench_gemm.mlr -o /tmp/bp_wzma_bench_gemm
// Run:
//   /tmp/bp_wzma_bench_gemm

import "../std/train.mlr"
import "../std/math_float.mlr"
import "../std/fmt.mlr"
import "../std/time.mlr"
import "../std/thread.mlr"

