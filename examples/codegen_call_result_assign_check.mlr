// Confirm: `t = some_fn()` (Assign with Call RHS) is safe — call results
// land in a fresh IR_CALL vreg, not aliased to anything else. Mutating
// `t` later does not corrupt the called function's storage.

import "../std/io.mlr"
import "../std/fmt.mlr"

static u64 g_seed = 100

fn produce() -> u64 {
    return g_seed
}

fn main() {
    u64 fail = 0

    u64 t = 0
    t = produce()
    while t < 105 {
        t = t + 1
    }

    if g_seed != 100 {
        print_str("BUG: g_seed clobbered after Assign-from-call loop; g_seed=")
        u64 s = fmt_dec(g_seed); print_str(s); dealloc(s); print_str("\n")
        fail = fail + 1
    }
    if t != 105 {
        print_str("BUG: t didn't reach 105; t=")
        u64 s = fmt_dec(t); print_str(s); dealloc(s); print_str("\n")
        fail = fail + 1
    }

    if fail == 0 {
        print_str("PASS\n")
    } else {
        print_str("FAIL\n")
    }
}
