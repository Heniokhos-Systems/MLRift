// phase3_atom_operand_test.mlr — smoke tests for the ATOM operand decoder
// (slice δ.0f). No GPU, no /tmp/mlrift_vbios.rom. Pure synthetic memory.
//
// 5 test cases:
//   1. PS read at DWORD align (attr=0x01)        -> 0x11223344
//   2. WS read at DWORD align (attr=0x02)        -> 0x55667788
//   3. IMM read at WORD align  (attr=0x0D)       -> 0x0000ABCD
//   4. IMM read at BYTE align  (attr=0x25)       -> 0x00000042
//   5. WS put+get round-trip   (arg=2, attr=0x02)-> 0xDEADBEEF
//
// Exit codes:
//   0  = all tests pass (GREEN)
//   11 = test 1 failed
//   12 = test 2 failed
//   13 = test 3 failed
//   14 = test 4 failed
//   15 = test 5 failed

import "../std/atom.mlr"
import "../std/sys.mlr"

@dynamic extern fn exit(uint64 code)
@dynamic extern fn puts(uint64 s) -> uint32

// Allocate a zeroed block.
fn _zalloc(uint64 sz) -> uint64 {
    uint64 p = alloc(sz)
    uint64 i = 0
    while i < sz {
        uint8 z = 0; unsafe { *((p + i) as uint8) = z }; i = i + 1
    }
    return p
}

// Build and return a packed record of 5 pointers: [ectx, ctx, ps, ws, image]
// each 8 bytes. Caller must free via _free_record.
// image_extra = extra bytes beyond offset 6 for operand bytes.
// Returns pointer to the 5-pointer record.
fn _make_state(uint64 image_extra,
               uint64 ps_dwords, uint64 ws_dwords) -> uint64 {
    uint64 img_sz = 6 + image_extra
    uint64 image  = _zalloc(img_sz)

    uint64 ctx = _zalloc(ATOM_CONTEXT_SIZE)
    unsafe { *((ctx + AC_OFF_IMAGE_BUF)  as uint64) = image }
    unsafe { *((ctx + AC_OFF_IMAGE_SIZE) as uint64) = img_sz }

    uint64 ps_buf = _zalloc(ps_dwords * 4 + 4)
    uint64 ws_buf = _zalloc(ws_dwords * 4 + 4)

    uint64 ectx = _zalloc(ATOM_EXEC_CONTEXT_SIZE)
    unsafe { *((ectx + AEC_OFF_CTX)     as uint64) = ctx }
    unsafe { *((ectx + AEC_OFF_PS)      as uint64) = ps_buf }
    unsafe { *((ectx + AEC_OFF_WS)      as uint64) = ws_buf }
    unsafe { *((ectx + AEC_OFF_PS_SIZE) as uint32) = ps_dwords }
    unsafe { *((ectx + AEC_OFF_WS_SIZE) as uint32) = ws_dwords }
    // ptr starts at offset 6 (start of "code" in the image).
    unsafe { *((ectx + AEC_OFF_PTR)     as uint64) = 6 }

    // Pack into a 5-pointer record: [ectx, ctx, ps, ws, image]
    uint64 rec = alloc(40)
    unsafe { *((rec + 0)  as uint64) = ectx }
    unsafe { *((rec + 8)  as uint64) = ctx  }
    unsafe { *((rec + 16) as uint64) = ps_buf }
    unsafe { *((rec + 24) as uint64) = ws_buf }
    unsafe { *((rec + 32) as uint64) = image }
    return rec
}

fn _free_state(uint64 rec) {
    uint64 ectx = 0; unsafe { *((rec + 0)  as uint64) -> ectx }
    uint64 ctx  = 0; unsafe { *((rec + 8)  as uint64) -> ctx }
    uint64 ps   = 0; unsafe { *((rec + 16) as uint64) -> ps }
    uint64 ws   = 0; unsafe { *((rec + 24) as uint64) -> ws }
    uint64 img  = 0; unsafe { *((rec + 32) as uint64) -> img }
    dealloc(ectx); dealloc(ctx); dealloc(ps); dealloc(ws); dealloc(img)
    dealloc(rec)
}

fn main() {
    // ------------------------------------------------------------------
    // Test 1: PS read at DWORD align.
    // attr = 0x01 (arg=ATOM_ARG_PS=1, align=ATOM_SRC_DWORD=0)
    // image[6] = 0x00  (PS slot index 0)
    // PS[0]    = 0x11223344 (LE: bytes 44 33 22 11)
    // expect   = 0x11223344
    // ------------------------------------------------------------------
    uint64 rec1 = _make_state(2, 2, 2)
    uint64 ectx1 = 0; unsafe { *((rec1 + 0)  as uint64) -> ectx1 }
    uint64 ps1   = 0; unsafe { *((rec1 + 16) as uint64) -> ps1 }
    uint64 img1  = 0; unsafe { *((rec1 + 32) as uint64) -> img1 }

    // Write PS[0] = 0x11223344 LE
    unsafe { *((ps1 + 0) as uint8) = 0x44 }
    unsafe { *((ps1 + 1) as uint8) = 0x33 }
    unsafe { *((ps1 + 2) as uint8) = 0x22 }
    unsafe { *((ps1 + 3) as uint8) = 0x11 }
    // Write PS slot index (0) into image[6]
    unsafe { *((img1 + 6) as uint8) = 0 }

    uint64 ptr_ptr1 = ectx1 + AEC_OFF_PTR
    uint64 r1 = _atom_get_src_int(ectx1, 0x01, ptr_ptr1, 0)
    _free_state(rec1)

    if r1 != 0x11223344 {
        puts("FAIL test1: PS@DWORD")
        exit(11)
    }
    puts("PASS test1: PS@DWORD")

    // ------------------------------------------------------------------
    // Test 2: WS read at DWORD align.
    // attr = 0x02 (arg=ATOM_ARG_WS=2, align=ATOM_SRC_DWORD=0)
    // image[6] = 0x00  (WS slot index 0, a regular slot < 0x40)
    // WS[0]    = 0x55667788 LE
    // expect   = 0x55667788
    // ------------------------------------------------------------------
    uint64 rec2 = _make_state(2, 2, 2)
    uint64 ectx2 = 0; unsafe { *((rec2 + 0)  as uint64) -> ectx2 }
    uint64 ws2   = 0; unsafe { *((rec2 + 24) as uint64) -> ws2 }
    uint64 img2  = 0; unsafe { *((rec2 + 32) as uint64) -> img2 }

    unsafe { *((ws2 + 0) as uint8) = 0x88 }
    unsafe { *((ws2 + 1) as uint8) = 0x77 }
    unsafe { *((ws2 + 2) as uint8) = 0x66 }
    unsafe { *((ws2 + 3) as uint8) = 0x55 }
    unsafe { *((img2 + 6) as uint8) = 0 }

    uint64 ptr_ptr2 = ectx2 + AEC_OFF_PTR
    uint64 r2 = _atom_get_src_int(ectx2, 0x02, ptr_ptr2, 0)
    _free_state(rec2)

    if r2 != 0x55667788 {
        puts("FAIL test2: WS@DWORD")
        exit(12)
    }
    puts("PASS test2: WS@DWORD")

    // ------------------------------------------------------------------
    // Test 3: IMM read at WORD align (ATOM_SRC_WORD0=1).
    // attr = 0x0D  (5 | (1<<3) = 13 = 0x0D)
    // image[6..7] = CD AB  (LE uint16 = 0xABCD)
    // expect = 0xABCD
    // ------------------------------------------------------------------
    uint64 rec3 = _make_state(4, 2, 2)
    uint64 ectx3 = 0; unsafe { *((rec3 + 0)  as uint64) -> ectx3 }
    uint64 img3  = 0; unsafe { *((rec3 + 32) as uint64) -> img3 }

    unsafe { *((img3 + 6) as uint8) = 0xCD }
    unsafe { *((img3 + 7) as uint8) = 0xAB }

    uint64 ptr_ptr3 = ectx3 + AEC_OFF_PTR
    uint64 r3 = _atom_get_src_int(ectx3, 0x0D, ptr_ptr3, 0)
    _free_state(rec3)

    if r3 != 0xABCD {
        puts("FAIL test3: IMM@WORD0")
        exit(13)
    }
    puts("PASS test3: IMM@WORD0")

    // ------------------------------------------------------------------
    // Test 4: IMM read at BYTE align (ATOM_SRC_BYTE0=4).
    // attr = 0x25  (5 | (4<<3) = 37 = 0x25)
    // image[6] = 0x42
    // expect = 0x42
    // ------------------------------------------------------------------
    uint64 rec4 = _make_state(2, 2, 2)
    uint64 ectx4 = 0; unsafe { *((rec4 + 0)  as uint64) -> ectx4 }
    uint64 img4  = 0; unsafe { *((rec4 + 32) as uint64) -> img4 }

    unsafe { *((img4 + 6) as uint8) = 0x42 }

    uint64 ptr_ptr4 = ectx4 + AEC_OFF_PTR
    uint64 r4 = _atom_get_src_int(ectx4, 0x25, ptr_ptr4, 0)
    _free_state(rec4)

    if r4 != 0x42 {
        puts("FAIL test4: IMM@BYTE0")
        exit(14)
    }
    puts("PASS test4: IMM@BYTE0")

    // ------------------------------------------------------------------
    // Test 5: WS put+get round-trip.
    // attr = 0x02  (arg=ATOM_ARG_WS=2, align=ATOM_SRC_DWORD=0)
    // image[6] = 0  (WS slot 0 for put)
    // image[7] = 0  (WS slot 0 for get)
    // put_dst with val=0xDEADBEEF, saved=0 (dword align = no merge needed)
    // then get_src_int on same slot => expect 0xDEADBEEF
    // ------------------------------------------------------------------
    uint64 rec5 = _make_state(4, 2, 4)
    uint64 ectx5 = 0; unsafe { *((rec5 + 0)  as uint64) -> ectx5 }
    uint64 img5  = 0; unsafe { *((rec5 + 32) as uint64) -> img5 }

    // Slot index 0 at both image[6] and image[7]
    unsafe { *((img5 + 6) as uint8) = 0 }
    unsafe { *((img5 + 7) as uint8) = 0 }

    uint64 ptr_ptr5 = ectx5 + AEC_OFF_PTR
    // Reset ptr to 6 for the put.
    unsafe { *(ptr_ptr5 as uint64) = 6 }
    // _atom_put_dst(ectx, arg, attr, ptr_ptr, val, saved)
    // DWORD align: mask=0xFFFFFFFF, shift=0, so val is stored as-is,
    // saved=0 => merged = (0xDEADBEEF & 0xFFFFFFFF) | (0 & ~0xFFFFFFFF) = 0xDEADBEEF
    _atom_put_dst(ectx5, 2, 0x02, ptr_ptr5, 0xDEADBEEF, 0)
    // ptr is now at 7; read back WS[0]
    uint64 r5 = _atom_get_src_int(ectx5, 0x02, ptr_ptr5, 0)
    _free_state(rec5)

    if r5 != 0xDEADBEEF {
        puts("FAIL test5: WS put+get round-trip")
        exit(15)
    }
    puts("PASS test5: WS put+get round-trip")

    puts("phase3_atom_operand_test: GREEN")
    exit(0)
}
