// phase3_atom_control_test.mlr — synthetic-bytecode smoke for ATOM opcode
// batch 2 (control flow): jump, calltable, switch, repeat, nop.
//
// 5 scenarios, each using a hand-built image buffer + atom_context.
// All observable results are written to a shared PS buffer (uint32[4])
// so that values survive after atom_execute_table frees the WS.

import "../std/atom.mlr"

@dynamic extern fn puts(uint64 s) -> uint32
@dynamic extern fn exit(uint64 code)

// ---- minimal puts helpers -----------------------------------------------

fn _p(uint64 s) { puts(s) }

// Write a uint64 as 8 hex digits.
fn _hex_u64(uint64 v) {
    uint64 buf = alloc(20)
    uint64 j = 0
    while j < 16 {
        uint64 sh = (15 - j) * 4
        uint64 nyb = (v >> sh) & 0xF
        uint8 ch = nyb + 48
        if nyb >= 10 { ch = nyb + 87 }
        unsafe { *((buf + j) as uint8) = ch }
        j = j + 1
    }
    uint8 nl = 10; unsafe { *((buf + 16) as uint8) = nl }
    uint8 nul = 0; unsafe { *((buf + 17) as uint8) = nul }
    puts(buf); dealloc(buf)
}

// ---- image builder helpers ----------------------------------------------

// Zero-fill a buffer region.
fn _zero(uint64 buf, uint64 off, uint64 n) {
    uint64 i = 0
    while i < n {
        uint8 z = 0; unsafe { *((buf + off + i) as uint8) = z }
        i = i + 1
    }
}

// Write a uint8.
fn _wb(uint64 buf, uint64 off, uint64 v) {
    uint8 b = v; unsafe { *((buf + off) as uint8) = b }
}

// Write a uint16 little-endian.
fn _ww(uint64 buf, uint64 off, uint64 v) {
    uint8 lo = v & 0xFF;      unsafe { *((buf + off)     as uint8) = lo }
    uint8 hi = (v >> 8) & 0xFF; unsafe { *((buf + off + 1) as uint8) = hi }
}

// Write a uint32 little-endian.
fn _wd(uint64 buf, uint64 off, uint64 v) {
    uint8 b0 = v & 0xFF;         unsafe { *((buf + off)     as uint8) = b0 }
    uint8 b1 = (v >> 8)  & 0xFF; unsafe { *((buf + off + 1) as uint8) = b1 }
    uint8 b2 = (v >> 16) & 0xFF; unsafe { *((buf + off + 2) as uint8) = b2 }
    uint8 b3 = (v >> 24) & 0xFF; unsafe { *((buf + off + 3) as uint8) = b3 }
}

// Write a cmd-table header at 'ct_off' inside 'buf':
//   CT_SIZE_PTR (u16 at +0): header(6) + bytecode_size
//   CT_WS_PTR   (u8  at +4): ws_dwords
//   CT_PS_PTR   (u8  at +5): ps_dwords
fn _write_ct_hdr(uint64 buf, uint64 ct_off, uint64 bc_size, uint64 ws, uint64 ps) {
    uint64 total = 6 + bc_size
    _ww(buf, ct_off + 0, total)        // CT_SIZE_PTR
    _ww(buf, ct_off + 2, 0)            // reserved
    _wb(buf, ct_off + 4, ws)           // CT_WS_PTR
    _wb(buf, ct_off + 5, ps)           // CT_PS_PTR
    // bytecode follows at ct_off + 6
}

// Allocate and initialise an atom_context with a synthetic image.
// Returns the ctx pointer (caller must dealloc ctx + image separately).
fn _make_ctx(uint64 image, uint64 img_size, uint64 cmd_list_off) -> uint64 {
    uint64 ctx = alloc(ATOM_CONTEXT_SIZE)
    uint64 i = 0
    while i < ATOM_CONTEXT_SIZE {
        uint8 z = 0; unsafe { *((ctx + i) as uint8) = z }; i = i + 1
    }
    unsafe { *((ctx + AC_OFF_IMAGE_BUF)      as uint64) = image }
    unsafe { *((ctx + AC_OFF_IMAGE_SIZE)     as uint64) = img_size }
    unsafe { *((ctx + AC_OFF_CMD_TABLE_BASE) as uint64) = cmd_list_off }
    return ctx
}

// Allocate a zeroed ps[] dword buffer (n dwords).
fn _make_ps(uint64 n) -> uint64 {
    uint64 buf = alloc(n * 4)
    uint64 i = 0
    while i < n * 4 {
        uint8 z = 0; unsafe { *((buf + i) as uint8) = z }; i = i + 1
    }
    return buf
}

// Read a uint32 from a ps[] buffer.
fn _ps_get(uint64 ps, uint64 idx) -> uint64 {
    uint32 v = 0; unsafe { *((ps + idx * 4) as uint32) -> v }
    uint64 r = v; return r
}

// =========================================================================
// Scenario 1 — jump-always: PS[0] should stay 0xAA (jump skips 0xBB move).
//
// Bytecode (offsets from bytecode_start):
//   +0: op=0x02, attr=0x05, ps_idx=0x00, 0xAA,0,0,0   (move PS[0]=0xAA, 7B)
//   +7: op=0x43,            0x11,0x00                   (jump ALWAYS, tgt=17, 3B)
//  +10: op=0x02, attr=0x05, ps_idx=0x00, 0xBB,0,0,0   (move PS[0]=0xBB, 7B — skipped)
//  +17: op=0x5B                                         (EOT)
// total bytecode = 18 bytes  →  CT_SIZE = 24 = 0x18
// =========================================================================
fn run_scenario_1() -> uint64 {
    uint64 IMG_SIZE  = 0x1000
    uint64 CT_OFF    = 0x300
    uint64 LIST_OFF  = 0x100

    uint64 image = alloc(IMG_SIZE)
    _zero(image, 0, IMG_SIZE)

    // cmd-list: not needed for direct call but set sensibly.
    _ww(image, LIST_OFF + 0, 0x0010)
    _ww(image, LIST_OFF + 4, CT_OFF)   // slot 0 → this table

    // cmd-table header.
    _write_ct_hdr(image, CT_OFF, 18, 2, 4)

    // bytecode at CT_OFF+6:
    uint64 bc = CT_OFF + 6
    _wb(image, bc+0,  0x02)           // op=2 (move PS)
    _wb(image, bc+1,  0x05)           // attr: DWORD, IMM src
    _wb(image, bc+2,  0x00)           // ps_idx=0
    _wd(image, bc+3,  0xAA)           // imm=0xAA
    _wb(image, bc+7,  0x43)           // op=67 (jump ALWAYS)
    // jump target is HEADER-relative per kernel atom_op_jump
    // (*ptr = ectx.start + target where start = cmd_table_offset).
    // Body byte 17 lives at header byte 17+6 = 23.
    _ww(image, bc+8,  23)             // target=body_17 → header-relative 23
    _wb(image, bc+10, 0x02)           // op=2 (move PS) — to be skipped
    _wb(image, bc+11, 0x05)
    _wb(image, bc+12, 0x00)
    _wd(image, bc+13, 0xBB)
    _wb(image, bc+17, 0x5B)           // EOT

    uint64 ctx = _make_ctx(image, IMG_SIZE, LIST_OFF)
    uint64 ps  = _make_ps(4)
    uint64 r   = atom_execute_table(ctx, CT_OFF, ps, 4)
    uint64 result = _ps_get(ps, 0)
    dealloc(ps); dealloc(ctx); dealloc(image)

    if r != 0 { return 0xDEAD0001 }
    return result
}

// =========================================================================
// Scenario 2 — jump-equal taken: compare PS[0]=5 vs IMM 5, equal → jump;
// "clear" move is skipped; PS[0] stays 5.
//
// Bytecode:
//   +0: op=0x02, attr=0x05, ps_idx=0x00, 5,0,0,0    (move PS[0]=5, 7B)
//   +7: op=0x3D, attr=0x05, ps_idx=0x00, 5,0,0,0    (compare PS, 7B)
//  +14: op=0x44,            0x18,0x00                (jump EQUAL, tgt=24, 3B)
//  +17: op=0x02, attr=0x05, ps_idx=0x00, 0,0,0,0    (move PS[0]=0, 7B — skipped)
//  +24: op=0x5B                                       (EOT)
// total bytecode = 25 bytes  →  CT_SIZE = 31 = 0x1F
// =========================================================================
fn run_scenario_2() -> uint64 {
    uint64 IMG_SIZE  = 0x1000
    uint64 CT_OFF    = 0x340
    uint64 LIST_OFF  = 0x100

    uint64 image = alloc(IMG_SIZE)
    _zero(image, 0, IMG_SIZE)

    _write_ct_hdr(image, CT_OFF, 25, 2, 4)

    uint64 bc = CT_OFF + 6
    // move PS[0]=5
    _wb(image, bc+0,  0x02)
    _wb(image, bc+1,  0x05)
    _wb(image, bc+2,  0x00)
    _wd(image, bc+3,  5)
    // compare PS (op=61=0x3D), attr=0x05, ps_idx=0x00, imm=5
    _wb(image, bc+7,  0x3D)
    _wb(image, bc+8,  0x05)
    _wb(image, bc+9,  0x00)
    _wd(image, bc+10, 5)
    // jump EQUAL (op=68=0x44), header-relative target.
    // Body byte 24 = header byte 30.
    _wb(image, bc+14, 0x44)
    _ww(image, bc+15, 30)
    // move PS[0]=0  (will be skipped)
    _wb(image, bc+17, 0x02)
    _wb(image, bc+18, 0x05)
    _wb(image, bc+19, 0x00)
    _wd(image, bc+20, 0)
    // EOT
    _wb(image, bc+24, 0x5B)

    uint64 ctx = _make_ctx(image, IMG_SIZE, LIST_OFF)
    uint64 ps  = _make_ps(4)
    uint64 r   = atom_execute_table(ctx, CT_OFF, ps, 4)
    uint64 result = _ps_get(ps, 0)
    dealloc(ps); dealloc(ctx); dealloc(image)

    if r != 0 { return 0xDEAD0002 }
    return result
}

// =========================================================================
// Scenario 3 — jump-equal NOT taken: compare PS[0]=5 vs IMM 7 → not equal;
// fall through to move PS[0]=99.
//
// Bytecode: identical layout to scenario 2 but compare imm=7, fallthrough
// move imm=99.
// =========================================================================
fn run_scenario_3() -> uint64 {
    uint64 IMG_SIZE  = 0x1000
    uint64 CT_OFF    = 0x380
    uint64 LIST_OFF  = 0x100

    uint64 image = alloc(IMG_SIZE)
    _zero(image, 0, IMG_SIZE)

    _write_ct_hdr(image, CT_OFF, 25, 2, 4)

    uint64 bc = CT_OFF + 6
    // move PS[0]=5
    _wb(image, bc+0,  0x02)
    _wb(image, bc+1,  0x05)
    _wb(image, bc+2,  0x00)
    _wd(image, bc+3,  5)
    // compare PS[0] vs IMM 7 → last_dst = 5-7 (wraps → cs_equal=0)
    _wb(image, bc+7,  0x3D)
    _wb(image, bc+8,  0x05)
    _wb(image, bc+9,  0x00)
    _wd(image, bc+10, 7)
    // jump EQUAL (NOT taken), target=24 (past the move below)
    _wb(image, bc+14, 0x44)
    _ww(image, bc+15, 24)
    // move PS[0]=99 (executed since jump not taken)
    _wb(image, bc+17, 0x02)
    _wb(image, bc+18, 0x05)
    _wb(image, bc+19, 0x00)
    _wd(image, bc+20, 99)
    // EOT
    _wb(image, bc+24, 0x5B)

    uint64 ctx = _make_ctx(image, IMG_SIZE, LIST_OFF)
    uint64 ps  = _make_ps(4)
    uint64 r   = atom_execute_table(ctx, CT_OFF, ps, 4)
    uint64 result = _ps_get(ps, 0)
    dealloc(ps); dealloc(ctx); dealloc(image)

    if r != 0 { return 0xDEAD0003 }
    return result
}

// =========================================================================
// Scenario 4 — calltable: main table (cmd idx=0) calls sub (cmd idx=1).
//   main: move PS[0]=1; calltable idx=1; EOT
//   sub:  move PS[1]=42; EOT
// PS is shared; after run: PS[0]=1, PS[1]=42.
//
// cmd-list layout at LIST_OFF=0x100:
//   [0-1]: size
//   [4-5]: uint16 = 0x200  (slot 0 → main table)
//   [6-7]: uint16 = 0x280  (slot 1 → sub table)
//
// main table at 0x200 (bytecode=10 bytes → CT_SIZE=16):
//   +0: 0x02, 0x05, 0x00, 1,0,0,0  (move PS[0]=1, 7B)
//   +7: 0x52, 0x01                  (calltable idx=1, 2B)
//   +9: 0x5B                        (EOT)
//
// sub table at 0x280 (bytecode=8 bytes → CT_SIZE=14):
//   +0: 0x02, 0x05, 0x01, 42,0,0,0 (move PS[1]=42, 7B)
//   +7: 0x5B                        (EOT)
// =========================================================================
fn run_scenario_4(uint64 out_ps1) -> uint64 {
    uint64 IMG_SIZE  = 0x1000
    uint64 LIST_OFF  = 0x100
    uint64 MAIN_OFF  = 0x200
    uint64 SUB_OFF   = 0x280

    uint64 image = alloc(IMG_SIZE)
    _zero(image, 0, IMG_SIZE)

    // cmd-list header.
    _ww(image, LIST_OFF + 0, 0x0010)  // size
    _ww(image, LIST_OFF + 2, 0x0000)  // reserved
    _ww(image, LIST_OFF + 4, MAIN_OFF) // slot 0 → main
    _ww(image, LIST_OFF + 6, SUB_OFF)  // slot 1 → sub

    // main table
    _write_ct_hdr(image, MAIN_OFF, 10, 2, 4)
    uint64 bc = MAIN_OFF + 6
    _wb(image, bc+0, 0x02); _wb(image, bc+1, 0x05); _wb(image, bc+2, 0x00)
    _wd(image, bc+3, 1)           // move PS[0]=1
    _wb(image, bc+7, 0x52)        // calltable
    _wb(image, bc+8, 0x01)        // idx=1
    _wb(image, bc+9, 0x5B)        // EOT

    // sub table
    _write_ct_hdr(image, SUB_OFF, 8, 2, 4)
    uint64 bc2 = SUB_OFF + 6
    _wb(image, bc2+0, 0x02); _wb(image, bc2+1, 0x05); _wb(image, bc2+2, 0x01)
    _wd(image, bc2+3, 42)         // move PS[1]=42
    _wb(image, bc2+7, 0x5B)       // EOT

    uint64 ctx = _make_ctx(image, IMG_SIZE, LIST_OFF)
    uint64 ps  = _make_ps(4)
    uint64 r   = atom_execute_table(ctx, MAIN_OFF, ps, 4)
    uint64 ps0 = _ps_get(ps, 0)
    uint64 ps1 = _ps_get(ps, 1)
    unsafe { *(out_ps1 as uint64) = ps1 }
    dealloc(ps); dealloc(ctx); dealloc(image)

    if r != 0 { return 0xDEAD0004 }
    return ps0
}

// =========================================================================
// Scenario 5 — nop sequence: two nops then move PS[0]=7, EOT.
// PS[0] should be 7.
//
// Bytecode (10 bytes → CT_SIZE=16):
//   +0: 0x5A        (nop)
//   +1: 0x5A        (nop)
//   +2: 0x02, 0x05, 0x00, 7,0,0,0  (move PS[0]=7, 7B)
//   +9: 0x5B        (EOT)
// =========================================================================
fn run_scenario_5() -> uint64 {
    uint64 IMG_SIZE  = 0x1000
    uint64 CT_OFF    = 0x3C0
    uint64 LIST_OFF  = 0x100

    uint64 image = alloc(IMG_SIZE)
    _zero(image, 0, IMG_SIZE)

    _write_ct_hdr(image, CT_OFF, 10, 2, 4)

    uint64 bc = CT_OFF + 6
    _wb(image, bc+0, 0x5A)           // nop
    _wb(image, bc+1, 0x5A)           // nop
    _wb(image, bc+2, 0x02)           // move PS
    _wb(image, bc+3, 0x05)           // attr
    _wb(image, bc+4, 0x00)           // ps_idx=0
    _wd(image, bc+5, 7)              // imm=7
    _wb(image, bc+9, 0x5B)           // EOT

    uint64 ctx = _make_ctx(image, IMG_SIZE, LIST_OFF)
    uint64 ps  = _make_ps(4)
    uint64 r   = atom_execute_table(ctx, CT_OFF, ps, 4)
    uint64 result = _ps_get(ps, 0)
    dealloc(ps); dealloc(ctx); dealloc(image)

    if r != 0 { return 0xDEAD0005 }
    return result
}

// =========================================================================
// main
// =========================================================================
fn main() {
    uint64 pass = 0
    uint64 fail = 0

    puts("phase3_atom_control_test")
    puts("========================")

    // --- scenario 1: jump-always ---
    uint64 s1 = run_scenario_1()
    if s1 == 0xAA {
        puts("PASS  1  jump-always taken  PS[0]=0xAA")
        pass = pass + 1
    } else {
        puts("FAIL  1  jump-always  got:")
        _hex_u64(s1)
        fail = fail + 1
    }

    // --- scenario 2: jump-equal taken ---
    uint64 s2 = run_scenario_2()
    if s2 == 5 {
        puts("PASS  2  jump-equal taken  PS[0]=5")
        pass = pass + 1
    } else {
        puts("FAIL  2  jump-equal taken  got:")
        _hex_u64(s2)
        fail = fail + 1
    }

    // --- scenario 3: jump-equal NOT taken ---
    uint64 s3 = run_scenario_3()
    if s3 == 99 {
        puts("PASS  3  jump-equal not-taken  PS[0]=99")
        pass = pass + 1
    } else {
        puts("FAIL  3  jump-equal not-taken  got:")
        _hex_u64(s3)
        fail = fail + 1
    }

    // --- scenario 4: calltable ---
    uint64 s4ps1_storage = alloc(8)
    unsafe { *(s4ps1_storage as uint64) = 0 }
    uint64 s4 = run_scenario_4(s4ps1_storage)
    uint64 s4ps1 = 0; unsafe { *(s4ps1_storage as uint64) -> s4ps1 }
    dealloc(s4ps1_storage)
    if s4 == 1 && s4ps1 == 42 {
        puts("PASS  4  calltable  PS[0]=1 PS[1]=42")
        pass = pass + 1
    } else {
        puts("FAIL  4  calltable  PS[0]:")
        _hex_u64(s4)
        puts("FAIL  4  calltable  PS[1]:")
        _hex_u64(s4ps1)
        fail = fail + 1
    }

    // --- scenario 5: nop ---
    uint64 s5 = run_scenario_5()
    if s5 == 7 {
        puts("PASS  5  nop-sequence  PS[0]=7")
        pass = pass + 1
    } else {
        puts("FAIL  5  nop-sequence  got:")
        _hex_u64(s5)
        fail = fail + 1
    }

    // --- summary ---
    puts("========================")
    if fail == 0 {
        puts("ALL PASS 5/5")
        exit(0)
    } else {
        puts("SOME FAILURES")
        exit(1)
    }
}
