// repack_abw_to_baw_f32 — [A,B,W] (a-major) → [B,A,W] (b-major) tensor repack.
//
// in[a,b,w]  at (a*B + b)*W + w        out[b,a,w] at (b*A + a)*W + w
//
// NAME-ROUTED stub: real ISA emitted by amdgpu_lower_repack_abw_to_baw_f32 in
// src/format_amdgpu.mlr.  Used by the multi-dispatch WZMA backward to convert
// the V/U gemm outputs inter[K,BS,R] / outk[K,BS,D] (k-major) into the
// [BS,K,*] (bs-major) layout the wzma_bwd helper reads.
//
// Grid: A*B blocks × W threads.
//
// Build:
//   ./build/mlrc --arch=x86_64 --target=amdgpu-native \
//       examples/llm/repack_abw_to_baw_f32.mlr -o /tmp/repack_abw_to_baw_f32

fn block_idx_x() -> uint64 { return 0 }
fn tid_local_x() -> uint64 { return 0 }

@kernel
fn repack_abw_to_baw_f32(uint64 in_ptr, uint64 out_ptr, uint64 A, uint64 B, uint64 W) {
    uint64 g = block_idx_x()
    uint64 d = tid_local_x()
    if d < W {
        uint64 a = g / B
        uint64 b = g - a * B
        f32 v = 0.0
        unsafe { *((in_ptr + (g * W + d) * 4) as f32) -> v }
        unsafe { *((out_ptr + ((b * A + a) * W + d) * 4) as f32) = v }
    }
}

fn main() { exit(0) }
