// Smoke test for the multi-shard safetensors loader on the real
// Qwen3-14B model (8 shards, ~28 GB total).  Verifies:
//   - all 8 shards open
//   - lookup of tensors known to live in shard 0 (e.g. embed_tokens)
//   - lookup of tensors known to live in shard 7 (e.g. lm_head)
//   - lookup of layer 0 vs layer 35 (which span different shards)
//
// Build:
//   ./build/mlrc --arch=x86_64 examples/llm/safetensors_shard_smoke.mlr -o /tmp/safetensors_shard_smoke
// Run:
//   /tmp/safetensors_shard_smoke

import "../../std/io.mlr"
import "../../std/fmt.mlr"
import "../../std/string.mlr"
import "../../std/safetensors.mlr"

@dynamic extern fn exit(uint64 code)

fn check(u64 ok, u64 label) {
    print_str(label)
    if ok != 0 { print_str(": OK\n") }
    else       { print_str(": FAIL\n"); exit(1) }
}

fn main() {
    u64 dir = "/home/pantelis/Desktop/Projects/Work/MLRift-experimental/Qwen3-14b"
    SafetensorShard sh = safetensors_shard_open(dir, 8)

    print_str("opened "); u64 sn = fmt_dec(sh.n_shards); print_str(sn); dealloc(sn); print_str(" shards\n")
    if sh.n_shards != 8 {
        print_str("FAIL: expected 8 shards\n")
        exit(1)
    }

    // Tensor known in shard 0:
    SafetensorView v_embed = safetensors_shard_get(sh, "model.embed_tokens.weight")
    if v_embed.ptr != 0 && v_embed.len != 0 {
        print_str("model.embed_tokens.weight: OK len=")
        u64 sl = fmt_dec(v_embed.len); print_str(sl); dealloc(sl); print_str("\n")
    } else {
        print_str("model.embed_tokens.weight: FAIL\n"); exit(1)
    }

    // Tensor known in shard 7:
    SafetensorView v_lmh = safetensors_shard_get(sh, "lm_head.weight")
    if v_lmh.ptr != 0 && v_lmh.len != 0 {
        print_str("lm_head.weight: OK len=")
        u64 sl = fmt_dec(v_lmh.len); print_str(sl); dealloc(sl); print_str("\n")
    } else {
        print_str("lm_head.weight: FAIL\n"); exit(1)
    }

    // Layer 0 q_proj (shard 0):
    SafetensorView v_l0q = safetensors_shard_get(sh, "model.layers.0.self_attn.q_proj.weight")
    if v_l0q.ptr != 0 { print_str("layer 0 q_proj: OK\n") } else { print_str("layer 0 q_proj: FAIL\n"); exit(1) }

    // Layer 35 q_proj (likely later shard):
    SafetensorView v_l35q = safetensors_shard_get(sh, "model.layers.35.self_attn.q_proj.weight")
    if v_l35q.ptr != 0 { print_str("layer 35 q_proj: OK\n") } else { print_str("layer 35 q_proj: FAIL\n"); exit(1) }

    // Final norm:
    SafetensorView v_norm = safetensors_shard_get(sh, "model.norm.weight")
    if v_norm.ptr != 0 { print_str("model.norm: OK\n") } else { print_str("model.norm: FAIL\n"); exit(1) }

    // Dtype check: should be BF16 (= 3) for all weights.
    u64 dt = safetensors_shard_dtype(sh, "model.embed_tokens.weight")
    print_str("embed_tokens dtype="); u64 sd = fmt_dec(dt); print_str(sd); dealloc(sd)
    if dt == 3 { print_str(" (BF16, OK)\n") } else { print_str(" (UNEXPECTED)\n"); exit(1) }

    safetensors_shard_free(sh)
    print_str("\nALL OK\n")
    exit(0)
}
