// Slice 4.1 launcher — cross-WG global-barrier microbench.
//
// Loads /tmp/mega_barrier_microbench.co (built from the matching
// .hip.cpp via hipcc) and times it across (n_wgs, n_iters) sweeps
// to derive per-barrier cost.
//
// Per-barrier cost = (kernel_wall - launch_overhead) / n_iters
//
// Slice 4 design assumes 5-10 µs per barrier at WG_PERSIST=256.
// If we measure materially more, slice 4 needs a redesign.
//
// Build:
//   hipcc --offload-arch=gfx1100 --genco -O3 \
//       examples/llm/mega_barrier_microbench.hip.cpp \
//       -o /tmp/mega_barrier_microbench.co
//   ./build/mlrc --arch=x86_64 --target=amdgpu-native \
//       examples/llm/mega_barrier_microbench_launch.mlr \
//       -o /tmp/mega_barrier_microbench_launch
// Run:
//   /tmp/mega_barrier_microbench_launch

import "../../std/hip.mlr"
import "../../std/time.mlr"

@dynamic extern fn puts(uint64 s) -> uint32
@dynamic extern fn write(int32 fd, uint64 buf, uint64 n) -> int64
@dynamic extern fn exit(uint64 code)

fn u64_dec(uint64 val, uint64 buf) -> uint64 {
    if val == 0 { uint8 z = 48; unsafe { *(buf as uint8) = z }; return 1 }
    uint64 n = 0; uint64 t = val
    while t > 0 { n = n + 1; t = t / 10 }
    uint64 i = n; t = val
    while i > 0 {
        i = i - 1
        uint64 d = t - (t / 10) * 10
        uint8 c = d + 48
        uint64 p = buf + i; unsafe { *(p as uint8) = c }
        t = t / 10
    }
    return n
}

fn put_kv(uint64 label, uint64 lab_len, uint64 v) {
    uint64 buf = alloc(96)
    uint64 i = 0
    while i < lab_len {
        uint64 sp = label + i; uint64 c = 0; unsafe { *(sp as uint8) -> c }
        uint64 dp = buf + i; uint8 cb = c; unsafe { *(dp as uint8) = cb }
        i = i + 1
    }
    uint64 sep_p = buf + lab_len
    uint8 eq = 61; unsafe { *(sep_p as uint8) = eq }
    uint64 num_p = buf + lab_len + 1
    uint64 nl = u64_dec(v, num_p)
    uint64 nul_p = buf + lab_len + 1 + nl
    uint8 nul = 0; unsafe { *(nul_p as uint8) = nul }
    puts(buf)
}

fn die(uint64 msg, uint64 code) { puts(msg); put_kv("err", 3, code); exit(1) }

// Run the kernel once and return the wall-clock kernel duration in
// nanoseconds.  Resets the global counter to zero before launch (the
// kernel relies on counter starting at 0 for the iter-expectation
// arithmetic).
fn run_once(uint64 fh, uint64 d_counter, uint64 n_wgs, uint64 n_iters) -> uint64 {
    // Zero the counter.  hipMemset isn't in the shim's public
    // surface; the simplest path is a host-side write through
    // host-mapped VRAM.  hipMalloc backs onto dev_alloc_smart_hostvis
    // which gives a host pointer for kind=1 / kind=2 allocations.
    // We use hipMemcpy(d, h_zeros, 4, kind=1) — robust regardless.
    uint64 h_zero = alloc(4)
    uint32 z = 0; unsafe { *(h_zero as uint32) = z }
    uint32 e_clear = hipMemcpy(d_counter, h_zero, 4, 1)
    if e_clear != 0 { die("clear counter", e_clear) }

    // Build kernarg slots. uint values go in 8-byte slots (low 4
    // bytes used, high zero).
    uint64 k_ctr   = alloc(8); unsafe { *(k_ctr   as uint64) = d_counter }
    uint64 k_nwgs  = alloc(8); unsafe { *(k_nwgs  as uint64) = n_wgs }
    uint64 k_iter  = alloc(8); unsafe { *(k_iter  as uint64) = n_iters }
    uint64 kp = alloc(3 * 8)
    unsafe { *((kp +  0) as uint64) = k_ctr  }
    unsafe { *((kp +  8) as uint64) = k_nwgs }
    unsafe { *((kp + 16) as uint64) = k_iter }

    uint64 t0 = time_now()
    uint32 err = hipModuleLaunchKernel(fh, n_wgs, 1, 1, 32, 1, 1, 0, 0, kp, 0)
    if err != 0 { die("launch", err) }
    err = hipDeviceSynchronize()
    if err != 0 { die("sync", err) }
    uint64 elapsed_ns = time_elapsed(t0)

    // Free the per-call kernarg holders so they don't accumulate.
    dealloc(kp); dealloc(k_iter); dealloc(k_nwgs); dealloc(k_ctr); dealloc(h_zero)
    return elapsed_ns
}

fn main() {
    uint32 err = hipSetDevice(0); if err != 0 { die("setDev", err) }

    uint64 fd = file_open("/tmp/mega_barrier_microbench.co", 0)
    if fd > 0xFFFFFFFFFFFFF000 {
        puts("missing /tmp/mega_barrier_microbench.co")
        puts("build with: hipcc --offload-arch=gfx1100 --genco -O3 \\")
        puts("              examples/llm/mega_barrier_microbench.hip.cpp \\")
        puts("              -o /tmp/mega_barrier_microbench.co")
        exit(1)
    }
    uint64 sz = file_size(fd); uint64 blob = alloc(sz)
    file_read(fd, blob, sz); file_close(fd)
    uint64 mod_slot = alloc(8)
    err = hipModuleLoadData(mod_slot, blob); if err != 0 { die("LoadData", err) }
    uint64 mod = 0; unsafe { *(mod_slot as uint64) -> mod }
    uint64 fh_slot = alloc(8)
    err = hipModuleGetFunction(fh_slot, mod, "mega_barrier_microbench")
    if err != 0 { die("getFn", err) }
    uint64 fh = 0; unsafe { *(fh_slot as uint64) -> fh }

    // Single-dword counter.
    uint64 d_counter = 0
    uint64 cslot = alloc(8); err = hipMalloc(cslot, 4); if err != 0 { die("malloc counter", err) }
    unsafe { *(cslot as uint64) -> d_counter }

    // Warm-up: kernel-load + first-launch overhead is bumpy, run once
    // and discard.  Tiny shape so warm-up doesn't wedge if barriers
    // are slow.
    uint64 warm = run_once(fh, d_counter, 4, 4)
    put_kv("warmup_ns", 9, warm)

    // Sweep WG counts.  At each WG count, run with B=1 (just launch
    // overhead) and B=B_HI; per-barrier cost = (B_HI - B=1) / (B_HI - 1).
    // Anchoring on the empty-launch baseline removes launch+sync
    // overhead from the measurement.
    uint64 wgs = alloc(6 * 8)
    unsafe { *((wgs +  0) as uint64) =  16 }
    unsafe { *((wgs +  8) as uint64) =  32 }
    unsafe { *((wgs + 16) as uint64) =  64 }
    unsafe { *((wgs + 24) as uint64) = 128 }
    unsafe { *((wgs + 32) as uint64) = 256 }
    unsafe { *((wgs + 40) as uint64) = 480 }
    uint64 B_HI = 1000
    uint64 wi = 0
    while wi < 6 {
        uint64 n_wgs = 0; unsafe { *((wgs + wi * 8) as uint64) -> n_wgs }

        // Each measurement averaged over 3 runs (kernels jitter under DPM).
        uint64 lo_sum = 0
        uint64 hi_sum = 0
        uint64 r = 0
        while r < 3 {
            uint64 lo = run_once(fh, d_counter, n_wgs, 1)
            uint64 hi = run_once(fh, d_counter, n_wgs, B_HI)
            lo_sum = lo_sum + lo
            hi_sum = hi_sum + hi
            r = r + 1
        }
        uint64 lo_ns = lo_sum / 3
        uint64 hi_ns = hi_sum / 3

        // Per-barrier ns = (hi - lo) / (B_HI - 1).
        uint64 net_ns  = 0
        if hi_ns > lo_ns { net_ns = hi_ns - lo_ns }
        uint64 per_barrier_ns = net_ns / (B_HI - 1)

        puts("---")
        put_kv("n_wgs",         5, n_wgs)
        put_kv("lo_ns_B=1",     9, lo_ns)
        put_kv("hi_ns_B=1000", 12, hi_ns)
        put_kv("per_barrier_ns",14, per_barrier_ns)
        // Convenience: us with 0.001 round-down (integer div).
        uint64 per_barrier_us = per_barrier_ns / 1000
        put_kv("per_barrier_us",14, per_barrier_us)

        wi = wi + 1
    }

    // Slice 4 budget gate.  At WG_PERSIST=256, total barrier cost
    // per token = per_barrier_us × 7 barriers × 28 layers.  Slice 4
    // saves ~6.7 ms launch overhead.  If barrier cost > 4 ms (= ~20
    // µs per barrier), slice 4 needs a redesign.
    puts("---")
    puts("decision rule: at n_wgs=256, per_barrier_us × 196 < 4000 ⇒ slice 4 OK")

    // Slice 4.2 dry-run: simulate what one mega-kernel layer dispatch
    // looks like (256 WGs × 7 barriers).  This is the skeleton's
    // wall-time at the chosen production shape — should be <5 µs of
    // real work plus launch+sync overhead.
    puts("---")
    puts("[slice 4.2 dry-run: 256 WGs × 7 barriers per kernel = 1 mega-layer-dispatch worth of barrier traffic]")
    uint64 r2 = 0
    uint64 sum_ns = 0
    while r2 < 10 {
        uint64 ns = run_once(fh, d_counter, 256, 7)
        sum_ns = sum_ns + ns
        r2 = r2 + 1
    }
    uint64 mean_ns = sum_ns / 10
    put_kv("dry_run_kernel_ns_mean_of_10", 28, mean_ns)
    // 28 layers × this = projected mega-kernel barrier+launch overhead per token.
    uint64 per_token_us = (mean_ns * 28) / 1000
    put_kv("projected_28x_us_per_token",   26, per_token_us)

    hipFree(d_counter)
    exit(0)
}
