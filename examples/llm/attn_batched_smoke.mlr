// Standalone smoke for attn_decode_f32_batched at batch=2.
// Tests the wg_y=batch_idx addressing fix (slice 2.4-pre).

import "../../std/hip.mlr"
import "../../std/kfd.mlr"
import "../../std/io.mlr"
import "../../std/fmt.mlr"
import "../../std/string.mlr"
import "../../std/math_float.mlr"
import "../../std/inference_gpu.mlr"

@dynamic extern fn exit(uint64 code)
fn die(uint64 m, uint64 c) { print_str(m); print_str(" e="); u64 s = fmt_dec(c); print_str(s); dealloc(s); print_str("\n"); exit(1) }

fn main() {
    uint32 err = hipSetDevice(0); if err != 0 { die("setDev", err) }

    // Simulate qwen3_generate's startup KV-cache GTT alloc.
    u64 dummy_slot = alloc(8); hipMalloc(dummy_slot, 64)
    u64 dummy_va = 0; unsafe { *(dummy_slot as u64) -> dummy_va }
    hipFree(dummy_va)
    u64 big1 = dev_try_alloc_host_visible(58720256)  // 56 MB (qwen3 KV cache size at batch=2)
    u64 big2 = dev_try_alloc_host_visible(58720256)
    print_str("simulated KV cache GTT allocated\n")

    // Simulate qwen3_generate's lazy GPU init (loads ~25 .co files).
    if gpu_matmul_enabled() == 1 { print_str("gpu_matmul_enabled\n") }
    else { print_str("gpu_matmul NOT enabled\n") }

    u64 fd = file_open("/tmp/attn_decode_f32_batched.co", 0)
    if fd > 0xFFFFFFFFFFFFF000 { die("missing co", 0) }
    u64 sz = file_size(fd); u64 blob = alloc(sz)
    file_read(fd, blob, sz); file_close(fd)
    u64 mod_slot = alloc(8)
    err = hipModuleLoadData(mod_slot, blob); if err != 0 { die("LoadData", err) }
    u64 mod = 0; unsafe { *(mod_slot as u64) -> mod }
    u64 fh_slot = alloc(8)
    err = hipModuleGetFunction(fh_slot, mod, "attn_decode_f32_batched"); if err != 0 { die("getFn", err) }
    u64 fh = 0; unsafe { *(fh_slot as u64) -> fh }
    print_str("attn_decode_f32_batched loaded\n")

    u64 nh = 16; u64 nkv = 8; u64 hd = 128
    u64 q_dim = nh * hd      // 2048
    u64 max_seq = 64
    u64 batch = 2
    u64 pos_plus_1 = 1       // single position per batch (pos=0)

    u64 q_bytes  = batch * q_dim * 4
    u64 out_bytes = q_bytes
    u64 kv_bytes = batch * max_seq * nkv * hd * 4   // 2 * 262144

    u64 d_q = 0; u64 d_kc = 0; u64 d_vc = 0; u64 d_out = 0
    u64 slot
    slot = alloc(8); err = hipMalloc(slot, q_bytes);   if err != 0 { die("mq", err) }; unsafe { *(slot as u64) -> d_q }
    slot = alloc(8); err = hipMalloc(slot, kv_bytes);  if err != 0 { die("mkc", err) }; unsafe { *(slot as u64) -> d_kc }
    slot = alloc(8); err = hipMalloc(slot, kv_bytes);  if err != 0 { die("mvc", err) }; unsafe { *(slot as u64) -> d_vc }
    slot = alloc(8); err = hipMalloc(slot, out_bytes); if err != 0 { die("mo", err) }; unsafe { *(slot as u64) -> d_out }

    // Q[b, h, j] = (b+1)*0.001*(h+1) + j*0.0001
    u64 h_q = alloc(q_bytes)
    u64 i = 0
    while i < batch * nh * hd {
        u64 b = i / (nh * hd)
        u64 ih  = (i / hd) % nh
        u64 ij  = i % hd
        f64 v = (int_to_f64(b) + 1.0) * 0.001 * (int_to_f64(ih) + 1.0) + int_to_f64(ij) * 0.0001
        unsafe { *((h_q + i * 4) as f32) = f64_to_f32(v) }
        i = i + 1
    }
    err = hipMemcpy(d_q, h_q, q_bytes, 1); if err != 0 { die("H2D q", err) }

    // K cache pattern: K[b, t, kvh, j] = (b+1)*10 + (t+1)*0.01 + kvh*0.001 + j*0.0001
    u64 h_kc = alloc(kv_bytes)
    i = 0
    while i < batch * max_seq * nkv * hd {
        u64 ib  = i / (max_seq * nkv * hd)
        u64 ipos = (i / (nkv * hd)) % max_seq
        u64 ikv  = (i / hd) % nkv
        u64 ij   = i % hd
        f64 v = (int_to_f64(ib) + 1.0) * 10.0 + (int_to_f64(ipos) + 1.0) * 0.01 + int_to_f64(ikv) * 0.001 + int_to_f64(ij) * 0.0001
        unsafe { *((h_kc + i * 4) as f32) = f64_to_f32(v) }
        i = i + 1
    }
    err = hipMemcpy(d_kc, h_kc, kv_bytes, 1); if err != 0 { die("H2D kc", err) }

    u64 h_vc = alloc(kv_bytes)
    i = 0
    while i < batch * max_seq * nkv * hd {
        u64 ib  = i / (max_seq * nkv * hd)
        u64 ipos = (i / (nkv * hd)) % max_seq
        u64 ikv  = (i / hd) % nkv
        u64 ij   = i % hd
        f64 v = (int_to_f64(ib) + 1.0) * 20.0 + (int_to_f64(ipos) + 1.0) * 0.02 + int_to_f64(ikv) * 0.002 + int_to_f64(ij) * 0.0002
        unsafe { *((h_vc + i * 4) as f32) = f64_to_f32(v) }
        i = i + 1
    }
    err = hipMemcpy(d_vc, h_vc, kv_bytes, 1); if err != 0 { die("H2D vc", err) }

    // Build kernarg.
    u64 a0 = alloc(8); unsafe { *(a0 as u64) = d_q }
    u64 a1 = alloc(8); unsafe { *(a1 as u64) = d_kc }
    u64 a2 = alloc(8); unsafe { *(a2 as u64) = d_vc }
    u64 a3 = alloc(8); unsafe { *(a3 as u64) = d_out }
    u64 a4 = alloc(8); unsafe { *(a4 as u64) = pos_plus_1 }
    u64 kp = alloc(5 * 8)
    unsafe { *(kp        as u64) = a0 }
    unsafe { *((kp +  8) as u64) = a1 }
    unsafe { *((kp + 16) as u64) = a2 }
    unsafe { *((kp + 24) as u64) = a3 }
    unsafe { *((kp + 32) as u64) = a4 }

    err = hipModuleLaunchKernel(fh, nh, batch, 1, 32, 1, 1, 0, 0, kp, 0)
    if err != 0 { die("launch", err) }
    err = hipDeviceSynchronize(); if err != 0 { die("sync", err) }

    u64 h_out = alloc(out_bytes)
    err = hipMemcpy(h_out, d_out, out_bytes, 2); if err != 0 { die("D2H", err) }

    // Reference: at pos=0 (pos_plus_1=1), softmax = [1.0], so out[b, h, j] = V[b, 0, h>>1, j].
    u64 fail = 0
    f32 max_abs = 0.0f
    u64 b = 0
    while b < batch {
        u64 head = 0
        while head < nh {
            u64 kvh = head / 2
            u64 j = 0
            while j < hd {
                u64 v_idx = b * max_seq * nkv * hd + 0 * nkv * hd + kvh * hd + j
                u64 out_idx = b * nh * hd + head * hd + j
                f32 expected = 0.0f; unsafe { *((h_vc + v_idx * 4) as f32) -> expected }
                f32 actual = 0.0f; unsafe { *((h_out + out_idx * 4) as f32) -> actual }
                // NaN detect via bit pattern (any > thresh check returns
                // false for NaN, so threshold-only verifies are misleading).
                u32 actbits = 0; unsafe { *((h_out + out_idx * 4) as u32) -> actbits }
                u64 is_nan = 0
                if (actbits & 0x7F800000) == 0x7F800000 { if (actbits & 0x007FFFFF) != 0 { is_nan = 1 } }
                f32 d = actual - expected; if d < 0.0f { d = 0.0f - d }
                if d > max_abs { max_abs = d }
                f32 abs_e = expected; if abs_e < 0.0f { abs_e = 0.0f - abs_e }
                f32 thresh = abs_e * 0.001f; if thresh < 0.00001f { thresh = 0.00001f }
                if is_nan == 1 { fail = fail + 1 }
                else { if d > thresh { fail = fail + 1 } }
                j = j + 1
            }
            head = head + 1
        }
        b = b + 1
    }

    u64 total = batch * nh * hd
    print_str("attn_batched fail count: "); u64 sf = fmt_dec(fail); print_str(sf); dealloc(sf)
    print_str(" / "); u64 stot = fmt_dec(total); print_str(stot); dealloc(stot); print_str("\n")
    if fail == 0 { print_str("OK — attn_batched batch=2 single-pos = V[b, 0]\n"); exit(0) }
    else         { print_str("FAIL\n"); exit(1) }
}
