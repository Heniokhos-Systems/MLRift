import "../../std/io.mlr"
import "../../std/fmt.mlr"
import "../../std/math_float.mlr"
import "../../std/quant.mlr"
@dynamic extern fn exit(uint64 code)
fn main() {
    u64 N = 4
    u64 K = 1024
    u64 bf16_buf = alloc(N * K * 2)
    u64 i = 0
    while i < N * K {
        u64 hash = (i * 2654435761) & 0xFFFFFFFF
        u64 modr = hash % 1024
        f64 vd = (int_to_f64(modr) - 512.0) / 1024.0
        f32 vf = f64_to_f32(vd)
        u64 pf = alloc(4); unsafe { *(pf as f32) = vf }
        u32 fbits = 0; unsafe { *(pf as u32) -> fbits }
        u16 b16 = (fbits >> 16) & 0xFFFF
        unsafe { *((bf16_buf + i * 2) as u16) = b16 }
        dealloc(pf)
        i = i + 1
    }
    u64 q4 = alloc(N * (K/32) * 18)
    quantize_bf16_to_q4_0(bf16_buf, q4, N, K)
    u64 dq = alloc(N * K * 4)
    dequantize_q4_0_to_f32(q4, dq, N, K)
    print_str("First f32 of each row (in u32 bits):\n")
    u64 r = 0
    while r < N {
        u64 addr = dq + r * K * 4
        u32 b = 0; unsafe { *(addr as u32) -> b }
        u64 b64 = b
        print_str("  row "); u64 sr = fmt_dec(r); print_str(sr); dealloc(sr)
        print_str(" elem 0 bits="); u64 sb = fmt_dec(b64); print_str(sb); dealloc(sb); print_str("\n")
        r = r + 1
    }
    exit(0)
}
