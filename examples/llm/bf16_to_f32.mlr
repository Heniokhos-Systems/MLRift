// LLM Phase 3a-6 — bf16_to_f32 expressed as a real @kernel body.
// bf16 == high 16 bits of f32, so dequant is `out[i] = u32(in[i]) << 16`.
// Recognised by `amdgpu_lower_bf16_to_f32_3a` in src/format_amdgpu.mlr.

fn block_idx_x() -> uint64 { return 0 }
fn tid_local_x() -> uint64 { return 0 }

@kernel
fn bf16_to_f32(uint64 in_ptr, uint64 out_ptr, uint64 n) {
    uint64 gid = block_idx_x() * 256 + tid_local_x()
    if gid < n {
        uint64 ip = in_ptr + gid * 2
        uint64 op = out_ptr + gid * 4
        uint16 b = 0
        unsafe { *(ip as uint16) -> b }
        uint64 b64 = b
        uint32 r = b64 << 16
        unsafe { *(op as uint32) = r }
    }
}

fn main() {
    exit(0)
}
