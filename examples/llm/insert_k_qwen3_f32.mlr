// LLM Phase 3c-15 — insert_k_qwen3_f32 expressed as a real @kernel.
// Scatters the per-position K vector (post-rope) into the per-batch
// K-cache slab.  Source layout: contiguous [batch, head, dim] with
// stride 4096 per batch.  Dest layout: [batch, head, kv_len, dim]
// K-cache slab with stride 262144 per batch.  2D grid (head, batch);
// block=128, one f32 per lane.
//
// Discriminator vs 3c-11 (extract_q): explicit `insert_k_marker()`
// Call — a name-tag helper that lets the recogniser pick the right
// emit body without doing literal-stride matching.

fn block_idx_x() -> uint64 { return 0 }
fn block_idx_y() -> uint64 { return 0 }
fn tid_local_x() -> uint64 { return 0 }
fn insert_k_marker() -> uint64 { return 0 }

@kernel
fn insert_k_qwen3_f32(uint64 src_ptr, uint64 k_cache_ptr) {
    uint64 wg_x = block_idx_x()
    uint64 wg_y = block_idx_y()
    uint64 lane = tid_local_x()
    uint64 _m   = insert_k_marker()
    uint64 src_off = wg_y * 4096   + wg_x * 512 + lane * 4
    uint64 dst_off = wg_y * 262144 + wg_x * 512 + lane * 4
    uint64 src = src_ptr     + src_off
    uint64 dst = k_cache_ptr + dst_off
    f32 v = 0.0
    unsafe { *(src as f32) -> v }
    unsafe { *(dst as f32) = v }
}

fn main() {
    exit(0)
}
