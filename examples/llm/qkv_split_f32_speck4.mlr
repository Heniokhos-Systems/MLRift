// LLM Phase 3c-18 — qkv_split_f32_speck4 expressed as a real @kernel.
// Same shape as qkv_split_f32_batched but the source/destination
// strides cover K consecutive positions within a single sequence's
// slab.  Discriminator: speck4_marker() Call.

fn block_idx_x() -> uint64 { return 0 }
fn block_idx_y() -> uint64 { return 0 }
fn tid_local_x() -> uint64 { return 0 }
fn speck4_marker() -> uint64 { return 0 }

@kernel
fn qkv_split_f32_speck4(uint64 qkv_ptr, uint64 k_slot_ptr, uint64 v_slot_ptr) {
    uint64 wg = block_idx_x()
    uint64 pos = block_idx_y()
    uint64 lane = tid_local_x()
    uint64 _m = speck4_marker()
    uint64 idx = wg * 128 + lane
    uint64 src_off = pos * 4096 + (2048 + idx) * 4
    uint64 src = qkv_ptr + src_off
    f32 v = 0.0
    unsafe { *(src as f32) -> v }
    if idx < 512 {
        uint64 dk = k_slot_ptr + (pos * 1024 + idx) * 4
        unsafe { *(dk as f32) = v }
    }
    if idx >= 512 {
        uint64 dv = v_slot_ptr + (pos * 1024 + idx - 512) * 4
        unsafe { *(dv as f32) = v }
    }
}

fn main() {
    exit(0)
}
