// Slice 4.18 — full launch smoke for the native-emit qwen3 mega-kernel.
//
// Allocates all 24 buffers (zero-initialised), zeroes the barrier
// counter, launches at max_phase=0 (only phase 1 runs + 1 barrier), and
// verifies the kernel returns cleanly with 512 WGs * 32 lanes.  If the
// .co's KD or metadata were mis-emitted, hipModuleLaunchKernel would
// either reject the kernarg layout or the kernel would deadlock on
// the barrier.  A clean return is strong evidence the native emit is
// dispatch-compatible with the hipcc reference.
//
// Build:
//   ./scripts/build_native_megakernel.sh  # one-shot
//   ./build/mlrc --emit-amdgpu-qwen3-megakernel=/tmp/qwen3_layer_megakernel_native.co dummy
//   ./build/mlrc --arch=x86_64 \
//       examples/llm/qwen3_layer_megakernel_native_smoke.mlr \
//       -o /tmp/qwen3_native_smoke
// Run:
//   /tmp/qwen3_native_smoke

import "../../std/hip.mlr"

@dynamic extern fn puts(uint64 s) -> uint32
@dynamic extern fn write(int32 fd, uint64 buf, uint64 n) -> int64
@dynamic extern fn exit(uint64 code)

static uint64 HIDDEN     = 1024
static uint64 HEAD_DIM   = 128
static uint64 N_HEADS    = 16
static uint64 N_KV_HEADS = 8
static uint64 Q_DIM      = 2048
static uint64 KV_DIM     = 1024
static uint64 QKV_DIM    = 4096
static uint64 FF         = 3072
static uint64 WG_PERSIST = 512
static uint64 MAX_SEQ    = 128

fn die(uint64 msg) { puts(msg); exit(1) }

fn main() {
    uint32 err = hipSetDevice(0)
    if err != 0 { die("setDev failed") }

    uint64 fd = file_open("/tmp/qwen3_layer_megakernel_native.co", 0)
    if fd > 0xFFFFFFFFFFFFF000 {
        die("missing /tmp/qwen3_layer_megakernel_native.co")
    }
    uint64 sz = file_size(fd)
    uint64 blob = alloc(sz)
    file_read(fd, blob, sz)
    file_close(fd)

    uint64 mod_slot = alloc(8)
    err = hipModuleLoadData(mod_slot, blob)
    if err != 0 { die("hipModuleLoadData failed") }
    uint64 mod = 0
    unsafe { *(mod_slot as uint64) -> mod }

    uint64 fh_slot = alloc(8)
    err = hipModuleGetFunction(fh_slot, mod, "qwen3_layer_megakernel")
    if err != 0 { die("getFn failed") }
    uint64 fh = 0
    unsafe { *(fh_slot as uint64) -> fh }

    // Allocate all 22 device buffers (zero-filled — undefined input
    // produces NaN propagation in the matmul phases but at max_phase=0
    // we only execute phase 1 then barrier-and-exit, so input zero is
    // fine).
    uint64 slot = alloc(8)
    uint64 in_resid = 0; uint64 out_resid = 0
    uint64 qkv_w = 0; uint64 o_w = 0; uint64 gate_up_w = 0; uint64 down_w = 0
    uint64 in_norm_g = 0; uint64 post_norm_g = 0; uint64 q_norm_g = 0; uint64 k_norm_g = 0
    uint64 rope_cos = 0; uint64 rope_sin = 0; uint64 kc = 0; uint64 vc = 0
    uint64 barrier_ctr = 0; uint64 gu_scratch = 0
    uint64 b_x_norm_g = 0; uint64 b_qkv_g = 0; uint64 b_attn_q_g = 0
    uint64 b_mid_g = 0; uint64 b_mid_norm_g = 0; uint64 b_attn_out_g = 0

    err = hipMalloc(slot, HIDDEN * 4); if err != 0 { die("a in_resid") }; unsafe { *(slot as uint64) -> in_resid }
    err = hipMalloc(slot, HIDDEN * 4); if err != 0 { die("a out_resid") }; unsafe { *(slot as uint64) -> out_resid }
    err = hipMalloc(slot, QKV_DIM * 1152 * 2); if err != 0 { die("a qkv_w") }; unsafe { *(slot as uint64) -> qkv_w }
    err = hipMalloc(slot, HIDDEN * 2176 * 2); if err != 0 { die("a o_w") }; unsafe { *(slot as uint64) -> o_w }
    err = hipMalloc(slot, 2 * FF * 1152 * 2); if err != 0 { die("a gate_up_w") }; unsafe { *(slot as uint64) -> gate_up_w }
    err = hipMalloc(slot, HIDDEN * 3200 * 2); if err != 0 { die("a down_w") }; unsafe { *(slot as uint64) -> down_w }
    err = hipMalloc(slot, HIDDEN * 4); if err != 0 { die("a in_norm_g") }; unsafe { *(slot as uint64) -> in_norm_g }
    err = hipMalloc(slot, HIDDEN * 4); if err != 0 { die("a post_norm_g") }; unsafe { *(slot as uint64) -> post_norm_g }
    err = hipMalloc(slot, HEAD_DIM * 4); if err != 0 { die("a q_norm_g") }; unsafe { *(slot as uint64) -> q_norm_g }
    err = hipMalloc(slot, HEAD_DIM * 4); if err != 0 { die("a k_norm_g") }; unsafe { *(slot as uint64) -> k_norm_g }
    err = hipMalloc(slot, (HEAD_DIM / 2) * 4); if err != 0 { die("a rope_cos") }; unsafe { *(slot as uint64) -> rope_cos }
    err = hipMalloc(slot, (HEAD_DIM / 2) * 4); if err != 0 { die("a rope_sin") }; unsafe { *(slot as uint64) -> rope_sin }
    err = hipMalloc(slot, MAX_SEQ * KV_DIM * 4); if err != 0 { die("a kc") }; unsafe { *(slot as uint64) -> kc }
    err = hipMalloc(slot, MAX_SEQ * KV_DIM * 4); if err != 0 { die("a vc") }; unsafe { *(slot as uint64) -> vc }
    err = hipMalloc(slot, 4); if err != 0 { die("a barrier") }; unsafe { *(slot as uint64) -> barrier_ctr }
    err = hipMalloc(slot, 2 * FF * 4); if err != 0 { die("a gu_scratch") }; unsafe { *(slot as uint64) -> gu_scratch }
    err = hipMalloc(slot, HIDDEN * 4); if err != 0 { die("a b_x_norm_g") }; unsafe { *(slot as uint64) -> b_x_norm_g }
    err = hipMalloc(slot, QKV_DIM * 4); if err != 0 { die("a b_qkv_g") }; unsafe { *(slot as uint64) -> b_qkv_g }
    err = hipMalloc(slot, Q_DIM * 4); if err != 0 { die("a b_attn_q_g") }; unsafe { *(slot as uint64) -> b_attn_q_g }
    err = hipMalloc(slot, HIDDEN * 4); if err != 0 { die("a b_mid_g") }; unsafe { *(slot as uint64) -> b_mid_g }
    err = hipMalloc(slot, HIDDEN * 4); if err != 0 { die("a b_mid_norm_g") }; unsafe { *(slot as uint64) -> b_mid_norm_g }
    err = hipMalloc(slot, Q_DIM * 4); if err != 0 { die("a b_attn_out_g") }; unsafe { *(slot as uint64) -> b_attn_out_g }

    // Zero the barrier counter — kernel's spin-load assumes it starts at 0.
    uint64 h_zero4 = alloc(4)
    uint32 z32 = 0
    unsafe { *(h_zero4 as uint32) = z32 }
    err = hipMemcpy(barrier_ctr, h_zero4, 4, 1)
    if err != 0 { die("clear barrier") }

    // Zero in_residual + in_norm_g (phase 1 reads them).
    uint64 hz = alloc(HIDDEN * 4)
    uint64 zi = 0
    while zi < HIDDEN * 4 {
        uint64 zp = hz + zi
        uint8 zb = 0
        unsafe { *(zp as uint8) = zb }
        zi = zi + 1
    }
    err = hipMemcpy(in_resid, hz, HIDDEN * 4, 1); if err != 0 { die("clear in_resid") }
    err = hipMemcpy(in_norm_g, hz, HIDDEN * 4, 1); if err != 0 { die("clear in_norm_g") }

    // 24 kernargs (u64 each), packed at natural alignment.
    uint64 pos = 0
    uint64 max_phase = 7   // full layer (all 8 phases + barriers)
    uint64 k_buf = alloc(24 * 8)
    unsafe { *((k_buf +  0 * 8) as uint64) = in_resid }
    unsafe { *((k_buf +  1 * 8) as uint64) = out_resid }
    unsafe { *((k_buf +  2 * 8) as uint64) = qkv_w }
    unsafe { *((k_buf +  3 * 8) as uint64) = o_w }
    unsafe { *((k_buf +  4 * 8) as uint64) = gate_up_w }
    unsafe { *((k_buf +  5 * 8) as uint64) = down_w }
    unsafe { *((k_buf +  6 * 8) as uint64) = in_norm_g }
    unsafe { *((k_buf +  7 * 8) as uint64) = post_norm_g }
    unsafe { *((k_buf +  8 * 8) as uint64) = q_norm_g }
    unsafe { *((k_buf +  9 * 8) as uint64) = k_norm_g }
    unsafe { *((k_buf + 10 * 8) as uint64) = rope_cos }
    unsafe { *((k_buf + 11 * 8) as uint64) = rope_sin }
    unsafe { *((k_buf + 12 * 8) as uint64) = kc }
    unsafe { *((k_buf + 13 * 8) as uint64) = vc }
    unsafe { *((k_buf + 14 * 8) as uint64) = pos }
    unsafe { *((k_buf + 15 * 8) as uint64) = barrier_ctr }
    unsafe { *((k_buf + 16 * 8) as uint64) = gu_scratch }
    unsafe { *((k_buf + 17 * 8) as uint64) = b_x_norm_g }
    unsafe { *((k_buf + 18 * 8) as uint64) = b_qkv_g }
    unsafe { *((k_buf + 19 * 8) as uint64) = b_attn_q_g }
    unsafe { *((k_buf + 20 * 8) as uint64) = b_mid_g }
    unsafe { *((k_buf + 21 * 8) as uint64) = b_mid_norm_g }
    unsafe { *((k_buf + 22 * 8) as uint64) = b_attn_out_g }
    unsafe { *((k_buf + 23 * 8) as uint64) = max_phase }

    uint64 kp = alloc(24 * 8)
    uint64 j = 0
    while j < 24 {
        uint64 slot_ptr = k_buf + j * 8
        unsafe { *((kp + j * 8) as uint64) = slot_ptr }
        j = j + 1
    }

    err = hipModuleLaunchKernel(fh,
                                 WG_PERSIST, 1, 1,
                                 32, 1, 1,
                                 0, 0, kp, 0)
    if err != 0 { die("launch failed") }
    err = hipDeviceSynchronize()
    if err != 0 { die("sync failed") }

    puts("ok: native qwen3_layer_megakernel launched (full max_phase=7) and returned cleanly")
    exit(0)
}
