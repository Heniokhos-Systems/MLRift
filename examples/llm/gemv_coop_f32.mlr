// LLM Phase 3c-7 — gemv_coop_f32 expressed as a real @kernel body.
// Cooperative-row gemv: one workgroup = one wave (32 lanes) = one row.
// Lanes 0..31 stride-32 over K, FMA into per-lane partial sums, then
// LDS-reduce 32 -> 1 and lane 0 stores c[row].  Same kernarg layout
// as gemv_f32; the recogniser distinguishes via the lds_reduce_sum_f32
// composer call.  REQUIRES: K is a multiple of 32 (Qwen3 head_dim 128,
// hidden 1024, intermediate 3072 all qualify).

fn block_idx_x() -> uint64 { return 0 }
fn tid_local_x() -> uint64 { return 0 }
fn lds_reduce_sum_f32(f32 x) -> f32 { return x }

@kernel
fn gemv_coop_f32(
    uint64 a_ptr,    // [M*K] row-major
    uint64 b_ptr,    // [K]
    uint64 c_ptr,    // [M]
    uint64 m,
    uint64 k_dim
) {
    uint64 row  = block_idx_x()
    uint64 lane = tid_local_x()
    if row < m {
        f32 partial = 0.0
        uint64 row_base = a_ptr + row * k_dim * 4
        uint64 j = lane
        while j < k_dim {
            uint64 ap = row_base + j * 4
            uint64 bp = b_ptr    + j * 4
            f32 a = 0.0
            f32 b = 0.0
            unsafe { *(ap as f32) -> a }
            unsafe { *(bp as f32) -> b }
            partial = partial + a * b
            j = j + 32
        }
        f32 total = lds_reduce_sum_f32(partial)
        if lane == 0 {
            uint64 cp = c_ptr + row * 4
            unsafe { *(cp as f32) = total }
        }
    }
}

fn main() {
    exit(0)
}
