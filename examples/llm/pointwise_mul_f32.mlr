// pointwise_mul_f32 — out[i] = a[i] * b[i], element-wise f32 multiply.
//
// Recognised by amdgpu_lower_pointwise_2in_3a in src/format_amdgpu.mlr
// via the 4-param (a_ptr, b_ptr, out_ptr, n) shape + BinOp(*) pattern.
//
// Build:
//   ./build/mlrc --arch=x86_64 --target=amdgpu-native \
//       examples/llm/pointwise_mul_f32.mlr -o /tmp/pointwise_mul_f32

fn block_idx_x() -> uint64 { return 0 }
fn tid_local_x() -> uint64 { return 0 }

@kernel
fn pointwise_mul_f32(uint64 a_ptr, uint64 b_ptr, uint64 out_ptr, uint64 n) {
    uint64 gid = block_idx_x() * 256 + tid_local_x()
    if gid < n {
        uint64 ap = a_ptr + gid * 4
        uint64 bp = b_ptr + gid * 4
        uint64 op = out_ptr + gid * 4
        f32 a = 0.0
        unsafe { *(ap as f32) -> a }
        f32 b = 0.0
        unsafe { *(bp as f32) -> b }
        f32 r = a * b
        unsafe { *(op as f32) = r }
    }
}

fn main() {
    exit(0)
}
