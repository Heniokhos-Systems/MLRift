// LLM Phase 3b-3-N128 — layernorm_f32 at N=128 via parametric body.
// Discriminator: layernorm_N128_marker() Call.

fn block_idx_x() -> uint64 { return 0 }
fn tid_local_x() -> uint64 { return 0 }
fn lds_reduce_sum_f32(f32 x) -> f32 { return x }
fn rsqrt_f32(f32 x) -> f32 { return x }
fn layernorm_N128_marker() -> uint64 { return 0 }

@kernel
fn layernorm_f32(uint64 in_ptr, uint64 out_ptr, uint64 m, uint64 n) {
    uint64 row = block_idx_x()
    uint64 lane = tid_local_x()
    uint64 _m = layernorm_N128_marker()
    if row < m {
        uint64 row_off = row * n
        uint64 idx = row_off + lane
        uint64 ip = in_ptr + idx * 4
        uint64 op = out_ptr + idx * 4
        f32 x = 0.0
        unsafe { *(ip as f32) -> x }
        f32 sum_x = lds_reduce_sum_f32(x)
        f32 mean = sum_x * 0.0078125
        f32 dx = x - mean
        f32 dxsq = dx * dx
        f32 sumsq = lds_reduce_sum_f32(dxsq)
        f32 var_v = sumsq * 0.0078125
        f32 ve = var_v + 0.00001
        f32 rrms = rsqrt_f32(ve)
        f32 r = dx * rrms
        unsafe { *(op as f32) = r }
    }
}

fn main() {
    exit(0)
}
