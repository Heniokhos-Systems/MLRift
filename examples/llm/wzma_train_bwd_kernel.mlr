// wzma_train_bwd — single-workgroup WZMA+InfoNCE BACKWARD + AdamW kernel.
//
// Multi-dispatch training pivot: the forward runs as full-occupancy GPU
// dispatches in examples/wzma_train_md.mlr; this kernel does the ENTIRE
// backward + AdamW (dense + embed) in one driver-synced dispatch.
//
// NAME-ROUTED stub: the body below is illustrative; the real ISA is produced
// by amdgpu_lower_wzma_train_bwd in src/format_amdgpu_megakernel.mlr (selected
// by the kernel name "wzma_train_bwd").  It is the megakernel's validated
// NW=1 Task-5/6 ISA lifted out (IDENTICAL math, IDENTICAL kernarg layout) —
// single WG, intra-WG s_barrier only → deterministic, no cross-WG wedge.
//
// Dims: B=8 S=16 D=384 K=4 R=32 vocab=8192 BS=128.
//
// Build:
//   ./build/mlrc --target=amdgpu-native \
//       examples/llm/wzma_train_bwd_kernel.mlr \
//       -o ~/mlrift_bin/wzma_train/wzma_train_bwd.co

fn block_idx_x() -> uint64 { return 0 }
fn tid_local_x() -> uint64 { return 0 }

@kernel
fn wzma_train_bwd(
    uint64 ids1_ptr,    // 0x00
    uint64 emb_ptr,     // 0x08
    uint64 x_out_ptr,   // 0x10
    uint64 U_ptr,       // 0x18
    uint64 V_ptr        // 0x20
) {
    uint64 d = tid_local_x()
    if d < 384 {
        uint64 bs = 0
        while bs < 128 {
            uint32 id = 0
            unsafe { *((ids1_ptr + bs * 4) as uint32) -> id }
            bs = bs + 1
        }
    }
}

fn main() { exit(0) }
