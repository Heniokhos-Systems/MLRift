// LLM Phase 3a-3 — silu_mul_f32 expressed as a real @kernel body.
// SwiGLU pointwise op: out[i] = silu(gate[i]) * up[i].
// Recognised by `amdgpu_lower_silu_mul_3a` in src/format_amdgpu.mlr.

fn block_idx_x() -> uint64 { return 0 }
fn tid_local_x() -> uint64 { return 0 }
fn silu_f32(f32 x) -> f32 { return x }

@kernel
fn silu_mul_f32(uint64 gate_ptr, uint64 up_ptr, uint64 out_ptr, uint64 n) {
    uint64 gid = block_idx_x() * 256 + tid_local_x()
    if gid < n {
        uint64 gp = gate_ptr + gid * 4
        uint64 up = up_ptr + gid * 4
        uint64 op = out_ptr + gid * 4
        f32 g = 0.0
        unsafe { *(gp as f32) -> g }
        f32 u = 0.0
        unsafe { *(up as f32) -> u }
        f32 sg = silu_f32(g)
        f32 r = sg * u
        unsafe { *(op as f32) = r }
    }
}

fn main() {
    exit(0)
}
