// LLM Phase 3c-D128 — rope_f32 at D=128 (Qwen3 head_dim, production).
// Discriminator: rope_D128_marker() Call.  Recogniser passes D=128 to
// the parametric _emit_rope_f32_body_D helper.

fn block_idx_x() -> uint64 { return 0 }
fn tid_local_x() -> uint64 { return 0 }
fn rope_D128_marker() -> uint64 { return 0 }

@kernel
fn rope_qwen3_f32(uint64 in_ptr, uint64 out_ptr, uint64 cos_ptr, uint64 sin_ptr, uint64 m) {
    uint64 i = block_idx_x()
    uint64 j = tid_local_x()
    uint64 _m = rope_D128_marker()
    if i < m {
        uint64 in_row = i * 128
        uint64 cs_row = i * 64
        uint64 ip_a = in_ptr  + (in_row + j) * 4
        uint64 ip_b = in_ptr  + (in_row + j + 64) * 4
        uint64 cp   = cos_ptr + (cs_row + j) * 4
        uint64 sp   = sin_ptr + (cs_row + j) * 4
        uint64 op_a = out_ptr + (in_row + j) * 4
        uint64 op_b = out_ptr + (in_row + j + 64) * 4
        f32 a = 0.0
        f32 b = 0.0
        f32 c = 0.0
        f32 s = 0.0
        unsafe { *(ip_a as f32) -> a }
        unsafe { *(ip_b as f32) -> b }
        unsafe { *(cp   as f32) -> c }
        unsafe { *(sp   as f32) -> s }
        f32 ac = a * c
        f32 bs = b * s
        f32 ra = ac - bs
        f32 as_v = a * s
        f32 bc = b * c
        f32 rb = as_v + bc
        unsafe { *(op_a as f32) = ra }
        unsafe { *(op_b as f32) = rb }
    }
}

fn main() {
    exit(0)
}
