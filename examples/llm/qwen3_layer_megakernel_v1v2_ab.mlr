// Slice 4.19.0 — A/B gate harness for the v2 stub mega-kernel.
//
// Validates:
//   (a) v1 .bin size == 10368 bytes (pinned 2026-05-07, md5 8ddefc8d5d92a9f8...)
//   (b) v2 stub .co loads cleanly under hipModuleLoadData
//   (c) v2 stub launches at max_phase=0 with WG_PERSIST=256 and returns
//       without deadlock
//
// "max_phase=0" means: stub phase 1 executes (s_nop), then barrier 0
// fires, then the max_phase < 1 check trips and the kernel exits.
// All 256 WGs must cross barrier 0 — a correct launch proves the ISA
// encoding for global_atomic_add_u32 + spin + s_cmp_lt_u32 is valid.
//
// Build:
//   ./build/mlrc --emit-amdgpu-qwen3-megakernel=/tmp/qwen3_layer_megakernel_native.co dummy
//   ./build/mlrc --emit-amdgpu-qwen3-megakernel-v2=/tmp/qwen3_layer_megakernel_v2.co dummy
//   ./build/mlrc --arch=x86_64 \
//       examples/llm/qwen3_layer_megakernel_v1v2_ab.mlr \
//       -o /tmp/qwen3_megakernel_v1v2_ab
// Run:
//   /tmp/qwen3_megakernel_v1v2_ab
// Expected:
//   v1 .bin: PASS (10368 bytes, md5 8ddefc8d5d92a9f81f0831124eb0bb3a)
//   v2 load: PASS
//   v2 launch max_phase=0: PASS
//   PASS -- slice 4.19.0 gate

import "../../std/hip.mlr"

@dynamic extern fn puts(uint64 s) -> uint32
@dynamic extern fn write(int32 fd, uint64 buf, uint64 n) -> int64
@dynamic extern fn exit(uint64 code)

static uint64 HIDDEN     = 1024
static uint64 HEAD_DIM   = 128
static uint64 N_HEADS    = 16
static uint64 N_KV_HEADS = 8
static uint64 Q_DIM      = 2048
static uint64 KV_DIM     = 1024
static uint64 QKV_DIM    = 4096
static uint64 FF         = 3072
// v2 uses WG_PERSIST=256 (one WG per CU on gfx1100; barrier threshold = 256)
static uint64 WG_PERSIST_V2 = 256
static uint64 MAX_SEQ    = 128

// V1 .text .bin size (pinned 2026-05-07, slice 4.18).
// md5: 8ddefc8d5d92a9f81f0831124eb0bb3a
static uint64 V1_BIN_SIZE = 10368

fn die(uint64 msg) { puts(msg); exit(1) }

fn main() {
    // Step (a): verify v1 .bin size.
    uint64 binpath = "build/native_megakernel/qwen3_layer_megakernel.gfx1100.bin"
    uint64 bfd = file_open(binpath, 0)
    if bfd > 0xFFFFFFFFFFFFF000 {
        puts("v1 .bin: SKIP (build/native_megakernel/qwen3_layer_megakernel.gfx1100.bin not found)")
    } else {
        uint64 bsz = file_size(bfd)
        file_close(bfd)
        if bsz == V1_BIN_SIZE {
            puts("v1 .bin: PASS (10368 bytes, md5 8ddefc8d5d92a9f81f0831124eb0bb3a)")
        } else {
            puts("v1 .bin: FAIL (size mismatch)")
            exit(1)
        }
    }

    // Step (b): load v2 stub .co.
    uint32 hip_err = hipSetDevice(0)
    if hip_err != 0 { die("hipSetDevice") }

    uint64 v2path = "/tmp/qwen3_layer_megakernel_v2.co"
    uint64 v2fd = file_open(v2path, 0)
    if v2fd > 0xFFFFFFFFFFFFF000 {
        die("missing /tmp/qwen3_layer_megakernel_v2.co")
    }
    uint64 v2sz = file_size(v2fd)
    uint64 v2blob = alloc(v2sz)
    file_read(v2fd, v2blob, v2sz)
    file_close(v2fd)

    uint64 mod_slot = alloc(8)
    hip_err = hipModuleLoadData(mod_slot, v2blob)
    if hip_err != 0 { die("v2 hipModuleLoadData failed") }
    uint64 v2mod = 0; unsafe { *(mod_slot as uint64) -> v2mod }
    puts("v2 load: PASS")

    uint64 fh_slot = alloc(8)
    hip_err = hipModuleGetFunction(fh_slot, v2mod, "qwen3_layer_megakernel")
    if hip_err != 0 { die("v2 getFn failed") }
    uint64 fh = 0; unsafe { *(fh_slot as uint64) -> fh }

    // Step (c): launch v2 at max_phase=0, WG_PERSIST=256.
    // Allocate minimal device buffers (only barrier_counter is read;
    // all others are pointers-to-zero-filled memory — phase 0 stub does
    // s_nop so it never dereferences them).
    uint64 slot = alloc(8)

    uint64 in_resid = 0; uint64 out_resid = 0
    uint64 qkv_w = 0; uint64 o_w = 0; uint64 gate_up_w = 0; uint64 down_w = 0
    uint64 in_norm_g = 0; uint64 post_norm_g = 0; uint64 q_norm_g = 0; uint64 k_norm_g = 0
    uint64 rope_cos = 0; uint64 rope_sin = 0; uint64 kc = 0; uint64 vc = 0
    uint64 barrier_ctr = 0; uint64 gu_scratch = 0
    uint64 b_x_norm_g = 0; uint64 b_qkv_g = 0; uint64 b_attn_q_g = 0
    uint64 b_mid_g = 0; uint64 b_mid_norm_g = 0; uint64 b_attn_out_g = 0

    hip_err = hipMalloc(slot, HIDDEN * 4);   if hip_err != 0 { die("a in_resid") };   unsafe { *(slot as uint64) -> in_resid }
    hip_err = hipMalloc(slot, HIDDEN * 4);   if hip_err != 0 { die("a out_resid") };  unsafe { *(slot as uint64) -> out_resid }
    hip_err = hipMalloc(slot, QKV_DIM * HIDDEN * 2); if hip_err != 0 { die("a qkv_w") };    unsafe { *(slot as uint64) -> qkv_w }
    hip_err = hipMalloc(slot, HIDDEN * Q_DIM * 2);   if hip_err != 0 { die("a o_w") };      unsafe { *(slot as uint64) -> o_w }
    hip_err = hipMalloc(slot, 2 * FF * HIDDEN * 2);  if hip_err != 0 { die("a gate_up_w") }; unsafe { *(slot as uint64) -> gate_up_w }
    hip_err = hipMalloc(slot, HIDDEN * FF * 2);      if hip_err != 0 { die("a down_w") };    unsafe { *(slot as uint64) -> down_w }
    hip_err = hipMalloc(slot, HIDDEN * 4);   if hip_err != 0 { die("a in_norm_g") };  unsafe { *(slot as uint64) -> in_norm_g }
    hip_err = hipMalloc(slot, HIDDEN * 4);   if hip_err != 0 { die("a post_norm_g") }; unsafe { *(slot as uint64) -> post_norm_g }
    hip_err = hipMalloc(slot, HEAD_DIM * 4); if hip_err != 0 { die("a q_norm_g") };   unsafe { *(slot as uint64) -> q_norm_g }
    hip_err = hipMalloc(slot, HEAD_DIM * 4); if hip_err != 0 { die("a k_norm_g") };   unsafe { *(slot as uint64) -> k_norm_g }
    hip_err = hipMalloc(slot, (HEAD_DIM / 2) * 4); if hip_err != 0 { die("a rope_cos") }; unsafe { *(slot as uint64) -> rope_cos }
    hip_err = hipMalloc(slot, (HEAD_DIM / 2) * 4); if hip_err != 0 { die("a rope_sin") }; unsafe { *(slot as uint64) -> rope_sin }
    hip_err = hipMalloc(slot, MAX_SEQ * KV_DIM * 4); if hip_err != 0 { die("a kc") };  unsafe { *(slot as uint64) -> kc }
    hip_err = hipMalloc(slot, MAX_SEQ * KV_DIM * 4); if hip_err != 0 { die("a vc") };  unsafe { *(slot as uint64) -> vc }
    hip_err = hipMalloc(slot, 4);            if hip_err != 0 { die("a barrier") };     unsafe { *(slot as uint64) -> barrier_ctr }
    hip_err = hipMalloc(slot, 2 * FF * 4);   if hip_err != 0 { die("a gu_scratch") };  unsafe { *(slot as uint64) -> gu_scratch }
    hip_err = hipMalloc(slot, HIDDEN * 4);   if hip_err != 0 { die("a b_x_norm_g") };  unsafe { *(slot as uint64) -> b_x_norm_g }
    hip_err = hipMalloc(slot, QKV_DIM * 4);  if hip_err != 0 { die("a b_qkv_g") };     unsafe { *(slot as uint64) -> b_qkv_g }
    hip_err = hipMalloc(slot, Q_DIM * 4);    if hip_err != 0 { die("a b_attn_q_g") };  unsafe { *(slot as uint64) -> b_attn_q_g }
    hip_err = hipMalloc(slot, HIDDEN * 4);   if hip_err != 0 { die("a b_mid_g") };     unsafe { *(slot as uint64) -> b_mid_g }
    hip_err = hipMalloc(slot, HIDDEN * 4);   if hip_err != 0 { die("a b_mid_norm_g") }; unsafe { *(slot as uint64) -> b_mid_norm_g }
    hip_err = hipMalloc(slot, Q_DIM * 4);    if hip_err != 0 { die("a b_attn_out_g") }; unsafe { *(slot as uint64) -> b_attn_out_g }

    // Zero barrier counter.
    uint64 h_zero4 = alloc(4); uint32 z32 = 0; unsafe { *(h_zero4 as uint32) = z32 }
    hip_err = hipMemcpy(barrier_ctr, h_zero4, 4, 1)
    if hip_err != 0 { die("clear barrier") }

    // Build 24-arg kernarg buffer (u64 each).
    uint64 pos_val = 0
    uint64 max_phase_val = 0    // max_phase=0: execute phase 0 stub + barrier 0, then exit
    uint64 k_buf = alloc(24 * 8)
    unsafe { *((k_buf +  0 * 8) as uint64) = in_resid }
    unsafe { *((k_buf +  1 * 8) as uint64) = out_resid }
    unsafe { *((k_buf +  2 * 8) as uint64) = qkv_w }
    unsafe { *((k_buf +  3 * 8) as uint64) = o_w }
    unsafe { *((k_buf +  4 * 8) as uint64) = gate_up_w }
    unsafe { *((k_buf +  5 * 8) as uint64) = down_w }
    unsafe { *((k_buf +  6 * 8) as uint64) = in_norm_g }
    unsafe { *((k_buf +  7 * 8) as uint64) = post_norm_g }
    unsafe { *((k_buf +  8 * 8) as uint64) = q_norm_g }
    unsafe { *((k_buf +  9 * 8) as uint64) = k_norm_g }
    unsafe { *((k_buf + 10 * 8) as uint64) = rope_cos }
    unsafe { *((k_buf + 11 * 8) as uint64) = rope_sin }
    unsafe { *((k_buf + 12 * 8) as uint64) = kc }
    unsafe { *((k_buf + 13 * 8) as uint64) = vc }
    unsafe { *((k_buf + 14 * 8) as uint64) = pos_val }
    unsafe { *((k_buf + 15 * 8) as uint64) = barrier_ctr }
    unsafe { *((k_buf + 16 * 8) as uint64) = gu_scratch }
    unsafe { *((k_buf + 17 * 8) as uint64) = b_x_norm_g }
    unsafe { *((k_buf + 18 * 8) as uint64) = b_qkv_g }
    unsafe { *((k_buf + 19 * 8) as uint64) = b_attn_q_g }
    unsafe { *((k_buf + 20 * 8) as uint64) = b_mid_g }
    unsafe { *((k_buf + 21 * 8) as uint64) = b_mid_norm_g }
    unsafe { *((k_buf + 22 * 8) as uint64) = b_attn_out_g }
    unsafe { *((k_buf + 23 * 8) as uint64) = max_phase_val }

    uint64 kp = alloc(24 * 8)
    uint64 j = 0
    while j < 24 {
        unsafe { *((kp + j * 8) as uint64) = k_buf + j * 8 }
        j = j + 1
    }

    hip_err = hipModuleLaunchKernel(fh,
                                    WG_PERSIST_V2, 1, 1,
                                    32, 1, 1,
                                    0, 0, kp, 0)
    if hip_err != 0 { die("v2 launch failed") }
    hip_err = hipDeviceSynchronize()
    if hip_err != 0 { die("v2 sync failed -- possible barrier deadlock") }

    puts("v2 launch max_phase=0: PASS")
    puts("PASS -- slice 4.19.0 gate")
    exit(0)
}
