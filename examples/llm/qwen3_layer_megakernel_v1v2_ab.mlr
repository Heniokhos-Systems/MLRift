// Slice 4.19.7 — A/B gate harness for the v2 mega-kernel (phases 1 + 3 + 5 + 7 + 9 + 11 + 13).
//
// Loads BOTH the v1 byte-wrapper .co and the v2 AST-walker .co,
// dispatches each with the same kernarg blob and MAX_PHASE value,
// and byte-diffs every output slab.
//
// Slice-4.19.7-specific gate:
//   MAX_PHASE=0: v2 phase 1 (rmsnorm) — ALL slabs match.
//   MAX_PHASE=1: v2 phase 3 (QKV matmul, b_qkv_g) — ALL slabs match.
//   MAX_PHASE=2: v2 phase 5 (QKV split + qknorm + RoPE) — ALL slabs match.
//   MAX_PHASE=3: v2 phase 7 (attn_decode-coop) — b_attn_out_g must match v1.
//   MAX_PHASE=4: v2 phase 9 (o_proj + residual-add, b_mid_g) — ALL slabs match.
//   MAX_PHASE=5: v2 phase 11 (post_norm rmsnorm, b_mid_norm_g) — ALL slabs match.
//   MAX_PHASE=6: v2 phase 13 (gate_up matmul, gu_scratch) — ALL slabs match.
//   PASS = both .co files load + dispatch without hang, ALL slabs match.
//
// Build:
//   ./build/mlrc --emit-amdgpu-qwen3-megakernel=/tmp/qwen3_layer_megakernel_v1.co dummy
//   ./build/mlrc --emit-amdgpu-qwen3-megakernel-v2=/tmp/qwen3_layer_megakernel_v2.co \
//       examples/llm/qwen3_layer_megakernel.mlr
//   ./build/mlrc examples/llm/qwen3_layer_megakernel_v1v2_ab_src.mlr \
//       -o /tmp/v1v2_ab --arch=x86_64 --target=linux --emit=elfexe
// Run:
//   MAX_PHASE=0 /tmp/v1v2_ab   → PASS -- slice 4.19.7 gate (MAX_PHASE=0)
//   MAX_PHASE=1 /tmp/v1v2_ab   → PASS -- slice 4.19.7 gate (MAX_PHASE=1)
//   MAX_PHASE=2 /tmp/v1v2_ab   → PASS -- slice 4.19.7 gate (MAX_PHASE=2)
// Expected output (MAX_PHASE=2):
//   v1 .bin fletcher-32 pin: PASS
//   v1 load: PASS  /  v2 load: PASS
//   OK out_residual  OK kc_layer  ... (all 10 slabs OK)
//   PASS -- slice 4.19.7 gate (MAX_PHASE=2)
// Exit: 0
//
// Implementation note on D2H buffer pre-allocation:
//   ROCm (gfx1100) uses a unified virtual address space where GPU and CPU
//   allocations share the same VA range.  mmap(MAP_ANON) allocations land in
//   the same 0x74Bx... region as hipMalloc allocations on this system.
//   After ~2 large (262 kB) mmap blocks are created, the next mmap collides
//   with a GPU VA region, causing hipMemcpy D2H to return hipErrorIllegalAddress
//   (700) even though the device pointer itself is still valid.
//
//   Fix: allocate ALL host comparison buffers via alloc() BEFORE the first
//   hipSetDevice call.  At that point ROCm has not yet claimed any GPU VA,
//   so every mmap lands safely below the GPU VA window.
//
// DispatchPath layout (heap-allocated uint64[36] struct, offsets in slots of 8):
//   [0]  fh                [1]  wg_persist
//   [2]  d_in_resid        [3]  d_out_resid     [4]  d_qkv_w        [5]  d_o_w
//   [6]  d_gate_up_w       [7]  d_down_w        [8]  d_in_norm_g    [9]  d_post_norm_g
//   [10] d_q_norm_g        [11] d_k_norm_g      [12] d_rope_cos     [13] d_rope_sin
//   [14] d_kc_layer        [15] d_vc_layer      [16] d_barrier      [17] d_gu_scratch
//   [18] d_b_x_norm_g      [19] d_b_qkv_g       [20] d_b_attn_q_g  [21] d_b_mid_g
//   [22] d_b_mid_norm_g    [23] d_b_attn_out_g
//   [24] ha_out_resid      [25] ha_kc            [26] ha_vc         [27] ha_gu_scr
//   [28] ha_bxnorm         [29] ha_bqkv          [30] ha_battnq     [31] ha_bmid
//   [32] ha_bmidnorm       [33] ha_battnout

import "../../std/hip.mlr"

@dynamic extern fn puts(uint64 s) -> uint32
@dynamic extern fn write(int32 fd, uint64 buf, uint64 n) -> int64
@dynamic extern fn exit(uint64 code)
@dynamic extern fn getenv(uint64 name) -> uint64

// ── Shape constants (Qwen3-0.6B, matches .hip.cpp) ──────────────────────
static uint64 HIDDEN      = 1024
static uint64 HEAD_DIM    = 128
static uint64 N_HEADS     = 16
static uint64 N_KV_HEADS  = 8
static uint64 Q_DIM       = 2048      // N_HEADS * HEAD_DIM
static uint64 KV_DIM      = 1024      // N_KV_HEADS * HEAD_DIM
static uint64 QKV_DIM     = 4096      // (N_HEADS + 2*N_KV_HEADS) * HEAD_DIM
static uint64 FF          = 3072
static uint64 HIDDEN_PAD  = 1152     // padded row stride for qkv_w / gate_up_w (from .hip.cpp #define HIDDEN_PAD 1152)
static uint64 Q_DIM_PAD   = 2176     // padded row stride for o_w     (from .hip.cpp #define Q_DIM_PAD 2176)
static uint64 FF_PAD      = 3200     // padded row stride for down_w  (from .hip.cpp #define FF_PAD 3200)
static uint64 WG_PERSIST_V1 = 512    // v1 native HIP kernel (#define WG_PERSIST 512 in .hip.cpp)
static uint64 WG_PERSIST_V2 = 512    // v2 AST-walker (matches v1 and HIP source)
static uint64 MAX_SEQ     = 64

// ── Tiny helpers ─────────────────────────────────────────────────────────

fn u64_dec(uint64 val, uint64 buf) -> uint64 {
    if val == 0 { uint8 z = 48; unsafe { *(buf as uint8) = z }; return 1 }
    uint64 n = 0; uint64 t = val
    while t > 0 { n = n + 1; t = t / 10 }
    uint64 i = n; t = val
    while i > 0 {
        i = i - 1
        uint64 d = t - (t / 10) * 10
        uint8 c = d + 48
        uint64 p = buf + i; unsafe { *(p as uint8) = c }
        t = t / 10
    }
    return n
}

fn put_kv(uint64 label, uint64 lab_len, uint64 v) {
    uint64 buf = alloc(128)
    uint64 i = 0
    while i < lab_len {
        uint64 sp = label + i; uint64 c = 0; unsafe { *(sp as uint8) -> c }
        uint64 dp = buf + i; uint8 cb = c; unsafe { *(dp as uint8) = cb }
        i = i + 1
    }
    uint64 sep_p = buf + lab_len; uint8 eq = 61; unsafe { *(sep_p as uint8) = eq }
    uint64 num_p = buf + lab_len + 1
    uint64 nl = u64_dec(v, num_p)
    uint64 nul_p = buf + lab_len + 1 + nl; uint8 nul = 0; unsafe { *(nul_p as uint8) = nul }
    puts(buf)
}

fn die(uint64 msg) { puts(msg); exit(1) }

fn atou64(uint64 s) -> uint64 {
    uint64 v = 0; uint64 i = 0
    while 1 {
        uint8 c = 0; unsafe { *((s + i) as uint8) -> c }
        uint64 cc = c
        if cc < 48 { return v }
        if cc > 57 { return v }
        v = v * 10 + (cc - 48); i = i + 1
    }
    return v
}

fn hzero(uint64 ptr, uint64 bytes) {
    uint64 i = 0
    while i < bytes { uint8 z = 0; unsafe { *((ptr + i) as uint8) = z }; i = i + 1 }
}

fn build_kp(uint64 k_buf, uint64 n) -> uint64 {
    uint64 kp = alloc(n * 8); uint64 j = 0
    while j < n {
        unsafe { *((kp + j * 8) as uint64) = k_buf + j * 8 }
        j = j + 1
    }
    return kp
}

fn lcg_step(uint64 state_ptr) -> f32 {
    uint64 s = 0; unsafe { *(state_ptr as uint64) -> s }
    s = s * 6364136223846793005 + 1442695040888963407
    unsafe { *(state_ptr as uint64) = s }
    uint64 hi = s >> 40
    f32 v = int_to_f32(hi) / 8388608.0f - 1.0f
    return v
}

fn dmalloc(uint64 bytes) -> uint64 {
    uint64 slot = alloc(8)
    uint32 err = hipMalloc(slot, bytes)
    if err != 0 { die("hipMalloc failed") }
    uint64 va = 0; unsafe { *(slot as uint64) -> va }
    return va
}

fn load_co(uint64 path, uint64 fname) -> uint64 {
    uint64 fd = file_open(path, 0)
    if fd > 0xFFFFFFFFFFFFF000 { return 0 }
    uint64 sz = file_size(fd)
    uint64 blob = alloc(sz)
    file_read(fd, blob, sz)
    file_close(fd)
    uint64 mod_slot = alloc(8)
    uint32 err = hipModuleLoadData(mod_slot, blob)
    if err != 0 { return 0 }
    uint64 mod = 0; unsafe { *(mod_slot as uint64) -> mod }
    uint64 fh_slot = alloc(8)
    err = hipModuleGetFunction(fh_slot, mod, fname)
    if err != 0 { return 0 }
    uint64 fh = 0; unsafe { *(fh_slot as uint64) -> fh }
    return fh
}

// ── Fletcher-32 pin check on v1 .bin ────────────────────────────────────
// Fatals if mismatch (baseline drift) or file not found.
// Fletcher-32 stand-in for md5; md5 of v1 .bin: 8ddefc8d5d92a9f81f0831124eb0bb3a.
// Update EXPECTED_FLETCHER32 if the v1 .bin is intentionally regenerated.
fn check_v1_bin_pin(uint64 bin_path) {
    uint64 EXPECTED_FLETCHER32 = 0x9E263327
    uint64 fd = file_open(bin_path, 0)
    if fd > 0xFFFFFFFFFFFFF000 { die("v1 .bin not found -- run: ./scripts/build_native_megakernel.sh") }
    uint64 sz = file_size(fd)
    uint64 buf = alloc(sz)
    file_read(fd, buf, sz)
    file_close(fd)
    // Fletcher-32 over little-endian 16-bit words; pad with 0 if sz is odd.
    uint64 sum1 = 0; uint64 sum2 = 0; uint64 i = 0
    while i < sz {
        uint8 lo = 0; unsafe { *((buf + i) as uint8) -> lo }
        uint64 lo64 = lo
        uint64 hi64 = 0; uint64 inext = i + 1
        if inext < sz { uint8 hi = 0; unsafe { *((buf + inext) as uint8) -> hi }; hi64 = hi }
        uint64 w = lo64 + (hi64 * 256)
        sum1 = sum1 + w
        while sum1 >= 65535 { sum1 = sum1 - 65535 }
        sum2 = sum2 + sum1
        while sum2 >= 65535 { sum2 = sum2 - 65535 }
        i = i + 2
    }
    uint64 got = (sum2 * 65536) + sum1
    if got != EXPECTED_FLETCHER32 {
        puts("v1 .bin fletcher-32 pin: FAIL -- .bin has changed (baseline drift)")
        die("update EXPECTED_FLETCHER32 in v1v2_ab.mlr if regeneration was intentional")
    }
    puts("v1 .bin fletcher-32 pin: PASS")
}

// ── DispatchPath struct helpers (heap uint64[34] array) ──────────────────
// Slot accessors for the DispatchPath struct (see header comment for layout).
// Only dp_fh and dp_wg are used by dispatch/copy_outputs_d2h (the rest
// of the struct is addressed via dp_slot with magic indices).
fn dp_fh(uint64 p) -> uint64 { uint64 v = 0; unsafe { *(p as uint64) -> v }; return v }
fn dp_wg(uint64 p) -> uint64 { uint64 v = 0; unsafe { *((p + 8) as uint64) -> v }; return v }
fn dp_slot(uint64 p, uint64 s) -> uint64 { uint64 v = 0; unsafe { *((p + s * 8) as uint64) -> v }; return v }

// Output slab sizes: in_resid_b, kv_b, gu_b, norm_b, b_qkv_b, b_q_b.
// Shared input device buffers: d_in_resid .. d_rope_sin (slots 2-13, no dmalloc needed).
fn make_dispatch_path(uint64 fh, uint64 wg_persist,
                      uint64 in_resid_b, uint64 kv_b, uint64 gu_b,
                      uint64 norm_b, uint64 b_qkv_b, uint64 b_q_b,
                      // shared read-only device buffers (same for v1 and v2)
                      uint64 d_in_resid, uint64 d_qkv_w, uint64 d_o_w,
                      uint64 d_gate_up_w, uint64 d_down_w,
                      uint64 d_in_norm_g, uint64 d_post_norm_g,
                      uint64 d_q_norm_g, uint64 d_k_norm_g,
                      uint64 d_rope_cos, uint64 d_rope_sin) -> uint64 {
    uint64 p = alloc(34 * 8)
    unsafe { *((p +  0 * 8) as uint64) = fh }
    unsafe { *((p +  1 * 8) as uint64) = wg_persist }
    unsafe { *((p +  2 * 8) as uint64) = d_in_resid }
    unsafe { *((p +  3 * 8) as uint64) = dmalloc(in_resid_b) }  // d_out_resid
    unsafe { *((p +  4 * 8) as uint64) = d_qkv_w }
    unsafe { *((p +  5 * 8) as uint64) = d_o_w }
    unsafe { *((p +  6 * 8) as uint64) = d_gate_up_w }
    unsafe { *((p +  7 * 8) as uint64) = d_down_w }
    unsafe { *((p +  8 * 8) as uint64) = d_in_norm_g }
    unsafe { *((p +  9 * 8) as uint64) = d_post_norm_g }
    unsafe { *((p + 10 * 8) as uint64) = d_q_norm_g }
    unsafe { *((p + 11 * 8) as uint64) = d_k_norm_g }
    unsafe { *((p + 12 * 8) as uint64) = d_rope_cos }
    unsafe { *((p + 13 * 8) as uint64) = d_rope_sin }
    unsafe { *((p + 14 * 8) as uint64) = dmalloc(kv_b) }        // d_kc_layer
    unsafe { *((p + 15 * 8) as uint64) = dmalloc(kv_b) }        // d_vc_layer
    unsafe { *((p + 16 * 8) as uint64) = dmalloc(4) }           // d_barrier
    unsafe { *((p + 17 * 8) as uint64) = dmalloc(gu_b) }        // d_gu_scratch
    unsafe { *((p + 18 * 8) as uint64) = dmalloc(norm_b) }      // d_b_x_norm_g
    unsafe { *((p + 19 * 8) as uint64) = dmalloc(b_qkv_b) }     // d_b_qkv_g
    unsafe { *((p + 20 * 8) as uint64) = dmalloc(b_q_b) }       // d_b_attn_q_g
    unsafe { *((p + 21 * 8) as uint64) = dmalloc(norm_b) }      // d_b_mid_g
    unsafe { *((p + 22 * 8) as uint64) = dmalloc(norm_b) }      // d_b_mid_norm_g
    unsafe { *((p + 23 * 8) as uint64) = dmalloc(b_q_b) }       // d_b_attn_out_g
    // host output buffers (pre-allocated before hipSetDevice)
    unsafe { *((p + 24 * 8) as uint64) = 0 }                    // ha_out_resid (set by caller)
    unsafe { *((p + 25 * 8) as uint64) = 0 }                    // ha_kc
    unsafe { *((p + 26 * 8) as uint64) = 0 }                    // ha_vc
    unsafe { *((p + 27 * 8) as uint64) = 0 }                    // ha_gu_scr
    unsafe { *((p + 28 * 8) as uint64) = 0 }                    // ha_bxnorm
    unsafe { *((p + 29 * 8) as uint64) = 0 }                    // ha_bqkv
    unsafe { *((p + 30 * 8) as uint64) = 0 }                    // ha_battnq
    unsafe { *((p + 31 * 8) as uint64) = 0 }                    // ha_bmid
    unsafe { *((p + 32 * 8) as uint64) = 0 }                    // ha_bmidnorm
    unsafe { *((p + 33 * 8) as uint64) = 0 }                    // ha_battnout
    return p
}

// Zero all output slabs, set barrier_counter=0, dispatch, sync.
fn dispatch(uint64 dp, uint64 max_phase,
            uint64 in_resid_b, uint64 kv_b, uint64 gu_b, uint64 norm_b,
            uint64 b_qkv_b, uint64 b_q_b, uint64 h_zero) {
    uint64 h_zero4 = alloc(4); hzero(h_zero4, 4)
    uint32 err = hipMemcpy(dp_slot(dp, 3),  h_zero,  in_resid_b, 1); if err != 0 { die("zero out_r") }
    err = hipMemcpy(dp_slot(dp, 14), h_zero,  kv_b,      1); if err != 0 { die("zero kc") }
    err = hipMemcpy(dp_slot(dp, 15), h_zero,  kv_b,      1); if err != 0 { die("zero vc") }
    err = hipMemcpy(dp_slot(dp, 16), h_zero4, 4,         1); if err != 0 { die("zero bar") }
    err = hipMemcpy(dp_slot(dp, 17), h_zero,  gu_b,      1); if err != 0 { die("zero gu") }
    err = hipMemcpy(dp_slot(dp, 18), h_zero,  norm_b,    1); if err != 0 { die("zero bxn") }
    err = hipMemcpy(dp_slot(dp, 19), h_zero,  b_qkv_b,   1); if err != 0 { die("zero bqkv") }
    err = hipMemcpy(dp_slot(dp, 20), h_zero,  b_q_b,     1); if err != 0 { die("zero baq") }
    err = hipMemcpy(dp_slot(dp, 21), h_zero,  norm_b,    1); if err != 0 { die("zero bm") }
    err = hipMemcpy(dp_slot(dp, 22), h_zero,  norm_b,    1); if err != 0 { die("zero bmn") }
    err = hipMemcpy(dp_slot(dp, 23), h_zero,  b_q_b,     1); if err != 0 { die("zero bao") }
    uint64 kb = alloc(24 * 8)
    uint64 pos_val = 0
    unsafe { *((kb +  0 * 8) as uint64) = dp_slot(dp,  2) }
    unsafe { *((kb +  1 * 8) as uint64) = dp_slot(dp,  3) }
    unsafe { *((kb +  2 * 8) as uint64) = dp_slot(dp,  4) }
    unsafe { *((kb +  3 * 8) as uint64) = dp_slot(dp,  5) }
    unsafe { *((kb +  4 * 8) as uint64) = dp_slot(dp,  6) }
    unsafe { *((kb +  5 * 8) as uint64) = dp_slot(dp,  7) }
    unsafe { *((kb +  6 * 8) as uint64) = dp_slot(dp,  8) }
    unsafe { *((kb +  7 * 8) as uint64) = dp_slot(dp,  9) }
    unsafe { *((kb +  8 * 8) as uint64) = dp_slot(dp, 10) }
    unsafe { *((kb +  9 * 8) as uint64) = dp_slot(dp, 11) }
    unsafe { *((kb + 10 * 8) as uint64) = dp_slot(dp, 12) }
    unsafe { *((kb + 11 * 8) as uint64) = dp_slot(dp, 13) }
    unsafe { *((kb + 12 * 8) as uint64) = dp_slot(dp, 14) }
    unsafe { *((kb + 13 * 8) as uint64) = dp_slot(dp, 15) }
    unsafe { *((kb + 14 * 8) as uint64) = pos_val }
    unsafe { *((kb + 15 * 8) as uint64) = dp_slot(dp, 16) }
    unsafe { *((kb + 16 * 8) as uint64) = dp_slot(dp, 17) }
    unsafe { *((kb + 17 * 8) as uint64) = dp_slot(dp, 18) }
    unsafe { *((kb + 18 * 8) as uint64) = dp_slot(dp, 19) }
    unsafe { *((kb + 19 * 8) as uint64) = dp_slot(dp, 20) }
    unsafe { *((kb + 20 * 8) as uint64) = dp_slot(dp, 21) }
    unsafe { *((kb + 21 * 8) as uint64) = dp_slot(dp, 22) }
    unsafe { *((kb + 22 * 8) as uint64) = dp_slot(dp, 23) }
    unsafe { *((kb + 23 * 8) as uint64) = max_phase }
    uint64 kp = build_kp(kb, 24)
    err = hipModuleLaunchKernel(dp_fh(dp), dp_wg(dp), 1, 1, 32, 1, 1, 0, 0, kp, 0)
    if err != 0 {
        uint64 errmsg = hipGetErrorString(err)
        puts(errmsg)
        die("launch failed")
    }
    err = hipDeviceSynchronize()
    if err != 0 {
        uint64 errmsg = hipGetErrorString(err)
        puts(errmsg)
        die("sync failed -- possible deadlock")
    }
}

// Copy all output slabs D2H into the path's host buffers.
fn copy_outputs_d2h(uint64 dp,
                    uint64 in_resid_b, uint64 kv_b, uint64 gu_b,
                    uint64 norm_b, uint64 b_qkv_b, uint64 b_q_b) {
    uint32 err = hipMemcpy(dp_slot(dp, 24), dp_slot(dp,  3), in_resid_b, 2); if err != 0 { die("D2H out_r") }
    err = hipMemcpy(dp_slot(dp, 25), dp_slot(dp, 14), kv_b,      2); if err != 0 { die("D2H kc") }
    err = hipMemcpy(dp_slot(dp, 26), dp_slot(dp, 15), kv_b,      2); if err != 0 { die("D2H vc") }
    err = hipMemcpy(dp_slot(dp, 27), dp_slot(dp, 17), gu_b,      2); if err != 0 { die("D2H gu") }
    err = hipMemcpy(dp_slot(dp, 28), dp_slot(dp, 18), norm_b,    2); if err != 0 { die("D2H bxn") }
    err = hipMemcpy(dp_slot(dp, 29), dp_slot(dp, 19), b_qkv_b,   2); if err != 0 { die("D2H bqkv") }
    err = hipMemcpy(dp_slot(dp, 30), dp_slot(dp, 20), b_q_b,     2); if err != 0 { die("D2H baq") }
    err = hipMemcpy(dp_slot(dp, 31), dp_slot(dp, 21), norm_b,    2); if err != 0 { die("D2H bm") }
    err = hipMemcpy(dp_slot(dp, 32), dp_slot(dp, 22), norm_b,    2); if err != 0 { die("D2H bmn") }
    err = hipMemcpy(dp_slot(dp, 33), dp_slot(dp, 23), b_q_b,     2); if err != 0 { die("D2H bao") }
}

// Bytewise diff two host slabs. Returns 0 on match, 1 on mismatch.
// Prints "OK <name>" or "MISMATCH <name> at byte <N>: A=<av> B=<bv>".
fn diff_slab(uint64 name_ptr, uint64 name_len, uint64 ha, uint64 hb, uint64 n_bytes) -> uint64 {
    uint64 fm = 0xFFFFFFFFFFFFFFFF; uint64 bk = 0
    while bk < n_bytes {
        uint8 xa = 0; unsafe { *((ha + bk) as uint8) -> xa }
        uint8 xb = 0; unsafe { *((hb + bk) as uint8) -> xb }
        if xa != xb { if fm == 0xFFFFFFFFFFFFFFFF { fm = bk } }
        bk = bk + 1
    }
    if fm == 0xFFFFFFFFFFFFFFFF {
        uint64 mb = alloc(32 + name_len)
        uint64 ok_s = "OK "; memcpy(mb, ok_s, 3); memcpy(mb + 3, name_ptr, name_len)
        uint8 nul = 0; unsafe { *((mb + 3 + name_len) as uint8) = nul }
        puts(mb); return 0
    }
    uint64 mb = alloc(64 + name_len); uint64 mp = mb
    uint64 pfx = "MISMATCH "; memcpy(mp, pfx, 9); mp = mp + 9
    memcpy(mp, name_ptr, name_len); mp = mp + name_len
    uint64 at_s = " at byte "; memcpy(mp, at_s, 9); mp = mp + 9
    uint64 nl = u64_dec(fm, mp); mp = mp + nl
    uint64 colon = ": A="; memcpy(mp, colon, 4); mp = mp + 4
    uint8 avb = 0; unsafe { *((ha + fm) as uint8) -> avb }
    uint64 avu = avb; uint64 al = u64_dec(avu, mp); mp = mp + al
    uint64 bstr = " B="; memcpy(mp, bstr, 3); mp = mp + 3
    uint8 bvb = 0; unsafe { *((hb + fm) as uint8) -> bvb }
    uint64 bvu = bvb; uint64 bl = u64_dec(bvu, mp); mp = mp + bl
    uint8 nul = 0; unsafe { *(mp as uint8) = nul }
    puts(mb); return 1
}

fn main() {
    // ── Size constants (bytes) ────────────────────────────────────────────
    uint64 in_resid_b   = HIDDEN * 4
    uint64 qkv_w_b      = QKV_DIM * HIDDEN_PAD * 2   // padded row stride: HIDDEN_PAD=1152 u16 per row
    uint64 o_w_b        = HIDDEN * Q_DIM_PAD * 2     // padded row stride: Q_DIM_PAD=2176 u16 per row
    uint64 gateup_b     = 2 * FF * HIDDEN_PAD * 2    // padded row stride: HIDDEN_PAD=1152 u16 per row
    uint64 down_b       = HIDDEN * FF_PAD * 2        // padded row stride: FF_PAD=3200 u16 per row
    uint64 in_norm_b    = HIDDEN * 4
    uint64 post_norm_b  = HIDDEN * 4
    uint64 q_norm_b     = HEAD_DIM * 4
    uint64 k_norm_b     = HEAD_DIM * 4
    uint64 cos_sin_b    = (HEAD_DIM / 2) * 4
    uint64 kv_b         = MAX_SEQ * KV_DIM * 4
    uint64 gu_b         = 2 * FF * 4
    uint64 norm_b       = HIDDEN * 4
    uint64 b_qkv_b      = QKV_DIM * 4
    uint64 b_q_b        = Q_DIM * 4

    // ── Step 1: Fletcher-32 pin check on v1 .bin ─────────────────────────
    // (before hipSetDevice so alloc() lands in pre-GPU VA window)
    uint64 bin_path = "build/native_megakernel/qwen3_layer_megakernel.gfx1100.bin"
    check_v1_bin_pin(bin_path)

    // ── PRE-ALLOCATE all host D2H comparison buffers BEFORE hipSetDevice ──
    uint64 v1ha = alloc(34 * 8); hzero(v1ha, 34 * 8)   // v1 host-output slot array
    uint64 v2ha = alloc(34 * 8); hzero(v2ha, 34 * 8)   // v2 host-output slot array
    // Slots 24..33: ha_out_resid, ha_kc, ha_vc, ha_gu_scr, ha_bxnorm,
    //               ha_bqkv, ha_battnq, ha_bmid, ha_bmidnorm, ha_battnout
    unsafe { *((v1ha + 24 * 8) as uint64) = alloc(in_resid_b) }; hzero(dp_slot(v1ha, 24), in_resid_b)
    unsafe { *((v1ha + 25 * 8) as uint64) = alloc(kv_b) };       hzero(dp_slot(v1ha, 25), kv_b)
    unsafe { *((v1ha + 26 * 8) as uint64) = alloc(kv_b) };       hzero(dp_slot(v1ha, 26), kv_b)
    unsafe { *((v1ha + 27 * 8) as uint64) = alloc(gu_b) };       hzero(dp_slot(v1ha, 27), gu_b)
    unsafe { *((v1ha + 28 * 8) as uint64) = alloc(norm_b) };     hzero(dp_slot(v1ha, 28), norm_b)
    unsafe { *((v1ha + 29 * 8) as uint64) = alloc(b_qkv_b) };    hzero(dp_slot(v1ha, 29), b_qkv_b)
    unsafe { *((v1ha + 30 * 8) as uint64) = alloc(b_q_b) };      hzero(dp_slot(v1ha, 30), b_q_b)
    unsafe { *((v1ha + 31 * 8) as uint64) = alloc(norm_b) };     hzero(dp_slot(v1ha, 31), norm_b)
    unsafe { *((v1ha + 32 * 8) as uint64) = alloc(norm_b) };     hzero(dp_slot(v1ha, 32), norm_b)
    unsafe { *((v1ha + 33 * 8) as uint64) = alloc(b_q_b) };      hzero(dp_slot(v1ha, 33), b_q_b)
    unsafe { *((v2ha + 24 * 8) as uint64) = alloc(in_resid_b) }; hzero(dp_slot(v2ha, 24), in_resid_b)
    unsafe { *((v2ha + 25 * 8) as uint64) = alloc(kv_b) };       hzero(dp_slot(v2ha, 25), kv_b)
    unsafe { *((v2ha + 26 * 8) as uint64) = alloc(kv_b) };       hzero(dp_slot(v2ha, 26), kv_b)
    unsafe { *((v2ha + 27 * 8) as uint64) = alloc(gu_b) };       hzero(dp_slot(v2ha, 27), gu_b)
    unsafe { *((v2ha + 28 * 8) as uint64) = alloc(norm_b) };     hzero(dp_slot(v2ha, 28), norm_b)
    unsafe { *((v2ha + 29 * 8) as uint64) = alloc(b_qkv_b) };    hzero(dp_slot(v2ha, 29), b_qkv_b)
    unsafe { *((v2ha + 30 * 8) as uint64) = alloc(b_q_b) };      hzero(dp_slot(v2ha, 30), b_q_b)
    unsafe { *((v2ha + 31 * 8) as uint64) = alloc(norm_b) };     hzero(dp_slot(v2ha, 31), norm_b)
    unsafe { *((v2ha + 32 * 8) as uint64) = alloc(norm_b) };     hzero(dp_slot(v2ha, 32), norm_b)
    unsafe { *((v2ha + 33 * 8) as uint64) = alloc(b_q_b) };      hzero(dp_slot(v2ha, 33), b_q_b)

    // ── GPU init + load both .co files ───────────────────────────────────
    uint32 err = hipSetDevice(0)
    if err != 0 { die("hipSetDevice failed") }

    uint64 kname = "qwen3_layer_megakernel"
    uint64 fh_v1 = load_co("/tmp/qwen3_layer_megakernel_v1.co", kname)
    if fh_v1 == 0 { die("v1 load failed -- run: ./build/mlrc --emit-amdgpu-qwen3-megakernel=/tmp/qwen3_layer_megakernel_v1.co dummy") }
    puts("v1 load: PASS")

    uint64 fh_v2 = load_co("/tmp/qwen3_layer_megakernel_v2.co", kname)
    if fh_v2 == 0 { die("v2 load failed -- run: ./build/mlrc --emit-amdgpu-qwen3-megakernel-v2=/tmp/qwen3_layer_megakernel_v2.co examples/llm/qwen3_layer_megakernel.mlr") }
    puts("v2 load: PASS")

    // ── Read MAX_PHASE env var (default 0) ───────────────────────────────
    uint64 mp_env = getenv("MAX_PHASE")
    uint64 max_phase = 0
    if mp_env != 0 { max_phase = atou64(mp_env) }
    put_kv("MAX_PHASE", 9, max_phase)

    // ── Allocate and fill shared host input buffers ───────────────────────
    uint64 h_in_resid    = alloc(in_resid_b)
    uint64 h_qkv_w       = alloc(qkv_w_b)
    uint64 h_o_w         = alloc(o_w_b)
    uint64 h_gate_up_w   = alloc(gateup_b)
    uint64 h_down_w      = alloc(down_b)
    uint64 h_in_norm_g   = alloc(in_norm_b)
    uint64 h_post_norm_g = alloc(post_norm_b)
    uint64 h_q_norm_g    = alloc(q_norm_b)
    uint64 h_k_norm_g    = alloc(k_norm_b)
    uint64 h_rope_cos    = alloc(cos_sin_b)
    uint64 h_rope_sin    = alloc(cos_sin_b)

    uint64 seed_slot = alloc(8)
    unsafe { *(seed_slot as uint64) = 0xDEADBEEFCAFE1234 }

    uint64 i = 0
    while i < HIDDEN { f32 v = lcg_step(seed_slot); unsafe { *((h_in_resid + i * 4) as f32) = v }; i = i + 1 }
    i = 0
    while i < HIDDEN { f32 v = lcg_step(seed_slot); f32 g = v * 0.5f + 1.0f; unsafe { *((h_in_norm_g + i * 4) as f32) = g }; i = i + 1 }
    i = 0
    while i < HIDDEN { f32 v = lcg_step(seed_slot); f32 g = v * 0.5f + 1.0f; unsafe { *((h_post_norm_g + i * 4) as f32) = g }; i = i + 1 }
    i = 0
    while i < HEAD_DIM { f32 v = lcg_step(seed_slot); f32 g = v * 0.5f + 1.0f; unsafe { *((h_q_norm_g + i * 4) as f32) = g }; i = i + 1 }
    i = 0
    while i < HEAD_DIM { f32 v = lcg_step(seed_slot); f32 g = v * 0.5f + 1.0f; unsafe { *((h_k_norm_g + i * 4) as f32) = g }; i = i + 1 }
    i = 0
    while i < (HEAD_DIM / 2) {
        f32 one_f = 1.0f; f32 zero_f = 0.0f
        unsafe { *((h_rope_cos + i * 4) as f32) = one_f }
        unsafe { *((h_rope_sin + i * 4) as f32) = zero_f }
        i = i + 1
    }
    i = 0; while i < qkv_w_b { uint8 bv = i; unsafe { *((h_qkv_w + i) as uint8) = bv }; i = i + 1 }
    i = 0; while i < o_w_b   { uint8 bv = i; unsafe { *((h_o_w + i) as uint8) = bv }; i = i + 1 }
    i = 0; while i < gateup_b { uint8 bv = i; unsafe { *((h_gate_up_w + i) as uint8) = bv }; i = i + 1 }
    i = 0; while i < down_b  { uint8 bv = i; unsafe { *((h_down_w + i) as uint8) = bv }; i = i + 1 }

    // H2D upload shared read-only inputs
    uint64 d_in_resid    = dmalloc(in_resid_b)
    uint64 d_qkv_w       = dmalloc(qkv_w_b)
    uint64 d_o_w         = dmalloc(o_w_b)
    uint64 d_gate_up_w   = dmalloc(gateup_b)
    uint64 d_down_w      = dmalloc(down_b)
    uint64 d_in_norm_g   = dmalloc(in_norm_b)
    uint64 d_post_norm_g = dmalloc(post_norm_b)
    uint64 d_q_norm_g    = dmalloc(q_norm_b)
    uint64 d_k_norm_g    = dmalloc(k_norm_b)
    uint64 d_rope_cos    = dmalloc(cos_sin_b)
    uint64 d_rope_sin    = dmalloc(cos_sin_b)
    err = hipMemcpy(d_in_resid,    h_in_resid,    in_resid_b, 1); if err != 0 { die("H2D in_r") }
    err = hipMemcpy(d_qkv_w,       h_qkv_w,       qkv_w_b,   1); if err != 0 { die("H2D qkv_w") }
    err = hipMemcpy(d_o_w,         h_o_w,         o_w_b,     1); if err != 0 { die("H2D o_w") }
    err = hipMemcpy(d_gate_up_w,   h_gate_up_w,   gateup_b,  1); if err != 0 { die("H2D gu_w") }
    err = hipMemcpy(d_down_w,      h_down_w,      down_b,    1); if err != 0 { die("H2D dn_w") }
    err = hipMemcpy(d_in_norm_g,   h_in_norm_g,   in_norm_b, 1); if err != 0 { die("H2D in_g") }
    err = hipMemcpy(d_post_norm_g, h_post_norm_g, post_norm_b,1); if err != 0 { die("H2D pn_g") }
    err = hipMemcpy(d_q_norm_g,    h_q_norm_g,    q_norm_b,  1); if err != 0 { die("H2D q_g") }
    err = hipMemcpy(d_k_norm_g,    h_k_norm_g,    k_norm_b,  1); if err != 0 { die("H2D k_g") }
    err = hipMemcpy(d_rope_cos,    h_rope_cos,    cos_sin_b, 1); if err != 0 { die("H2D rc") }
    err = hipMemcpy(d_rope_sin,    h_rope_sin,    cos_sin_b, 1); if err != 0 { die("H2D rs") }
    puts("host buffers filled + H2D done")

    // ── Build DispatchPath structs + set host-output slots ────────────────
    uint64 h_zero = alloc(kv_b); hzero(h_zero, kv_b)
    uint64 dp_v1 = make_dispatch_path(fh_v1, WG_PERSIST_V1,
                       in_resid_b, kv_b, gu_b, norm_b, b_qkv_b, b_q_b,
                       d_in_resid, d_qkv_w, d_o_w, d_gate_up_w, d_down_w,
                       d_in_norm_g, d_post_norm_g, d_q_norm_g, d_k_norm_g,
                       d_rope_cos, d_rope_sin)
    // Copy pre-allocated host output ptrs into v1 struct slots 24..33
    uint64 s = 24
    while s < 34 {
        uint64 hap = dp_slot(v1ha, s)
        unsafe { *((dp_v1 + s * 8) as uint64) = hap }
        s = s + 1
    }

    uint64 dp_v2 = make_dispatch_path(fh_v2, WG_PERSIST_V2,
                       in_resid_b, kv_b, gu_b, norm_b, b_qkv_b, b_q_b,
                       d_in_resid, d_qkv_w, d_o_w, d_gate_up_w, d_down_w,
                       d_in_norm_g, d_post_norm_g, d_q_norm_g, d_k_norm_g,
                       d_rope_cos, d_rope_sin)
    s = 24
    while s < 34 {
        uint64 hap = dp_slot(v2ha, s)
        unsafe { *((dp_v2 + s * 8) as uint64) = hap }
        s = s + 1
    }
    puts("device buffers allocated")

    // ── Dispatch v1, copy D2H ─────────────────────────────────────────────
    dispatch(dp_v1, max_phase, in_resid_b, kv_b, gu_b, norm_b, b_qkv_b, b_q_b, h_zero)
    puts("v1 dispatch: PASS")
    copy_outputs_d2h(dp_v1, in_resid_b, kv_b, gu_b, norm_b, b_qkv_b, b_q_b)

    // ── Dispatch v2, copy D2H ─────────────────────────────────────────────
    dispatch(dp_v2, max_phase, in_resid_b, kv_b, gu_b, norm_b, b_qkv_b, b_q_b, h_zero)
    puts("v2 dispatch: PASS")
    copy_outputs_d2h(dp_v2, in_resid_b, kv_b, gu_b, norm_b, b_qkv_b, b_q_b)

    // ── Bytewise diff all 10 output slabs ────────────────────────────────
    // Edit 1-2 lines here each slice to adjust expected mismatch set.
    uint64 r0 = diff_slab("out_residual", 12, dp_slot(dp_v1,24), dp_slot(dp_v2,24), in_resid_b)
    uint64 r1 = diff_slab("kc_layer",      8, dp_slot(dp_v1,25), dp_slot(dp_v2,25), kv_b)
    uint64 r2 = diff_slab("vc_layer",      8, dp_slot(dp_v1,26), dp_slot(dp_v2,26), kv_b)
    uint64 r3 = diff_slab("gu_scratch",   10, dp_slot(dp_v1,27), dp_slot(dp_v2,27), gu_b)
    uint64 r4 = diff_slab("b_x_norm_g",   10, dp_slot(dp_v1,28), dp_slot(dp_v2,28), norm_b)
    uint64 r5 = diff_slab("b_qkv_g",       7, dp_slot(dp_v1,29), dp_slot(dp_v2,29), b_qkv_b)
    uint64 r6 = diff_slab("b_attn_q_g",   10, dp_slot(dp_v1,30), dp_slot(dp_v2,30), b_q_b)
    uint64 r7 = diff_slab("b_mid_g",       7, dp_slot(dp_v1,31), dp_slot(dp_v2,31), norm_b)
    uint64 r8 = diff_slab("b_mid_norm_g", 12, dp_slot(dp_v1,32), dp_slot(dp_v2,32), norm_b)
    uint64 r9 = diff_slab("b_attn_out_g", 12, dp_slot(dp_v1,33), dp_slot(dp_v2,33), b_q_b)

    // Slice-4.19.7 gate: at MAX_PHASE=0..6 ALL slabs must match.
    //   MAX_PHASE=0: v2 phase 1 (rmsnorm) produces b_x_norm_g; all others zero = match.
    //   MAX_PHASE=1: v2 phase 3 (QKV matmul) produces b_qkv_g; must match v1.
    //   MAX_PHASE=2: v2 phase 5 (QKV split + qknorm + RoPE) produces kc_layer, vc_layer,
    //                b_attn_q_g; all 10 slabs must match v1.
    //   MAX_PHASE=3: v2 phase 7 (attn_decode-coop) produces b_attn_out_g; all slabs match.
    //   MAX_PHASE=4: v2 phase 9 (o_proj + residual-add) produces b_mid_g; all slabs match.
    //   MAX_PHASE=5: v2 phase 11 (post_norm rmsnorm) produces b_mid_norm_g; all slabs match.
    //   MAX_PHASE=6: v2 phase 13 (gate_up matmul) produces gu_scratch; all slabs match.
    // At MAX_PHASE>=7, phases 15+ are still stubs so downstream slabs will mismatch v1
    // (expected; those mismatches are informational, not failures).
    uint64 n_mismatch = r0 + r1 + r2 + r3 + r4 + r5 + r6 + r7 + r8 + r9

    if max_phase == 0 {
        if n_mismatch != 0 { puts("FAIL -- slice 4.19.7 gate (MAX_PHASE=0): expected all slabs to match"); exit(1) }
        puts("PASS -- slice 4.19.7 gate (MAX_PHASE=0)")
        exit(0)
    }
    if max_phase == 1 {
        if n_mismatch != 0 { puts("FAIL -- slice 4.19.7 gate (MAX_PHASE=1): expected all slabs to match"); exit(1) }
        puts("PASS -- slice 4.19.7 gate (MAX_PHASE=1)")
        exit(0)
    }
    if max_phase == 2 {
        if n_mismatch != 0 { puts("FAIL -- slice 4.19.7 gate (MAX_PHASE=2): expected all slabs to match"); exit(1) }
        puts("PASS -- slice 4.19.7 gate (MAX_PHASE=2)")
        exit(0)
    }
    if max_phase == 3 {
        if n_mismatch != 0 { puts("FAIL -- slice 4.19.7 gate (MAX_PHASE=3): expected all slabs to match"); exit(1) }
        puts("PASS -- slice 4.19.7 gate (MAX_PHASE=3)")
        exit(0)
    }
    if max_phase == 4 {
        if n_mismatch != 0 { puts("FAIL -- slice 4.19.7 gate (MAX_PHASE=4): expected all slabs to match"); exit(1) }
        puts("PASS -- slice 4.19.7 gate (MAX_PHASE=4)")
        exit(0)
    }
    if max_phase == 5 {
        if n_mismatch != 0 { puts("FAIL -- slice 4.19.7 gate (MAX_PHASE=5): expected all slabs to match"); exit(1) }
        puts("PASS -- slice 4.19.7 gate (MAX_PHASE=5)")
        exit(0)
    }
    if max_phase == 6 {
        if n_mismatch != 0 { puts("FAIL -- slice 4.19.7 gate (MAX_PHASE=6): expected all slabs to match"); exit(1) }
        puts("PASS -- slice 4.19.7 gate (MAX_PHASE=6)")
        exit(0)
    }
    put_kv("mismatch_slabs", 14, n_mismatch)
    if n_mismatch == 0 { puts("all slabs match") }
    exit(0)
}
