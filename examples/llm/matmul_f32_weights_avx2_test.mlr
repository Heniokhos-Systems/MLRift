// Phase F1 validator for slice 8.3 (Llama-3.2-3B fp32 path, 2026-05-14).
//
// Bit-exact equivalence between the new f32-weights AVX2 worker and the
// existing bf16-weights AVX2 worker (std/matmul.mlr).
//
// Strategy:
//   1. Generate deterministic bf16 W [N, K] via xorshift32.
//   2. Materialize a parallel f32 weight buffer Wf32 where every element
//      is the bf16-widened form of the corresponding bf16 element
//      (low 16 bits = 0). Math-equivalent to feeding the bf16 weights
//      through the bf16-widen step that mm_worker_bf16_f32_avx2_naive
//      does inline (vpmovzxwd + vpslld).
//   3. Generate deterministic f32 X [K] via xorshift32.
//   4. Run mm_worker_bf16_f32_avx2_naive → out_bf16[N]
//   5. Run mm_worker_f32_weights_f32_avx2_naive → out_f32[N]
//   6. Byte-compare out_bf16 vs out_f32. Expect mismatch_dwords == 0
//      for ALL K (the reduction tree is identical; only the load shape
//      and stride differ, and the bf16→f32 widen is replaced by a
//      direct 32-byte f32 load of pre-widened weights).
//
// Build:
//   ./build/mlrc --arch=x86_64 --target=linux --emit=elfexe \
//                -o /tmp/matmul_f32_test \
//                examples/llm/matmul_f32_weights_avx2_test.mlr
// Run:
//   /tmp/matmul_f32_test
//   K=8    /tmp/matmul_f32_test    # single AVX2 iter
//   K=32   N=16   /tmp/matmul_f32_test
//   K=3072 N=512  /tmp/matmul_f32_test    # Llama-3B QKV shape (smaller N)
// Success criterion: prints "matmul_f32_weights_avx2: PASS (mismatches=0 over N dwords)"

import "../../std/io.mlr"
import "../../std/fmt.mlr"
import "../../std/string.mlr"
import "../../std/matmul.mlr"

@dynamic extern fn exit(uint64 code)
@dynamic extern fn getenv(uint64 name) -> uint64

fn parse_env_u64(u64 name, u64 default_v) -> u64 {
    u64 ev = getenv(name)
    if ev == 0 { return default_v }
    u64 parsed = 0; u64 i = 0
    u8 c = 0; unsafe { *(ev as u8) -> c }
    while c >= 48 && c <= 57 {
        parsed = parsed * 10 + (c - 48); i = i + 1
        unsafe { *((ev + i) as u8) -> c }
    }
    if parsed > 0 { return parsed }
    return default_v
}

// Single-iteration xorshift32 — deterministic test data.
fn xorshift32(u64 state) -> u64 {
    u64 s = state & 0xFFFFFFFF
    s = (s ^ (s << 13)) & 0xFFFFFFFF
    s = (s ^ (s >> 17)) & 0xFFFFFFFF
    s = (s ^ (s << 5))  & 0xFFFFFFFF
    return s
}

// Build a sane f32 bit pattern from a 32-bit xorshift word:
//   sign = bit 31, mantissa = bits 0..22, exponent = 0x7D (≈ 2^-2 .. 2^-1).
// Avoids subnormals / inf / NaN so the matmul outputs stay finite.
fn rand_word_to_f32_bits(u64 r) -> u64 {
    u64 sign = (r >> 31) & 1
    u64 mant = r & 0x7FFFFF
    u64 exp  = 0x7D
    u64 bits = (sign << 31) | (exp << 23) | mant
    return bits & 0xFFFFFFFF
}

// bf16 = top 16 bits of f32.
fn rand_word_to_bf16_bits(u64 r) -> u64 {
    u64 f32_bits = rand_word_to_f32_bits(r)
    return (f32_bits >> 16) & 0xFFFF
}

// Run mm_worker_bf16_f32_avx2_naive(0, N, ctx) once on a freshly populated ctx.
fn run_bf16_worker(u64 out_ptr, u64 x_ptr, u64 w_ptr, u64 M, u64 N, u64 K) {
    u64 ctx = alloc(48)
    unsafe { *(ctx as u64) = out_ptr }
    u64 c8  = ctx + 8;   unsafe { *(c8  as u64) = x_ptr }
    u64 c16 = ctx + 16;  unsafe { *(c16 as u64) = w_ptr }
    u64 c24 = ctx + 24;  unsafe { *(c24 as u64) = M }
    u64 c32 = ctx + 32;  unsafe { *(c32 as u64) = N }
    u64 c40 = ctx + 40;  unsafe { *(c40 as u64) = K }
    mm_worker_bf16_f32_avx2_naive(0, N, ctx)
    dealloc(ctx)
}

fn run_f32_worker(u64 out_ptr, u64 x_ptr, u64 w_ptr, u64 M, u64 N, u64 K) {
    u64 ctx = alloc(48)
    unsafe { *(ctx as u64) = out_ptr }
    u64 c8  = ctx + 8;   unsafe { *(c8  as u64) = x_ptr }
    u64 c16 = ctx + 16;  unsafe { *(c16 as u64) = w_ptr }
    u64 c24 = ctx + 24;  unsafe { *(c24 as u64) = M }
    u64 c32 = ctx + 32;  unsafe { *(c32 as u64) = N }
    u64 c40 = ctx + 40;  unsafe { *(c40 as u64) = K }
    mm_worker_f32_weights_f32_avx2_naive(0, N, ctx)
    dealloc(ctx)
}

fn run_one(u64 N, u64 K) -> u64 {
    print_str("  shape N="); u64 sn = fmt_dec(N); print_str(sn); dealloc(sn)
    print_str(" K="); u64 sk = fmt_dec(K); print_str(sk); dealloc(sk); print_str("\n")

    // --- Allocate buffers ---
    u64 bytes_wb = N * K * 2     // bf16 weight  [N, K]
    u64 bytes_wf = N * K * 4     // f32  weight  [N, K] (bf16-widened)
    u64 bytes_x  = K * 4         // f32  input  [K]
    u64 bytes_y  = N * 4         // f32  output [N]

    u64 h_W_bf16 = alloc(bytes_wb)
    u64 h_W_f32  = alloc(bytes_wf)
    u64 h_X      = alloc(bytes_x)
    u64 h_Y_bf16 = alloc(bytes_y)
    u64 h_Y_f32  = alloc(bytes_y)

    // Zero outputs (any garbage write would be detectable).
    u64 i = 0
    while i < bytes_y { uint8 z = 0; unsafe { *((h_Y_bf16 + i) as u8) = z }; i = i + 1 }
    i = 0
    while i < bytes_y { uint8 z = 0; unsafe { *((h_Y_f32 + i) as u8) = z }; i = i + 1 }

    // --- Populate bf16 W + parallel widened f32 W ---
    u64 state = 0xDEADBEEF
    u64 j = 0
    while j < N * K {
        state = xorshift32(state)
        u64 b16 = rand_word_to_bf16_bits(state)
        // Store bf16 (2 bytes LE).
        u64 pwb = h_W_bf16 + j * 2
        uint8 b0 = b16 & 0xFF
        uint8 b1 = (b16 >> 8) & 0xFF
        unsafe { *(pwb as u8) = b0 }
        unsafe { *((pwb + 1) as u8) = b1 }
        // Widened f32 = bf16_bits << 16  (low 16 bits = 0).
        u64 f32_bits = (b16 << 16) & 0xFFFFFFFF
        u64 pwf = h_W_f32 + j * 4
        uint8 c0 = f32_bits & 0xFF
        uint8 c1 = (f32_bits >> 8) & 0xFF
        uint8 c2 = (f32_bits >> 16) & 0xFF
        uint8 c3 = (f32_bits >> 24) & 0xFF
        unsafe { *(pwf as u8) = c0 }
        unsafe { *((pwf + 1) as u8) = c1 }
        unsafe { *((pwf + 2) as u8) = c2 }
        unsafe { *((pwf + 3) as u8) = c3 }
        j = j + 1
    }

    // --- Populate X (f32) ---
    j = 0
    while j < K {
        state = xorshift32(state)
        u64 bits = rand_word_to_f32_bits(state)
        u64 p = h_X + j * 4
        uint8 b0 = bits & 0xFF
        uint8 b1 = (bits >> 8) & 0xFF
        uint8 b2 = (bits >> 16) & 0xFF
        uint8 b3 = (bits >> 24) & 0xFF
        unsafe { *(p as u8) = b0 }
        unsafe { *((p + 1) as u8) = b1 }
        unsafe { *((p + 2) as u8) = b2 }
        unsafe { *((p + 3) as u8) = b3 }
        j = j + 1
    }

    // --- Run both workers (M=1, single-thread direct call) ---
    run_bf16_worker(h_Y_bf16, h_X, h_W_bf16, 1, N, K)
    run_f32_worker (h_Y_f32,  h_X, h_W_f32,  1, N, K)

    // --- Compare byte-for-byte ---
    u64 mismatch = 0
    u64 first_bad = 0xFFFFFFFFFFFFFFFF
    u64 first_bad_bf16 = 0
    u64 first_bad_f32  = 0
    u64 n_i = 0
    while n_i < N {
        u64 cp = h_Y_bf16 + n_i * 4
        u64 gp = h_Y_f32  + n_i * 4
        u32 cv = 0; unsafe { *(cp as u32) -> cv }
        u32 gv = 0; unsafe { *(gp as u32) -> gv }
        if cv != gv {
            mismatch = mismatch + 1
            if first_bad == 0xFFFFFFFFFFFFFFFF {
                first_bad = n_i
                first_bad_bf16 = cv
                first_bad_f32  = gv
            }
        }
        n_i = n_i + 1
    }

    if mismatch == 0 {
        print_str("    OK: mismatches=0\n")
    } else {
        print_str("    FAIL: mismatches="); u64 sm = fmt_dec(mismatch); print_str(sm); dealloc(sm)
        print_str(" first_bad_n="); u64 sf = fmt_dec(first_bad); print_str(sf); dealloc(sf)
        print_str(" bf16_bits="); u64 sb = fmt_hex(first_bad_bf16); print_str(sb); dealloc(sb)
        print_str(" f32_bits=");  u64 sf2 = fmt_hex(first_bad_f32);  print_str(sf2); dealloc(sf2)
        print_str("\n")
    }

    dealloc(h_W_bf16)
    dealloc(h_W_f32)
    dealloc(h_X)
    dealloc(h_Y_bf16)
    dealloc(h_Y_f32)
    return mismatch
}

fn main() {
    u64 N_env = parse_env_u64("N", 0)
    u64 K_env = parse_env_u64("K", 0)

    u64 total_mismatch = 0

    if N_env != 0 && K_env != 0 {
        print_str("matmul_f32_weights_avx2_test: single shape\n")
        total_mismatch = run_one(N_env, K_env)
    } else {
        print_str("matmul_f32_weights_avx2_test: sweep\n")
        // K=8 — single AVX2 iter (no loop carried accumulator drift).
        total_mismatch = total_mismatch + run_one(4, 8)
        total_mismatch = total_mismatch + run_one(16, 8)
        // K=16 — two iters.
        total_mismatch = total_mismatch + run_one(16, 16)
        // K=32 — four iters.
        total_mismatch = total_mismatch + run_one(32, 32)
        // K=128 — practical-ish micro shape.
        total_mismatch = total_mismatch + run_one(64, 128)
        // K=3072 N=128 — Llama-3.2-3B QKV K dim, small N to stay fast.
        total_mismatch = total_mismatch + run_one(128, 3072)
    }

    if total_mismatch == 0 {
        print_str("matmul_f32_weights_avx2: PASS (mismatches=0)\n")
        exit(0)
    } else {
        print_str("matmul_f32_weights_avx2: FAIL total_mismatches=")
        u64 s = fmt_dec(total_mismatch); print_str(s); dealloc(s); print_str("\n")
        exit(1)
    }
}
