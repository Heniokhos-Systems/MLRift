// wzma_train_mega — single-workgroup WZMA+InfoNCE training mega-kernel.
//
// Task 1 of 8 (wzma-train-megakernel): scaffold + phase 1 (embed-gather).
//
// This @kernel is a NAME-ROUTED stub: the body below is illustrative (the
// CPU-readable reference of what phase 1 computes), but the actual ISA is
// produced by amdgpu_lower_wzma_train_mega in
// src/format_amdgpu_megakernel.mlr — selected by the kernel name
// "wzma_train_mega" in amdgpu_lower_kernel_to_table.  This mirrors the
// gate_bwd_bs_f32 / row_scale_f32 / transpose_f32 pattern.
//
// One workgroup, 512 threads.  Lane d (= threadIdx.x) gathers, for every
// bs in 0..BS-1:
//     x_out[bs*D + d] = emb[ids[bs]*D + d]
//
// Dims: B=8 S=16 D=384 K=4 R=32 vocab=8192 BS=128.
//
// Build:
//   ./build/mlrc --target=amdgpu-native \
//       examples/llm/wzma_train_mega_kernel.mlr \
//       -o ~/mlrift_bin/wzma_train/wzma_train_mega.co

fn block_idx_x() -> uint64 { return 0 }
fn tid_local_x() -> uint64 { return 0 }

@kernel
fn wzma_train_mega(
    uint64 ids_ptr,     // [BS] i32 token ids ([B,S] flattened)
    uint64 emb_ptr,     // [vocab,D] f32 embedding table
    uint64 x_out_ptr,   // [BS,D] f32 gathered output
    uint64 BS,
    uint64 D
) {
    uint64 d = tid_local_x()
    if d < D {
        uint64 bs = 0
        while bs < BS {
            uint32 id = 0
            unsafe { *((ids_ptr + bs * 4) as uint32) -> id }
            uint64 id64 = id
            uint64 emb_row = emb_ptr + id64 * D * 4
            uint64 out_row = x_out_ptr + bs * D * 4
            f32 v = 0.0
            unsafe { *((emb_row + d * 4) as f32) -> v }
            unsafe { *((out_row + d * 4) as f32) = v }
            bs = bs + 1
        }
    }
}

fn main() { exit(0) }
