// LLM Phase 3b-2 — softmax_f32 expressed as a real @kernel body.
// Numerically-stable softmax over rows of M×N f32 input (N=256).
// Recognised by `amdgpu_lower_softmax_f32_3b` in src/format_amdgpu.mlr.

fn block_idx_x() -> uint64 { return 0 }
fn tid_local_x() -> uint64 { return 0 }
fn lds_reduce_max_f32(f32 x) -> f32 { return x }
fn lds_reduce_sum_f32(f32 x) -> f32 { return x }
fn exp_f32(f32 x) -> f32 { return x }
fn rcp_f32(f32 x) -> f32 { return x }

@kernel
fn softmax_f32(uint64 in_ptr, uint64 out_ptr, uint64 m, uint64 n) {
    uint64 row = block_idx_x()
    uint64 lane = tid_local_x()
    if row < m {
        uint64 row_off = row * n
        uint64 idx = row_off + lane
        uint64 ip = in_ptr + idx * 4
        uint64 op = out_ptr + idx * 4
        f32 x = 0.0
        unsafe { *(ip as f32) -> x }
        f32 max_x = lds_reduce_max_f32(x)
        f32 xm = x - max_x
        f32 ex = exp_f32(xm)
        f32 sum_ex = lds_reduce_sum_f32(ex)
        f32 inv = rcp_f32(sum_ex)
        f32 r = ex * inv
        unsafe { *(op as f32) = r }
    }
}

fn main() {
    exit(0)
}
