// Slice 4.18 — load the native-emit qwen3 mega-kernel .co and resolve
// its symbol.  Validates the ELF wrapping (KD bytes, metadata MsgPack,
// symbol table, dynamic section) MLRift's own .co packager produced
// against the .text bytes pulled from the hipcc -O3 reference.
//
// A successful load proves the .co is bit-exact equivalent to the
// hipcc-built one from HIP runtime's perspective — the ROCm loader
// would reject any mis-encoded KD or metadata at hipModuleLoadData.
//
// Build:
//   ./build/mlrc --emit-amdgpu-qwen3-megakernel=/tmp/qwen3_layer_megakernel_native.co dummy
//   ./build/mlrc --arch=x86_64 \
//       examples/llm/qwen3_layer_megakernel_native_load_smoke.mlr \
//       -o /tmp/qwen3_native_load_smoke
// Run:
//   /tmp/qwen3_native_load_smoke

import "../../std/hip.mlr"

@dynamic extern fn puts(uint64 s) -> uint32
@dynamic extern fn write(int32 fd, uint64 buf, uint64 n) -> int64
@dynamic extern fn exit(uint64 code)

fn main() {
    uint32 err = hipSetDevice(0)
    if err != 0 { puts("setDev failed"); exit(1) }

    uint64 fd = file_open("/tmp/qwen3_layer_megakernel_native.co", 0)
    if fd > 0xFFFFFFFFFFFFF000 { puts("open failed (run --emit-amdgpu-qwen3-megakernel first)"); exit(1) }
    uint64 sz = file_size(fd)
    uint64 blob = alloc(sz)
    file_read(fd, blob, sz)
    file_close(fd)

    uint64 mod_slot = alloc(8)
    err = hipModuleLoadData(mod_slot, blob)
    if err != 0 { puts("hipModuleLoadData failed (.co is malformed)"); exit(1) }
    uint64 mod = 0
    unsafe { *(mod_slot as uint64) -> mod }

    uint64 fh_slot = alloc(8)
    err = hipModuleGetFunction(fh_slot, mod, "qwen3_layer_megakernel")
    if err != 0 { puts("hipModuleGetFunction failed (symbol missing)"); exit(1) }

    puts("ok: native qwen3_layer_megakernel.co loaded and symbol resolved")
    exit(0)
}
