// LLM Phase 3c-12 — qkv_split_f32 expressed as a real @kernel body.
// Splits the fused [qkv_dim] activation into K and V slot buffers.
// Q stays in-place in the source buffer; K and V are copied out to
// the per-position K/V cache slots.  Hardcoded q_dim=2048 (Qwen3-0.6B).

fn block_idx_x() -> uint64 { return 0 }
fn tid_local_x() -> uint64 { return 0 }

@kernel
fn qkv_split_f32(uint64 qkv_ptr, uint64 k_slot_ptr, uint64 v_slot_ptr) {
    uint64 wg = block_idx_x()
    uint64 lane = tid_local_x()
    uint64 idx = wg * 128 + lane
    uint64 src_off = (2048 + idx) * 4
    uint64 src = qkv_ptr + src_off
    f32 v = 0.0
    unsafe { *(src as f32) -> v }
    if idx < 512 {
        uint64 dk = k_slot_ptr + idx * 4
        unsafe { *(dk as f32) = v }
    }
    if idx >= 512 {
        uint64 dv = v_slot_ptr + (idx - 512) * 4
        unsafe { *(dv as f32) = v }
    }
}

fn main() {
    exit(0)
}
