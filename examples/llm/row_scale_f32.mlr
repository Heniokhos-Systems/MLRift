// row_scale_f32 — per-element scale by per-row scalar.
//
// out[bs, d] = in[bs, d] * scale[bs]
//
// Params:
//   in_ptr:    [BS*D] f32 input
//   scale_ptr: [BS]   f32 per-row scale values
//   out_ptr:   [BS*D] f32 output
//   n:         total elements = BS * D
//   row_width: D (inner dimension)
//
// Grid: ceil(BS*D/256) blocks × 256 threads.
//
// Build:
//   ./build/mlrc --arch=x86_64 --target=amdgpu-native \
//       examples/llm/row_scale_f32.mlr -o /tmp/row_scale_f32

fn block_idx_x() -> uint64 { return 0 }
fn tid_local_x() -> uint64 { return 0 }

@kernel
fn row_scale_f32(uint64 in_ptr, uint64 scale_ptr, uint64 out_ptr, uint64 n, uint64 row_width) {
    uint64 gid = block_idx_x() * 256 + tid_local_x()
    if gid < n {
        uint64 bs = gid / row_width
        uint64 d  = gid - bs * row_width
        uint64 ip = in_ptr    + gid * 4
        uint64 sp = scale_ptr + bs * 4
        uint64 op = out_ptr   + gid * 4
        f32 v = 0.0
        unsafe { *(ip as f32) -> v }
        f32 s = 0.0
        unsafe { *(sp as f32) -> s }
        unsafe { *(op as f32) = v * s }
    }
}

fn main() {
    exit(0)
}
