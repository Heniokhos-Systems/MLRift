// wzma_bwd_pre — full-occupancy backward phase 1: InfoNCE-bwd + renorm/L2/
// meanpool.  NAME-ROUTED stub: real ISA from amdgpu_lower_wzma_bwd_pre in
// src/format_amdgpu_megakernel.mlr (reuses the validated _wzm_emit_* math).
// grid=1 (B=8 logits matrix is single-WG by construction).  Writes dv1/dv2 +
// dz1/dz2.  Same 63-arg kernarg block as wzma_train_bwd.
//
// Build:
//   ./build/mlrc --target=amdgpu-native \
//       examples/llm/wzma_bwd_pre_kernel.mlr -o /tmp/wzma_bwd_pre

fn block_idx_x() -> uint64 { return 0 }
fn tid_local_x() -> uint64 { return 0 }

@kernel
fn wzma_bwd_pre(
    uint64 ids1_ptr,    // 0x00
    uint64 emb_ptr,     // 0x08
    uint64 x_out_ptr,   // 0x10
    uint64 U_ptr,       // 0x18
    uint64 V_ptr        // 0x20
) {
    uint64 d = tid_local_x()
    if d < 384 {
        uint32 id = 0
        unsafe { *((ids1_ptr + d * 4) as uint32) -> id }
    }
}

fn main() { exit(0) }
