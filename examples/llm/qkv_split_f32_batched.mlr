// LLM Phase 3c-14 — qkv_split_f32_batched expressed as a real @kernel.
// Same K/V split as qkv_split_f32 but with block_idx_y for the batch
// stream.  Discriminator: 3 params + block_idx_y() presence.

fn block_idx_x() -> uint64 { return 0 }
fn block_idx_y() -> uint64 { return 0 }
fn tid_local_x() -> uint64 { return 0 }

@kernel
fn qkv_split_f32_batched(uint64 qkv_ptr, uint64 k_slot_ptr, uint64 v_slot_ptr) {
    uint64 wg = block_idx_x()
    uint64 batch = block_idx_y()
    uint64 lane = tid_local_x()
    uint64 idx = wg * 128 + lane
    uint64 qkv_stride = 4096
    uint64 src_off = batch * qkv_stride + (2048 + idx) * 4
    uint64 src = qkv_ptr + src_off
    f32 v = 0.0
    unsafe { *(src as f32) -> v }
    if idx < 512 {
        uint64 dk = k_slot_ptr + (batch * 1024 + idx) * 4
        unsafe { *(dk as f32) = v }
    }
    if idx >= 512 {
        uint64 dv = v_slot_ptr + (batch * 1024 + idx - 512) * 4
        unsafe { *(dv as f32) = v }
    }
}

fn main() {
    exit(0)
}
