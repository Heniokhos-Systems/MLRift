// Smoke test for gemv_coop_bf16_f32_batched.  Computes
//   out[batch, N] = w_bf16[N, K] @ x[batch, K]^T
// on the GPU via the new bf16-direct batched kernel and compares against
// matmul_bf16_weights_f32 per stream.
//
// Build:
//   ./build/mlrc --arch=x86_64 --emit-amdgpu-gemv-coop-bf16-f32-batched=/tmp/gemv_coop_bf16_f32_batched.co dummy
//   ./build/mlrc --arch=x86_64 --target=amdgpu-native examples/llm/gemv_batched_bf16_smoke.mlr -o /tmp/gemv_batched_bf16_smoke
// Run:
//   /tmp/gemv_batched_bf16_smoke

import "../../std/hip.mlr"
import "../../std/inference.mlr"
import "../../std/io.mlr"
import "../../std/fmt.mlr"
import "../../std/string.mlr"
import "../../std/thread.mlr"
import "../../std/time.mlr"
import "../../std/math_float.mlr"

@dynamic extern fn exit(uint64 code)
@dynamic extern fn getenv(uint64 name) -> uint64

fn die(uint64 msg, uint64 code) {
    print_str(msg); print_str(" e="); u64 s = fmt_dec(code); print_str(s); dealloc(s); print_str("\n"); exit(1)
}

fn main() {
    u64 num_workers = 16
    thread_pool_init(num_workers)
    uint32 err = hipSetDevice(0); if err != 0 { die("setDev", err) }

    u64 fd = file_open("/tmp/gemv_coop_bf16_f32_batched.co", 0)
    if fd > 0xFFFFFFFFFFFFF000 { die("missing co", 0) }
    u64 sz = file_size(fd); u64 blob = alloc(sz)
    file_read(fd, blob, sz); file_close(fd)
    u64 mod_slot = alloc(8)
    err = hipModuleLoadData(mod_slot, blob); if err != 0 { die("LoadData", err) }
    u64 mod = 0; unsafe { *(mod_slot as u64) -> mod }
    u64 fh_slot = alloc(8)
    err = hipModuleGetFunction(fh_slot, mod, "gemv_coop_bf16_f32_batched"); if err != 0 { die("getFn", err) }
    u64 fh = 0; unsafe { *(fh_slot as u64) -> fh }
    print_str("gemv_coop_bf16_f32_batched loaded\n")

    u64 N = 4096
    u64 K = 1024
    u64 batch = 1
    u64 ev_n = getenv("N")
    if ev_n != 0 {
        u64 parsed = 0; u64 ii = 0
        u8 cc = 0; unsafe { *(ev_n as u8) -> cc }
        while cc >= 48 && cc <= 57 { parsed = parsed * 10 + (cc - 48); ii = ii + 1; unsafe { *((ev_n + ii) as u8) -> cc } }
        if parsed > 0 { N = parsed }
    }
    u64 ev_b = getenv("B")
    if ev_b != 0 {
        u64 parsed = 0; u64 ii = 0
        u8 cc = 0; unsafe { *(ev_b as u8) -> cc }
        while cc >= 48 && cc <= 57 { parsed = parsed * 10 + (cc - 48); ii = ii + 1; unsafe { *((ev_b + ii) as u8) -> cc } }
        if parsed > 0 { batch = parsed }
    }
    print_str("N="); u64 sn = fmt_dec(N); print_str(sn); dealloc(sn)
    print_str(" K="); u64 sk = fmt_dec(K); print_str(sk); dealloc(sk)
    print_str(" batch="); u64 sb = fmt_dec(batch); print_str(sb); dealloc(sb); print_str("\n")
    u64 w_bytes   = N * K * 2          // bf16
    u64 x_bytes   = batch * K * 4      // f32
    u64 out_bytes = batch * N * 4      // f32

    u64 h_w   = alloc(w_bytes)
    u64 h_x   = alloc(x_bytes)
    u64 h_ref = alloc(out_bytes)
    u64 h_gpu = alloc(out_bytes)

    // Synthetic bf16 weights: take top 16 bits of f32 values (round-down).
    u64 i = 0
    while i < N * K {
        f64 vd = (int_to_f64(i % 997) * 0.001) - 0.5
        f32 vf = f64_to_f32(vd)
        u64 pf = alloc(4); unsafe { *(pf as f32) = vf }
        u32 fbits = 0; unsafe { *(pf as u32) -> fbits }
        u16 b16 = (fbits >> 16) & 0xFFFF
        unsafe { *((h_w + i * 2) as u16) = b16 }
        dealloc(pf)
        i = i + 1
    }
    // f32 inputs (per-batch).
    i = 0
    while i < batch * K {
        f64 v = (int_to_f64(i) * 0.0003) - 0.05
        unsafe { *((h_x + i * 4) as f32) = f64_to_f32(v) }
        i = i + 1
    }

    // CPU reference: per-stream matmul_bf16_weights_f32 with 1 row.
    u64 b = 0
    while b < batch {
        u64 x_row   = h_x + b * K * 4
        u64 out_row = h_ref + b * N * 4
        matmul_bf16_weights_f32_mt(out_row, x_row, h_w, 1, N, K, num_workers)
        b = b + 1
    }
    print_str("CPU reference computed\n")

    u64 d_w = 0; u64 d_x = 0; u64 d_out = 0
    u64 slot
    slot = alloc(8); err = hipMalloc(slot, w_bytes);   if err != 0 { die("mw",  err) }; unsafe { *(slot as u64) -> d_w }
    slot = alloc(8); err = hipMalloc(slot, x_bytes);   if err != 0 { die("mx",  err) }; unsafe { *(slot as u64) -> d_x }
    slot = alloc(8); err = hipMalloc(slot, out_bytes); if err != 0 { die("mout",err) }; unsafe { *(slot as u64) -> d_out }
    err = hipMemcpy(d_w, h_w, w_bytes, 1); if err != 0 { die("H2D w", err) }
    err = hipMemcpy(d_x, h_x, x_bytes, 1); if err != 0 { die("H2D x", err) }

    u64 a0 = alloc(8); unsafe { *(a0 as u64) = d_w }
    u64 a1 = alloc(8); unsafe { *(a1 as u64) = d_x }
    u64 a2 = alloc(8); unsafe { *(a2 as u64) = d_out }
    u64 a3 = alloc(8); unsafe { *(a3 as u64) = N }
    u64 a4 = alloc(8); unsafe { *(a4 as u64) = K }
    u64 kp = alloc(5 * 8)
    unsafe { *(kp        as u64) = a0 }
    unsafe { *((kp +  8) as u64) = a1 }
    unsafe { *((kp + 16) as u64) = a2 }
    unsafe { *((kp + 24) as u64) = a3 }
    unsafe { *((kp + 32) as u64) = a4 }

    u64 t0 = time_now()
    u32 cgrid_x = N
    u32 cgrid_y = batch
    err = hipModuleLaunchKernel(fh, cgrid_x, cgrid_y, 1, 32, 1, 1, 0, 0, kp, 0)
    if err != 0 { die("launch", err) }
    err = hipDeviceSynchronize(); if err != 0 { die("sync", err) }
    u64 t1 = time_now()

    err = hipMemcpy(h_gpu, d_out, out_bytes, 2); if err != 0 { die("D2H", err) }
    print_str("kernel_us="); u64 ks = fmt_dec((t1 - t0) / 1000); print_str(ks); dealloc(ks); print_str("\n")

    // Compare bit-exactly against the CPU reference (same accumulation
    // order on GPU vs CPU since CPU matmul does sequential f32 fmac in
    // K-order and the GPU lane partitioning then reduces).  We accept
    // small numerical drift due to LDS reduce-tree order — bit-exact
    // is unrealistic across CPU summation order vs LDS reduce.
    u64 fail = 0
    u64 nan_gpu = 0
    f32 max_abs = 0.0f
    u64 k = 0
    while k < batch * N {
        u32 cb = 0; u32 gb = 0
        unsafe { *((h_ref + k * 4) as u32) -> cb }
        unsafe { *((h_gpu + k * 4) as u32) -> gb }
        u32 g_exp = (gb >> 23) & 0xFF; u32 g_man = gb & 0x7FFFFF
        if g_exp == 0xFF && g_man != 0 { nan_gpu = nan_gpu + 1 }
        f32 cv = 0.0f; unsafe { *((h_ref + k * 4) as f32) -> cv }
        f32 gv = 0.0f; unsafe { *((h_gpu + k * 4) as f32) -> gv }
        f32 d = cv - gv; if d < 0.0f { d = 0.0f - d }
        if d > max_abs { max_abs = d }
        f32 ac = cv; if ac < 0.0f { ac = 0.0f - ac }
        f32 thresh = ac * 0.001f
        if thresh < 0.001f { thresh = 0.001f }
        if d > thresh { fail = fail + 1 }
        k = k + 1
    }
    u64 total = batch * N
    print_str("batched-bf16-gemv fail count: "); u64 sf = fmt_dec(fail); print_str(sf); dealloc(sf)
    print_str(" / "); u64 stot = fmt_dec(total); print_str(stot); dealloc(stot); print_str("\n")
    print_str("nan_gpu: "); u64 sng = fmt_dec(nan_gpu); print_str(sng); dealloc(sng); print_str("\n")
    u64 mb = alloc(4); unsafe { *(mb as f32) = max_abs }
    u32 mb_b = 0; unsafe { *(mb as u32) -> mb_b }
    u64 mb64 = mb_b
    print_str("max abs diff bits="); u64 smb = fmt_dec(mb64); print_str(smb); dealloc(smb); print_str("\n"); dealloc(mb)
    if fail == 0 && nan_gpu == 0 {
        print_str("OK — gemv_coop_bf16_f32_batched matches per-stream reference.\n")
        thread_pool_shutdown(); exit(0)
    } else {
        print_str("FAIL\n")
        thread_pool_shutdown(); exit(1)
    }
}
