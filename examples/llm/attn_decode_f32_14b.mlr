fn lds_reduce_max_f32(f32 x) -> f32 { return x }
fn lds_reduce_sum_f32(f32 x) -> f32 { return x }
fn exp_f32(f32 x) -> f32 { return x }
fn attn_decode_14b_marker() -> uint64 { return 0 }

@kernel
fn attn_decode_f32_14b(
    uint64 q_ptr,
    uint64 k_cache_ptr,
    uint64 v_cache_ptr,
    uint64 out_ptr,
