// Microbench: how long does alloc(8) actually take?
import "../../std/io.mlr"
import "../../std/fmt.mlr"
import "../../std/time.mlr"

@dynamic extern fn exit(uint64 code)

fn main() {
    u64 N = 10000
    u64 t0 = time_now()
    u64 i = 0
    while i < N {
        u64 p = alloc(8)
        unsafe { *(p as u64) = i }
        i = i + 1
    }
    u64 t1 = time_now()
    u64 dt = t1 - t0
    print_str("alloc(8) x "); u64 sn = fmt_dec(N); print_str(sn); dealloc(sn)
    print_str(" took "); u64 sd = fmt_dec(dt / 1000); print_str(sd); dealloc(sd); print_str(" us\n")
    print_str("mean ns/alloc: "); u64 sm = fmt_dec(dt / N); print_str(sm); dealloc(sm); print_str("\n")
    exit(0)
}
