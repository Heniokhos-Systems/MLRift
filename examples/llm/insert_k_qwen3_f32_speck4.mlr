// LLM Phase 3c-20 — insert_k_qwen3_f32_speck4 expressed as a real
// @kernel.  Per-position stride 4096 (vs insert_k's per-batch 262144).
// Discriminator: insert_k_speck4_marker() Call.

fn block_idx_x() -> uint64 { return 0 }
fn block_idx_y() -> uint64 { return 0 }
fn tid_local_x() -> uint64 { return 0 }
fn insert_k_speck4_marker() -> uint64 { return 0 }

@kernel
fn insert_k_qwen3_f32_speck4(uint64 src_ptr, uint64 k_cache_ptr) {
    uint64 wg_x = block_idx_x()
    uint64 pos  = block_idx_y()
    uint64 lane = tid_local_x()
    uint64 _m = insert_k_speck4_marker()
    uint64 src_off = pos * 4096 + wg_x * 512 + lane * 4
    uint64 dst_off = pos * 4096 + wg_x * 512 + lane * 4
    uint64 src = src_ptr     + src_off
    uint64 dst = k_cache_ptr + dst_off
    f32 v = 0.0
    unsafe { *(src as f32) -> v }
    unsafe { *(dst as f32) = v }
}

fn main() {
    exit(0)
}
