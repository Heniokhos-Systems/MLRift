// Phase F3a validator for Llama-3.2-3B fp32 bit-exactness (2026-05-14).
//
// Standalone launcher that:
//   1. Generates deterministic fp32 W [N,K] + f32 X [K] via xorshift.
//   2. Computes a CPU reference inline that mirrors the 8-lane stride-8
//      vhaddps reduction tree the GPU kernel emits (8 parallel accumulators
//      reduced via XOR offsets [4,1,2]).
//   3. Dispatches the new gemv_coop_f32_f32_cputree kernel.
//   4. Byte-compares CPU vs GPU output dword-for-dword.
//
// SUCCESS = mismatch_dwords: 0, first_bad: -1.
//
// Build:
//   ./build/mlrc --emit-amdgpu-gemv-coop-f32-f32-cputree=/tmp/gemv_coop_f32_f32_cputree.co
//   ./build/mlrc --arch=x86_64 --target=amdgpu-native -o /tmp/gemv_f32_cputree_launch \
//                examples/llm/gemv_coop_f32_f32_cputree_launch.mlr
// Run:
//   GEMV_K=3072 GEMV_N=5120 /tmp/gemv_f32_cputree_launch     # Llama-3B QKV shape
//   GEMV_K=1024 GEMV_N=2048 /tmp/gemv_f32_cputree_launch     # Qwen3 shape
//   GEMV_K=4096 GEMV_N=6144 /tmp/gemv_f32_cputree_launch     # Mistral shape

import "../../std/hip.mlr"

@dynamic extern fn puts(uint64 s) -> uint32
@dynamic extern fn write(int32 fd, uint64 buf, uint64 n) -> int64
@dynamic extern fn exit(uint64 code)
@dynamic extern fn getenv(uint64 name) -> uint64

static uint64 N_DEF = 5120
static uint64 K_DEF = 3072

fn u64_to_ascii_decimal(uint64 val, uint64 buf) -> uint64 {
    if val == 0 { uint8 z = 48; unsafe { *(buf as uint8) = z }; return 1 }
    uint64 n = 0
    uint64 tmp = val
    while tmp > 0 { n = n + 1; tmp = tmp / 10 }
    uint64 i = n
    tmp = val
    while i > 0 {
        i = i - 1
        uint64 d = tmp - (tmp / 10) * 10
        uint64 p = buf + i
        uint8 c = d + 48
        unsafe { *(p as uint8) = c }
        tmp = tmp / 10
    }
    return n
}

fn print_label_val(uint64 label, uint64 label_len, uint64 val) {
    uint64 buf = alloc(128)
    uint64 i = 0
    while i < label_len {
        uint64 sp = label + i
        uint64 c = 0
        unsafe { *(sp as uint8) -> c }
        uint64 dp = buf + i
        uint8 cb = c
        unsafe { *(dp as uint8) = cb }
        i = i + 1
    }
    uint64 cp = buf + label_len
    uint8 col = 58; unsafe { *(cp as uint8) = col }
    uint64 sp2 = buf + label_len + 1
    uint8 space = 32; unsafe { *(sp2 as uint8) = space }
    uint64 num_buf = buf + label_len + 2
    uint64 dlen = u64_to_ascii_decimal(val, num_buf)
    uint64 nul_p = buf + label_len + 2 + dlen
    uint8 nul = 0; unsafe { *(nul_p as uint8) = nul }
    puts(buf)
}

fn print_label_hex32(uint64 label, uint64 label_len, uint64 val) {
    uint64 buf = alloc(128)
    uint64 i = 0
    while i < label_len {
        uint64 sp = label + i
        uint64 c = 0
        unsafe { *(sp as uint8) -> c }
        uint64 dp = buf + i
        uint8 cb = c
        unsafe { *(dp as uint8) = cb }
        i = i + 1
    }
    uint64 cp = buf + label_len
    uint8 col = 58; unsafe { *(cp as uint8) = col }
    uint64 sp2 = buf + label_len + 1
    uint8 space = 32; unsafe { *(sp2 as uint8) = space }
    uint64 z0 = buf + label_len + 2; uint8 cz = 48; unsafe { *(z0 as uint8) = cz }
    uint64 z1 = buf + label_len + 3; uint8 cx = 120; unsafe { *(z1 as uint8) = cx }
    uint64 h = 0
    while h < 8 {
        uint64 shift = (7 - h) * 4
        uint64 nib = (val >> shift) & 0xF
        uint8 cnib = 0
        if nib < 10 { cnib = nib + 48 } else { cnib = nib - 10 + 97 }
        uint64 hp = buf + label_len + 4 + h
        unsafe { *(hp as uint8) = cnib }
        h = h + 1
    }
    uint64 nul_p = buf + label_len + 12
    uint8 nul = 0; unsafe { *(nul_p as uint8) = nul }
    puts(buf)
}

fn die(uint64 msg, uint64 code) {
    puts(msg)
    print_label_val("hipError", 8, code)
    exit(1)
}

fn parse_env_count(uint64 name) -> uint64 {
    uint64 s = getenv(name)
    if s == 0 { return 0 }
    uint64 v = 0
    uint64 i = 0
    while 1 == 1 {
        uint64 cp = s + i
        uint64 c = 0
        unsafe { *(cp as uint8) -> c }
        if c == 0 { break }
        if c >= 48 && c <= 57 { v = v * 10 + (c - 48); i = i + 1; continue }
        break
    }
    return v
}

fn xorshift32(uint64 state) -> uint64 {
    uint64 s = state & 0xFFFFFFFF
    s = (s ^ (s << 13)) & 0xFFFFFFFF
    s = (s ^ (s >> 17)) & 0xFFFFFFFF
    s = (s ^ (s << 5))  & 0xFFFFFFFF
    return s
}

// Convert a 32-bit xorshift word into a sensible f32 bit pattern:
// keep low 23 bits of mantissa, force exponent into a known range
// (0x7D = ~2^-2..2^-1 magnitude), random sign.
fn rand_word_to_f32_bits(uint64 r) -> uint64 {
    uint64 sign = (r >> 31) & 1
    uint64 mant = r & 0x7FFFFF
    uint64 exp  = 0x7D
    uint64 bits = (sign << 31) | (exp << 23) | mant
    return bits & 0xFFFFFFFF
}

fn main() {
    uint32 err = hipSetDevice(0)
    if err != 0 { die("hipSetDevice failed", err) }

    uint64 N = N_DEF
    uint64 K = K_DEF
    uint64 ne = parse_env_count("GEMV_N"); if ne != 0 { N = ne }
    uint64 ke = parse_env_count("GEMV_K"); if ke != 0 { K = ke }

    print_label_val("N", 1, N)
    print_label_val("K", 1, K)

    // ── Load .co ───────────────────────────────────────────────────────
    uint64 co_path = "/tmp/gemv_coop_f32_f32_cputree.co"
    uint64 fd = file_open(co_path, 0)
    if fd > 0xFFFFFFFFFFFFF000 {
        puts("cannot open /tmp/gemv_coop_f32_f32_cputree.co — build first via --emit-amdgpu-gemv-coop-f32-f32-cputree=/tmp/gemv_coop_f32_f32_cputree.co")
        exit(1)
    }
    uint64 co_size = file_size(fd)
    uint64 co_blob = alloc(co_size)
    file_read(fd, co_blob, co_size)
    file_close(fd)

    uint64 mod_slot = alloc(8)
    err = hipModuleLoadData(mod_slot, co_blob)
    if err != 0 { die("hipModuleLoadData", err) }
    uint64 mod = 0; unsafe { *(mod_slot as uint64) -> mod }

    uint64 fh_slot = alloc(8)
    err = hipModuleGetFunction(fh_slot, mod, "gemv_coop_f32_f32_cputree")
    if err != 0 { die("getFn gemv_coop_f32_f32_cputree", err) }
    uint64 fh = 0; unsafe { *(fh_slot as uint64) -> fh }

    // ── Allocate host + device buffers ────────────────────────────────
    uint64 bytes_w = N * K * 4     // f32 weight (4B per elem)
    uint64 bytes_x = K * 4         // f32 input
    uint64 bytes_y = N * 4         // f32 output

    uint64 h_W = alloc(bytes_w)
    uint64 h_X = alloc(bytes_x)
    uint64 h_Y_cpu = alloc(bytes_y)
    uint64 h_Y_gpu = alloc(bytes_y)

    // Zero output buffers.
    uint64 i = 0
    while i < bytes_y { uint64 p = h_Y_cpu + i; uint8 z = 0; unsafe { *(p as uint8) = z }; i = i + 1 }
    i = 0
    while i < bytes_y { uint64 p = h_Y_gpu + i; uint8 z = 0; unsafe { *(p as uint8) = z }; i = i + 1 }

    // ── Generate deterministic W (f32) and X (f32) via xorshift32 ─────
    uint64 state = 0xDEADBEEF
    uint64 j = 0
    while j < N * K {
        state = xorshift32(state)
        uint64 bits32 = rand_word_to_f32_bits(state)
        uint64 p = h_W + j * 4
        uint8 b0 = bits32 & 0xFF
        uint8 b1 = (bits32 >> 8) & 0xFF
        uint8 b2 = (bits32 >> 16) & 0xFF
        uint8 b3 = (bits32 >> 24) & 0xFF
        unsafe { *(p as uint8) = b0 }
        uint64 p1 = p + 1; unsafe { *(p1 as uint8) = b1 }
        uint64 p2 = p + 2; unsafe { *(p2 as uint8) = b2 }
        uint64 p3 = p + 3; unsafe { *(p3 as uint8) = b3 }
        j = j + 1
    }
    j = 0
    while j < K {
        state = xorshift32(state)
        uint64 bits32 = rand_word_to_f32_bits(state)
        uint64 p = h_X + j * 4
        uint8 b0 = bits32 & 0xFF
        uint8 b1 = (bits32 >> 8) & 0xFF
        uint8 b2 = (bits32 >> 16) & 0xFF
        uint8 b3 = (bits32 >> 24) & 0xFF
        unsafe { *(p as uint8) = b0 }
        uint64 p1 = p + 1; unsafe { *(p1 as uint8) = b1 }
        uint64 p2 = p + 2; unsafe { *(p2 as uint8) = b2 }
        uint64 p3 = p + 3; unsafe { *(p3 as uint8) = b3 }
        j = j + 1
    }

    // ── CPU reference: 8 stride-8 accumulators + [4,1,2] XOR-bpermute tree ─
    // Mirrors exactly what the GPU kernel computes per row:
    //   lane j ∈ [0..7] sums w_row[k*8 + j] * x[k*8 + j] for k in 0..K/8 (single
    //   v_fmac_f32_e32, so per-lane order is left-to-right FMA).  Then a
    //   3-level reduce with XOR offsets [4, 1, 2]:
    //     after 4: s'[i] = s[i] + s[i^4]
    //     after 1: s''[i] = s'[i] + s'[i^1]
    //     after 2: s'''[i] = s''[i] + s''[i^2]
    //   Lane 0 stores s'''[0].
    //
    // For lane 0 (which is what gets stored) the equivalent reduce is:
    //   T0 = (s[0] + s[4]) + (s[1] + s[5])
    //   T1 = (s[2] + s[6]) + (s[3] + s[7])
    //   out = T0 + T1
    uint64 acc_buf = alloc(8 * 4)   // 8 f32 accumulators
    uint64 k_blocks = K / 8

    uint64 n_row = 0
    while n_row < N {
        // Zero the 8 accumulators.
        uint64 li = 0
        while li < 8 {
            uint64 p = acc_buf + li * 4
            uint32 zw = 0
            unsafe { *(p as uint32) = zw }
            li = li + 1
        }
        // Inner: per stride-8 lane, accumulate K/8 single-rounded FMAs.
        //
        // The GPU emits v_fmac_f32_e32 which is a single-rounding FMA.
        // MLRift f32 ops emit separate mulss + addss (TWO roundings) so
        // a naive `acc + w*x` mismatches the GPU on ~LSB.
        //
        // Emulate single-rounded f32 FMA by promoting to f64: the product
        // (24+24 bit mantissa) fits exactly in f64 (52-bit mantissa); the
        // f64 add to the f64-promoted acc is also exact for f32-magnitude
        // values; narrowing back to f32 is a single rounding — bit-identical
        // to vfmadd231ss / v_fmac_f32_e32.
        uint64 lane = 0
        while lane < 8 {
            f32 acc = 0.0
            uint64 kb = 0
            while kb < k_blocks {
                uint64 idx = kb * 8 + lane
                uint64 wp = h_W + (n_row * K + idx) * 4
                uint64 xp = h_X + idx * 4
                f32 wv = 0.0
                f32 xv = 0.0
                unsafe { *(wp as f32) -> wv }
                unsafe { *(xp as f32) -> xv }
                f64 wd = f32_to_f64(wv)
                f64 xd = f32_to_f64(xv)
                f64 ad = f32_to_f64(acc)
                f64 nd = ad + wd * xd
                acc = f64_to_f32(nd)
                kb = kb + 1
            }
            uint64 ap = acc_buf + lane * 4
            unsafe { *(ap as f32) = acc }
            lane = lane + 1
        }
        // Reduce-tree mirroring GPU XOR offsets [4, 1, 2].  Lane 0 result:
        //   level 4: s4[0] = s[0] + s[4]; s4[1] = s[1] + s[5]; s4[2] = s[2] + s[6]; s4[3] = s[3] + s[7]
        //   level 1: s1[0] = s4[0] + s4[1]; s1[2] = s4[2] + s4[3]
        //   level 2: out = s1[0] + s1[2]
        uint64 p0 = acc_buf + 0; uint64 p1 = acc_buf + 4
        uint64 p2 = acc_buf + 8; uint64 p3 = acc_buf + 12
        uint64 p4 = acc_buf + 16; uint64 p5 = acc_buf + 20
        uint64 p6 = acc_buf + 24; uint64 p7 = acc_buf + 28
        f32 v0 = 0.0; f32 v1 = 0.0; f32 v2 = 0.0; f32 v3 = 0.0
        f32 v4 = 0.0; f32 v5 = 0.0; f32 v6 = 0.0; f32 v7 = 0.0
        unsafe { *(p0 as f32) -> v0 }
        unsafe { *(p1 as f32) -> v1 }
        unsafe { *(p2 as f32) -> v2 }
        unsafe { *(p3 as f32) -> v3 }
        unsafe { *(p4 as f32) -> v4 }
        unsafe { *(p5 as f32) -> v5 }
        unsafe { *(p6 as f32) -> v6 }
        unsafe { *(p7 as f32) -> v7 }
        f32 a0 = v0 + v4
        f32 a1 = v1 + v5
        f32 a2 = v2 + v6
        f32 a3 = v3 + v7
        f32 b0 = a0 + a1
        f32 b1 = a2 + a3
        f32 out = b0 + b1
        uint64 op = h_Y_cpu + n_row * 4
        unsafe { *(op as f32) = out }
        n_row = n_row + 1
    }
    puts("cpu_reference: done")

    // ── Allocate device buffers + upload W, X ─────────────────────────
    uint64 d_W = 0; uint64 d_X = 0; uint64 d_Y = 0
    uint64 slot = alloc(8); err = hipMalloc(slot, bytes_w); if err != 0 { die("malloc W", err) }; unsafe { *(slot as uint64) -> d_W }
    slot = alloc(8); err = hipMalloc(slot, bytes_x); if err != 0 { die("malloc X", err) }; unsafe { *(slot as uint64) -> d_X }
    slot = alloc(8); err = hipMalloc(slot, bytes_y); if err != 0 { die("malloc Y", err) }; unsafe { *(slot as uint64) -> d_Y }

    err = hipMemcpy(d_W, h_W, bytes_w, 1); if err != 0 { die("memcpy W H2D", err) }
    err = hipMemcpy(d_X, h_X, bytes_x, 1); if err != 0 { die("memcpy X H2D", err) }
    err = hipMemcpy(d_Y, h_Y_gpu, bytes_y, 1); if err != 0 { die("memcpy Y H2D", err) }

    // ── Pack kernargs: (W, X, Y, N, K).
    uint64 k_w = alloc(8); unsafe { *(k_w as uint64) = d_W }
    uint64 k_x = alloc(8); unsafe { *(k_x as uint64) = d_X }
    uint64 k_y = alloc(8); unsafe { *(k_y as uint64) = d_Y }
    uint64 k_n = alloc(8); uint64 nv = N; unsafe { *(k_n as uint64) = nv }
    uint64 k_k = alloc(8); uint64 kv = K; unsafe { *(k_k as uint64) = kv }
    uint64 kp = alloc(5 * 8)
    unsafe { *(kp        as uint64) = k_w }
    unsafe { *((kp +  8) as uint64) = k_x }
    unsafe { *((kp + 16) as uint64) = k_y }
    unsafe { *((kp + 24) as uint64) = k_n }
    unsafe { *((kp + 32) as uint64) = k_k }

    uint32 grid_x  = N
    uint32 block_x = 32

    err = hipModuleLaunchKernel(fh, grid_x, 1, 1, block_x, 1, 1, 0, 0, kp, 0)
    if err != 0 { die("launch", err) }
    err = hipDeviceSynchronize(); if err != 0 { die("sync", err) }

    err = hipMemcpy(h_Y_gpu, d_Y, bytes_y, 2); if err != 0 { die("memcpy Y D2H", err) }

    // ── Compare ────────────────────────────────────────────────────────
    uint64 mismatch = 0
    uint64 first_bad = 0xFFFFFFFFFFFFFFFF
    uint64 n_i = 0
    while n_i < N {
        uint64 cp = h_Y_cpu + n_i * 4
        uint64 gp = h_Y_gpu + n_i * 4
        uint64 cv = 0
        uint64 gv = 0
        unsafe { *(cp as uint32) -> cv }
        unsafe { *(gp as uint32) -> gv }
        if cv != gv {
            mismatch = mismatch + 1
            if first_bad == 0xFFFFFFFFFFFFFFFF { first_bad = n_i }
        }
        n_i = n_i + 1
    }

    print_label_val("mismatch_dwords", 15, mismatch)
    if mismatch == 0 {
        puts("first_bad: -1")
        puts("PASS")
    } else {
        print_label_val("first_bad", 9, first_bad)
        uint64 cp = h_Y_cpu + first_bad * 4
        uint64 gp = h_Y_gpu + first_bad * 4
        uint64 cv = 0
        uint64 gv = 0
        unsafe { *(cp as uint32) -> cv }
        unsafe { *(gp as uint32) -> gv }
        print_label_hex32("cpu_bits", 8, cv)
        print_label_hex32("gpu_bits", 8, gv)
        puts("FAIL")
    }

    hipFree(d_W); hipFree(d_X); hipFree(d_Y)
    exit(0)
}
