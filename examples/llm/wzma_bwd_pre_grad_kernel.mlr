// wzma_bwd_pre_grad — L1 Dispatch-2 of the split bwd_pre.  Reads the materialized
// shared [B,B] dlogits (offset 0) and computes dv1/dv2 (B-3) + dz1/dz2
// (renorm/L2/meanpool bwd), outputs gated to this WG's B-range.
// NAME-ROUTED stub: real ISA from amdgpu_lower_wzma_bwd_pre_grad in
// src/format_amdgpu_megakernel.mlr.  Same 71-arg kernarg block as wzma_bwd_pre.
//
// Build:
//   ./build/mlrc --target=amdgpu-native \
//       examples/llm/wzma_bwd_pre_grad_kernel.mlr -o /tmp/wzma_bwd_pre_grad

fn block_idx_x() -> uint64 { return 0 }
fn tid_local_x() -> uint64 { return 0 }

@kernel
fn wzma_bwd_pre_grad(
    uint64 ids1_ptr,    // 0x00
    uint64 emb_ptr,     // 0x08
    uint64 x_out_ptr,   // 0x10
    uint64 U_ptr,       // 0x18
    uint64 V_ptr        // 0x20
) {
    uint64 d = tid_local_x()
    if d < 384 {
        uint32 id = 0
        unsafe { *((ids1_ptr + d * 4) as uint32) -> id }
    }
}

fn main() { exit(0) }
