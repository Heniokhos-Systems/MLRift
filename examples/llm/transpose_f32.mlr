// transpose_f32 — out[N, M] = transpose(in[M, N]).
//
// 16×16 LDS-tile transpose; one workgroup per tile pair, 256 lanes per WG.
// LDS uses +1 stride padding (17×16 × 4 = 1088 bytes) to avoid bank conflicts.
//
// Grid: ((M+15)/16) × ((N+15)/16) workgroups packed into a 1-D grid_x.
// The kernel recovers (tile_m, tile_n) from wg_id_x internally.
//
// Kernarg layout (4 args, 32 bytes):
//   [0x00] uint64 in_ptr   (f32[M, N])   — read
//   [0x08] uint64 out_ptr  (f32[N, M])   — written
//   [0x10] uint64 m        — row count of in
//   [0x18] uint64 n        — column count of in
//
// Build:
//   ./build/mlrc --arch=x86_64 --target=amdgpu-native \
//       examples/llm/transpose_f32.mlr -o ~/mlrift_bin/wzma_train/transpose_f32
//
// The ISA is hand-coded in src/format_amdgpu.mlr:amdgpu_lower_transpose_f32().
// This file serves as the AST source; the kernel body is a stub — the
// name-dispatch recogniser replaces it with the full LDS-tile ISA before
// any body analysis.
//
// The resulting .co exports one kernel symbol: transpose_f32(in_ptr, out_ptr, m, n).
// Launch: tiles_m * tiles_n blocks of 256 threads.

fn block_idx_x() -> uint64 { return 0 }
fn tid_local_x() -> uint64 { return 0 }

@kernel
fn transpose_f32(uint64 in_ptr, uint64 out_ptr, uint64 m, uint64 n) {
    // Stub body — replaced by the name-dispatch ISA emitter.
    // The full kernel performs a coalesced 16×16 LDS-tiled transpose:
    //   1. Each lane loads in[tile_m*16 + row_in_tile, tile_n*16 + col_in_tile]
    //      into a shared LDS tile (row-major write, stride-padded for coalescing).
    //   2. After s_barrier, each lane reads out of LDS with swapped row/col and
    //      writes out[tile_n*16 + col_in_tile, tile_m*16 + row_in_tile].
    uint64 wg     = block_idx_x()
    uint64 lane   = tid_local_x()
    uint64 tiles_n = (n + 15) / 16
    uint64 tile_m  = wg / tiles_n
    uint64 tile_n  = wg - tile_m * tiles_n
    uint64 row = tile_m * 16 + lane / 16
    uint64 col = tile_n * 16 + lane - (lane / 16) * 16
    if row < m {
        if col < n {
            uint64 ip = in_ptr  + (row * n + col) * 4
            uint64 op = out_ptr + (col * m + row) * 4
            uint32 v = 0
            unsafe { *(ip as uint32) -> v }
            unsafe { *(op as uint32) = v }
        }
    }
}

fn main() {
    exit(0)
}
