// Slice 4.19.0 — qwen3-0.6B layer mega-kernel as a MLRift @kernel.
//
// HIP source: examples/llm/qwen3_layer_megakernel.hip.cpp
//
// This file is the MLRift-side declaration of the same 24-arg kernel.
// Slice 4.19.0: body rewritten as 9 stub phases + 8 mega_barrier calls,
// shaped exactly as plan Step 1.8: each phase is wrapped in
// `if (wg_id ...)` so the AST walker can dispatch each block to a
// phase-shape sub-recognizer starting at slice 4.19.1.
//
// The AMDGPU recognizer (recognize_megakernel_swiglu_dense_gqa in
// src/format_amdgpu_megakernel.mlr) walks this structure and emits
// a stub kernel with working cross-WG barriers.
//
// WG_PERSIST = 512 (matches HIP source #define WG_PERSIST 512).
//
// Build the v2 stub .co:
//   ./build/mlrc --emit-amdgpu-qwen3-megakernel-v2=/tmp/qwen3_layer_megakernel_v2.co \
//       examples/llm/qwen3_layer_megakernel.mlr
//
// Build the v1 byte-wrapper .co (unchanged, production default):
//   ./scripts/build_native_megakernel.sh   # one-shot bytes extraction
//   ./build/mlrc --emit-amdgpu-qwen3-megakernel=/tmp/qwen3_layer_megakernel_native.co dummy
//
// Use v1 at runtime (opt-in):
//   MLRIFT_NATIVE_MEGAKERNEL=1 ./build/qwen3_generate ...

// CPU stubs for block_idx_x / tid_local_x — the recognizer pattern-matches
// the @kernel body via AST walk; these are never called on AMDGPU.
fn block_idx_x() -> uint64 { return 0 }
fn tid_local_x()  -> uint64 { return 0 }

// rmsnorm_wg0_marker — CPU no-op; tells the AMDGPU recognizer that the
// phase-1 block should emit real inline rmsnorm ISA (WG-0 gated, N=1024).
// Pattern-matched by _body_has_rmsnorm_wg0_marker in format_amdgpu_megakernel.mlr.
fn rmsnorm_wg0_marker() { }

// qkv_matmul_marker — CPU no-op; tells the AMDGPU recognizer that the
// phase-3 block should emit real inline QKV matmul ISA (gemv_coop_bf16_f32,
// padded-row stride, WG<256, all 256 WGs participate).
// Pattern-matched by _body_has_qkv_matmul_marker in format_amdgpu_megakernel.mlr.
fn qkv_matmul_marker() { }

// mega_barrier is a 3-arg void intrinsic (registered in the parser's
// builtin table — see src/analysis.mlr is_builtin / builtin_arg_count).
// Lowered by the AMDGPU emitter to the validated cross-WG barrier ISA
// sequence (global_atomic_add_u32 + spin-loop, ~31 dwords per barrier).
// On CPU (non-AMDGPU targets) the call is a no-op — the kernel body is
// never compiled for CPU execution.
@kernel
fn qwen3_layer_megakernel(
    uint64 in_residual,        //  0
    uint64 out_residual,       //  1
    uint64 qkv_w,              //  2
    uint64 o_w,                //  3
    uint64 gate_up_w,          //  4
    uint64 down_w,             //  5
    uint64 in_norm_g,          //  6
    uint64 post_norm_g,        //  7
    uint64 q_norm_g,           //  8
    uint64 k_norm_g,           //  9
    uint64 rope_cos,           // 10
    uint64 rope_sin,           // 11
    uint64 kc_layer,           // 12
    uint64 vc_layer,           // 13
    uint64 pos,                // 14  (by_value u64)
    uint64 barrier_counter,    // 15
    uint64 gu_scratch,         // 16
    uint64 b_x_norm_g,         // 17
    uint64 b_qkv_g,            // 18
    uint64 b_attn_q_g,         // 19
    uint64 b_mid_g,            // 20
    uint64 b_mid_norm_g,       // 21
    uint64 b_attn_out_g,       // 22
    uint64 max_phase           // 23  (by_value u64)
) {
    // Slice 4.19.0: 9 stub phases + 8 cross-WG barriers + max_phase guards.
    // Body shape matches plan Step 1.8: each phase wrapped in if(wg_id ...)
    // so slice 4.19.1+ sub-recognizers can pattern-match each block.
    // WG_PERSIST=512 (matches HIP source).

    uint64 wg_id = block_idx_x()
    uint64 lane  = tid_local_x()

    if wg_id == 0 {
        rmsnorm_wg0_marker()       // phase 1: input rmsnorm (WG-0 gated, N=1024)
    }
    mega_barrier(barrier_counter, 0, 512)
    if max_phase < 1 { return }

    if wg_id < 256 {
        qkv_matmul_marker()        // phase 3: QKV matmul (gemv_coop_bf16_f32, padded-row, WG<256)
    }
    mega_barrier(barrier_counter, 1, 512)
    if max_phase < 2 { return }

    if wg_id < 32 {
        uint64 _stub = 0           // phase 5 stub (qkv_split + qknorm + rope, wg<32)
    }
    mega_barrier(barrier_counter, 2, 512)
    if max_phase < 3 { return }

    if wg_id < 64 {
        uint64 _stub = 0           // phase 7 stub (attn_decode, wg<64)
    }
    mega_barrier(barrier_counter, 3, 512)
    if max_phase < 4 { return }

    if wg_id < 256 {
        uint64 _stub = 0           // phase 9 stub (o_proj + residual, wg<256)
    }
    mega_barrier(barrier_counter, 4, 512)
    if max_phase < 5 { return }

    if wg_id == 0 {
        uint64 _stub = 0           // phase 11 stub (post_norm, wg==0 only)
    }
    mega_barrier(barrier_counter, 5, 512)
    if max_phase < 6 { return }

    if wg_id < 256 {
        uint64 _stub = 0           // phase 13 stub (gate_up matmul, wg<256)
    }
    mega_barrier(barrier_counter, 6, 512)
    if max_phase < 7 { return }

    if wg_id < 256 {
        uint64 _stub = 0           // phase 15 stub (silu_mul, wg<256)
    }
    mega_barrier(barrier_counter, 7, 512)

    if wg_id < 256 {
        uint64 _stub = 0           // phase 17 stub (down + final residual)
    }
}

fn main() {
    exit(0)
}
