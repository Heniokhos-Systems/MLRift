// Slice 4.18 — qwen3-0.6B layer mega-kernel as a MLRift @kernel.
//
// HIP source: examples/llm/qwen3_layer_megakernel.hip.cpp
//
// This file is the MLRift-side declaration of the same 24-arg kernel.
// The @kernel body is a structural stub (just enough to parse) — the
// AST-walker dispatcher in src/format_amdgpu.mlr routes by name to
// emit_amdgpu_qwen3_megakernel_blob, which stamps the gfx1100 .text
// bytes (bit-identical to hipcc -O3) into a fresh ELF wrapped by
// MLRift's own .co packager.  This removes the runtime hipcc
// dependency from the .co build pipeline; the .text bytes themselves
// are still hipcc-compiled, but the ELF + KD + metadata are MLRift.
//
// Build the .co (MLRift-only, no hipcc invocation):
//   ./scripts/build_native_megakernel.sh   # one-shot bytes extraction
//   ./build/mlrc --emit-amdgpu-qwen3-megakernel=/tmp/qwen3_layer_megakernel_native.co dummy
//
// Use it at runtime (opt-in):
//   MLRIFT_NATIVE_MEGAKERNEL=1 ./build/qwen3_generate ...
//
// Speck variants (4/8/16) are follow-up slices.

// CPU-side stubs so the parser accepts the body intrinsics; the
// AMDGPU emitter ignores the body and stamps pre-extracted ISA.
fn _qmk_marker() -> uint64 { return 0 }

@kernel
fn qwen3_layer_megakernel(
    uint64 in_residual,        //  0
    uint64 out_residual,       //  1
    uint64 qkv_w,              //  2
    uint64 o_w,                //  3
    uint64 gate_up_w,          //  4
    uint64 down_w,             //  5
    uint64 in_norm_g,          //  6
    uint64 post_norm_g,        //  7
    uint64 q_norm_g,           //  8
    uint64 k_norm_g,           //  9
    uint64 rope_cos,           // 10
    uint64 rope_sin,           // 11
    uint64 kc_layer,           // 12
    uint64 vc_layer,           // 13
    uint64 pos,                // 14  (by_value u64)
    uint64 barrier_counter,    // 15
    uint64 gu_scratch,         // 16
    uint64 b_x_norm_g,         // 17
    uint64 b_qkv_g,            // 18
    uint64 b_attn_q_g,         // 19
    uint64 b_mid_g,            // 20
    uint64 b_mid_norm_g,       // 21
    uint64 b_attn_out_g,       // 22
    uint64 max_phase           // 23  (by_value u64)
) {
    // Body marker.  The AST-walker dispatcher recognises this kernel
    // by name and emits the pre-extracted .text bytes; the body is
    // not lowered.
    uint64 _x = _qmk_marker()
}

fn main() {
    exit(0)
}
