// Compares MLRift's GGUF-embedded BPE encoder (task #297 Phase 2)
// against the canonical token-ID sequences produced by the HuggingFace
// `tokenizers` Python library for both Llama-3 and Qwen3 model
// families. The expected IDs are baked in below; they were generated
// with /home/pantelis/Desktop/Projects/Work/MLRift/venv against the
// upstream Llama-3.2-1B-Instruct and Qwen3-0.6B tokenizer.json files.
//
// Usage:
//   tokenizer_gguf_bpe_canonical llama3 <model.gguf>
//   tokenizer_gguf_bpe_canonical qwen3  <model.gguf>
//
// Exit status: 0 if every prompt matches token-for-token; 1 on first
// divergence.

import "../std/tokenizer.mlr"
import "../std/gguf.mlr"
import "../std/io.mlr"
import "../std/fmt.mlr"
import "../std/string.mlr"

static uint64 cli_argc = 0
static uint64 cli_argv = 0

fn put(u64 s) { print_str(s) }
fn putu(u64 v) { u64 s = fmt_dec(v); put(s); dealloc(s) }

fn argv_at(u64 i) -> u64 {
    u64 slot = cli_argv + i * 8
    u64 v = 0
    unsafe { *(slot as u64) -> v }
    return v
}

// Encode `prompt` via tk and check the result matches `expected` (a
// flat u32 array of length `expected_n`). Returns 1 on match, 0 on
// divergence (and prints the mismatch).
fn check_one(Tokenizer tk, u64 prompt, u64 expected_arr, u64 expected_n) -> u64 {
    u64 plen = str_len(prompt)
    u64 ids_box = alloc(8); unsafe { *(ids_box as u64) = 0 }
    u64 cnt_box = alloc(8); unsafe { *(cnt_box as u64) = 0 }
    tokenizer_encode(tk, prompt, plen, ids_box, cnt_box)
    u64 ids = 0; unsafe { *(ids_box as u64) -> ids }
    u64 cnt = 0; unsafe { *(cnt_box as u64) -> cnt }
    dealloc(ids_box); dealloc(cnt_box)

    u64 ok = 1
    if cnt != expected_n { ok = 0 }
    else {
        u64 i = 0
        while i < cnt {
            u32 got32 = 0; unsafe { *((ids          + i * 4) as uint32) -> got32 }
            u32 exp32 = 0; unsafe { *((expected_arr + i * 4) as uint32) -> exp32 }
            if got32 != exp32 { ok = 0; i = cnt; continue }
            i = i + 1
        }
    }

    put("  \""); put(prompt); put("\": ")
    if ok != 0 {
        put("PASS ("); putu(cnt); put(" tokens)\n")
    } else {
        put("FAIL\n")
        put("    got      ["); u64 j = 0
        while j < cnt {
            if j != 0 { put(", ") }
            u32 g = 0; unsafe { *((ids + j * 4) as uint32) -> g }
            putu(g)
            j = j + 1
        }
        put("]\n")
        put("    expected ["); j = 0
        while j < expected_n {
            if j != 0 { put(", ") }
            u32 e = 0; unsafe { *((expected_arr + j * 4) as uint32) -> e }
            putu(e)
            j = j + 1
        }
        put("]\n")
    }
    if ids != 0 { dealloc(ids) }
    return ok
}

fn put_u32(u64 buf, u64 idx, u64 v) {
    u32 v32 = v
    unsafe { *((buf + idx * 4) as uint32) = v32 }
}

// Run all 5 chat-REPL representative prompts against the canonical
// Llama-3 token IDs.
fn run_llama3(Tokenizer tk) -> u64 {
    u64 ok_all = 1

    // Prompt 1: "Hello" → [9906]
    u64 e1 = alloc(4)
    put_u32(e1, 0, 9906)
    if check_one(tk, "Hello", e1, 1) == 0 { ok_all = 0 }
    dealloc(e1)

    // Prompt 2: "What is 2+2?" → [3923, 374, 220, 17, 10, 17, 30]
    u64 e2 = alloc(7 * 4)
    put_u32(e2, 0, 3923); put_u32(e2, 1, 374); put_u32(e2, 2, 220)
    put_u32(e2, 3, 17);   put_u32(e2, 4, 10);  put_u32(e2, 5, 17); put_u32(e2, 6, 30)
    if check_one(tk, "What is 2+2?", e2, 7) == 0 { ok_all = 0 }
    dealloc(e2)

    // Prompt 3: " Hello world" → [22691, 1917]
    u64 e3 = alloc(2 * 4)
    put_u32(e3, 0, 22691); put_u32(e3, 1, 1917)
    if check_one(tk, " Hello world", e3, 2) == 0 { ok_all = 0 }
    dealloc(e3)

    // Prompt 4: "Tell me a joke" → [41551, 757, 264, 22380]
    u64 e4 = alloc(4 * 4)
    put_u32(e4, 0, 41551); put_u32(e4, 1, 757); put_u32(e4, 2, 264); put_u32(e4, 3, 22380)
    if check_one(tk, "Tell me a joke", e4, 4) == 0 { ok_all = 0 }
    dealloc(e4)

    // Prompt 5: "preprocessing" → [1762, 21315]
    //   This is the canonical regression test for the BPE encoder —
    //   greedy longest-prefix-match would return [72874, 49787] instead.
    u64 e5 = alloc(2 * 4)
    put_u32(e5, 0, 1762); put_u32(e5, 1, 21315)
    if check_one(tk, "preprocessing", e5, 2) == 0 { ok_all = 0 }
    dealloc(e5)

    return ok_all
}

// Same 5 prompts against the canonical Qwen3 token IDs.
fn run_qwen3(Tokenizer tk) -> u64 {
    u64 ok_all = 1

    // "Hello" → [9707]
    u64 e1 = alloc(4)
    put_u32(e1, 0, 9707)
    if check_one(tk, "Hello", e1, 1) == 0 { ok_all = 0 }
    dealloc(e1)

    // "What is 2+2?" → [3838, 374, 220, 17, 10, 17, 30]
    u64 e2 = alloc(7 * 4)
    put_u32(e2, 0, 3838); put_u32(e2, 1, 374); put_u32(e2, 2, 220)
    put_u32(e2, 3, 17);   put_u32(e2, 4, 10);  put_u32(e2, 5, 17); put_u32(e2, 6, 30)
    if check_one(tk, "What is 2+2?", e2, 7) == 0 { ok_all = 0 }
    dealloc(e2)

    // " Hello world" → [21927, 1879]
    u64 e3 = alloc(2 * 4)
    put_u32(e3, 0, 21927); put_u32(e3, 1, 1879)
    if check_one(tk, " Hello world", e3, 2) == 0 { ok_all = 0 }
    dealloc(e3)

    // "Tell me a joke" → [40451, 752, 264, 21646]
    u64 e4 = alloc(4 * 4)
    put_u32(e4, 0, 40451); put_u32(e4, 1, 752); put_u32(e4, 2, 264); put_u32(e4, 3, 21646)
    if check_one(tk, "Tell me a joke", e4, 4) == 0 { ok_all = 0 }
    dealloc(e4)

    // "preprocessing" → [1726, 20660]   (greedy gives [72874, 49787]-equiv)
    u64 e5 = alloc(2 * 4)
    put_u32(e5, 0, 1726); put_u32(e5, 1, 20660)
    if check_one(tk, "preprocessing", e5, 2) == 0 { ok_all = 0 }
    dealloc(e5)

    return ok_all
}

fn main() {
    if cli_argc < 3 {
        put("usage: tokenizer_gguf_bpe_canonical {llama3|qwen3} <model.gguf>\n")
        exit(1)
    }
    u64 family = argv_at(1)
    u64 path   = argv_at(2)

    GGUFFile gf = gguf_open(path)
    if gf.file_size == 0 {
        put("[bpe_canonical] gguf_open failed at "); put(path); put("\n")
        exit(1)
    }
    Tokenizer tk = tokenizer_load_from_gguf(gf)
    if tk.vocab_count == 0 {
        put("[bpe_canonical] tokenizer_load_from_gguf failed\n")
        exit(1)
    }

    put("[bpe_canonical] family="); put(family)
    put(" vocab="); putu(tk.vocab_count); put("\n")

    u64 ok = 0
    if str_compare(family, "llama3") == 0 {
        ok = run_llama3(tk)
    } else if str_compare(family, "qwen3") == 0 {
        ok = run_qwen3(tk)
    } else {
        put("[bpe_canonical] unknown family: "); put(family); put("\n")
        exit(1)
    }

    tokenizer_free(tk)
    gguf_free(gf)
    if ok != 0 {
        put("[bpe_canonical] ALL PASS\n")
        exit(0)
    } else {
        put("[bpe_canonical] FAIL\n")
        exit(1)
    }
}
