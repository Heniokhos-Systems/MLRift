// Phase 3 slice γ.2 B.4 — verify all 11 firmware blobs decompress
// byte-identical to zstdcat output.

import "../std/zstd.mlr"
import "../std/sys.mlr"

@dynamic extern fn exit(uint64 code)
@dynamic extern fn puts(uint64 s) -> uint32

fn _print_dec(uint64 lab, uint64 lab_len, uint64 val) {
    uint64 buf = alloc(64)
    uint64 i = 0
    while i < lab_len {
        uint8 c = 0; unsafe { *((lab + i) as uint8) -> c }
        unsafe { *((buf + i) as uint8) = c }
        i = i + 1
    }
    uint8 eq = 61; unsafe { *((buf + lab_len) as uint8) = eq }
    uint64 digits = 0
    if val == 0 {
        uint8 z = 48; unsafe { *((buf + lab_len + 1) as uint8) = z }; digits = 1
    } else {
        uint64 t = val
        while t > 0 { digits = digits + 1; t = t / 10 }
        uint64 k = digits
        t = val
        while k > 0 {
            k = k - 1
            uint64 d = t - (t / 10) * 10
            uint8 db = d + 48
            unsafe { *((buf + lab_len + 1 + k) as uint8) = db }
            t = t / 10
        }
    }
    uint8 nul = 0; unsafe { *((buf + lab_len + 1 + digits) as uint8) = nul }
    puts(buf)
    dealloc(buf)
}

fn _load_file(uint64 path, uint64 out_buf_ptr, uint64 out_size_ptr) -> uint64 {
    uint64 fd = sys_open(path, 0, 0)
    if fd > 0xFFFFFFFFFFFFF000 { return 1 }
    uint64 size = syscall_raw(8, fd, 0, 2, 0, 0, 0)
    if size > 0xFFFFFFFFFFFFF000 { sys_close(fd); return 2 }
    syscall_raw(8, fd, 0, 0, 0, 0, 0)
    uint64 buf = alloc(size)
    uint64 nread = syscall_raw(0, fd, buf, size, 0, 0, 0)
    sys_close(fd)
    if nread != size { dealloc(buf); return 3 }
    unsafe { *(out_buf_ptr  as uint64) = buf }
    unsafe { *(out_size_ptr as uint64) = size }
    return 0
}

// Returns 1 on PASS, 0 on FAIL. Prints results.
fn _verify_one(uint64 zst_path, uint64 ref_path, uint64 name) -> uint64 {
    puts("")
    puts(name)
    uint64 cb_p = alloc(8); unsafe { *(cb_p as uint64) = 0 }
    uint64 cs_p = alloc(8); unsafe { *(cs_p as uint64) = 0 }
    if _load_file(zst_path, cb_p, cs_p) != 0 {
        puts("  FAIL: load compressed")
        dealloc(cb_p); dealloc(cs_p)
        return 0
    }
    uint64 cbuf = 0; unsafe { *(cb_p as uint64) -> cbuf }
    uint64 csz  = 0; unsafe { *(cs_p as uint64) -> csz }
    dealloc(cb_p); dealloc(cs_p)

    uint64 ref_p = alloc(8); unsafe { *(ref_p as uint64) = 0 }
    uint64 rs_p  = alloc(8); unsafe { *(rs_p as uint64) = 0 }
    if _load_file(ref_path, ref_p, rs_p) != 0 {
        puts("  FAIL: load reference")
        dealloc(cbuf); dealloc(ref_p); dealloc(rs_p)
        return 0
    }
    uint64 rbuf = 0; unsafe { *(ref_p as uint64) -> rbuf }
    uint64 rsz  = 0; unsafe { *(rs_p as uint64) -> rsz }
    dealloc(ref_p); dealloc(rs_p)

    uint64 outcap = rsz + 4096
    uint64 outbuf = alloc(outcap)
    uint64 wp = alloc(8); unsafe { *(wp as uint64) = 0 }
    uint64 e = zstd_decompress(cbuf, csz, outbuf, outcap, wp)
    uint64 wrote = 0; unsafe { *(wp as uint64) -> wrote }
    dealloc(wp)
    if e != 0 {
        _print_dec("  decompress_err", 15, e)
        _print_dec("  last_err",        9, zstd_last_error())
        dealloc(cbuf); dealloc(rbuf); dealloc(outbuf)
        return 0
    }
    if wrote != rsz {
        _print_dec("  size_mismatch_got", 19, wrote)
        _print_dec("  size_mismatch_want", 20, rsz)
        dealloc(cbuf); dealloc(rbuf); dealloc(outbuf)
        return 0
    }
    uint64 i = 0
    uint64 mismatches = 0
    uint64 first_mismatch = 0xFFFFFFFFFFFFFFFF
    while i < rsz {
        uint8 a = 0; unsafe { *((outbuf + i) as uint8) -> a }
        uint8 b = 0; unsafe { *((rbuf   + i) as uint8) -> b }
        if a != b {
            if first_mismatch == 0xFFFFFFFFFFFFFFFF { first_mismatch = i }
            mismatches = mismatches + 1
        }
        i = i + 1
    }
    dealloc(cbuf); dealloc(rbuf); dealloc(outbuf)
    if mismatches == 0 {
        _print_dec("  bytes_ok", 10, rsz)
        return 1
    }
    _print_dec("  mismatches",     12, mismatches)
    _print_dec("  first_mismatch", 16, first_mismatch)
    return 0
}

fn main() {
    puts("=== zstd full-firmware verify (11 blobs) ===")
    uint64 passes = 0
    uint64 fails = 0
    if _verify_one("/lib/firmware/amdgpu/psp_13_0_10_sos.bin.zst",
                   "/tmp/mlrift_fw/psp_13_0_10_sos.bin",
                   "psp_13_0_10_sos") != 0 { passes = passes + 1 } else { fails = fails + 1 }
    if _verify_one("/lib/firmware/amdgpu/psp_13_0_10_ta.bin.zst",
                   "/tmp/mlrift_fw/psp_13_0_10_ta.bin",
                   "psp_13_0_10_ta") != 0 { passes = passes + 1 } else { fails = fails + 1 }
    if _verify_one("/lib/firmware/amdgpu/smu_13_0_10.bin.zst",
                   "/tmp/mlrift_fw/smu_13_0_10.bin",
                   "smu_13_0_10") != 0 { passes = passes + 1 } else { fails = fails + 1 }
    if _verify_one("/lib/firmware/amdgpu/sdma_6_0_3.bin.zst",
                   "/tmp/mlrift_fw/sdma_6_0_3.bin",
                   "sdma_6_0_3") != 0 { passes = passes + 1 } else { fails = fails + 1 }
    if _verify_one("/lib/firmware/amdgpu/gc_11_0_3_pfp.bin.zst",
                   "/tmp/mlrift_fw/gc_11_0_3_pfp.bin",
                   "gc_11_0_3_pfp") != 0 { passes = passes + 1 } else { fails = fails + 1 }
    if _verify_one("/lib/firmware/amdgpu/gc_11_0_3_me.bin.zst",
                   "/tmp/mlrift_fw/gc_11_0_3_me.bin",
                   "gc_11_0_3_me") != 0 { passes = passes + 1 } else { fails = fails + 1 }
    if _verify_one("/lib/firmware/amdgpu/gc_11_0_3_mec.bin.zst",
                   "/tmp/mlrift_fw/gc_11_0_3_mec.bin",
                   "gc_11_0_3_mec") != 0 { passes = passes + 1 } else { fails = fails + 1 }
    if _verify_one("/lib/firmware/amdgpu/gc_11_0_3_imu.bin.zst",
                   "/tmp/mlrift_fw/gc_11_0_3_imu.bin",
                   "gc_11_0_3_imu") != 0 { passes = passes + 1 } else { fails = fails + 1 }
    if _verify_one("/lib/firmware/amdgpu/gc_11_0_3_rlc.bin.zst",
                   "/tmp/mlrift_fw/gc_11_0_3_rlc.bin",
                   "gc_11_0_3_rlc") != 0 { passes = passes + 1 } else { fails = fails + 1 }
    if _verify_one("/lib/firmware/amdgpu/gc_11_0_3_mes1.bin.zst",
                   "/tmp/mlrift_fw/gc_11_0_3_mes1.bin",
                   "gc_11_0_3_mes1") != 0 { passes = passes + 1 } else { fails = fails + 1 }
    if _verify_one("/lib/firmware/amdgpu/gc_11_0_3_mes_2.bin.zst",
                   "/tmp/mlrift_fw/gc_11_0_3_mes_2.bin",
                   "gc_11_0_3_mes_2") != 0 { passes = passes + 1 } else { fails = fails + 1 }

    puts("")
    _print_dec("PASSES", 6, passes)
    _print_dec("FAILS",  5, fails)
    if fails == 0 {
        puts("phase3_zstd_verify_all: ALL 11 FIRMWARE BLOBS BYTE-EXACT GREEN")
    } else {
        puts("phase3_zstd_verify_all: FAILURES PRESENT")
    }
    exit(0)
}
