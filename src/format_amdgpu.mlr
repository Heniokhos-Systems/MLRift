                if tok_matches(callee, "gemv_coop_batched_marker", 24) != 0 { saw_marker = 1 }
                if tok_matches(callee, "lds_reduce_sum_f32",       18) != 0 { saw_lds = 1 }
                if tok_matches(callee, "block_idx_y",              11) != 0 { saw_block_y = 1 }
            }
