    uint64 v2_tcount = lexer_run()
    if v2_tcount == 0 {
        write(2, "emit_amdgpu_llama_megakernel_blob_v2: lexer produced 0 tokens -- syntax error in .mlr\n", 86)
        return 1
    }

    // Parse into a fresh AST arena
    ast_init(65536)
    codegen_init(1048576, v2_src, v2_tokens)
    parser_init(v2_tokens, v2_tcount)
    uint64 v2_root = parse_module()
    if v2_root == 0 {
        write(2, "emit_amdgpu_llama_megakernel_blob_v2: parse_module returned null -- syntax error in .mlr\n", 89)
        return 1
    }

    // ── Step 2: find the @kernel fn llama_layer_megakernel node ────────
    uint64 fn_node = 0
    uint32 wc = ast_child(v2_root)
    while wc != 0 {
        uint32 k = ast_kind(wc)
        if k == 2 {
            if ast_fn_is_kernel(wc) != 0 {
                uint32 name_tok = ast_data1(wc)
                if tok_matches(name_tok, "llama_layer_megakernel", 22) != 0 {
