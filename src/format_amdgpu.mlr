// Batched qkv_split: grid (8, batch_size, 1).  Same body as the single-
// stream variant but with an 8-instruction prologue that shifts the
// three pointers in s[4..9] by per-batch strides:
//   src_qkv += wg_y * 16384   (qkv_dim*4)
//   dst_k   += wg_y * 262144  (kv_layer_stride = max_seq*nkv*hd*4)
//   dst_v   += wg_y * 262144
// Both strides are powers of 2 so each batch shift is one s_lshl_b32.
fn _emit_qkv_split_f32_batched_body_qd(uint64 args_desc, uint64 q_dim_bytes) {
    asm_init()
    asm_u32_arch(0xF40C0100, 0xF40C0100); asm_u32_arch(0xF8000000, 0xFA000000)
    asm_u32_arch(0xBF89FC07, 0xBF8CC07F)

    asm_u32_arch(0x84168E10, 0x8F168E10) // s_lshl_b32 s22, s16, 14
    asm_u32     (0x80041604)
    asm_u32     (0x82058005)
    asm_u32_arch(0x84179210, 0x8F179210) // s_lshl_b32 s23, s16, 18
    asm_u32     (0x80061706)
    asm_u32     (0x82078007)
    asm_u32     (0x80081708)
    asm_u32     (0x82098009)

    asm_u32_arch(0x840E890F, 0x8F0E890F)
    asm_u32_arch(0xBE8C00FF, 0xBE8C03FF); asm_u32(q_dim_bytes & 0xFFFFFFFF)
    asm_u32     (0x800C0E0C)
    asm_u32     (0x80100C04)
    asm_u32     (0x82118005)
    asm_u32_arch(0xBE8D00FF, 0xBE8D03FF); asm_u32(0x00001000)
    asm_u32     (0x800C0D0C)
    asm_u32     (0x80120C04)
    asm_u32     (0x82138005)
    asm_u32     (0x80140E06)
    asm_u32     (0x82158007)
    asm_u32     (0x801A0E08)
    asm_u32     (0x821B8009)
    asm_u32_arch(0x30020082, 0x34020082)
    asm_s_delay_alu(0x01)
    asm_u32_arch(0xDC520000, 0xDC308000); asm_u32(0x02100001)
    asm_u32_arch(0xDC520000, 0xDC308000); asm_u32(0x03120001)
    asm_u32_arch(0xBF8903F7, 0xBF8C3F70)
    asm_u32_arch(0xDC6A0000, 0xDC708000); asm_u32(0x00140201)
    asm_u32_arch(0xDC6A0000, 0xDC708000); asm_u32(0x001A0301)
    asm_u32_arch(0xBC7C0000, 0xBBFD0000)
    asm_u32_arch(0xBFB00000, 0xBF810000)

    uint64 a0 = args_desc + 0;   unsafe { *(a0 as uint64) = 8 }
    uint64 a1 = args_desc + 8;   unsafe { *(a1 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a2 = args_desc + 16;  unsafe { *(a2 as uint64) = 8 }
    uint64 a3 = args_desc + 24;  unsafe { *(a3 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a4 = args_desc + 32;  unsafe { *(a4 as uint64) = 8 }
    uint64 a5 = args_desc + 40;  unsafe { *(a5 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
}

// Backward-compat wrapper: 0.6B's q_dim=2048.
fn _emit_qkv_split_f32_batched_body(uint64 args_desc) {
    _emit_qkv_split_f32_batched_body_qd(args_desc, 0x2000)
}

