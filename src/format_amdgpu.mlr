// Phase 3c-10 — attn_decode_f32 (single-stream decode-shape attention).
//
// Discriminator: 5 params + presence of `lds_reduce_max_f32` Call.
// Distinguishes from gemv_coop_* (sum reduce only) and softmax_f32
// (4 params).  Routing places 3c-10 BEFORE the gemv_coop family.
// Delegates ISA emission to `_emit_attn_decode_f32_body` (which calls
// `_emit_attn_decode_f32_body_kvr(args_desc, 2)` — kv_ratio=2 for
// Qwen3-0.6B).
fn amdgpu_lower_attn_decode_f32_3c(uint64 fn_node, uint64 source,
                                    uint64 kname_ptr, uint64 nl) -> uint64 {
    uint64 n_params = 0
    uint64 wp = ast_child(fn_node)
    while wp != 0 {
        n_params = n_params + 1
        wp = ast_next(wp)
    }
    if n_params != 5 { return 1 }

    uint32 body = ast_data3(fn_node)
    if body == 0 { return 1 }
    if ast_kind(body) != 15 { return 1 }

    // Recursive search for lds_reduce_max_f32.
    uint64 saw_max = 0
    uint32 walk = ast_child(body)
    while walk != 0 {
        if ast_kind(walk) == 35 {
            uint32 callee = ast_data1(walk)
            if tok_matches(callee, "lds_reduce_max_f32", 18) != 0 { saw_max = 1 }
        }
        if ast_kind(walk) == 10 {
            uint32 init = ast_child(walk)
            if init != 0 && ast_kind(init) == 35 {
                uint32 callee = ast_data1(init)
                if tok_matches(callee, "lds_reduce_max_f32", 18) != 0 { saw_max = 1 }
            }
        }
        if ast_kind(walk) == 13 {
            uint32 tblk = ast_data1(walk)
            if tblk != 0 && ast_kind(tblk) == 15 {
                uint32 tw = ast_child(tblk)
                while tw != 0 {
                    if ast_kind(tw) == 10 {
                        uint32 i2 = ast_child(tw)
                        if i2 != 0 && ast_kind(i2) == 35 {
                            uint32 c2 = ast_data1(i2)
                            if tok_matches(c2, "lds_reduce_max_f32", 18) != 0 { saw_max = 1 }
                        }
                    }
                    if ast_kind(tw) == 35 {
                        uint32 c2 = ast_data1(tw)
                        if tok_matches(c2, "lds_reduce_max_f32", 18) != 0 { saw_max = 1 }
                    }
                    tw = ast_next(tw)
                }
            }
        }
        walk = ast_next(walk)
    }
    if saw_max == 0 { return 1 }

    // ── emit ISA ─────────────────────────────────────────────────
    uint64 args_desc = alloc(10 * 16)
    _emit_attn_decode_f32_body(args_desc)

    uint64 k_text_size = asm_text_len
    uint64 k_text_buf  = alloc(k_text_size)
    uint64 ci = 0
    while ci < k_text_size {
        uint64 sp = asm_text_buf + ci
        uint64 b = 0
        unsafe { *(sp as uint8) -> b }
        uint64 dp = k_text_buf + ci
        uint8 b8 = b
        unsafe { *(dp as uint8) = b8 }
        ci = ci + 1
    }

    // KD identical to attn_decode_f32 blob: 18 SGPRs / 32 VGPRs,
    // USER_SGPR_COUNT=15, LDS=1024, rsrc1=0xE0AF0003, rsrc2=0x9E.
    uint64 rsrc1 = 0xE0AF0003
    uint64 rsrc2 = 0x0000009E
    uint64 rsrc3 = 0x00000010
    uint64 props = 0x0408

    kt_push_lds(kname_ptr, nl, k_text_buf, k_text_size,
                args_desc, 5, 40,
                18, 32,
                rsrc1, rsrc2, rsrc3, props,
                1024)
    return 0
}

// Phase 3c-13 — attn_decode_f32_batched (2D-grid batched attention).
//
// Discriminator: 5 params + lds_reduce_max_f32 Call + block_idx_y Call.
// Distinguishes from 3c-10 (single-stream, no batch dim) — runs BEFORE
// it.  Delegates ISA emission to `_emit_attn_decode_f32_batched_body`
