// Phase 2 Slice 2.2a: speculative-layout qkv_split.  Identical to the
// Phase 1 batched variant EXCEPT the K/V destination stride: speculative
// decoding writes K consecutive POSITIONS within a single sequence's
// slab (per-position stride 4096), not K independent batch slabs (per-
// batch stride 262144).
//
// Single-instruction delta vs _emit_qkv_split_f32_batched_body:
//   0x84179210  (s_lshl_b32 s23, s16, 18  → wg_y * 262144)
//     →
//   0x84178C10  (s_lshl_b32 s23, s16, 12  → wg_y *   4096)
//
// Caller passes K/V dst pointers already shifted to the position-pos
// row inside batch=0's slab:
//   d_k_pos_base = layer_K_base + 0*262144 + pos*4096
//   d_v_pos_base = layer_V_base + 0*262144 + pos*4096
// kernel adds wg_y * 4096 → writes K K/V vectors at positions pos,
// pos+1, ..., pos+K-1.
fn _emit_qkv_split_f32_speck4_body(uint64 args_desc) {
    asm_init()
    asm_u32_arch(0xF40C0100, 0xF40C0100); asm_u32_arch(0xF8000000, 0xFA000000)
    asm_u32_arch(0xBF89FC07, 0xBF8CC07F)

    asm_u32_arch(0x84168E10, 0x8F168E10) // s_lshl_b32 s22, s16, 14
    asm_u32     (0x80041604)
    asm_u32     (0x82058005)
    asm_u32_arch(0x84178C10, 0x8F178C10) // s_lshl_b32 s23, s16, 12 (per-pos K/V)
    asm_u32     (0x80061706)
    asm_u32     (0x82078007)
    asm_u32     (0x80081708)
    asm_u32     (0x82098009)

    asm_u32_arch(0x840E890F, 0x8F0E890F)
    asm_u32_arch(0xBE8C00FF, 0xBE8C03FF); asm_u32(0x00002000)
    asm_u32     (0x800C0E0C)
    asm_u32     (0x80100C04)
    asm_u32     (0x82118005)
    asm_u32_arch(0xBE8D00FF, 0xBE8D03FF); asm_u32(0x00001000)
    asm_u32     (0x800C0D0C)
    asm_u32     (0x80120C04)
    asm_u32     (0x82138005)
    asm_u32     (0x80140E06)
    asm_u32     (0x82158007)
    asm_u32     (0x801A0E08)
    asm_u32     (0x821B8009)
    asm_u32_arch(0x30020082, 0x34020082)
    asm_s_delay_alu(0x01)
    asm_u32_arch(0xDC520000, 0xDC308000); asm_u32(0x02100001)
    asm_u32_arch(0xDC520000, 0xDC308000); asm_u32(0x03120001)
    asm_u32_arch(0xBF8903F7, 0xBF8C3F70)
    asm_u32_arch(0xDC6A0000, 0xDC708000); asm_u32(0x00140201)
    asm_u32_arch(0xDC6A0000, 0xDC708000); asm_u32(0x001A0301)
    asm_u32_arch(0xBC7C0000, 0xBBFD0000)
    asm_u32_arch(0xBFB00000, 0xBF810000)

    uint64 a0 = args_desc + 0;   unsafe { *(a0 as uint64) = 8 }
    uint64 a1 = args_desc + 8;   unsafe { *(a1 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a2 = args_desc + 16;  unsafe { *(a2 as uint64) = 8 }
    uint64 a3 = args_desc + 24;  unsafe { *(a3 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a4 = args_desc + 32;  unsafe { *(a4 as uint64) = 8 }
    uint64 a5 = args_desc + 40;  unsafe { *(a5 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
}

@export
fn emit_amdgpu_qkv_split_f32_speck4_blob(uint64 out_path) -> uint64 {
    uint64[6] args_desc
    _emit_qkv_split_f32_speck4_body(args_desc)
    uint64 size = emit_amdgpu_code_object_lds("qkv_split_f32_speck4", 20,
                                               asm_text_buf, asm_text_len,
                                               24, 8, 16, 28,
                                               0xE0AF0001, 0x0000019E, 0x00000010, 0x0408,
                                               args_desc, 3,
                                               0)
    uint64 fd = file_open(out_path, 1)
    if fd > 0xFFFFFFFFFFFFF000 {
        write(2, "emit_amdgpu_qkv_split_f32_speck4_blob: cannot open output\n", 59)
        return 1
    }
    file_write(fd, amd_buf, size)
    file_close(fd)
    return 0
}

// Qwen3-0.6B Q-extract kernel (Phase 1 Slice 1.7): copies the Q part
// (q_dim = 2048 f32) out of the fused [batch, qkv_dim] _gpuq_d_qkv
// buffer into the contiguous [batch, q_dim] _gpuq_d_q_attn buffer, so
// the per-head qknorm can fire as a single batched M = batch * nh
// dispatch instead of M sequential calls.
//
// Grid (16, batch_size, 1).  Per WG: 128 Q elements at byte offset
//   src = qkv + wg_y * 16384 + wg_x * 512   (qkv_dim*4 = 16384, head*4*128 = 512)
//   dst = q   + wg_y *  8192 + wg_x * 512   (q_dim*4   =  8192)
// Block 128, one f32 per lane.  rsrc2 = 0x019E enables wg_id_x and y.
//
// Kernarg layout (16 bytes, 2 args):
//   [0x00] qkv_ptr → s[4:5]
//   [0x08] q_ptr   → s[6:7]
fn _emit_extract_q_qwen3_f32_body(uint64 args_desc) {
    asm_init()
    asm_u32_arch(0xF40C0100, 0xF40C0100); asm_u32_arch(0xF8000000, 0xFA000000)
    asm_u32_arch(0xBF89FC07, 0xBF8CC07F)

    asm_u32_arch(0x840E8E10, 0x8F0E8E10) // s_lshl_b32 s14, s16, 14
    asm_u32_arch(0x8411890F, 0x8F11890F) // s_lshl_b32 s17, s15, 9
    asm_u32     (0x800E110E)
    asm_u32     (0x80120E04)
    asm_u32     (0x82138005)

    asm_u32_arch(0x84168D10, 0x8F168D10) // s_lshl_b32 s22, s16, 13
    asm_u32     (0x80161116)
    asm_u32     (0x80141606)
    asm_u32     (0x82158007)

    asm_u32_arch(0x30020082, 0x34020082) // v_lshlrev_b32 v1, 2, v0
    asm_s_delay_alu(0x01)
    asm_u32_arch(0xDC520000, 0xDC308000); asm_u32(0x02120001)
    asm_u32_arch(0xBF8903F7, 0xBF8C3F70)
    asm_u32_arch(0xDC6A0000, 0xDC708000); asm_u32(0x00140201)
    asm_u32_arch(0xBC7C0000, 0xBBFD0000)
    asm_u32_arch(0xBFB00000, 0xBF810000)

    uint64 a0 = args_desc + 0;   unsafe { *(a0 as uint64) = 8 }
    uint64 a1 = args_desc + 8;   unsafe { *(a1 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a2 = args_desc + 16;  unsafe { *(a2 as uint64) = 8 }
    uint64 a3 = args_desc + 24;  unsafe { *(a3 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
}

@export
fn emit_amdgpu_extract_q_qwen3_f32_blob(uint64 out_path) -> uint64 {
    uint64[4] args_desc
    _emit_extract_q_qwen3_f32_body(args_desc)
    uint64 size = emit_amdgpu_code_object_lds("extract_q_qwen3_f32", 19,
                                               asm_text_buf, asm_text_len,
                                               16, 8, 16, 16,
                                               0xE0AF0001, 0x0000019E, 0x00000010, 0x0408,
                                               args_desc, 2,
                                               0)
    uint64 fd = file_open(out_path, 1)
    if fd > 0xFFFFFFFFFFFFF000 {
        write(2, "emit_amdgpu_extract_q_qwen3_f32_blob: cannot open output\n", 58)
        return 1
    }
    file_write(fd, amd_buf, size)
    file_close(fd)
    return 0
}

// extract_k_qwen3_f32: copies K from per-batch K-cache slots into a
// contiguous [batch, kv_dim] stage buffer.  Grid (8, batch); per WG
// copies 128 f32 elements.
//   src per-batch stride = max_seq * nkv * hd * 4 = 262144 = 1 << 18
//   dst per-batch stride = nkv * hd * 4 = 4096 = 1 << 12
fn _emit_extract_k_qwen3_f32_body(uint64 args_desc) {
    asm_init()
    asm_u32_arch(0xF40C0100, 0xF40C0100); asm_u32_arch(0xF8000000, 0xFA000000)
    asm_u32_arch(0xBF89FC07, 0xBF8CC07F)
    asm_u32_arch(0x840E9210, 0x8F0E9210) // s_lshl_b32 s14, s16, 18
    asm_u32_arch(0x8411890F, 0x8F11890F)
    asm_u32     (0x800E110E)
    asm_u32     (0x80120E04)
    asm_u32     (0x82138005)
    asm_u32_arch(0x84168C10, 0x8F168C10) // s_lshl_b32 s22, s16, 12
    asm_u32     (0x80161116)
    asm_u32     (0x80141606)
    asm_u32     (0x82158007)
    asm_u32_arch(0x30020082, 0x34020082)
    asm_s_delay_alu(0x01)
    asm_u32_arch(0xDC520000, 0xDC308000); asm_u32(0x02120001)
    asm_u32_arch(0xBF8903F7, 0xBF8C3F70)
    asm_u32_arch(0xDC6A0000, 0xDC708000); asm_u32(0x00140201)
    asm_u32_arch(0xBC7C0000, 0xBBFD0000)
    asm_u32_arch(0xBFB00000, 0xBF810000)
    uint64 a0 = args_desc + 0;   unsafe { *(a0 as uint64) = 8 }
    uint64 a1 = args_desc + 8;   unsafe { *(a1 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a2 = args_desc + 16;  unsafe { *(a2 as uint64) = 8 }
    uint64 a3 = args_desc + 24;  unsafe { *(a3 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
}

@export
fn emit_amdgpu_extract_k_qwen3_f32_blob(uint64 out_path) -> uint64 {
    uint64[4] args_desc
    _emit_extract_k_qwen3_f32_body(args_desc)
    uint64 size = emit_amdgpu_code_object_lds("extract_k_qwen3_f32", 19,
                                               asm_text_buf, asm_text_len,
                                               16, 8, 16, 16,
                                               0xE0AF0001, 0x0000019E, 0x00000010, 0x0408,
                                               args_desc, 2, 0)
    uint64 fd = file_open(out_path, 1)
    if fd > 0xFFFFFFFFFFFFF000 { write(2, "extract_k blob fail\n", 20); return 1 }
    file_write(fd, amd_buf, size); file_close(fd); return 0
}

// insert_k_qwen3_f32: inverse of extract_k.
fn _emit_insert_k_qwen3_f32_body(uint64 args_desc) {
    asm_init()
    asm_u32_arch(0xF40C0100, 0xF40C0100); asm_u32_arch(0xF8000000, 0xFA000000)
    asm_u32_arch(0xBF89FC07, 0xBF8CC07F)
    asm_u32_arch(0x840E8C10, 0x8F0E8C10)
    asm_u32_arch(0x8411890F, 0x8F11890F)
    asm_u32     (0x800E110E)
    asm_u32     (0x80120E04)
    asm_u32     (0x82138005)
    asm_u32_arch(0x84169210, 0x8F169210) // s_lshl_b32 s22, s16, 18
    asm_u32     (0x80161116)
    asm_u32     (0x80141606)
    asm_u32     (0x82158007)
    asm_u32_arch(0x30020082, 0x34020082)
    asm_s_delay_alu(0x01)
    asm_u32_arch(0xDC520000, 0xDC308000); asm_u32(0x02120001)
    asm_u32_arch(0xBF8903F7, 0xBF8C3F70)
    asm_u32_arch(0xDC6A0000, 0xDC708000); asm_u32(0x00140201)
    asm_u32_arch(0xBC7C0000, 0xBBFD0000)
    asm_u32_arch(0xBFB00000, 0xBF810000)
    uint64 a0 = args_desc + 0;   unsafe { *(a0 as uint64) = 8 }
    uint64 a1 = args_desc + 8;   unsafe { *(a1 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a2 = args_desc + 16;  unsafe { *(a2 as uint64) = 8 }
    uint64 a3 = args_desc + 24;  unsafe { *(a3 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
}

@export
fn emit_amdgpu_insert_k_qwen3_f32_blob(uint64 out_path) -> uint64 {
    uint64[4] args_desc
    _emit_insert_k_qwen3_f32_body(args_desc)
    uint64 size = emit_amdgpu_code_object_lds("insert_k_qwen3_f32", 18,
                                               asm_text_buf, asm_text_len,
                                               16, 8, 16, 16,
                                               0xE0AF0001, 0x0000019E, 0x00000010, 0x0408,
                                               args_desc, 2, 0)
    uint64 fd = file_open(out_path, 1)
    if fd > 0xFFFFFFFFFFFFF000 { write(2, "insert_k blob fail\n", 19); return 1 }
    file_write(fd, amd_buf, size); file_close(fd); return 0
}

// Phase 2 Slice 2.2b: speculative-layout extract_k.  Identical to the
// per-batch extract EXCEPT the SOURCE stride: speculative reads K
// consecutive POSITIONS within a single sequence's slab (per-position
// stride 4096), not K independent batch slabs (per-batch 262144).
//
// Single-instruction delta vs _emit_extract_k_qwen3_f32_body:
//   0x840E9210  (s_lshl_b32 s14, s16, 18  → wg_y * 262144 src)
//     →
//   0x840E8C10  (s_lshl_b32 s14, s16, 12  → wg_y *   4096 src)
//
// Caller passes src already shifted to the position-pos slot in
// batch=0's slab (kv_layer_base + 0*262144 + pos*4096); kernel reads
// positions pos, pos+1, ..., pos+K-1 into a contiguous [K, kv_dim]
// stage buffer (dst stride wg_y * 4096 unchanged).
fn _emit_extract_k_qwen3_f32_speck4_body(uint64 args_desc) {
    asm_init()
    asm_u32_arch(0xF40C0100, 0xF40C0100); asm_u32_arch(0xF8000000, 0xFA000000)
    asm_u32_arch(0xBF89FC07, 0xBF8CC07F)
    asm_u32_arch(0x840E8C10, 0x8F0E8C10)
    asm_u32_arch(0x8411890F, 0x8F11890F)
    asm_u32     (0x800E110E)
    asm_u32     (0x80120E04)
    asm_u32     (0x82138005)
    asm_u32_arch(0x84168C10, 0x8F168C10)
    asm_u32     (0x80161116)
    asm_u32     (0x80141606)
    asm_u32     (0x82158007)
    asm_u32_arch(0x30020082, 0x34020082)
    asm_s_delay_alu(0x01)
    asm_u32_arch(0xDC520000, 0xDC308000); asm_u32(0x02120001)
    asm_u32_arch(0xBF8903F7, 0xBF8C3F70)
    asm_u32_arch(0xDC6A0000, 0xDC708000); asm_u32(0x00140201)
    asm_u32_arch(0xBC7C0000, 0xBBFD0000)
    asm_u32_arch(0xBFB00000, 0xBF810000)
    uint64 a0 = args_desc + 0;   unsafe { *(a0 as uint64) = 8 }
    uint64 a1 = args_desc + 8;   unsafe { *(a1 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a2 = args_desc + 16;  unsafe { *(a2 as uint64) = 8 }
    uint64 a3 = args_desc + 24;  unsafe { *(a3 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
}

@export
fn emit_amdgpu_extract_k_qwen3_f32_speck4_blob(uint64 out_path) -> uint64 {
    uint64[4] args_desc
    _emit_extract_k_qwen3_f32_speck4_body(args_desc)
    uint64 size = emit_amdgpu_code_object_lds("extract_k_qwen3_f32_speck4", 26,
                                               asm_text_buf, asm_text_len,
                                               16, 8, 16, 16,
                                               0xE0AF0001, 0x0000019E, 0x00000010, 0x0408,
                                               args_desc, 2, 0)
    uint64 fd = file_open(out_path, 1)
    if fd > 0xFFFFFFFFFFFFF000 { write(2, "extract_k_speck4 blob fail\n", 27); return 1 }
    file_write(fd, amd_buf, size); file_close(fd); return 0
}

// Phase 2 Slice 2.2b: speculative-layout insert_k.  Inverse of
// extract_k_speck4.  Single-instruction delta vs _emit_insert_k:
//   0x84169210  (s_lshl_b32 s22, s16, 18  → wg_y * 262144 dst)
//     →
//   0x84168C10  (s_lshl_b32 s22, s16, 12  → wg_y *   4096 dst)
fn _emit_insert_k_qwen3_f32_speck4_body(uint64 args_desc) {
    asm_init()
    asm_u32_arch(0xF40C0100, 0xF40C0100); asm_u32_arch(0xF8000000, 0xFA000000)
    asm_u32_arch(0xBF89FC07, 0xBF8CC07F)
    asm_u32_arch(0x840E8C10, 0x8F0E8C10)
    asm_u32_arch(0x8411890F, 0x8F11890F)
    asm_u32     (0x800E110E)
    asm_u32     (0x80120E04)
    asm_u32     (0x82138005)
    asm_u32_arch(0x84168C10, 0x8F168C10)
    asm_u32     (0x80161116)
    asm_u32     (0x80141606)
    asm_u32     (0x82158007)
    asm_u32_arch(0x30020082, 0x34020082)
    asm_s_delay_alu(0x01)
    asm_u32_arch(0xDC520000, 0xDC308000); asm_u32(0x02120001)
    asm_u32_arch(0xBF8903F7, 0xBF8C3F70)
    asm_u32_arch(0xDC6A0000, 0xDC708000); asm_u32(0x00140201)
    asm_u32_arch(0xBC7C0000, 0xBBFD0000)
    asm_u32_arch(0xBFB00000, 0xBF810000)
    uint64 a0 = args_desc + 0;   unsafe { *(a0 as uint64) = 8 }
    uint64 a1 = args_desc + 8;   unsafe { *(a1 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a2 = args_desc + 16;  unsafe { *(a2 as uint64) = 8 }
    uint64 a3 = args_desc + 24;  unsafe { *(a3 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
}

@export
fn emit_amdgpu_insert_k_qwen3_f32_speck4_blob(uint64 out_path) -> uint64 {
    uint64[4] args_desc
    _emit_insert_k_qwen3_f32_speck4_body(args_desc)
    uint64 size = emit_amdgpu_code_object_lds("insert_k_qwen3_f32_speck4", 25,
                                               asm_text_buf, asm_text_len,
                                               16, 8, 16, 16,
                                               0xE0AF0001, 0x0000019E, 0x00000010, 0x0408,
                                               args_desc, 2, 0)
    uint64 fd = file_open(out_path, 1)
    if fd > 0xFFFFFFFFFFFFF000 { write(2, "insert_k_speck4 blob fail\n", 26); return 1 }
    file_write(fd, amd_buf, size); file_close(fd); return 0
}

// Phase 2 routing: lower a name-matched @kernel `gemv_f32` into the
// kernel table. Snapshots the ISA so a subsequent kernel's asm_init
// can't clobber it before emit_amdgpu_multi_code_object runs.

// LLM Phase A milestone 2 — tile GEMM f32, native-emit. One workgroup
// of 256 lanes computes one 16x16 output tile; one lane per output
// cell. Reference: /tmp/gemm_f32_native.s (llvm-mc verified).
// Kernarg layout (48 bytes): a, b, c, m, n, k_dim — all u64.
// Dispatch: block=256 (1-D), grid=ceil(M/16)*ceil(N/16).
@export



// LLM Phase A milestone 3 — gemm f32 LDS-tiled, native-emit.
// 2-D dispatch: grid=(tiles_n, tiles_m, 1), block=(16, 16, 1).
// SGPR setup: USER_SGPR_KERNARG_PTR=2, WORKGROUP_ID_X=1, WORKGROUP_ID_Y=1.
//   s[0:1]=kernarg, s2=blockIdx.x=tile_col, s3=blockIdx.y=tile_row.
//   v0=threadIdx.x=tx, v1=threadIdx.y=ty (rsrc2 enables both).
// LDS layout: 2 KiB (1 KiB A + 1 KiB B).
fn _emit_gemm_f32_lds_body(uint64 args_desc) {
    asm_init()
    // Kernarg load.
    asm_u32_arch(0xF40C0100, 0xF40C0100); asm_u32_arch(0xF8000000, 0xFA000000)
    asm_u32_arch(0xF4040300, 0xF4040300); asm_u32_arch(0xF8000020, 0xFA000020)
    asm_u32_arch(0xF4040380, 0xF4040380); asm_u32_arch(0xF8000028, 0xFA000028)
    asm_u32_arch(0xBF89FC07, 0xBF8CC07F)
    // v_bfe_u32 v1, v0, 10, 10 — VOP3 op 0x110 → 0x148.
    asm_u32_arch(0xD6100001, 0xD5480001); asm_u32(0x02291500)
    asm_u32     (0x360000FF); asm_u32(0x000003FF) // v_and_b32 v0, 0x3FF, v0 (VOP2 stable + literal)
    asm_u32_arch(0x84108403, 0x8F108403) // s_lshl_b32 s16, s3, 4
    asm_u32_arch(0x84118402, 0x8F118402) // s_lshl_b32 s17, s2, 4
    asm_u32     (0x4A060210)             // v_add_nc_u32 v3, s16, v1
    asm_u32     (0x4A080011)             // v_add_nc_u32 v4, s17, v0
    asm_u32_arch(0xBE82007E, 0xBE82037E) // s_mov_b32 s2, exec_lo
    asm_u32_arch(0x7C98060A, 0x7D88060A) // v_cmp_gt_u32 vcc_lo, s10, v3
    asm_u32_arch(0x8B7E6A7E, 0x877E6A7E) // s_and_b32
    asm_u32_arch(0x7C98080C, 0x7D88080C) // v_cmp_gt_u32 vcc_lo, s12, v4
    asm_u32_arch(0x8B7E6A7E, 0x877E6A7E)
    asm_u32_arch(0xBFA50054, 0xBF880054) // s_cbranch_execz +84 → .Lend
    asm_u32_arch(0x8512840E, 0x9012840E) // s_lshr_b32 s18, s14, 4
    asm_u32     (0x7E0C0280)             // v_mov_b32 v6, 0
    asm_u32_arch(0xBE930080, 0xBE930380) // s_mov_b32 s19, 0
    asm_u32_arch(0x300A0284, 0x340A0284) // v_lshlrev_b32 v5, 4, v1
    asm_u32     (0x4A0A0105)             // v_add_nc_u32 v5, v5, v0
    asm_u32_arch(0x300A0A82, 0x340A0A82) // v_lshlrev_b32 v5, 2, v5
    asm_u32_arch(0x30220286, 0x34220286) // v_lshlrev_b32 v17, 6, v1
    asm_u32_arch(0x30240082, 0x34240082) // v_lshlrev_b32 v18, 2, v0
    asm_u32     (0xD5250012); asm_u32(0x0001FF12); asm_u32(0x00000400) // v_add_nc_u32_e64 v18, v18, 0x400 (VOP3 stable + literal)
    // gfx11-only s_waitcnt_depctr — gfx10 has no such opcode; emit s_nop 0.
    asm_u32_arch(0xBF068012, 0xBF800000)
    asm_u32_arch(0xBFA2003D, 0xBF85003D) // s_cbranch_scc1 +61 → .Lstore
    // .Lkt_loop:
    asm_u32_arch(0x84148413, 0x8F148413) // s_lshl_b32 s20, s19, 4
    asm_u32     (0x4A0E0014)             // v_add_nc_u32 v7, s20, v0
    asm_u32_arch(0xD72C0008, 0xD5690008); asm_u32(0x00001D03) // v_mul_lo_u32 v8, v3, s14
    asm_u32     (0x4A100F08)             // v_add_nc_u32 v8, v8, v7
    asm_u32     (0x7E120280)             // v_mov_b32 v9, 0
    asm_u32_arch(0xD73C0008, 0xD6FF0008); asm_u32(0x00021082) // v_lshlrev_b64 v[8:9], 2, v[8:9]
    asm_u32_arch(0xD7006A08, 0xD70F6A08); asm_u32(0x00021004) // v_add_co_u32 v8, vcc_lo, s4, v8
    asm_u32_arch(0xD5207C09, 0xD5287D09); asm_u32(0x01AA1205) // v_add_co_ci_u32 v9
    asm_u32_arch(0xBF870001, 0xBF800000) // s_delay_alu (gfx11) → s_nop 0 (gfx10)
    asm_u32_arch(0xDC520000, 0xDC308000); asm_u32_arch(0x0A7C0008, 0x0A7D0008) // global_load_b32 v10, v[8:9]
    asm_u32     (0x4A160214)             // v_add_nc_u32 v11, s20, v1
    asm_u32_arch(0xD72C000C, 0xD569000C); asm_u32(0x0000190B) // v_mul_lo_u32 v12, v11, s12
    asm_u32     (0x4A18090C)             // v_add_nc_u32 v12, v12, v4
    asm_u32     (0x7E1A0280)             // v_mov_b32 v13, 0
    asm_u32_arch(0xD73C000C, 0xD6FF000C); asm_u32(0x00021882) // v_lshlrev_b64 v[12:13], 2, v[12:13]
    asm_u32_arch(0xD7006A0C, 0xD70F6A0C); asm_u32(0x00021806) // v_add_co_u32 v12, vcc_lo, s6, v12
    asm_u32_arch(0xD5207C0D, 0xD5287D0D); asm_u32(0x01AA1A07) // v_add_co_ci_u32 v13
    asm_u32_arch(0xBF870001, 0xBF800000) // s_delay_alu → s_nop 0
    asm_u32_arch(0xDC520000, 0xDC308000); asm_u32_arch(0x0E7C000C, 0x0E7D000C) // global_load_b32 v14, v[12:13]
    asm_u32_arch(0xBF8903F7, 0xBF8C3F70) // s_waitcnt vmcnt(0)
    asm_u32     (0xD8340000); asm_u32(0x00000A05) // ds_store v5, v10
    asm_u32     (0xD8340400); asm_u32(0x00000E05) // ds_store v5+, v14
    asm_u32_arch(0xBF89FC07, 0xBF8CC07F)
    asm_u32_arch(0xBFBD0000, 0xBF8A0000) // s_barrier
    asm_u32     (0xE0AC0000); asm_u32(0x00000000) // tbuffer/MUBUF instruction (preserved verbatim — same encoding both archs)
    asm_u32_arch(0xBE940080, 0xBE940380) // s_mov_b32 s20, 0
    asm_u32     (0x7E1E0311)             // v_mov_b32 v15, v17
    asm_u32     (0x7E200312)             // v_mov_b32 v16, v18
    // .Linner:
    asm_u32_arch(0xBF870002, 0xBF800000) // s_delay_alu → s_nop 0
    asm_u32     (0xD8D80000); asm_u32(0x0900000F) // ds_load_b32 v9, v15
    asm_u32     (0xD8D80000); asm_u32(0x0A000010) // ds_load_b32 v10, v16
    asm_u32_arch(0xBF89FC07, 0xBF8CC07F)
    asm_u32     (0x560C1509)             // v_fmac_f32 v6, v9, v10
    asm_u32     (0xD525000F); asm_u32(0x0001090F) // v_add_nc_u32_e64 v15, v15, 4
    asm_u32     (0xD5250010); asm_u32(0x00018110) // v_add_nc_u32_e64 v16, v16, 64
    asm_u32     (0x80148114)             // s_add_u32 s20, s20, 1
    asm_u32     (0xBF0A9014)             // s_cmp_lt_u32 s20, 16
    asm_u32_arch(0xBFA2FFF2, 0xBF85FFF2) // s_cbranch_scc1 -14
    asm_u32_arch(0xBFBD0000, 0xBF8A0000) // s_barrier
    asm_u32     (0xE0AC0000); asm_u32(0x00000000)
    asm_u32     (0x80138113)             // s_add_u32 s19, s19, 1
    asm_u32     (0xBF0A1213)             // s_cmp_lt_u32 s19, s18
    asm_u32_arch(0xBFA2FFC3, 0xBF85FFC3) // s_cbranch_scc1 -61
    // .Lstore:
    asm_u32_arch(0xD72C0008, 0xD5690008); asm_u32(0x00001903) // v_mul_lo_u32 v8, v3, s12
    asm_u32     (0x4A100908)             // v_add_nc_u32 v8, s8, v8
    asm_u32     (0x7E120280)             // v_mov_b32 v9, 0
    asm_u32_arch(0xD73C0008, 0xD6FF0008); asm_u32(0x00021082) // v_lshlrev_b64
    asm_u32_arch(0xD7006A08, 0xD70F6A08); asm_u32(0x00021008) // v_add_co_u32 v8, vcc_lo, s8, v8
    asm_u32_arch(0xD5207C09, 0xD5287D09); asm_u32(0x01AA1209) // v_add_co_ci_u32 v9
    asm_u32_arch(0xDC6A0000, 0xDC708000); asm_u32_arch(0x007C0608, 0x007D0608) // global_store_b32 v[8:9], v6
    asm_u32_arch(0xBC7C0000, 0xBBFD0000) // s_waitcnt_vscnt
    asm_u32_arch(0xBFB00000, 0xBF810000) // s_endpgm

    uint64 a0  = args_desc + 0;   unsafe { *(a0  as uint64) = 8 }
    uint64 a1  = args_desc + 8;   unsafe { *(a1  as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a2  = args_desc + 16;  unsafe { *(a2  as uint64) = 8 }
    uint64 a3  = args_desc + 24;  unsafe { *(a3  as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a4  = args_desc + 32;  unsafe { *(a4  as uint64) = 8 }
    uint64 a5  = args_desc + 40;  unsafe { *(a5  as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a6  = args_desc + 48;  unsafe { *(a6  as uint64) = 8 }
    uint64 a7  = args_desc + 56;  unsafe { *(a7  as uint64) = AMD_ARG_KIND_BY_VALUE }
    uint64 a8  = args_desc + 64;  unsafe { *(a8  as uint64) = 8 }
    uint64 a9  = args_desc + 72;  unsafe { *(a9  as uint64) = AMD_ARG_KIND_BY_VALUE }
    uint64 a10 = args_desc + 80;  unsafe { *(a10 as uint64) = 8 }
    uint64 a11 = args_desc + 88;  unsafe { *(a11 as uint64) = AMD_ARG_KIND_BY_VALUE }
}

@export
fn emit_amdgpu_gemm_f32_lds_blob(uint64 out_path) -> uint64 {
    uint64[12] args_desc
    _emit_gemm_f32_lds_body(args_desc)

    uint64 size = emit_amdgpu_code_object_lds("gemm_f32_lds", 12,
                                               asm_text_buf, asm_text_len,
                                               32, 8, 16, 14,
                                               0xE0AF0001, 0x0000009E, 0x00000010, 0x0408,
                                               args_desc, 4,
                                               1024)

    uint64 fd = file_open(out_path, 1)
    if fd > 0xFFFFFFFFFFFFF000 {
        write(2, "emit_amdgpu_gemm_f32_lds_blob: cannot open output\n", 50)
        return 1
    }
    file_write(fd, amd_buf, size)
    file_close(fd)
    return 0
}



// LLM Phase A milestone 4 — gemm f16 storage, f32 accum, native-emit.
// Identical structure to N3 (16x16 LDS-tiled, 2-D dispatch) except:
//   - A and B are f16 in global memory (2 bytes/element, not 4).
//   - global_load_d16_b16 reads f16; v_cvt_f32_f16 converts to f32.
//   - LDS still holds f32 (2 KiB layout unchanged from N3).
//   - C output is f32 (store unchanged).
//   - Address arithmetic for A/B: lshlrev_b64 by 1 (×2) instead of 2 (×4).
@export
fn _emit_gemm_f16f32_body(uint64 args_desc) {
    asm_init()
    // Kernarg load.
    asm_u32_arch(0xF40C0100, 0xF40C0100); asm_u32_arch(0xF8000000, 0xFA000000)
    asm_u32_arch(0xF4040300, 0xF4040300); asm_u32_arch(0xF8000020, 0xFA000020)
    asm_u32_arch(0xF4040380, 0xF4040380); asm_u32_arch(0xF8000028, 0xFA000028)
    asm_u32_arch(0xBF89FC07, 0xBF8CC07F)
    asm_u32_arch(0xD6100001, 0xD5480001); asm_u32(0x02291500) // v_bfe_u32 v1, v0, 10, 10
    asm_u32     (0x360000FF); asm_u32(0x000003FF) // v_and_b32 v0, 0x3FF, v0
    asm_u32_arch(0x84108403, 0x8F108403) // s_lshl_b32 s16, s3, 4
    asm_u32_arch(0x84118402, 0x8F118402) // s_lshl_b32 s17, s2, 4
    asm_u32     (0x4A060210)             // v_add_nc_u32 v3, s16, v1
    asm_u32     (0x4A080011)             // v_add_nc_u32 v4, s17, v0
    asm_u32_arch(0xBE82007E, 0xBE82037E)
    asm_u32_arch(0x7C98060A, 0x7D88060A)
    asm_u32_arch(0x8B7E6A7E, 0x877E6A7E)
    asm_u32_arch(0x7C98080C, 0x7D88080C)
    asm_u32_arch(0x8B7E6A7E, 0x877E6A7E)
    asm_u32_arch(0xBFA5005A, 0xBF88005A) // s_cbranch_execz +90 → .Lend
    asm_u32_arch(0x8512840E, 0x9012840E) // s_lshr_b32 s18, s14, 4
    asm_u32     (0x7E0C0280)             // v_mov_b32 v6, 0
    asm_u32_arch(0xBE930080, 0xBE930380) // s_mov_b32 s19, 0
    asm_u32_arch(0x300A0284, 0x340A0284) // v_lshlrev_b32 v5, 4, v1
    asm_u32     (0x4A0A0105)
    asm_u32_arch(0x300A0A82, 0x340A0A82)
    asm_u32_arch(0x30220286, 0x34220286) // v_lshlrev_b32 v17, 6, v1
    asm_u32_arch(0x30240082, 0x34240082)
    asm_u32     (0xD5250012); asm_u32(0x0001FF12); asm_u32(0x00000400)
    asm_u32_arch(0xBF068012, 0xBF800000) // s_waitcnt_depctr (gfx11) → s_nop 0 (gfx10)
    asm_u32_arch(0xBFA20040, 0xBF850040) // s_cbranch_scc1 +64 → .Lstore
    // .Lkt_loop:
    asm_u32_arch(0x84148413, 0x8F148413)
    asm_u32     (0x4A0E0014)
    asm_u32_arch(0xD72C0008, 0xD5690008); asm_u32(0x00001D03)
    asm_u32     (0x4A100F08)
    asm_u32     (0x7E120280)
    asm_u32_arch(0xD73C0008, 0xD6FF0008); asm_u32(0x00021081) // v_lshlrev_b64 ×2 (f16)
    asm_u32_arch(0xD7006A08, 0xD70F6A08); asm_u32(0x00021004)
    asm_u32_arch(0xD5207C09, 0xD5287D09); asm_u32(0x01AA1205)
    asm_u32_arch(0xBF870001, 0xBF800000) // s_delay_alu → s_nop 0
    asm_u32_arch(0xDC820000, 0xDC908000); asm_u32_arch(0x0A7C0008, 0x0A7D0008) // global_load_d16_b16/short_d16
    asm_u32     (0x4A160214)
    asm_u32_arch(0xD72C000C, 0xD569000C); asm_u32(0x0000190B)
    asm_u32     (0x4A18090C)
    asm_u32     (0x7E1A0280)
    asm_u32_arch(0xD73C000C, 0xD6FF000C); asm_u32(0x00021881)
    asm_u32_arch(0xD7006A0C, 0xD70F6A0C); asm_u32(0x00021806)
    asm_u32_arch(0xD5207C0D, 0xD5287D0D); asm_u32(0x01AA1A07)
    asm_u32_arch(0xBF870001, 0xBF800000)
    asm_u32_arch(0xDC820000, 0xDC908000); asm_u32_arch(0x0E7C000C, 0x0E7D000C)
    asm_u32_arch(0xBF8903F7, 0xBF8C3F70)
    asm_u32     (0x7E14170A)             // v_cvt_f32_f16 v10, v10 (VOP1 stable)
    asm_u32     (0x7E1C170E)             // v_cvt_f32_f16 v14, v14
    asm_u32_arch(0xBF870001, 0xBF800000)
    asm_u32     (0xD8340000); asm_u32(0x00000A05)
    asm_u32     (0xD8340400); asm_u32(0x00000E05)
    asm_u32_arch(0xBF89FC07, 0xBF8CC07F)
    asm_u32_arch(0xBFBD0000, 0xBF8A0000) // s_barrier
    asm_u32     (0xE0AC0000); asm_u32(0x00000000) // buffer_gl0_inv (preserved verbatim)
    asm_u32_arch(0xBE940080, 0xBE940380) // s_mov_b32 s20, 0
    asm_u32     (0x7E1E0311)
    asm_u32     (0x7E200312)
    // .Linner:
    asm_u32_arch(0xBF870002, 0xBF800000) // s_delay_alu → s_nop 0
    asm_u32     (0xD8D80000); asm_u32(0x0900000F)
    asm_u32     (0xD8D80000); asm_u32(0x0A000010)
    asm_u32_arch(0xBF89FC07, 0xBF8CC07F)
    asm_u32     (0x560C1509)
    asm_u32     (0xD525000F); asm_u32(0x0001090F)
    asm_u32     (0xD5250010); asm_u32(0x00018110)
    asm_u32     (0x80148114)
    asm_u32     (0xBF0A9014)
    asm_u32_arch(0xBFA2FFF2, 0xBF85FFF2)
    asm_u32_arch(0xBFBD0000, 0xBF8A0000)
    asm_u32     (0xE0AC0000); asm_u32(0x00000000)
    asm_u32     (0x80138113)
    asm_u32     (0xBF0A1213)
    asm_u32_arch(0xBFA2FFC0, 0xBF85FFC0)
    // .Lstore:
    asm_u32_arch(0xD72C0008, 0xD5690008); asm_u32(0x00001903)
    asm_u32     (0x4A100908)
    asm_u32     (0x7E120280)
    asm_u32_arch(0xD73C0008, 0xD6FF0008); asm_u32(0x00021082) // ×4 for f32 C
    asm_u32_arch(0xD7006A08, 0xD70F6A08); asm_u32(0x00021008)
    asm_u32_arch(0xD5207C09, 0xD5287D09); asm_u32(0x01AA1209)
    asm_u32_arch(0xDC6A0000, 0xDC708000); asm_u32_arch(0x007C0608, 0x007D0608)
    asm_u32_arch(0xBC7C0000, 0xBBFD0000)
    asm_u32_arch(0xBFB00000, 0xBF810000)

    uint64 a0  = args_desc + 0;   unsafe { *(a0  as uint64) = 8 }
    uint64 a1  = args_desc + 8;   unsafe { *(a1  as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a2  = args_desc + 16;  unsafe { *(a2  as uint64) = 8 }
    uint64 a3  = args_desc + 24;  unsafe { *(a3  as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a4  = args_desc + 32;  unsafe { *(a4  as uint64) = 8 }
    uint64 a5  = args_desc + 40;  unsafe { *(a5  as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a6  = args_desc + 48;  unsafe { *(a6  as uint64) = 8 }
    uint64 a7  = args_desc + 56;  unsafe { *(a7  as uint64) = AMD_ARG_KIND_BY_VALUE }
    uint64 a8  = args_desc + 64;  unsafe { *(a8  as uint64) = 8 }
    uint64 a9  = args_desc + 72;  unsafe { *(a9  as uint64) = AMD_ARG_KIND_BY_VALUE }
    uint64 a10 = args_desc + 80;  unsafe { *(a10 as uint64) = 8 }
    uint64 a11 = args_desc + 88;  unsafe { *(a11 as uint64) = AMD_ARG_KIND_BY_VALUE }
}

fn emit_amdgpu_gemm_f16f32_blob(uint64 out_path) -> uint64 {
    uint64[12] args_desc
    _emit_gemm_f16f32_body(args_desc)

    uint64 size = emit_amdgpu_code_object_lds("gemm_f16f32", 11,
                                               asm_text_buf, asm_text_len,
                                               32, 8, 16, 14,
                                               0xE0AF0001, 0x0000009E, 0x00000010, 0x0408,
                                               args_desc, 4,
                                               1024)

    uint64 fd = file_open(out_path, 1)
    if fd > 0xFFFFFFFFFFFFF000 {
        write(2, "emit_amdgpu_gemm_f16f32_blob: cannot open output\n", 49)
        return 1
    }
    file_write(fd, amd_buf, size)
    file_close(fd)
    return 0
}


// LLM Phase A milestone 5 — gemm f16-storage / f32-accum, WMMA-tiled.
// gfx1100 v_wmma_f32_16x16x16_f16 instruction does one 16×16×16 f16→f32
// matrix multiply per wave32. Kernel: 1 wave per 16×16 output tile.
//   Block = 32 (1 wave), grid = (tiles_n, tiles_m, 1).
//   v0 = lane (0..31).
//   v1..v8   = B fragment (lane L holds column L%16 of B's 16×16 tile,
//              16 f16 packed lo/hi across 8 vgprs, with rows 0,2,...,14
//              in lo halves and 1,3,...,15 in hi halves).
//   v9..v16  = A fragment (lane L holds row L%16 of A's tile, 16 f16
//              packed in 8 dwords).
//   v17..v24 = C accumulator (lane L holds 8 f32 = column L%16 of C,
//              rows 2*i + L/16 for i = 0..7).
//   v25..v30 = scratch (wave-half, idx, A v_off, B v_off lo/hi, C v_off).
fn _emit_gemm_f16f32_wmma_body(uint64 args_desc) {
    asm_init()
    // USER_SGPR=15 (rsrc2=0x19E) → WG_ID_X in s15, WG_ID_Y in s16
    // (NOT s2/s3 — original emit was a latent multi-WG bug).
    // s_load_b64 s[14:15] below overwrites s15 with the high half of
    // K (always 0), so we must stash WG_ID_X first. s16 (WG_ID_Y) is
    // not in any kernarg-load destination range, so it survives.
    asm_u32(0xBE82000F)                         // s_mov_b32 s2, s15  (save WG_ID_X)
    // Kernarg load
    asm_u32(0xF40C0100); asm_u32(0xF8000000)   // s_load_b256 s[4:11]
    asm_u32(0xF4040300); asm_u32(0xF8000020)   // s_load_b64 s[12:13]
    asm_u32(0xF4040380); asm_u32(0xF8000028)   // s_load_b64 s[14:15]  (clobbers s15)
    asm_u32(0xBF89FC07)                         // s_waitcnt lgkmcnt(0)
    asm_u32(0x84108410)                         // s_lshl_b32 s16, s16, 4  (WG_ID_Y → tile_row*16)
    asm_u32(0x84118402)                         // s_lshl_b32 s17, s2,  4  (WG_ID_X → tile_col*16)
    // Whole-tile bounds
    asm_u32(0xBF090A10)                         // s_cmp_ge_u32 s16, s10
    asm_u32(0xBFA2007C)                         // s_cbranch_scc1 +124 → .Lend
    asm_u32(0xBF090C11)                         // s_cmp_ge_u32 s17, s12
    asm_u32(0xBFA2007A)                         // s_cbranch_scc1 +122 → .Lend
    // Lane decompose
    asm_u32(0x3634008F)                         // v_and_b32 v26, 15, v0
    asm_u32(0x32320084)                         // v_lshrrev_b32 v25, 4, v0
    // Stride constants
    asm_u32(0x8413810C)                         // s_lshl_b32 s19, s12, 1   (N*2)
    asm_u32(0x8414820C)                         // s_lshl_b32 s20, s12, 2   (N*4)
    asm_u32(0x8417830C)                         // s_lshl_b32 s23, s12, 3   (N*8)
    // A v_off = (s16 + v26) * s14 * 2
    asm_u32(0x4A363410)                         // v_add_nc_u32 v27, s16, v26
    asm_u32(0xD72C001B); asm_u32(0x00001D1B)   // v_mul_lo_u32 v27, v27, s14
    asm_u32(0x30363681)                         // v_lshlrev_b32 v27, 1, v27
    // B v_off lo = (s17 + v26) * 2
    asm_u32(0x4A383411)                         // v_add_nc_u32 v28, s17, v26
    asm_u32(0x30383881)                         // v_lshlrev_b32 v28, 1, v28
    asm_u32(0x4A3A3813)                         // v_add_nc_u32 v29, s19, v28  (= +N*2)
    // C v_off = ((s16 + v25) * s12 + s17 + v26) * 4
    asm_u32(0x4A3C3210)                         // v_add_nc_u32 v30, s16, v25
    asm_u32(0xD72C001E); asm_u32(0x0000191E)   // v_mul_lo_u32 v30, v30, s12
    asm_u32(0x4A3C3C11)                         // v_add_nc_u32 v30, s17, v30
    asm_u32(0x4A3C351E)                         // v_add_nc_u32 v30, v30, v26
    asm_u32(0x303C3C82)                         // v_lshlrev_b32 v30, 2, v30
    // num_kt, kt counter
    asm_u32(0x8515840E)                         // s_lshr_b32 s21, s14, 4
    asm_u32(0xBE960080)                         // s_mov_b32 s22, 0
    // Init C accumulator
    asm_u32(0x7E220280); asm_u32(0x7E240280)   // v17 = v18 = 0
    asm_u32(0x7E260280); asm_u32(0x7E280280)   // v19 = v20 = 0
    asm_u32(0x7E2A0280); asm_u32(0x7E2C0280)   // v21 = v22 = 0
    asm_u32(0x7E2E0280); asm_u32(0x7E300280)   // v23 = v24 = 0
    // Skip K-loop if K=0
    asm_u32(0xBF068015)                         // s_cmp_eq_u32 s21, 0
    asm_u32(0xBFA20044)                         // s_cbranch_scc1 +68 → .Lstore
    // .Lkt_loop:
    asm_u32(0xBF870001)                         // s_delay_alu instid0(VALU_DEP_1)
    asm_u32(0xDC5E0000); asm_u32(0x0904001B)   // global_load_b128 v[9:12], v27, s[4:5]
    asm_u32(0xDC5E0010); asm_u32(0x0D04001B)   // global_load_b128 v[13:16], v27, s[4:5] offset:16
    // 8 pairs of B loads
    asm_u32(0xBF870001)
    asm_u32(0xDC820000); asm_u32(0x0106001C)   // d16_b16    v1, v28
    asm_u32(0xDC8E0000); asm_u32(0x0106001D)   // d16_hi_b16 v1, v29
    asm_u32(0x4A383814); asm_u32(0x4A3A3A14)   // v28 += s20; v29 += s20
    asm_u32(0xBF870001)
    asm_u32(0xDC820000); asm_u32(0x0206001C)
    asm_u32(0xDC8E0000); asm_u32(0x0206001D)
    asm_u32(0x4A383814); asm_u32(0x4A3A3A14)
    asm_u32(0xBF870001)
    asm_u32(0xDC820000); asm_u32(0x0306001C)
    asm_u32(0xDC8E0000); asm_u32(0x0306001D)
    asm_u32(0x4A383814); asm_u32(0x4A3A3A14)
    asm_u32(0xBF870001)
    asm_u32(0xDC820000); asm_u32(0x0406001C)
    asm_u32(0xDC8E0000); asm_u32(0x0406001D)
    asm_u32(0x4A383814); asm_u32(0x4A3A3A14)
    asm_u32(0xBF870001)
    asm_u32(0xDC820000); asm_u32(0x0506001C)
    asm_u32(0xDC8E0000); asm_u32(0x0506001D)
    asm_u32(0x4A383814); asm_u32(0x4A3A3A14)
    asm_u32(0xBF870001)
    asm_u32(0xDC820000); asm_u32(0x0606001C)
    asm_u32(0xDC8E0000); asm_u32(0x0606001D)
    asm_u32(0x4A383814); asm_u32(0x4A3A3A14)
    asm_u32(0xBF870001)
    asm_u32(0xDC820000); asm_u32(0x0706001C)
    asm_u32(0xDC8E0000); asm_u32(0x0706001D)
    asm_u32(0x4A383814); asm_u32(0x4A3A3A14)
    asm_u32(0xBF870001)
    asm_u32(0xDC820000); asm_u32(0x0806001C)
    asm_u32(0xDC8E0000); asm_u32(0x0806001D)
    asm_u32(0x4A383814); asm_u32(0x4A3A3A14)
    // A v_off += 32 (next K-tile)
    asm_u32(0x4A3636A0)                         // v_add_nc_u32 v27, 32, v27
    asm_u32(0xBF8903F7)                         // s_waitcnt vmcnt(0)
    asm_u32(0xCC404011); asm_u32(0x1C460309)   // v_wmma_f32_16x16x16_f16
    asm_u32(0x80168116)                         // s_add_u32 s22, s22, 1
    asm_u32(0xBF0A1516)                         // s_cmp_lt_u32 s22, s21
    asm_u32(0xBFA2FFBC)                         // s_cbranch_scc1 -68 → .Lkt_loop
    // .Lstore: 8 stores at v_off, increment by N*8 between
    asm_u32(0xDC6A0000); asm_u32(0x0008111E)   // global_store_b32 v30, v17, s[8:9]
    asm_u32(0x4A3C3C17)                         // v_add_nc_u32 v30, s23, v30
    asm_u32(0xDC6A0000); asm_u32(0x0008121E)
    asm_u32(0x4A3C3C17)
    asm_u32(0xDC6A0000); asm_u32(0x0008131E)
    asm_u32(0x4A3C3C17)
    asm_u32(0xDC6A0000); asm_u32(0x0008141E)
    asm_u32(0x4A3C3C17)
    asm_u32(0xDC6A0000); asm_u32(0x0008151E)
    asm_u32(0x4A3C3C17)
    asm_u32(0xDC6A0000); asm_u32(0x0008161E)
    asm_u32(0x4A3C3C17)
    asm_u32(0xDC6A0000); asm_u32(0x0008171E)
    asm_u32(0x4A3C3C17)
    asm_u32(0xDC6A0000); asm_u32(0x0008181E)   // last store, no increment after
    asm_u32(0xBC7C0000)                         // s_waitcnt_vscnt null, 0
    // .Lend:
    asm_u32(0xBFB00000)                         // s_endpgm

    uint64 a0  = args_desc + 0;   unsafe { *(a0  as uint64) = 8 }
    uint64 a1  = args_desc + 8;   unsafe { *(a1  as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a2  = args_desc + 16;  unsafe { *(a2  as uint64) = 8 }
    uint64 a3  = args_desc + 24;  unsafe { *(a3  as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a4  = args_desc + 32;  unsafe { *(a4  as uint64) = 8 }
    uint64 a5  = args_desc + 40;  unsafe { *(a5  as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a6  = args_desc + 48;  unsafe { *(a6  as uint64) = 8 }
    uint64 a7  = args_desc + 56;  unsafe { *(a7  as uint64) = AMD_ARG_KIND_BY_VALUE }
    uint64 a8  = args_desc + 64;  unsafe { *(a8  as uint64) = 8 }
    uint64 a9  = args_desc + 72;  unsafe { *(a9  as uint64) = AMD_ARG_KIND_BY_VALUE }
    uint64 a10 = args_desc + 80;  unsafe { *(a10 as uint64) = 8 }
    uint64 a11 = args_desc + 88;  unsafe { *(a11 as uint64) = AMD_ARG_KIND_BY_VALUE }
}

@export
fn emit_amdgpu_gemm_f16f32_wmma_blob(uint64 out_path) -> uint64 {
    uint64[12] args_desc
    _emit_gemm_f16f32_wmma_body(args_desc)

    uint64 size = emit_amdgpu_code_object("gemm_f16f32_wmma", 16,
                                           asm_text_buf, asm_text_len,
                                           48, 8, 24, 31,
                                           0xE0AF0083, 0x0000019E, 0x00000010, 0x0408,
                                           args_desc, 6)

    uint64 fd = file_open(out_path, 1)
    if fd > 0xFFFFFFFFFFFFF000 {
        write(2, "emit_amdgpu_gemm_f16f32_wmma_blob: cannot open output\n", 54)
        return 1
    }
    file_write(fd, amd_buf, size)
    file_close(fd)
    return 0
}


// Destroy-PyTorch slice — bf16 input WMMA GEMM. Byte-identical to the
// f16 emitter above (`_emit_gemm_f16f32_wmma_body`) except for the WMMA
// instruction itself: gfx1100's `v_wmma_f32_16x16x16_bf16` encodes as
// 0xCC414011 (vs 0xCC404011 for f16). All other ops (loads, layout,
// stores, sgpr/vgpr usage, KD) are identical — bf16 and f16 share the
// same 16-bit storage shape, so the kernel body just re-interprets the
// loaded bytes as bf16. Used for lm_head GEMV (padded to M=16) and the
// bf16 matmul phases that benefit from tensor-core throughput.
fn _emit_gemm_bf16f32_wmma_body(uint64 args_desc) {
    asm_init()
    // Save WG_ID_X before kernarg load clobbers s15 (see f16 variant).
    asm_u32(0xBE82000F)                         // s_mov_b32 s2, s15
    asm_u32(0xF40C0100); asm_u32(0xF8000000)
    asm_u32(0xF4040300); asm_u32(0xF8000020)
    asm_u32(0xF4040380); asm_u32(0xF8000028)
    asm_u32(0xBF89FC07)
    asm_u32(0x84108410)                         // s_lshl_b32 s16, s16, 4  (WG_ID_Y)
    asm_u32(0x84118402)                         // s_lshl_b32 s17, s2,  4  (WG_ID_X from stash)
    asm_u32(0xBF090A10)
    asm_u32(0xBFA2007C)
    asm_u32(0xBF090C11)
    asm_u32(0xBFA2007A)
    asm_u32(0x3634008F)
    asm_u32(0x32320084)
    asm_u32(0x8413810C)
    asm_u32(0x8414820C)
    asm_u32(0x8417830C)
    asm_u32(0x4A363410)
    asm_u32(0xD72C001B); asm_u32(0x00001D1B)
    asm_u32(0x30363681)
    asm_u32(0x4A383411)
    asm_u32(0x30383881)
    asm_u32(0x4A3A3813)
    asm_u32(0x4A3C3210)
    asm_u32(0xD72C001E); asm_u32(0x0000191E)
    asm_u32(0x4A3C3C11)
    asm_u32(0x4A3C351E)
    asm_u32(0x303C3C82)
    asm_u32(0x8515840E)
    asm_u32(0xBE960080)
    asm_u32(0x7E220280); asm_u32(0x7E240280)
    asm_u32(0x7E260280); asm_u32(0x7E280280)
    asm_u32(0x7E2A0280); asm_u32(0x7E2C0280)
    asm_u32(0x7E2E0280); asm_u32(0x7E300280)
    asm_u32(0xBF068015)
    asm_u32(0xBFA20044)
    asm_u32(0xBF870001)
    asm_u32(0xDC5E0000); asm_u32(0x0904001B)
    asm_u32(0xDC5E0010); asm_u32(0x0D04001B)
    asm_u32(0xBF870001)
    asm_u32(0xDC820000); asm_u32(0x0106001C)
    asm_u32(0xDC8E0000); asm_u32(0x0106001D)
    asm_u32(0x4A383814); asm_u32(0x4A3A3A14)
    asm_u32(0xBF870001)
    asm_u32(0xDC820000); asm_u32(0x0206001C)
    asm_u32(0xDC8E0000); asm_u32(0x0206001D)
    asm_u32(0x4A383814); asm_u32(0x4A3A3A14)
    asm_u32(0xBF870001)
    asm_u32(0xDC820000); asm_u32(0x0306001C)
    asm_u32(0xDC8E0000); asm_u32(0x0306001D)
    asm_u32(0x4A383814); asm_u32(0x4A3A3A14)
    asm_u32(0xBF870001)
    asm_u32(0xDC820000); asm_u32(0x0406001C)
    asm_u32(0xDC8E0000); asm_u32(0x0406001D)
    asm_u32(0x4A383814); asm_u32(0x4A3A3A14)
    asm_u32(0xBF870001)
    asm_u32(0xDC820000); asm_u32(0x0506001C)
    asm_u32(0xDC8E0000); asm_u32(0x0506001D)
    asm_u32(0x4A383814); asm_u32(0x4A3A3A14)
    asm_u32(0xBF870001)
    asm_u32(0xDC820000); asm_u32(0x0606001C)
    asm_u32(0xDC8E0000); asm_u32(0x0606001D)
    asm_u32(0x4A383814); asm_u32(0x4A3A3A14)
    asm_u32(0xBF870001)
    asm_u32(0xDC820000); asm_u32(0x0706001C)
    asm_u32(0xDC8E0000); asm_u32(0x0706001D)
    asm_u32(0x4A383814); asm_u32(0x4A3A3A14)
    asm_u32(0xBF870001)
    asm_u32(0xDC820000); asm_u32(0x0806001C)
    asm_u32(0xDC8E0000); asm_u32(0x0806001D)
    asm_u32(0x4A383814); asm_u32(0x4A3A3A14)
    asm_u32(0x4A3636A0)
    asm_u32(0xBF8903F7)
    asm_u32(0xCC414011); asm_u32(0x1C460309)   // v_wmma_f32_16x16x16_bf16 (bf16 input variant)
    asm_u32(0x80168116)
    asm_u32(0xBF0A1516)
    asm_u32(0xBFA2FFBC)
    asm_u32(0xDC6A0000); asm_u32(0x0008111E)
    asm_u32(0x4A3C3C17)
    asm_u32(0xDC6A0000); asm_u32(0x0008121E)
    asm_u32(0x4A3C3C17)
    asm_u32(0xDC6A0000); asm_u32(0x0008131E)
    asm_u32(0x4A3C3C17)
    asm_u32(0xDC6A0000); asm_u32(0x0008141E)
    asm_u32(0x4A3C3C17)
    asm_u32(0xDC6A0000); asm_u32(0x0008151E)
    asm_u32(0x4A3C3C17)
    asm_u32(0xDC6A0000); asm_u32(0x0008161E)
    asm_u32(0x4A3C3C17)
    asm_u32(0xDC6A0000); asm_u32(0x0008171E)
    asm_u32(0x4A3C3C17)
    asm_u32(0xDC6A0000); asm_u32(0x0008181E)
    asm_u32(0xBC7C0000)
    asm_u32(0xBFB00000)

    uint64 a0  = args_desc + 0;   unsafe { *(a0  as uint64) = 8 }
    uint64 a1  = args_desc + 8;   unsafe { *(a1  as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a2  = args_desc + 16;  unsafe { *(a2  as uint64) = 8 }
    uint64 a3  = args_desc + 24;  unsafe { *(a3  as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a4  = args_desc + 32;  unsafe { *(a4  as uint64) = 8 }
    uint64 a5  = args_desc + 40;  unsafe { *(a5  as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a6  = args_desc + 48;  unsafe { *(a6  as uint64) = 8 }
    uint64 a7  = args_desc + 56;  unsafe { *(a7  as uint64) = AMD_ARG_KIND_BY_VALUE }
    uint64 a8  = args_desc + 64;  unsafe { *(a8  as uint64) = 8 }
    uint64 a9  = args_desc + 72;  unsafe { *(a9  as uint64) = AMD_ARG_KIND_BY_VALUE }
    uint64 a10 = args_desc + 80;  unsafe { *(a10 as uint64) = 8 }
    uint64 a11 = args_desc + 88;  unsafe { *(a11 as uint64) = AMD_ARG_KIND_BY_VALUE }
}

@export
fn emit_amdgpu_gemm_bf16f32_wmma_blob(uint64 out_path) -> uint64 {
    uint64[12] args_desc
    _emit_gemm_bf16f32_wmma_body(args_desc)

    uint64 size = emit_amdgpu_code_object("gemm_bf16f32_wmma", 17,
                                           asm_text_buf, asm_text_len,
                                           48, 8, 24, 31,
                                           0xE0AF0083, 0x0000019E, 0x00000010, 0x0408,
                                           args_desc, 6)

    uint64 fd = file_open(out_path, 1)
    if fd > 0xFFFFFFFFFFFFF000 {
        write(2, "emit_amdgpu_gemm_bf16f32_wmma_blob: cannot open output\n", 55)
        return 1
    }
    file_write(fd, amd_buf, size)
    file_close(fd)
    return 0
}


// LLM Phase 2 — softmax_f32 native emit. Numerically-stable softmax
// over rows of M×N f32 input (N must be 256). Block = 256 lanes,
// grid = M (one WG per row). LDS-based pairwise reduction (max + sum)
// with 8 strides each (256 → 1).
//
// Kernarg layout (32 bytes, 4 args):
//   [0x00] uint64 in_ptr   (M × N f32)
//   [0x08] uint64 out_ptr  (M × N f32)
//   [0x10] uint64 m
//   [0x18] uint64 n        (only low 32 used; must equal 256)

// Shape-parametric softmax_f32. N must be a power of two in [32, 1024].
// Same kernel structure as _emit_softmax_f32_body but with the LDS
// reduction tree depth driven by log2(N) and the s_cbranch_scc1 to .Lend
// patched in after the body length is known.  Block size = N (one lane
// per element of the row).  LDS allocation = 4*N bytes.
fn _emit_softmax_f32_body_N(uint64 args_desc, uint64 N) {
    asm_init()
    uint64 Np = _round_up_pow2(N)

    // ── Prologue ────────────────────────────────────────────────────
    asm_u32_arch(0xF40C0100, 0xF40C0100) // s_load_b256/dwordx8 s[4:11], s[0:1], 0x0
    asm_u32_arch(0xF8000000, 0xFA000000)
    asm_u32_arch(0xBF89FC07, 0xBF8CC07F) // s_waitcnt lgkmcnt(0)
    asm_u32     (0xBF09080F)             // s_cmp_ge_u32 s15, s8 (SOPC stable)
    uint64 cbranch_dword_idx = asm_text_len / 4
    asm_u32_arch(0xBFA20000, 0xBF850000) // s_cbranch_scc1 (op shift, patched later)
    asm_u32_arch(0x960C0A0F, 0x930C0A0F) // s_mul_i32 s12, s15, s10
    asm_u32     (0x4A02000C)             // v_add_nc_u32 v1, s12, v0
    asm_u32_arch(0x30080282, 0x34080282) // v_lshlrev_b32 v4, 2, v1
    asm_u32     (0x7E060280)             // v_mov_b32 v3, 0
    asm_u32_arch(0xD7006A02, 0xD70F6A02) // v_add_co_u32 v2, vcc_lo, s4, v4
    asm_u32     (0x00020804)
    asm_u32_arch(0xD5207C03, 0xD5287D03) // v_add_co_ci_u32 v3, null, s5, v3, vcc_lo
    asm_u32     (0x01AA0605)
    asm_u32     (0x7E1A0280)             // v_mov_b32 v13, 0
    asm_u32_arch(0xD7006A0C, 0xD70F6A0C) // v_add_co_u32 v12, vcc_lo, s6, v4
    asm_u32     (0x00020806)
    asm_u32_arch(0xD5207C0D, 0xD5287D0D) // v_add_co_ci_u32 v13, null, s7, v13, vcc_lo
    asm_u32     (0x01AA1A07)
    if N != Np {
        _emit_gated_load_v10(12, 10, 0xFF800000)
    } else {
        asm_u32_arch(0xDC520000, 0xDC308000) // global_load_b32 v10, v[2:3], off
        asm_u32_arch(0x0A7C0002, 0x0A7D0002)
        asm_u32_arch(0xBF8903F7, 0xBF8C3F70) // s_waitcnt vmcnt(0)
    }
    asm_u32     (0x7E0A030A)             // v_mov_b32 v5, v10 (VOP1 stable)
    asm_u32_arch(0x300C0082, 0x340C0082) // v_lshlrev_b32 v6, 2, v0
    asm_u32     (0x7E120280)             // v_mov_b32 v9, 0
    asm_u32     (0xD8340000)             // ds_store_b32 v6, v5 (DS stable)
    asm_u32     (0x00000506)
    asm_u32_arch(0xBF89FC07, 0xBF8CC07F) // s_waitcnt lgkmcnt(0)
    asm_u32_arch(0xBFBD0000, 0xBF8A0000) // s_barrier

    // ── Phase A: max-reduce ─────────────────────────────────────────
    _emit_lds_reduce_pow2(Np, 0x200A0F05, 12)

    // ── Mid: broadcast max, e = exp((x-max)*log2e) ──────────────────
    asm_u32     (0xD8D80000)             // ds_load_b32 v8, v9
    asm_u32     (0x08000009)
    asm_u32_arch(0xBF89FC07, 0xBF8CC07F) // s_waitcnt lgkmcnt(0)
    asm_u32     (0x0816110A)             // v_sub_f32 v11, v10, v8
    asm_u32_arch(0xBE8C00FF, 0xBE8C03FF) // s_mov_b32 s12, lit (SOP1 imm op shift)
    asm_u32     (0x3FB8AA3B)             // log2(e)
    asm_u32     (0x1016160C)             // v_mul_f32 v11, s12, v11
    asm_u32     (0x7E164B0B)             // v_exp_f32 v11, v11
    asm_u32_arch(0xBFBD0000, 0xBF8A0000) // s_barrier
    asm_u32     (0x7E0A030B)             // v_mov_b32 v5, v11
    asm_u32     (0xD8340000)             // ds_store_b32 v6, v5
    asm_u32     (0x00000506)
    asm_u32_arch(0xBF89FC07, 0xBF8CC07F) // s_waitcnt lgkmcnt(0)
    asm_u32_arch(0xBFBD0000, 0xBF8A0000) // s_barrier

    // ── Phase B: sum-reduce ─────────────────────────────────────────
    _emit_lds_reduce_pow2(Np, 0x060A0F05, 12)

    // ── Finalize ────────────────────────────────────────────────────
    asm_u32     (0xD8D80000)             // ds_load_b32 v8, v9
    asm_u32     (0x08000009)
    asm_u32_arch(0xBF89FC07, 0xBF8CC07F) // s_waitcnt
    asm_u32     (0x7E105508)             // v_rcp_f32 v8, v8 (VOP1 stable)
    asm_u32     (0x100A110B)             // v_mul_f32 v5, v11, v8
    if N != Np { _emit_store_gate(12, 10) }
    asm_u32_arch(0xDC6A0000, 0xDC708000) // global_store_b32 v[12:13], v5, off
    asm_u32_arch(0x007C050C, 0x007D050C)
    asm_u32_arch(0xBC7C0000, 0xBBFD0000) // s_waitcnt_vscnt null, 0
    asm_u32_arch(0xBFB00000, 0xBF810000) // s_endpgm

    uint64 total_dwords = asm_text_len / 4
    uint64 simm16 = total_dwords - cbranch_dword_idx - 2
    uint64 sccbr_top = 0xBFA20000
    if _is_gfx10() != 0 { sccbr_top = 0xBF850000 }
    asm_patch_u32(cbranch_dword_idx, sccbr_top | (simm16 & 0xFFFF))

    uint64 a0 = args_desc + 0;   unsafe { *(a0 as uint64) = 8 }
    uint64 a1 = args_desc + 8;   unsafe { *(a1 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a2 = args_desc + 16;  unsafe { *(a2 as uint64) = 8 }
    uint64 a3 = args_desc + 24;  unsafe { *(a3 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a4 = args_desc + 32;  unsafe { *(a4 as uint64) = 8 }
    uint64 a5 = args_desc + 40;  unsafe { *(a5 as uint64) = AMD_ARG_KIND_BY_VALUE }
    uint64 a6 = args_desc + 48;  unsafe { *(a6 as uint64) = 8 }
    uint64 a7 = args_desc + 56;  unsafe { *(a7 as uint64) = AMD_ARG_KIND_BY_VALUE }
}

// Thread-coarsened softmax body for N > 1024.  Same template as
// softmax_causal large-N but without the per-chunk causal mask.
fn _emit_softmax_f32_body_NL(uint64 args_desc, uint64 N) {
    asm_init()
    uint64 K = (N + 1023) / 1024
    uint64 last_chunk_size = N - (K - 1) * 1024
    uint64 last_partial = 0
    if last_chunk_size != 1024 { last_partial = 1 }

    asm_u32(0xF40C0100); asm_u32(0xF8000000)
    asm_u32(0xBF89FC07)
    asm_u32(0xBF09080F)
    uint64 cbranch_dword_idx = asm_text_len / 4
    asm_u32(0xBFA20000)
    asm_u32(0x960C0A0F)
    asm_u32(0x4A02000C)
    asm_u32(0x30080282)
    _emit_vpair_build_from_sbase(2, 4, 4)
    _emit_vpair_build_from_sbase(12, 6, 4)
    asm_u32(0x300C0082); asm_u32(0x7E120280)
    asm_u32(0x7E0A02FF); asm_u32(0xFF800000)   // v5 = -inf

    // PASS 1: max-reduce (no causal mask)
    uint64 c = 0
    while c < K {
        if c > 0 { _emit_vpair_add_imm(2, 4096) }
        if c == K - 1 && last_partial != 0 {
            asm_u32(0xBE8C00FF); asm_u32(last_chunk_size)
            _emit_gated_load_v10(12, 12, 0xFF800000)
        } else {
            asm_u32(0xDC520000); asm_u32(0x0A7C0002)
            asm_u32(0xBF8903F7)
        }
        asm_u32(0x200A1505)             // v_max_f32 v5, v5, v10
        c = c + 1
    }
    asm_u32(0xD8340000); asm_u32(0x00000506)
    asm_u32(0xBF89FC07); asm_u32(0xBFBD0000)
    _emit_lds_reduce_pow2(1024, 0x200A0F05, 12)

    asm_u32(0xD8D80000); asm_u32(0x08000009)
    asm_u32(0xBF89FC07)
    asm_u32(0x7E260308)             // v19 = v8 (save max)
    asm_u32(0xBFBD0000)
    _emit_vpair_build_from_sbase(2, 4, 4)
    asm_u32(0x7E0A0280)             // v5 = 0 for sum

    // PASS 2: sum-of-exp
    c = 0
    while c < K {
        if c > 0 { _emit_vpair_add_imm(2, 4096) }
        if c == K - 1 && last_partial != 0 {
            asm_u32(0xBE8C00FF); asm_u32(last_chunk_size)
            _emit_gated_load_v10(12, 12, 0xFF800000)
        } else {
            asm_u32(0xDC520000); asm_u32(0x0A7C0002)
            asm_u32(0xBF8903F7)
        }
        asm_u32(0x0816270A)             // diff = v10 - v19
        asm_u32(0xBE8C00FF); asm_u32(0x3FB8AA3B)
        asm_u32(0x1016160C)             // v11 *= log2e
        asm_u32(0x7E164B0B)             // v11 = exp(v11)
        asm_u32(0x060A1705)             // v5 += v11
        c = c + 1
    }
    asm_u32(0xD8340000); asm_u32(0x00000506)
    asm_u32(0xBF89FC07); asm_u32(0xBFBD0000)
    _emit_lds_reduce_pow2(1024, 0x060A0F05, 12)

    asm_u32(0xD8D80000); asm_u32(0x08000009)
    asm_u32(0xBF89FC07)
    asm_u32(0x7E105508)             // v_rcp_f32 v8, v8 (inv_sum)

    _emit_vpair_build_from_sbase(2, 4, 4)
    _emit_vpair_build_from_sbase(12, 6, 4)

    // PASS 3: apply
    c = 0
    while c < K {
        if c > 0 {
            _emit_vpair_add_imm(2, 4096)
            _emit_vpair_add_imm(12, 4096)
        }
        if c == K - 1 && last_partial != 0 {
            asm_u32(0xBE8C00FF); asm_u32(last_chunk_size)
            _emit_gated_load_v10(12, 12, 0xFF800000)
        } else {
            asm_u32(0xDC520000); asm_u32(0x0A7C0002)
            asm_u32(0xBF8903F7)
        }
        asm_u32(0x0816270A)             // diff
        asm_u32(0xBE8C00FF); asm_u32(0x3FB8AA3B)
        asm_u32(0x1016160C)
        asm_u32(0x7E164B0B)
        asm_u32(0x100A110B)             // out = e * inv_sum
        if c == K - 1 && last_partial != 0 {
            asm_u32(0xBE8C00FF); asm_u32(last_chunk_size)
            _emit_store_gate(12, 12)
        }
        asm_u32(0xDC6A0000); asm_u32(0x007C050C)
        c = c + 1
    }

    asm_u32(0xBC7C0000); asm_u32(0xBFB00000)

    uint64 total_dwords = asm_text_len / 4
    uint64 simm16 = total_dwords - cbranch_dword_idx - 2
    asm_patch_u32(cbranch_dword_idx, 0xBFA20000 | (simm16 & 0xFFFF))

    uint64 a0 = args_desc + 0;   unsafe { *(a0 as uint64) = 8 }
    uint64 a1 = args_desc + 8;   unsafe { *(a1 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a2 = args_desc + 16;  unsafe { *(a2 as uint64) = 8 }
    uint64 a3 = args_desc + 24;  unsafe { *(a3 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a4 = args_desc + 32;  unsafe { *(a4 as uint64) = 8 }
    uint64 a5 = args_desc + 40;  unsafe { *(a5 as uint64) = AMD_ARG_KIND_BY_VALUE }
    uint64 a6 = args_desc + 48;  unsafe { *(a6 as uint64) = 8 }
    uint64 a7 = args_desc + 56;  unsafe { *(a7 as uint64) = AMD_ARG_KIND_BY_VALUE }
}

@export
fn emit_amdgpu_softmax_f32_N_blob(uint64 out_path, uint64 N) -> uint64 {
    if N < 32 || N > 8192 {
        write(2, "emit_amdgpu_softmax_f32_N_blob: N must be in [32, 8192]\n", 56)
        return 1
    }
    uint64[8] args_desc
    uint64 lds_bytes = 0
    if N <= 1024 {
        _emit_softmax_f32_body_N(args_desc, N)
        uint64 Np = _round_up_pow2(N)
        lds_bytes = Np * 4
    } else {
        _emit_softmax_f32_body_NL(args_desc, N)
        lds_bytes = 4096
    }
    uint64 rsrc1 = 0xE0AF0001
    if N > 1024 { rsrc1 = 0xE0AF0002 }
    uint64 size = emit_amdgpu_code_object_lds("softmax_f32", 11,
                                               asm_text_buf, asm_text_len,
                                               32, 8, 16, 20,
                                               rsrc1, 0x0000009E, 0x00000010, 0x0408,
                                               args_desc, 4,
                                               lds_bytes)
    uint64 fd = file_open(out_path, 1)
    if fd > 0xFFFFFFFFFFFFF000 {
        write(2, "emit_amdgpu_softmax_f32_N_blob: cannot open output\n", 52)
        return 1
    }
    file_write(fd, amd_buf, size)
    file_close(fd)
    return 0
}



// Shape-parametric layernorm_f32. N must be a power of two in [32, 1024].
// Same kernel structure as _emit_layernorm_f32_body with the LDS
// reductions parameterised by log2(N) and the two `1/N` constants
// computed from N at emit time.  No gamma/beta (output =
// (x - mean) / sqrt(var + eps), eps = 1e-5).
fn _emit_layernorm_f32_body_N(uint64 args_desc, uint64 N) {
    asm_init()
    uint64 Np = _round_up_pow2(N)
    uint64 inv_n_bits = _f32_bits_recip(N)

    // ── Prologue ────────────────────────────────────────────────────
    asm_u32_arch(0xF40C0100, 0xF40C0100) // s_load_b256/dwordx8 s[4:11], s[0:1], 0x0
    asm_u32_arch(0xF8000000, 0xFA000000)
    asm_u32_arch(0xBF89FC07, 0xBF8CC07F) // s_waitcnt
    asm_u32     (0xBF09080F)             // s_cmp_ge_u32 s15, s8 (SOPC stable)
    uint64 cbranch_dword_idx = asm_text_len / 4
    asm_u32_arch(0xBFA20000, 0xBF850000) // s_cbranch_scc1 (patched)
    asm_u32_arch(0x960C0A0F, 0x930C0A0F) // s_mul_i32 s12, s15, s10
    asm_u32     (0x4A02000C)             // v_add_nc_u32 v1, s12, v0
    asm_u32_arch(0x30080282, 0x34080282) // v_lshlrev_b32 v4, 2, v1
    asm_u32     (0x7E060280)
    asm_u32_arch(0xD7006A02, 0xD70F6A02)
    asm_u32     (0x00020804)
    asm_u32_arch(0xD5207C03, 0xD5287D03)
    asm_u32     (0x01AA0605)
    asm_u32     (0x7E1A0280)
    asm_u32_arch(0xD7006A0C, 0xD70F6A0C)
    asm_u32     (0x00020806)
    asm_u32_arch(0xD5207C0D, 0xD5287D0D)
    asm_u32     (0x01AA1A07)
    if N != Np {
        _emit_gated_load_v10(12, 10, 0x00000000)
    } else {
        asm_u32_arch(0xDC520000, 0xDC308000) // global_load_b32 v10, v[2:3], off
        asm_u32_arch(0x0A7C0002, 0x0A7D0002)
        asm_u32_arch(0xBF8903F7, 0xBF8C3F70)
    }
    asm_u32     (0x7E0A030A)             // v5 = x
    asm_u32_arch(0x300C0082, 0x340C0082) // v6 = lane*4
    asm_u32     (0x7E120280)
    asm_u32     (0xD8340000)             // ds_store v6, v5 (DS stable)
    asm_u32     (0x00000506)
    asm_u32_arch(0xBF89FC07, 0xBF8CC07F)
    asm_u32_arch(0xBFBD0000, 0xBF8A0000) // s_barrier

    // ── Phase A: sum-reduce x ───────────────────────────────────────
    _emit_lds_reduce_pow2(Np, 0x060A0F05, 12)

    // ── Mid ─────────────────────────────────────────────────────────
    asm_u32     (0xD8D80000)
    asm_u32     (0x08000009)
    asm_u32_arch(0xBF89FC07, 0xBF8CC07F)
    asm_u32_arch(0xBE8C00FF, 0xBE8C03FF) // s_mov_b32 s12, lit
    asm_u32     (inv_n_bits)
    asm_u32     (0x1010100C)             // v_mul_f32 v8, s12, v8
    asm_u32     (0x0816110A)             // v_sub_f32 v11, v10, v8
    asm_u32     (0x100A170B)             // v_mul_f32 v5, v11, v11
    if N != Np { _emit_identity_fill_v5(12, 10, 0x00000000) }
    asm_u32_arch(0xBFBD0000, 0xBF8A0000) // s_barrier
    asm_u32     (0xD8340000)
    asm_u32     (0x00000506)
    asm_u32_arch(0xBF89FC07, 0xBF8CC07F)
    asm_u32_arch(0xBFBD0000, 0xBF8A0000) // s_barrier

    // ── Phase B: sum-reduce diff² ───────────────────────────────────
    _emit_lds_reduce_pow2(Np, 0x060A0F05, 12)

    // ── Finalize ────────────────────────────────────────────────────
    asm_u32     (0xD8D80000)
    asm_u32     (0x08000009)
    asm_u32_arch(0xBF89FC07, 0xBF8CC07F)
    asm_u32_arch(0xBE8C00FF, 0xBE8C03FF)
    asm_u32     (inv_n_bits)
    asm_u32     (0x1010100C)             // v_mul_f32 v8, s12, v8 (var)
    asm_u32_arch(0xBE8C00FF, 0xBE8C03FF)
    asm_u32     (0x3727C5AC)             // eps
    asm_u32     (0x0610100C)             // v_add_f32 v8, s12, v8
    asm_u32     (0x7E105D08)             // v_rsq_f32 v8, v8 (VOP1 stable)
    asm_u32     (0x100A110B)             // v_mul_f32 v5, v11, v8
    if N != Np { _emit_store_gate(12, 10) }
    asm_u32_arch(0xDC6A0000, 0xDC708000)
    asm_u32_arch(0x007C050C, 0x007D050C)
    asm_u32_arch(0xBC7C0000, 0xBBFD0000)
    asm_u32_arch(0xBFB00000, 0xBF810000)

    uint64 total_dwords = asm_text_len / 4
    uint64 simm16 = total_dwords - cbranch_dword_idx - 2
    uint64 sccbr_top = 0xBFA20000
    if _is_gfx10() != 0 { sccbr_top = 0xBF850000 }
    asm_patch_u32(cbranch_dword_idx, sccbr_top | (simm16 & 0xFFFF))

    uint64 a0 = args_desc + 0;   unsafe { *(a0 as uint64) = 8 }
    uint64 a1 = args_desc + 8;   unsafe { *(a1 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a2 = args_desc + 16;  unsafe { *(a2 as uint64) = 8 }
    uint64 a3 = args_desc + 24;  unsafe { *(a3 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a4 = args_desc + 32;  unsafe { *(a4 as uint64) = 8 }
    uint64 a5 = args_desc + 40;  unsafe { *(a5 as uint64) = AMD_ARG_KIND_BY_VALUE }
    uint64 a6 = args_desc + 48;  unsafe { *(a6 as uint64) = 8 }
    uint64 a7 = args_desc + 56;  unsafe { *(a7 as uint64) = AMD_ARG_KIND_BY_VALUE }
}

// Thread-coarsened layernorm body for N > 1024. Three passes (sum-of-x,
// sum-of-(x-mean)², apply). Padding lanes in PASS 2 must contribute 0
// to variance — gated load defaults v10 = 0, then `diff = -mean`
// pollutes if not zeroed; we cndmask v11 (= diff) to 0 for padding
// lanes before the diff² accumulate via v_fmac.
fn _emit_layernorm_f32_body_NL(uint64 args_desc, uint64 N) {
    asm_init()
    uint64 K = (N + 1023) / 1024
    uint64 last_chunk_size = N - (K - 1) * 1024
    uint64 last_partial = 0
    if last_chunk_size != 1024 { last_partial = 1 }
    uint64 inv_n_bits = _f32_bits_recip(N)

    // ── Prologue ────────────────────────────────────────────────────
    asm_u32(0xF40C0100); asm_u32(0xF8000000)
    asm_u32(0xBF89FC07)
    asm_u32(0xBF09080F)
    uint64 cbranch_dword_idx = asm_text_len / 4
    asm_u32(0xBFA20000)
    asm_u32(0x960C0A0F)             // s_mul_i32 s12, s15, s10
    asm_u32(0x4A02000C)
    asm_u32(0x30080282)
    _emit_vpair_build_from_sbase(2, 4, 4)
    _emit_vpair_build_from_sbase(12, 6, 4)
    asm_u32(0x300C0082); asm_u32(0x7E120280)
    asm_u32(0x7E0A0280)             // v5 = 0

    // ── PASS 1: sum-of-x ────────────────────────────────────────────
    uint64 c = 0
    while c < K {
        if c > 0 { _emit_vpair_add_imm(2, 4096) }
        if c == K - 1 && last_partial != 0 {
            asm_u32(0xBE8C00FF); asm_u32(last_chunk_size)
            _emit_gated_load_v10(12, 12, 0x00000000)
        } else {
            asm_u32(0xDC520000); asm_u32(0x0A7C0002)
            asm_u32(0xBF8903F7)
        }
        asm_u32(0x060A1505)             // v_add_f32 v5, v5, v10
        c = c + 1
    }
    asm_u32(0xD8340000); asm_u32(0x00000506)
    asm_u32(0xBF89FC07); asm_u32(0xBFBD0000)
    _emit_lds_reduce_pow2(1024, 0x060A0F05, 12)

    asm_u32(0xD8D80000); asm_u32(0x08000009)
    asm_u32(0xBF89FC07)
    asm_u32(0xBE8C00FF); asm_u32(inv_n_bits)
    asm_u32(0x1010100C)             // v_mul_f32 v8, s12, v8 (mean)
    asm_u32(0x7E260308)             // v19 = v8 (save mean)
    asm_u32(0xBFBD0000)
    _emit_vpair_build_from_sbase(2, 4, 4)
    asm_u32(0x7E0A0280)             // v5 = 0

    // ── PASS 2: sum-of-(x - mean)² ──────────────────────────────────
    c = 0
    while c < K {
        if c > 0 { _emit_vpair_add_imm(2, 4096) }
        if c == K - 1 && last_partial != 0 {
            asm_u32(0xBE8C00FF); asm_u32(last_chunk_size)
            _emit_gated_load_v10(12, 12, 0x00000000)
        } else {
            asm_u32(0xDC520000); asm_u32(0x0A7C0002)
            asm_u32(0xBF8903F7)
        }
        asm_u32(0x0816270A)             // v11 = v10 - v19 (diff)
        if c == K - 1 && last_partial != 0 {
            // Zero out v11 for padding lanes (lane >= last_chunk_size).
            // gated_load clobbered s12 with old-exec; re-load the
            // last_chunk_size into s12 so the comparison is correct.
            asm_u32(0xBE8C00FF); asm_u32(last_chunk_size)
            asm_u32(0xD449000C); asm_u32(0x00001900)   // v_cmp_lt_u32_e64 s12, v0, s12
            asm_u32(0xD501000B); asm_u32(0x00321680)   // v_cndmask v11, 0, v11, s12
        }
        // v_fmac_f32 v5, v11, v11  (v5 += v11²)
        asm_u32(0x560A170B)
        c = c + 1
    }
    asm_u32(0xD8340000); asm_u32(0x00000506)
    asm_u32(0xBF89FC07); asm_u32(0xBFBD0000)
    _emit_lds_reduce_pow2(1024, 0x060A0F05, 12)

    asm_u32(0xD8D80000); asm_u32(0x08000009)
    asm_u32(0xBF89FC07)
    asm_u32(0xBE8C00FF); asm_u32(inv_n_bits)
    asm_u32(0x1010100C)             // v_mul_f32 v8, s12, v8 (variance)
    asm_u32(0xBE8C00FF); asm_u32(0x3727C5AC)   // eps
    asm_u32(0x0610100C)             // v_add_f32 v8, s12, v8 (var+eps)
    asm_u32(0x7E105D08)             // v_rsq_f32 v8, v8 (inv_stddev)

    _emit_vpair_build_from_sbase(2, 4, 4)
    _emit_vpair_build_from_sbase(12, 6, 4)

    // ── PASS 3: apply (out = (x - mean) * inv_stddev) ──────────────
    c = 0
    while c < K {
        if c > 0 {
            _emit_vpair_add_imm(2, 4096)
            _emit_vpair_add_imm(12, 4096)
        }
        if c == K - 1 && last_partial != 0 {
            asm_u32(0xBE8C00FF); asm_u32(last_chunk_size)
            _emit_gated_load_v10(12, 12, 0x00000000)
        } else {
            asm_u32(0xDC520000); asm_u32(0x0A7C0002)
            asm_u32(0xBF8903F7)
        }
        asm_u32(0x0816270A)             // v11 = v10 - v19 (diff)
        asm_u32(0x100A110B)             // v_mul_f32 v5, v11, v8 (out)
        if c == K - 1 && last_partial != 0 {
            asm_u32(0xBE8C00FF); asm_u32(last_chunk_size)
            _emit_store_gate(12, 12)
        }
        asm_u32(0xDC6A0000); asm_u32(0x007C050C)
        c = c + 1
    }

    asm_u32(0xBC7C0000); asm_u32(0xBFB00000)

    uint64 total_dwords = asm_text_len / 4
    uint64 simm16 = total_dwords - cbranch_dword_idx - 2
    asm_patch_u32(cbranch_dword_idx, 0xBFA20000 | (simm16 & 0xFFFF))

    uint64 a0 = args_desc + 0;   unsafe { *(a0 as uint64) = 8 }
    uint64 a1 = args_desc + 8;   unsafe { *(a1 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a2 = args_desc + 16;  unsafe { *(a2 as uint64) = 8 }
    uint64 a3 = args_desc + 24;  unsafe { *(a3 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a4 = args_desc + 32;  unsafe { *(a4 as uint64) = 8 }
    uint64 a5 = args_desc + 40;  unsafe { *(a5 as uint64) = AMD_ARG_KIND_BY_VALUE }
    uint64 a6 = args_desc + 48;  unsafe { *(a6 as uint64) = 8 }
    uint64 a7 = args_desc + 56;  unsafe { *(a7 as uint64) = AMD_ARG_KIND_BY_VALUE }
}

@export
fn emit_amdgpu_layernorm_f32_N_blob(uint64 out_path, uint64 N) -> uint64 {
    if N < 32 || N > 8192 {
        write(2, "emit_amdgpu_layernorm_f32_N_blob: N must be in [32, 8192]\n", 58)
        return 1
    }
    uint64[8] args_desc
    uint64 lds_bytes = 0
    if N <= 1024 {
        _emit_layernorm_f32_body_N(args_desc, N)
        uint64 Np = _round_up_pow2(N)
        lds_bytes = Np * 4
    } else {
        _emit_layernorm_f32_body_NL(args_desc, N)
        lds_bytes = 4096
    }
    uint64 rsrc1 = 0xE0AF0001
    if N > 1024 { rsrc1 = 0xE0AF0002 }
    uint64 size = emit_amdgpu_code_object_lds("layernorm_f32", 13,
                                               asm_text_buf, asm_text_len,
                                               32, 8, 16, 20,
                                               rsrc1, 0x0000009E, 0x00000010, 0x0408,
                                               args_desc, 4,
                                               lds_bytes)
    uint64 fd = file_open(out_path, 1)
    if fd > 0xFFFFFFFFFFFFF000 {
        write(2, "emit_amdgpu_layernorm_f32_N_blob: cannot open output\n", 54)
        return 1
    }
    file_write(fd, amd_buf, size)
    file_close(fd)
    return 0
}

// rmsnorm_f32 (N=256 hardcoded): emitted by Phase 3b
// (`amdgpu_lower_rmsnorm_f32_3b`) from examples/llm/rmsnorm_f32.mlr.
// Hand-emit body deleted — AST-walker produces byte-identical ISA.
// Production rmsnorm_f32_1024 / _5120 still come from the parametric
// `_emit_rmsnorm_f32_body_N` path below.

// Shape-parametric rmsnorm_f32. N in [32, 1024] (any value, not just
// power of two). For non-pow2 N, the LDS reduction tree runs at depth
// log2(round_up_pow2(N)); padding lanes are identity-filled (0 for
// sum-of-x²) at load time and gated out at the final store.
// out_i = x_i * rsqrt(mean(x²) + eps) * gamma_i (gamma is row-shared).
// Saved-exec SGPR is s14 (s12/s13 hold `n` from the second kernarg load).
// Block size at launch must be Np = round_up_pow2(N).
fn _emit_rmsnorm_f32_body_N(uint64 args_desc, uint64 N) {
    _emit_rmsnorm_f32_body_N_eps(args_desc, N, 0x3727C5AC)
}

// Same as _emit_rmsnorm_f32_body_N but with a caller-chosen eps literal
// (f32 bits).  Used by qknorm emit (eps = 1e-6 = 0x358637BD) so that
// qknorm output matches Qwen3's CPU reference bit-for-bit.
fn _emit_rmsnorm_f32_body_N_eps(uint64 args_desc, uint64 N, uint64 eps_bits) {
    asm_init()
    uint64 Np = _round_up_pow2(N)
    uint64 inv_n_bits = _f32_bits_recip(N)

    // ── Prologue ────────────────────────────────────────────────────
    // gfx10 dword pairs for SMEM/FLAT NULL re-encode, SOPP/SOP1/SOP2
    // op shifts, and VOP2 v_lshlrev_b32 op shift.
    asm_u32_arch(0xF40C0100, 0xF40C0100) // s_load_b256/dwordx8 s[4:11], s[0:1], 0x0
    asm_u32_arch(0xF8000000, 0xFA000000)
    asm_u32_arch(0xF4040300, 0xF4040300) // s_load_b64/dwordx2 s[12:13], s[0:1], 0x20
    asm_u32_arch(0xF8000020, 0xFA000020)
    asm_u32_arch(0xBF89FC07, 0xBF8CC07F) // s_waitcnt lgkmcnt(0)
    asm_u32     (0xBF090A0F)             // s_cmp_ge_u32 s15, s10  (SOPC stable)
    uint64 cbranch_dword_idx = asm_text_len / 4
    asm_u32_arch(0xBFA20000, 0xBF850000) // s_cbranch_scc1 → .Lend (SOPP op 0x22 → 0x05)
    asm_u32_arch(0x960E0C0F, 0x930E0C0F) // s_mul_i32 s14, s15, s12  (SOP2 op 0x16 → 0x13)
    asm_u32     (0x4A02000E)             // v_add_nc_u32 v1, s14, v0
    asm_u32_arch(0x30080282, 0x34080282) // v_lshlrev_b32 v4, 2, v1
    asm_u32     (0x7E060280)             // v_mov_b32 v3, 0
    asm_u32_arch(0xD7006A02, 0xD70F6A02) // v_add_co_u32 v2, vcc_lo, s4, v4
    asm_u32     (0x00020804)
    asm_u32_arch(0xD5207C03, 0xD5287D03) // v_add_co_ci_u32 v3, null, s5, v3, vcc_lo
    asm_u32     (0x01AA0605)
    asm_u32     (0x7E1A0280)             // v_mov_b32 v13, 0
    asm_u32_arch(0xD7006A0C, 0xD70F6A0C) // v_add_co_u32 v12, vcc_lo, s6, v4
    asm_u32     (0x00020806)
    asm_u32_arch(0xD5207C0D, 0xD5287D0D) // v_add_co_ci_u32 v13, null, s7, v13, vcc_lo
    asm_u32     (0x01AA1A07)
    if N != Np {
        _emit_gated_load_v10(14, 12, 0x00000000)
    } else {
        asm_u32_arch(0xDC520000, 0xDC308000) // global_load v10, x
        asm_u32_arch(0x0A7C0002, 0x0A7D0002)
        asm_u32_arch(0xBF8903F7, 0xBF8C3F70) // s_waitcnt vmcnt(0)
    }

    asm_u32_arch(0x30040082, 0x34040082) // v_lshlrev_b32 v2, 2, v0  (gamma offset)
    asm_u32     (0x7E060280)             // v_mov_b32 v3, 0
    asm_u32_arch(0xD7006A02, 0xD70F6A02) // v_add_co_u32 v2, vcc_lo, s8, v2
    asm_u32     (0x00020408)
    asm_u32_arch(0xD5207C03, 0xD5287D03) // v_add_co_ci_u32 v3, null, s9, v3, vcc_lo
    asm_u32     (0x01AA0609)
    asm_u32_arch(0xDC520000, 0xDC308000) // global_load v11, gamma
    asm_u32_arch(0x0B7C0002, 0x0B7D0002)
    asm_u32_arch(0xBF8903F7, 0xBF8C3F70) // s_waitcnt vmcnt(0)

    asm_u32     (0x100A150A)             // v_mul_f32 v5, v10, v10
    asm_u32_arch(0x300C0082, 0x340C0082) // v6 = lane*4
    asm_u32     (0x7E120280)             // v_mov_b32 v9, 0
    asm_u32     (0xD8340000)             // ds_store v6, v5  (DS stable)
    asm_u32     (0x00000506)
    asm_u32_arch(0xBF89FC07, 0xBF8CC07F) // s_waitcnt lgkmcnt(0)
    asm_u32_arch(0xBFBD0000, 0xBF8A0000) // s_barrier  (SOPP op 0x3D → 0x0A)

    // ── Sum-reduce x² over Np lanes (pow2 reduction) ────────────────
    _emit_lds_reduce_pow2(Np, 0x060A0F05, 14)

    // ── Finalize ────────────────────────────────────────────────────
    asm_u32     (0xD8D80000)             // ds_load v8, v9
    asm_u32     (0x08000009)
    asm_u32_arch(0xBF89FC07, 0xBF8CC07F) // s_waitcnt lgkmcnt(0)
    asm_u32_arch(0xBE8E00FF, 0xBE8E03FF) // s_mov_b32 s14, lit  (SOP1 imm op 0x00 → 0x03)
    asm_u32     (inv_n_bits)
    asm_u32     (0x1010100E)             // v_mul_f32 v8, s14, v8
    asm_u32_arch(0xBE8E00FF, 0xBE8E03FF) // s_mov_b32 s14, lit
    asm_u32     (eps_bits)
    asm_u32     (0x0610100E)             // v_add_f32 v8, s14, v8
    asm_u32     (0x7E105D08)             // v_rsq_f32 v8, v8  (VOP1 stable)
    asm_u32     (0x100A110A)             // v_mul_f32 v5, v10, v8
    asm_u32     (0x100A1705)             // v_mul_f32 v5, v5, v11
    if N != Np { _emit_store_gate(14, 12) }
    asm_u32_arch(0xDC6A0000, 0xDC708000) // global_store_b32/dword v[12:13], v5, off
    asm_u32_arch(0x007C050C, 0x007D050C)
    asm_u32_arch(0xBC7C0000, 0xBBFD0000) // s_waitcnt_vscnt null, 0
    asm_u32_arch(0xBFB00000, 0xBF810000) // s_endpgm

    uint64 total_dwords = asm_text_len / 4
    uint64 simm16 = total_dwords - cbranch_dword_idx - 2
    uint64 sccbr_top = 0xBFA20000
    if _is_gfx10() != 0 { sccbr_top = 0xBF850000 }
    asm_patch_u32(cbranch_dword_idx, sccbr_top | (simm16 & 0xFFFF))

    uint64 a0 = args_desc + 0;   unsafe { *(a0 as uint64) = 8 }
    uint64 a1 = args_desc + 8;   unsafe { *(a1 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a2 = args_desc + 16;  unsafe { *(a2 as uint64) = 8 }
    uint64 a3 = args_desc + 24;  unsafe { *(a3 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a4 = args_desc + 32;  unsafe { *(a4 as uint64) = 8 }
    uint64 a5 = args_desc + 40;  unsafe { *(a5 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a6 = args_desc + 48;  unsafe { *(a6 as uint64) = 8 }
    uint64 a7 = args_desc + 56;  unsafe { *(a7 as uint64) = AMD_ARG_KIND_BY_VALUE }
    uint64 a8 = args_desc + 64;  unsafe { *(a8 as uint64) = 8 }
    uint64 a9 = args_desc + 72;  unsafe { *(a9 as uint64) = AMD_ARG_KIND_BY_VALUE }
}

// Slice 2b — fused residual_add + rmsnorm.  Same body as
// _emit_rmsnorm_f32_body_N_eps but with two extra kernarg slots
// (in_b, out_resid) at offset 0x28 / 0x30 and a 14-instruction
// prologue inserted right after `v10 = global_load(in_a[idx])`:
//
//   v10 = a[idx]                  (existing rmsnorm load)
//   v8  = b[idx]                  (NEW)
//   v10 = v10 + v8                (NEW)
//   *out_resid[idx] = v10         (NEW; residual side-output)
//   ... rmsnorm body continues with v10 as the post-residual `x`
//
// Kernarg layout (so s4..s13 keep the existing rmsnorm SGPR
// assignments and the rmsnorm body emits unchanged):
//   0x00  in_a       (s4..5)
//   0x08  out_norm   (s6..7)   — placed at the rmsnorm 'out' slot
//   0x10  gamma      (s8..9)
//   0x18  m          (s10)
//   0x20  n          (s12)
//   0x28  in_b       (s16..17) — NEW
//   0x30  out_resid  (s18..19) — NEW
//
// VGPRs unchanged from rmsnorm.  v8 is reused for the residual-`b`
// load (its later rmsnorm use is the LDS reduce broadcast, after
// the prologue is done).  v[14:15] / v[16:17] are scratch addr regs
// for in_b / out_resid; both ranges are unused by the rmsnorm body.
// rsrc1 sgprs field bumped from 0 to 1 (32 SGPRs grant) to admit
// s16..s19.  Every dword below is llvm-mc verified for gfx1100.
fn _emit_residual_rmsnorm_f32_body_N_eps(uint64 args_desc, uint64 N, uint64 eps_bits) {
    asm_init()
    uint64 Np = _round_up_pow2(N)
    uint64 inv_n_bits = _f32_bits_recip(N)

    // Kernarg loads: identical to rmsnorm's first two SMEM loads.
    asm_u32_arch(0xF40C0100, 0xF40C0100) // s_load_b256 s[4:11], s[0:1], 0x0
    asm_u32_arch(0xF8000000, 0xFA000000)
    asm_u32_arch(0xF4040300, 0xF4040300) // s_load_b64 s[12:13], s[0:1], 0x20
    asm_u32_arch(0xF8000020, 0xFA000020)
    // NEW kernarg loads: in_b → s[16:17], out_resid → s[18:19].
    asm_u32_arch(0xF4040400, 0xF4040400) // s_load_b64 s[16:17], s[0:1], 0x28
    asm_u32_arch(0xF8000028, 0xFA000028)
    asm_u32_arch(0xF4040480, 0xF4040480) // s_load_b64 s[18:19], s[0:1], 0x30
    asm_u32_arch(0xF8000030, 0xFA000030)
    asm_u32_arch(0xBF89FC07, 0xBF8CC07F) // s_waitcnt lgkmcnt(0)
    asm_u32     (0xBF090A0F)             // s_cmp_ge_u32 s15, s10
    uint64 cbranch_dword_idx = asm_text_len / 4
    asm_u32_arch(0xBFA20000, 0xBF850000) // s_cbranch_scc1 → .Lend
    asm_u32_arch(0x960E0C0F, 0x930E0C0F) // s_mul_i32 s14, s15, s12
    asm_u32     (0x4A02000E)             // v_add_nc_u32 v1, s14, v0
    asm_u32_arch(0x30080282, 0x34080282) // v_lshlrev_b32 v4, 2, v1
    asm_u32     (0x7E060280)             // v_mov_b32 v3, 0
    asm_u32_arch(0xD7006A02, 0xD70F6A02) // v_add_co_u32 v2, vcc_lo, s4, v4
    asm_u32     (0x00020804)
    asm_u32_arch(0xD5207C03, 0xD5287D03) // v_add_co_ci_u32 v3, null, s5, v3, vcc_lo
    asm_u32     (0x01AA0605)
    asm_u32     (0x7E1A0280)             // v_mov_b32 v13, 0
    asm_u32_arch(0xD7006A0C, 0xD70F6A0C) // v_add_co_u32 v12, vcc_lo, s6, v4
    asm_u32     (0x00020806)
    asm_u32_arch(0xD5207C0D, 0xD5287D0D) // v_add_co_ci_u32 v13, null, s7, v13, vcc_lo
    asm_u32     (0x01AA1A07)
    if N != Np {
        _emit_gated_load_v10(14, 12, 0x00000000)
    } else {
        asm_u32_arch(0xDC520000, 0xDC308000) // global_load v10, x
        asm_u32_arch(0x0A7C0002, 0x0A7D0002)
        asm_u32_arch(0xBF8903F7, 0xBF8C3F70) // s_waitcnt vmcnt(0)
    }

    // ── Residual prologue (NEW) ────────────────────────────────────
    // v[14:15] = in_b + (lane * 4); v[16:17] = out_resid + (lane * 4).
    asm_u32     (0x7E1E0280)             // v_mov_b32 v15, 0
    asm_u32_arch(0xD7006A0E, 0xD70F6A0E) // v_add_co_u32 v14, vcc_lo, s16, v4
    asm_u32     (0x00020810)
    asm_u32_arch(0xD5207C0F, 0xD5287D0F) // v_add_co_ci_u32 v15, null, s17, v15, vcc_lo
    asm_u32     (0x01AA1E11)
    asm_u32_arch(0xDC520000, 0xDC308000) // global_load v8, v[14:15]
    asm_u32_arch(0x087C000E, 0x087D000E)
    asm_u32_arch(0xBF8903F7, 0xBF8C3F70) // s_waitcnt vmcnt(0)
    asm_u32     (0x0614110A)             // v_add_f32 v10, v10, v8  (v10 = a + b)
    asm_u32     (0x7E220280)             // v_mov_b32 v17, 0
    asm_u32_arch(0xD7006A10, 0xD70F6A10) // v_add_co_u32 v16, vcc_lo, s18, v4
    asm_u32     (0x00020812)
    asm_u32_arch(0xD5207C11, 0xD5287D11) // v_add_co_ci_u32 v17, null, s19, v17, vcc_lo
    asm_u32     (0x01AA2213)
    asm_u32_arch(0xDC6A0000, 0xDC708000) // global_store v[16:17], v10
    asm_u32_arch(0x007C0A10, 0x007D0A10)

    // ── rmsnorm body (unchanged) ───────────────────────────────────
    asm_u32_arch(0x30040082, 0x34040082) // v_lshlrev_b32 v2, 2, v0
    asm_u32     (0x7E060280)             // v_mov_b32 v3, 0
    asm_u32_arch(0xD7006A02, 0xD70F6A02) // v_add_co_u32 v2, vcc_lo, s8, v2
    asm_u32     (0x00020408)
    asm_u32_arch(0xD5207C03, 0xD5287D03) // v_add_co_ci_u32 v3, null, s9, v3, vcc_lo
    asm_u32     (0x01AA0609)
    asm_u32_arch(0xDC520000, 0xDC308000) // global_load v11, gamma
    asm_u32_arch(0x0B7C0002, 0x0B7D0002)
    asm_u32_arch(0xBF8903F7, 0xBF8C3F70) // s_waitcnt vmcnt(0)

    asm_u32     (0x100A150A)             // v_mul_f32 v5, v10, v10
    asm_u32_arch(0x300C0082, 0x340C0082) // v6 = lane * 4
    asm_u32     (0x7E120280)             // v_mov_b32 v9, 0
    asm_u32     (0xD8340000)             // ds_store v6, v5
    asm_u32     (0x00000506)
    asm_u32_arch(0xBF89FC07, 0xBF8CC07F) // s_waitcnt lgkmcnt(0)
    asm_u32_arch(0xBFBD0000, 0xBF8A0000) // s_barrier

    _emit_lds_reduce_pow2(Np, 0x060A0F05, 14)

    asm_u32     (0xD8D80000)             // ds_load v8, v9
    asm_u32     (0x08000009)
    asm_u32_arch(0xBF89FC07, 0xBF8CC07F) // s_waitcnt lgkmcnt(0)
    asm_u32_arch(0xBE8E00FF, 0xBE8E03FF) // s_mov_b32 s14, lit (inv_n)
    asm_u32     (inv_n_bits)
    asm_u32     (0x1010100E)             // v_mul_f32 v8, s14, v8
    asm_u32_arch(0xBE8E00FF, 0xBE8E03FF) // s_mov_b32 s14, lit (eps)
    asm_u32     (eps_bits)
    asm_u32     (0x0610100E)             // v_add_f32 v8, s14, v8
    asm_u32     (0x7E105D08)             // v_rsq_f32 v8, v8
    asm_u32     (0x100A110A)             // v_mul_f32 v5, v10, v8
    asm_u32     (0x100A1705)             // v_mul_f32 v5, v5, v11
    if N != Np { _emit_store_gate(14, 12) }
    asm_u32_arch(0xDC6A0000, 0xDC708000) // global_store v[12:13], v5
    asm_u32_arch(0x007C050C, 0x007D050C)
    asm_u32_arch(0xBC7C0000, 0xBBFD0000) // s_waitcnt_vscnt null, 0
    asm_u32_arch(0xBFB00000, 0xBF810000) // s_endpgm

    uint64 total_dwords = asm_text_len / 4
    uint64 simm16 = total_dwords - cbranch_dword_idx - 2
    uint64 sccbr_top = 0xBFA20000
    if _is_gfx10() != 0 { sccbr_top = 0xBF850000 }
    asm_patch_u32(cbranch_dword_idx, sccbr_top | (simm16 & 0xFFFF))

    // 7 args: in_a, in_b, out_resid, out_norm, gamma  (5 buffers) +
    // m, n  (2 by-value).  args_desc layout pairs (size, kind).
    uint64 a0 = args_desc + 0;    unsafe { *(a0 as uint64) = 8 }
    uint64 a1 = args_desc + 8;    unsafe { *(a1 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a2 = args_desc + 16;   unsafe { *(a2 as uint64) = 8 }
    uint64 a3 = args_desc + 24;   unsafe { *(a3 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a4 = args_desc + 32;   unsafe { *(a4 as uint64) = 8 }
    uint64 a5 = args_desc + 40;   unsafe { *(a5 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a6 = args_desc + 48;   unsafe { *(a6 as uint64) = 8 }
    uint64 a7 = args_desc + 56;   unsafe { *(a7 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a8 = args_desc + 64;   unsafe { *(a8 as uint64) = 8 }
    uint64 a9 = args_desc + 72;   unsafe { *(a9 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a10 = args_desc + 80;  unsafe { *(a10 as uint64) = 8 }
    uint64 a11 = args_desc + 88;  unsafe { *(a11 as uint64) = AMD_ARG_KIND_BY_VALUE }
    uint64 a12 = args_desc + 96;  unsafe { *(a12 as uint64) = 8 }
    uint64 a13 = args_desc + 104; unsafe { *(a13 as uint64) = AMD_ARG_KIND_BY_VALUE }
}

// Slice 2c — fused qknorm + rope_qk over Q+K heads in one launch.
//
// Replaces the four per-layer dispatches (qknorm Q, qknorm K, rope Q,
// rope K) with one launch over (n_q_heads + n_kv_heads) WGs.  Saves 3
// launches per qwen3 layer × 28 layers = 84 launches/token.
//
// Two-phase body:
//   Phase 1: rmsnorm at N=128, eps=1e-6 — clones the body of
//            _emit_rmsnorm_f32_body_N_eps but replaces the final
//            global_store with an LDS store (staging for rope).
//   s_barrier
//   Phase 2: lanes 0..63 only.  Read pair (lane, lane+64) from LDS,
//            multiply by cos/sin, store rotated (a*c-b*s, a*s+b*c)
//            back to global at base+(head_in_set*128 + lane | +64)*4.
//
// Per-WG SGPR setup (after kernarg loads + cselects):
//   s3            = wg_id_x stash (preserved through SMEM clobber)
//   s4..s5        = chosen base (q_inout if !is_k else k_inout)
//   s6..s7        = base copy (rmsnorm body uses s6..s7 for "out")
//   s8..s9        = chosen gamma
//   s10           = nh_q + nh_k (M for body's bound check)
//   s12           = 128 (N for body's row-stride)
//   s14           = scratch (rmsnorm's row*N + LDS reduce save_exec)
//   s15           = head_in_set (replaces wg_id_x for body)
//   s20..s21      = cos_ptr (preserved)
//   s22..s23      = sin_ptr (preserved)
//   s24           = nh_q (low 32, for is_k discriminator)
//   s26           = nh_k (unused after total compute)
//
// VGPRs: same as rmsnorm body (v0..v13) plus v14..v17 for cos/sin
// addr-pair build in phase 2, and v18..v21 for cos/sin loads + math.
// rsrc1 bumped to 0xE0AF0042 (24 VGPR / 24 SGPR grant) — same as
// slice 2b's residual_rmsnorm.  rsrc2 = 0x9E (USER_SGPR_COUNT=15,
// WG_ID_X at s15 — we stash to s3 BEFORE the SMEM load that would
// clobber s15).
//
// Every dword below is llvm-mc verified for gfx1100.
fn _emit_qknorm_rope_qk_fused_f32_body(uint64 args_desc) {
    asm_init()
    uint64 N = 128
    uint64 Np = 128
    uint64 inv_n_bits = _f32_bits_recip(N)        // 0x3C000000 = 1/128
    uint64 eps_bits = 0x358637BD                  // f32 bits of 1e-6

    // ── Stash WG_ID_X (s15) into s3 before the second SMEM load
    // (s_load_b128 s[20:23] doesn't clobber s15, but s_load_b256 ABOVE
    // s15 would; here we keep the same pattern as the gemm s15-stash
    // for safety against future kernarg-layout changes).
    asm_u32_arch(0xBE83000F, 0xBE83030F) // s_mov_b32 s3, s15

    // ── Kernarg loads (8 args × 8 bytes = 64 bytes)
    //   0x00..0x1F → s[4:11]   (q_inout, k_inout, q_gamma, k_gamma)
    //   0x20..0x2F → s[20:23]  (cos_ptr, sin_ptr)
    //   0x30..0x3F → s[24:27]  (nh_q, nh_k)
    asm_u32_arch(0xF40C0100, 0xF40C0100) // s_load_b256 s[4:11], s[0:1], 0x0
    asm_u32_arch(0xF8000000, 0xFA000000)
    asm_u32_arch(0xF4080500, 0xF4080500) // s_load_b128 s[20:23], s[0:1], 0x20
    asm_u32_arch(0xF8000020, 0xFA000020)
    asm_u32_arch(0xF4080600, 0xF4080600) // s_load_b128 s[24:27], s[0:1], 0x30
    asm_u32_arch(0xF8000030, 0xFA000030)
    asm_u32_arch(0xBF89FC07, 0xBF8CC07F) // s_waitcnt lgkmcnt(0)

    // ── Compute is_k, head_in_set, chosen base/gamma ─────────────────
    // s2 = head - nh_q  (candidate head_in_set when is_k).  Sets SCC,
    // but we re-set SCC via s_cmp_ge_u32 below before any cselect.
    asm_u32     (0x80821803)             // s_sub_u32 s2, s3, s24
    // SCC = is_k = (head >= nh_q)
    asm_u32     (0xBF091803)             // s_cmp_ge_u32 s3, s24
    // Cselects all read the SCC set above and don't modify it.
    asm_u32     (0x98040406)             // s_cselect_b32 s4, s6, s4   (base_lo)
    asm_u32     (0x98050507)             // s_cselect_b32 s5, s7, s5   (base_hi)
    asm_u32     (0x9808080A)             // s_cselect_b32 s8, s10, s8  (gamma_lo)
    asm_u32     (0x9809090B)             // s_cselect_b32 s9, s11, s9  (gamma_hi)
    asm_u32     (0x980F0302)             // s_cselect_b32 s15, s2, s3  (head_in_set)
    // After cselects, s10/s11 are dead.  Compute s10 = nh_q + nh_k for
    // the rmsnorm body's bound check.  s_add_u32 sets SCC but we no
    // longer need the is_k value.
    asm_u32     (0x800A1A18)             // s_add_u32 s10, s24, s26
    // Copy chosen base into s6:s7 so the rmsnorm body's "out" pointer
    // (which it computes from s6:s7) also points at chosen base.
    asm_u32     (0xBE860004)             // s_mov_b32 s6, s4
    asm_u32     (0xBE870005)             // s_mov_b32 s7, s5
    // s12 = 128 (rmsnorm body's row stride).  s_mov_b32 with 7-bit
    // inline imm: 0x80+n for 0..64, full literal otherwise.  128 doesn't
    // fit in 7-bit inline; use 0xFF SSRC0 + 32-bit literal.
    asm_u32_arch(0xBE8C00FF, 0xBE8C03FF) // s_mov_b32 s12, lit
    asm_u32     (0x00000080)             // 128

    // ── Phase 1: rmsnorm at N=128, eps=1e-6 (cloned from
    //    _emit_rmsnorm_f32_body_N_eps body, lines 9117-9176).
    asm_u32     (0xBF090A0F)             // s_cmp_ge_u32 s15, s10
    uint64 cbranch_dword_idx = asm_text_len / 4
    asm_u32_arch(0xBFA20000, 0xBF850000) // s_cbranch_scc1 → .Lend (patched)
    asm_u32_arch(0x960E0C0F, 0x930E0C0F) // s_mul_i32 s14, s15, s12
    asm_u32     (0x4A02000E)             // v_add_nc_u32 v1, s14, v0
    asm_u32_arch(0x30080282, 0x34080282) // v_lshlrev_b32 v4, 2, v1
    asm_u32     (0x7E060280)             // v_mov_b32 v3, 0
    asm_u32_arch(0xD7006A02, 0xD70F6A02) // v_add_co_u32 v2, vcc_lo, s4, v4
    asm_u32     (0x00020804)
    asm_u32_arch(0xD5207C03, 0xD5287D03) // v_add_co_ci_u32 v3, null, s5, v3, vcc_lo
    asm_u32     (0x01AA0605)
    asm_u32     (0x7E1A0280)             // v_mov_b32 v13, 0
    asm_u32_arch(0xD7006A0C, 0xD70F6A0C) // v_add_co_u32 v12, vcc_lo, s6, v4
    asm_u32     (0x00020806)
    asm_u32_arch(0xD5207C0D, 0xD5287D0D) // v_add_co_ci_u32 v13, null, s7, v13, vcc_lo
    asm_u32     (0x01AA1A07)
    // global_load_b32 v10 from v[2:3]  (N=Np=128, no gating)
    asm_u32_arch(0xDC520000, 0xDC308000) // global_load v10
    asm_u32_arch(0x0A7C0002, 0x0A7D0002)
    asm_u32_arch(0xBF8903F7, 0xBF8C3F70) // s_waitcnt vmcnt(0)

    asm_u32_arch(0x30040082, 0x34040082) // v_lshlrev_b32 v2, 2, v0  (gamma offset)
    asm_u32     (0x7E060280)             // v_mov_b32 v3, 0
    asm_u32_arch(0xD7006A02, 0xD70F6A02) // v_add_co_u32 v2, vcc_lo, s8, v2
    asm_u32     (0x00020408)
    asm_u32_arch(0xD5207C03, 0xD5287D03) // v_add_co_ci_u32 v3, null, s9, v3, vcc_lo
    asm_u32     (0x01AA0609)
    asm_u32_arch(0xDC520000, 0xDC308000) // global_load v11, gamma
    asm_u32_arch(0x0B7C0002, 0x0B7D0002)
    asm_u32_arch(0xBF8903F7, 0xBF8C3F70) // s_waitcnt vmcnt(0)

    asm_u32     (0x100A150A)             // v_mul_f32 v5, v10, v10  (x²)
    asm_u32_arch(0x300C0082, 0x340C0082) // v_lshlrev_b32 v6, 2, v0  (LDS off = lane*4)
    asm_u32     (0x7E120280)             // v_mov_b32 v9, 0          (broadcast read addr)
    asm_u32     (0xD8340000)             // ds_store v6, v5
    asm_u32     (0x00000506)
    asm_u32_arch(0xBF89FC07, 0xBF8CC07F) // s_waitcnt lgkmcnt(0)
    asm_u32_arch(0xBFBD0000, 0xBF8A0000) // s_barrier

    _emit_lds_reduce_pow2(Np, 0x060A0F05, 14)

    asm_u32     (0xD8D80000)             // ds_load v8, v9
    asm_u32     (0x08000009)
    asm_u32_arch(0xBF89FC07, 0xBF8CC07F) // s_waitcnt lgkmcnt(0)
    asm_u32_arch(0xBE8E00FF, 0xBE8E03FF) // s_mov_b32 s14, lit (inv_n)
    asm_u32     (inv_n_bits)
    asm_u32     (0x1010100E)             // v_mul_f32 v8, s14, v8
    asm_u32_arch(0xBE8E00FF, 0xBE8E03FF) // s_mov_b32 s14, lit (eps)
    asm_u32     (eps_bits)
    asm_u32     (0x0610100E)             // v_add_f32 v8, s14, v8
    asm_u32     (0x7E105D08)             // v_rsq_f32 v8, v8
    asm_u32     (0x100A110A)             // v_mul_f32 v5, v10, v8   (x * rrms)
    asm_u32     (0x100A1705)             // v_mul_f32 v5, v5, v11   (× gamma)

    // ── Stage normalised value in LDS (replaces the rmsnorm body's
    //    final global_store).  v6 = lane*4 (still valid from Phase 1
    //    pre-reduce ds_store, because the reduce tree only touches
    //    LDS via v6 with offsets and v9=0 for the broadcast — neither
    //    overwrites v6).
    asm_u32_arch(0xBF89FC07, 0xBF8CC07F) // s_waitcnt lgkmcnt(0)  (drain reduce ds traffic)
    asm_u32     (0xD8340000)             // ds_store v6, v5
    asm_u32     (0x00000506)
    asm_u32_arch(0xBF89FC07, 0xBF8CC07F) // s_waitcnt lgkmcnt(0)
    asm_u32_arch(0xBFBD0000, 0xBF8A0000) // s_barrier

    // ── Phase 2: rope rotation, lanes 0..63 only ─────────────────────
    // exec mask: lanes where v0 < 64.  s14 dead after the rrms compute
    // (held inv_n / eps literals, and the rsqrt result went into v8).
    asm_u32_arch(0xD449000E, 0xD4C1000E) // v_cmp_lt_u32_e64 s14, v0, 64
    asm_u32     (0x00018100)             // src0=v0(0x100), src1=64(0x80+0x40 inline = 0xC0)? let's check
    // (encoding above is the verified probe2 dword: 0x00018100 = src0=v0(0x100),
    //  src1 = 64 (which encodes as inline constant 0x80 + 64 = 0xC0); shifted
    //  src1 << 9 = 0x18000; v0 = 0x100 → low 9 bits = 0x100; total = 0x18100;
    //  bit 16 set for omod0/abs etc. — verified by llvm-mc.)
    asm_u32_arch(0xBE8E200E, 0xBE8E3C0E) // s_and_saveexec_b32 s14, s14

    // ── LDS loads: a = LDS[lane*4], b = LDS[lane*4 + 256] ─────────────
    asm_u32     (0xD8D80000)             // ds_load v7, v6
    asm_u32     (0x07000006)
    asm_u32     (0xD8D80100)             // ds_load v8, v6 offset:256
    asm_u32     (0x08000006)
    asm_u32_arch(0xBF89FC07, 0xBF8CC07F) // s_waitcnt lgkmcnt(0)

    // ── cos/sin global loads at lane*4 offset (v6 still = lane*4). ────
    // v[14:15] = cos_ptr (s20:21) + v6
    asm_u32     (0x7E1E0280)             // v_mov_b32 v15, 0
    asm_u32_arch(0xD7006A0E, 0xD70F6A0E) // v_add_co_u32 v14, vcc_lo, s20, v6
    asm_u32     (0x00020C14)
    asm_u32_arch(0xD5207C0F, 0xD5287D0F) // v_add_co_ci_u32 v15, null, s21, v15, vcc_lo
    asm_u32     (0x01AA1E15)
    // v[16:17] = sin_ptr (s22:23) + v6
    asm_u32     (0x7E220280)             // v_mov_b32 v17, 0
    asm_u32_arch(0xD7006A10, 0xD70F6A10) // v_add_co_u32 v16, vcc_lo, s22, v6
    asm_u32     (0x00020C16)
    asm_u32_arch(0xD5207C11, 0xD5287D11) // v_add_co_ci_u32 v17, null, s23, v17, vcc_lo
    asm_u32     (0x01AA2217)
    asm_u32_arch(0xDC520000, 0xDC308000) // global_load_b32 v18, v[14:15]
    asm_u32_arch(0x127C000E, 0x127D000E)
    asm_u32_arch(0xDC520000, 0xDC308000) // global_load_b32 v19, v[16:17]
    asm_u32_arch(0x137C0010, 0x137D0010)
    asm_u32_arch(0xBF8903F7, 0xBF8C3F70) // s_waitcnt vmcnt(0)

    // ── Rotation math:  ra = a*c - b*s;  rb = a*s + b*c ──────────────
    // a = v7, b = v8, c = v18, s = v19
    asm_u32     (0x10282507)             // v_mul_f32 v20, v7, v18    (a*c)
    asm_u32     (0x102A2708)             // v_mul_f32 v21, v8, v19    (b*s)
    asm_u32     (0x08282B14)             // v_sub_f32 v20, v20, v21   (ra = a*c - b*s)
    asm_u32     (0x102A2707)             // v_mul_f32 v21, v7, v19    (a*s)
    asm_u32     (0x562A2508)             // v_fmac_f32 v21, v8, v18   (rb = a*s + b*c)

    // ── Stores: v[12:13] still = chosen_base + (head_in_set*128 + lane)*4
    //    from Phase 1 (lanes 0..63 had the original v0 = lane id, so
    //    the addr is correct for lane = 0..63).
    asm_u32_arch(0xDC6A0000, 0xDC708000) // global_store_b32 v[12:13], v20, off
    asm_u32_arch(0x007C140C, 0x007D140C)
    asm_u32_arch(0xDC6A0100, 0xDC708100) // global_store_b32 v[12:13], v21, off offset:256
    asm_u32_arch(0x007C150C, 0x007D150C)
    asm_u32_arch(0xBC7C0000, 0xBBFD0000) // s_waitcnt_vscnt null, 0
    asm_u32_arch(0xBFB00000, 0xBF810000) // s_endpgm

    uint64 total_dwords = asm_text_len / 4
    uint64 simm16 = total_dwords - cbranch_dword_idx - 2
    uint64 sccbr_top = 0xBFA20000
    if _is_gfx10() != 0 { sccbr_top = 0xBF850000 }
    asm_patch_u32(cbranch_dword_idx, sccbr_top | (simm16 & 0xFFFF))

    uint64 a0 = args_desc + 0;    unsafe { *(a0 as uint64) = 8 }
    uint64 a1 = args_desc + 8;    unsafe { *(a1 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a2 = args_desc + 16;   unsafe { *(a2 as uint64) = 8 }
    uint64 a3 = args_desc + 24;   unsafe { *(a3 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a4 = args_desc + 32;   unsafe { *(a4 as uint64) = 8 }
    uint64 a5 = args_desc + 40;   unsafe { *(a5 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a6 = args_desc + 48;   unsafe { *(a6 as uint64) = 8 }
    uint64 a7 = args_desc + 56;   unsafe { *(a7 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a8 = args_desc + 64;   unsafe { *(a8 as uint64) = 8 }
    uint64 a9 = args_desc + 72;   unsafe { *(a9 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a10 = args_desc + 80;  unsafe { *(a10 as uint64) = 8 }
    uint64 a11 = args_desc + 88;  unsafe { *(a11 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a12 = args_desc + 96;  unsafe { *(a12 as uint64) = 8 }
    uint64 a13 = args_desc + 104; unsafe { *(a13 as uint64) = AMD_ARG_KIND_BY_VALUE }
    uint64 a14 = args_desc + 112; unsafe { *(a14 as uint64) = 8 }
    uint64 a15 = args_desc + 120; unsafe { *(a15 as uint64) = AMD_ARG_KIND_BY_VALUE }
}

// Slice 2c — fused qknorm + rope_qk code-object emit.
// Block size at launch = 128, grid = nh_q + nh_k.  Kernarg layout is
// 8 args (6 buffer ptrs + 2 by-value uint64) = 64 bytes.
@export
fn emit_amdgpu_qknorm_rope_qk_fused_f32_blob(uint64 out_path) -> uint64 {
    uint64[16] args_desc
    _emit_qknorm_rope_qk_fused_f32_body(args_desc)
    // rsrc1 = 0xE0AF0042 — same as slice 2b: 24 VGPR / 24 SGPR grant.
    // We use v0..v21 (22 VGPRs) and s0..s27 used + s14 saveexec
    // (28 SGPRs).  Bump to 32 SGPR grant by setting bits 6..7 to 0x2:
    // 0xE0AF0042 has bit6=1 (= 24-SGPR grant).  Need 32-SGPR: bits 6..7 = 0x2.
    // Encoding: rsrc1 SGPRS field = bits 6..9 of low word (bits 6:9).
    // Simpler: 0xE0AF0082 = 32 SGPRs / 24 VGPRs grant.
    uint64 rsrc1 = 0xE0AF0082
    // LDS bytes: 128 lanes × 4 bytes = 512 (rmsnorm reduce + rope staging
    // share the same slab — the staging ds_store overwrites the post-
    // reduce LDS contents which are dead by then).  Allocate 1024 to
    // leave headroom and match slice 2b's allocation precedent.
    uint64 lds_bytes = 1024
    uint64 size = emit_amdgpu_code_object_lds("qknorm_rope_qk_fused_f32", 24,
                                               asm_text_buf, asm_text_len,
                                               64, 8, 32, 22,
                                               rsrc1, 0x0000009E, 0x00000010, 0x0408,
                                               args_desc, 8,
                                               lds_bytes)
    uint64 fd = file_open(out_path, 1)
    if fd > 0xFFFFFFFFFFFFF000 {
        write(2, "emit_amdgpu_qknorm_rope_qk_fused_f32_blob: cannot open output\n", 62)
        return 1
    }
    file_write(fd, amd_buf, size)
    file_close(fd)
    return 0
}

// Thread-coarsened rmsnorm body for N > 1024. Block size is fixed at
// 1024 lanes (gfx11 max workgroup size); each lane processes K =
// ceil(N / 1024) elements across two passes (reduce + apply) over the
// row.  Last chunk's partial-coverage lanes use an identity-fill
// gated load (default 0) and the final store is gated to lane<remainder.
//
//   PASS 1: v5 = sum(x_chunk² for chunk in 0..K-1)
//   LDS pairwise tree at depth log2(1024) = 10
//   inv_rms = rsqrt(sum / N + eps)
//   PASS 2: for each chunk, out_chunk = x_chunk * inv_rms * gamma_chunk
//
// Re-loads x in PASS 2 instead of caching to keep VGPR pressure
// manageable.  Uses _emit_vpair_add_imm to bump in/out/gamma addrs by
// 4096 bytes between chunks.
fn _emit_rmsnorm_f32_body_NL(uint64 args_desc, uint64 N) {
    asm_init()
    uint64 K = (N + 1023) / 1024
    uint64 last_chunk_size = N - (K - 1) * 1024     // 1..1024
    uint64 last_partial = 0
    if last_chunk_size != 1024 { last_partial = 1 }
    uint64 inv_n_bits = _f32_bits_recip(N)

    // ── Prologue ────────────────────────────────────────────────────
    asm_u32(0xF40C0100)             // s_load_b256 s[4:11], s[0:1], 0x0
    asm_u32(0xF8000000)
    asm_u32(0xF4040300)             // s_load_b64  s[12:13], s[0:1], 0x20
    asm_u32(0xF8000020)
    asm_u32(0xBF89FC07)             // s_waitcnt
    asm_u32(0xBF090A0F)             // s_cmp_ge_u32 s15, s10
    uint64 cbranch_dword_idx = asm_text_len / 4
    asm_u32(0xBFA20000)             // s_cbranch_scc1 → .Lend (patched)
    asm_u32(0x960E0C0F)             // s_mul_i32 s14, s15, s12 (row * n)
    asm_u32(0x4A02000E)             // v_add_nc_u32 v1, s14, v0
    asm_u32(0x30080282)             // v_lshlrev_b32 v4, 2, v1  (chunk-0 byte off)
    // Build v[2:3] = in_ptr + v4
    asm_u32(0x7E060280)
    asm_u32(0xD7006A02); asm_u32(0x00020804)
    asm_u32(0xD5207C03); asm_u32(0x01AA0605)
    // Build v[12:13] = out_ptr + v4
    asm_u32(0x7E1A0280)
    asm_u32(0xD7006A0C); asm_u32(0x00020806)
    asm_u32(0xD5207C0D); asm_u32(0x01AA1A07)
    // Build v[16:17] = gamma_ptr + (lane*4).  v6 = lane*4, computed below.
    asm_u32(0x300C0082)             // v_lshlrev_b32 v6, 2, v0
    asm_u32(0x7E220280)             // v_mov_b32 v17, 0
    asm_u32(0xD7006A10); asm_u32(0x00020C08)   // v_add_co_u32 v16, vcc_lo, s8, v6
    asm_u32(0xD5207C11); asm_u32(0x01AA2209)   // v_add_co_ci_u32_e64 v17, null, s9, v17, vcc_lo
    // Initialise reduction accumulator v5 = 0.
    asm_u32(0x7E0A0280)             // v_mov_b32 v5, 0

    // ── PASS 1: accumulate sum(x²) across K chunks ──────────────────
    uint64 c = 0
    while c < K {
        if c > 0 {
            _emit_vpair_add_imm(2, 4096)   // v[2:3] += 4096
        }
        if c == K - 1 && last_partial != 0 {
            // Set s14 = last_chunk_size, then gated load with default 0.
            // _emit_gated_load_v10 expects an n-kernarg sgpr; we
            // synthesise one by writing last_chunk_size into s14.
            asm_u32(0xBE8E00FF); asm_u32(last_chunk_size)
            _emit_gated_load_v10(14, 14, 0x00000000)
            // ↑ mask_sgpr=14 reuses s14 (will overwrite the size, fine
            // since we don't need it after this gated load).
        } else {
            asm_u32(0xDC520000); asm_u32(0x0A7C0002)   // global_load v10
            asm_u32(0xBF8903F7)                         // s_waitcnt
        }
        // v_fmac_f32 v5, v10, v10  (v5 += v10*v10)
        asm_u32(0x560A150A)
        c = c + 1
    }

    // ── LDS reduction tree at block size 1024 ──────────────────────
    asm_u32(0x7E120280)             // v_mov_b32 v9, 0  (broadcast read addr)
    asm_u32(0xD8340000); asm_u32(0x00000506)   // ds_store v6, v5
    asm_u32(0xBF89FC07)
    asm_u32(0xBFBD0000)
    _emit_lds_reduce_pow2(1024, 0x060A0F05, 14)

    // ── Compute inv_rms ────────────────────────────────────────────
    asm_u32(0xD8D80000); asm_u32(0x08000009)   // ds_load v8, v9
    asm_u32(0xBF89FC07)
    asm_u32(0xBE8E00FF); asm_u32(inv_n_bits)   // s14 = 1/N
    asm_u32(0x1010100E)             // v_mul_f32 v8, s14, v8 (mean_sq)
    asm_u32(0xBE8E00FF); asm_u32(0x3727C5AC)   // s14 = eps
    asm_u32(0x0610100E)             // v_add_f32 v8, s14, v8
    asm_u32(0x7E105D08)             // v_rsq_f32 v8, v8 (inv_rms)

    // ── Rebuild v[2:3] and v[12:13] from v4 for PASS 2 ─────────────
    asm_u32(0x7E060280)
    asm_u32(0xD7006A02); asm_u32(0x00020804)
    asm_u32(0xD5207C03); asm_u32(0x01AA0605)
    asm_u32(0x7E1A0280)
    asm_u32(0xD7006A0C); asm_u32(0x00020806)
    asm_u32(0xD5207C0D); asm_u32(0x01AA1A07)
    // Rebuild v[16:17] (gamma addr) — bumped K-1 times in PASS 2 if K>1
    asm_u32(0x7E220280)
    asm_u32(0xD7006A10); asm_u32(0x00020C08)
    asm_u32(0xD5207C11); asm_u32(0x01AA2209)

    // ── PASS 2: store output ───────────────────────────────────────
    c = 0
    while c < K {
        if c > 0 {
            _emit_vpair_add_imm(2, 4096)
            _emit_vpair_add_imm(12, 4096)
            _emit_vpair_add_imm(16, 4096)
        }
        // Load x (gated for last partial chunk; default 0).
        if c == K - 1 && last_partial != 0 {
            asm_u32(0xBE8E00FF); asm_u32(last_chunk_size)
            _emit_gated_load_v10(14, 14, 0x00000000)
        } else {
            asm_u32(0xDC520000); asm_u32(0x0A7C0002)
            asm_u32(0xBF8903F7)
        }
        // Load gamma (always — page slack handles last-row OOB).
        asm_u32(0xDC520000); asm_u32(0x0B7C0010)   // global_load v11, v[16:17]
        asm_u32(0xBF8903F7)
        // v_mul_f32 v5, v10, v8 (x * inv_rms)
        asm_u32(0x100A110A)
        // v_mul_f32 v5, v5, v11 (* gamma)
        asm_u32(0x100A1705)
        // Store (gated for last partial chunk).
        if c == K - 1 && last_partial != 0 {
            asm_u32(0xBE8E00FF); asm_u32(last_chunk_size)
            _emit_store_gate(14, 14)
        }
        asm_u32(0xDC6A0000); asm_u32(0x007C050C)   // global_store v[12:13], v5
        if c == K - 1 && last_partial != 0 {
            // Restore exec for any subsequent waitcnt — actually we go
            // straight to s_endpgm after the loop, so exec restore is
            // unnecessary. But if not the last iteration this matters.
            // (Only the last chunk gates, and it's followed by endpgm.)
        }
        c = c + 1
    }

    asm_u32(0xBC7C0000)             // s_waitcnt_vscnt null, 0
    asm_u32(0xBFB00000)             // s_endpgm

    uint64 total_dwords = asm_text_len / 4
    uint64 simm16 = total_dwords - cbranch_dword_idx - 2
    asm_patch_u32(cbranch_dword_idx, 0xBFA20000 | (simm16 & 0xFFFF))

    uint64 a0 = args_desc + 0;   unsafe { *(a0 as uint64) = 8 }
    uint64 a1 = args_desc + 8;   unsafe { *(a1 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a2 = args_desc + 16;  unsafe { *(a2 as uint64) = 8 }
    uint64 a3 = args_desc + 24;  unsafe { *(a3 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a4 = args_desc + 32;  unsafe { *(a4 as uint64) = 8 }
    uint64 a5 = args_desc + 40;  unsafe { *(a5 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a6 = args_desc + 48;  unsafe { *(a6 as uint64) = 8 }
    uint64 a7 = args_desc + 56;  unsafe { *(a7 as uint64) = AMD_ARG_KIND_BY_VALUE }
    uint64 a8 = args_desc + 64;  unsafe { *(a8 as uint64) = 8 }
    uint64 a9 = args_desc + 72;  unsafe { *(a9 as uint64) = AMD_ARG_KIND_BY_VALUE }
}

// Like emit_amdgpu_rmsnorm_f32_N_blob but with caller-chosen eps bits
// (used by qknorm where Qwen3's eps is 1e-6 = 0x358637BD, vs the
// default 1e-5).
@export
fn emit_amdgpu_rmsnorm_f32_N_eps_blob(uint64 out_path, uint64 N, uint64 eps_bits) -> uint64 {
    if N < 32 || N > 1024 {
        write(2, "emit_amdgpu_rmsnorm_f32_N_eps_blob: N must be in [32, 1024]\n", 60)
        return 1
    }
    uint64[10] args_desc
    _emit_rmsnorm_f32_body_N_eps(args_desc, N, eps_bits)
    uint64 Np = _round_up_pow2(N)
    uint64 lds_bytes = Np * 4
    uint64 size = emit_amdgpu_code_object_lds("rmsnorm_f32", 11,
                                               asm_text_buf, asm_text_len,
                                               40, 8, 16, 18,
                                               0xE0AF0001, 0x0000009E, 0x00000010, 0x0408,
                                               args_desc, 5,
                                               lds_bytes)
    uint64 fd = file_open(out_path, 1)
    if fd > 0xFFFFFFFFFFFFF000 {
        write(2, "emit_amdgpu_rmsnorm_f32_N_eps_blob: cannot open output\n", 56)
        return 1
    }
    file_write(fd, amd_buf, size)
    file_close(fd)
    return 0
}

@export
fn emit_amdgpu_rmsnorm_f32_N_blob(uint64 out_path, uint64 N) -> uint64 {
    if N < 32 || N > 8192 {
        write(2, "emit_amdgpu_rmsnorm_f32_N_blob: N must be in [32, 8192]\n", 56)
        return 1
    }
    uint64[10] args_desc
    uint64 lds_bytes = 0
    if N <= 1024 {
        // Small-N path: single-pass, block = round_up_pow2(N).
        _emit_rmsnorm_f32_body_N(args_desc, N)
        uint64 Np = _round_up_pow2(N)
        lds_bytes = Np * 4
    } else {
        // Large-N path: thread-coarsening, block = 1024 fixed.
        _emit_rmsnorm_f32_body_NL(args_desc, N)
        lds_bytes = 4096
    }
    // VGPR count: small-N path uses ≤16, large-N path uses ≤24 (v17
    // for the gamma addr hi).  Use rsrc1 byte 0 = 0x02 (24 VGPRs)
    // unconditionally to cover both; small-N occupancy hit is minor.
    uint64 rsrc1 = 0xE0AF0001
    if N > 1024 { rsrc1 = 0xE0AF0002 }
    uint64 size = emit_amdgpu_code_object_lds("rmsnorm_f32", 11,
                                               asm_text_buf, asm_text_len,
                                               40, 8, 16, 18,
                                               rsrc1, 0x0000009E, 0x00000010, 0x0408,
                                               args_desc, 5,
                                               lds_bytes)
    uint64 fd = file_open(out_path, 1)
    if fd > 0xFFFFFFFFFFFFF000 {
        write(2, "emit_amdgpu_rmsnorm_f32_N_blob: cannot open output\n", 52)
        return 1
    }
    file_write(fd, amd_buf, size)
    file_close(fd)
    return 0
}

// Slice 2b — fused residual_add + rmsnorm code-object emit.
// Block size at launch must be Np = round_up_pow2(N), grid = M.
// Kernarg layout: 7 args (in_a, in_b, out_resid, out_norm, gamma, m, n).
// rsrc1 sgprs field bumped to 0x40 for the extended SGPR window
// (s4..s19) needed by the residual prologue's in_b / out_resid.
fn emit_amdgpu_residual_rmsnorm_f32_N_blob(uint64 out_path, uint64 N) -> uint64 {
    if N < 32 || N > 1024 {
        write(2, "emit_amdgpu_residual_rmsnorm_f32_N_blob: N must be in [32, 1024]\n", 65)
        return 1
    }
    uint64[14] args_desc
    _emit_residual_rmsnorm_f32_body_N_eps(args_desc, N, 0x3727C5AC)
    uint64 Np = _round_up_pow2(N)
    uint64 lds_bytes = Np * 4
    // 0xE0AF0042 = rsrc1 bumping both:
    //   bits 0-5 (VGPRS field) = 2 → 24-VGPR grant (rmsnorm used 16,
    //     fused kernel touches v0-v17 → needs >= 24)
    //   bit 6 (SGPRS LSB)      = 1 → 24-SGPR grant (rmsnorm used 16,
    //     fused kernel touches s4-s19 → needs >= 20)
    uint64 rsrc1 = 0xE0AF0042
    uint64 size = emit_amdgpu_code_object_lds("residual_rmsnorm_f32", 20,
                                               asm_text_buf, asm_text_len,
                                               56, 8, 24, 18,
                                               rsrc1, 0x0000009E, 0x00000010, 0x0408,
                                               args_desc, 7,
                                               lds_bytes)
    uint64 fd = file_open(out_path, 1)
    if fd > 0xFFFFFFFFFFFFF000 {
        write(2, "emit_amdgpu_residual_rmsnorm_f32_N_blob: cannot open output\n", 60)
        return 1
    }
    file_write(fd, amd_buf, size)
    file_close(fd)
    return 0
}

// silu_f32: emitted by Phase 3a-5 (`amdgpu_lower_silu_f32_3a`) from
// examples/llm/silu_f32.mlr.  Hand-emit body deleted — AST-walker
// produces byte-identical ISA.

// silu_mul_f32 single-stream: emitted by Phase 3a-3 (`amdgpu_lower_silu_mul_3a`)
// from examples/llm/silu_mul_f32.mlr.  Hand-emit body + blob deleted —
// the AST-walker produces byte-identical ISA.

// Batched silu_mul: grid (n/256, batch).  Hardcoded Qwen3 strides:
//   in_gate / in_up batch stride = 2 * ff * 4 = 24576 (= 0x6000)
//   out batch stride             = ff * 4    = 12288 (= 0x3000)
// Neither is a power of 2 (3 * 4096), so we use s_mul_i32 with a 32-bit
// literal SSRC1 instead of s_lshl_b32.
fn _emit_silu_mul_f32_batched_body(uint64 args_desc) {
    asm_init()
    asm_u32_arch(0xF40C0100, 0xF40C0100); asm_u32_arch(0xF8000000, 0xFA000000)
    asm_u32_arch(0xBF89FC07, 0xBF8CC07F)
    // s14 = wg_y * 0x6000 (gate/up batch stride)
    asm_u32_arch(0x960EFF10, 0x930EFF10); asm_u32(0x00006000) // s_mul_i32 s14, s16, 0x6000
    asm_u32     (0x80040E04)
    asm_u32     (0x82058005)
    asm_u32     (0x80060E06)
    asm_u32     (0x82078007)
    // s17 = wg_y * 0x3000 (out batch stride)
    asm_u32_arch(0x9611FF10, 0x9311FF10); asm_u32(0x00003000) // s_mul_i32 s17, s16, 0x3000
    asm_u32     (0x80081108)
    asm_u32     (0x82098009)

    // Body identical to Phase 3a-3 silu_mul template.
    asm_u32_arch(0x840C880F, 0x8F0C880F) // s_lshl_b32 s12, s15, 8
    asm_u32     (0x4A02000C)             // v_add_nc_u32 v1, s12, v0
    asm_u32_arch(0x7C98020A, 0x7D88020A) // v_cmp_gt_u32 vcc_lo, s10, v1
    asm_u32_arch(0xBE8D206A, 0xBE8D3C6A) // s_and_saveexec_b32 s13, vcc_lo
    asm_u32_arch(0xBFA50021, 0xBF880021) // s_cbranch_execz +33
    asm_u32_arch(0x30100282, 0x34100282) // v_lshlrev_b32 v8, 2, v1
    asm_u32     (0x7E060280)
    asm_u32_arch(0xD7006A02, 0xD70F6A02); asm_u32(0x00021004)
    asm_u32_arch(0xD5207C03, 0xD5287D03); asm_u32(0x01AA0605)
    asm_u32     (0x7E0A0280)
    asm_u32_arch(0xD7006A04, 0xD70F6A04); asm_u32(0x00021006)
    asm_u32_arch(0xD5207C05, 0xD5287D05); asm_u32(0x01AA0A07)
    asm_u32     (0x7E0E0280)
    asm_u32_arch(0xD7006A06, 0xD70F6A06); asm_u32(0x00021008)
    asm_u32_arch(0xD5207C07, 0xD5287D07); asm_u32(0x01AA0E09)
    asm_u32_arch(0xDC520000, 0xDC308000); asm_u32_arch(0x097C0002, 0x097D0002)
    asm_u32_arch(0xDC520000, 0xDC308000); asm_u32_arch(0x0A7C0004, 0x0A7D0004)
    asm_u32_arch(0xBF8903F7, 0xBF8C3F70)
    asm_u32_arch(0xBE8C00FF, 0xBE8C03FF); asm_u32(0x3FB8AA3B) // s_mov_b32 s12, log2(e)
    asm_u32     (0xD508000B); asm_u32_arch(0x20001909, 0x00001909) // v_mul_f32_e64 (omod-bit gfx11)
    asm_u32     (0x7E164B0B)
    asm_u32     (0x061616F2)
    asm_u32     (0x7E16550B)
    asm_u32     (0x10121709)
    asm_u32     (0x10121509)
    asm_u32_arch(0xDC6A0000, 0xDC708000); asm_u32_arch(0x007C0906, 0x007D0906)
    asm_u32_arch(0xBC7C0000, 0xBBFD0000)
    asm_u32_arch(0xBFB00000, 0xBF810000)

    uint64 a0 = args_desc + 0;   unsafe { *(a0 as uint64) = 8 }
    uint64 a1 = args_desc + 8;   unsafe { *(a1 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a2 = args_desc + 16;  unsafe { *(a2 as uint64) = 8 }
    uint64 a3 = args_desc + 24;  unsafe { *(a3 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a4 = args_desc + 32;  unsafe { *(a4 as uint64) = 8 }
    uint64 a5 = args_desc + 40;  unsafe { *(a5 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a6 = args_desc + 48;  unsafe { *(a6 as uint64) = 8 }
    uint64 a7 = args_desc + 56;  unsafe { *(a7 as uint64) = AMD_ARG_KIND_BY_VALUE }
}

@export
fn emit_amdgpu_silu_mul_f32_batched_blob(uint64 out_path) -> uint64 {
    uint64[8] args_desc
    _emit_silu_mul_f32_batched_body(args_desc)
    uint64 size = emit_amdgpu_code_object_lds("silu_mul_f32_batched", 20,
                                               asm_text_buf, asm_text_len,
                                               32, 8, 16, 12,
                                               0xE0AF0001, 0x0000019E, 0x00000010, 0x0408,
                                               args_desc, 4,
                                               0)
    uint64 fd = file_open(out_path, 1)
    if fd > 0xFFFFFFFFFFFFF000 { write(2, "silu_mul_batched blob fail\n", 27); return 1 }
    file_write(fd, amd_buf, size); file_close(fd); return 0
}

// amdgpu_lower_llm_silu_mul_f32 deleted — Phase 3a-3 owns this kernel now.

// LLM Phase 2 — rope_f32: GPT-NeoX/Qwen half-split rotary embedding.
// Per row i (token position), pair element j with j+64:
//   cos_p = cos[i*64 + j];  sin_p = sin[i*64 + j]
//   a = in[i*128 + j];      b = in[i*128 + j + 64]
//   out[i*128 + j]      = a*cos_p - b*sin_p
//   out[i*128 + j + 64] = a*sin_p + b*cos_p
// Block = 64 (one lane per pair), grid = M. D = 128 hardcoded.
// cos/sin tables precomputed by host (each [M, 64] f32).
//
// Kernarg layout (40 bytes, 5 args):
//   [0x00] uint64 in_ptr   (M × 128 f32)
//   [0x08] uint64 out_ptr  (M × 128 f32)
//   [0x10] uint64 cos_ptr  (M × 64 f32)
//   [0x18] uint64 sin_ptr  (M × 64 f32)
//   [0x20] uint64 m
//
// VGPRs: 17 active (v0..v16) — bumps rsrc1 byte 0 from 0x01 (≤16) to
// 0x02 (≤24) versus the layernorm/softmax/rmsnorm/silu/silu_mul pattern.

// Shape-parametric rope_f32. D = head_dim, must be power of two in
// [4, 2048] (block size = D/2 ≤ 1024 = gfx11 max).  Same 17-VGPR
// half-split rotation kernel as the hand-coded D=128 version, with
// four D-dependent dwords substituted at emit time:
//   - s_lshl_b32 s13, s15, log2(D)+2  — row * D * 4   (in/out stride)
//   - s_lshl_b32 s13, s15, log2(D)+1  — row * D/2 * 4 (cos/sin stride)
//   - global_load_b32 ... offset:D*2   — second-half x load
//   - global_store_b32 ... offset:D*2  — second-half out store
fn _emit_rope_f32_body_D(uint64 args_desc, uint64 D) {
    asm_init()
    uint64 logD = _ilog2_pow2(D)        // pow2-only
    uint64 shift_full = logD + 2        // log2(D*4)
    uint64 shift_half = logD + 1        // log2(D*2)
    uint64 half_off   = D * 2           // D/2 * 4

    asm_u32(0xF40C0100); asm_u32(0xF8000000)
    asm_u32(0xF4000300); asm_u32(0xF8000020)
    asm_u32(0xBF89FC07)
    asm_u32(0xBF090C0F)
    asm_u32(0xBFA2002D)
    // s_lshl_b32 s13, s15, shift_full   (was 0x840D890F for shift=9 / D=128)
    //   byte 1 = (shift_full | 0x80)
    asm_u32(0x840D000F | (((shift_full | 0x80) & 0xFF) << 8))
    asm_u32(0x30020082)
    asm_u32(0x4A02020D)
    asm_u32(0x7E060280)
    asm_u32(0xD7006A02); asm_u32(0x00020204)
    asm_u32(0xD5207C03); asm_u32(0x01AA0605)
    asm_u32(0x7E0A0280)
    asm_u32(0xD7006A04); asm_u32(0x00020206)
    asm_u32(0xD5207C05); asm_u32(0x01AA0A07)
    // s_lshl_b32 s13, s15, shift_half   (was 0x840D880F for shift=8 / D=128)
    asm_u32(0x840D000F | (((shift_half | 0x80) & 0xFF) << 8))
    asm_u32(0x30200082)
    asm_u32(0x4A20200D)
    asm_u32(0x7E0E0280)
    asm_u32(0xD7006A06); asm_u32(0x00022008)
    asm_u32(0xD5207C07); asm_u32(0x01AA0E09)
    asm_u32(0x7E120280)
    asm_u32(0xD7006A08); asm_u32(0x0002200A)
    asm_u32(0xD5207C09); asm_u32(0x01AA120B)
    asm_u32(0xDC520000); asm_u32(0x0A7C0002)        // load a (first half)
    // global_load_b32 v11, v[2:3], off offset:half_off   (was 0xDC520100 for D=128)
    asm_u32(0xDC520000 | (half_off & 0xFFF))
    asm_u32(0x0B7C0002)
    asm_u32(0xDC520000); asm_u32(0x0C7C0006)        // cos
    asm_u32(0xDC520000); asm_u32(0x0D7C0008)        // sin
    asm_u32(0xBF8903F7)
    asm_u32(0x101C1B0B)
    asm_u32(0xD613000E)
    asm_u32(0x843A190A)
    asm_u32(0x101E1B0A)
    asm_u32(0x561E190B)
    asm_u32(0xDC6A0000); asm_u32(0x007C0E04)        // store first half
    // global_store_b32 v[4:5], v15, off offset:half_off
    asm_u32(0xDC6A0000 | (half_off & 0xFFF))
    asm_u32(0x007C0F04)
    asm_u32(0xBC7C0000)
    asm_u32(0xBFB00000)

    uint64 a0 = args_desc + 0;   unsafe { *(a0 as uint64) = 8 }
    uint64 a1 = args_desc + 8;   unsafe { *(a1 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a2 = args_desc + 16;  unsafe { *(a2 as uint64) = 8 }
    uint64 a3 = args_desc + 24;  unsafe { *(a3 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a4 = args_desc + 32;  unsafe { *(a4 as uint64) = 8 }
    uint64 a5 = args_desc + 40;  unsafe { *(a5 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a6 = args_desc + 48;  unsafe { *(a6 as uint64) = 8 }
    uint64 a7 = args_desc + 56;  unsafe { *(a7 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a8 = args_desc + 64;  unsafe { *(a8 as uint64) = 8 }
    uint64 a9 = args_desc + 72;  unsafe { *(a9 as uint64) = AMD_ARG_KIND_BY_VALUE }
}

@export
fn emit_amdgpu_rope_f32_D_blob(uint64 out_path, uint64 D) -> uint64 {
    if _ilog2_pow2(D) == 0xFF || D < 4 || D > 2048 {
        write(2, "emit_amdgpu_rope_f32_D_blob: D must be power of two in [4, 2048]\n", 65)
        return 1
    }
    uint64[10] args_desc
    _emit_rope_f32_body_D(args_desc, D)
    uint64 size = emit_amdgpu_code_object_lds("rope_f32", 8,
                                               asm_text_buf, asm_text_len,
                                               40, 8, 16, 17,
                                               0xE0AF0002, 0x0000009E, 0x00000010, 0x0408,
                                               args_desc, 5,
                                               0)
    uint64 fd = file_open(out_path, 1)
    if fd > 0xFFFFFFFFFFFFF000 {
        write(2, "emit_amdgpu_rope_f32_D_blob: cannot open output\n", 49)
        return 1
    }
    file_write(fd, amd_buf, size)
    file_close(fd)
    return 0
}

@export


// residual_add_f32: emitted by Phase 3a-2 (`amdgpu_lower_pointwise_2in_3a`)
// from examples/llm/residual_add_f32.mlr.  Hand-emit body deleted —
// the AST-walker produces byte-identical ISA.

// LLM Phase 2 — kv_broadcast_f32: GQA K/V materialised broadcast.
// Hardcoded shape: num_heads=32, num_kv_heads=8, group_size=4,
// head_dim=128 (Llama 3 8B / Qwen3-7B-with-pow2-config layout).
// Each output element (m, h, d) reads from K[m, h>>2, d].  All
// pow2 → all index extractions are shifts; non-pow2 group_size
// (Qwen3 family: 5/6/7) needs multiply-by-reciprocal magic-number
// division — deferred to a follow-up slice.
//
// Block = 128 (head_dim, one lane per element).
// Grid = M * 32 (one workgroup per (m, h)).
// Kernarg layout (16 bytes, 2 args):
//   [0x00] uint64 in_ptr   (M × 8 × 128 f32)
//   [0x08] uint64 out_ptr  (M × 32 × 128 f32)
fn _emit_kv_broadcast_f32_body(uint64 args_desc) {
    asm_init()
    asm_u32(0xF4080100)
    asm_u32(0xF8000000)
    asm_u32(0xBF89FC07)
    asm_u32(0x8508850F)
    asm_u32(0x8B099F0F)
    asm_u32(0x850A8209)
    asm_u32(0x840B8C08)
    asm_u32(0x840C890A)
    asm_u32(0x800B0C0B)
    asm_u32(0x840D890F)
    asm_u32(0x30020082)
    asm_u32(0x7E060280)
    asm_u32(0xD7006A02)
    asm_u32(0x0002020B)
    asm_u32(0xD5207C03)
    asm_u32(0x01AA0680)
    asm_u32(0xD7006A02)
    asm_u32(0x00020404)
    asm_u32(0xD5207C03)
    asm_u32(0x01AA0605)
    asm_u32(0x7E0A0280)
    asm_u32(0xD7006A04)
    asm_u32(0x0002020D)
    asm_u32(0xD5207C05)
    asm_u32(0x01AA0A80)
    asm_u32(0xD7006A04)
    asm_u32(0x00020806)
    asm_u32(0xD5207C05)
    asm_u32(0x01AA0A07)
    asm_u32(0xDC520000)
    asm_u32(0x067C0002)
    asm_u32(0xBF8903F7)
    asm_u32(0xDC6A0000)
    asm_u32(0x007C0604)
    asm_u32(0xBC7C0000)
    asm_u32(0xBFB00000)

    uint64 a0 = args_desc + 0;   unsafe { *(a0 as uint64) = 8 }
    uint64 a1 = args_desc + 8;   unsafe { *(a1 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a2 = args_desc + 16;  unsafe { *(a2 as uint64) = 8 }
    uint64 a3 = args_desc + 24;  unsafe { *(a3 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
}

// LLM Phase 2 — embedding_lookup_f32: out[seq, d] = embed[token_ids[seq], d].
// One workgroup per sequence position; one lane per dim.  block = D
// (embed_dim), grid = seq_len.  D must be in [32, 1024] and a multiple
// of 32.  For D > 1024 we'd need thread-coarsening (each lane covers
// K = D/1024 dims) — open follow-up; covers Qwen3-0.6B (D=1024) but
// not Qwen3-1.5B (D=1536) or larger.
//
// Kernarg layout (32 bytes, 4 args):
//   [0x00] uint64 token_ids_ptr  (uint32[seq])  → s4,s5
//   [0x08] uint64 embed_ptr      (f32[V, D])    → s6,s7
//   [0x10] uint64 out_ptr        (f32[seq, D])  → s8,s9
//   [0x18] uint64 D              (low 32 used)  → s10
fn _emit_embedding_lookup_f32_body(uint64 args_desc) {
    asm_init()
    asm_u32(0xF40C0100); asm_u32(0xF8000000)        // s_load_b256 s[4:11], 0x00
    asm_u32(0xBF89FC07)                             // s_waitcnt lgkmcnt(0)
    asm_u32(0x840C820F)                             // s_lshl_b32 s12, s15, 2
    asm_u32(0x80020C04)                             // s_add_u32 s2, s4, s12
    asm_u32(0x82038005)                             // s_addc_u32 s3, s5, 0
    asm_u32(0xF4000301); asm_u32(0xF8000000)        // s_load_b32 s12, s[2:3], 0
    asm_u32(0xBF89FC07)                             // s_waitcnt lgkmcnt(0)
    asm_u32(0x840D8208)                             // s_lshl_b32 s13, s8, 2  (unused; harmless)
    asm_u32(0x840E820A)                             // s_lshl_b32 s14, s10, 2 (D*4)
    asm_u32(0x96100E0F)                             // s_mul_i32 s16, s15, s14   (out row offset)
    asm_u32(0x96110E0C)                             // s_mul_i32 s17, s12, s14   (in row offset = tok_id*D*4)
    asm_u32(0x30020082)                             // v_lshlrev_b32 v1, 2, v0
    asm_u32(0x7E060280)                             // v_mov_b32 v3, 0
    asm_u32(0xD7006A02); asm_u32(0x00020211)        // v_add_co_u32 v2, vcc_lo, s17, v1
    asm_u32(0xD5207C03); asm_u32(0x01AA0680)        // v_add_co_ci_u32 v3, null, 0, v3, vcc_lo
    asm_u32(0xD7006A02); asm_u32(0x00020406)        // v_add_co_u32 v2, vcc_lo, s6, v2
    asm_u32(0xD5207C03); asm_u32(0x01AA0607)        // v_add_co_ci_u32 v3, null, s7, v3, vcc_lo
    asm_u32(0x7E0A0280)                             // v_mov_b32 v5, 0
    asm_u32(0xD7006A04); asm_u32(0x00020210)        // v_add_co_u32 v4, vcc_lo, s16, v1
    asm_u32(0xD5207C05); asm_u32(0x01AA0A80)        // v_add_co_ci_u32 v5, null, 0, v5, vcc_lo
    asm_u32(0xD7006A04); asm_u32(0x00020808)        // v_add_co_u32 v4, vcc_lo, s8, v4
    asm_u32(0xD5207C05); asm_u32(0x01AA0A09)        // v_add_co_ci_u32 v5, null, s9, v5, vcc_lo
    asm_u32(0xDC520000); asm_u32(0x067C0002)        // global_load_b32 v6, v[2:3], off
    asm_u32(0xBF8903F7)                             // s_waitcnt vmcnt(0)
    asm_u32(0xDC6A0000); asm_u32(0x007C0604)        // global_store_b32 v[4:5], v6, off
    asm_u32(0xBC7C0000)                             // s_waitcnt_vscnt null, 0
    asm_u32(0xBFB00000)                             // s_endpgm

    uint64 a0 = args_desc + 0;   unsafe { *(a0 as uint64) = 8 }
    uint64 a1 = args_desc + 8;   unsafe { *(a1 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a2 = args_desc + 16;  unsafe { *(a2 as uint64) = 8 }
    uint64 a3 = args_desc + 24;  unsafe { *(a3 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a4 = args_desc + 32;  unsafe { *(a4 as uint64) = 8 }
    uint64 a5 = args_desc + 40;  unsafe { *(a5 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a6 = args_desc + 48;  unsafe { *(a6 as uint64) = 8 }
    uint64 a7 = args_desc + 56;  unsafe { *(a7 as uint64) = AMD_ARG_KIND_BY_VALUE }
}


