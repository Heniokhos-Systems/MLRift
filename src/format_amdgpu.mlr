    asm_u32(word2)
}

// v_mul_hi_u32 vdst, v_src0, s_src1
//   Verified: v_mul_hi_u32 v3, v0, s4 → 0xD72D0003 0x00000900.
fn asm_v_mul_hi_u32_vs(uint64 vdst, uint64 v_src0, uint64 s_src1) {
    uint64 word1 = 0xD72D0000 | (vdst & 0xFF)
    uint64 src0_enc = 0x100 | (v_src0 & 0xFF)
    uint64 src1_enc = s_src1 & 0x1FF
    uint64 word2 = ((src1_enc & 0x1FF) << 9) | (src0_enc & 0x1FF)
