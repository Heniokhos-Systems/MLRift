    asm_u32(word2)
}

// v_lshrrev_b64 v[dst:dst+1], <imm shift 0..63>, v[src:src+1]   (VOP3 op 0x13D)
//   word1 = 0xD73D0000 | (dst & 0xFF)
//   word2 = ((0x100|src_pair) << 9) | (0x80 + shift)
//   Verified: v_lshrrev_b64 v[2:3], 30, v[0:1] → 0xD73D0002 0x0002009E.
//             v_lshrrev_b64 v[2:3], 27, v[0:1] → 0xD73D0002 0x0002009B.
//             v_lshrrev_b64 v[2:3], 31, v[0:1] → 0xD73D0002 0x0002009F.
fn asm_v_lshrrev_b64_imm_vv(uint64 vdst_pair, uint64 shift_amount, uint64 v_src_pair) {
    uint64 word1 = 0xD73D0000 | (vdst_pair & 0xFF)
    uint64 src0_enc = 0x80 + (shift_amount & 0x3F)
    uint64 src1_enc = 0x100 | (v_src_pair & 0xFF)
    uint64 word2 = ((src1_enc & 0x1FF) << 9) | (src0_enc & 0x1FF)
    asm_u32(word1)
    asm_u32(word2)
}

