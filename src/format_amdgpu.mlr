// v_rsq_f32_e64 vdst, v_src   (VOP3 op 0x1AE; ~24-bit rsqrt)
//   Verified: v_rsq_f32_e64 v0, v2 → 0xD5AE0000 0x00000102.
fn asm_v_rsq_f32_e64_v(uint64 vdst, uint64 v_src) {
    uint64 word1 = 0xD5AE0000 | (vdst & 0xFF)
    uint64 src0_enc = 0x100 | (v_src & 0xFF)
