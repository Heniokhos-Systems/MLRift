    if body == 0 { return 1 }
    if ast_kind(body) != 15 { return 1 }

    uint64 saw_marker = 0
    uint32 walk = ast_child(body)
    while walk != 0 {
        if ast_kind(walk) == 35 {
            uint32 callee = ast_data1(walk)
            if tok_matches(callee, "softmax_N128_marker", 19) != 0 { saw_marker = 1 }
        }
        if ast_kind(walk) == 10 {
            uint32 init = ast_child(walk)
            if init != 0 && ast_kind(init) == 35 {
                uint32 callee = ast_data1(init)
                if tok_matches(callee, "softmax_N128_marker", 19) != 0 { saw_marker = 1 }
            }
        }
        walk = ast_next(walk)
    }
    if saw_marker == 0 { return 1 }

    uint64 args_desc = alloc(8 * 16)
    _emit_softmax_f32_body_N(args_desc, 128)

    uint64 k_text_size = asm_text_len
    uint64 k_text_buf  = alloc(k_text_size)
    uint64 ci = 0
    while ci < k_text_size {
        uint64 sp = asm_text_buf + ci
        uint64 b = 0
        unsafe { *(sp as uint8) -> b }
        uint64 dp = k_text_buf + ci
        uint8 b8 = b
        unsafe { *(dp as uint8) = b8 }
        ci = ci + 1
    }

    uint64 rsrc1 = 0xE0AF0001
    uint64 rsrc2 = 0x0000009E
    uint64 rsrc3 = 0x00000010
    uint64 props = 0x0408

    kt_push_lds(kname_ptr, nl, k_text_buf, k_text_size,
                args_desc, 4, 32,
                16, 20,
                rsrc1, rsrc2, rsrc3, props,
                512)
    return 0
}

// Phase 3b-2 — softmax_f32 (max + sum LDS reductions, hardcoded N=256).
//
// Recognises a kernel of the form:
//
//   @kernel fn name(uint64 in_ptr, uint64 out_ptr, uint64 m, uint64 n) {
//       uint64 row  = block_idx_x()
//       uint64 lane = tid_local_x()
//       if row < m {
//           ...
//           f32 max_x  = lds_reduce_max_f32(x)
//           f32 sum_ex = lds_reduce_sum_f32(exp_f32(x - max_x))
//           ...
//       }
//   }
//
// Loose body validation: requires both reduce-max and reduce-sum
// composer calls; the canonical 230-dword ISA is hardcoded N=256.
//
// Returns 0 on success; non-zero means "doesn't match the 3b-2 shape".
fn amdgpu_lower_softmax_f32_3b(uint64 fn_node, uint64 source,
                                uint64 kname_ptr, uint64 nl) -> uint64 {
    // ── shape: 4 params (in, out, m, n) ─────────────────────────
    uint64 n_params = 0
    uint64 wp = ast_child(fn_node)
    while wp != 0 {
        n_params = n_params + 1
        wp = ast_next(wp)
    }
    if n_params != 4 { return 1 }

    // ── shape: body Block has 3 top-level stmts (row, lane, If) ──
    uint32 body = ast_data3(fn_node)
    if body == 0 { return 1 }
    if ast_kind(body) != 15 { return 1 }
    uint32 stmt0 = ast_child(body)
    if stmt0 == 0 || ast_kind(stmt0) != 10 { return 1 }
    uint32 stmt1 = ast_next(stmt0)
    if stmt1 == 0 || ast_kind(stmt1) != 10 { return 1 }
    uint32 stmt2 = ast_next(stmt1)
    if stmt2 == 0 || ast_kind(stmt2) != 13 { return 1 }
    if ast_next(stmt2) != 0 { return 1 }

    // ── if-then-block must contain Calls to lds_reduce_max_f32 and
    //    lds_reduce_sum_f32 (both reductions for stable softmax). ──
    uint32 then_block = ast_data1(stmt2)
    if then_block == 0 || ast_kind(then_block) != 15 { return 1 }
    uint64 saw_max = 0
    uint64 saw_sum = 0
    uint32 walk = ast_child(then_block)
    while walk != 0 {
        if ast_kind(walk) == 10 {
            uint32 init = ast_child(walk)
            if init != 0 && ast_kind(init) == 35 {
                uint32 callee = ast_data1(init)
                if tok_matches(callee, "lds_reduce_max_f32", 18) != 0 { saw_max = 1 }
                if tok_matches(callee, "lds_reduce_sum_f32", 18) != 0 { saw_sum = 1 }
            }
        }
        walk = ast_next(walk)
    }
    if saw_max == 0 { return 1 }
    if saw_sum == 0 { return 1 }

    // ── emit ISA via parametric helper at N=256 ──────────────────
    // Same path as the parametric softmax_f32_N128 lowerer; single
    // source of truth, target-arch-aware.
    uint64 args_desc = alloc(8 * 16)
    _emit_softmax_f32_body_N(args_desc, 256)

    uint64 k_text_size = asm_text_len
    uint64 k_text_buf  = alloc(k_text_size)
    uint64 ci = 0
    while ci < k_text_size {
        uint64 sp = asm_text_buf + ci
        uint64 b = 0
        unsafe { *(sp as uint8) -> b }
        uint64 dp = k_text_buf + ci
        uint8 b8 = b
        unsafe { *(dp as uint8) = b8 }
        ci = ci + 1
    }

    // KD identical to legacy hand-tuned softmax_f32: 16 SGPRs / 14 VGPRs,
    // USER_SGPR_COUNT=15, LDS=1024, rsrc1=0xE0AF0001.
    uint64 rsrc1 = 0xE0AF0001
    uint64 rsrc2 = 0x0000009E
    uint64 rsrc3 = 0x00000010
    uint64 props = 0x0408

    kt_push_lds(kname_ptr, nl, k_text_buf, k_text_size,
                args_desc, 4, 32,
                16, 14,
                rsrc1, rsrc2, rsrc3, props,
                1024)
    return 0
}

// Phase 3b-3-N128 — layernorm_f32 parametric N=128.
fn amdgpu_lower_layernorm_f32_N128_3b(uint64 fn_node, uint64 source,
