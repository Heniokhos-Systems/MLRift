// LLM Phase 2 — transpose_f32: out[N, M] = transpose(in[M, N]).
// 16×16 LDS-tile transpose to keep VMEM coalesced in both directions.
// One workgroup per (tile_m, tile_n); 256 lanes per WG, 1 f32 per lane.
// LDS uses +1 stride padding (17×16) to avoid bank conflicts on read.
//
// Grid: ((M+15)/16) × ((N+15)/16) workgroups in 1-D grid_x; the kernel
// divides wg_id_x by num_tiles_n internally to recover (tile_m, tile_n).
//
// Kernarg layout (32 bytes, 4 args):
//   [0x00] uint64 in_ptr   (f32[M, N])  → s4,s5
//   [0x08] uint64 out_ptr  (f32[N, M])  → s6,s7
//   [0x10] uint64 M                     → s8 (low 32 used)
//   [0x18] uint64 N                     → s10 (low 32 used)
fn _emit_transpose_f32_body(uint64 args_desc) {
    asm_init()
    asm_u32(0xF40C0100)
    asm_u32(0xF8000000)
    asm_u32(0xBF89FC07)
    asm_u32(0x800C8F0A)
    asm_u32(0x850C840C)
    asm_u32(0xBE8D000F)
    asm_u32(0xBE8E0080)
    asm_u32(0xBF0A0C0D)
    asm_u32(0xBFA20003)
    asm_u32(0x808D0C0D)
    asm_u32(0x800E810E)
    asm_u32(0xBFA0FFFB)
    asm_u32(0x32020084)
    asm_u32(0x3604008F)
    asm_u32(0x8410840E)
    asm_u32(0x8411840D)
    asm_u32(0x4A060210)
    asm_u32(0x4A080411)
    asm_u32(0xBE92007E)
    asm_u32(0x7C980608)
    asm_u32(0x8B7E6A7E)
    asm_u32(0x7C98080A)
    asm_u32(0x8B7E6A7E)
    asm_u32(0xD72C0005)
    asm_u32(0x00001503)
    asm_u32(0x4A0A0905)
    asm_u32(0x300A0A82)
    asm_u32(0x7E0C0280)
    asm_u32(0xD7006A05)
    asm_u32(0x00020A04)
    asm_u32(0xD5207C06)
    asm_u32(0x01AA0C05)
    asm_u32(0xDC520000)
    asm_u32(0x077C0005)
    asm_u32(0xBF8903F7)
    asm_u32(0x30100482)
    asm_u32(0xD72C0009)
    asm_u32(0x0001FF01)
    asm_u32(0x00000044)
    asm_u32(0x4A101308)
    asm_u32(0xD8340000)
    asm_u32(0x00000708)
    asm_u32(0xBEFE0012)
    asm_u32(0xBF89FC07)
    asm_u32(0xBFBD0000)
    asm_u32(0x30100282)
    asm_u32(0xD72C0009)
    asm_u32(0x0001FF02)
    asm_u32(0x00000044)
    asm_u32(0x4A101308)
    asm_u32(0xD8D80000)
    asm_u32(0x07000008)
    asm_u32(0xBF89FC07)
    asm_u32(0x4A060211)
    asm_u32(0x4A080410)
    asm_u32(0xBE92007E)
    asm_u32(0x7C98060A)
    asm_u32(0x8B7E6A7E)
    asm_u32(0x7C980808)
    asm_u32(0x8B7E6A7E)
    asm_u32(0xD72C0005)
    asm_u32(0x00001103)
    asm_u32(0x4A0A0905)
    asm_u32(0x300A0A82)
    asm_u32(0x7E0C0280)
    asm_u32(0xD7006A05)
    asm_u32(0x00020A06)
    asm_u32(0xD5207C06)
    asm_u32(0x01AA0C07)
    asm_u32(0xDC6A0000)
    asm_u32(0x007C0705)
    asm_u32(0xBC7C0000)
    asm_u32(0xBFB00000)

    uint64 a0 = args_desc + 0;   unsafe { *(a0 as uint64) = 8 }
    uint64 a1 = args_desc + 8;   unsafe { *(a1 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a2 = args_desc + 16;  unsafe { *(a2 as uint64) = 8 }
    uint64 a3 = args_desc + 24;  unsafe { *(a3 as uint64) = AMD_ARG_KIND_GLOBAL_BUFFER }
    uint64 a4 = args_desc + 32;  unsafe { *(a4 as uint64) = 8 }
    uint64 a5 = args_desc + 40;  unsafe { *(a5 as uint64) = AMD_ARG_KIND_BY_VALUE }
    uint64 a6 = args_desc + 48;  unsafe { *(a6 as uint64) = 8 }
    uint64 a7 = args_desc + 56;  unsafe { *(a7 as uint64) = AMD_ARG_KIND_BY_VALUE }
}

// amdgpu_lower_transpose_f32 — name-dispatch lowerer for transpose_f32.
// Called by amdgpu_lower_kernel_to_table when the kernel name matches
// "transpose_f32".  Emits the pre-validated LDS-tile ISA bytes via
// _emit_transpose_f32_body and pushes a kt entry with the correct
// LDS size (1088 = 17×16×4 with +1 stride padding).
fn amdgpu_lower_transpose_f32(uint64 kname_ptr, uint64 nl) -> uint64 {
    uint64[8] args_desc
    _emit_transpose_f32_body(args_desc)

    uint64 k_text_size = asm_text_len
    uint64 k_text_buf  = alloc(k_text_size)
    uint64 ci = 0
    while ci < k_text_size {
        uint64 sp = asm_text_buf + ci
        uint64 b = 0
        unsafe { *(sp as uint8) -> b }
        uint64 dp = k_text_buf + ci
        uint8 b8 = b
        unsafe { *(dp as uint8) = b8 }
        ci = ci + 1
    }

    // Kernel descriptor params from the validated blob emit:
    //   kernarg_size=32 (4 args × 8 bytes), sgpr_count=24, vgpr_count=10
    //   LDS=1088 (17×16×4 bytes — +1 stride padding avoids bank conflicts)
    uint64 rsrc1 = 0xE0AF0001
    uint64 rsrc2 = 0x0000009E
    uint64 rsrc3 = 0x00000010
    uint64 props = 0x0408
    kt_push_lds(kname_ptr, nl, k_text_buf, k_text_size,
                args_desc, 4, 32,
                24, 10,
                rsrc1, rsrc2, rsrc3, props,
                1088)
    return 0
}

@export
fn emit_amdgpu_transpose_f32_blob(uint64 out_path) -> uint64 {
    uint64[8] args_desc
    _emit_transpose_f32_body(args_desc)
    // group_segment_size = 1088 bytes (17 × 16 × 4 LDS tile with +1 padding).
    uint64 size = emit_amdgpu_code_object_lds("transpose_f32", 13,
                                               asm_text_buf, asm_text_len,
                                               32, 8, 24, 10,
                                               0xE0AF0001, 0x0000009E, 0x00000010, 0x0408,
                                               args_desc, 4,
                                               1088)
    uint64 fd = file_open(out_path, 1)
    if fd > 0xFFFFFFFFFFFFF000 {
        write(2, "emit_amdgpu_transpose_f32_blob: cannot open output\n", 51)
        return 1
    }
    file_write(fd, amd_buf, size)
    file_close(fd)
    return 0
}
@export
fn emit_amdgpu_embedding_lookup_f32_blob(uint64 out_path) -> uint64 {
    uint64[8] args_desc
    _emit_embedding_lookup_f32_body(args_desc)
    uint64 size = emit_amdgpu_code_object_lds("embedding_lookup_f32", 20,
                                               asm_text_buf, asm_text_len,
                                               32, 8, 18, 7,
                                               0xE0AF0001, 0x0000009E, 0x00000010, 0x0408,
                                               args_desc, 4,
                                               0)
    uint64 fd = file_open(out_path, 1)
    if fd > 0xFFFFFFFFFFFFF000 {
        write(2, "emit_amdgpu_embedding_lookup_f32_blob: cannot open output\n", 58)
        return 1
    }
    file_write(fd, amd_buf, size)
    file_close(fd)
    return 0
}


// LLM Phase 2 — argmax_logits_f32: out[seq] = argmax_v(logits[seq, V]).
// One workgroup per row, single wave32 (block=32).  Each lane scans a
// strided slice of V; lane 0 then collects per-lane (best_val, best_idx)
// via 31× v_readlane and emits the row-global argmax.  No LDS, no
// s_barrier.  Sufficient for batch-of-1 generation; for V≥1M or
// batch≫1, a 256-way LDS reduction would be more efficient.
//
// Kernarg layout (32 bytes, 4 args):
//   [0x00] uint64 logits_ptr  (f32[seq, V])  → s4,s5
//   [0x08] uint64 out_ptr     (uint32[seq])  → s6,s7
